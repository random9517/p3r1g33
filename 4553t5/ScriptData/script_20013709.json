{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0136" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「やれやれ……妙に小賢しい罠だらけでしたが、それもいい加減ネタ切れのよ\nうですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090022630001" ]},
		{"command":[ "SETCHARA", "0", "char_00000510_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「残った扉はあと一つ……さて、何が待っていますか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090022630002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「む……この部屋は……っ……今までにない濃密な気配を感じます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090022630003" ]},
		{"command":[ "SETCHARA", "0", "char_00000510_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「これは、いよいよ……求めていたものが近くにあるかもしれませんね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090022630004" ]},
		{"command":[ "SETCHARA", "0", "char_00000510_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「さて……中心にある棺のようなもの……ここが、この気配の発生源のようで\nすね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090022630005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「何にせよ、今のうちに中身を改めさせてもらいましょうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090022630006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そうはいかんぞっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022630001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「む……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090022630007" ]},
		{"command":[ "SETCHARA", "0", "char_00000510_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁっ、ぜはぁっ……なんとか……追いついたみたい、だなっ……\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「結局、足止めは効きませんでしたか。しかし、随分とボロボロのようですが\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090022630008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はんっ、出てきたトラップにことごとく引っかかったからな！　それでもフ\nィジカルで突破したんだよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「到底、胸を張って言える台詞ではありませんな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022630001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「言っとくが、お前が踏んだトラップが一番多いんだからな？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「はて、そうでしたかなぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022630002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「足手まとい二人は黙っていろ。とにかく、貴様の思い通りにはさせんぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022630002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「ふん、ここまでついてきたことだけは褒めてやるですよ。ですが、少し遅す\nぎたようですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090022630009" ]},
		{"command":[ "SETCHARA", "0", "char_00000510_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「何だと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022630003" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「『古より伝わる伝統の鎧』……どうやら、ここに眠っているようですからね\n。ウチが、それを頂きます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090022630010" ]},
		{"command":[ "SETCHARA", "0", "char_00000510_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "声" ]},
		{"command":[ "SETTEXT", "「待っていたぞ。我を着用せしものよ……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「こ、この声は……あの入り口の時の……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「絶対にビキニアーマーじゃないとダメという異常なこだわりを持ったアレで\nすな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022630003" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "声" ]},
		{"command":[ "SETTEXT", "「数多の試練を乗り越えて、この場所までたどり着いた者は、既にその資格を\n満たしている。我を身につけるがよい」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「…………身につけるがよいって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090022630011" ]},
		{"command":[ "SETCHARA", "0", "char_00000510_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「まさかっ……このっ、更にアレなものを着ろというのですかっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090022630012" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "声" ]},
		{"command":[ "SETTEXT", "「我の姿は、身につける者によって、ある程度大きさを変えることが出来る。\n心配には及ばない」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「じゃ、じゃあ、もう少し隠す面積を大きく……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090022630013" ]},
		{"command":[ "SETCHARA", "0", "char_00000510_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "声" ]},
		{"command":[ "SETTEXT", "「体型に合わせた変化は出来るが、本質的な形を変えることは出来ぬ」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「……ぐぬっ！　な、何の解決にもならないです……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090022630014" ]},
		{"command":[ "SETCHARA", "0", "char_00000510_01", "2", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "声" ]},
		{"command":[ "SETTEXT", "「だが、誰にでも合わせられるのだ。極上の着心地を保証しよう。さあ、我を\n身につけるがいい」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「そ、そういう問題じゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090022630015" ]},
		{"command":[ "SETCHARA", "0", "char_00000510_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「隙ありっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「あっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090022630016" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ためらってるなら、頂くぜっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "声" ]},
		{"command":[ "SETTEXT", "「うむ。ここにたどり着いた者には等しく我を身につける資格を得たものであ\nる。さあ、遠慮なく我を着るがいい」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、俺が着たら、今以上に社会的に終わるから。より相応しいのは、こっ\nちだ、パスっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「でかしたぞ、下僕！　初めてまともな仕事をしたな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022630004" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "声" ]},
		{"command":[ "SETTEXT", "「今度こそ我を着る者か？　そろそろたらい回しは辛くなってきたのだが……\n」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「安心するがいい、伝統の鎧とやら。私がこれ以上ない位に、貴様を着こなし\nてやろう。たぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022630005" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うわ……迷いなく真っ裸に……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「あの思い切りの良さは、そうそう迷いなく出来るものではありませんな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022630004" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「くっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090022630017" ]},
		{"command":[ "SETCHARA", "0", "char_00000510_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「見せてもらうぞ、鎧の力……おぉぉぉぉぉぉーーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022630006" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0136" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「…………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022630007" ]},
		{"command":[ "SETCHARA", "0", "char_00000114_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おお、これが……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「待たせたな。これぞ、新生ルナテミス……ビキニアーマーモードだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022630008" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}