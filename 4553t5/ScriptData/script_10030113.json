{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0043" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「Ｍ．Ａ．Ｍ．Ａちゃん、こんばんは～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040114750001" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「あら、ディアナちゃん。ひとりでなんて珍しいじゃな～い？　お飲み物は？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114750001" ]},
		{"command":[ "SETCHARA", "0", "char_00021202_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「生絞りレモンサワーちゃんおねが～い。はぁ～……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040114750002" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「どうしたの？　なにかお悩みかしら～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114750002" ]},
		{"command":[ "SETCHARA", "0", "char_00021202_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「実はそうなのよ～。ディアナちゃん、このままでいいのかな～って、考えち\nゃって～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040114750003" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「あらあら。深刻そうねえ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114750003" ]},
		{"command":[ "SETCHARA", "0", "char_00021202_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「ディアナちゃん、女幹部になる前は地球防衛組織でまじめに働いてたのよね\n～それが、まあ……いろいろあって～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040114750004" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「ふむふむ～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114750004" ]},
		{"command":[ "SETCHARA", "0", "char_00021202_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「でもね？　女幹部になったこと自体は、そんなに悪くない選択だったかなぁ\n～って、思ってたのよ？　ついこないだまでは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040114750005" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「この間、なにかあったのね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114750005" ]},
		{"command":[ "SETCHARA", "0", "char_00021202_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「そう。ほら、次元管理統制局の……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040114750006" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「ああ！　レディ・ホープって人ね？　あの人ってやっぱり……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114750006" ]},
		{"command":[ "SETCHARA", "0", "char_00021202_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「別次元のディアナちゃん……っていうか、園子ちゃんだと思うのよね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040114750007" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「だってあの人、真面目な頃のディアナちゃんが『将来こうなりたい』って思\nってた、できる正義の幹部ちゃんそのまんまなんだもの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040114750008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「あー……なるほどねえ。それで、あなた自身の今の生活に、ついつい疑問を\n感じちゃった、っていうわけなのね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114750007" ]},
		{"command":[ "SETCHARA", "0", "char_00021202_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「そうなのよ……別に、いまから軌道修正しようと思ったって、できるわけも\nないんだけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040114750009" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「できるわよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114750008" ]},
		{"command":[ "SETCHARA", "0", "char_00021202_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「え！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040114750010" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「できる！　あなたならできるわ～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114750009" ]},
		{"command":[ "SETCHARA", "0", "char_00021202_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「そ、そうかしら～……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040114750011" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「ええ！　でもね、あなたが進むべき道は、レディ・ホープみたいな方向じゃ\nないわよ～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114750010" ]},
		{"command":[ "SETCHARA", "0", "char_00021202_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「え……？　どういうこと……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040114750012" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「実はね、Ｍ．Ａ．Ｍ．Ａ。あなたには才能があるって思ってたのよ。いい機\n会だから言っちゃうけど～！？　ディアナちゃん、このお店で働かない！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114750011" ]},
		{"command":[ "SETCHARA", "0", "char_00021202_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「そっちなのぉ～～っ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040114750013" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「そうよ！　あなたと私が組めば、きっとこのお店はもっともっと繁盛するわ\n～～！　ぜひあなたに『チーＭ．Ａ．Ｍ．Ａ』として働いてほしいのよぉ～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114750012" ]},
		{"command":[ "SETCHARA", "0", "char_00021202_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「いや、あの『チーＭ．Ａ．Ｍ．Ａ』って……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040114750014" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「いいと思うんだけど～？　ね！　どう～？　ディアナちゃ～ん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114750013" ]},
		{"command":[ "SETCHARA", "0", "char_00021202_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「えと……ディアナちゃん、やめとくわ。やっぱり真面目に、悪の女幹部続け\nる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040114750015" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「あらあら……残念。でももし、気が変わったら知らせてね～？　お替りいか\nが～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114750014" ]},
		{"command":[ "SETCHARA", "0", "char_00021202_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}