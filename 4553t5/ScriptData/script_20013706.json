{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0136" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「その声は……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022600001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「ようやく追いつくことが出来た。我々も助太刀しよう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010022600001" ]},
		{"command":[ "SETCHARA", "0", "char_00016703_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「イグニス……それに、ミラとルシオラも……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「やー、派手にやったみたいだねぇ。至るところで罠に引っかかった後があっ\nたから、追いかけるのは簡単だったよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_010022600001" ]},
		{"command":[ "SETCHARA", "0", "char_00017002_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「……ど、どうも……です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_010022600001" ]},
		{"command":[ "SETCHARA", "0", "char_00016902_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「えぇと、とりあえず、その格好は……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「ああ、以前にも特殊な任務の為にビキニアーマーを用意したことがあってな\n。今回はそれに着替えたという訳だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010022600002" ]},
		{"command":[ "SETCHARA", "0", "char_00016703_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「まぁ、ちょっと前だったから、どこにしまったかって探しちゃったけどね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_010022600002" ]},
		{"command":[ "SETCHARA", "0", "char_00017002_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「また使う機会があるとは思っていなかったが、こんなにもうってつけの任務\nがあるとはな。わからないものだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010022600003" ]},
		{"command":[ "SETCHARA", "0", "char_00016703_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「……あ、あの……出来れば……その、あまり見ないで頂けると……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_010022600002" ]},
		{"command":[ "SETCHARA", "0", "char_00016902_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「でも、例の声の人も絶賛だったよ。めちゃくちゃフレンドリーに通してくれ\nた」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_010022600003" ]},
		{"command":[ "SETCHARA", "0", "char_00017002_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なるほど……って、ビキニアーマーを着る必要がある特殊な任務？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「ち、違いますよ！？　熱帯とか酷暑の場所で必要になる任務用のアーマーで\n、貴方が想像するようなエッチな任務じゃありませんから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_010022600003" ]},
		{"command":[ "SETCHARA", "0", "char_00016902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「いや、誰もエッチな任務だなんて言ってないでしょ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_010022600004" ]},
		{"command":[ "SETCHARA", "0", "char_00017002_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「で、ですが、こんなエッチな格好をしていることは、ちゃんと説明しないと\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_010022600004" ]},
		{"command":[ "SETCHARA", "0", "char_00016902_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「間違っても、男性の方を誘惑するとかっ、いかがわしい場所に潜入するとか\nっ、そういうことではありませんからっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_010022600005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「とにかく好きでこんな露出度の高い格好をしている訳じゃないんですっ、分\nかりますかっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_010022600006" ]},
		{"command":[ "SETCHARA", "0", "char_00016902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「い、いや、うん、まぁ……わかるよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「そんな、憐れみの表情で言われても困るんですが！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_010022600007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「むぅ……私は、別にそこまで恥ずかしい姿とは思わないのだが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022600002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「あっ、いえっ、そのルナテミスさんのことを言っている訳ではっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_010022600008" ]},
		{"command":[ "SETCHARA", "0", "char_00016902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そ、そうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022600003" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「うぅ……と、とにかく……そういうことですから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_010022600009" ]},
		{"command":[ "SETCHARA", "0", "char_00016902_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「慣れれば、これはこれで動きやすくていいとは思うのだがな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010022600004" ]},
		{"command":[ "SETCHARA", "0", "char_00016703_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「イグニスくらい割り切れたらルシオラも苦労はないんだろうけどねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_010022600005" ]},
		{"command":[ "SETCHARA", "0", "char_00017002_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まぁ、なんだな……一応、ルシオラには恥ずかしいって自覚があるんだな…\n…」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人がついぞ忘れてしまった、まっとうな感覚ですな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022600001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「忘れてねぇよ！　くそっ……一刻も早くここから出て、俺も変態から脱却し\nねぇと……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人のは一際強烈ですからなぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022600002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「とにかく、我々が来たからには心配はいらない。目の前の障害も一気に吹き\n飛ばしてしまおう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010022600005" ]},
		{"command":[ "SETCHARA", "0", "char_00016703_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「うむ、戦力は整った。ビキニアーマー隊、皆、いくぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022600004" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「ビキニアーマー隊だけはやめて下さい！　その名前だけはっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_010022600010" ]},
		{"command":[ "SETCHARA", "0", "char_00016902_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「む……そうか？　では、ビキニ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022600005" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「ですから、ビキニはもういいですからっ！　敵に集中して下さいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_010022600011" ]},
		{"command":[ "SETCHARA", "0", "char_00016902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}