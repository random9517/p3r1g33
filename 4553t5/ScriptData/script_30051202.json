{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000512_02_02" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あぁう……恥ずかしいですぅ……こ、こんな格好しちゃうなんてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1204101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ずっとイタズラしたいって……思ってたのに、ウチの方がイタズラされる感\nじになっちゃいました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1204102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……んっ、全部……見えちゃってますか？　ウチのヌルヌルに\nなってるオマンコぉ……あぁう、お尻の穴までぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1204103" ]},
		{"command":[ "SETIMAGE", "0", "still_00000512_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「恥ずかしいです……恥ずかしいに決まってますぅ……でも、ウチは……ずっ\nと待ってたかもしれません……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1204104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「はい、貴方にイタズラして欲しいって……あっ、んんっ、はひっ、オマンコ\n……くちゅくちゅされてますぅっ……指ぃ……は、入るぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1204105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んんっ、気持ちいいです……あぁ、オマンコから、お汁も……どんどん溢れ\nて来ちゃいますぅ……んふぁぁ……あぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1204106" ]},
		{"command":[ "SETIMAGE", "0", "still_00000512_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、あぁ……ダメです。こんな焦らされ方ぁ……絶対我慢なんか\n出来るわけないですからぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1204107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「お尻……振りますっ、フリフリしますぅ……オチンチン入れてもらう為なら\n、ちゃんとおねだりしますからぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1204108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「お願いします……ウチの、発情しきった……恥ずかしいオマンコにぃ……貴\n方のオチンチン入れて……ハメて下さいです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1204109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ここ、ここですぅ……ヌルヌルのオマンコぉ……あぁ、先っぽでツンツンし\nないでぇ……意地悪しないで、ちゃんと入れて下さいぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1204110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んんっ、あっ、はっ、あぁぁぁぁっ、はぁぁぁぁぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1204111" ]},
		{"command":[ "SETIMAGE", "0", "still_00000512_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あぁ……これですっ、オチンチン……深いのっ、はひぃっ……入って……来\nますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1204112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「はぁぁんっ、ずっと待ってたから……一番深くまで簡単に入っちゃいました\nぁ……あぁ、すごく熱いです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1204113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んくぅ……ど、どうですか？　ウチのオマンコ……ユルユルだったりしませ\nんか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1204114" ]},
		{"command":[ "SETIMAGE", "0", "still_00000512_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ちゃんと、気持ちよく出来てるならいいですけど……んくぅっ、は、はひっ\n、ウチは……もう、すごく……気持ちいいです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1204115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「で、でも、出来たら……じゅくって、んんっ、オマンコの中……かき回して\n欲しいです……あっ、はぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1204116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「はひっ、あんっ、あぁっ……はいっ、これですっ、はひっ、あひんっ、ずぶ\nって深いのっ、届いてますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1204117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「そうです、ウチが欲しかったのはお菓子よりも……このオチンチンですぅ…\n…は、あっ、あふぁっ、あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1204118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「この太くて硬いオチンチンが……ウチの、中でズンズンする度にっ、あぁっ\n、お汁が……溢れてっ……オマンコ蕩けてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1204119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あんっ、はんっ、あぁっ、発情するですっ……ウチが、どれだけこれを待っ\nてたかぁ……あぁ、はんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1204120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「いつもと違う格好で……やらしくお尻振ってぇ……こんなの、本当はウチの\nキャラじゃないんです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1204121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「でもっ、少しでも喜んで貰えるならって……してるうちに、何となく……馴\n染んで来てぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1204122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あぁ……でも、いざ……エッチすると……い、いつも以上に……恥ずかしく\nて……それなのに、気持ちよくてっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1204123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「はぁぁっ、もっとして欲しいですっ、んぁんっ……もっと激しくぅっ、オマ\nンコ……パンパンしてっ、くらひゃいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1204124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んぁぁっ！　あひっ、はひぃっ！　あぁんっ、あぁぁっ、激しいれふぅっ！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1204125" ]},
		{"command":[ "SETIMAGE", "0", "still_00000512_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「オチンチンっ……こんな、じゅくじゅくされてぇっ……ひゃふっ、腰が……\n抜けっ、ちゃいますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1204126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あっ、はぁんっ、はいっ、オチンチンずぼずぼされてっ、オマンコっ……気\n持ちいいでひゅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1204127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あんっ、はぁっ、あぁっ……お汁……溢れて来るぅっ……ぽたぽた……垂れ\nちゃうのっ、は、恥ずかしいっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1204128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あぁんっ……はんっ、そんな、オマンコのお汁……お尻に塗っちゃダメです\nっ、あぁぅっ……また発情しちゃうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1204129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んふぁっ！　貴方も鼻息が……ふんふんってっ、ウチでそんなにサカってく\nれるですか？　あぁ……嬉しい……はひぁっ、んふぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1204130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あぁっ、興奮してくれるの……分かりますっ、あぁんっ、さっきよりパンパ\nンしてぇっ、ずぶって出し入れが速くなってぇっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1204131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「オチンチン……あっ、ビクビクしてっ……イキたいですかっ？　中出しした\nがってますかっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1204132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あんっ、はぁんっ、分かりますっ……いいですよっ、ウチの欲しがりオマン\nコは、いつでも準備出来てますからぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1204133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「はひぁっ、中にっ……下さいっ、このまま……オマンコの中っ……射精して\n下さいっ……あひぃっ、んくぅぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1204134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んぁぁぁぁぁっ！　出てまひゅっ……せぇえきっ……びゅくんって……あち\nゅいのっ……流れ込んできまひゅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1204135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000512_02_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ふぁぁぁ……ひゅご……んんっ、イク……イッてまひゅ……ウチのオマンコ\n……ずっときもひよくなったままれひゅぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1204136" ]},
		{"command":[ "SETIMAGE", "0", "still_00000512_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……んっ、オチンチン……まだヒクヒクして……ずっと出たまま\nみたいになってます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1204137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んふぁ……はぁ……あふぁ……あぁ……やっと、射精……落ち着いて来まし\nたです……んっ、あぁ……こぼれちゃう……精液……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1204138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「はふぁ……あぁ……ねっとりしてるです……これだけ出されたら……妊娠し\nちゃってるかもしれません……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1204139" ]},
		{"command":[ "SETIMAGE", "0", "still_00000512_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「でも、嬉しいです……ウチのオマンコ……それだけ良かったってことですか\nら……ね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1204140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んんっ……あ、待って……オチンチン……まだ抜いちゃ、いやです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1204201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「まだ、あなたが満足してないことをウチは知ってるです。絶対２回はしない\nと、物足りないんですよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1204202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「そんなことないですか？　とぼけやがるなです……て言うか、ウチが……ま\nだ満足しきってないのですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1204203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「さあ、分かったら、もっとオチンチン頑張るです。んひあっ！　あっ、あぁ\nっ、そうですっ……またオチンチンっ、動かすですぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1204204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ、んんっ……ほら、あっという間に……オチンチン元気に戻って\nます。やっぱり、満足してなかったですね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1204205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「分かりきってます。スケベな貴方のことはちゃんとお見通しです……ちゃん\nとオマンコでも、理解してますからっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1204206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「はんっ、あっ、あぁんっ……今度は、ウチも一緒にお尻……動かしてっ……\n貴方のオチンチン……満足させてやるですっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1204207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「今日のウチは魔女なのです……だから、オチンチンにもっとエッチになる魔\n法を掛けちゃいますから……んっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1204208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んふっ！　くぅんっ！　ほらっ……この締め付け……どうですか？　このヒ\nクヒクオマンコの動きにメロメロじゃないですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1204209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「か、可愛い？　きゅ、急に何を言うんですかっ……えっ、ま、魔法使いの格\n好が似合ってる……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1204210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「そんなのっ、さ、最初に言うことですっ！　何でっ……あっ、こ、こんなっ\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1204211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「激しくオチンチン……突かれてる時にっ、そんなこと言われたらっ、はっ、\nあっ、あぁんっ……はぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1204212" ]},
		{"command":[ "SETIMAGE", "0", "still_00000512_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「う、嬉しいですけどっ、あぅぅっ、また……おかしくなりますぅっ！　あぁ\nんっ、あひっ、はひんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1204213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あぁぅ……また、お尻……ナデナデしてるぅ……うぅっ、これじゃウチは…\n…愛玩動物みたいですっ……で、でもっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1204214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「はぁんっ、ナデナデされると……嬉しくなっちゃう……んっ、オチンチンで\nかき混ぜられてっ、いっぱい愛してくれてっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1204215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「くぅぅんっ……もっとして欲しいですぅっ、あぁっ、オチンチンがいいっ、\nまた止まらなくなってまひゅっ、ウチッ……またイキそうですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1204216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「はんっ、あっ、あぁっ、貴方も……ですかっ？　はいっ、分かりますっ……\nオマンコの中で、またビクビクし始めてますっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1204217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んっ、あぁっ、一緒っ……今度は一緒がいいですっ、貴方と一緒に最後まで\nイキたいっ、だから、もっとかき回してっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1204218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あっ、あぁっ、ひぁぁっ、はんっ、あんっ、あぁんっ……また射精……する\nですっ、ウチも……もう我慢出来ないですからぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1204219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「出して下さいっ……貴方の濃いのっ、またっ……好きなトコにっ……ビュル\nってしてですぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1204220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
