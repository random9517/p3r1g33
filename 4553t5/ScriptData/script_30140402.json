{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0098" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ふふ……さあ、待ちに待った幸せの時間がやってきましたよ……ふふ、どん\nどん脱がしちゃいましょうね～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0404101" ]},
		{"command":[ "SETCHARA", "0", "char_00001404_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「はい、そのままベッドの上に寝そべって下さい。私もすぐに参りますから…\n…んっしょ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0404102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ふふっ、上から失礼します。はーい、大丈夫ですよ……そのまま動かなくて\nも、私の方で準備をしちゃいますから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0404103" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00001404_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「まずは、これ……このローションをちょっと垂らして……ふふ、滑りやすく\nしちゃいます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0404104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「あら……もうオチンポ……どんどん大きくなって来ちゃいましたね……じゃ\nあ、ここにも塗り塗りして……んっ、ふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0404105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「このまま……ずっぽり……の前に……ふふ、ちょっと素股で……気持ち高め\nて行きましょうか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0404106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「んふっ、ほら……ローションがにゅるにゅるってして……んっ、オマンコの\n手前で……擦れていくの……気持ちいいでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0404107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……太ももがしっかりオチンポをロックしてますから……中に入\nれてるみたいに……フィットしちゃうんですよ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0404108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「このまま、上下に……うんっ、ふっ、動かしたら……ふふっ、おっぱいがぷ\nるぷるしちゃいますね……んっ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0404109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「あらぁ……またオチンポがビクって……ふふ……本当はオマンコにずぶって\n挿入したいんじゃないですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0404110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「やせ我慢しても、分かっちゃいますよ……貴方のことなら、どこが好きで…\n…どこが苦手で……どうしたいのかも……全部知ってます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0404111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「もし、どうしてもって言うんでしたら……直接生ハメセックスしてもいいで\nすよ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0404112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ほら、このヌルヌルローションと……このヌルヌルオマンコ……本当にオチ\nンポが味わいたいのはどっちですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0404113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「んふふっ、そうですか。やっぱり、オマンコがいいんですね？　私の素股な\nんかじゃ全然満足できないってことですか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0404114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「違う……？　ふふっ、素股もいいけど……生ハメはもっとすごいから……？\n　んー、そうですね……どうしましょうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0404115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「なんて……ふふっ、もういっぱい我慢しましたもんね？　はい……ちゃんと\n待てたご褒美……あげちゃいます……はぁんっ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0404116" ]},
		{"command":[ "SETIMAGE", "0", "still_00001404_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「んふっ……ほら……あふっ、本物の生オマンコですよ……あぁんっ……んふ\nっ、ビキビキの逞しいオチンポ……素敵ですっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0404117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「はぁぁんっ……大きいのが……一番奥に届いて……子宮口をこつんってノッ\nクして来ますね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0404118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「分かってます。ちゃーんとオチンポを気持ちよくして差し上げますから……\n行きますよ……？　んっ、ふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0404119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「んっ、あっ、はっ、あんっ、はっ、あんっ、どうですか……？　オマンコの\nお肉が……勃起オチンポをごしごし……扱いてます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0404120" ]},
		{"command":[ "SETIMAGE", "0", "still_00001404_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「んふぅ……それにしても硬いです……オマンコを、ぐぱって押し広げて……\n中の存在感が……堪りません……はふぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0404121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「動かしているだけで……お腹の中で反り返っていくみたいに……はぁんっ、\nちょうど気持ちいいところに当たってますぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0404122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「んふっ、あんっ、あぁんっ、ここの気持ちいいとこっ……続けて擦らせても\nらいますねぇっ……あっ、ふっ、んっ、んふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0404123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「あぁんっ、腰の動き……いやらしくなっちゃう……オチンポ欲しがりすぎて\nぇ……下品にカクカク……動いちゃいますぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0404124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「はぁんっ、んふっ、ほら……見えてますか……？　ぶっといオチンポをぱっ\nくり咥えてるオマンコぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0404125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ここから、涎がドロドロにあふれてぇ……はひぃ……あぁっ、ぬちゃぬちゃ\nっ……スケベな音がしてますぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0404126" ]},
		{"command":[ "SETIMAGE", "0", "still_00001404_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「はぁっ、んふっ、うくっ、んくんっ……あぁ……オマンコいい……オマンコ\n感じます……んふぅっ、オチンポすごいですっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0404127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「あっ、んくっ、はぁぁっ、腰が止まらないっ……おっぱいプルプルさせなが\nらっ、オマンコピストンっ……ずっとしちゃいますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0404128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「はぁんっ、んふっ、あっ、ダメです……んっ、まだ動いちゃ……ダメですよ\n？　もうちょっと射精は待って……ん、ふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0404129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ふふっ……こうして、根元を締め付けちゃえば……出したくても出せなくな\nっちゃいますからね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0404130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「このままで……うんっ、はっ、んふっ……ほらぁ……ふしだらなオマンコが\n……いっぱいオチンポを扱いちゃいますっ……あ、ひっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0404131" ]},
		{"command":[ "SETIMAGE", "0", "still_00001404_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「はっ、んんっ、んふっ……んっ！　あぁんっ、いい……オマンコ……ずっと\n悦んじゃってます……擦れるオチンポがよくて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0404132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「エッチな感じに……んふっ、お尻振ってぇ……あひっ、はぁっ、ぎゅうっと\nオチンポ絞りこんで……ふふっ、そろそろ限界ですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0404133" ]},
		{"command":[ "SETIMAGE", "0", "still_00001404_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「それじゃあ……おねだりが聞きたいです……私のオマンコの中に、オチンポ\nドピュって射精したいって……ほら、どうしますか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0404134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「んふっ……もう言っちゃうんですね。もう少し我慢するかと思いましたけど\n……そんな余裕はありませんでしたか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0404135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ふふっ、仕方ないです。ちゃんとおねだり出来たご褒美ですよ……んっ、さ\nあ……いっぱいドピュって中出しして下さいっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0404136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「んはぁぁぁんっ！　あぁっ……ドピュドピュっ……出てますっ、熱いの……\nオマンコ……届いてますぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0404137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001404_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「はふぁぁぁ……んんっ、イクッ……んんっ、イキますっ！　私のオマンコ…\n…中出しスペルマで……ずっとイッてますぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0404138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「んっ、あふっ……はぁぁ……いっぱい出ましたね……サキュバスのエッチな\nピストン……楽しんで頂けたなら何よりです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0404139" ]},
		{"command":[ "SETIMAGE", "0", "still_00001404_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「でも、正直……私の方が楽しんじゃったかも知れません。ふふ……お腹の紋\nがキュンキュン疼いて……今も気持ちいいです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0404140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「さ……気持ちよく一発出してもらったところで……続き……しちゃいましょ\nうか。ふふっ、休みなんてなくても大丈夫ですよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0404201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「だって、ほら……まだオチンポ、こんなにビンビンです。もっとしたいって\n……オマンコの中で震えてますよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0404202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「もう、私のスイッチも入っちゃいましたから……これは、止まれっていって\nも止まらないんです……んふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0404203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、今度は……もっと腰を回して……中の精液……かき混ぜちゃ\nいますよ……あっ、ふっ、おふっ……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0404204" ]},
		{"command":[ "SETIMAGE", "0", "still_00001404_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「んんっ、あぁ……オマンコの中がじゅくじゅくですっ……はぁっ、ふっ……\nオチンポがさっきより滑って……あんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0404205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「でも、硬さは全然変わってないです……んふっ、気持ちいいとこを……グリ\nって擦り上げてくれるの……好きです……あふぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0404206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「あっ……んっ！　んふっ、どうしました……？　急にオチンポ……あっ、下\nから……突き上げて来て……あふっ、んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0404207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「んふっ……ずっとやられっ放しじゃないって……そういう気持ちになっちゃ\nいましたか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0404208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「あんっ、はっ、はい……もちろん大歓迎です……いっぱいオチンポでオマン\nコっ……突きまくって欲しいですっ、あふっ、んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0404209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「はぁっ、あんっ、あっ、あぁっ、ほぉら、頑張ってっ♪　オチンポファイト\n♪　オチンポ頑張れっ、オチンポっ……オチンポっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0404210" ]},
		{"command":[ "SETIMAGE", "0", "still_00001404_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「んふっ、もちろん……オマンコも頑張っちゃいますからっ……はっ、んんっ\n、あっ、んくんっ、はぁっ、こうして……また、ぎゅって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0404211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ふふっ、駄目ですよ……これ位で腰を止めたら……まだまだ、こんなものじ\nゃありませんよね？　んっ、おふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0404212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ほぉら……この……根元と……先っぽの同時締め付け……んんっ、いいでし\nょう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0404213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「んっ、私のオマンコとオチンポのキスぅ……ちゅぷって……あぁっ、何回で\nもしちゃいます……はっ、ふっ……！", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0404214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「あっ、あぁっ……！　その突き上げぇっ！　好きっ……あひっ、大好きです\nっ……オマンコっ、悦びっぱなしになっちゃってますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0404215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「んふっ、あぁっ……キュンキュンって……オマンコ締めたらっ……あふっ、\nまた腰がビクってなっちゃいますねっ……んっ、あっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0404216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「この感じ……またオチンポっ……我慢出来なくなってますか？　ふふっ、こ\nのビクビクって……そうですよねっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0404217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「んっ、じゃあ、またおねだりしちゃいましょう？　ドピュっていっぱいオチ\nンポ射精したいって……さあ……どうぞっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0404218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ふふっ、またすぐイっちゃうんですねぇ。もう……本当に我慢出来ないんで\nすから……仕方ない人です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0404219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「んっ、いいですよ……じゃあ、好きなところに出しちゃいましょっ……ほら\nほら……オチンポ……またドピュってっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0404220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「んぁぁぁっ……！　またオチンポっ……熱いのっ、中出しっ……来てますぅ\nっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0404301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001404_02_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「あっ……イクッ！　中出しでイクッ！　発情したサキュバスオマンコッ、続\nけてイッてますぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0404302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ふぁふっ……すごい勢い……あぁ、子宮にびゅくびゅくって……スペルマ射\nち込まれて……はぁぁぁ……素敵ぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0404303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「んくぅぅぅ……もっと出して……このまま種付けしちゃって下さい……はぁ\nぁ、貴方の赤ちゃん孕んじゃうかも知れません……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0404304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「くふぅ……はぁ……はぁ、あっ、ふっ……んふっ……ふふ……まだ勢いよく\n出てるなんて……貴方もその気なんですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0404305" ]},
		{"command":[ "SETIMAGE", "0", "still_00001404_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「はぁ、あぁ……落ち着きはじめちゃいました……でも、これだけいっぱい出\nしてくれたんですから、贅沢は言えませんよね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0404306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「あふっ……んんっ、ふふっ、続けての２連発……お疲れ様でした。お腹の中\nで、精液がちゅぷんってしてます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0404307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「まだ……オチンポ抜かなくてもいいですよね？　もうちょっと、オマンコの\n中に残ってる感触を楽しんでいたいです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0404308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ふふっ、大丈夫です。流石に、続けてもう一回という風にはしませんよ。ち\nょっと位は休憩しないと大変ですもんね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0404309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「でも……一息ついたら、またオチンポには頑張ってもらって……私のオマン\nコ……もっともっと可愛がって下さいね……ふふっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0404310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ふぁぁんっ！　あっ……おっぱいっ……顔まで……精液飛んでっ……はぁぁ\nんっ、ぶっ掛けっ……されますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0404401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001404_02_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「んっ……はぁぁ……私もイクっ……スペルマっ……お肌に染み込んでっ……\nはひぃっ、イキっ……ますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0404402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「あぁっ……まだ噴水みたいに……ドプって……んふっ……どれだけ出す気な\nんですか……あふっ、んふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0404403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「あぁ……ねとねとです……このぬめり……オチンポ直接塗りつけて下さい…\n…ふはぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0404404" ]},
		{"command":[ "SETIMAGE", "0", "still_00001404_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……んっ、あぁ……射精……止まりました……でも、まだ亀頭に\n……粘っこいのが残ってます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0404405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「はい……お腹に擦りつけちゃって下さい……んふっ……気持ちいい……ヌル\nヌルオチンポの感触……クセになっちゃいそうです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0404406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「全部……出し切りましたか？　はい、いっぱい出して下さってありがとうご\nざいます。本当にお疲れさまでした」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0404407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ほら見て下さい……こんなにねっとりして……ちょっとお味見……ちゅぱっ\n、んちゅぷ……んーーっ、美味しい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0404408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ふふっ、こんな濃いのを味わっちゃうと……またオマンコがウズウズして来\nちゃいますね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0404409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「という訳で……少しだけ一休みして……まだまだ、いっぱいオマンコ……可\n愛がって下さいね。私……楽しみにしていますから♪」", "NORMAL" ]},
