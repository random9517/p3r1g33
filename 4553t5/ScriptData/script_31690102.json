		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「もう一回っ……中にっ……あぁっ、はいっ、ご主人の熱い子種っ……喜んで\nお受けしますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0104301" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「下さいっ……あぁっ、ビュビュってっ……中っ……いっぱいっ、満たしてぇ\nっ、んぁぁぁぁぁぁーーーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「あはぁぁぁぁ……は、ふぁっ……出て、ますぅ……精液ぃビュクビュク……\nオマンコ……満たされてるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0104303" ]},
