		{"command":[ "PLAYVOICE", "v2_169_0104304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「んぁふっ……あぁ……出ましたか……？　残った分……オマンコで吸い上げ\nますね……んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0104305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「んふっ……！　残りが出て……来ましたぁ……くぅぅん、またイクぅぅぅ…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0104306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「あふっ、はぁぁ……出して、頂きました……あぁ……少し、溢れて来てます\nぅ……ダメ……勿体ない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0104307" ]},
		{"command":[ "SETIMAGE", "0", "still_00016901_02_16" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「中に頂いた分はしっかり……吸い上げないとぉ……んっくぅ……ん、ふっ…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0104308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……はぁ……あぁ……も、申し訳ありません……腰に、力が…\n…入らなくて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「あと、もう少しだけ……このままでよろしいでしょうか……んふぅ……あり\nがとうございます、ご主人……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0104310" ]},
		{"command":[ "SETIMAGE", "0", "still_00016901_02_18" ]},
