		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「ありがとうございました、ご主人……改めて、わたくしは……身も心も……\nご主人のものにして頂きました……」", "NORMAL" ]},
