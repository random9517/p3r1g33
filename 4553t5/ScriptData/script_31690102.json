		{"command":[ "SETIMAGE", "0", "still_00016901_02_20" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「んぁぁ……イク……精液の匂いでイクっ……ヌルヌルの感触でイクッ……あ\nぁっ、ずっとイッてますぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0104404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……後もう少し出るんですか……？　はい、後は顔にも……浴\nびせて下さい……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0104405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「はぁ……あぁ……ねばねばぁ……ちゅぷっ、ご主人の精液の味……とっても\n濃いです……んちゅぷぅ……美味しい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0104406" ]},
		{"command":[ "SETIMAGE", "0", "still_00016901_02_19" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「あぁ……わたくしの汗と精液が入り混じって……いやだ……変に匂ったりし\nていませんか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0104407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「後でしっかりシャワーを浴びないと……はぁ……でも、ご主人の匂いを染み\n込ませるのも、いいかも知れませんね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0104408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「はふ……もう少し、このままいさせて下さい……初めての感覚……大事にし\nておきたいんです……」", "NORMAL" ]},
