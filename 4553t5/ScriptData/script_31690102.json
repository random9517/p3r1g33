		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「あっ、あぁっ、身体にっ……はいっ、掛けてっ、出して下さいっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0104401" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「ご主人のっ……濃厚ザーメンっ、わたくしの身体にいっぱいぶっ掛けてぇっ\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0104402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「はぁぁぁぁんっ……！　あぁっ、出てるっ……濃いのがっ……あふぁぁぁ…\n…全身に染み渡りますぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0104403" ]},
