{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016901_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「ご主人……んっ、はぁぁ……まだ、なのですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0104101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「ようやく、ご主人と一つになれると……なのに、このように焦らされては…\n…わたくし……あぁ……どうにかなってしまいそうです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「んっ……わ、分かっています。まず、わたくしの陥没乳首がその気にならな\nいと……オチンポを頂けないのですよね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0104103" ]},
		{"command":[ "SETIMAGE", "0", "still_00016901_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「もう十分にそれは理解していますから……あぁ……もっと、おっぱいを……\n乳首をコリコリなさって下さい……はぁんっ、あ、ひっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0104104" ]},
		{"command":[ "SETIMAGE", "0", "still_00016901_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「あひっ！　あっ、あぁっ、そうですっ……んくぅっ、あっ、ひぁっ、それっ\n……あぅんっ、乳首それぇっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0104105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「ご主人のっ……指が……上手くてっ、あぉっ、乳首っ……ムズムズしてっ、\n出てっ……来てぇっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0104106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「はひぃんっ、イクッ……おっぱいイキますっ！　あぉぅんっ、乳首でイック\nぅぅぅぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0104107" ]},
		{"command":[ "SETIMAGE", "0", "still_00016901_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「はぁっ……はぁっ、あっ、ふぁっ……は、ひっ……乳首……イキましたぁ…\n…ジンジン……勃起して、ますぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0104108" ]},
		{"command":[ "SETIMAGE", "0", "still_00016901_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「これで……んっ……もう準備出来てます……後は……お、おねだりぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0104109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「あぁ……お願いします、ご主人……わたくしの……発情した、濡れ濡れのオ\nマンコ……ご覧下さいませぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0104110" ]},
		{"command":[ "SETIMAGE", "0", "still_00016901_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「このように……オマンコは、ご主人の逞しい……ギンギンオチンポが頂きた\nくて……ずっと、はしたなく涎を垂らしております……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0104111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「どうか、この飢えたメスオマンコに……このぶっとくて、かたぁいオチンポ\n様を……どうかずぶりとお恵み下さいませ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0104112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「まだ経験の至らない、初物オマンコですが……精一杯ご主人にお尽くし致し\nますので……たっぷりオマンコして下さいませ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0104113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「あぁっ！　はい、ありがとうございますっ……そ、それでは……自分からで\n失礼しますが……オチンポ、ハメさせて頂きます……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0104114" ]},
		{"command":[ "SETIMAGE", "0", "still_00016901_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「は……んんんんぅぅぅっ……あ……っくぅぅぅぅんっ……！　ハ、ハマりま\nしたぁ……オチンポぉ……ふ、深くまでぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0104115" ]},
		{"command":[ "SETIMAGE", "0", "still_00016901_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「こんな……あぉぉぉ……お、思った以上に……大きくてぇ……あぁ、中……\n広げられていく感じですぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0104116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「んっ、く、ふっ……！　あぁ……これで、ね、根元までぇ……ズッポリ届い\nてしまいましたぁ……んぁ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0104117" ]},
		{"command":[ "SETIMAGE", "0", "still_00016901_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「んっく……あぁ、少しだけ……このままでいいですか？　何とか慣れて、し\nまいますから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0104118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ……凄い……みっちり、くっついて来るぅ……あぉぉ……くぉ\nぉぉん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0104119" ]},
		{"command":[ "SETIMAGE", "0", "still_00016901_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「あふっ……も、もう大丈夫ですわ……上手く出来るか分かりませんが……今\n日は、たっぷりわたくしのオマンコで……ご奉仕致します……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0104120" ]},
		{"command":[ "SETIMAGE", "0", "still_00016901_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「んっ、あっ、おぉっ、あっ、おぉんっ、あぁっ、こんなにも雄々しくて……\n柔らかさと硬さが一緒になって……これがオチンポぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0104121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「ご主人のエネルギーを……胎内に感じますぅ……オマンコが、ずっと心待ち\nにしていたと……言ってますわぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「少しずつ、んっ、速めて行きますね……腰ぃ……ズボズボっ……します、か\nらぁっ……んぁふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0104123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「はっ、あっ、あぁっ……んっ、オチンポの感触……乳首にされていた時とは\n……やっぱり全然違いますぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0104124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「脈動してる……感じが……んんんっ、中のヒダに……直接届いて……あっ、\nはぁぁぁぁぁんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「あぁっ……まるで、身体中が……ご主人のオチンポに服従するように……作\nり変えられているようなっ……そんな気分ですっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「は、はいっ……ちゃんと口にしてお伝えしますっ……わたくし、ルシオラは\nっ……ご主人のオチンポでオマンコ気持ちよくなっていますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0104127" ]},
		{"command":[ "SETIMAGE", "0", "still_00016901_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「オマンコ気持ちいいっ、あひぃっ、オチンポズボズボする度っ、どんどんオ\nマンコ気持ちよくなって行きますっ、ひぃんっ、オマンコいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「あぁっ、はいっ、おっぱいもいいですっ……もっと揉んで下さいっ、はした\nなく勃起した乳首もっ……コリコリしてぇっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「んはぁっ、全体……モミモミされながらっ、先端……扱かれてっ、あぁっ、\n一緒にお尻振るのっ……堪らないですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「あぁ……いけませんっ、そんなに顔を覗き込まないでぇ……だらしなく緩ん\nでるの……見つかっちゃう……あぁ、そんなことで興奮されてもぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0104131" ]},
		{"command":[ "SETIMAGE", "0", "still_00016901_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「はぁっ、ひっ、あひんっ！　あぁっ、じわって来るっ……ご主人のオチンポ\nがっ……もうすぐ出そうになってるの分かりますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「あぁっ……お願いします……最初はどうかっ……中にっ、このままわたくし\nのオマンコの中に出して下さいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0104133" ]},
		{"command":[ "SETIMAGE", "0", "still_00016901_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「ご主人の精液をっ……ちゃんと胎内で感じたいんですっ……はいっ、一生懸\n命腰を振りますからぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「あっ、あぁっ、わたくしもイキますっ、はいっ、あぉんっ、オマンコッ……\nイキますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0104135" ]},
		{"command":[ "SETIMAGE", "0", "still_00016901_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「んぁっ、はっ、あっ、あぁぁぁぁぁぁぁーっ！　イクぅぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0104136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016901_02_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「はぁ……あぁっ……中ぁ……出されてます……んんっ、どぷってぇ……あふ\n……生精液ぃ……いっぱいにぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0104137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「んっ、あぁ……ご主人のエネルギーを……そのまま頂いているような気分で\nす……はぁぁぁぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「んふっ……落ち着かれましたか……？　いっぱい射精なされましたね……ふ\nふ、ありがとうございます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0104139" ]},
		{"command":[ "SETIMAGE", "0", "still_00016901_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「これで、またわたくしとご主人は……より強く結びつくことが出来たような\n……おこがましいかもしれませんが、そんなことを思ってしまいます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「あっ、ご主人……オチンポが……また、大きく……はっ、あぁぁぁ……こん\nなに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0104201" ]},
		{"command":[ "SETIMAGE", "0", "still_00016901_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「はひっ、そ、そんなに下からこつんって、さ、催促されては……あぁ……ま\nた欲しくなってしまいます……あっ、おっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0104202" ]},
		{"command":[ "SETIMAGE", "0", "still_00016901_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「まだ……オマンコ発情したままなのに……あっ、おっ、ご主人のオチンポが\n……その気にさせて……あぁ……意地悪です……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「ダメ……まだ、満足しきれていませんっ……お願いします……もっと続けて\nっ……ご主人も一緒に動いて下さいっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0104204" ]},
		{"command":[ "SETIMAGE", "0", "still_00016901_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「もうご主人なしではいられないオマンコをっ……いっぱい突いてっ、はぁん\nっ、もっと感じさせてくださいませぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0104205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「あひぁぁぁぁんっ！　下からっ、ズコズコっ……強い突き上げっ、来るぅぅ\nぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0104206" ]},
		{"command":[ "SETIMAGE", "0", "still_00016901_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「んぁっ、あぁっ、これがっ……ご主人のっ、本気セックスぅっ！　あぁっ、\nすごいっ、こんなにっ、なんてぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「はぁんっ、オマンコっ……子宮の深い所に届いてぇっ……あぁっ、身体が…\n…悦んじゃってますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「うんっ、あふっ、くぅんっ、あっ、あぁっ、何度もっ、何度もっ、かき混ぜ\n……られてぇっ、ぶじゅってお汁っ……出てきてぇっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「あぁっ、亀頭がぁっ……気持ちいい所に擦れてぇっ、あぁっ、感じるっ！　\nオマンコいいっ、オマンコ気持ちいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0104210" ]},
		{"command":[ "SETIMAGE", "0", "still_00016901_02_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「んくぁっ！　あぁっ、おっぱいも一緒にぃっ！　はひっ、コリコリの乳首っ\n……んくぅんっ、こねられたらぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0104211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「ま、また勃起しちゃうっ……だらしない陥没乳首が元気になってっ、はぁぁ\nんっ、ゾクゾクっ……しますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0104212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「あぁっ、こんなっ、淫らなっ……はしたない姿っ……ご主人にしかお見せ出\n来ませんっ！　いつも真面目な優等生なんて言われてっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0104213" ]},
		{"command":[ "SETIMAGE", "0", "still_00016901_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「でも、わたくしの本性はっ……これぇっ、あぁっ、オチンポ大好きなっ、ご\n主人だけのオマンコ牝なんですぅっ、ま、またイクぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0104214" ]},
		{"command":[ "SETIMAGE", "0", "still_00016901_02_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「はぁっ、あぁっ……申し訳ありません……ご主人より前に、またメスアクメ\nぇ……してしまいましたぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0104215" ]},
		{"command":[ "SETIMAGE", "0", "still_00016901_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「んっ、大丈夫ですっ……わたくしも、頑張って腰を振ってぇ……ご主人の射\n精を……お手伝いしますからぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0104216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「このままっ、続けて下さい……おっぱいもモミモミしてぇっ……オチンポも\n、オマンコかき回してぇっ、あはぁんっ、ギュッて締め付けますぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0104217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「んぁっ！　オチンポビクンってなりましたっ……これは……また、次の射精\nがすぐそこっ……ですよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0104218" ]},
		{"command":[ "SETIMAGE", "0", "still_00016901_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「はいっ、頑張りますっ……もっと深く密着させてぇ……オチンポと子宮っ…\n…キスしてぇっ……あぁっ、ビクって！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0104219" ]},
		{"command":[ "SETIMAGE", "0", "still_00016901_02_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「もうすぐ出るのっ……あぁっ、下さいっ……精液っ……びゅびゅってっ……\nいっぱいっ、出してぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0104220" ]},
