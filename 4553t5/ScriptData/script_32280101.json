	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「なんのつもりって……パ・イ・ズ・リ・に決まってるじゃん。あとフェラも\n追加で～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0103101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「地球人は、これされると喜ぶって聞いたけどー？　えっ？　違った？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0103102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「なんだー、やっぱそうじゃん。まあ、これ……めっちゃ大きくなってるし…\n…おまえが興奮してるのはしってたけどー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0103103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「えーっと……これ、なんて言うんだっけ？　チ、チン……？　チンポ？　\nそう！　チンポ！　キャハハッ、そうそうチンポチンポ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0103104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「地球人の生殖器はおもしろい形してんねー。てかさー、これをおっぱいで\n挟もうなんて、誰が考えたの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0103105" ]},
		{"command":[ "SETIMAGE", "0", "still_00022801_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「地球人って、男も女も変態すぎない？　まー、おもしろいから、あーしは\n好きだよ、そーゆーの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0103106" ]},
		{"command":[ "SETIMAGE", "0", "still_00022801_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「でー、ヤるの？　ヤんないの？　おまえがイヤっていうなら、止めてあげる\nけど、どーするー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0103107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「返事はやっ……！　そんなにヤッて欲しいんだー？　わーったって、わかっ\nたから……チンポ押しつけてくんなし……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「てことでー、おまえのチンポを……てってーてきに……イジメてやるからさ\n……んしょっと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「あはっ……なにこれ、あっつー……しかもすっごい硬いじゃん……石みたい\nになってる……すごー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0103110" ]},
		{"command":[ "SETIMAGE", "0", "still_00022801_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「は、はあ～？　ビビってないし……！　おまえのチンポなんかに、あーしが\nビビるわけないじゃん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0103111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「てかまだ始めたばっかだし……本番はこれからだっつうの……ちゃーんと\n知ってんだから……チンポの弱いとこ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0103112" ]},
		{"command":[ "SETIMAGE", "0", "still_00022801_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「こうやってさ、チンポ挟んでぇ、締めつけながらぁ……先っぽを……舌で\nチロチロ～って……ほら、ペロペロ～、ペロペロ～～～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「プッ……めっちゃビクビクしてるじゃん。あーしに舐められてー、感じちゃ\nったんだー？　ねーねー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0103114" ]},
		{"command":[ "SETIMAGE", "0", "still_00022801_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「はあ～？　よゆー？　ホントかなぁ？　先っぽ舐められるとぉ……男は泣い\nて悦ぶって聞いたんだけど……んー、ちゅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0103115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「ちゅ、ぷっ……ちゅるっ……れろっ、れろっ……あはっ……舐めるたんびに\n……チンポ、ヒクヒクしてんじゃん……れろぉっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「やっぱ気持ちいいんじゃん？　あーしに舐められてぇ……感じさせられてぇ\n……どんな気分？　泣いて悦んじゃう～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0103117" ]},
		{"command":[ "SETIMAGE", "0", "still_00022801_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「強がっても～、ムダムダ～……さっきから、反応しっぱなしじゃん……ちゅ\n、ちゅっ……んぁ、れろっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「これくらいでぇ……アヘアヘ言ってたらぁ……もたなくない？　まだ舐めて\nるだけだし……ちゅぱ、ちゅぱっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「んっ……知ってんだから……先っぽ、咥えて……しゃぶったら、もっと感じ\nるって……ほら、こうやって……じゅぽ、じゅぽぽっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「……ンぶっ！　こらぁ……勝手に動くなってー、歯が当たってもしんないか\nらね？　大人しく、しゃぶられてなー……じゅるるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「f大丈夫だって、本気で……んぶっ……歯ぁ、立てたりしない、から……\nじゅぷ、じゅぷっ……じゅぼ、じゅぼぉっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0103122" ]},
		{"command":[ "SETIMAGE", "0", "still_00022801_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「はぁ、んぶっ……わーってるって、胸も……動かせって言いたいん、だろ…\n…？　ちゃんと、根本のほう……扱いてやっから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「んっんふっ……！　んっぷ……じゅぷっ……れろっ、ちゅばっ……は、あ\nはぁ……ヤバぁ……どんどんデカくなってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「ちゅぽっ……しかも、なんか……変な味するし……これって、あれ？　がま\nんじる……って、やつ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0103125" ]},
		{"command":[ "SETIMAGE", "0", "still_00022801_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「てことは～……おまえ、もうしゃせーしそうなんだ？　もっと時間かかるっ\nて聞いたんだけど……早すぎない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0103126" ]},
		{"command":[ "SETIMAGE", "0", "still_00022801_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「ま、いーんだけどー……ちゅ、ちゅぷ……出るなら、さっさ出しなよ……\nほら、ほーら……ぢゅうっ、れろっ……れろっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「んっ、んぶっ……じゅぽ……！　チンポ……先っぽから、汁が溢れてきて…\n…まずぅ……んっ、ふぅう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0103128" ]},
		{"command":[ "SETIMAGE", "0", "still_00022801_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「あーしに、こんなまずいもの……舐めさせて……れる、れろれろっ……さい\nてーな男だよ、おまえはぁ……んぶっ、じゅぼぼっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「はうっ、ううっ……おっぱいがベトベトしてきて、滑るせいで……んっ……\n変な擦れ方しちゃうっス……ひぃうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「ほら、さっきから……腰、動いちゃってるじゃん……ぐぷっ、んぷぅ……\nじゅるるっ……！　じゅぽ、じゅぽぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「んっんっ！　だ、出ふぇ……許して、やるから……んぶっ、ずちゅぅ……\nぐっぽ、ぐっぽ……んんっ！　んっ……んうううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「はっ、んぶっ！　そんな突き出したら……んぶっ！？　んふっ、んんっ……\nんっンンンぅぅぅぅぅ～～～！！！！！！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0103133" ]},
		{"command":[ "SETIMAGE", "0", "still_00022801_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「んぐっ！　んっぐっ……んふぅ……んくっ、んくっ……んっ……ぷはぁ……\nはぁ、はぁ……んんぅっ！　んぅ～～……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0103134" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022801_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「ぷっはぁぁ～～……うっ、ぶっ……これが、せーしって……やつ……？　\nクッソまずいんだけど……おえ～……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0103135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「飲んでやると悦ぶって聞いたから……飲んじゃったけどさぁ……ホントみん\nな飲んでるの、これぇ……？　マズすぎなんだけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0103136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「しかも、くっさー……なにこの匂い……ヤバすぎ……今まで嗅いだことない\nレベルの臭さだし……大丈夫なのマジで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0103137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「しかもさぁ、しゃせーしたら……チンポ小さくなるって聞いたんだけど、\n全然大きいままじゃん？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0103138" ]},
		{"command":[ "SETIMAGE", "0", "still_00022801_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「マジ？　一回じゃ足りない？　えー、あーしのパイズリフェラが気持ちよす\nぎたから、もっとして欲しーの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「しゃーない、特別サービスしてやっか～……感謝しなよ？　地球人にこんな\nことするなんて……おまえだけなんだからさ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0103140" ]},
		{"command":[ "SETIMAGE", "0", "still_00022801_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「で～？　おっぱいと、口……どっちがよかった？　……どっちも？　欲張り\nだな、おまえって……でも、まあいいや……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0103201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「そんなにあーしの、が……気に入ったなら……たっぷり味わわせてやるよ…\n…ンンっ、んあっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「やばぁ……チンポ、またデカくなってない？　こんなに腫れちゃって、大丈\n夫なん？　んっ……気持ちいい？　ならいいけどさー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0103203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「はぁ、む……んっ、んぶっ……ちゅぶっ……おっぱいの中で、ヒクヒク震え\nちゃって……気持ちいーんだぁ……あはっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0103204" ]},
		{"command":[ "SETIMAGE", "0", "still_00022801_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「もっと舌使え？　注文、多いし……んぅう……れろっ……れっろっ……んぉ\n、ちゅるっ、れろれろぉ……じゅぷじゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「んぷっ……舐めると、どんどん我慢汁……溢れてくるじゃん……まっずー…\n…んっ、れろっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「ふぅっ、んっ、あうっ……ずっと乳首が勃起しっぱなし？　もうっ……恥ず\nかしいから、言わないでくださいってばぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「あっ、歯が当たっちった……おまえがもっと舐めろとか言うから……わーっ\nてるって、気をつけるって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「優しく、って……なんかムカつくけど……まー、そうして欲しいんなら……\nやってやるよ……れろ、れろっ……んぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「じゅっぷっ……んっ、じゅぷっ……マズくて、くさい……けど……じゅる、\nんぷっ……なんか、クセになるっていうか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0103210" ]},
		{"command":[ "SETIMAGE", "0", "still_00022801_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「なんか、おまえが気持ちよさそうにしてると……まあいっかって、気持ちに\nなるんだよな……ぺろっ……んぁ、ちゅぶっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「感謝、しなよー？　じゅるるっ……ンっ、んふぅ……あーしが……わざわざ\n、こんなこと……してやってんだからぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「おっぱいも、ほら……動かしてやってるじゃん……谷間で、挟んで……むに\nむに～って……気持ちいいっしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「また、我慢汁の味……濃くなってきてっし……んぶっ、ちゅくちゅく……\nんっぷっ……ずっ、ずずっ、じゅるるぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0103214" ]},
		{"command":[ "SETIMAGE", "0", "still_00022801_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「ぷはぁ……まずぅ……でも、いいよー……出したいなら、出して……いいか\nらさぁ……んれぉ、れっろっ、じゅっぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0103215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「あーしにぃ……感謝しながらぁ……んっぷっ……しゃせー、しなって……\nほら……また飲んでやっからさぁ……じゅぷ、じゅぽっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0103216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「いーから、いーから……じゅぶっ、んぶっ……！　ぐちゅっ……んはっ、\nあぶっ……じゅぷじゅぷっ……ちゅぶぶっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……んっ、んんっ……もしかして、我慢してんの？　生意気な\nことしてないで……さっさと、出しなって……れろれろっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0103218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「んっンンっ！　じゅるっ、じゅるるっ……じゅぽっ！　んぶっ！　んふぅっ\n！　じゅっぽ……んぶぶっ！　んぶぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「ンはあっ！　あぶっ、あんっ……！　だ、出せって……あぶっ！　んっはっ\n！　んんうぅぅぅっ！　じゅぶっ！　じゅるるるっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「んっ、んぶっ！　ぐっんぅぅぅぅっ！　うっ、うぶっ……むぐっ！　んんぅ\nぅぅっ！　んふぅ！　んんぅ～～～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0103301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022801_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「うっ……んうぅっ、ぐっうっ……んくっ……むぐぅぅぅ……はぁっ……うぶ\nっ……でて、る……んくっんくっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「はぁ、あっあぶっ……さっきより、多くない？　んくっ……んんっ！　むぐ\nっ…のどに、からみつくぅ……んぐ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0103303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「濃いし、マズいし……ごくっ、ごくんっ……はーっ、はぁ……んぶっ……\nんくんくっ……んんぅぅっ……ぷっ、はぁぁぁ～～～……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0103304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「ヤバすぎ……どんだけ出してんの？　そりゃ出せって言ったけどさぁ……\n喉が詰まるかと思ったんだけど……あーしを殺す気か～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0103305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「まあ、気持ちよさそうだったもんなー、情けない顔してさ。は？　気づかれ\nてないと思ったの？　ちゃーんと見てたし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0103306" ]},
		{"command":[ "SETIMAGE", "0", "still_00022801_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「てかさー、こーんなにしゃせーしてたらさー……顔見なくても、感じまくっ\nてたのバレバレじゃん？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0103307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「で、実際どーよ？　あーしの、パイズリとフェラはー？　びゅーびゅーしち\nゃったわけだしー、最高だったよな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0103308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「キャハハハ！　そうそう～、素直に言えたじゃん。あーしのこと、もっと\n褒めていーよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「まー、おまえがそんなに悦んでくれるなら……またしてやってもいーけど？\n　え？　今から……おまえホントスケベだな～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「んぐっ！　げほっ、げほっ……！　い、いきなり腰、突き出すな……吐き\n出しちゃって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0103401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022801_01_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「ひゃうっ！　ちょ、おまえっ……んんっ！　んぶっ……んっ、んんうぅうぅ\nっぅうっぅぅ～～～～っ！！！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「な、なにしてんのっ！　あーしの顔に……かけてっ……バカっ！　ひゃっ…\n…んはぁっ！　やっ、やめぇ……ろぉ……ひぐっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0103403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「あっ、んあっ……！　あ、熱いっ……！　んぶっ！　はっ、あぁっ……！　\nちょ、もぉぉぉ～～～……ひっ、ひいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0103404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「う、嬉しそうな、顔すんな～～～……うぶっ！　んはぁっ！　くっさいっ…\n…！　か、かけんなって……言ってぇ……うぐっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0103405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「うぅうっ……くっさー……マジでくさいんだけどぉ……しかも、ドロドロ\nしてて、キモぉ……うぇぇぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0103406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁぁ……はーっ……どんだけ出してんの……顔がザーメンまみれに\nなっちゃったじゃん……ヤバぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0103407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「気持ちよかった～って……そりゃよかったけどさぁ……これ、どーしてくれ\nんの？　マジで顔も髪もグチャグチャなんだけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0103408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「えー、まだすんの？　そんなにあーしのパイズリとフェラ気に入っちゃった\n？　一回顔ふいた方がよくない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0103409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「ちょ、ちょっと……押しつけんなし……！　わーったから……舐めてやる\nから……ホント変態すぎ～、ま、いいけどさー」", "NORMAL" ]},
