		{"command":[ "PLAYVOICE", "152_0103140" ]},
		{"command":[ "SETNAME", "戦闘員Ｅ" ]},
		{"command":[ "SETTEXT", "「来てっ、来てぇ……わたしの子宮に孕ませ汁ぅ注ぎ込んで欲しいよぉ、んあ\nあぁぁ～～！！」", "NORMAL" ]},
