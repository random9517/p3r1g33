		{"command":[ "SETNAME", "戦闘員Ｅ" ]},
		{"command":[ "SETTEXT", "「あぁ、えっと……言いそびれてたんだけど、さ。その……わたし、そ、その\n……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
