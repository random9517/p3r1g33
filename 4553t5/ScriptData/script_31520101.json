		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "152_0103102" ]},
		{"command":[ "SETNAME", "戦闘員Ｅ" ]},
		{"command":[ "SETTEXT", "「ええっと、えっと……うぅぅ。経験が、ないの。え、エッチした経験ことも\n誰かと付き合ったこともないの……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "152_0103103" ]},
		{"command":[ "SETNAME", "戦闘員Ｅ" ]},
		{"command":[ "SETTEXT", "「ほら、笑うなら笑いなさいよ！　……え？　ど、どうして喜ぶの？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015201_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "152_0103104" ]},
		{"command":[ "SETNAME", "戦闘員Ｅ" ]},
		{"command":[ "SETTEXT", "「自分が初めての男になれるから嬉しい？　で、でもわたし……見られるの好\nきだし」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "152_0103105" ]},
		{"command":[ "SETNAME", "戦闘員Ｅ" ]},
		{"command":[ "SETTEXT", "「あなたのこと坊やって呼んだり、あからさまに上から目線だったのに、それ\nでもいいの……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "152_0103106" ]},
		{"command":[ "SETNAME", "戦闘員Ｅ" ]},
		{"command":[ "SETTEXT", "「……いいんだ？　ちょっ、真顔でそんなこと言わないでよ……嬉しすぎる。\nこれがいい、だなんて」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015201_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "152_0103107" ]},
		{"command":[ "SETNAME", "戦闘員Ｅ" ]},
		{"command":[ "SETTEXT", "「じゃ、じゃあセックスしたことないけど、ぱ、ぱぱぱ……パイズリフェラ、\n頑張っちゃうね……？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015201_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "152_0103108" ]},
		{"command":[ "SETNAME", "戦闘員Ｅ" ]},
		{"command":[ "SETTEXT", "「おっぱいで揉んで……はぁ、あぁっ、すごいよ、画像で見たのと全然違うっ\n……あなたのオチンポ大きくて……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "152_0103109" ]},
		{"command":[ "SETNAME", "戦闘員Ｅ" ]},
		{"command":[ "SETTEXT", "「硬くて、熱くて……んうぅ、生き物みたいに脈打ってるの……ふあぁ、すご\nい匂いっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "152_0103110" ]},
		{"command":[ "SETNAME", "戦闘員Ｅ" ]},
		{"command":[ "SETTEXT", "「舐めるの？　おっぱいでしごくだけじゃなくてしゃぶるんだね？　わ、分か\nってるけど初めてだから……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "152_0103111" ]},
		{"command":[ "SETNAME", "戦闘員Ｅ" ]},
		{"command":[ "SETTEXT", "「いくよ？　ちゅっ、ちゅるる、ちゅっ。んうぅ、く、咥えるよ……あむっ。\nちゅむ、ちゅむむ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015201_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "152_0103112" ]},
		{"command":[ "SETNAME", "戦闘員Ｅ" ]},
		{"command":[ "SETTEXT", "「んうぅ、わたしいま……本当に恋人とエッチなことしちゃってるんだ……ち\nゅむむ、ちゅるっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "152_0103113" ]},
		{"command":[ "SETNAME", "戦闘員Ｅ" ]},
		{"command":[ "SETTEXT", "「んあぁ、お口の中でビクビク跳ねてるよ、あなたのオチンチン……？　い、\nいいんだ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "152_0103114" ]},
		{"command":[ "SETNAME", "戦闘員Ｅ" ]},
		{"command":[ "SETTEXT", "「気持ちイイんだね？　じゃあ、わたしも頑張っちゃう……不慣れだけど、で\nも」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "152_0103115" ]},
		{"command":[ "SETNAME", "戦闘員Ｅ" ]},
		{"command":[ "SETTEXT", "「じゅむ、じゅむ！　んふぅ、こんなわたしでもあなたを気持ち良くさせられ\nるって思いたいもん」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "152_0103116" ]},
		{"command":[ "SETNAME", "戦闘員Ｅ" ]},
		{"command":[ "SETTEXT", "「じゅぷ、じゅぷぷ、んみゅうぅ、んっ！　んっ！　ふぇ……？　しゃぶって\nるわたしの顔、可愛い……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "152_0103117" ]},
		{"command":[ "SETNAME", "戦闘員Ｅ" ]},
		{"command":[ "SETTEXT", "「やっやだぁ、見ないで……！　えっ、いつもは見ろって言ってるくせに？　\nうううっ……見られたいよ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015201_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "152_0103118" ]},
		{"command":[ "SETNAME", "戦闘員Ｅ" ]},
		{"command":[ "SETTEXT", "「本当はもっと恥ずかしいところゼンブ……ぜーんぶあなたに見られたいの、\nでも拒絶されるのが怖い……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015201_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "152_0103119" ]},
		{"command":[ "SETNAME", "戦闘員Ｅ" ]},
		{"command":[ "SETTEXT", "「わたし、こんなだから……そ、それがいいの？　うん、じゃあ見てて……つ\nたないパイズリフェラ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "152_0103120" ]},
		{"command":[ "SETNAME", "戦闘員Ｅ" ]},
		{"command":[ "SETTEXT", "「ちゅむ、ちゅむむ……じゅむ！　じゅぽ！　じゅぷぷ、んふうぅ、んああぁ\nん」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015201_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "152_0103121" ]},
		{"command":[ "SETNAME", "戦闘員Ｅ" ]},
		{"command":[ "SETTEXT", "「我慢汁ぅあとからあとから溢れてくる……！　んちゅっ、ごく……！　ふあ\nぁ変な味……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "152_0103122" ]},
		{"command":[ "SETNAME", "戦闘員Ｅ" ]},
		{"command":[ "SETTEXT", "「きゃっ！？　イタズラしないで……やぅぅん！？　乳首っ、んっ、ん～～～\n！！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015201_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "152_0103123" ]},
		{"command":[ "SETNAME", "戦闘員Ｅ" ]},
		{"command":[ "SETTEXT", "「引っ張っちゃダメ……！！　あっああああ、あああぁぁぁ～～～～！！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "152_0103124" ]},
		{"command":[ "SETNAME", "戦闘員Ｅ" ]},
		{"command":[ "SETTEXT", "「はぁ！　はあぁ！　ダメ、そこ……弱いの、急所、いつもわたし、あなたの\nこと考えながら……あぁっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "152_0103125" ]},
		{"command":[ "SETNAME", "戦闘員Ｅ" ]},
		{"command":[ "SETTEXT", "「クリトリスと乳首いじりながらオナニーしちゃってたんだもん……！　あう\nぅっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "152_0103126" ]},
		{"command":[ "SETNAME", "戦闘員Ｅ" ]},
		{"command":[ "SETTEXT", "「だ、だから今もひとりでイッちゃったし、うぅ……今度はあなたにもイッて\n欲しい」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015201_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "152_0103127" ]},
		{"command":[ "SETNAME", "戦闘員Ｅ" ]},
		{"command":[ "SETTEXT", "「お詫びにお口の中で射精してもいいからぁ……じゅぷ、じゅぷぷ、じゅむむ\n、んふぅ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015201_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "152_0103128" ]},
		{"command":[ "SETNAME", "戦闘員Ｅ" ]},
		{"command":[ "SETTEXT", "「じゅっぷ、じゅぷ、んあぁ、お口の中でビクビクしてる……！　来る、来る\nぅ……っ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "152_0103129" ]},
		{"command":[ "SETNAME", "戦闘員Ｅ" ]},
		{"command":[ "SETTEXT", "「んみゅうううぅ～～～！！？　じゅぷ！　じゅむむ！　ちゅぽ、じゅぷぷ…\n…んふあぁ！」", "NORMAL" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015201_01_05" ]},
