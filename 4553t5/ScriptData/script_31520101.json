		{"command":[ "PLAYVOICE", "152_0103130" ]},
		{"command":[ "SETNAME", "戦闘員Ｅ" ]},
		{"command":[ "SETTEXT", "「はっ！　はあぁ！　これゼンブ飲んで欲しいの？　ごきゅ、んっ……じゅる\n、じゅるるっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "152_0103131" ]},
		{"command":[ "SETNAME", "戦闘員Ｅ" ]},
		{"command":[ "SETTEXT", "「ネバネバしすぎて、飲めないよ……んんぅ、頑張る……じゅぷ、じゅる、じ\nゅるる、んふあぁ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015201_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "152_0103132" ]},
		{"command":[ "SETNAME", "戦闘員Ｅ" ]},
		{"command":[ "SETTEXT", "「はぁーっ、はあぁ、飲ん……じゃったぁ、すごい匂い……ああぁっ、本当に\n射精されちゃったんだ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015201_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "152_0103133" ]},
		{"command":[ "SETNAME", "戦闘員Ｅ" ]},
		{"command":[ "SETTEXT", "「ふぇ！？　パイズリフェラして、ザーメンごっくんしてる姿、とってもエロ\nくて可愛い……？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015201_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "152_0103134" ]},
		{"command":[ "SETNAME", "戦闘員Ｅ" ]},
		{"command":[ "SETTEXT", "「う、うぅっ……そんなこと言われたら、またわたしのオマンコ濡れてきちゃ\nうっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "152_0103135" ]},
		{"command":[ "SETNAME", "戦闘員Ｅ" ]},
		{"command":[ "SETTEXT", "「さっきイッて愛液溢れてきてるのにぃ……え、や、やだぁ、見ないで……！\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "152_0103136" ]},
		{"command":[ "SETNAME", "戦闘員Ｅ" ]},
		{"command":[ "SETTEXT", "「そ……そうなの、トロトロで、愛液がアナルまで覆っちゃってる……ふあぁ\n！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "152_0103137" ]},
		{"command":[ "SETNAME", "戦闘員Ｅ" ]},
		{"command":[ "SETTEXT", "「またオチンポ元気になったぁ……えっ？　つ、続きをするの？　わたしのヴ\nァージン奪っちゃう……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "152_0103138" ]},
		{"command":[ "SETNAME", "戦闘員Ｅ" ]},
		{"command":[ "SETTEXT", "「い、いいよ……あなたにあげる。ゼンブ……わたしの全て貰って欲しいの…\n…」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015201_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "152_0103139" ]},
		{"command":[ "SETNAME", "戦闘員Ｅ" ]},
		{"command":[ "SETTEXT", "「やあぁっ、濡れてるけど、こんな大きいオチンポ入るかな……あ、ああっ、\nああぁぁ～～！！？」", "NORMAL" ]},
