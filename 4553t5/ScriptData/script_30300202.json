		{"command":[ "PLAYVOICE", "v2_030_0204105" ]},
		{"command":[ "SETIMAGE", "0", "still_00003002_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
