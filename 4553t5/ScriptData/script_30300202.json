		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あぁっ、出るっ……母乳が出ますっ……！　んんっ、あっ、オマ○コからも\nっ……愛液が……溢れて……止まらないですっ！」", "NORMAL" ]},
