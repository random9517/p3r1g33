		{"command":[ "PLAYVOICE", "v2_030_0204140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んっ……はぁ……今……イッたのか……ですか？　その、申し訳ありません\n……よく、分からないまま……ふわふわしていまして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0204201" ]},
		{"command":[ "SETIMAGE", "0", "still_00003002_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あ……もっとはっきり、イッたことを確認出来た方がいい……ですか。貴方\nがそう仰るなら、はい……このまま続きをお願い致します……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0204202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あっ……んんっ、あふっ、あっ、あぁっ……先程よりも……勢いが、んっ、\nついての出し入れに……なって、います……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0204203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「いえ、痛みは……ありません……とても、刺激は感じますが……切なさのよ\nうな、んっ、感覚に……近いです……あぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0204204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「その、厚かましいお願いで恐縮ですが……もっと……して頂いても、よろし\nいでしょうか……お、おねだりをする……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0204205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「は、はい……どうか、貴方の太い……オ、オチ○ポで……私のオマ○コを、\nかき回して……下さい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0204206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「もっと、オマ○コして欲しいんです……あぁ……オマ○コして……あっ、は\nぁっ、あぁぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0204207" ]},
		{"command":[ "SETIMAGE", "0", "still_00003002_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「ひぁぁっ、くぅんっ……あぁっ、突き上げられてっ、ますっ……！　うんっ\n、ふっ、はっ、強い……のっ、がっ……んぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0204208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はいっ、あぁっ、オチ○ポ……気持ちいいっ！　これですっ、オチ○ポっ…\n…気持ちいいですぅっ、んぁっ、あぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0204209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「中出しされてっ……ドロドロになってるオマ○コをかき回されてっ、はぁん\nっ、私っ……感じすぎてっ、また母乳をお漏らししてっ……はぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0204210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あっ、あぁっ！　ズンズンっ……突かれっ、ますっ！　はぅんっ、あぁっ、\nダメですっ、身体が……言うことを聞いて、くれませんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0204211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「何も、かもがっ……あっ、あぁっ、めちゃくちゃになってっ……あひっ、ひ\nんっ！　冷静で……いられなくてっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0204212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あぁっ、おっぱいっ……揉んで下さいっ……ぎゅって搾られるとっ……それ\nだけで、あぅんっ！　胸が蕩けそうになって……！」", "NORMAL" ]},
