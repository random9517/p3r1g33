		{"command":[ "PLAYVOICE", "v2_030_0204109" ]},
		{"command":[ "SETIMAGE", "0", "still_00003002_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「ん、あぁぁぁ……溢れて来る……んんっ、母乳が……吸い出されて行きます\nぅ……はぁ……んふっ、くぅぅん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0204110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「確かに、気持ち……いいです……んっ、これを続けて頂けたら……身体がす\nっきりするかも知れません……んぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0204111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あぁ……ま、まだ出る……出るぅ……おっぱい出ます……止まらない……ん\nんっ、すみません……もっと、飲んで下さい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0204112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んっ、ふ……はぁぁ……やっと落ち着いて……来ました……はい、さっきよ\nりも、少し身体の熱は落ち着いてくれたみたいです……ありがとうございます\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0204113" ]},
		{"command":[ "SETIMAGE", "0", "still_00003002_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「え……？　今度は、貴方の方が……身体に熱が……？　それは申し訳ありま\nせん、私の母乳を飲んでしまったからでしょうか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0204114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「は、はい、もちろん……私でお役に立てるのでしたら、喜んで協力させて頂\nきます。その……どのようにすれば……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0204115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「え……足を広げて……はい、あっ、はぁぁんっ！　あっ……んぅぅぅぅんっ\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0204116" ]},
		{"command":[ "SETIMAGE", "0", "still_00003002_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あぁ……これは……あっ、オ、オマ○コの中に……オチ○ポが……は、入っ\nて……しまって……ます……んんぅっ、一体……どういう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0204117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「こうして、刺激することで……男の方もミルクが出るから……あっ、あぁ…\n…そ、そういう……ことなのですか……んっ、くぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0204118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「分かりました……それで、私に何かすることは……あっ、あぁっ！　はっ、\nんっ！　あっ、んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0204119" ]},
		{"command":[ "SETIMAGE", "0", "still_00003002_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「か、感じるままに……声を出せば……それでいい……のですか？　それだけ\nで……あっ、は、はい……あ、ひっ、あひっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0204120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「後は……んっ、今……自分がどうされているのかを……口で、説明……する\n……ですか……あ、あの、それでは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0204121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「今は……あっ、貴方のオ、オチ○ポが……私のオマ○コに……挿入、されて\n……ゆっくりと上下……して、います……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0204122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「オチ○ポの大きさは……かなり、膨らんでいて……オマ○コを……内側から\n広げていくような……そんな、感覚に……なっています……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0204123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「ぐっと……奥へめり込んで、行くと……んっ！　あぁっ、身体に……また、\n違う……熱が感じられて……はぁぁ……あっ、熱い……ですっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0204124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んんっ、もっと動かさないと……発散出来ない……ですかっ……分かりまし\nた……このまま、あっ、オチ○ポ……動かして、下さい……あひっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0204125" ]},
		{"command":[ "SETIMAGE", "0", "still_00003002_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あんっ、はっ、んぁっ、あぁぁっ……何と、言えば……いいのかっ……あっ\n、こんな……感覚を味わうのは……初めてですっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0204126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「オチ○ポが……んくっ、深く……オマ○コをえぐり取るように、されてぇっ\n……はぁっ、何だか、また……おっぱいまで……疼いて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0204127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んんっ！？　あっ、また……吸って……んぁっ、あぁっ、オチ○ポで……オ\nマ○コをかき回されながら……おっぱい、吸われていますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0204128" ]},
		{"command":[ "SETIMAGE", "0", "still_00003002_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あっ、あぁっ、あひぁっ！　おっぱいとっ……オマ○コがっ……別々に気持\nち……よくてっ……は、ひぁっ、あぁっ、すごっ、い……ですぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0204129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
