		{"command":[ "PLAYVOICE", "v2_030_0204130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んぁぁぁ……はぁぁ……さ、さっきよりも……母乳を出す時に……感じてぇ\n……はぁ、んっ、あぁぁ……あひっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0204131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あっ、あんっ、あぁっ、オチ○ポっ、激しくなっていますっ、あぁっ、すご\nい勢いで……ズボズボされてっ、あ、あぁっ、くぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0204132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はんっ、あぁっ、汗がっ……出てっ……んくっ、ぐちゅぐちゅっ……オマ○\nコから音がしてっ……中が泡立ってるようなっ……感じになって……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0204133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
