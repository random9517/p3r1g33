		{"command":[ "SETIMAGE", "0", "still_00003002_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はっ、んくっ、あぁっ、はぁうんっ、あぁっ、もっと下さいっ！　オチ○ポ\nっ……抉ってっ！　んぁぁっ、オマ○コメロメロにして下さいっ！」", "NORMAL" ]},
