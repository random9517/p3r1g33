		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「やったよ姉さん……！　成功だ……！　大成功だ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022430004" ]},
		{"command":[ "SETCHARA", "0", "char_00015801_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「５万枚のカードの中から、たった１枚のエースをつかんだんですね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022430004" ]},
		{"command":[ "SETCHARA", "0", "char_00015701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「ええ、そうよ。これがＭ.Ｏ.Ｅちゃんと私が変形合体した姿――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010022430003" ]},
		{"command":[ "SETCHARA", "0", "char_00011104_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「その名も、デッカーＭ．Ｏ．Ｅよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010022430004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ.Ａ.Ｍ.Ｉ" ]},
		{"command":[ "SETTEXT", "「ふんっ……！　合体したからって、私に勝てると思ってるの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_010022430002" ]},
		{"command":[ "SETCHARA", "0", "char_00022502_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「このボディから溢れるカツマちゃんへの愛……これがあれば、私たちは負け\nないわ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010022430005" ]},
		{"command":[ "SETCHARA", "0", "char_00011104_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「そうよ！　私たちを追い込んだくらいで、カツマちゃんへの愛が冷めると思\nったら大きな間違いよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010022430002" ]},
		{"command":[ "SETCHARA", "0", "char_00011104_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ.Ａ.Ｍ.Ｉ" ]},
		{"command":[ "SETTEXT", "「なにが愛よ！　そんなの、超人口知能には不要な感情よ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_010022430003" ]},
		{"command":[ "SETCHARA", "0", "char_00022502_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「そんなことないわ。私たちは愛があるから強くなれるし、人に優しくなれる\n……それを貴方に教えてあげるわ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010022430003" ]},
		{"command":[ "SETCHARA", "0", "char_00011104_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「すごい……！　Ｍ.Ｏ.Ｅちゃんのそばに居ると、ご主人様への愛が溢れて\nきます♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022430005" ]},
		{"command":[ "SETCHARA", "0", "char_00015701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「うん……胸の奥から不思議と力が湧いてくる……！　これなら、コピーなん\nかに負ける気がしない……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022430005" ]},
		{"command":[ "SETCHARA", "0", "char_00015801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「愛が溢れて力が湧くだなんて、そんな非合理的なことあるはずありませんっ\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_050022430002" ]},
		{"command":[ "SETCHARA", "0", "char_00015705_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「そうだよ……！　いくらＭ.Ｏ.Ｅが変形したからって、貴方たちが強くな\nるなんてことはありえない……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_050022430002" ]},
		{"command":[ "SETCHARA", "0", "char_00015805_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふふ♪　それなら、試してみましょうか♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022430006" ]},
		{"command":[ "SETCHARA", "0", "char_00015701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ご主人への愛で……貴方たちを倒してみせる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022430006" ]},
		{"command":[ "SETCHARA", "0", "char_00015801_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ.Ａ.Ｍ.Ｉ" ]},
		{"command":[ "SETTEXT", "「わけのわからないことを……！　いいから、さっさとスクラップになりなさ\nいっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_010022430004" ]},
		{"command":[ "SETCHARA", "0", "char_00022502_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「Ｍ.Ｏ.Ｅちゃん、来るわよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010022430006" ]},
		{"command":[ "SETCHARA", "0", "char_00011104_01", "0", "CENTER", "0" ]},
