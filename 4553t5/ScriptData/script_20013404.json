		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「Ｍ.Ａ.Ｍ.Ａ……！　Ｍ.Ａ.Ｍ.Ａも無事だったんだね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022430003" ]},
