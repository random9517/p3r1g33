{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「た、隊長様……。今夜もどうか、無知な私に性の知識を教えてください……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0104101" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00014101_01", "2", "CENTER", "0" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「あっ……きょ、今日するのは何なのですか？　セックス……これもまた、強\nくなるために必要なことなのでしょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「私はセックスというものを見たことも聞いたことも……もちろん、したこと\nもありません。ですので、怖くもありますが、楽しみでもあります」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0104103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「隊長様はいつも、私の経験したことのない世界を見せてくださいます。それ\nがどこかくすぐったくて、好奇心がそそられて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0104104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「はい。ベッドに横たわって……下着を脱いで……。こ、こうですか？　恥部\nをさらけ出すのは恥ずかしいですが……セックスをするためですから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0104105" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014101_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「ええと……脚を広げたまま……。このままじっとしていればいいのですね？\n　あっ、隊長様？　股間の突起を押し付けて、何を……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0104106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「あっ……えっ？　い、入れるのですか？　それを？　入りませんよね？　だ\n、だって、私の股間には穴なんて開いていな……ああああっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0104107" ]},
		{"command":[ "SETIMAGE", "0", "still_00014101_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「えっ！？　えっえっ！？　なぜ！？　なぜ突起が侵入してきて……？　えっ\n？　あ、穴がある？　穴が開いているのですか私の股間には！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0104108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「えっ……？　その穴に隊長様の突起をねじ入れる、それがセックス……！？\n　そ、想像を絶する行為です。信じられない……せ、セックス……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0104109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「あ、はい。していただくのはいいのですが、穴が……あいているなんて。そ\nれに驚いてしまいました。そうなのですね、ここは突起を入れる穴」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0104110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「セックスのための穴が女性にはあったなんて……。でも、それ専用の穴なの\nでしたらセックスに使うのがいいでしょう。どうぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0104111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「っ……あれ……い、痛い、痛いです……んんっ？　私の穴、塞がっていたの\nですか？　あっ！？　何っ！？　い、いやっ……あ、熱い……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0104112" ]},
		{"command":[ "SETIMAGE", "0", "still_00014101_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「はぁっ！？　ああっ！？　入りました、入りましたぁ……！　で、でも……\nあっ、穴がい、痛いです、それにジンジン熱くて……あああ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0104113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「さ、最初はそういうもの？　あ……な、ならいいのです。セックスは大変な\nのですね。すぐ慣れる？　ああ、良かった。安心しました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0104114" ]},
		{"command":[ "SETIMAGE", "0", "still_00014101_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「それで……ここからは……？　……。う、動かす！？　動かすとは何をって\n……ああああっ！？　突起を！？　突起を中で！？　う、嘘っ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0104115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「ああっ！？　あっ、ああああっ！？　お、おやめくださいっ……あぁんっ！\n？　ああっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0104116" ]},
		{"command":[ "SETIMAGE", "0", "still_00014101_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「あッ、穴が、穴が拡がってしまいま、す……！　それに、し、下腹の奥が…\n…あっ！？　妙に気持ち良くて……あッ、な、なんなのです！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0104117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「セックスをすると気持ちが良くなるのですか！？　あっ……！？　初めての\n感覚、です、あぅううっ！？　知らない、知らない、これ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0104118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「知らない何かが、あっ！？　穴の方から……脳へ突き抜けて……！　ふぁっ\n！？　ああっ！　あっ、ああああっああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「ええっ？　この水の音、ど、どこから……？　これも穴からっ……！？　あ\nあ、穴から水が、ヌルヌルする水が……んぁああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0104120" ]},
		{"command":[ "SETIMAGE", "0", "still_00014101_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「水が増えると、き、気持ち良さも増していきます……！　あーっ！　せ、セ\nックスっ、セックスって……はああっ、こういうっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0104121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「んぁっ！　あああっ！　これは予想外、です、セックス……ああっ、これが\nセックス……！　皆のしている、皆の大好きなセックス……っ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「よくわかりませんけど、わ、私も好きな気がしますっ……セックス。だって\n……だって気持ちが良くて……穴が、穴が濡れて……んんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0104123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「隊長様の突起が、私の穴に出入りすると……！　ピリピリと全身が快感でけ\nば立つんですっ……納得しました、これは皆好きになります！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0104124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「あぁ……そうだったのですね。私に隠れて、皆これをして……。私も今まで\nの分を取り戻したい！　ですからたくさんしましょう、セックス！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「はぁっ……はぁ、あああっ！　あっ！　あっあっ、あっ、あっ！　はい、私\nも穴を使って……穴で突起を刺激して……はい、んあああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0104126" ]},
		{"command":[ "SETIMAGE", "0", "still_00014101_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「これをすると、白い汁が出て……！　その汁を穴に塗るといいことが起こる\nのですね、ああっ……セックスはいいことばかり……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0104127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「き、もちよくて……白いお汁もいただけて……悪いところ無しです、もっと\nしたい……何度でもしたい……！　あっ、あっ、セックス、セックスぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「セックスが好きで、す……大好きです！　セックス気持ちいいですっ、すご\nく……！　白いお汁も好き、隊長様のすることは全て好、き……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「あっうっ！　あっあっあッ、にちゃにちゃしているこの音も素敵、です……\n！　セックス、セックス……ああああっ、ああ、ズポズポってぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「気持ちいい、気持ちいい、気持ちいいい……！　隊長様っ……隊長様、もう\n私、何がなんだかよくわかりません、ただ、ただわかるのは……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「穴が気持ちいいということだけっ……ああ、穴、セックスのための穴、使う\nと気持ちのいい穴……あああっ！　あふっあっあっあぁっああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「最高、最高ですぅうう……！　あっ……あーっ！！　あっあっあっ！　ああ\nーっ！　あっあっあっ！　あーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「えっ？　隊長様の白いお汁が出る！？　は、はい！　出してください！　私\nのセックス専用の穴に、白いお汁出してください！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0104134" ]},
		{"command":[ "SETIMAGE", "0", "still_00014101_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「ッあーっ！！　お汁っ、白いお汁がぶびゅーって！　穴に、私の穴に注がれ\nて……！　ひゅ、ひゅごい、ひゅごい……これも気持ちいいいい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0104135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014101_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「気持ちい……気持ち良すぎてぇえ……！　おかしくなってしまいます！　あ\nあ、満たされていく、セックス穴がお汁でたぷたぷになっていく……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0104136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「っ……はぁ、はぁ、はぁ……。は、はい……大丈夫です。気を失いかけはし\nましたが……私は正常です……。はぁ、はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0104137" ]},
		{"command":[ "SETIMAGE", "0", "still_00014101_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「初めてのセックス……。とても、とても楽しめました……。ただ、一つ言う\nことがあるとすれば……、んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「セックスもっとしたい、です……。またお願い出来ますか？　なんだか、日\n頃のストレスも吹き飛ぶようで……身体にも心にも良さそうで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0104139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「……いいのですか！？　ああ……良かった。それでは、ずっとお待ちしてい\nますね。セックス……またしてください。約束です……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「え？　ずっと待つ必要などない？　今すぐにでも？　って……隊長様！？　\nあ！　あ！　あああああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0104201" ]},
		{"command":[ "SETIMAGE", "0", "still_00014101_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「こ、こ、こんなにすぐできるものなのですか！？　セックスと言うものは！\n？　さっき終わったばかりなのに！　ぁあああん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「あ、あ、ああっ！　普通は、すぐにはできない！？　隊長様の突起は特別製\n？　あああああ！　素晴らしいです！　隊長様の突起ぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0104203" ]},
		{"command":[ "SETIMAGE", "0", "still_00014101_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「は、は、はいっ！　隊長様の突起！　突起大好きですっ！　もっとください\n！　突起で穴を突いてくださいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0104204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「はぁあああ……ああああっ！　な、なぜでしょうっ！？　さっきよりも、と\nても気持ちいい気がしますっ！　あ、は、あああああん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0104205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「慣れてきたから！？　私が、セックスに慣れてきたからですか！？　んああ\nああっ！　そうかも！　そうかもしれません！　あああん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0104206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「あ、あ、あ、あ、あん！　隊長様ぁ！　もっと！　もっと私を、セックスに\n慣らしてくださいっ！　はぁあああ～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「くぅうううっ！　そうです！　ぐっと奥まで慣らしてっ！　私、もっともっ\nとセックスに慣れたいんですぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「はぁあああ……ああん！　あっ、あっ！　すごい！　確かに私、セックスに\n慣れてます！　もう、穴からこんなに水が……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「穴からどんどん水が出てくるから、隊長様の突起がこんなに……あああん！\n　こんなに元気に動いて、あ、あ、はぁああん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0104210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「んんっ！　くっ！　はっ！　あああんっ！　あああぁっ！　ふぁあああ……\nっ！　ふぇえ？　隊長様？　なんですかぁ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0104211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「んっ、くっ……！　腰、ですか？　私の、腰が、動いてる？　んぁああ……\nよく、わかりません……はぁああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0104212" ]},
		{"command":[ "SETIMAGE", "0", "still_00014101_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「ただ、気持よくて、むずむずして……あ、あ、あ、あああっ！　じっとして\n、いられなくて……あああんっ！　あん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0104213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「だ、隊長様も？　隊長様も気持ちいいんですか？　私の穴、とても気持ちい\nいんですか？　はああああん！　嬉しいですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0104214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「隊長様の突起も、最高ですっ！　突起気持ちいいっ！　突起好きですぅっ！\n　はぁああん！　あああん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0104215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「あ、もっと、もっともっと突起で！　突起でええええっ！　あ、ああああっ\n！　はぁあああああ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0104216" ]},
		{"command":[ "SETIMAGE", "0", "still_00014101_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「た、隊長様！　また、何が何だかわからなくなってきてしまいましたっ！　\n頭が、だんだん真っ白に……ああああああん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0104217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「隊長様も？　隊長様も、また白いお汁出しそうなんですかっ！？　やあああ\nああん！　素敵ですぅううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0104218" ]},
		{"command":[ "SETIMAGE", "0", "still_00014101_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「出して！　出してくださいっ！　隊長様のお汁、私の穴の中に……あ、ああ\nああああああああっ！　私もう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0104219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「気持ちいいっ！　セックス、最高に気持ちいいですぅううううっ！　はぁあ\nあああああああああーん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0104220" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},
		{"command":[ "LABEL", "LABEL1" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「んあああああああああっ！？　出てるぅっ！　隊長様の白いお汁、私の穴の\n中でどぴゅって！　たくさん出てますぅっ！　あああああああ～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0104301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014101_02_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「あああああっ！　白いお汁が！　穴の奥っ！　穴の奥をびゅーびゅー叩いて\nますぅ！　はあああああああ～……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「あ、あ、あああああ……熱いです、隊長様の汁……熱くて……。穴の奥から\n、お腹のほうまで熱がじんわりと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0104303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「あ、あ、あ、まだ出てる……隊長様の白い汁、すごい量です……はぁあああ\n……こんなに出るなんてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0104304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「あ、穴に力を……こう、ですか……？　ん、んんん……っ！　あ、ああああ\n……っ！　まだ出てる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0104305" ]},
		{"command":[ "SETIMAGE", "0", "still_00014101_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「はい、わかりますぅ……私の穴が、隊長様の突起をくわえ込んで、白いお汁\nを搾り取って……はぁあああ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0104306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……はぁ……穴の中、お汁でいっぱいになってしまいました…\n…中でぽちゃぽちゃ言ってます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0104307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「はぁ……私また、気を失いそうになってしまいました。気を失うほど、気持\nちよかったです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0104308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「セックス……最高です。こんなに気持ちよくなれて、こんないいものがあっ\nたなんて……全然知りませんでした」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「隊長様、どうかお願いです……私に、もっともっと、セックスを教えてくだ\nさい……よろしくお願いします……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},
		{"command":[ "LABEL", "LABEL2" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「あっ！　突起が！　突起が外れてしまい……きゃあああっ！？　あっ！？　\nあああああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0104401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014101_02_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「んあああああっ！　汁が！　臭いお汁が私の身体に……はぁあん！　あああ\nっ！　ああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0104402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「あああああっ……ベトベトの汁が、穴の周りだけでなく胸にも……あ、あ、\nあああああ……はぁああっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0104403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「はぁああああ……！　あっ……！　熱いお汁が、全身にかかって……！　体\nが、火照ってしまいますぅ……はぁああ……ああん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0104404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「あ、あ、あああ……まだこんなに出てくるなんて。隊長様の汁、凄い量です\n……私、隊長様の汁でドロドロになってしまいます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0104405" ]},
		{"command":[ "SETIMAGE", "0", "still_00014101_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「はぁあ……体中ベトベト……それに、すごい匂い……隊長様の、すごい匂い\nが全身にしみついて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0104406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「なるほど……つまり、そういうことなのですね。隊長様は、私の身体の中も\n外も、隊長様の匂いで満たしたいと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0104407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「隊長様は、私のすべてが欲しいとおっしゃっているのですね。ふふふっ、う\nれしいです。隊長様に、そこまで想っていただけて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0104408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「ええ、私の身も心も、すべて隊長様のものです。隊長様の望むことなら、私\n、どんなことだって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0104409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「ですから、隊長様もそうしてくださいね。さしあたっては……そうですね、\nもう一度、セックスをお願いします……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0104410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
	{"command":[ "EXIT" ]}
	]
}