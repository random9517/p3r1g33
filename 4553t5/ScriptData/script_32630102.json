{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「ふうっ、はあっ……隊長、隊長……来てくれたんですね……えへ……へへへ\nへへへ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0104101" ]},
		{"command":[ "SETCHARA", "0", "char_00026301_01", "2", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「隊長のせいなんですよ……この前、お腹でするだけだったから……それ以来\nずっと、私の中がきゅんきゅん疼いているのです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「ねえ、もう隊長の好きにしていいですから……どう扱ってもいいですから…\n…お願いですから、抱いて欲しいのです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0104103" ]},
		{"command":[ "SETCHARA", "0", "char_00026301_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「隊長、隊長、お願いですから隊長のおちんちんを私のオマンコに入れて……\n入れてくださいなのです……んんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0104104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「あっ、隊長どこに連れて……また風呂場……今日は抱いてやるって……本当\nなのです？　えへ、嬉しい……えへへへへへへっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0104105" ]},
		{"command":[ "SETCHARA", "0", "char_00026301_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「んんっ、でもこの格好はちょっと恥ずかしいのです……けど隊長が触れてく\nれてるのなら、安心できるのです……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0104106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00026301_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「あんっ、隊長のおちんちんが当たってる……実はこの前お腹でされたときか\nら、その……ずっと身体から水じゃなくてローションが出てるのです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0104107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「私にだってなぜだか分からないのです！！　隊長のせいなのです！！　しか\nもこれが出ると、ずっとエッチなことばかり考えちゃうのです！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0104108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「自分でやっても全然収まらなくて、ずっとずっと隊長にしてもらうことばか\nり考えちゃうのです！！　責任を取ってもらうのです！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0104109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「え？　大丈夫、俺に任せろって……そんな優しい声で囁かれたら、期待しち\nゃうのですうんんんんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0104110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「いきなり、入れるなんて……ふああっ、でも、これが、これが夢にまで見た\n隊長のおちんちん……形まで分かっちゃう……あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0104111" ]},
		{"command":[ "SETIMAGE", "0", "still_00026301_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「あんっ、あっ、あううっ！！　んくうううっ！！　気持ちいいっ！！　これ\nが、男の人の……想像してたのより何倍も気持ちいいのですっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0104112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「隊長のカリ首が私の中をごりっとけずって、竿が中にみっちり入って、それ\nで先端が……ふあああっ、それっ、そのこんこんこんってするの！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0104113" ]},
		{"command":[ "SETIMAGE", "0", "still_00026301_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「叩いたら、私の中叩いたら駄目なのですっ！！　あううっ、んっ、叩かれる\nたびに、頭の中でばちばちって気持ちよさが弾けるのですっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0104114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「あうっ、ああっ、あっあっあっ、だからだめだって言ってるのに！！　隊長\nの意地悪っ！！　んんんっ、ひあっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0104115" ]},
		{"command":[ "SETIMAGE", "0", "still_00026301_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「おちんちんの先端、熱くて硬くて……中を突き上げられたら頭のてっぺんま\nで衝撃が来るのですっ！！　ふああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0104116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「これ、これが隊長とのセックス……男の人とのセックス……んんっ、気持ち\nいい、気持ちよすぎるのですっ、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0104117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「隊長が動くたびに、身体中がじんじんって痺れて、溶けて、おちんちんがじ\nゅぷじゅぷって音を立てて私の中をかき混ぜてるのですっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0104118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「あっあっあっ、そこ、こつこつこつって叩かれるの、好きです……んんっ、\n気持ちいいっ！！　んっ、あっ、あんっ、ひあっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「隊長は……隊長は気持ちいいです？　あんっ、あっ、このおちんちんの硬さ\nが答えって……えへ、嬉しいのです……やんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0104120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「んっんっんっ、その小刻みに奥を叩くの、いいっ、んんっ！！　私の奥、赤\nちゃんの部屋、隊長のおちんちんでふやかされてるのですっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0104121" ]},
		{"command":[ "SETIMAGE", "0", "still_00026301_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「ふうっ、あっ、ああっ、突かれるたびにきゅってしちゃうのですっ！！　隊\n長のおちんちん、私のオマンコが締めつけちゃうっ！！　んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「気持ちいいからもっとって……あんっ、こうです？　ふあっ、あんっ、あっ\n！！　締めつけたら、隊長の形がもっと分かるように、ひああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0104123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「あっ、これ、すごい、このまま動かれたら、中全部が隊長のおちんちんでこ\nすられちゃうのですっ！！　ふあっ、あああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0104124" ]},
		{"command":[ "SETIMAGE", "0", "still_00026301_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「隊長のおちんちんもびくびく跳ねて……気持ちいいのです？　だったらもっ\nと、ふうっ、んんっ、二人で、二人で気持ちよくなるのですっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「あっんっふっ、そこ、奥こりこりされるのも好きっ！！　こんこんされるの\nも好きっ！！　ひうっ、あっ、んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「隊長にされるならっ！！　隊長のおちんちんなら全部好きなのですっ！！　\nふああっ、あっ、んんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0104127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「あっ、今の言葉で、カリ首が膨らんでるのですっ！！　隊長、好きっ！！　\n好きなのですっ！！　隊長の全部好きなのですっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「ふああああっ！！　私の中でおちんちんが膨らんで、いっぱいになってるの\nですっ！！　私の中、隊長で埋めつくされてるのですっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「あっうっんんんっ！！　それでこんなに動かれたら、あっ、もう、頭の中ま\nでおちんちんでいっぱいになっちゃうのですっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「私の中、身体も頭も全部、隊長のおちんちんでいっぱいになっちゃって……\nんんっ、これが好きな人と繋がるってことなのですね……ふああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「私の身体そのものに隊長のしるしがつけられて……隊長のことをもっともっ\nと好きになっていっちゃうのです……あんっ、ああっ、あくっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「んふうっ、うっ、隊長のおちんちんもぱんぱんに膨らんできてるのです。隊\n長もそろそろイきそうなのですね、ふああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「嬉しいのですっ！！　私で気持ちよくなってくれてるのが、私を求めてくれ\nてるのが、嬉しいのですっ！！　はうっ、あっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「だから一緒に、一緒にイくのですっ！！　初めて隊長に抱かれたのだから、\n最初は一緒に、んんっ、あっ、またおちんちんが大きく、ひああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0104135" ]},
		{"command":[ "SETIMAGE", "0", "still_00026301_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「あんっ、ああっ、あくううううっ！！　隊長、隊長、好きっ、好きなのです\nっ！！　隊長となら、ずっと一緒にいたいぐらい好きなのですっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0104136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「あっ、ああっ、あんっ、イく、イく、イっく、隊長も、一緒にイって、あっ\n、あああああああっ、あくっ、イっくううううううううううううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0104137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「ふあああっ、一番奥でおちんちんが爆発してるっ、隊長の精液、どくどくっ\nて流しこまれてるのですっ、ふあっ、あっ、熱い……んくうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0104138" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00026301_02_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「ふうっ、はっ、んんっ、感触だけで、どろどろの濃い精液だって分かるので\nす……私の中がいっぱいなのが分かるのです……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0104139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「ふふ……こんなに愛されて満たされて、私は幸せなのです……んんっ、ふっ\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0104140" ]},
		{"command":[ "SETIMAGE", "0", "still_00026301_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「あっ……え、出したばかりでまた硬くなってるのです……男の人って出した\nら萎えるんじゃ……ふあっ、あああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0104201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「私が可愛いからもう一回？　え、えへへへへへ、しょうがない隊長ですね。\nじゃあ、いいのです。隊長の好きなように動いていいのですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「あっあっあっ、すごい、出されてから動かれたら、中がぬぷぬぷってかき混\nぜられてるのです……んっ、ふああっ、んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「さっき出されたのがまた中で熱くなって、こすりつけられて……私の中がき\nゅうきゅうって啼いてるのですっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0104204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「隊長、もっと、もっとしてくださいです！！　あうっ、ひあっ、んんっ、ふ\nああああああああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0104205" ]},
		{"command":[ "SETIMAGE", "0", "still_00026301_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「私も、私も隊長のおちんちんをもっと気持ちよくしますから……んんっ、こ\nうやって、お腹に力を入れたら……んっ、うっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0104206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「どうです、私のオマンコが隊長のおちんちんをぎゅっと抱きしめて……んっ\n、にゅるにゅるってお互いの気持ちいいところを……あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「引きこもりで、ぐうたらな私だけど、隊長のためならこれぐらいできるので\nす……あんっ、あっ、ふあああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「オマンコがおちんちんにちゅっちゅってキスしてるのです。あふっ、ううっ\n！！　隊長の先端も、私のオマンコにキスしてくるのです……あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0104209" ]},
		{"command":[ "SETIMAGE", "0", "still_00026301_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「外も中も繋がって、ふああっ、あっ、私、今、幸せなのです……んんっ、幸\nせなんて、部屋の中にしかないと思っていたのに……あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0104210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「隊長がいれば、引きこもれる部屋も、ネットも、最新PCもなにもいらない\nのですっ！！　隊長だけ、隊長だけがいればいいのですっ！！　んうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0104211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「ああっ、好きっ！！　好きっ！！　大好きっ！！　繋がってるところから、\n幸せが溢れて……んんっ、ふうっ、ふあああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0104212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「あっあっあっ、隊長のおちんちんが私の中で暴れ回ってるのです……ふうっ\n、あっ、ああっ、隊長が、隊長のおちんちんで……ふあっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0104213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「あんっ、あっ、あうっ、んんっ、また奥をぐりぐりって、隊長、出したいの\nですね。私の一番奥で、精液を出したいのですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0104214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「いいですよ。好きなときに、好きな場所で出していいのです。私の全ては隊\n長のものなのですから……あんっ、ああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0104215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「んんっ、あうっ、おちんちんが膨らんで、硬くなって……隊長の手も熱くな\nってるのです……あんっ、あっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0104216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「私で気持ちよくなったおちんちんから精液いっぱい出して、私にいっぱい出\nしてなのですっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0104217" ]},
		{"command":[ "SETIMAGE", "0", "still_00026301_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「隊長がいないときも忘れられないぐらい、濃くて熱い精液を出してください\nですっ！！　ふあっ、ああああああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0104218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「私も、私も隊長で気持ちよくなってイくっ！！　イくのですっ！！　隊長の\nおちんちんで、またイっく！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0104219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「出して、気持ちいいの全部出してっ！！　ふあああああっ、あっ、イっくう\nううううううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0104220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「ああああああっ、来たあっ、熱い精液、また来たあっ！！　私の中に、どぷ\nどぷって来たあっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0104301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00026301_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「んううううっ！！　さっきのと混ぜあわされて、オマンコの中、精液とおち\nんちんだけになっちゃうのです……あううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「んんっ、出されてるだけなのに、気持ちいい……隊長から注いでもらってる\nだけで、気持ちいいのです……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0104303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「おちんちんが跳ねるたびに、私の中が満たされて……んっ、隊長のが出てる\nのが分かるのです……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0104304" ]},
		{"command":[ "SETIMAGE", "0", "still_00026301_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「こうやってきゅっきゅってしたら……あんっ、やっぱりまた出てきたのです\n……最後の一滴まで、私の中に出してください……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0104305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「隊長の精液、少しも無駄にしたくないのです……全部全部、私のものなので\nす……私の全部も、隊長のものなのです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0104306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「んんっ、全部出たのです。えへ、えへへへへへ。初めてだったけど、隊長も\n私も気持ちよくなれて、よかったのです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0104307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「また、しましょうね。私なら、いつでもオッケーですから……ゲームしてた\nって、隊長のためなら中断できるのです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0104308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「それにしても……こんなに出されて子宮までいっぱいにされて……もしかし\nたら赤ちゃんができているのかもしれないのです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「ふふっ、もしも赤ちゃんができてたら、ずっと養ってくださいね、隊長。あ\nなたにいっぱい幸せにしてもらうのです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「あんっ！！　あっ、なんで抜いて……あっ、ふああっ、隊長の精液が身体に\n……あんっ、あっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0104401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00026301_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「すごい、全身にかけられて……熱い……んんっ、量もすごい……ふあっ、ん\nっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0104402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「どろどろねばねばで、濃いのが全身に……中も外も隊長の精液でいっぱいに\nされてる……んっ、匂いもすごいのです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0104403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「んふっ、私は水神なのですから、中に出されたのも、かけられたのも、液体\nは全て糧になるのです……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0104404" ]},
		{"command":[ "SETIMAGE", "0", "still_00026301_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「隊長の精液……んっ、私の中に染みこんでるのです……私という存在が、隊\n長で塗り替えられていくのです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0104405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「でも嫌じゃないのです。むしろ、全部してほしいぐらいなのです……あんっ\n、またおちんちんから精液が……んふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0104406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「私の中にある水を全て隊長の精液に……ふふ、神話でもそんなことを成し遂\nげた男はいないのです。でも、隊長ならきっとできるのです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0104407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「でも一回や二回じゃできないのです。だから、これからもまたいっぱいいっ\nぱいしてもらうのです。えへ、えへへへへへへ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0104408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「んんっ、なんだか、隊長に抱いてもらってすっきりしたのです……これが賢\n者タイム……なんちゃってです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0104409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「でも、やっぱりまだまだ隊長に抱いてもらいたいのです。外でも中でも、身\n体でも髪の毛でも、好きなようにいっぱい出してくださいね、隊長」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0104410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}