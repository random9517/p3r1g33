{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0105" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "ある日曜日のお昼前のこと……。", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「うわぁ……この前は気にしている余裕もなかったけど、すごい人混みね……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010114930001" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「まりあは、無理なら帰ってもいい。私だけで行ってくるから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010114930001" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ちょっと待ちなさい！　また抜け駆けしようったって、そうはいかないわよ\n！　あなただけ、カツマさんの気持ちを理解しようなんて！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010114930002" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「なら、覚悟を決めていくしかない。カツマがどうして、休日ごとにここに来\nて舟券を拾ったり、なけなしのお小遣いをスッたりしているのか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010114930002" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「私たちも、自分で体験してみるしかないということね。この、競艇というも\nのを……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010114930003" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「……で、なんでわたしまで付き合わされてるの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010114930001" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「とにかく、競艇というのは何艘かのモーターボートが競争するので、どのボ\nートが勝つかを当てるゲーム。それを予想するためには――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010114930003" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「これね。レース新聞。カツマさんはこれを読みながら予想を立てているみた\nいだけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010114930004" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「……なにが書いてあるのかさっぱりわからない。つきみはどう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010114930004" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「わたしにわかるわけないよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010114930002" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「……いいわ。新聞はあきらめましょう。なんでも、レースに出るボートは、\n本番の前に『展示航走』というのをするみたい。つまり練習ね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010114930005" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「なるほど。練習を見れば、その日の調子がわかると……まりあ、つきみ、行\nってみよう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010114930005" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「なんでわたしまで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010114930003" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0108" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "というわけで、３人は客席に入り、展示航走を熱心に見つめる。しかし……？", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「わからない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010114930006" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "4", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「わたしも……姉ちゃんは？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010114930004" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「え、えーと、展示航走のほかにも、選手とか、船に積んだモーターの成績で\nも予想が立てられる……らしいけど？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010114930006" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「つまり……姉ちゃんもわからないんだね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010114930005" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「………………。こ、こうなったらしょうがないわ！　あとは倍率よ！　とに\nかく倍率が一番高い組み合わせに、資金を全部つっこむの！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010114930007" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「うわっ！　見て！　これ見て！　これとこれとこの舟が、１、２、３位で入\n賞したら――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010114930008" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「こんなに！？　すごい！　こんなに増えるなんて！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010114930008" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「いや、それってほとんど勝つ可能性がないからだよね！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010114930006" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「うるっさいわね！　とにかく、舟券を買ってきましょう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010114930009" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「待って。学生はこういうところでお金を賭けちゃダメ。いちおう、私も教師\nなのでそこは見過ごせない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010114930009" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「シーズン２の設定、まだ生きてるの？　でもまあ、カグヤのいうことももっ\nともだわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010114930010" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「だからここは、大人の私が……あくまでも、お小遣いの範囲内で」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010114930010" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「さすがカグヤ……真面目だ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010114930007" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「まあ今回は、あくまでもカツマさんの心理を研究するのが目的だし……それ\nじゃカグヤ、お願い！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010114930011" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ふふっ。冷静に考えたら、たぶんきっと当たらない。期待しないで待ってて\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010114930011" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0108" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "と言って、カグヤが舟券を買いに行って数十分後……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「カ、カ、カ、カグヤ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010114930012" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「こ、こ、こ、これ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010114930008" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「し、し、信じられない……！　まさか、ホントに当たるなんて……当たるな\nんてっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010114930012" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「ね、ね、ね、ねえ！？　わ、わたしたち、ホントに大丈夫！？　こんなとこ\nろでツキを使い果たしちゃって……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010114930009" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「はっ！　そ、そうね！　まさか、そのせいで帰りに交通事故なんかに会った\nり……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010114930013" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「それどころか、次の話数からレギュラー外されたりなんて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010114930013" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「うわああああ！　やめてやめてやめてぇ！　もし、ホントにそんなことにな\nっちゃったら！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010114930010" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「うううう……！　どうしましょう、どうしましょう～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010114930014" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「私たち、いったいどうしたら……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010114930014" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "３人" ]},
		{"command":[ "SETTEXT", "「隊長！　助けてぇ～～～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010114930015" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "1", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "SETCHARA", "2", "char_00001401_01", "3", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "DISPCHARA", "2", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}