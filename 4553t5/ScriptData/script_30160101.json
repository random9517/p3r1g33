{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「前回の任務で、私を助けたお礼をまだ貰ってないだと？　そういえば、基地\nに戻ったら礼をするという約束をしていたな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0103101" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「いいだろう。貴様の願いをなんでも叶えてやろう。勿論、私に出来る範囲で\nだが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0103102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「……な、なに！？　わ、私のエッチな体験談を聞きたいだと……！？　き、\n貴様っ……最初からそれが目的で……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0103103" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「いや、私も鬼としてのプライドがある……！　自ら言い出したことを、訂正\nしたりはしない……！　いいだろう。話してやる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0103104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「あ、あれは、私が初めてパイズリというモノをした日のことだ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0103105" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「くうぅ……！　あ、熱い……！　チンポとは、こんなにも熱を持つものなの\nか……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0103106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001601_01_02" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「パワーアップするためとはいえ、こんなモノを挟むとは……このままでは、\n胸が火傷してしまいそうだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0103107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「な、なに？　おっぱいを上下に動かして、チンポをシコシコすれば、熱くな\nくなるだと……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0103108" ]},
		{"command":[ "SETIMAGE", "0", "still_00001601_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「貴様の言うことはイマイチ信用できんが……とにかく、胸で擦ればいいんだ\nな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「ちゃんとシコシコできるか不安だと……？　バカにするな。この轟天童子・\n修羅姫に不可能はない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「ち、チンポの一つや二つ、ちゃんとシゴいてみせる！　いいから、貴様は大\n人しくしていろ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0103111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「んっ……くっ、あっ！　ふっ、ふあああぁぁぁ……！　か、カタいっ……！\n　まるで金棒みたいだ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0103112" ]},
		{"command":[ "SETIMAGE", "0", "still_00001601_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「それに……うぐっ！　擦っていると、変なニオイが……！　クサイのに、妙\nに嗅ぎたくなってしまう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「すぅぅぅ～～～……はあああぁぁ……蒸れたチンポの香りが、頭に響くぅ…\n…！　嗅ぎ続けたら、頭がおかしくなりそうだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「チンポを堪能してないで、もっと胸を擦れ……？　こ、これはイヤでもニオ\nイが鼻につくだけで、別に堪能しているわけではない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0103115" ]},
		{"command":[ "SETIMAGE", "0", "still_00001601_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「パワーアップのためでなければ、誰がこんなことをするものか……！　くっ\n、あふっ……んっ、ああっ！　ふぐっ、あっ、はぁ、あああっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0103116" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETIMAGE", "0", "still_00001601_01_02" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「ど、どうだ……ちゃんとできているだろう？　私にかかれば、チンポを胸で\nシゴくなど容易いことだ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0103117" ]},
		{"command":[ "SETIMAGE", "0", "still_00001601_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「あっ、あんんっ……！　と、ところで、これはどうやったら終わりになるん\nだ……？　ずっとシコシコするのは、流石に疲れるんだが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「パイズリをし続ければ、いつかチンポから精液が出る……？　つまり、射精\nさせれば終わりということだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「い、いいだろう……私のパイズリを思い切り味わわせてやる。覚悟しろよ…\n…！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「ああっ、あんっ……！　くっ、あっ！　あふっ……あっ、ああっ……！　あ\n、汗でどんどん滑りがよくなっていくっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0103121" ]},
		{"command":[ "SETIMAGE", "0", "still_00001601_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「それにチンポの先端から変な汁が溢れて、私の胸に染み込んでくるっ……！\n　ふぐっ、あっ、あんっ……！　くっ、んくうぅぅぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「ニオイも濃くなってきて……胸でシコシコするたびに、鼻の奥が感じて……\n！　な、なんだこの汁は……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0103123" ]},
		{"command":[ "SETIMAGE", "0", "still_00001601_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「チンポが気持ちいいと出て来る、我慢汁……？　なるほど。つまり貴様は、\nおっぱいでシコシコされて、感じているということだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「ふふっ。こんなにも我慢汁を出していれば、射精も近いと見える……少し、\n本気を出してやるとしようか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「ぐっ、あっ……んっ、んむぅ……！　どうだ、私のパイズリは……き、気持\nちいいだろう……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「そんなに首を振って否定してもムダだ。さっきからチンポがビクビクと動い\nて、我慢汁を吹き出しまくっているぞ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「んんっ、はあっ、ああっ……！　あ、熱いチンポが、さらに熱くなって……\nんはああぁ……！　む、胸から貴様の体温が伝わってくるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0103128" ]},
		{"command":[ "SETIMAGE", "0", "still_00001601_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「これはどういうことだ……！？　シコシコすればするほど、熱くなくなるん\nじゃなかったのか……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「もっと汗と我慢汁をおっぱいに染み込ませれば、水分でチンポが冷めていく\nのか……な、なるほど。では、さっそく試してやろう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0103130" ]},
		{"command":[ "SETIMAGE", "0", "still_00001601_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……あっ、くっ、あああぁ……！　確かに一瞬だけ冷たくはなる\nが……シコシコすればするほど、摩擦熱でさらに熱く……はああぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0103131" ]},
		{"command":[ "SETIMAGE", "0", "still_00001601_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「んふっ、ああっ、ひっ、あはあぁ……！　ち、チンポがさっきよりもビクビ\nクして……あっ、んぐっ、ふくうぅ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「私のおっぱいの動きに合わせて、どんどん振動が激しくなってくるっ……！\n　これはいったい、どういうことだ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「しゃ、射精しそうだと……！？　ば、バカ者っ！　そういうことはもっと早\nく言えっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「ああっ！　んっ、あぐっ、ふあああぁ……！？　ど、どうすればいいんだ…\n…！？　んっ、はああぁ！　ビクビクがもっと激しく……あっ、ああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0103135" ]},
		{"command":[ "SETIMAGE", "0", "still_00001601_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「んぶううぅぅぅ！？　白くて熱いのが、どぴゅどぴゅ出ているぅ！？　す、\nすごい量だ……あっ、あんんっ！　あはああぁぁぁ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0103136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001601_01_04" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「それにニオイも酷くて……あひっ、んんっ！　我慢汁よりクサイのに、もっ\nと嗅ぎたくなるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0103137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「すううぅぅぅ……ぐっ、あぐっ！　んっ、あっ、あはあぁぁあんっ！　なん\nだこれは……！　精液のニオイを嗅ぐと、オマンコが疼くぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「こんなの嗅がされ続けたら、本当におかしくなる……！　もっとシコシコし\nてやるから、早くチンポの中にある精液を全部吐き出せっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「んんっ、んぐっ、くうううっ……！　はっ、んっ、うああっ……！　ふっ、\nあっ……んはあぁぁぁぁぁ～～～っ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「はあ、はあぁ……射精したから、これで終わりだな……待っていろ。すぐに\nチンポを拭いて、綺麗にしてやる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0103201" ]},
		{"command":[ "SETIMAGE", "0", "still_00001601_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「えっ……まだ終わりじゃない？　ど、どういうことだ！？　貴様は確かに、\n射精すれば終わりだと言っただろう！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「射精すれば終わりとは言ったが、射精の回数までは指定してない……？　そ\n、そんな屁理屈が通るわけないだろうが！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0103203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「い、いいだろう……また私の胸で、チンポをシコシコしてやる！　だが、あ\nと一回だけだ！　いいな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「くっ、あふっ、ああっ……！　先ほどの精液が、おっぱいにべっとり付いて\n……！　あっ、んんっ！　もっと動きやすくなっている……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0103206" ]},
		{"command":[ "SETIMAGE", "0", "still_00001601_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「こんな状態でおっぱいをシコシコするだなんて……あっ、んひっ……！　そ\n、想像するだけで……オマンコ感じて……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「はあ、はあぁ……ち、乳首もこんなに大きくなっている……！　チンポを擦\nっているだけなのに、なんてはしたないんだ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0103208" ]},
		{"command":[ "SETIMAGE", "0", "still_00001601_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「あはあぁぁぁん！　ち、チンポを動かすなっ！　急かなくても、ちゃんとシ\nコシコしてやるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「んっ、はぁ……あっ、あふっ！　さっきよりも、おっぱいを激しく動かして\n……ほら、これでいいだろう……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0103210" ]},
		{"command":[ "SETIMAGE", "0", "still_00001601_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「もっとおっぱいを寄せて、チンポに圧をかけて欲しいだと……？　注文の多\nいヤツだ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「ぐむっ、んむっ……あっ、あふうぅ……！　もっと胸を寄せて、チンポに刺\n激を……んくっ、ああっ！　はああぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0103212" ]},
		{"command":[ "SETIMAGE", "0", "still_00001601_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「あっあっ！　あああぁ……！　チンポのカタチが、はっきりわかるっ……！\n　この傘みたいなところが、いっぱい胸に当たって……ひぐううぅ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0103213" ]},
		{"command":[ "SETIMAGE", "0", "still_00001601_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「やっ、ああっ！　これ、気持ちいいっ……！　私がシコシコしてる側なのに\n、チンポで感じてしまうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0103214" ]},
		{"command":[ "SETIMAGE", "0", "still_00001601_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「あひっ、んぐっ、ふんくうぅぅぅ！？　か、勝手に動くなっ！　そんなこと\nされたら、余計にチンポを感じて……あああぁん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0103215" ]},
		{"command":[ "SETIMAGE", "0", "still_00001601_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「谷間でぐちゅぐちゅ擦れて、精液のニオイがさらに濃くなってきてるっ……\nあっ、あああっ！　こんなの嗅がされたら、私っ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0103216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ！　は、早くイケっ！　さっきみたいに、いっぱいチンポからび\nゅるびゅる精液を出せっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「くっ、あふっ……あっ、あっ！　んひっ、はああぁ！？　また、さっきみた\nいにチンポがビクビクしているっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0103218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「で、出るんだな……！？　チンポから精液、どぴゅどぴゅ出すんだな……！\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「はっ、早く……いっぱい、出してくれ……！　でないと、私……が、我慢が\n……！　あっ、ああっ！　ふあああああぁ～～～～～！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「あっ、あああんっ！　んんっ、あっ、はああぁぁぁん！？　また熱い精液が\n、おっぱいに出ているぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0103301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001601_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「チンポの先から、いっぱい出てるっ！　私のおっぱいを孕ませるみたいに、\nたくさん……あああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「だ、ダメだっ……！　こんな射精を味わわされたら、イッてしまう……！　\nおっぱいでチンポシゴいて感じるなんて、そんなの……んんん～～～っ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0103303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「ま、まだ射精止まらないのか！？　さっきもあんなに出したのに、まだこん\nなに出るなんて……貴様のチンポは、どうなっているんだ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0103304" ]},
		{"command":[ "SETIMAGE", "0", "still_00001601_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「あああっ、ダメっ……！　今イッたばかりなのに、またイクッ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0103305" ]},
		{"command":[ "SETIMAGE", "0", "still_00001601_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「やっ、ああっ……！　あっ、ふああぁ……あああぁぁぁぁぁん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0103306" ]},
		{"command":[ "SETIMAGE", "0", "still_00001601_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「くっ……あっ……！　はぁ、ああっ……たくさん、出たな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0103307" ]},
		{"command":[ "SETIMAGE", "0", "still_00001601_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「その……つ、次の機会があれば、パイズリをしてやる！　だから今回はこれ\nで終わりだ！　いいなっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「きゃあああぁっ！？　せ、精液が私のおっぱいにかかって……あああっ！　\nあっ、熱いぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0103401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001601_01_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「やっ、やめっ……！　んんっ～～～！？　だ、出すなら、せめておっぱいの\n間にしろ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「こんなにもクサくて、熱い精液を浴びせられたら……私のオマンコが……！\n　あっ、あっ！　んはあああぁぁぁ～～～～！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0103403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「あっ……ああっ……！？　そんな……精液を浴びせられて、イクだなんて…\n…！　こんなの、ありえるわけが……んふうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0103404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「あっ、んんっ、あはあぁぁぁ！？　ま、まだ精液出て……！？　もっ、もう\n出すんじゃないっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0103405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「いい加減、射精を止めろっ！　そんなに出していいなんて、言ってないだろ\nうがっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0103406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「はあ、はあ……やっと終わったか……まったく。どれだけ出す気なんだ……\n！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0103407" ]},
		{"command":[ "SETIMAGE", "0", "still_00001601_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「見ろ。お前のせいで、おっぱいが精液でベトベトだ。肌にニオイも染み付い\nている」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0103408" ]},
		{"command":[ "SETIMAGE", "0", "still_00001601_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「こんなに染み込まされたら、洗っても暫くニオイが残りそうだ……これでは\n、活動に支障が出るぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0103409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「もし次があったら、今度はニオイが残らないよう、パイズリ以外の方法を試\nさせてもらうからな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0103410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}