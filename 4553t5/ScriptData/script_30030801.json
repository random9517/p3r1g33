{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000308_01_03" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「い、いいわよ……そこにオチ○ポを挟み込むの……そう、そのまま……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0803101" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「あっ……んっ……もう、すっかり大きくさせて……最初からそのつもりだっ\nたんでしょう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0803102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「私もって……そ、そんなことはないわ。ただ、その色々雰囲気というか……\n貴方は最近頑張っていたみたいだし……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0803103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「大使館の館長としては、一応ねぎらう必要はあるかなって……その、もちろ\nん誰でもという訳ではないのだけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0803104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「あんっ！　ま、まだ話は終わってないのよ？　もうっ、待ちきれないからっ\nて動かないのっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0803105" ]},
		{"command":[ "SETIMAGE", "0", "still_00000308_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「そう、もう少し大人しくしてなさい。心配しなくても……ちゃんと、する…\n…から……んっ……ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0803106" ]},
		{"command":[ "SETIMAGE", "0", "still_00000308_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「とにかく……聖夜なりの過ごし方って訳ではないけど……おっぱいで、して\nあげるわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0803107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「あ……ふふっ、なぁに……オチ○ポをプルプルさせて……そんなに\n楽しみだったのね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0803108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「ん……挟むわ……ぎゅっと……左右から……ど、どうかしら……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0803109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「柔らかい……？　それはそうよ……私だって、まだまだ肌の張りには自信が\nあるんだから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0803110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「ほら……こうして、ぎゅっとしてあげたら……んっ、気持ちいいでしょう…\n…？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0803111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、それにしても……すごく元気ね……貴方の熱が直接おっぱい\nから身体全体に広がっているみたい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0803112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「んっ……いいわ……大人しくしてなさい……じっくり時間を掛けて扱いてあ\nげるから……んっ、ふっ、はっ……あ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0803113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「またそんなにおっぱいをじっと見て……普段仕事をしている時から、ずっと\n同じところばっかり……そこまでおっぱいが好きな訳？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0803114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「そ、そんなに何度も頷かなくてもいいわ。もう、イヤって言うほど伝わった\nから……そ、それで……私のは……その、どう、かしら……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0803115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「じ、自信がない訳じゃないのよ？　でも、うちの組織にだって魅力的な人は\nいっぱいいるし、比べるものじゃないって分かってるけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0803116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「あ……そ、そうなの。私のだから……気になる……え、えぇ……ありがとう\n。例えお世辞だったとしても……嬉しいわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0803117" ]},
		{"command":[ "SETIMAGE", "0", "still_00000308_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「そうね……それなら、もっと……それだけの期待に応えてあげないとよね。\nうんっ……あ、ふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0803118" ]},
		{"command":[ "SETIMAGE", "0", "still_00000308_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「もう少し滑りやすくさせた方がいいかしら……あ……んっ、でも……結構汗\nかいちゃってるから……大丈夫……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0803119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「匂いとか……平気よね？　ああ、やだ、もう色々気にしちゃって……ちゃん\nと集中しないと……ん、んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0803120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「でも、こうして……間近で見ると……迫力あるわよね……その、貴方のオチ\n○ポ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0803121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「気のせいか……挟み始めた時よりも、大きくなってない……？　まだ膨張し\nちゃうなんてこと……あるの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0803122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「んっ……ふっ、これ以上はダメよ……？　ちゃんと挟みきれなくなっちゃう\nから……今ぐらいがちょうどいいわ……はっ、んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0803123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「あぁ……何だか私も変な気持ちになって来たわ……おっぱいが……すごく、\n敏感になっちゃってるの……んっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0803124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「あんっ……ちょっと乳首が擦れちゃう……えっ……今の、もっとして欲しい\n……の？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0803125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「仕方ないわね……本当に今日だけ、特別よ……？　ここ、あっ……んっ、コ\nリコリさせるの……は、うんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0803126" ]},
		{"command":[ "SETIMAGE", "0", "still_00000308_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「や、やだ……私の乳首の方が……どんどん硬くなっちゃってる……あぁ……\nオチ○ポに当たって……痺れちゃう……んっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0803127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「うん、んふっ、くぅぅ……んんっ……あら……そっちも、カウパーが滲んで\n来たわね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0803128" ]},
		{"command":[ "SETIMAGE", "0", "still_00000308_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「いいわ……ここからは本気で擦るから……んんっ、おっぱいを潰すようにし\nて……右っ……左っ……はっ、あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0803129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「やだ……はしたない……こんなに激しくおっぱい揺らして……淫乱だって思\nわれちゃう……あんっ、はんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0803130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「でも……んっ、貴方が気持ちいいならそれでも……いいわ……ほらっ、もう\n我慢出来なくなってるんでしょう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0803131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「このまま、おっぱいの中に出しちゃいなさい……んっ、ぴくぴく震えてるオ\nチ○ポから……濃いザーメン、射精するのよ……んっ、あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0803132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「はんっ、あっ、あぁっ、いいっ……私もっ……これっ、気持ちいいのっ……\nこのまま出されたらっ、おっぱいでイッちゃうかも……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0803133" ]},
		{"command":[ "SETIMAGE", "0", "still_00000308_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「はぁっ、んふっ、後……少しっ……ダメよっ、我慢しないでっ……全部出す\nのよっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0803134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「ほらっ……おっぱいに中出ししてっ、早くっ……熱いのっ、ぶっ掛けてぇぇ\nぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0803135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「んぁんっ！　あっ……出てるわ……ドロドロのザーメン……谷間に流れ込ん\nで来てる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0803136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000308_01_04" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「んはぁ……嘘……まだ出てくる……もう、貴方……どれだけ溜め込んでたの\nよ……はぁぁ……ねばねば、するぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0803137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……あ……収まったみたい、ね……本当に遠慮なく出してくれち\nゃって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0803138" ]},
		{"command":[ "SETIMAGE", "0", "still_00000308_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「ふふっ、冗談よ。私がそうしてくれってお願いしたんですものね。これだけ\n出たのは、ちゃんと感じてくれたから……よね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0803139" ]},
		{"command":[ "SETIMAGE", "0", "still_00000308_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「ええ……私も気持ちよかったわ……特別な夜のご奉仕……悪くないかもね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0803140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「ただ……どうも、貴方はまだ終わったつもりじゃないようね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0803201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「結構いっぱい出したのに、オチ○ポは硬いまま……それに、おっぱいから離\nれようともしないで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0803202" ]},
		{"command":[ "SETIMAGE", "0", "still_00000308_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「はぁ……分かったわ。ちゃんと続きも面倒見てあげます。もう……意外な所\nで甘えん坊なんだから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0803203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「んっ……貴方の精液のお陰で、お肌がベトベトよ……オチ○ポもヌルヌルじ\nゃない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0803204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「んっく……でも、よく滑る分……より、いいパイズリが出来るかも知れない\nわね……んふっ、こうして……ぎゅっと抑えたまま上下に……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0803205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「あらあら、気持ちよさそうな顔しちゃって……今の、そんなによかった？　\nじゃあ……もうちょっと本気で行くわ……んんぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0803206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「ほら、オチ○ポの皮が剥けたところと……おっぱいの所がぴったり重なって\n……んふっ、擦ってあげたら……あんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0803207" ]},
		{"command":[ "SETIMAGE", "0", "still_00000308_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「あっ……これ、私も……気持ちいいの……はぁ……んんっ、あっ、あぁんっ\n、はっ、あっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0803208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「ちょ、ちょっと……何、腰振り始めてるの……そんなことしなくても、ちゃ\nんとしてあげるわよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0803209" ]},
		{"command":[ "SETIMAGE", "0", "still_00000308_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「こ、この方が……おっぱいを犯してる気になるって……何をさらっと言って\nるの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0803210" ]},
		{"command":[ "SETIMAGE", "0", "still_00000308_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「も、もう……仕方ないわね……こんな性欲の塊を野放しにしていてたら問題\nだもの……私がしっかりしなくちゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0803211" ]},
		{"command":[ "SETIMAGE", "0", "still_00000308_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「んっ……いいわ、腰も振りなさい……でも、程々によ……そんなことしなく\nても、ちゃんと……射精させてあげますから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0803212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「んんっ、はっ、んんっ……もう……そんなに元気になって……しょうがない\nんだから……んっ、はっ、あぁっ、んっ……ふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0803213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「あぁっ、そう……もっとオチ○ポを押し付けて……んっ、おっぱいにめり込\nませるの……乳首もぎゅってして、いいから……きゃふっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0803214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「あっ、あぁっ、こんなおっぱいを犯されてる感じ……あっ、思ったより……\nい、いいかも……はっ、んっ、あぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0803215" ]},
		{"command":[ "SETIMAGE", "0", "still_00000308_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「もっと遠慮しないで動かして……そうよっ、オチ○ポずりゅずりゅって……\nおっぱい擦ってっ……はぁんっ、あぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0803216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「うんっ、くぅんっ……あっ……ピクってオチ○ポが……また、出したくなっ\nたのね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0803217" ]},
		{"command":[ "SETIMAGE", "0", "still_00000308_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「いいわっ、後はもう好きに動かしてっ！　私も……いっぱい扱いてあげるか\nらっ、んっ、くぅぅっ、はっ、んっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0803218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「はっ、んんっ、分かるの……ビクビクして……余裕のない顔をして……んふ\nっ、イキそうなのよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0803219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「だったら、出しちゃいなさいっ……大好きなおっぱいプレスよっ……これで\nっ、ほらっ、射精するのっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0803220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「えっ……中がいいのね？　いいわ……好きになさいっ、オチ○ポ激しくして\nっ、全部出すのよっ、あふぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0803301" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「はぁぁんっ……あっ……また出たわね……さっきよりいっぱい……あぁ、お\nっぱいがドロドロで気持ちいいの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0803302" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000308_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「ふふ……こんなに懸命に亀頭を震わせちゃって……大丈夫よ、慌てないでゆ\nっくり出しなさい、ちゃんと全部受け止めるわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0803303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「んっ……本当にやんちゃなオチ○ポよね……もう、おっぱいの中……精液で\nぐちゅぐちゅよ……これが子宮だったら妊娠しちゃってるわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0803304" ]},
		{"command":[ "SETIMAGE", "0", "still_00000308_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「もう、終わる……？　分かったわ……最後にぎゅうっと……おっぱいで絞っ\nて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0803305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「んふっ……あぁ……出てきたわ……もう残ってないわよね？　全部スッキリ\nするまでは離しませんから。うん、大丈夫みたいね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0803306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「はい、これでおしまい。もう……いくら特別な格好だからと言っても、ちょ\nっと盛りすぎなんじゃないのかしら……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0803307" ]},
		{"command":[ "SETIMAGE", "0", "still_00000308_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「ま、まぁ……スッキリしてくれたなら、それでいいのだけど。あぁ……早く\nシャワー浴びなきゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0803308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「え……一緒に？　こら、何を調子に乗ってるの。特別なご奉仕はもう終わっ\nたのよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0803309" ]},
		{"command":[ "SETIMAGE", "0", "still_00000308_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「ま、まぁ……どうしてもって言うなら、仕方ないけど……ほ、ほら、何して\nるの、さっさと行くわよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0803310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「な……顔に掛けたいって……あ、貴方ねぇ……すぐ調子にのって……あぁん\n、いいわっ、何でもいいから好きになさいっ、ほら、出すのっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0803401" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「んぁぷっ……！　あんっ！　また……こんなにっ、あぁっ、臭くて……粘っ\nこいの掛かってるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0803402" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000308_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「んっ……もう、そんなにオチ○ポを震わせて……大丈夫よ、慌てないでゆっ\nくり出しなさい、ちゃんと全部受け止めるわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0803403" ]},
		{"command":[ "SETIMAGE", "0", "still_00000308_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「あぁ……それにしても、濃厚よね……本当に２回目とは思えない位ドロドロ\nで……ちゅぷ……んっ」」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0803404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「んぁ……喉にも絡みついてくる……こんなの口に出されてたら、とても全部\n飲みきれなかったわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0803405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、後もう少しだけ出そう？　ダメよ、中途半端に我慢なんかし\nないで……出し切りなさい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0803406" ]},
		{"command":[ "SETIMAGE", "0", "still_00000308_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「あんっ！　最後に飛ばしてくれたわね……でも、これで全部出たわね……ふ\nぅ……思ったより大変だったわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0803407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「ま、まぁ……スッキリしてくれたなら、それでいいのだけど。あぁ……早く\nシャワー浴びなきゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0803408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「え……一緒に？　こら、何を調子に乗ってるの。特別なご奉仕はもう終わっ\nたのよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0803409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「ま、まぁ……どうしてもって言うなら、仕方ないけど……ほ、ほら、何して\nるの、さっさと行くわよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0803410" ]},
		{"command":[ "SETIMAGE", "0", "still_00000308_01_10" ]},
