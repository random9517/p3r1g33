{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "貴子" ]},
		{"command":[ "SETTEXT", "「あの、隊長。お呼びと伺いしましたが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0203101" ]},
		{"command":[ "SETCHARA", "0", "char_00012502_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴子" ]},
		{"command":[ "SETTEXT", "「え？　ご、ご奉仕、ですか？　ご奉仕とは、その、一体どんなことを……？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0203102" ]},
		{"command":[ "SETCHARA", "0", "char_00012502_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴子" ]},
		{"command":[ "SETTEXT", "「いえ、それ以前に、どうしてわたくしが隊長にそんなことしなければならな\nいのですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0203103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴子" ]},
		{"command":[ "SETTEXT", "「パワーアップのため……隊長には、そんな能力が？　あの、冗談でしたら、\n欠片も面白くないのですけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0203104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴子" ]},
		{"command":[ "SETTEXT", "「ほ、本当なんですのね……なるほど、確かにここ最近、力をつけてる人が増\nえていますものね。その理由、合点がいきましたわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0203105" ]},
		{"command":[ "SETCHARA", "0", "char_00012502_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴子" ]},
		{"command":[ "SETTEXT", "「そ、そういうことなら……わたくしも、今のままでいいとは思っていません\nでしたから……ですから、し、仕方なくですよ！　仕方なく！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0203106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴子" ]},
		{"command":[ "SETTEXT", "「仕方なくですけど、ご奉仕させていただきますわ。その……た、隊長のペニ\nスを、お口で、させていただきます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0203107" ]},
		{"command":[ "SETCHARA", "0", "char_00012502_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴子" ]},
		{"command":[ "SETTEXT", "「はうっ！？　こ、こんなに、大きい。殿方のこれって、こんなに大きい物な\nんですの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0203108" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00012502_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴子" ]},
		{"command":[ "SETTEXT", "「そうなんですか。隊長のは、特別大きいんですのね。これを……こ、これを\n……うぅぅぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0203109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴子" ]},
		{"command":[ "SETTEXT", "「は、早くって、急かさないでください。こういうのには、覚悟が必要なんで\nすから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0203110" ]},
		{"command":[ "SETIMAGE", "0", "still_00012502_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴子" ]},
		{"command":[ "SETTEXT", "「心を落ち着けて……すぅ、はぁ、すぅ、はぁ……よ、よし。いきますわよ！\n　あーむ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0203111" ]},
		{"command":[ "SETIMAGE", "0", "still_00012502_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴子" ]},
		{"command":[ "SETTEXT", "「んむぅ、ん、むぅ……こ、これへ、よろひい、れふの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0203112" ]},
		{"command":[ "SETIMAGE", "0", "still_00012502_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴子" ]},
		{"command":[ "SETTEXT", "「ふえ？　な、舐める？　咥えるらけじゃらくれ、これを、舐める……う、う\nぅ……れるぅぅ、ん、れる、じゅるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0203113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴子" ]},
		{"command":[ "SETTEXT", "「こ、こう、れふか？　じゅる、じゅる……ん、ん！？　ペニスが、びくっれ\n……んん！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0203114" ]},
		{"command":[ "SETIMAGE", "0", "still_00012502_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴子" ]},
		{"command":[ "SETTEXT", "「えほ！？　えほえほえほ！　げほっ！　う、うぅ……ペニスが、口の中で跳\nねて、喉に……く、苦しくて、びっくりしてしまいましたわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0203115" ]},
		{"command":[ "SETIMAGE", "0", "still_00012502_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴子" ]},
		{"command":[ "SETTEXT", "「あ、あうぅ……ペニスが、わたくしの唾液で、ぬらぬらしてますわ。なんて\n嫌らしい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0203116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴子" ]},
		{"command":[ "SETTEXT", "「わ、分かってますわ。最後まで、ちゃんと……あーむっ！　ん、むぅ、ん、\nじゅるぅぅぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0203117" ]},
		{"command":[ "SETIMAGE", "0", "still_00012502_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴子" ]},
		{"command":[ "SETTEXT", "「は、はひ。くちびる、れも、こすっれ……ん、ぶぅ、ぐぶぅ、んじゅ、じゅ\nる、ぶぅぅぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0203118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴子" ]},
		{"command":[ "SETTEXT", "「んんっ、むぅ、ぶぅ……ひうぅ。に、にほい……鼻から、抜けるぅ。これ、\nくしゃいぃ……んうぅぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0203119" ]},
		{"command":[ "SETIMAGE", "0", "still_00012502_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴子" ]},
		{"command":[ "SETTEXT", "「も、もっろ、激しく、れふか？　そう言われましても、ろうすれば、いいろ\nか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0203120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴子" ]},
		{"command":[ "SETTEXT", "「か、顔を、上下に動かす……わ、分かりましたわ。やってみまふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0203121" ]},
		{"command":[ "SETIMAGE", "0", "still_00012502_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴子" ]},
		{"command":[ "SETTEXT", "「ん、んぐ、ぐぼ、ぐぷ、ぐぽ、ぶぅ、ん、ぐぶぅ、ん、ぶぅぅうぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0203122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴子" ]},
		{"command":[ "SETTEXT", "「ろ、ろう、れすか？　え？　上手、ですか……あはは。褒められると、嬉し\n──」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0203123" ]},
		{"command":[ "SETIMAGE", "0", "still_00012502_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴子" ]},
		{"command":[ "SETTEXT", "「くない！　嬉しくないです！　こんなこと、褒められても、わたくし、全然\n嬉しくなんかありませんからね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0203124" ]},
		{"command":[ "SETIMAGE", "0", "still_00012502_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴子" ]},
		{"command":[ "SETTEXT", "「そんなことより、これ、まだ終わらないんですか？　わたくし、顎が疲れて\n……そうですの。まだ、ですのね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0203125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴子" ]},
		{"command":[ "SETTEXT", "「なら、仕方ありませんわね。続けますわよ。あむぅ、じゅるぅ、ん、ちゅぶ\nぅ、ちゅ、ぶぅ、ぶぅうぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0203126" ]},
		{"command":[ "SETIMAGE", "0", "still_00012502_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴子" ]},
		{"command":[ "SETTEXT", "「んぶ！？　ぺ、ぺにすぅ、びくっれ……まら、びくっれぇ。ひょっろして？\n　そう、なんれふ、ね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0203127" ]},
		{"command":[ "SETIMAGE", "0", "still_00012502_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴子" ]},
		{"command":[ "SETTEXT", "「は、はひっ。ラストスパート、がんばり、まふ！　んぶぅうぅ。んじゅる、\nじゅる、ぶぅ、んぷ、ぷあっ、ん、あぶ、ぶじゅるぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0203128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴子" ]},
		{"command":[ "SETTEXT", "「んぶぶうう！？　ぺにす、びくびくっれ……どんどん、おっきく……んあ、\nん！？　んんんん！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0203129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴子" ]},
		{"command":[ "SETTEXT", "「んぶううぅぅううぅぅぅ！　ん、ぶぅ、じゅぶぅ……う、あぶぅ……く、く\nひの、なかに、どろどろしたの、がぁ……あぶぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0203130" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00012502_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴子" ]},
		{"command":[ "SETTEXT", "「うぅ……口の中、すごいころに、なっれ、まふぅ。ティッシュ、いただけま\nふぇん、か？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0203131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴子" ]},
		{"command":[ "SETTEXT", "「へ？　こ、これを、飲む？　ほんきれ、おっひゃっれるん、れふの？　ぱわ\nーあっぷの、ため？　あ、うぅ、そんらぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0203132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴子" ]},
		{"command":[ "SETTEXT", "「う、うぅ……んく、んっ。ごく……ん、ごく。ごきゅ……ん、んくぅ……ん\n、んっ。こくん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0203133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴子" ]},
		{"command":[ "SETTEXT", "「ぷあっ。はぁ、はぁ、はぁ……の、飲んで、しまいましたわ。わたくし、男\nの人の、あれを、飲んでしまうなんてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0203134" ]},
		{"command":[ "SETIMAGE", "0", "still_00012502_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴子" ]},
		{"command":[ "SETTEXT", "「どろどろしてて、喉に引っかかって、青臭くて、不味くってぇ……こんなも\nの、飲ませるなんて……うぅぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0203135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴子" ]},
		{"command":[ "SETTEXT", "「でも、なんだか、不思議と癖になる感覚で……頭が、ぼうっとしてしまって\nますわ。一体どうしてなんでしょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0203136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴子" ]},
		{"command":[ "SETTEXT", "「それに、気持ち良かったから、出るんですのよね、これって。そう思うと、\n少しだけ、嬉し──」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0203137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴子" ]},
		{"command":[ "SETTEXT", "「くないですわ！　嬉しくないです嬉しくないです嬉しくないですわ！　あ、\n危なかったですわ。危うく、とち狂ったことを言ってしまうところでしたわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0203138" ]},
		{"command":[ "SETIMAGE", "0", "still_00012502_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴子" ]},
		{"command":[ "SETTEXT", "「それぐらい、この匂いと達成感、癖になってしまうようなものがありますわ\n。不思議な能力が秘められていても、おかしくありませんわね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0203139" ]},
		{"command":[ "SETIMAGE", "0", "still_00012502_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴子" ]},
		{"command":[ "SETTEXT", "「と、とにかく、これで奉仕活動は終わりということでよろしいですわね？　\nであれば、わたくしこれで失礼させていただきますわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0203140" ]},
		{"command":[ "SETIMAGE", "0", "still_00012502_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}