{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「フフフ……かなり苦しそうだね……でも、これは君が招いた不幸なんだよ…\n…？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0203101" ]},
		{"command":[ "SETCHARA", "0", "char_00001802_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「私の側に居ると不幸が訪れる……しかも、私を襲おうとすれば、そうなるの\nは必然だよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0203102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「……え？　私の不幸に耐える人……？　フフフ……そんな人、居るワケが…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0203103" ]},
		{"command":[ "SETCHARA", "0", "char_00001802_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「あっ……いや。あの人は……私がお口でしてあげたとき、耐えるどころか…\n…幸せそうだったね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0203104" ]},
		{"command":[ "SETCHARA", "0", "char_00001802_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「ああ、思い出してきたら……身体が疼いてきちゃったよ……！　フフ、フフ\nフ……フフフフフ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0203105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「フフフ……私とこんなことするなんて……思ってもみなかったって顔だね…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0203106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00001802_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「別に気にしなくていいよ……これは私のためでもあるからね……それに、君\nも私のお口を使いたいでしょ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0203107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「いいんだよ……私のお口を道具みたいに使って……君専用の精液便所にして\nくれても……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0203108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「フフフ……おチンポ、もっと大きくなったね……これはもう、お互いに合意\nしたってことでいいよね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0203109" ]},
		{"command":[ "SETIMAGE", "0", "still_00001802_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「それじゃ、契約成立だね……私のお口でいっぱい気持ちよくなって……ザー\nメン出してね……あむっ、んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0203110" ]},
		{"command":[ "SETIMAGE", "0", "still_00001802_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「じゅぷっ、んじゅ……ちゅぱっ、ちゅちゅ……じゅるっ、ちゅぶ、じゅぷぷ\nっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0203111" ]},
		{"command":[ "SETIMAGE", "0", "still_00001802_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「んっ、ちゅぱっ、ぐちゅるっ……！　はあぁ……出したくなったら、好きな\nタイミングで出していいからね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0203112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「私のお口は君専用のザーメンタンクなんだから……遠慮なんてしなくていい\nんだよ……あむっ、ちゅぷっ……じゅちゅ、んじゅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0203113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「ちゅぷっ……ちゅ、じゅぢゅ……！　じゅぱっ、ぢゅぽっ……んぐっ、んむ\nっ……！　ぷはっ……あんまり上手くないフェラチオでごめんね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0203114" ]},
		{"command":[ "SETIMAGE", "0", "still_00001802_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「実はこういうことするの初めてなんだよ……よかったら、君が感じるところ\n……教えて貰ってもいいかな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0203115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「んっ、ちゅ……なるほど。おチンポの先端とか、この傘みたいなところが特\nに気持ちいいんだね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0203116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「じゃあ、この部分を重点的に舐めるね……ぐぶっ、んりゅ……じゅぱっ、れ\nろ……ぐむっ、じゅぽっ……ちゅ、じゅるるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0203117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「はあぁ、くぷっ……んぷぷっ……！　あっ、歯が当たっちゃった……だ、大\n丈夫……？　痛くなかったかい……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0203118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「噛まれたワケじゃないから、大丈夫……？　むしろ、甘噛みされてるみたい\nで気持ちいいの……？　フフフ……そうなんだね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0203119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「なら、もっと甘噛みしながら……いっぱいペロペロしてあげるね……ぐちゅ\n、んぢゅぷっ……ぴちゅ、ぷちゅるっ……ちゅ、ちゅぱっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0203120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「んっ、んむっ……！　ちゅ、じゅずっ……ぢゅぱっ、くちゅるっ……！　お\nチンポの先っぽから、お汁が出てきたね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0203121" ]},
		{"command":[ "SETIMAGE", "0", "still_00001802_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「このお汁も……いっぱい飲ませてもらうね……じゅるるっ……！　ずっ、ぢ\nゅずっ……！　ちゅ、くちゅ……ちゅちゅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0203122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「フフフ……先っぽを吸ったり、おチンポのスジを舐めると……どんどんお汁\nが吹き出してくるね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0203123" ]},
		{"command":[ "SETIMAGE", "0", "still_00001802_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「ちょっとしょっぱいけど……君のエッチなお汁だと思うと、全然イヤじゃな\nいよ……ちゅ、じゅるっ……んちゅ、ちゅぽっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0203124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「んくっ、こくっ……ごくん……！　ああっ……君の体液が私の身体の中に…\n…！　もっと……もっと飲ませて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0203125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ、じゅる……じゅぷっ、ぐちゅ……！　ぐちょ、あむっ……れりゅ\n、ぴちゃ、ぷちゅ……ぢりゅるるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0203126" ]},
		{"command":[ "SETIMAGE", "0", "still_00001802_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「んっ、んぐっ……！　はぁ、あああぁ……！　おチンポ、美味しいよぉ……\n！　こんなの、ずっと舐めてたくなるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0203127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「じゅぷ、ちゅぴっ……！　んっ、あふっ……！　ダメっ……おマンコ、疼い\nてきちゃう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0203128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「君のおチンポがビクビクってお口で跳ねて……私のこと、犯してるって思う\nと……気持ちよくて感じちゃう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0203129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「ぐちゅ、じゅるっ、じゅるるっ……！　もっと奥まで咥えるね……喉の奥ま\nで、突き入れてもいいから……んぐっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0203130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「じゅるっ、じゅるるっ……！　れろっ、ちゅぴっ……ぢゅぷっ、ぢりゅうぅ\nぅぅ……！　んぷっ、ぐぽっ、ちゅるるっ、ぷちゅるうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0203131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「んっ、んんんぅ……！　おチンポ……お口の中で暴れてるぅ……！　私のお\n口、いっぱい犯してるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0203132" ]},
		{"command":[ "SETIMAGE", "0", "still_00001802_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「はぁ、あっ、あんんっ……！　イキそう、なんだね……！　いいよ……好き\nに出して……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0203133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「私のお口に……ザーメン、吐き出して……！　ちゅ、んちゅ……じゅるるっ\n……！　き、君だけの……精液便所にしてっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0203134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「れろっ、ぐちゅ……！　じゅぷっ、ぢゅるうぅ……！　んりゅ、ぐちゅ……\n！　んっ、あむっ……ぐちゅ、ぢゅちゅうううぅ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0203135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「んぶぅっ……！？　んくっ、んぐっ……！　熱いザーメン、いっぱい出たぁ\n……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0203136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001802_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「ぐぼっ、ぐぐぐっ……！　ごくっ、くふっ……！　んっ、んぷぅ……お口の\n中、火傷しちゃいそう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0203137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「すごい勢いで……何度も私のお口や喉を穢して……！　あっ、あああっ……\nじゅる、ちゅぱっ、んぐぶっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0203138" ]},
		{"command":[ "SETIMAGE", "0", "still_00001802_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「わ、私のことなんて、気にしなくていいよ……！　苦しいのも、気持ちいい\nから……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0203139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「君のザーメンも……一滴残らず、全部飲むからぁ……！　じゅぞっ、ちゅる\nるっ……！　じゅぱっ、ぐちゅうぅぅぅん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0203140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「はあ……ああっ……ちゅ、じゅるっ……ザーメン、美味しい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0203201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「おチンポの中に、まだ残ってるね……ちゃんと吸い出してあげるから……ず\nっ、ずずっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0203202" ]},
		{"command":[ "SETIMAGE", "0", "still_00001802_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「んっ、んふっ……！　ザーメン吸い出したら、またおチンポが暴れて……ぐ\nちゅ、ちゅるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0203203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「あっ、あっ……さっきより、カタくなってるね……もしかして、まだ出した\nかったりする……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0203204" ]},
		{"command":[ "SETIMAGE", "0", "still_00001802_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「フフフ……いいよ……好きなだけ私のお口を使って……？　いっぱい犯して\n……メチャクチャにして……！　んっ、んむううぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0203205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「ぐっ、ぐぼっ……！　んっ……おっ、んごっ……！　じゅるっ、ちゅぱっ…\n…ぐっ、ぢゅじゅるっ、んぶうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0203206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「ぷちゅ、れろっ……おっ、おむっ……！　ごぶっ、ぶっ、じゅぶぅ……！　\nいきなり、激しいね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0203207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「でも、この激しさが……私のこと使ってくれてるって気がして……すごく気\n持ちいいよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0203208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「ぐちゅ、じゅるるっ……！　おごっ、うぐぐっ……！　あっ、あっ……！　\nおチンポで犯されるの……たまらないよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0203209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「はあぁ、あああぁ……もっと奥まで咥えて欲しいの……？　うん、いいよ…\n…限界まで、咥え込むね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0203210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「んっ……ぐぼっ、じゅるるっ……！　うぐっ、じゅる……ちゅ、ちゅぱっ…\n…！　げほっ、おっ、おおおぉ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0203211" ]},
		{"command":[ "SETIMAGE", "0", "still_00001802_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「の、喉に直接、エッチなお汁流し込まれてるっ……！　じゅる、れろっ、ち\nゅぷっ……！　これ、好きぃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0203212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「じゅぱっ、ちゅちゅ……！　じゅぞっ、ずりゅうぅ……！　もっとお口でじ\nゅぽじゅぽしながら……舌でペロペロするね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0203213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「私の動きに合わせて、腰を動かしてもいいから……好きなだけお口オマンコ\n……堪能してっ……！　ちゅ、じゅるるっ……ちゅ、ぐずっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0203214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「ぐぽっ、ぢゅぽっ……！　じゅぷ、ずぼっ……！　ぐじゅ、ぢゅぢゅ、んぶ\nぶっ……！　んちゅ、ぴちゅ……ちゅ、ぶちゅ、じゅぞぞぞっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0203215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「あぶっ、うぶぅ……！　お、お口の奥に……傘の部分が引っかかってるっ…\n…！　苦しいけど……気持ちいいよぉ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0203216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
