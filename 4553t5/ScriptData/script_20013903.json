{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0101" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_011" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「実は……実はアヌビスさんが大変なんです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010022750001" ]},
		{"command":[ "SETCHARA", "0", "char_00016501_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "なんとか事情を説明しようとするアーマーン。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "しかし、慌てているせいかその説明はつかみどころがなく……こちらが話を理\n解する前に、張本人がやってきてしまった。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、はぁ……♪　みんな……ここにいたんだね……フフフ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_010022750001" ]},
		{"command":[ "SETCHARA", "0", "char_00008104_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「ぎぃやああああああああ！　来たぁ！　来ちゃった、ガチヤバです～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010022750002" ]},
		{"command":[ "SETCHARA", "0", "char_00016501_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「ねぇ……この姿になってから、とっても幸せな気分なの……。これがハロウ\nィンなのかなぁ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_010022750002" ]},
		{"command":[ "SETCHARA", "0", "char_00008104_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「もしかして、昨日の詠唱の影響か？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「そのもしか、です！　なんか、アヌビスパイセン……無駄に本気を出して呪\n文ヤッちゃったみたいでして……うううう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010022750003" ]},
		{"command":[ "SETCHARA", "0", "char_00016501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「ハロウィンコスプレってゆーより、その……なんていうか！　サ、サキュバ\nス、になっちゃって！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010022750004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「さ……サキュバスですか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010022750001" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「サキュバス……とはなんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090022750001" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あー、サキュバスっていうのは……って悠長に説明してる場合じゃねえ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「も、もうすぐそこまでアヌビス殿が迫ってきてますぞぉおおおお！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022750001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「はぁはぁはぁ……やっと会えた。早く、私と夜の宴……しよ♪　今日は何回\nしてもいいよ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_010022750003" ]},
		{"command":[ "SETCHARA", "0", "char_00008104_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「私が上になる？　それとも、下になる？　好きにしていいよ。ねえ……どこ\nでする？　いっぱいしよ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_010022750004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「待て待て待て待て」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ギリッギリの卑猥な衣装のまま、アヌビスが俺にしなだれかかり、甘い吐息を\n吹きかけてくる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「ふぅ～……♪　んんん♪　もう我慢できない……。ここでいいよ。今すぐし\nよ。エッチ。したい。身体が熱いの……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_010022750005" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「……次から次に、風紀を乱す人達ばかり……！　こんなところで発情しない\nでください！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010022750002" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「そうだぞ。それに、カツマと子作りをするのは私だけだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090022750002" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「素直になっていいよ……。みーんなハロウィンしたいんだよね♪　くちゅく\nちゅで、ぬぷぬぷで、びしょびしょのハロウィン……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_010022750006" ]},
		{"command":[ "SETCHARA", "0", "char_00008104_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「それは絶対ハロウィンとは違うアダルトなアレだ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "俺のツッコミに、サキュバスと化したアヌビスは少し悲し気な表情になった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「……そんなことない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_010022750007" ]},
		{"command":[ "SETCHARA", "0", "char_00008104_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「私のハロウィンは間違ってない……。それをみんなにもわかってもらう……\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_010022750008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「あ、あ、……これはガチヤバかも！　み、みなさぁん！！　逃げてください\nッス！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010022750005" ]},
		{"command":[ "SETCHARA", "0", "char_00016501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「え……？　え？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010022750003" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「きゃあああああああ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010022750004" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「なっ、なんだ！？　この異様な空気は！？　うぁっ……！　包み込まれる！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090022750003" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「えっえええええええ！？　わ、私までサキュバスに！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010022750005" ]},
		{"command":[ "SETCHARA", "0", "char_00001404_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あああっ……なぜだ！？　身体が熱い……少しでも肌を露出したい、カツマ\nとすぐに絡み合いたい……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090022750004" ]},
		{"command":[ "SETCHARA", "0", "char_00000124_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ですから！　公衆の面前で卑猥なことは！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010022750006" ]},
		{"command":[ "SETCHARA", "0", "char_00001404_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「……してはいけないのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090022750005" ]},
		{"command":[ "SETCHARA", "0", "char_00000124_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「私にさせろと言っているんです……♪　カツマさぁん、お洋服ぬぎぬぎしま\nしょうか～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010022750007" ]},
		{"command":[ "SETCHARA", "0", "char_00001404_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「カツマ……♪　この疼き、お前にしか止められないのだ。さあ、愛の口づけ\nを……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090022750006" ]},
		{"command":[ "SETCHARA", "0", "char_00000124_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「あ、では私は下のお口でキスさせていただければ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010022750008" ]},
		{"command":[ "SETCHARA", "0", "char_00001404_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "二人は目をハートにして、発情したまますり寄ってくる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ア、アーマーン！　なんとかしてくれえ！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「それがですね～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010022750006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「すんません……あーしも魔法にかかっちゃいました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010022750007" ]},
		{"command":[ "SETCHARA", "0", "char_00016503_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「最後の希望が打ち砕かれた！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "気付けばサキュバスまみれになってしまったＥＤＯ本部。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "混沌とした状態の中で、俺を助けてくれそうな人は……残念ながら、１人も見\nつけられなかった。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}