{
		"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0117" ]},
		{"command":[ "DISPIMAGE","0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そういえば、今日はＥＤＯ（地球防衛機構）から新戦力が投入される日だっ\nけか？」", "NORMAL" ]},
	{"command":[ "DISPTEXT", "TRUE" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「そういえば、先日そのようなことを長官殿が言っておりましたな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021150001" ]},
	{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「俺としては手のかからないヤツなら誰でも大歓迎だが……ちょっと様子でも\n見に行くか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「様子を見に行くのはいいのですが、この書類の山はどうするつもりですかな\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021150002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そのことを忘れるためにも、様子を見に行くんだよ！　少しぐらい察しろ！\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "bg_0101" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_011" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「えーっと……入口に立ってる子が噂の新人かな？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「小柄な女子（おなご）のようですね。しかも車で送迎されるとは、随分とＶ\nＩＰ待遇ですなあ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021150003" ]},
	{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「イイトコのお嬢様だったりするなら、是非ともお近づきになって玉の輿に乗\nっておきたいもんだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「隊長の権限を振りかざして新人に手を出すとは、クズの極みですな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021150004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まだなにもしてないだろうが！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「にゃふふ♪　あなたが私のご主人様ですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010021150001" ]},
	{"command":[ "SETCHARA", "0", "char_00015701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うおっ！？　な、なんだこいつ……！　人間じゃないぞ！？　それにご主人\n様ってどういうことだ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「姉さん。まずは自己紹介しないと……ご主人様が私たちのこと見て、びっく\nりしてる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010021150001" ]},
	{"command":[ "SETCHARA", "0", "char_00015801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「あっ、それもそうですね。こほん……初めまして、ご主人様。私は猫型メイ\nドロボットのロッテ。こっちは妹のクララです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010021150002" ]},
	{"command":[ "SETCHARA", "0", "char_00015701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「それと外で待機してもらってる車は、ご主人様専用の車……メカニカル・オ\nーガニゼーション・エレクトリックカー。通称ＭＯＥ（モエ）ちゃんです♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010021150003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「私たちはご主人様のために作られた、ご主人様専用のメイドロボットだよ。\n今日からご主人様のところでお世話になるね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010021150002" ]},
	{"command":[ "SETCHARA", "0", "char_00015801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ちょ、ちょっと待て。メイドロボってどういうことだ？　長官の言ってた新\n戦力はどうしたんだ？　それに世話になるってどういう意味だ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ご主人様の疑問に一つずつお答えしていきますから、落ち着いてください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010021150004" ]},
	{"command":[ "SETCHARA", "0", "char_00015701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「そうですぞご主人。今更ロボットの一つや二つで驚くこともないでしょうに\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021150005" ]},
	{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「それもそうなんだが、あまりにも唐突すぎて理解が追い付かなくてな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふふ♪　まずはメイドロボットについて説明しますね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010021150005" ]},
	{"command":[ "SETCHARA", "0", "char_00015701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「メイドロボットっていうのは、言葉通りの意味だよ。私たちは人工的に作ら\nれた存在……自立型のＡＩを搭載した、ロボットなんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010021150003" ]},
	{"command":[ "SETCHARA", "0", "char_00015801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「確かに遠目で見ると小柄な女の子みたいに見えるけど、近くで見るとロボッ\nトって感じがするな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ロボットなのは理解できましたが、ご主人をご主人様と呼ぶのはどうしてで\nすかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021150006" ]},
	{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「私たちのＡＩは、カツマさんをご主人様として認識するように作られてるん\nです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010021150006" ]},
	{"command":[ "SETCHARA", "0", "char_00015701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「だから貴方は私たちの隊長であり、ご主人様なの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010021150004" ]},
	{"command":[ "SETCHARA", "0", "char_00015801_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「急にご主人様って言われても、反応に困るんだが」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふふ♪　可愛い側仕えが出来たと思ってもらえればいいですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010021150007" ]},
	{"command":[ "SETCHARA", "0", "char_00015701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「それで次の質問だけど、ご主人様の言ってた新戦力っていうのは、私たちの\nことだよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010021150005" ]},
	{"command":[ "SETCHARA", "0", "char_00015801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「私たちはご主人様のお世話をするだけじゃなくて、襲来者（インベーダー）\nと戦うこともお仕事の一つなんです♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010021150008" ]},
	{"command":[ "SETCHARA", "0", "char_00015701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「随分と小柄だけど、本当に襲来者（インベーダー）と戦えるのか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「私たちはロボットなので、見た目以上のパワーがありますよ。お望みでした\nら、今ここでお披露目しましょうか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010021150009" ]},
	{"command":[ "SETCHARA", "0", "char_00015701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうだな。どれぐらいのパワーがあるのか、確かめさせてもらおうか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「余計なことはしない方がいいと思いますぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021150007" ]},
	{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「あまり派手なことをするのは気が引けるので……えっと、私の手を握っても\nらえますか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010021150010" ]},
	{"command":[ "SETCHARA", "0", "char_00015701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いいけど……おっ、この肉球の感触。本物の猫みたいだな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「私たちの装甲は、質感とかも忠実に再現してるから……気に入ってもらえる\nと、嬉しいな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010021150006" ]},
	{"command":[ "SETCHARA", "0", "char_00015801_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「それでは、私の実力を見せますね。ちょっと力を入れるので、痛かったらす\nぐにギブアップしてくださいね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010021150011" ]},
	{"command":[ "SETCHARA", "0", "char_00015701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「握力勝負みたいなもんか。まあ、俺がこんな小さなロボ娘に負けるわけが―\n―」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いっっっでえええええぇぇぇえええええぇえええぇぇぇーーーーーーーーー\nーーーーーー！？！？！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ロボット相手なんですから、こうなることぐらい少し考えればわかるでしょ\nうに」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021150008" ]},
	{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ご、ごめんなさい！　ちょっと強くしすぎましたね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010021150012" ]},
	{"command":[ "SETCHARA", "0", "char_00015701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「大丈夫、ご主人様……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010021150007" ]},
	{"command":[ "SETCHARA", "0", "char_00015801_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「だ、大丈夫だ……実力を見せてくれって言ったのは俺だし……気にしないで\nくれ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「そう……？　じゃあ、説明を続けるね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010021150008" ]},
	{"command":[ "SETCHARA", "0", "char_00015801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「最後にお世話になるって話だけど……私たちのＡＩには、ご主人様に仕える\nようインプットされてるんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010021150009" ]},
	{"command":[ "SETCHARA", "0", "char_00015801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「これからは戦闘は勿論、家事や炊事などもサポートさせてもらいますね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010021150013" ]},
	{"command":[ "SETCHARA", "0", "char_00015701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「家事や炊事って言われても、俺はそこまで求めてないんだが……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ご主人様に捨てられたら、私たちは行くところがなくなる……だから、側で\n仕えさせて欲しいな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010021150010" ]},
	{"command":[ "SETCHARA", "0", "char_00015801_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「そうですよー。私たちは優秀なメイドロボなので、必ずお役に立ちますよ♪\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010021150014" ]},
	{"command":[ "SETCHARA", "0", "char_00015701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そんな風に言われると、断りづらいというか、なんというか……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「な、なんだ！？　襲来者（インベーダー）か！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「そのようですね。私のサーチ機能によれば、市街地の方でワームホールが開\nいたみたいです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010021150015" ]},
	{"command":[ "SETCHARA", "0", "char_00015701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「そのような機能まで備わっているとは驚きですな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021150009" ]},
	{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「これぐらい、私たちＡＩロボットには標準装備だよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010021150011" ]},
	{"command":[ "SETCHARA", "0", "char_00015801_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「話はあとだ！　とりあえず現場に急ぐぞ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「カツマちゃん！　話は聞かせてもらったわ！　早く私に乗って！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010021150001" ]},
	{"command":[ "SETCHARA", "0", "char_00011101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「車がしゃべったあああああぁぁぁーーーーー！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ＭＯＥちゃんも私たちと同じでＡＩを搭載してるので、喋ることぐらいでき\nますよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010021150016" ]},
	{"command":[ "SETCHARA", "0", "char_00015701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ただの車じゃなかったのか！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ご主人様。驚くのはいいけど、早く現場に行かないと被害が出るよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010021150012" ]},
	{"command":[ "SETCHARA", "0", "char_00015801_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そ、それもそうだな！　よし、現場に急ぐぞ！　みんな車に乗ってくれ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ＭＯＥ" ]},
		{"command":[ "SETTEXT", "「任せて、カツマちゃん！　私の加速ならすぐに到着するからね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010021150002" ]},
	{"command":[ "SETCHARA", "0", "char_00011101_01", "0", "CENTER", "0" ]},
