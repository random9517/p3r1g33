		{"command":[ "PLAYVOICE", "002_0103303" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ……まだ出てるっ、びゅく、びゅくって、精液がいっぱいっ……\nおっぱいの中に、中出しされちゃってるっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0103304" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んあぁ、すごいよぉ……濃くてどろどろしたエッチなミルクが、どんどんお\nっぱいの中に注ぎ込まれて、べとべとになっちゃうぅっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0103305" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あぁっ、なにこれぇっ……精液がべったりとへばりついて、全然落ちないよ\nぉ……それにすごくエッチな臭い……あぁっ、本当に妊娠しちゃいそう……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0103306" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「このおっきくて固いオチンチンを、あそこに入れられちゃったら……ビンビ\nンのオチンチンで、あそこの中をゴシゴシ擦られちゃったらっ……んあぁっ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000201_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0103307" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あふれるくらいに精液を注がれてっ、奥の赤ちゃんの部屋もいっぱいにされ\nちゃうぅ……赤ちゃんの素を、たくさん仕込まれちゃうぅっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0103308" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「……でも、あなたのだったら……あなたの赤ちゃんだったら……私は、それ\nでも……はあぁぁっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0103309" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あんっ……オチンチンがぴくぴくして……あなたも興奮してるの？　……も\nう、エッチなんだから……うふふっ」", "NORMAL" ]},
