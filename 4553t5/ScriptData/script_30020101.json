		{"command":[ "PLAYVOICE", "002_0103407" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「忍びなのに、こんなに精液の臭いをつけられて……エッチな臭いを身体に染\nみ込まされされちゃったら、隠れていてもすぐにバレちゃうよぉ……」", "NORMAL" ]},
