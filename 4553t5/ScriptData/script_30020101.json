		{"command":[ "WAITMOVE" ]},
		{"command":[ "PLAYVOICE", "002_0103101" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「……こんなところに呼び出して、私に何か用事……？　……そのイヤらしい\n笑顔は……もしかして、また、エッチなこと考えてる……？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "2", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
        {"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0103102" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「……もう、本当にいつまでたっても、変わらないんだから……それで、私は\nなにをすればいいの？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0103103" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「……っ～～～！？　お、おっぱいで、あなたのオ、オチンチンを挟んで、擦\nる……！？　そ、そんなイヤらしいこと……っ！！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0103104" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「……それは、命令なの……？　……そう、またエッチな命令するのね……あ\nなたは本当に卑怯で、スケベなんだから……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0103105" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「……でも、命令なら仕方ない……早く済ませちゃうから、どうすればいいか\n、やり方を教えて……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0103106" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「……本当は、命令なんてしなくたって、あなたなら……な、なんでもない…\n…！　と、とにかく、どうすればいいの……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0103107" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「……おっぱいを寄せて、オチンチンをぎゅって挟む……んっ……どう……？\n　これでいい……？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000201_01_01" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0103108" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「はぅ……おっぱいの中に、固くて熱いのが、挟まって……これがあなたのオ\nチンチン……すごい、びくん、びくん、てしてる……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0103109" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「このまま、上下に擦ればいいの……？　ひぁ、オチンチンがビクビクしてる\n……もしかして、気持ちいいの……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0103110" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「……もう、こんなことがしたいだなんて……本当にあなたは、イヤらしくて\n、変態なんだから……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0103111" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「……あなた以外に言われたら、闇討ちするか、罠にかけて殺しているところ\nよ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0103112" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ、ふぅっ……これで、いいの……？　オチンチンがさっきよりも\n、ビンビンに腫れて熱くなってるけど……大丈夫……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0103113" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「……これが気持ちいいってことなの……？　だ、だって、オチンチンを触る\nのなんて、あなたのが初めてだから、良くわからなくて……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0103114" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「こうやって、おっぱいとおっぱいで、オチンチンを優しく包み込んで……ん\nっ、ふっ……上下に擦って……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0103115" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ふぁぁ……熱々のオチンチンが、おっぱいに出たり入ったり……ふぅっ、ふ\nぅっ……すごくエッチだよぅ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000201_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0103116" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ふぁ、あっ、あっ……固いオチンチンでおっぱいが擦れて……んふぁ……あ\nそこがムズムズしてきちゃう……ふぁぁっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0103117" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あんっ……！　オチンチンが、おっぱいの中でびくびく跳ね回って、飛び出\nしていっちゃうっ……！　もう、オチンチン、落ち着いて……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0103118" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「……もっと、強く挟んでもいいの……？　でも、痛くないかな……？　……\nじゃあ、オチンチンがつぶれるくらい、おっぱいを押し付けて……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0103119" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んんっ……オチンチンがおっぱいの中にほとんど隠れちゃった……このまま\n、ぎゅって押し付けながら、上下に擦って……んっ、ふっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0103120" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んあぁっ……さっきよりもいっぱい擦れるっ……んぅっ……オチンチンのイ\nヤらしい形が、はっきりとわかっちゃうっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0103121" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ビンビンに固くなってて、すごく凸凹してて……あんっ、あぁっ……さきっ\nぽのでっぱりが、ごしごし擦れちゃってるっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0103122" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「オチンチンて、すごくエッチな形をしてるのね……ビンビンに固くて、おっ\nきくて……こんなところばっかり、男らしいんだから……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0103123" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あっ、やだっ……オチンチンのさきから、変なお汁が出てる……んあぁっ…\n…ヌルヌルして、エッチな臭いがするよぉっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0103124" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「イヤらしい臭いで、頭がくらくらしてきちゃうっ……あぁんっ、おっぱいの\n中でオチンチンがにゅるにゅる擦れて、イヤらしい音がなっちゃうっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0103125" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ひゃんっ、なにっ……！？　オチンチンがびくびく震えて、破裂しそうなほ\nど、ビンビンに晴れちゃってるっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0103126" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「出るって……精液が、出ちゃうの……？　オチンチンのさきっぽから、また\nエッチなお汁が出てくるのっ……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0103127" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「私のおっぱいでオチンチンを押しつぶされながら、にゅるにゅるシゴかれて\n……んふぁっ、オチンチンから、精液を出しちゃうのっ……！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0103128" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あぁっ、すごくイヤらしい顔して……そんなに私のおっぱい、気持ちいいの\nっ……？　本当に、スケベなんだからっ……んふぅっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0103129" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、やだっ、オチンチンのさきっぽが、パンパンに膨らんで、お口\nが金魚みたいに、パクパクしてるよっ……！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0103130" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「もう出ちゃうのっ？　いいよ、出してっ……！　おっぱいでオチンチン激し\nくシゴかれて、エッチなミルク、いっぱい出してぇっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0103131" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ひゃぁうっ！？　ふぁっ、あっ、あっ……！　すごい、オチンチンのさきっ\nぽから、精液が勢いよく、飛び出しちゃってるっ……！」", "NORMAL" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000201_01_06" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0103132" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「びくん、びくんて、オチンチンが震える度に、びゅうっ、びゅうっ、って…\n…んあぁっ、エッチなミルクがおっぱいの中に注がれちゃうっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0103133" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あぁっ……精液、熱いよぉ……ドロドロのマグマみたいで……んふぅぅっ、\nおっぱいが火傷しちゃうっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0103134" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「……全部、出たの？　ふぅ……やだっ、おっぱいの間がぬるぬるになっちゃ\nってる……精液ってこんなにたくさん出ちゃうの……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0103135" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「……私のおっぱいが気持ちよくて、たくさん射精しちゃったの……？　そう\n……もう、エッチなんだから……うふふっ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000201_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0103136" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ふあぁ……おっぱいの中が精液でぬちゃぬちゃのドロドロに汚されちゃった\nよぉ……んふぁ、すごく、イヤらしい臭いがするぅ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000201_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0103137" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「エッチで、香ばしくて……これが、精液の匂い……？　あぁっ……頭の奥が\nじんじん、しびれてきちゃうぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0103138" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「精液を出されちゃったところから、おっぱいに熱がうつってくるみたいで…\n…心臓がどくどくいってる……あぁ、身体が熱くなってきちゃう……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0103139" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……ぬるぬるして、熱くて、エッチな臭いで……んふぁ、頭が変\nになっちゃいそう……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0103140" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「身体に覚えさせられちゃうぅ……エッチな精液の臭いと感触を、覚え込まさ\nれちゃうぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0103201" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あんっ……！　オチンチンがビクビクして、ガチガチに固くなってきた……\nもしかして、もっとおっぱいでしてほしいの……？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000201_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0103202" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「……もう、本当にしょうがないんだから……また、おっぱいでゴシゴシ、オ\nチンチンを擦ればいいの……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0103203" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「……ひゃうっ、やだっ、精液でおっぱいもオチンチンも、ヌルヌルになっち\nゃってるぅ……にちゃにちゃ、すごくエッチな音がしてるよぉ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0103204" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「イヤらしい顔してる……ヌルヌルのおっぱいで、オチンチンをぬちゃぬちゃ\n擦られるのが、興奮するの……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0103205" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「……そんなに嬉しそうな顔されたら、私まで嬉しくなっちゃうよぉ……私の\nおっぱいで、もっと気持ちよくなって欲しくなっちゃう……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0103206" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「……いいよ、あなたのエッチな精液でどろどろになったおっぱいで、ビンビ\nンのオチンチンをねちゃねちゃシゴいてあげるね……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0103207" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「こうやって……んっ……オチンチンがつぶれちゃうくらい、おっぱいでぎゅ\nうぎゅうに挟まれるのが好きなのよね……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0103208" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んっ、ふぅっ……おっぱいで挟んだまま、にゅちにゅち上下にシゴかれると\n……気持ちよくなっちゃうんでしょうっ……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0103209" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ガチガチになった先っぽのところも、してほしいの……？　おっぱいで包み\n込んで、たっぷり中出しされた精液で、にゅるにゅるされたいのね……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0103210" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あんっ……さっきよりもビンビンになったオチンチンが、おっぱいの中でヌ\nルヌル擦れてるぅ……あぁんっ、おっぱいが変になっちゃいそうっ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000201_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0103211" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あなたにイヤらしい命令をされて、エッチなご奉仕をしてっ……あぁんっ、\nおっぱいの中が犯されちゃってるっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0103212" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あぁっ、オチンチンが焼いた鉄の棒みたいに熱いよぉ……カチカチに固くな\nって、おっぱいの中をぐりぐり擦ってるぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0103213" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「こんなの形を覚えちゃうっ……私のおっぱいが、あなたのオチンチンの形に\nされちゃうよぉ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0103214" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「オチンチンの焼きごてをされて……あぁっ、あなたのオチンチンをシゴくた\nめの、専用おっぱいにされちゃうぅっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0103215" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んあぁっ、あっ、あっ……にゅるにゅるのおっぱいに、オチンチンが出たり\n入ったりしてぇ、すごくエッチだよぉ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0103216" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「まるで、あそこに入れられてるみたいっ……あぁんっ、おまたが濡れてきち\nゃうっ、切なくなっちゃうっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0103217" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「もし、あそこにオチンチンを入れられたら……こんなに固くて大きなものが\n入ってきたらっ、どうなっちゃうのっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0103218" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
