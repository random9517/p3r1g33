		{"command":[ "PLAYVOICE", "v2_012_0303106" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「エッチなことばーっかり考えてるんだね、ほんといけない人なんだ～」", "NORMAL" ]},
