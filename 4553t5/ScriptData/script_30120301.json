		{"command":[ "PLAYVOICE", "v2_012_0303102" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「これ絶対にウソだよね？　だって、警備員さんのオチンチンこ～んなにもカ\nチコチになっちゃってるし～」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYVOICE", "v2_012_0303103" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「おっぱいに挟んじゃってるもんね？　それでさ～、わたしにどうして欲しい\nのかな？　んふふふ」", "NORMAL" ]},
