{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0031" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「はい、そういうわけでカツマたちは、セレーナ相手に人生相談を始めました\nが、こちらはと言いますと……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_010115030001" ]},
		{"command":[ "SETCHARA", "0", "char_00022701_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「オボロ……オボロですか。たしかにウチも、なんだか気になっていたですが\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110115030001" ]},
		{"command":[ "SETCHARA", "0", "char_00000511_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「過去にオボロと、なんかあったのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_040115030001" ]},
		{"command":[ "SETCHARA", "0", "char_00015604_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「それは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110115030002" ]},
		{"command":[ "SETCHARA", "0", "char_00000511_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈ・Ｍサムライ" ]},
		{"command":[ "SETTEXT", "「残念だがハルノブは、昔の記憶を失ってしまっているのだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_020115030001" ]},
		{"command":[ "SETCHARA", "0", "char_00014502_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「そうだったのか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_040115030002" ]},
		{"command":[ "SETCHARA", "0", "char_00015604_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈ・Ｍサムライ" ]},
		{"command":[ "SETTEXT", "「うむ。自分の名前すらわからぬ状態で『ザ・ハンド』の客分となった。覚え\nていたのは『月』と『兎』という文字だけ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_020115030002" ]},
		{"command":[ "SETCHARA", "0", "char_00014502_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈ・Ｍサムライ" ]},
		{"command":[ "SETTEXT", "「ふふふ、思い出すのう。あのときは――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_020115030003" ]},
		{"command":[ "SETCHARA", "0", "char_00014502_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "sbg_0185" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
		{"command":[ "SETNAME", "Ｈ・Ｍサムライ" ]},
		{"command":[ "SETTEXT", "「ふふふふ、名前が欲しいな。『記憶喪失の女』じゃあ今いち呼びにくいッ！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_020115030004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「そうですか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110115030003" ]},
		{"command":[ "SETCHARA", "0", "char_00000511_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈ・Ｍサムライ" ]},
		{"command":[ "SETTEXT", "「このマッポー・サムライが名付け親になってやるッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_020115030005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「どうでもいいですが、そのテンションはなんなんですか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110115030004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈ・Ｍサムライ" ]},
		{"command":[ "SETTEXT", "「そうだな……『月の兎』を描いた絵師にちなんで『ハルノブ』というのはど\nうかな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_020115030006" ]},
		{"command":[ "SETCHARA", "0", "char_00014502_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ハルノブ……ですか。悪くはないですが、なぜ絵師にちなんで？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110115030005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈ・Ｍサムライ" ]},
		{"command":[ "SETTEXT", "「べ、別に……憎っくきあのウサピョン忍者どものマネをしたんじゃないぞ！\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_020115030007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「誰の話をしてるんですか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110115030006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0031" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
		{"command":[ "SETNAME", "Ｈ・Ｍサムライ" ]},
		{"command":[ "SETTEXT", "「と、いうことがあってだな――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_020115030008" ]},
		{"command":[ "SETCHARA", "0", "char_00014502_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「オボロの言った通りだ！　やはりここにおったか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100115030001" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈ・Ｍサムライ" ]},
		{"command":[ "SETTEXT", "「むむっ！？　人の思い出話の腰を折るとは！　スゴイ＝マナー違反な！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_020115030009" ]},
		{"command":[ "SETCHARA", "0", "char_00014502_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「うるさい！　さっきはよくも邪魔してくれたな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080115030001" ]},
		{"command":[ "SETCHARA", "0", "char_00000408_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「おっと！　また出てきました縄張り荒らし！　今度は、私たちが戦うしかな\nさそうです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_010115030002" ]},
		{"command":[ "SETCHARA", "0", "char_00022701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「だったらカメラ止めろっつーの！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_010115030001" ]},
		{"command":[ "SETCHARA", "0", "char_00022801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}