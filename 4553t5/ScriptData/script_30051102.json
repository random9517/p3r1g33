		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ウチのことを散々開発してくれて……あぁ、もう……待ちきれないです……\n入れちゃいますよ……？　いいですよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1104102" ]},
		{"command":[ "SETIMAGE", "0", "still_00000511_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「っ……な、何でですか。貴方だってしたい筈です……ウチが、いいって……\n一線を越えていいと……そう言っているんですよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1104103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ひぁっ！　なっ……何で急に、お尻を叩くですっ？　こんなのっ……絶対お\nかしいですっ……ウチのことを何だと思って……あんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1104104" ]},
		{"command":[ "SETIMAGE", "0", "still_00000511_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はぁんっ、ああっ……だからっ、ウチはウチですっ……他の誰でも……ない\nですっ……マスクもっ……取りませんからっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1104105" ]},
		{"command":[ "SETIMAGE", "0", "still_00000511_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「あんっ！　そんなオチンチン擦りつけないで下さいっ……んぅっ……するな\nらっ、一思いにっ……こんなっ、焦らすなんてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1104106" ]},
		{"command":[ "SETIMAGE", "0", "still_00000511_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ま、待ちきれなくなってる訳じゃっ……あんっ、はぁっ、でも……ウチ……\nウチはっ……あぁっ、そこぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1104107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んくぅぅ……や、やっぱりダメです……ムリです……もう、ウズウズが止ま\nらないんですから……あぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1104108" ]},
		{"command":[ "SETIMAGE", "0", "still_00000511_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「分かりました……ちゃんとおねだりしますから……だから、もう焦らさない\nで下さい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1104109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……お願いします……発情した……ウチのオマンコを……貴方の\n太いオチンチンで……埋めて下さい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1104110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「させてあげるなんて……偉そうにしてましたけど、本当は……ウチがして欲\nしくて……仕方ないんです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1104111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ほら……ここぉ……もう、ヌルヌルで……待ちきれなくなってる、オマンコ\nぉ……そのまま、オチンチンでぶすってぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1104112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「深く串刺しにしてぇっ……ウチのっ、いやらしいオマンコっ……オチンチン\nハメて下さいぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1104113" ]},
		{"command":[ "SETIMAGE", "0", "still_00000511_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「は……ぁぁぁぁぁんっ！　あぁっ……くぅぅぅんっ……いきなりっ……一番\nっ、奥ぅっ……あっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1104114" ]},
		{"command":[ "SETIMAGE", "0", "still_00000511_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「あぁぁ……入ってます……んんっ、そうですっ……これが、んんっ、欲しか\nったやつぅ……あぁ……すごい、ですぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1104115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「く……はぁぁ……オチンチン大きいです……中……オ、オマンコ……広げら\nれちゃいます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1104116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「あ……んくっ……う、動かすのはちょっとだけ、待って下さい……心の準備\nが……か、感じ過ぎるので……ぁふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1104117" ]},
		{"command":[ "SETIMAGE", "0", "still_00000511_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「大丈夫です……想定より、少し……太い感じだっただけで……深呼吸すれば\n、何とかなるですから……すぅぅ……はぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1104118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「は、はい。もう……いいですよ。ウチの……中、どうか……好きなように…\n…か、かき回して下さい……んぁっ、はっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はんっ、あっ、あぁっ……擦れるぅ……中のヒダヒダが、広げられる感じ…\n…しますぅ……んくっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1104120" ]},
		{"command":[ "SETIMAGE", "0", "still_00000511_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んんっ、はんっ、くぅぅ……これ、ダメなやつです……あぁ……ウチの発情\nしてる身体にっ……伸し掛かってくる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1104121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はへぁっ……あぁぁ……やぁっ、ぐちゅぐちゅって……音、しちゃってます\n……ウチのオマンコから、いやらしい音ぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はんっ、あぁっ、そ、そこぉっ……感じますっ、どうして……ウチの弱い所\n……全部、バ、バレてるぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1104123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はんっ、あぁっ、何でこんなにっ……ウチのことっ、分かるですっ？　激し\nいのにっ、痛く……なくてっ……力加減が絶妙でっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1104124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「あぁっ……は、はいっ……気持ちっ……いいですっ、貴方のオチンチンでっ\n……ウチのオマンコっ……気持ちよくなってますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1104125" ]},
		{"command":[ "SETIMAGE", "0", "still_00000511_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んぁぁっ、も、もっとかき混ぜて下さいっ、はひっ、もっと強くてもっ……\nあんっ、大丈夫っ、ですからぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「あひぃんっ！　ま、またっ、お尻ペンペンされてるぅっ！　こんなのっ、く\n、悔しい筈なのにっ……ジンジン痺れてっ、気持ちっ……よくてぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1104127" ]},
		{"command":[ "SETIMAGE", "0", "still_00000511_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ひぁんっ！　も、もうイクっ、あっ、イッちゃいますっ……すぐにイッちゃ\nうっ……あひんっ、イキッ……ますぅぅぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はぁぁ……んっ、あぁ……イカされちゃいました……何で、こんなに手玉に\n取られてる感じに……おかしいです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「え……は、初めての感じじゃない……？　そんなこと……ウチと貴方は、初\nめてで……あっ……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「あっ、はぁっ……確かにっ、そこはっ……好きなトコっ……くぅっ、ウチが\nして欲しいとこぉっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「あぁっ、はんっ、あっ、あぁっ……イッたばっかりなのに、はんっ、どんど\nん気持ちよくなってっ……あんっ！　また、お尻叩かれてぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ひうっ、んんっ、くぅんっ！　あぁっ、もっと激しくっ……あひっ、貴方も\nっ……出るんですかっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1104133" ]},
		{"command":[ "SETIMAGE", "0", "still_00000511_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「あぁっ、はひっ、どうにでもっ……このまま、最後までっ……して下さいっ\n……射精っ、大丈夫ですからぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「中にっ……出してっ、ウチのオマンコにっ……濃い精液っ……オチンチンっ\n、いっぱいっ、出してぇぇぇぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1104135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んぁぁぁぁぁぁぁーっ！　出てますっ……あくぅんっ、またっ……熱いのっ\n……来るぅぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1104136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000511_02_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はぁぁ……勢いがっ、びゅくって……お腹……オマンコ……いっぱいにさせ\nられてますぅ……んへぁぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1104137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「あふ……んっ、や、やっと……落ち着いて来ました……まだ、オマンコ敏感\nなままですけど……はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1104138" ]},
		{"command":[ "SETIMAGE", "0", "still_00000511_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「まさか、ここまで……ウチが何も出来ないなんて思いませんでした……はぁ\n……はふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1104139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「あぁ……あったかいです……お腹の奥が満たされてる感じ……ウチは……本\n当にダメになってしまったかも知れません……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んぁっ……ま、まだ……オチンチン動いて……このまま、続き……ですか？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1104201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「どうせ、ウチに拒否権はありません……好きなようにすればいいです……ん\nっ、ふっ、けど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「くぅんっ……それならっ、ウチもっ……んんっ、ふっ、んぅっ、くんっ……\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1104203" ]},
		{"command":[ "SETIMAGE", "0", "still_00000511_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ふふっ……どうしました？　ちょっと、声に余裕がなくなって……来ました\nよ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1104204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ええ、ウチだって……一方的にされたままではいられません……何となく、\nんっ……貴方の……動きのクセは分かりました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1104205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「後はタイミングを合わせて、ぎゅっと……オマンコに力を入れたら……はん\nっ！　気持ちよくっ……出来る筈ですっ、ふぁっ、んくぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1104206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んふっ、あぁっ……ほら、これ……いいでしょう？　ウチのヌルヌルが、オ\nチンチンに……しっかり纏わりついて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「敏感な場所をっ……ずりゅって擦ってっ……絶対気持ちいいに決まってます\nっ……んふっ、くぅんっ、あっ……はっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1104208" ]},
		{"command":[ "SETIMAGE", "0", "still_00000511_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「くふっ、息が荒くなって来ましたよ……？　もっと、やらしく……お尻……\n振ってあげますからっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「リズムに合わせてっ……うんっ、はっ、んっ、くんっ、はふっ……これ……\nちょっとした、ロデオ気分ですっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1104210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「オマンコ……キュンってさせながらっ、オチンチン乗りこなしてっ……いい\n感じになって……来てますよねっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1104211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「た、ただ、これはっ……ウチも……感じるのがっ……ちょっと、アレです…\n…オチンチンっ……ぐりってされるとぉっ、はひぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1104212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「また、あぁっ……ジワってイキそうにっ……ひんっ！　あっ、んぁぁぁっ…\n…イッ……くんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1104213" ]},
		{"command":[ "SETIMAGE", "0", "still_00000511_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はぁぁ……これ、簡単にスイッチ入っちゃいます……気持ちいい……もっと\n、して……オマンコかき回して下さい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1104214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んんっ、あっ、はぁぁぁっ、激しいっ……いっぱい突いてっ、くぅんっ、お\n尻もっ……ペンペンして下さいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1104215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「あんっ、はぁぁぁんっ！　イジめられてるのに気持ちいいっ！　ウチもっ、\n腰を回してっ……んあんっ、頑張りますぅっ、んぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1104216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ふんっ、はっ、んんっ、あぁっ、激しいっ……オチンチンッ……突かれてっ\n……あぁっ、この速さっ……もうすぐですかっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1104217" ]},
		{"command":[ "SETIMAGE", "0", "still_00000511_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はいっ……欲しいっ、精液欲しいですっ……どこでもっ、何でもいいですか\nらぁっ！」", "NORMAL" ]},
