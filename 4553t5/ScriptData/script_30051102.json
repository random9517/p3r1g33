		{"command":[ "SETIMAGE", "0", "still_00000511_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「あぁ……でも、そうだったとしてもウチは……んっ、あぁ……もう、ここま\nで来たら出し切って下さい……オチンチン、もっと射精してぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1104304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んっふ……あぁ……ドロっと溢れて来ちゃいます……は、はしたない……あ\nぁ……粘っこいの、飲みきれないです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1104305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……終わりましたか……んっ、トロトロのが溢れてる……くん、\nくんくんっ……んはぁぁぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1104306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
