{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0195" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「ほらほらお二人とも、まずは離れてください。こんにちはカツマさん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_020023320001" ]},
		{"command":[ "SETCHARA", "0", "char_00018202_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ハルミ？　なんでお前がここに？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「派遣ですよ～。籠絡部とはまた別件です。掛け持ちが許されるっていいこと\nですよね～。今はｓｕｃｃｕＢｉの派遣社員やってます～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_020023320002" ]},
		{"command":[ "SETCHARA", "0", "char_00018202_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なるほど。それで、肝心なことってなんだ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「そりゃあもう、ｓｕｃｃｕＢｉの問題点ですよ～。会社を立ち上げたのはい\nいけれど、全く仕事がないんですよね～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_020023320003" ]},
		{"command":[ "SETCHARA", "0", "char_00018202_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「毎日暇で暇で～。雑務で雇われたのにその雑務がまったくないっていう状況\nなんですよ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_020023320004" ]},
		{"command":[ "SETCHARA", "0", "char_00018202_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「座ってるだけで賃金が出るってのもそれはそれでいいことだと思うが」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「健全じゃないですよ～。人間、仕事をしてないとそのうち精神が腐っちゃい\nますよ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_020023320005" ]},
		{"command":[ "SETCHARA", "0", "char_00018202_01", "3", "CENTER", "0" ]},		
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まあ、分からんでもないが」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「さすが、精神がすでに腐っているご主人はよくご存じの様子」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023320001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はっ倒すぞお前。で、仕事が欲しいのか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「そうですそうです～。私、こういうことなら得意なんですけどね～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_020023320006" ]},
		{"command":[ "SETCHARA", "0", "char_00018202_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おっ、ふっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ああ、二の腕タッチ。ご主人は二の腕タッチにも弱い」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023320002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「ねぇ～カツマさん～どうにかならないですか～？　私、こういうお仕事なら\n全力でこなしますよ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_020023320007" ]},
		{"command":[ "SETCHARA", "0", "char_00018202_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「う……うーん……そう言われてもなあ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「今度は胸筋さわさわに太ももタッチ。ご主人はこれにも弱い」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023320003" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「なんだか……弱点だらけですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_010023320001" ]},
		{"command":[ "SETCHARA", "0", "char_00026901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「仕方ないのです。ご主人……いや、この世の男は皆、女性からのタッチに弱\nいのです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023320004" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「それはジュンジローさんもですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_010023320001" ]},
		{"command":[ "SETCHARA", "0", "char_00027001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「無論。あなた方のような美女に身体を撫でられればほら、私の尻尾はこの通\nり」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023320005" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「わあ……ものすごい勢いで揺れてる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_010023320002" ]},
		{"command":[ "SETCHARA", "0", "char_00026901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「ねえ～カツマさん。ちょっとだけ、ちょっとだけ頼りになるあなたのアドバ\nイスが欲しいな～って」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_020023320008" ]},
		{"command":[ "SETCHARA", "0", "char_00018202_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そ、そこまで言われたらな～。うへへへへへ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ああ、あれは身体を密着させてうるうる眼で見上げる連携技……あれに勝て\nる男はおりますまい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023320006" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「ていうか、あの人私たちよりサキュバスっぽいことをしているんですが……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_010023320003" ]},
		{"command":[ "SETCHARA", "0", "char_00026901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「サキュバスのムーブがフィットしていますね……いや、これは貴梨果の力を\n使えばあるいは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_010023320002" ]},
		{"command":[ "SETCHARA", "0", "char_00027001_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「ね、私と、貴梨果さんと、魅白さんを助けると思って……力になってくれた\nら、今度すっごいお礼しちゃうから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_020023320009" ]},
		{"command":[ "SETCHARA", "0", "char_00018202_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……しょ、しょうがねえな。俺でできる範囲なら」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「やったあ！！　さすがはカツマさん～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_020023320010" ]},
		{"command":[ "SETCHARA", "0", "char_00018202_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「チョロい。あまりにもチョロいですぞご主人」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023320007" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うるせえ！！　サキュバス二人に撫でられて尻尾振り回してるお前に言われ\nたくねえよ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「つまり、私たちは似たもの同士ということですな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023320008" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「で、問題解決か……仕事が来ないって言ってたが、そもそもそのｓｕｃｃｕ\nＢｉってなにをしている会社なんだ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「それは……『クライアントにクリティカルなアサインを』です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_010023320003" ]},
		{"command":[ "SETCHARA", "0", "char_00027001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……それはモットーだろ。モットーはあるに越したことはないが、実際の商\n材だよ。なにをして利益を得る会社なんだよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_010023320004" ]},
		{"command":[ "SETCHARA", "0", "char_00026901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_010023320004" ]},
		{"command":[ "SETCHARA", "0", "char_00027001_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おいお前ら、まさかとは思うが……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「そのまさかなんですよね～。この会社、なにするかもまだ決まってないんで\nすって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_020023320011" ]},
		{"command":[ "SETCHARA", "0", "char_00018202_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「将来の展望……スキームすらも決まってない状況でして～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_020023320012" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんでそれで起業したんだよ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「先輩サキュバスに『今時の女は起業してキラキラなビジネスパーソンになら\nなきゃダメよ』って言われたもので」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_010023320005" ]},
		{"command":[ "SETCHARA", "0", "char_00026901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「女性が社会にコミットメントするという貴梨果の思想をサポートするために\n私もついてきました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_010023320005" ]},
		{"command":[ "SETCHARA", "0", "char_00027001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「ちょうどその時、無一文から起業して大企業に成長させた映画も見まして」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_010023320006" ]},
		{"command":[ "SETCHARA", "0", "char_00026901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「私が読んだ本にも『迷わず行けよ、行けば分かるさ』ともありましたし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_010023320006" ]},
		{"command":[ "SETCHARA", "0", "char_00027001_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「二人で話し合って会社を作ってみたのです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_010023320007" ]},
		{"command":[ "SETCHARA", "0", "char_00026901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「こいつら……ビジネス用語っぽいことを言ってるだけのポンコツじゃねえか\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「なんというか、ＳＮＳで怪しい勧誘に引っかかりそうなお二方ですな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023320009" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「私はその先輩サキュバスの人妻ネットワークで『後輩が事務員を募集してる\nから』って言われたので～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_020023320013" ]},
		{"command":[ "SETCHARA", "0", "char_00018202_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「それで来てみたらオフィスだけの会社だったってことか……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「カツマさんの言うとおり、暇で稼げる状況ではあるんですけど、でもこのま\nまじゃ会社自体が倒産しちゃいそうなんです～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_020023320014" ]},
		{"command":[ "SETCHARA", "0", "char_00018202_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「つってもなあ……俺は別に経営コンサルタントってわけじゃないからなあ…\n…」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人はむしろ経営者の資金で博打をして素寒貧になるタイプ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023320010" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「タイプ、じゃねえよ。喋る犬を見世物にする会社にしてもいいんだが」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「私も真面目に考えますぞご主人。三人寄れば文殊の知恵と言うではありませ\nんか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023320011" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お前は人じゃなくて犬だけどな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「話を戻すぞ。商売するからには、なにかお前らが得意なことを売れば手っ取\nり早いんだが……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お前ら、なにができるんだ？　ハルミは派遣だからとりあえず横に置くとし\nて、貴梨果と魅白、お前ら二人だ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「えーと……なんでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_010023320008" ]},
		{"command":[ "SETCHARA", "0", "char_00026901_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「言われてみれば……我々の能力でマネタイズできることを考えていませんで\nしたね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_010023320007" ]},
		{"command":[ "SETCHARA", "0", "char_00027001_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まず第一に考えるところだろそれ！！　マジで！！　勢いで大金を使うなよ\n！！　真剣に後悔するからなそれ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人迫真のお言葉」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023320012" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああもう、こいつら放っておいたら絶対ろくなことにならんぞ。くそ、どう\nすっかなあ……」", "NORMAL" ]},
