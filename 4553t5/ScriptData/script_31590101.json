		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「最近、頑張っているみたいだから、なにかご褒美をあげたいのだけれど、希\n望はあるかしら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0103101" ]},
		{"command":[ "SETCHARA", "0", "char_00015901_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「ご奉仕をして欲しいの……？　別にいいけど、どんな奉仕をして欲しいのか\n、はっきり言って頂戴」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0103102" ]},
		{"command":[ "SETCHARA", "0", "char_00015901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「満足するまで、む、胸でオチンチンをしごきながら舐めて欲しいって……！\n　あ、あなた、自分がなにを言っているのかわかってるの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0103103" ]},
		{"command":[ "SETCHARA", "0", "char_00015901_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「そんな破廉恥なこと、できるわけが……！　……え？　自分で言い出したこ\nと反故にするのかって？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0103104" ]},
		{"command":[ "SETCHARA", "0", "char_00015901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「くっ……！　わ、わかったわ。今回だけ特別にしてあげる……！　さ、さっ\nさと服を脱ぎなさい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0103105" ]},
		{"command":[ "SETCHARA", "0", "char_00015901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「はあぁ……あ、熱くて、硬い……それに、すごく濃いニオイがするわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0103106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00015901_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「こんなモノを舐めるだなんて、とてもできないわ……今からでも、別の褒美\nを……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0103107" ]},
		{"command":[ "SETIMAGE", "0", "still_00015901_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「くうぅ……わ、わかったわよ……！　おっぱいでしごきながら、舐めればい\nいんでしょ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「んっ、ちゅぷ……れろっ、くじゅ……うぅ……！　変な味がするわ……それ\nに、オチンチンの先端から変な液体まで出てきて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0103109" ]},
		{"command":[ "SETIMAGE", "0", "still_00015901_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「ちゅぷ、れりゅ……粘ついてて、少し塩気のあるモノが……！　な、なによ\nこの液体……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0103110" ]},
		{"command":[ "SETIMAGE", "0", "still_00015901_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「オチンチンが気持ちよくなると、出てくる液体……？　そ、そそそ、それぐ\nらい知ってるわ！　バカにしないで頂戴！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0103111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「ちゅぷっ……じゅ、れろっ……む、胸も動かせ、ですって……？　わ、わか\nってるわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「んっ、んくっ……ちゅぱ、れりゅ、くじゅ……こんな感じかしら……？　し\nたことがないから、勝手がわからないわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0103113" ]},
		{"command":[ "SETIMAGE", "0", "still_00015901_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「そ、そうよ……男の人とこういう関係になったことないもの……！　ふん…\n…！　下手で悪かったわね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0103114" ]},
		{"command":[ "SETIMAGE", "0", "still_00015901_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「い、いいから、続けるわよ……ちゅぷ、れろっ……んっ、んくっ……じゅ、\nちゅぱ、じゅぞっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0103115" ]},
		{"command":[ "SETIMAGE", "0", "still_00015901_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「じゅる……ちゅ、んちゅ……え？　お、オチンチンを、咥えて欲しいって…\n…こ、これを口に入れるの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0103116" ]},
		{"command":[ "SETIMAGE", "0", "still_00015901_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「さっきは胸でしごきながら、舐めるだけって言ったじゃない！　どうしてオ\nチンチンを咥える必要があるの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「そっちの方が気持ちいいって……き、キスもしたことないのに……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「キスならさっきからオチンチンにしてる……？　そ、そういう意味のキスじ\nゃないってことぐらいわかるでしょ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「……終わったら、ちゃんとキスしなさい……それで許してあげるわ……んっ\n、ちゅぱっ……んっ、あむっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0103120" ]},
		{"command":[ "SETIMAGE", "0", "still_00015901_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「じゅる、ちゅぱ……んっ、んんっ……ちゅ、ちゅぱっ……じゅるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「んっ、ちゅぱ……！　どこを舐めればいいのか、よくわからないわ……ここ\n、かしら……んっ、じゅ、はむっ……んっ、くちゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「ふぐっ、あむっ……んっ、んんんっ……！？　ぷはっ……い、今、オチンチ\nンがビクって動いて……！　い、痛かったかしら……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「気持ちいいから動いたの……？　そ、そう……それならよかったわ……あむ\nっ、ちゅぱ、じゅぱ……ちゅっ、んぷっ……じゅる、んじゅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0103124" ]},
		{"command":[ "SETIMAGE", "0", "still_00015901_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「れろっ、じゅぞっ……んっ、ちゅぷ……確か、さっきこのあたりを舐めたら\n、ビクビクしてたわね……あむっ、んむ、んむうぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「じゅぱ、ちゅ……んちゅ、んっ……れろっ、れりゅ……ぐちゅ、じゅ、ちゅ\nぱっ……んんっ、ずちゅ、ぢゅうううぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「んっ、んぐっ……あぷっ、あっ……そ、そうね……おっぱいで擦るのも、忘\nれちゃダメよね……んっ、んんんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……こんなに擦ったら、火傷しちゃいそうだわ……あむっ、じゅ\nるっ、ちゅ、ちゅぷ……んむっ、んぐうぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「あぶっ……あっ、んんんっ、んっ、くううぅ……れろっ、れりゅ……じゅぷ\n、じゅぱ……じゅぷっ……！　エッチなお汁が、いっぱい出てきてるわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「ふふっ……気持ちいいのね……んぐっ、んじゅる……んぷっ、んっ、んぐ…\n…ちゅりゅ、ぢゅ、じゅぞっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「んんんっ……！　ビクビク、ひてりゅ……！　じゅる、ちゅぱ……じゅ、じ\nゅぞ……けほっ、けほ……あむっ、じゅぷ……じゅりゅうぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0103131" ]},
		{"command":[ "SETIMAGE", "0", "still_00015901_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「んぶっ、あっ、んんっ……んむうぅ……！　な、なに……オチンチンがすご\nく跳ねてて……！　もしかして、もうすぐイキそうなの……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「お、オチンチンから精液が出ることぐらい知ってるわ……！　そこまで無知\nじゃないのよ……あむっ、ちゅぱ、んっ……あぶっ、んむうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「ぢゅ、じゅりゅ、んむううぅ……！　ちゅぱ……！　はぁ、はぁ……い、イ\nクのね……！　いいわ……このまま、受け止めてあげる……あむっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0103134" ]},
		{"command":[ "SETIMAGE", "0", "still_00015901_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「んっ、んむうううぅ……！　じゅる、ちゅ、じゅぱ……あむっ、んっ！　ん\nぐっ……んむうううぅ～～～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0103135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015901_01_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「あぶっ、んぐうううぅ！？　あっ、じゅる……ごくっ、ごくん……！　はぁ\n、はぁ……じゅる、じゅぞおおおぉ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0103136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「く、口の中に精液が、いっぱい……！　ううぅ……な、なんなのこのニオイ\n……！　嗅いでるだけで、アソコが疼いて……あんんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0103137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「ごく……じゅる、ごくんっ……！　はぁ、はぁ……じゅる、じゅぞっ……変\nな味が、口の中に広がって……んっ、んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「ちゅ、ちゅぱ……いっぱい、出たわね……これで、終わりよ……ほら、さっ\nさと片付けなさい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0103139" ]},
		{"command":[ "SETIMAGE", "0", "still_00015901_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「えっ……ど、どうしてまだ硬いままなの……！？　男の人って、一回出せば\n小さくなるんじゃ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0103140" ]},
		{"command":[ "SETIMAGE", "0", "still_00015901_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「もしかして、まだ満足してないの……？　あ、あれだけ出したのに……！？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0103201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「た、確かに、あなたが満足するまで奉仕するって約束だけど……！　それと\nこれとは、話が違うわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「くううぅ……！　わかったわ……やればいいんでしょ、やれば……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0103203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「その代わり、私との約束もちゃんと守ってもらうわよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0103204" ]},
		{"command":[ "SETIMAGE", "0", "still_00015901_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「んっ……んむっ……本当に、まだ硬くて熱い……！　それに、精液の味がま\nだ口の中に……あむっ、じゅるううぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0103205" ]},
		{"command":[ "SETIMAGE", "0", "still_00015901_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「んっ、くっ……じゅぷ、じゅりゅ……んんっ、オチンチンの中に精液が残っ\nてるわね……じゅ、じゅぞっ、ちりゅううぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「んぐっ、あっ、じゅぞっ……んっ、ごくん……ううぅ……精液がなくなった\nら、今度はエッチなお汁が……ちゅぱっ、れりゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「あっ、んぐっ……じゅ、んっ……んんんっ！？　ど、どうして、急に腰を動\nかすの……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0103208" ]},
		{"command":[ "SETIMAGE", "0", "still_00015901_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「この方がもっと気持ちよくなれて、早く射精できるの……？　わ、わかった\nわ……あなたの動きに合わせて、おっぱいを擦ればいいのね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「んっ……じゅりゅ、ちゅぱ……んむうぅ……これ、少し難しいわね……それ\nに、咥えにくいわ……んぐっ、れろ、じゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0103210" ]},
		{"command":[ "SETIMAGE", "0", "still_00015901_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……れろ、れりゅ……なんだか、精液とあなたのニオイで、クラ\nクラしてきたわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「早く、イッて……全部、出して……！　んっ、ぐちゅ、ああっ……ちゅる、\nぢゅるるるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「んはあああぁ……もう、身体の中まであなたで染まってるわ……初めてなの\nに、こんな感覚を知るだなんて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「くっ、あんんっ……こんなの、もう私はあなたのモノみたいじゃない……！\n　ちゅ、くちゅ……じゅる、じゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0103214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「えっ……それでも、いいですって……？　な、なにを言ってるの……！　い\nいから、オチンチンに集中しなさい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0103215" ]},
		{"command":[ "SETIMAGE", "0", "still_00015901_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「ちゅぱ、じゅるっ……んっ、あんっ……れろっ、れじゅっ……ちゅぱっ、ち\nゅぴ……んっ、ぐちゅ……じゅぞおおおぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0103216" ]},
		{"command":[ "SETIMAGE", "0", "still_00015901_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「あっ、んぐっ……じゅ、んむうぅ……！？　ま、またビクビクして……！　\nんっ、じゅぱっ、ちゅぐ、ぐちゅう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「さっきよりも……大きく跳ねてるわ……！　んぐっ、あむっ……ぷはっ……\nく、口から、こぼれちゃいそうだわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0103218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「はぁ、あぁ……じゅぷぷっ、ちゅぱ、れりょ……もう、我慢できないのね…\n…！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「ええ、いいわよ……あなたの精液、最後まで全部出し切って……！　んんっ\n、じゅぷ、んじゅうううううぅ～～～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「んんんっ！　あぶっ、んぶっ……！　んぐっ、むううううぅ～～～～～！！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0103301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015901_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「じゅるっ、じゅぱ……ごくん、ごくんっ……！　さっきよりも、精液が多い\n……！　じゅる、じゅぱ……す、すごい量だわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「全部飲まないと、息ができないぐらい……！　んっ、んくっ……じゅる、あ\nんんっ……じゅぷ、ぢゅぞおぉ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0103303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「んむううぅ……！　の、喉に絡んで……けほっ、げほっ……ごくっ、んごく\nっ……ごくんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0103304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……ぜ、全部飲んだわよ……これで、満足したかしら……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0103305" ]},
		{"command":[ "SETIMAGE", "0", "still_00015901_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「ふふっ……お腹の中、あなたの精液でいっぱいよ……苦しいぐらいだわ……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0103306" ]},
		{"command":[ "SETIMAGE", "0", "still_00015901_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「もしこの精液をアソコに出されてたら、絶対にあなたの赤ちゃんを孕んでた\nわね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0103307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「今度はオマンコに出したい……？　ば、バカ言わないで頂戴！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0103308" ]},
		{"command":[ "SETIMAGE", "0", "still_00015901_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「もう全部精液を出したでしょう！　その証拠に、オチンチンが小さくなって\nいってるじゃない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「それに、私とのセックスはご褒美に入ってないわ！　調子に乗らないで！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「ぷはっ……ちょ、ちょっとなにを……きゃあああっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0103401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015901_01_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「か、顔にかけるだなんて聞いてないわ……んっ、あっ……あああっ……！？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「あなたの精液でベトベトじゃない……！　それに、濃いニオイが充満して…\n…んんんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0103403" ]},
		{"command":[ "SETIMAGE", "0", "still_00015901_01_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「こ、こんなの……ニオイだけでイッちゃいそうだわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0103404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「口の中も、顔も、全部あなたに染められて……私、まだそういったことをし\nたことないのに、あなたのモノになったみたいだわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0103405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「きゃっ！？　ちょ、ちょっと……！　どうしてまだオチンチンをビクビクさ\nせてるの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0103406" ]},
		{"command":[ "SETIMAGE", "0", "still_00015901_01_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「私の全てが欲しいですって……？　ななな、なにを言ってるの……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0103407" ]},
		{"command":[ "SETIMAGE", "0", "still_00015901_01_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「わ、私たち、まだキスもしてないのに……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0103408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「そ、そうよ！　キスよ！　さっきの約束、忘れてないでしょうね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0103409" ]},
		{"command":[ "SETIMAGE", "0", "still_00015901_01_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「終わったら、キスをするって約束でしょう！　は、早くしなさい！」", "NORMAL" ]},
