{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ついに、ついにです！　ＹＳＫモードの最終兵器をご主人様に披露する時が\nやってきました！　ドンドン、ぱふぱふ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0604101" ]},
		{"command":[ "SETCHARA", "0", "char_00015706_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「――にゃふふ、そりゃテンションも高くなりますとも！　この機能を、いっ\nたいどれだけのスペースネット産のロボットが待ち望んでいたことか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0604102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「なんと……ＹＳＫモード状態だと、私は妊娠することが可能なのです！　ご\n主人様！　子作りですよ！　子作り！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0604103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「理解が追い付かない、って顔をしてますね？　――いえ、私がロボットであ\nることに変わりはありませんよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0604104" ]},
		{"command":[ "SETCHARA", "0", "char_00015706_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「胎内に精子を取り込むと、その遺伝子情報を解析し、スペースネットのマザ\nーコンピュータにデータを送信するシステムが搭載されているんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0604105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「その情報と私のAI情報を掛け合わせ、新たなロボットを作成……つまり、\n疑似的に子供を作る事が可能になった、といった感じですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0604106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「――ご主人様の悩みや不安は分かります。ですけど……私はご主人様との子\n供が欲しいです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0604107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ご主人様、どうか、貴方のメイドを可愛がってはいただけませんか？　愛し\nて、頂けませんか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0604108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「……にゃふふ、ありがとうございます♪　それでこそ、私の大好きなご主人\n様です♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0604109" ]},
		{"command":[ "SETCHARA", "0", "char_00015706_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「あっ♪　ご主人様のおちんちんが、おまんこに当たってる……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0604110" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00015706_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「驚きました？　ＹＳＫモードはリアルを追及していますからね！　当然、お\nまんこだって、ご主人様と同じ『人』のものです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0604111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「あっ、んあぁんっ♪　だ、だから、そうやっておちんちんで割れ目をなでな\nでされると、待ちきれないというか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0604112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ご、ご主人様？　どうしておちんちん挿入してくれないのですか？　私のお\nまんこ、我慢しきれずびちょびちょに濡れちゃってますよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0604113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「――私のおねだりがないと挿入できない？　エロく誘ってほしい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0604114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふふ、まったく、私のご主人様はしょーがないですねぇ……そんなお馬\n鹿なところも大好きです♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0604115" ]},
		{"command":[ "SETIMAGE", "0", "still_00015706_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「では……ご主人様、どうか私のおまんこに、そのご立派なおちんちんを挿入\nしてください！　いっぱい私を可愛がって、種付けしてくださいな♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0604116" ]},
		{"command":[ "SETIMAGE", "0", "still_00015706_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んにゃあぁぁん……！　は、入ってきたぁ！　ご主人様のおちんちん、奥の\n奥までっ、あっ、んあぁあんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0604117" ]},
		{"command":[ "SETIMAGE", "0", "still_00015706_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「こ、これ、すご過ぎますっ！　挿入されただけなのに、頭の中にノイズが走\nってっ、あっ、ふにゃぁんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0604118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「おちんちんも、最初からパンパンに膨れ上がってて、んあぁんっ！　こ、こ\nれが『人』のおまんこで感じる、おちんちんの感触……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0604119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んひゃぁんっ！　あっ、あひっ、ふあぁんんっ！　ご、ご主人様、最初から\n、激しすぎますっ！　んにゃぁんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0604120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「あっ、ああぁんっ！　ずんずんって、子宮を突かれると、どんどんノイズが\n増えて！　んあぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0604121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「こ、こんなの知らない！　こんな気持ちいいおちんちん知りません！　お腹\nの中全部が、ご主人様で満たされてっ！　んああぁんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0604122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「そっか……これが『子作り』なんですね！　私とご主人様との共同作業……\nにゃふ、にゃふふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0604123" ]},
		{"command":[ "SETIMAGE", "0", "still_00015706_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「も、もちろん遠慮なんて必要ありません。私の事を壊すような勢いで……ご\n主人様のお好きなように、滅茶苦茶に可愛がってくださいな♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0604124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んひゃぁん！　あっ、ふあぁんっ！　来たぁ、また一気に、おちんちんがっ\n、あひゃんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0604125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「おまんこの中、ゴリゴリ削られちゃう！　あひっ、あっ、んひゃぁん♪　お\nちんちんの凸凹が、ひっかかってっ、ふあぁん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0604126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「それに、この体勢だとっ、ああぁんっ♪　おへその裏に、おちんちんごりご\nり来てますっ！　乱暴に突かれると、お腹ぽっこりして、んひゃん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0604127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「いつもと違って『肌』が柔らかいから、私のお腹、やぶれちゃうかも♪　あ\nっ、あぁんんっ♪　本当にご主人様に壊されちゃうかもぉ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0604128" ]},
		{"command":[ "SETIMAGE", "0", "still_00015706_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「おちんちんに苛められて、愛液も止まらない！　んあぁんっ！　えっちな音\nいっぱいで、恥ずかしいのに、嬉しくてっ、んひゃぁんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0604129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「あひっ、んにゃぁあんっ！　お腹の中でおちんちんが大きく跳ねて、あっあ\nっ、んぁああっん！　これ、そういうことですよね、ご主人様！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0604130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「――わ、分かってますよ♪　んあぁんっ！　中にだしてほしかったら、えっ\nちな言葉でおねだり、ですよね？　にゃふふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0604131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「あぁんっ、ふあぁんっ！　だ、出してくださいご主人様！　ロッテのいやら\nしいおまんこは、我慢なんてできないです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0604132" ]},
		{"command":[ "SETIMAGE", "0", "still_00015706_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ご主人様の子種が欲しくて、おまんこがずーっとおちんちんにむしゃぶりつ\nいているんです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0604133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んあぁぁぁんっ！　あっあっ、んにゃぁんっ！　そ、それに、頭の中にノイ\nズの量もすごくてっ！　小さくイってるのが、止まらない……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0604134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「だ、出してください！　私の情けないおまんこを、ご主人様の精液でいっぱ\nいにしてください！　ご主人様の子を、孕ませてください！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0604135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んにゃあぁあぁ～～っ！！　ご主人様の精液、きたぁ……！　ドクドクって\n精液が溢れて、あひっ、あっ、ふあぁぁんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0604136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015706_02_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「こ、これが膣内出し……！　今までの身体で感じてたのとは何か違う！　あ\n、んあぁんっ！　んにゃぁんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0604137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ご主人様の遺伝子情報が、子宮を通して私のデータに刻まれていきます！　\nこれが子種、私とご主人様との愛の結晶の欠片……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0604138" ]},
		{"command":[ "SETIMAGE", "0", "still_00015706_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……にゃふふ♪　今日もいっぱいだしましたね～ご主人様♪　流\n石にすべておまんこで受け止めきるのは無理でした……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0604139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ですが、必要な情報は、全て解析させていただきました♪　このデータをマ\nザーコンピュータに送信して、っと……にゃふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0604140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふ、にゃふふふ♪　どうしました～ご主人様、そんなに慌てちゃって？\n　このお腹が気になりますか～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0604201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「言ったじゃないですか、ご主人様の子を孕ませてくださいって♪　データを\n送信した時点で受精は成功、疑似妊娠機能が働き始めたんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0604202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「確かに、人のそれとは少しスピードが違うかもしれませんが……早く子供と\n出合えると考えれば便利だと思いません？　にゃふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0604203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「とはいえ、まだ疑似妊娠機能が働いてるだけなので、まぁ見た目だけの変化\nですよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0604204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ですが、ボテ腹状態がアンロックされたことで、おまんこの締め付けがより\nいっそうキツキツになってるの、分かりますか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0604205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「――私の全てはご主人様のモノ。妊娠したてのキツキツおまんこ、ご主人様\nのお好きなように、楽しんでくれていいんですからね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0604206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「あっ、あ、んにゃぁんっ！　ご主人様のチンポ、今度は浅い所ずんずんって\n、あっ、んあぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0604207" ]},
		{"command":[ "SETIMAGE", "0", "still_00015706_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「私ももっと締め付けますから、んんんっ！　腰をゆっくりまわして、ぎゅゅ\nっぎゅって、おちんちん搾り取ってっ、んくぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0604208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んあっ、あっ、ふあぁんっ……！　んくっ、んんっ、ふあぁんっ……！　ま\nた、小さいノイズの波も、止まらないっ！　ふあぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0604209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ご主人様ぁ、幸せですねぇ♪　ご主人様と『子作り』出来るなんて、とって\nもとーっても幸せです♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0604210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「――大丈夫ですよ、私の体は丈夫ですから！　お腹が膨れてるからって遠慮\nなんていりません！　もっと強く、もっと激しく来て下さい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0604211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んひゃあぁんっ♪　そ、そう！　それですっ！　キツキツのおまんこを無理\n矢理押し開いて、奥を突き上げて！　あひっ、ふああぁんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0604212" ]},
		{"command":[ "SETIMAGE", "0", "still_00015706_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「子宮口の所をズドンってっ、んひゃんんっ！　おまんこ掻き回して！　もっ\nともっと、貴方のメイドを感じさせてください！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0604213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「あひっ、あっ、んにゃぁんっ！　エラーとノイズの量、すごいっ！　処理が\n全然追いつかないけど、それがいいのっ、ああぁんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0604214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ふあぁっ！？　そ、それ、膨らんだお腹撫でられるの、なんか変っ……んふ\nっ、あっ、んひゃぁうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0604215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「く、くすぐったいんじゃなくて、あひっ、ふくぅんっ……！　『肌』敏感だ\nからぁ……！　あっ、んひゃぁうんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0604216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「あひっ、んあぁんっ！　またおちんちん、ビクンッて跳ねて、ふあぁん！　\nご主人様も、イキそうなんですねっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0604217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「私もイキますっ！　ご主人様といっしょにイキますからっ！　ロッテの妊娠\nおまんこで、びゅーびゅー射精してください！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0604218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んひゃぁんっ！　あっ、ふあぁんっ！　お腹も撫でて欲しいですっ！　ご主\n人様の手で、感じさせてっ、ふあぁんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0604219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「あっあっ、にゃひぃぃんっ！　ノイズ、すご、いっぱいっ、あひぃんっ！　\nイク、イクイクイク！　イクぅぅ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0604220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「にゃぁあぁぁんんっ～～♪　ご主人様の熱い精液が、お腹の中にびゅくびゅ\nく来てっ、あひっ、あっ、んひゃぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0604301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015706_02_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ご主人様の遺伝子情報が、どんどん溢れてくるっ！　んにゃぁんっ♪　すご\nい、私、ご主人様と一つになってる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0604302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「それに、イクのも止まらないっ！　あっ、ふあぁんんっ！　エラーいっぱい\nですけど、それが気持ちよくてっ！　んにゃぁん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0604303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んんっ、んあぁんっ……はぁ、はぁ……にゃふふ、まったくもー、どれだけ\n出すんですが、ご主人様♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0604304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「子宮の中、ご主人様の精液でパンパンになっちゃいましたよ？　普通の『人\n』でも妊娠してる量かもしれませんね～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0604305" ]},
		{"command":[ "SETIMAGE", "0", "still_00015706_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「……ねぇ、ご主人様、私のお腹、さっきみたいに撫でてもらってもいいです\nか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0604306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んっ……まだ、影も形もない、遺伝子データだけの存在ですけど……ここに\n確かに存在します。私とご主人様の子供が……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0604307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふふ♪　なんですか、今更そんな真面目な顔しちゃって♪　そんなの、\n嬉しいに決まってるじゃないですか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0604308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「これからもメイドとして……そして、この子のママとして、ご主人様に精一\n杯尽くさせて頂きますね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0604309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「だからどうか末永く、私の事を可愛がってくださいね♪　大大だーい好きな\n、私だけのご主人様♪　にゃふふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0604310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んにゃぁあぁぁんんっ～～っ！！　こ、これ、おちんちん、抜けちゃって！\n　あっ、んんひゃぁん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0604401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015706_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「膨らんだお腹に、精液いっぱい降りかかってきてる、んふぅんっ！　でも、\nこれはこれで、ご主人様に染められてる気がして、いいかもっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0604402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んんっ、あっ、あぁんんっ！　中も外も、内部データも全てのパーツも、私\nはご主人様のモノ……ご主人様だけの、メイドだから……あぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0604403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「『肌』敏感、だからぁ……んひゅ、あっ、んにゃんっ♪　精液が降りかかる\n度、エラーが出てっ、あひっ、イクの止まりません！　んにゃんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0604404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んんっ、あっ、ふぁ……はぁ、はぁ……相変わらず、すごい量をぶちまけて\nくださいましたねー、ご主人様？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0604405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふふ♪　あなたの『パパ』は酷い人だねー？　『ママ』をこーんなに汚\nしたのに、にこにこ嬉しそうに笑っちゃってるんですよー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0604406" ]},
		{"command":[ "SETIMAGE", "0", "still_00015706_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「でも……そんな酷いご主人様の事も、この子は好きになっちゃうんでしょう\nね。なんといっても『私の子』ですからね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0604407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「――え？　俺たちの子だろ、って……にゃふ、にゃふふふふ♪　もう、もう\nもうご主人様ってば！　そーゆーところですよ、そーゆーところ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0604408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「大好きです、ご主人様！　どんなにパーツを換装しても、どんな私になった\nとしても、絶対、ぜーったいご主人様を好きになります！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0604409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「私は貴方だけのロボット。貴方のメイドで、そしてこれからは……にゃふふ\n♪　これからも末永く、よろしくお願い致しますね、ご主人様♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0604410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
