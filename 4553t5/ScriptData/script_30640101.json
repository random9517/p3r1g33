{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「はいはい。隊長、私になんの用でしょうか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0103101" ]},
		{"command":[ "SETCHARA", "0", "char_00006401_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「ほほう、パワーアップのためのトレーニングですか。いったいどうすればい\nいんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0103102" ]},
		{"command":[ "SETCHARA", "0", "char_00006401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「……って、急におちんぽ出さないでくださいよ！　ははーん、なんだかんだ\n理由を付けて、私とやらしいことしたいんですね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0103103" ]},
		{"command":[ "SETCHARA", "0", "char_00006401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「え？　パワーアップするのは本当？　まあまあ、そういうことにしておいて\nあげましょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0103104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「隊長の持ってる武器、おちんぽにも興味があったのでね。ふふ、丁度いい機\n会です。どれほどのものか確かめさせてもらいますよ」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00006401_01", "0", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_064_0103105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「ひゃっ、いきなり押し倒して、馬乗りになるなんて乱暴ですね。んぅっ、隊\n長のおちんぽがおっぱいの間に……んっ、挟まっちゃってますよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0103106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00006401_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「どうですか、隊長？　私も、けっこういいものもってるでしょう？　んふふ\n、動いちゃいます？　腰振っちゃいます？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0103107" ]},
		{"command":[ "SETIMAGE", "0", "still_00006401_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「あはっ、本当に腰振って、おちんぽをおっぱいにこすりつけてきて……んっ\n、ああ、熱いですね……隊長のおちんぽ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「んふぅ、私だっておっぱいでしっかり隊長のおちんぽを挟んであげないとい\nけませんよねー。えいっ、えいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「おっぱいで挟んだらびくびくしちゃって……。これが隊長のおちんぽなんで\nすね。おっぱいお好きなんですかぁ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「んっ、んっ、真っ赤っかな先っぽが谷間から顔を出して、あんっ、いやらし\nい匂いが漂ってくるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0103111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「あんっ、んっ、ん……っ。濃い……男の人の匂いぃ……。こういうの、私好\nきです……すんすんすん……ふはぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「アツアツガチガチの勃起ちんぽ、ああ、すっごい。こんな武器、初めてです\n。こういう武器、大好きなんですよー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「もっといっぱい、腰振っちゃって……んっ、あっ、あんぅ……んふぅ……っ\n！　おっぱいの中……熱い……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「それじゃ、私も……んっ、んしょ……っと、おちんぽしっかり、挟んで……\nんんっ、硬いの感じちゃいます……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0103115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、おっぱいの間、おちんぽが出たり入ったり、いっぱいごりごり\nこすれて……んっ、あっ、すっごぉ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「そんなに私のおっぱい気持ちいいですかー？　んふふ、まあ、私もおっぱい\nには自信あるんですよねー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「それっ、それそれっ！　私もこのおっぱいを使って、隊長のおちんぽ、いっ\nぱい刺激しちゃいますよー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「おっぱいこねこね～。んふふっ、だんだん腰の動きに余裕がなくなってきち\nゃってるんじゃないですか、隊長？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「真っ赤な先っぽから、ぬるぬるトロトロ、先走り汁が垂れてきちゃっている\nじゃないですかー。んんっ、ぬめりが気持ちいいですよー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「んんっ、隊長のおちんぽ、やばいですね……。こんなに一生懸命におっぱい\n犯されたら、なんだかこっちまで……変な気分……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「ええっ、具体的には？　んー、そうですねー。おちんぽいじめるだけじゃな\nくて、たっぷり気持ちよくしてあげたくなっちゃいますね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「ふふーん、これが隊長の武器の威力ってわけですか……んっ、ああっ、おっ\nぱい気持ちよくなって……おかしくなっちゃいます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「んっ、んっ、それっ、それっ。おっぱいぎゅ～って密着させて、んっ、あん\nっ、すっごい熱い……はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「おっぱいの中で、あんっ、おちんぽが膨らんで……。隊長、もしかしてこの\nままびゅーっと射精しちゃう気ですかー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「んふふっ、やっぱり男の人の武器といったらおちんぽと射精ですよねー。私\n、隊長の射精を感じたいですー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「だから、こうして、びくんびくんしているおちんぽをおっぱいで締めつけち\nゃって……っと、んっ、元気なおちんぽ感じる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「あんっ、隊長もいっぱい腰振って、私のおっぱいをおまんこみたいに犯しち\nゃってるっ！　んっ、お汁いっぱい……ぬるぬる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「隊長、隊長……っ！　あんっ、おちんぽイキそうになってますね……ビクビ\nクしちゃってますもんね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「んふふ～、どぴゅっとしちゃってくださいねー。私に隊長のおちんぽの威力\n、確かめさせてくださいなー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「んっ、んっ、んん……っ！　あっ、ああ……ああ……熱いの、びくびくして\n……んっ、んんんぅうううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0103131" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00006401_01_05" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「すっごい、おっぱいの間で脈打って、これ、射精……っ！　隊長の精液、私\nのおっぱいに注がれちゃってますー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「あはは、すっごい匂い……。カウパーとは比べものにならないくらいドロッ\nドロの精液……たっくさんですねー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0103133" ]},
		{"command":[ "SETIMAGE", "0", "still_00006401_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……。まだまだおっぱいの中で跳ねて、精液びゅっびゅってだ\nしちゃってるじゃないですか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0103134" ]},
		{"command":[ "SETIMAGE", "0", "still_00006401_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「隊長のおちんぽ、どんだけ精液出すんですかー？　それとも、私に精液食ら\nわせるために溜めてました？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0103135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「あ、でも、こんなにいっぱい射精させられたのは、私のおっぱいのおかげで\nすよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0103136" ]},
		{"command":[ "SETIMAGE", "0", "still_00006401_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「えっ、本当にそうなんですか？　私のおっぱい、パイズリ、そんなに気持ち\nよかったですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0103137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「えへへ……。いやぁ、面と向かってそう言われると嬉しいやら恥ずかしいや\nらですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「隊長のおちんぽも、太さといい長さといい、射精の量もとっても素敵だと思\nいますよ。お気に入りになりそうです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「まあ、これで本当にパワーアップできたのかは疑問ですけどねー。だけど、\n気持ちよかったのでオッケーですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「……ところで、どうしていつまでもおちんぽをおっぱいに突っ込んだままで\nいるんですか、隊長？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0103201" ]},
		{"command":[ "SETIMAGE", "0", "still_00006401_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「んぇっ！？　まだまだ足りない？　もっと私のおっぱいを味わいたいんです\nか？　……んふぅ、隊長も好きですねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0103202" ]},
		{"command":[ "SETIMAGE", "0", "still_00006401_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「そういうことなら、私のおっぱいを使わせてあげましょうかね。とっても素\n敵な武器を見せてくれたお礼ですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0103203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「んぅっ、さっきの射精でぬるぬるネトネトになったおっぱい……あんっ、ま\nた、隊長のおちんぽが出入りしてる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0103204" ]},
		{"command":[ "SETIMAGE", "0", "still_00006401_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……んっ、ああっ！　さっきよりも、おっぱいがおちんぽに密着\nして……んんっ、んふぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「まだまだ勃起してるおちんぽ……。ああ、熱い……っ！　んん……んふぅ…\n…。はぁ、はぁ……。ああっ、んんぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「そんなに、あんっ、激しく腰を……んっ、んんっ！　おっぱいに、うちつけ\nて……あっ、ああんっ！　んくぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「んぁっ、な、なんだかおかしく……おっぱい犯されて、すっごく感じちゃう\nぅ……っ！　ああっ、んっ、んくぅ……んふぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「ああっ、隊長におっぱい犯されながら、すごく興奮しちゃってますっ！　ん\nっ、乳首……すごく勃起ぃ……しちゃってる……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0103209" ]},
		{"command":[ "SETIMAGE", "0", "still_00006401_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「やぁっ、ああっ、褐色おっぱい、気持ちいいですか？　んんっ、腰振り……\nおっぱいレイプ……とまりませんかぁ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0103210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ。そんなに、がっついて……っ！　ああっ、がちがちの硬いので\n、おっぱい抉るみたいに突いて……んっ、んんぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「それ、それ……やっばぁ……っ！　隊長の腰振り見てたら、なんだか、心が\nざわざわします……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「ぐちょぐちょのおっぱい、おちんぽにかき回されて……つ！　ああんっ、気\n持ちいい……です……！　あっ、んぅ……くぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「わ、私のおっぱいも、エロくて……気持ちいい、ですか……？　んんっ、い\nつもならそんなこと言われてもなんともないのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0103214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「いまに限っては、なんだか……興奮します……っ！　隊長、もっと私の武器\nであるおっぱいを味わってください……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0103215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「隊長のおちんぽしっかり捕まえて、んっ、んっ、んっ！　おっぱい押しつけ\nて、挟み込んで、気持ちよくしちゃいますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0103216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「おちんぽ限界ですか？　んふっ、またぴゅっぴゅーって、精液だしちゃいそ\nうですか？　んぁっ、びっくんびくんして返事してるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「ああっ、また射精しちゃうんですね？　んふっ、また私のおっぱいに、隊長\nの精液を撃ちこんでください！　はぁ……はぁ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0103218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「おっぱいマンコ、いっぱい気持ちよくなっちゃいます！　隊長、隊長……！\n　ああ、私もおちんぽ感じて気持ちいい……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「また、ください！　隊長のおちんぽからでる精液、エロエロ褐色おっパイズ\nリで……射精して……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「んんんぅううっ！　あっ、ああ……あああぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00006401_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0103301" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「また、またおっぱいに……勢いよく精液がびゅーっ、びゅーって出てますよ\n……すごい……二度目なのにいっぱい……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0103302" ]},
		{"command":[ "SETIMAGE", "0", "still_00006401_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……熱いです……。それに、匂いも……さっきより濃くなって\nるみたいじゃないですか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0103303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「んぁあっ、まだ、動く……。射精しながら、おちんぽゆっくり動かして……\nはぁ……はぁ……んふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0103304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「そんなにしたら、私のおっぱいに隊長の精液の匂いが染みついちゃうじゃな\nいですかー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0103305" ]},
		{"command":[ "SETIMAGE", "0", "still_00006401_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……。たっぷりおっぱいに射精されて、ヌルヌルになって……\nしかも、気持ちいい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0103306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「隊長のおちんぽすごい……隊長のおちんぽ、私のお気に入りになっちゃいそ\nうですよー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0103307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「んふふ、私、強い武器には目がないんです。こんなに強力な射精を食らった\nら虜になっちゃいますよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0103308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「これを、おまんこで味わったらと思うと……。んふふぅ。なんだか、それも\nためしてみたいです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「隊長はどうですか？　ふふ、私のもう一つの武器をためしたいか、考えてお\nいてくださいね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「んひゃっ、おちんぽがおっぱいから飛び出して……っ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0103401" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「んひぃいいいっ！？　おおっ、おちんぽ暴発っ！　精液が、わ、私の身体に\n……いっぱい、か、かかって……っ！？」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00006401_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「ああっ、すっごい、すっごいです隊長！　二度目なのに、こんな……ドロッ\nドロ……ネバネバぁ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0103403" ]},
		{"command":[ "SETIMAGE", "0", "still_00006401_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「ぷりっぷりの真っ白精液が、んっ、おっぱいに……顔にぃ……。はぁ……は\nぁ……すぅ……。男の人の……濃い匂い……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0103404" ]},
		{"command":[ "SETIMAGE", "0", "still_00006401_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「あはは、おちんぽまだヒクヒクして、精液の残り汁を垂らしているじゃない\nですか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0103405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「んふふ、隊長、褐色肌には真っ白い濃い精液が映えると思いませんか？　実\nはこれも、私の武器なんですよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0103406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「隊長ってば、まだまだやらしい気持ちが収まらないんですか？　おちんぽ勃\n起しっぱなしじゃないですかー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0103407" ]},
		{"command":[ "SETIMAGE", "0", "still_00006401_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「持久力も高いんですね、隊長の武器は。んふふぅ、これはなかなかいいもの\nをお持ちですね、隊長？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0103408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「隊長の武器が気に入っちゃったので、私、これから隊長の武器のお世話もし\nてあげたいです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0103409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「その武器、いーっぱい愛でさせてくださいね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0103410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
