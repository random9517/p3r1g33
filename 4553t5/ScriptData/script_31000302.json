{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010003_02_02" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「急に呼び出してすまないな。ちょっと相談があるんだが、聞いてもらえるか\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0304101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「別に深刻な話ではない。ただ、身体が火照って仕方ないから、おまえには性\n処理用の肉バイブになってもらおうと思ってな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0304102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「おっと、逃げようだなんて考えるんじゃないぞ。それにこれは、お願いじゃ\nなくて命令だ。おまえの返事は、はいかイエスしかないんだ。わかるな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0304103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「はああぁ……！　この熱くてドクドクと脈を打つペニス……！　やはり本物\nはいい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0304104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ん？　どうしてそんなにもイヤそうな顔をするんだ？　私のアソコに、遠慮\nなくペニスを挿れられるんだぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0304105" ]},
		{"command":[ "SETIMAGE", "0", "still_00010003_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「この発情したヌレヌレのアソコに挿れたら、絶対に気持ちいいぞ……ほら。\nエッチな汁がペニスに垂れてきているのがわかるだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0304106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「軽く擦るだけで、くちゅくちゅといやらしい音が鳴って……ふふっ。おまえ\nに期待している証拠だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0304107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「もし途中でペニスを萎えさせたりでもしたら、どうなるかわかっているな？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0304108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「うむ。いい返事だ。なに、心配しなくていい。ちゃんとおまえのことも、気\n持ちよくしてやる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0304109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「私が満足するまで、何度でも使ってやるからな……！　んっ、あっ……あっ\n、あっ！　んふううううぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0304110" ]},
		{"command":[ "SETIMAGE", "0", "still_00010003_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「はあ、あふっ……んっ、あっ……！　この腹の奥が圧迫される感覚……！　\n本当にたまらないな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0304111" ]},
		{"command":[ "SETIMAGE", "0", "still_00010003_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「狭くてキツいアソコが、思い切り広げられて……！　おまえのカタチを憶え\nてしまいそうだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0304112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふふっ。動いてもないのに、ペニスがビクビクと跳ねまわっているぞ……ま\nさかとは思うが、挿れただけでイキそうなのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0304113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ほう。そう簡単にイクわけはないと？　では、少しだけ責めさせてもらうぞ\n……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0304114" ]},
		{"command":[ "SETIMAGE", "0", "still_00010003_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んっ、あっ……ふぐっ、んんっ……！　どうだ……！　こうやって、アソコ\nをぎゅっぎゅっと締め付けられるのは……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0304115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「亀頭だけでなく、ペニス全体に圧が加わって……搾り上げられるような感覚\nだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0304116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「シゴいてるわけじゃないのに、シゴいてるみたいでたまらない？　ふふっ。\n当たり前だ。そうなるように締め付けているからな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0304117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「こうやって緩急をつけて締め付ければ……ああっ！　カリの部分が、気持ち\nいいところをゴリゴリ抉ってくるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0304118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「これは私も我慢ができそうにないな……！　早速、動くとしよう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0304119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「当然だが、私が許可するまで絶対にイクんじゃないぞ。もしイッたら……忍\n法で強制的に勃起させてやるからな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0304120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あっ！　あっ！　んっ、あああっ！　これだ！　このアソコのヒダが削られ\nるような感覚っ！　これが欲しかったんだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0304121" ]},
		{"command":[ "SETIMAGE", "0", "still_00010003_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「奥の深いところにもしっかり当たって……！　んんっ！　カタさも長さも丁\n度いい……！　まさに理想的なペニスだな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0304122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「こんなにも気持ちいいと、夢中で腰を振りたくなってしまう……！　ぐっ、\nあうっ……！　あっ、んんっ！　ふっ、あっ、んぐうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0304123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「私のアソコとペニスがぶつかり合うたびに、パンパンとエッチな音が響いて\nくる……！　おまえもこの音を聞いていると、興奮するだろう……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0304124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「興奮して気持ちよくなりすぎるから、もう少し速度を落とすか、アソコの締\nまりを緩めて欲しい？　あははっ！　なにを言っている！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0304125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「気持ちいいなら、もっと速く動くのが普通のことだ！　それに締まりを緩め\nたりしたら、私が気持ちよくないだろう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0304126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「そもそも、これは私のためのセックス……いや、オナニーだ！　おまえはた\nだの肉バイブで、使われるだけの存在だ！　それを忘れるなよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0304127" ]},
		{"command":[ "SETIMAGE", "0", "still_00010003_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あっ、んふっ……！　ぐっ、くううぅ……！　おまえの切なそうな顔を見て\nいると、余計動きたくなってくる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0304128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「これ以上激しく動かさると、射精してしまいそうだと？　ふふっ。ならもっ\nと激しく動くとしようか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0304129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んっ、ああっ！　こうして奥をグリグリすると、ペニスも反応して我慢汁を\n吹いてくる……！　ああっ、最高だ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0304130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「小刻みにビクビクと動いて、今にも射精しそうな感じが伝わってくるっ……\n！　んっ、あっ！　この震えが、またいい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0304131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「子宮口に振動するバイブが当たっているみたいで……！　ぐっ、あひっ、ん\nひいぃ！　気持ちよくて、私もイッてしまいそうだっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0304132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「出そうだから抜いてくれ？　バカなことを言うな……！　アソコにペニスを\n挿れているんだ。射精するなら、子宮に出してもらわないとな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0304133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふっ、うぐっ！　あっあっ！　んむっ、んひいいぃ……！　あっ、イクっ！\n　イクぅ！　すごいの、すぐそこまで来てるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0304134" ]},
		{"command":[ "SETIMAGE", "0", "still_00010003_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あああっ！？　ペニスの動きも激しくなって……！　出せっ！　思いっきり\n射精しろっ！　子宮におまえの子種を、たくさん注ぎ込めっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0304135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「っああああぁ……！　あっ、ひあっ……！　んっ、はあああぁ……！　熱い\nのが、どぴゅどぴゅ出てる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0304136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010003_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「子宮の入り口とペニスの先端がキスをして……！　奥の奥に、ドロドロの精\n液が流し込まれて……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0304137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「やはり発情したアソコには、勃起したペニスと精液が一番だ……！　作り物\nの張型では、この快感は味わえない……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0304138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ほら……！　遠慮しないで、もっと出せ……！　私を孕ませるぐらい、勢い\nのある射精を見せてみろっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0304139" ]},
		{"command":[ "SETIMAGE", "0", "still_00010003_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んふっ……！　ぐっ、あっ……！　お腹の奥が満たされていく……！　ああ\nっ……本当に気持ちいいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0304140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふうううぅ……中々に心地いいオナニーだった。おまえも気持ちよかっただ\nろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0304201" ]},
		{"command":[ "SETIMAGE", "0", "still_00010003_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「気持ちよかったから、早くアソコからペニスを抜いて欲しい？　なにを言っ\nているのだ？　私は満足したとは、一言も言ってないぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0304202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「確かにたくさん膣内出ししてもらったし、先ほども大きくイッてしまったが\n……私のオナニーが、たった一回で終わるわけがないだろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0304203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「絞られすぎてもうペニスが限界……？　あははっ！　そんな見え透いたウソ\nをつくとはな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0304204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「本当に限界なら、ペニスはとっくに萎えているはずだ。だがおまえのペニス\nはまだカタいまま……なら、動いても問題はないということだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0304205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んんんっ！　一度出したから、さっきよりも膨張力は落ちているみたいだが\n……それでも、しっかりと勃起しているな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0304206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「はぁ、ああっ！　んひっ、はふっ……！　ふふっ。せっかくの機会だ。私の\n房中術を見せてやろう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0304207" ]},
		{"command":[ "SETIMAGE", "0", "still_00010003_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「こうして上下に動くだけでなく、グリグリと前後左右に腰を動かせば……！\n　あっ、あっ！　いいっ！　奥を抉られるの、すごくいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0304208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あんっ、あっ！　あああぁん！　おまえも気持ちいいだろう！？　ペニス全\n体を愛撫されているみたいで、たまらないだろう！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0304209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「そんな情けない声を出してもムダだっ！　私の腰使いで、ペニスがさっきと\n同じくらいカタくなってきているぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0304210" ]},
		{"command":[ "SETIMAGE", "0", "still_00010003_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「これなら、もっと激しく動いても問題ないな……！　よしっ、ここからは本\n気でいくぞっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0304211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ひっ、あんっ！　あっ、あっ！　ふあああぁっ！　杭打ちするみたいに腰を\n動かすと、ペニスがヒダをゾリゾリ削ってくるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0304212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「こんなの子宮が完全に開いて……！　おっ、おおおぉ……！？　亀頭が奥に\n入ってきてしまいそうだ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0304213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「はぁ、はああぁ！　気持ちいいのが、アソコの奥から溢れ出てくるのがわか\nるっ！　これなら、すぐにイケそうだなっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0304214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「いいか、私がイクまで絶対に射精するんじゃないぞっ！　もし一滴でも精子\nを出したら、容赦しないぞっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0304215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んふうううぅ！　ペニスがアソコの震えに合わせて、ビクビクしているっ！\n　ま、まだだっ！　まだ出すなっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0304216" ]},
		{"command":[ "SETIMAGE", "0", "still_00010003_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あと、少しで……！　んんんっ！　気持ちいいのが、どんどん迫ってきてっ\n……！　あっ、あっ！　ぐっ、ああああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0304217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
