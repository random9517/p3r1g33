{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024901_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「本日のお掃除はボイラーの内部洗浄ですのね。カツマ様はボイラーのお掃除\nの経験はございまして？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0104101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「あら、ボイラーは初めてなのですか。では私が説明をいたしますので、どう\nか気負わずに作業してくださいませ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「まず使う道具ですが、専用の洗浄機がございますので、そちらをお使いくだ\nさい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0104103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「洗浄機のノズルを私の洗浄口に入れてスイッチを押していただくと、お水が\n出てきてボイラーの中が洗浄される仕組みですの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0104104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「洗浄口は車体の側面にありますわ。あまり激しくならないよう、まずはゆっ\nくりとノズルを挿入してくださいませ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0104105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「んっ、くっ、あはぁぁぁっ……！　ノズルが洗浄口から、少しずつ奥に入っ\nてきてますわっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0104106" ]},
		{"command":[ "SETIMAGE", "0", "still_00024901_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「あっ！　あんんっ！　う、上手く奥まで入らないのですね……！　でしたら\n、ノズルをしっかりとお持ちいただき、軽く揺らしてください……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0104107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「グリグリしていただけましたら、少しずつ奥へと入っていきますので……！\n　あっ、んひっ！？　あああぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0104108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「この焦らされるような感覚……気持ちいいですわっ……！　不慣れな手つき\nが、私の弱いところを刺激してきますっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0104109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ！　お、奥に入ってきてますっ……！　太くてたくましいノズル\nが、ボイラーの中に……んくぅぅっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0104110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「はぁ、あっ、あはぁ……！　ノズルが奥まで届きましたわね……では、スイ\nッチを入れてお水を出してくださいませ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0104111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「おっ、おほぉぉぉ……！？　お水が少しずつ流れてきて、ボイラーの内部を\n満たしていっていますわっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0104112" ]},
		{"command":[ "SETIMAGE", "0", "still_00024901_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「ですが、この勢いではボイラーに付着している汚れが水圧で流れていきませ\nん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0104113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「カツマ様……お手元のスイッチを操作して、水圧を上げてくださいませんこ\nと……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0104114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「んひっ！？　あっ、あっ！　そ、そうですわっ……！　その調子で、少しず\nつ圧を強めていってくださいませっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0104115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「あああっ！　ノズルの先端がお水の勢いでどんどん膨らんでいっております\nっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0104116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「こんなに太いノズルは初めてですっ……！　たくましくて、硬くて……！　\nとても素敵ですわっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0104117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……！　そのまましっかりとノズルを握って、固定しておいてく\nださい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0104118" ]},
		{"command":[ "SETIMAGE", "0", "still_00024901_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「お水に勢いがありますので、少しでも力を抜くとノズルが暴れて大変なこと\nになって……ひぎっ！？　あっ！？　んひぃぃぃ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「の、ノズルの先端がボイラーの中で暴れておりますぅ！？　ビクビク跳ねて\n、私の大事なところをズンズンって小突いきて……あひぃ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0104120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「おっ、おおおぉぉっ！？　今度は円を描くようにグリグリと撫でまわされて\nおりますわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0104121" ]},
		{"command":[ "SETIMAGE", "0", "still_00024901_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「ど、どうして急にこんなにも荒々しい動きになっておりますのっ！？　か、\nカツマ様っ！　ちゃんとお手元にノズルはございましてっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「そんなっ……！？　しっかり握っておりますが、お水に勢いがありすぎて上\n手く制御できないんですのっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0104123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「でしたら、もう少し圧を弱めてくださいませっ！　そうでなければ、私……\nはしたない声が止まらなくなってしまいますわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0104124" ]},
		{"command":[ "SETIMAGE", "0", "still_00024901_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「おほぉぉぉぉぉぉっ！？　んっ、おっ！？　あっ、あはぁぁぁっ！？　ど、\nどうしてまた水圧が強くなりますのぉ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0104125" ]},
		{"command":[ "SETIMAGE", "0", "still_00024901_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「私は圧を弱めてくださいと申したはずなのに……！　んひっ、ひぎぃ！？　\nノズルが激しく奥を小突いてきますぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「洗浄口がズルズル擦れる感覚もたまりませんわっ！　こんなにも出し入れさ\nれたら、気持ちいいのが車体全体に響いてきますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0104127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「か、カツマ様っ！　早くお手元のスイッチで水圧を操作してくださいませっ\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「ノズルが暴れすぎて、上手く操作できないのですかっ……！？　それでは、\nしばらくこのままだということなんですのっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「そんなの耐え切れませんわっ！　ボイラーの中もお水でいっぱいになってき\nておりますのに、さらにノズルの快感に抗うだなんてっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「んひっ！？　おっ、あっ！　くっ、んんんっ！　排水口のすぐ傍まで、お水\nが迫ってきておりますわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「排水口から汚れが出るときが特に気持ちいいのに……！　ボイラーの中を責\nめられながら排水をすれば、間違いなくイッてしまいますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「あっ！　やっ、あああっ！　イキたくないのに、ボイラー内部の振動に合わ\nせて車体全体が震えておりますぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「こんなの、我慢できませんわっ！　私、イッてしまいますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「ひっ、んひっ！？　あっ、イクッ！　イキますわっ！　ノズルでズポズポさ\nれながら、排水してしまいますぅぅぅっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0104135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「んひぃぃぃぃぃっ！？　ボイラーに詰まった汚れと共に、お水がびゅーびゅ\nー出ていますわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0104136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024901_02_04" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「今まで感じたことのない排水感覚で、たまらなく気持ちいいですっ！　汚水\nを吐き出すの、たまりませんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0104137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「あっ、んっ、あっ！　気持ちよすぎて、煙突から煙も出ておりますわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「粗相に粗相を重ねるなんて、淑女としてあってはならないのに……この快感\nに抗えませんのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0104139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「あああぁんっ！　カツマ様ぁ！　もう勘弁してくださいっ！　お願いですか\nら、お水を止めてくださいませぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「はぁ……くっ、んふっ……！　よ、ようやくお水が止まりましたのね……！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0104201" ]},
		{"command":[ "SETIMAGE", "0", "still_00024901_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「あまりにも勢いがありすぎたせいか、お水も全て排水口から出し切ってしま\nいましたわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「あっ、いえ……！　上手くお掃除できなくて申し訳ないだなんて……！　そ\nんな、謝らないでくださいませっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「初めてのお掃除でしたので、仕方ありませんわ。それに、私も気持ちよかっ\nたですし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0104204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「せっかくの機会ですし、もしよろしければもう一度ボイラーの内部を洗浄し\nていただけますと幸いですわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0104205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「あんっ……！　またノズルが奥にまで入ってきております……！　やる気に\nなってくださったのですね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0104206" ]},
		{"command":[ "SETIMAGE", "0", "still_00024901_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「あっ、ふっ、ああぁっ！　そ、そうですわ……！　その調子でノズルをかき\n回しながら、奥まで突き入れてくださいませっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「奥まで入ったら、あとはお水の出るスイッチを押して……そ、そうです……\n！　その調子ですっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「はああぁ……！　２回目の洗浄で、さらに汚れが洗い流されていっておりま\nす……！　とても気持ちいいです……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「ですが、何でしょうか……この物足りなさは……もっと強い水圧で、ボイラ\nーの内部を綺麗にして欲しいとさえ思ってしまいます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0104210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「あっ、あの……カツマ様……！　可能であれば、もう少し水圧を強めていた\nだいてもよろしいでしょうか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0104211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「もっと綺麗にボイラーの内部を洗浄したいですし、カツマ様にしっかりとノ\nズルを制御していただければ、大丈夫ですので……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0104212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「んんっ！　また水圧が強くなってきてます……！　こ、この感覚……クセに\nなってしまいますわっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0104213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「あっ！　んひっ！　おっ、おおおぉっ！？　か、カツマ様っ！　このままノ\nズルを前後させて、お水を押してくださいませっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0104214" ]},
		{"command":[ "SETIMAGE", "0", "still_00024901_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「その方が汚れも早く落ちますし……！　はひっ！？　あっ、あっあっ！　こ\nれですわっ！　この感覚、たまりませんのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0104215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「ノズルがズポズポされる快感と、ボイラーの中がお水で満ちて、押し広げら\nれる感覚……！　最高ですわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0104216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「もっと激しく突いてくださいませっ！　私のボイラー、いっぱいノズルでズ\nポズポしてくださいませぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0104217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「ああああっ！　いいっ！　いいですわっ！　排水口にもお水が迫ってきてお\nりますぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0104218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「このまま最後までお掃除してくださいっ！　私の身体、お水で綺麗にしてく\nださいぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0104219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「んひぃっ！？　イクッ！　イキますわっ！　ノズルを出し入れされながら、\nまたイッてしまいますぅぅぅ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0104220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「おほぉぉぉぉぉっ！？　さ、さらに奥までノズルが入り込んできております\nぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0104301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024901_02_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「排水の感覚だけでも気持ちいいのに、さらにノズルを奥に突き入れられると\n……か、感じすぎてしまいますわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「あああぁんっ！　また煙突から煙も出ておりますっ！　気持ちいいのが、全\n身から溢れてきてますぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0104303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「これでは全身の震えが止まりませんわっ！　気持ちよすぎて、さらに排水の\n勢いも増していってしまいますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0104304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「ひぎっ！？　あっ、んはぁぁぁっ！？　汚水をびゅーびゅー出すのたまりま\nせんっ！　気持ちいいの、止まりませんわぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0104305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「ああっ……こんなにも激しく感じて、我を忘れてしまうだなんて……とても\nはしたないですわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0104306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「えっ……？　ボイラーの汚れが落ちたか知りたいのですか……？　も、勿論\n、全て綺麗に落ちておりますわ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0104307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「汚水もしっかりと流れ出ておりますし……って、ダメですっ！　私の汚いお\n水、見ないでくださいませっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0104308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「例えカツマ様といえど、見られたくないものもございまして……！　ううぅ\n……お恥ずかしい限りですわっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「ですが、おかげでかなり綺麗になりました。本当にありがとうございます。\n助かりましたわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「きゃあああぁっ！？　の、ノズルが急に引き抜かれて……！　おっ、おおお\nぉっ！？　車体全体にお水がかかってますぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0104401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024901_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「ボイラーの中だけでなく、全身にお水をかけられるなんてっ！　こんなの気\n持ちよすぎますわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0104402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「あっ！　んひっ！　排水口からもお水がびゅるびゅる出ておりますっ！　気\n持ちいいのが、どんどん溢れておりますわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0104403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「中も外もお水でいっぱいにされるなんてっ……！　気持ちよすぎて、またイ\nッてしまいますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0104404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「ひぐっ、んんっ！　あっ、あっ！　イクッ！　イキますっ！　お水をかけら\nれながら、イキますのぉぉぉっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0104405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、あふっ……！　ボイラーのお掃除だけでなく、洗車までして\nいただけるなんて……嬉しいですわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0104406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「うふふっ……洗車は不可抗力とはいえ、こうしてカツマ様の手で綺麗にされ\nたことが、私にとってはとても大事なことなのです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0104407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「それにカツマ様のお掃除は荒々しくも心地よくて……つい夢中になって、感\nじすぎてしまいましたわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0104408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「あの、カツマ様……もしよろしければ、またお掃除をお願いできませんこと\n……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0104409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「お掃除ならいつでも大歓迎ですの……？　まあ、嬉しいですわっ！　では、\nまた明日もお掃除をお願いいたしますね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0104410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}