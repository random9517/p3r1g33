{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012801_01_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "PLAYVOICE", "128_0103101" ]},
		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「ほら、ほらほらほらぁ、どうなん？　キモチええのん？　ふ～ん……そうな\nん。ウチは若干気持ち悪いわー……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "128_0103102" ]},
		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「チンコって、けったいな形してるやん？　いや、形だけやない……この感触\n……。何これ？　わけわからへんわ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012801_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "128_0103103" ]},
		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「グニグニして変な感じやわ……ソーセージ踏んづけたらこんな感じなんかな\n？　まあ、食べ物を粗末にするつもりはないけどな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "128_0103104" ]},
		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「……え？　痛い？　強すぎ？　そんなん言われてもなぁ……足の指のコント\nロールってそんなに簡単ちゃうで？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "128_0103105" ]},
		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「練習もなく突然こんなことさせて、それで上手いこといくわけあらへんやん\n？　せやから……ガマンやでぇ……ガ・マ・ン……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "128_0103106" ]},
		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「なんなん、その顔……気持ちエエの？　困ってんの？、どっちなん？　なん\nか、ウチもどんなテンションでやったらエエんかわからへんわ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "128_0103107" ]},
		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「はぁ、なんやて？　もっとグイグイ強くやれ？　けど、痛いのはお手柔らか\nに……やって？　めっちゃムズいやん……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012801_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "128_0103108" ]},
		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「まあ、やるけどやなぁ……けど、こんなんホンマにパワーアップになんの？\n　なんかあとでアンタに会うた時、気まず～い気持ちにならへん？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "128_0103109" ]},
		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「はぁ……それも込みで楽しい……？　アンタなぁ……ガチンコの変態なんや\nね……はぁ……そんなん上官にせんとならんとは……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012801_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "128_0103110" ]},
		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「ホンマ、ウチは宇宙で一番不幸なお姫様や……はぁ……はぁ……ちょっと疲\nれてきてもうたわ……まだ続けなアカン？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "128_0103111" ]},
		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「え？　何？　だんだん気持ちよくなってきた……？　そらそうやろ。気持ち\nよくなかったら、これ、ウチが暴力奮ってるだけやもんな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "128_0103112" ]},
		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「暴力は大好きやけど……チンコをピンポイントにいたぶる趣味はないねん…\n…けど、ん、ふぅ……ちょっとだけ楽しなってきたわ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "128_0103113" ]},
		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「もう、何なん？　アンタ……めっちゃ興奮してるやん……ハァハァ言い過ぎ\nやで。アカン……そんなに呼吸したら、部屋の空気薄なるで」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "128_0103114" ]},
		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「うわっ、これ、エグいな……チンコ、ガッチガチになってるやん……うわぁ\n……こ、これって、その……イク寸前なん？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012801_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "128_0103115" ]},
		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「へ？　まだまだイカへんの？　せやのに、こんなにカッチカチのヌルヌルに\n……ってか、なんでこんなにヌルってんの？　射精……したん？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "128_0103116" ]},
		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「はぁ……ガマン汁？　なんや、それ……ウチ、その……あんまり性教育マジ\nメに受けてへんから、詳しぅ知らんねん」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012801_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "128_0103117" ]},
		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「マンコの中にチンコ挿れて、射精したら妊娠する……そんぐらいしか知らん\nわ……せやから、何で今こんなヌルヌルなってんのか、理解でけへん」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "128_0103118" ]},
		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「はぁ……ガマン汁は精液とは違う……気持ちいいと溢れ出す変な汁……？　\nうん、変な汁やわ……だって、こんなにヌルヌルしてんねんもん……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "128_0103119" ]},
		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「とにかく、自分、気持ちよぉなってんねんな？　そうか……ほな、このまま\n続けさせてもらうで……なんかウチもちょっと楽しなってきたわ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "128_0103120" ]},
		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「心配せんでエエ……強くしたりせぇへん……。痛くしないようにしつつ、激\nしくチンコ踏みにじったるわ……覚悟しーやぁ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012801_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "128_0103121" ]},
		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「ほ～ら……どうやぁ？　はぁ、ふぅ……チンコ、ドエライことになっとるで\nぇ……我慢汁でビッチャビチャになっとる……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "128_0103122" ]},
		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「この音……聞こえる？　ニチャニチャ音立てて……うわぁ、やらしいなぁ…\n…ウチ、変な気分になってきたわ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "128_0103123" ]},
		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「え？　何？　もっとスカートの中がみたい？　自分、何言うてんの。なんで\nウチがそこまでサービスせんとアカンねん」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012801_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "128_0103124" ]},
		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「へ？　上官の命令？　それに恥ずかしい方がパワーアップ出来るから？　そ\nれ、本気で言うてんの……？　はぁ……しゃあないなぁ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "128_0103125" ]},
		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「ほら、しっかいみーやぁ……ウチのパンツなんか、滅多に拝めへんで……へ\n？　何、匂いかぎたい……？　アホ……そこまでさせるわけないやん」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "128_0103126" ]},
		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「はぁ？　じゃあせめておっぱいアピールをもっと……って、せやから、なん\nでウチがそこまでせんとアカンねんちゅーとるやん……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "128_0103127" ]},
		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「はぁ、わかったわ……そんな切ない顔せんといて……ウチ、乳小ちゃいから\n、ちょっと恥ずかしいねん……あんま見んといて……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "128_0103128" ]},
		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「ほわぁ？　何、これ……チンコ、ギンギンやん……ウチのつま先の中で、脈\n打ってる……うわぁ、なんかごっついなぁ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012801_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "128_0103129" ]},
		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「へ？　何？　イキそう……？　何、自分……こんなことされて、ホンキで気\n持ちよくなってんの？　うわ、エグいなぁ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "128_0103130" ]},
		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「自分、マジ変態やわ……救いようないわ……せやけど、ウチは見捨てたりせ\nーへんでぇ……ほら、しっかり気持ちよぅなりやぁ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012801_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "128_0103131" ]},
		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「さぁ、どうや？　気持ちいいエエやろ……はぁ、ふぅ……ほら、ほら、そろ\nそろイッてもエエねんでぇ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "128_0103132" ]},
		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「先っちょが赤紫に腫れ上がっとるやん……はぁ、はぁ……ああ、エグい……\nなんやこれ……踏み潰してやりたい気分や……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "128_0103133" ]},
		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「エエで……早ぅ射精しぃ……ウチにイクとこ見せてや……はぁ、はぁ……出\nして……精液、タップリぶちまけたってぇ……ん、ん、んん～～」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "128_0103134" ]},
		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「ひゃううぅ！？　うわぁっ、なんやこれぇ……うわ、うわ、\nうわ～～……エゲつなぁ～～……思ったより白くないねんな……」", "NORMAL" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012801_01_06" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "128_0103135" ]},
		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「けど、なんやねん、この匂い……胸が悪ぅなる……うう、気色悪ぅ……足の\n指が溶けてしもうたみたいやわ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "128_0103136" ]},
		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「つま先の中でビュクビュク脈打っとる……ああ、なんやろ……今、結構楽し\nい……ウチ、これ、気に入ったかも……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "128_0103137" ]},
		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「あー、精液はあんまり好きになれんかも……この匂い、ちょっとなぁ……け\nど、これがマンコの中にぶちまけられるんやな……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012801_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "128_0103138" ]},
		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「ちょっと想像つかんけど……いずれ、そんな時も来るんやろうなぁ……プリ\nンセス道の行き着く先っちゅう感じやな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "128_0103139" ]},
		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「へ？　何？　アンタが中出しキメたい？　ちょ、自分……何言うてんのかわ\nかってんの？　ウチ、巷で有名な『カイザーナックル姫』やねんで？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012801_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "128_0103140" ]},
		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「……ホンマ物好きなんやなぁ。まあエエわ……ウチとしたいっちゅうなら、\nそうなるように行動してみ？　ウチはな、お安い女と違うんやさかいな」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012801_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}