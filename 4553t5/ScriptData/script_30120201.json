		{"command":[ "PLAYVOICE", "v2_012_0203103" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「えぇ～？　警備員さんのオチンチンを舐めるだけ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYVOICE", "v2_012_0203104" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「ほーんと警備員さんってエッチなことば～っかり考えてるんだから～」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYVOICE", "v2_012_0203105" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「でもい～よ、それで喜んでくれるなら……んふふ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYVOICE", "v2_012_0203106" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「わぁ……もうすっごくカチカチになってる……！　熱くて硬くて、おっきい\nよ～」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001202_01_01" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYVOICE", "v2_012_0203107" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「寝転がってる警備員さんのオチンチン、ちゅっぱちゅっぱ吸っちゃうね？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYVOICE", "v2_012_0203108" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「え～っと、こうかな？　お手々でオチンチン持ってぇ……ふあぁ、ビクビク\nって跳ねてるぅ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYVOICE", "v2_012_0203109" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「先っぽを舐めて欲しいの？　うんっ、い～よ？　お手々でゴシゴシして～…\n…」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYVOICE", "v2_012_0203110" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「ちゅっ、ちゅるる、ちゅぱ……ぴちゅ、ちゅっ、ちゅうぅ、ちゅっ……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001202_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYVOICE", "v2_012_0203111" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「けーびいんさんのオチンチン、もっと硬くなってきちゃってる……んふふっ\n」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001202_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYVOICE", "v2_012_0203112" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「気持ち良くなってくれてるのかな～？　ほーら、ゴシゴシしちゃうよ～」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001202_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYVOICE", "v2_012_0203113" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「えっ？　玉も撫でて欲しいの？　じゃあこっちの手で～……ゴシゴシしなが\nら、揉んじゃうんだから」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYVOICE", "v2_012_0203114" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「んふふ、すっごくイイ顔してる～♪　喜んでくれてるんだね～」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001202_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYVOICE", "v2_012_0203115" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「嬉しくなってきちゃった。じゃあ、お口でも……ちゅっ、ちゅるる、ちゅぱ\n……んふあぁ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001202_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYVOICE", "v2_012_0203116" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「なんか縦笛みたい……ちゅ、ちゅぱぁ……ちゅっ、ちゅうぅ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001202_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYVOICE", "v2_012_0203117" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「ふぇ？　オチンチンを咥えるの？　い～よ、咥えればいいんだね？　それじ\nゃ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001202_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYVOICE", "v2_012_0203118" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「あむっ、んふぅ……ちゅぷぷ、ちゅる！　ちゅるる！　ちゅぷ！　ちゅぷぷ\n！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001202_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYVOICE", "v2_012_0203119" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「んむぅ……警備員さんのココ、ますます硬くなってきたぁ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYVOICE", "v2_012_0203120" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「もう鉄の棒みたいだよ？　こんなのしゃぶらせるだなんて、いけないんだぁ\n～」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYVOICE", "v2_012_0203121" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「はむっ……ぢゅぷぷ！　ちゅむっ、ちゅむむ！　じゅぷ、じゅぷぷ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYVOICE", "v2_012_0203122" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「んっ、んんぅ～！？　ふあぁ、いきなりおっぱい弄るのダメぇ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001202_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYVOICE", "v2_012_0203123" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「そこっ、んっ、んんん……っ！　乳首弱いんだもん、んあぁぁん……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYVOICE", "v2_012_0203124" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「そ～いうイタズラする子にはお仕置きだぞ～？　オチンチン、す～っごく深\nく咥え込んじゃうんだから～」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001202_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYVOICE", "v2_012_0203125" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「んぁん！　おっぱいイタズラ、ダメぇ……あ、あむぅ！　じゅむむ……じゅ\nぅぅっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYVOICE", "v2_012_0203126" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「んぢゅっ、じゅるるる……！　じゅっぽ！　じゅぽぉ！　えほっ、えふぉ！\n」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001202_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYVOICE", "v2_012_0203127" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「だ、だいじょ～ぶ！　いっきに喉までいっちゃっただけだから。喉まで咥え\n込んじゃうもんね～」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYVOICE", "v2_012_0203128" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「あむぅ……んじゅ、じゅるりゅ、だいたい分かってきたもん……じゅるりゅ\n、じゅるるる……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYVOICE", "v2_012_0203129" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「んみゅっ、じゅぷぷ！　ぢゅっぽ！　じゅむむ！　じゅむっ！　じゅむむ！\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYVOICE", "v2_012_0203130" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「んんぅ！？　だからぁ、乳首ダメって……んあぁぁん！　ふぇ？　イキそう\n、なの？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYVOICE", "v2_012_0203131" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「じゃあ一緒にイこう？　わたしと一緒に……おっぱいイタズラしていいから\nぁ……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001202_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYVOICE", "v2_012_0203132" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「じゅぷぷ、じゅぷ！　じゅっぷ！　じゅむみゅ、んふぅ、ん～っ！　じゅる\nる、じゅぷ！　じゅぷっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001202_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYVOICE", "v2_012_0203133" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「んあぁぁん……！　んっんん、んぅぅ～～～っ！？　ふあぁ！？　なんかオ\nチンチンがビクビクしてるっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYVOICE", "v2_012_0203134" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「ひゃうぅ！？　あっ、んああぁ、あっ……あああぁぁ～～～～！！！！」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001202_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYVOICE", "v2_012_0203135" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「あふぅぅっ、んあぁ！？　わあぁ……す、すっごくたくさん精液が出てるぅ\n……んあぁ、もぅ、おっぱいも顔も精液まみれだよぉ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYVOICE", "v2_012_0203136" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「くんくん……んはぁ、ちゅる、ちゅりゅ……！　ごっ……くん。んん～っ、\n美味しくないなぁ～」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYVOICE", "v2_012_0203137" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「……でも、何だかとってもエッチな味がする……んふふっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYVOICE", "v2_012_0203138" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「え？　もっとオチンチンしゃぶって欲しいの？　しょうがないな～」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001202_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYVOICE", "v2_012_0203139" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「それじゃ、警備員さんがマイッタって言うまでしてあげるね～えへへ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYVOICE", "v2_012_0203140" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「これから、もっともっとエッチなこと、しよ～ね？」", "NORMAL" ]},
