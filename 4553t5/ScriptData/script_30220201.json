{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「ボクもいろんなエッチを経験してきたけど、一番記憶に残ってるのはパイズ\nリかな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0203101" ]},
		{"command":[ "SETCHARA", "0", "char_00002202_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「生殖を目的としないエッチが斬新だったのと、多少強引に迫られたというこ\nとがあってね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0203102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「最初は戸惑ったし、少しだけ怖かったけど……好意を寄せている相手だった\nから、イヤじゃなかったよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0203103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「……ん？　その時の話を聞かせて欲しいのかい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0203104" ]},
		{"command":[ "SETCHARA", "0", "char_00002202_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「はあ……本当にキミはその手のセクハラが好きだね。でもまあ、話すぐらい\nなら別にいいかな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0203105" ]},
		{"command":[ "SETCHARA", "0", "char_00002202_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「ちょ、ちょっとキミ！？　自分がなにをしているか、わかっているのかい！\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0203106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00002202_01_02" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「ボクの胸に無理やりオチンポを挟むだなんて……！　こんなの、恋人でもし\nないことだよ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0203107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「えっ……ボクのおっぱいを見てたら、我慢できなくなった……？　悪いけど\n、パイズリさせて欲しい……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0203108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「それにこれは、ボクのチカラを高める効果があるから、お互いにウィンウィ\nンな関係になる……？　そんなウソ、信じるワケないだろう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0203109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「べ、別にキミが相手だから、イヤということはないけど……！　心の準備と\nいうモノがだね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0203110" ]},
		{"command":[ "SETIMAGE", "0", "still_00002202_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「それに、もし本当にチカラを高めることが出来たとしても、こういうのはも\nっとお互いを知ってからの方がいいと思うんだ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0203111" ]},
		{"command":[ "SETIMAGE", "0", "still_00002202_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「な、なんだい、その顔は……！　わかった！　わかったから！　ボクの胸を\n使ってパイズリしていいから、そんな悲しそうな顔をしないでくれ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0203112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「まったく、キミというヤツは……相手がボクだからいいものを……もし他の\n子にこんなことしたら、タダじゃ済まないんだぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0203113" ]},
		{"command":[ "SETIMAGE", "0", "still_00002202_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「こんなことをしたいと思うのはボクだけ……？　ボクのおっぱいだから興奮\nした……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0203114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「そ、そそそ……そうなんだ……！　それもこれも、ボクがグラマラスで、魅\n力的すぎるせいかな……は、はははっ。ボクって罪作りな女だね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0203115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「んっ、あふっ……！　おっぱいが強く揉まれて……！　ほ、本当にパイズリ\nするんだね……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0203116" ]},
		{"command":[ "SETIMAGE", "0", "still_00002202_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「熱さとカタさが、谷間から伝わってくる……これがキミのオチンポなんだね\n……！　男らしくて、すごくたくましいよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0203117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「んぐっ、あっ、うふっ……！　あっ……あっ……！　ボクの目の前で、オチ\nンポが出たり入ったりしてる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0203118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「先端から汁も出てきて、変なニオイもしてくるし……こんなの、エッチすぎ\nるよぉ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0203119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「あっ、んんっ……！　ね、ねえ……ボクのおっぱい、気持ちいい……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0203120" ]},
		{"command":[ "SETIMAGE", "0", "still_00002202_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「ふああぁ……！　オチンポがビクって跳ねて……んんっ！　も、もう……オ\nチンポで返事しないで、ちゃんと言葉に出してくれたまえ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0203121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「あっ、いや……気持ちいいなら、それでいいんだ……！　ボクの胸でキミが\n悦んでくれるなら……すごく嬉しいし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0203122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「きゃっ……！？　急に手にチカラが入って……はああぁん！　そんな乱暴に\n胸を揉まないでくれ……んんっ！　乳首、大きくなっちゃうからっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0203123" ]},
		{"command":[ "SETIMAGE", "0", "still_00002202_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「はぁ、あっ……ふぐっ、くううぅ……！　エッチな汁がボクの汗と絡まって\n……ぐちゅぐちゅって、いやらしい音が鳴ってるよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0203124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「オチンポの滑りもどんどんよくなってきてるし……はぁ、ああっ……！　こ\nんなの、ボクも気持ちよくなっちゃう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0203125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「ひぐっ、んふううぅ……！　やっ、あああぁんっ……！　ボクの勃起した乳\n首……刺激しないで……くっ、あっ……ふああぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0203126" ]},
		{"command":[ "SETIMAGE", "0", "still_00002202_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「あっ、ああっ！　ダメ……！　おっぱいがオチンポのカタチになってるっ…\n…！　グニグニって、いやらしく変形してるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0203127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「こんなの、まるで性器じゃないか……！　おかしいよ……おっぱいがオマン\nコみたいになるなんて……非科学的だ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0203128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「ふえ……？　ボクのおっぱいオマンコ、すごく気持ちいい……？　孕ませた\nい……？　な、なにを言っているのかね……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0203129" ]},
		{"command":[ "SETIMAGE", "0", "still_00002202_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「おっぱいで孕むことなんて、本当に非科学的だ……！　絶対にありえなっ…\n…いや、ボクが肉体改造をすればできないこともないけど……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0203130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「そもそも、孕ませるって妊娠させるということだよね……！？　ぼ、ボクと\nキミはそういう関係じゃないだろう……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0203131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「これはあくまでも、チカラのためであって……あああっん！　オチンポの動\nきが速くなってっ……それに、すごくビクビクしてるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0203132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「ちょ、ちょっと……！　ボクの話を聞いて……！　あぐっ、んむうぅ……！\n　えっ……そ、そろそろイキそう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0203133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「イクって……精子が出るってこと……！？　ま、待って……！　いま出され\nたら、ボクも気持ちよくてイッちゃう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0203134" ]},
		{"command":[ "SETIMAGE", "0", "still_00002202_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「あああっ……オチンポ跳ねまくってるっ……！　やっ、あっあっ……！　ひ\nぐっ、んくっ……はぁ、あっ、ああああぁんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0203135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「で、出てるっ……！　ボクのおっぱいに、白いのドクドク出されてるぅ……\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0203136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002202_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「これがキミの精液……！　ボクを孕ませる、赤ちゃんのモト……はああぁ…\n…！　ダメ……！　嬉しくて、イッちゃうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0203137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「おっぱいで妊娠なんてしないのに……！　どぴゅどぴゅされるのが、たまら\nなく嬉しくて……か、感じちゃうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0203138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「はあああぁっ……！　オマンコイクッ……！　イッちゃうっ……！　射精さ\nれながら、イッ……イクッ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0203139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「ああああっ！　あっ、んひっ！　くるっ、くるぅ！　オマンコからすごいの\nきて……んんんっ～～～～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0203140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「ふぅ、ふぅ……ボクのおっぱいが気持ちいいのはわかるけど……さすがに興\n奮しすぎだよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0203201" ]},
		{"command":[ "SETIMAGE", "0", "still_00002202_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「確かに、ボクも気持ちよくてイッちゃったけど……少しは人の話を聞いても\nらいたいものだね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0203202" ]},
		{"command":[ "SETIMAGE", "0", "still_00002202_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「んっ、あふっ……あまり長々とお説教をするのもアレだし……そろそろ手を\n離してもらってもいいかい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0203203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「……えっと、ボクの話を聞いてたかい？　おっぱいから手を離して……え？\n　まだ出したりない……？　もっとパイズリしたい……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0203204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「いやいや！　もう十分出したじゃないか！　たくさん出せば、チカラも増す\nって……そ、そんなこと言われても……！　あっ、はああぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0203205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「ひううっ、はぁ、あっ、んふううぅ……！　さっきよりも激しくオチンポが\n出し入れされてるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0203206" ]},
		{"command":[ "SETIMAGE", "0", "still_00002202_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「さっき出された精液が、おっぱいとオチンポに絡んで……はぁ、あああっ…\n…！　ローションみたいに、ヌルヌルして……んっ、んああぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0203207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「ダメっ、ああっ！　気持ちいいっ……！　おっぱい乱暴に犯されてるのに、\n感じちゃうじゃないかぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0203208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「んぐっ、ふぐっ……はぁ、んはあぁ……！　精液のニオイも濃くなって……\nんっ、はああぁ……嗅いでるだけで、オマンコ疼いちゃう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0203209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「やっ、ああぁ！　ち、乳首を押さえつけないでくれたまえ……！　そんなこ\nとされたら、もっと感じて……んふううぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0203210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「オマンコが切なくて……きゅんきゅんするぅ……！　キミの精子が欲しくて\n……妊娠したくて、たまらないよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0203211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「うううっ……！　でも、これはセックスじゃないし……！　こういうのは、\n恋人同士がするものだから……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0203212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「はああぁ！　おっぱいが強く押されて……んっ、あふっ……！　ボクの谷間\nに、オチンポがべったり引っ付いてくるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0203213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「ボクのおっぱい、キミ専用のパイズリ穴になってるっ……！　こんなの、エ\nッチすぎるよぉ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0203214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「んうぅ、ふぎゅっ、ひぐうぅ……！？　ど、どうしてまた激しく腰を動かす\nんだい……！？　ボク、なにか変なこと言ったかな……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0203215" ]},
		{"command":[ "SETIMAGE", "0", "still_00002202_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「出来るなら、本当に孕ませたい……？　なっ、なにを言っているんだい、キ\nミは……！　こんな、年増女に……んっ、あああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0203216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
