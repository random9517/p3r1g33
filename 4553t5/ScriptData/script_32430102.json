	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「ついに……この日が来てしまったな……。あっ、いや……。嫌だとかそうい\nうことではまったく無く……。ただ、感慨深くて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0104101" ]},
		{"command":[ "SETCHARA", "0", "char_00024301_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「私は……戦うことしか出来ない粗忽者だし、こうして……男を喜ばせるすべ\nは何一つわからない。それでも……いいと言ってくれるのなら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0104102" ]},
		{"command":[ "SETCHARA", "0", "char_00024301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「抱いて……ほしい。いや、抱いてください。私を貴方のオンナにしてほしい\n。どうか、お願いします……。……あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0104103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「ふ、ぅ……っ。ううぅ……！　あ、あのっ……私が震えているのは怖いから\nではなく、き、緊張、緊張しているだけだから……始めてほしい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0104104" ]},
		{"command":[ "SETCHARA", "0", "char_00024301_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「私は貴方を信頼している。だから……何をされても文句は言わないから。さ\n、触って……。す、好きなように使ってください……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0104105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「奥手で……自分からは何も出来ない私だけど……。今夜は！　今夜からは…\n…あなたに悦んでもらえるように頑張るから……。あぁ、でも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0104106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「まだ……信じられない。貴方の肉棒が、私の身体を見てそんなに大きくなっ\nているなんて……。……いや、想像より……遥かに凄いけれど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0104107" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00024301_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「そっ……それがこれから私の中に入るのだよな？　処女膜を貫いて……。私\n本人すら触ったことのない深い場所にもぐりこんできて……っはぁっ、はぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0104108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「……駄目だ。想像だけで……アソコがヒクヒクしてしまう。恥ずかしいから\n……あまり見ないでくれ。んッ……私のここ、おかしくないか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0104109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「お、まんこ……。そう呼ぶように、貴方が教えてくれたから……。おまんこ\n……ちゃんと綺麗にしてきました。すみずみまで清めて……。んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0104110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「きゃ……！　胸……胸を触って……。んっ、キスをして……。ちゅっ……。\n次に、脚……？　はぁっ！　はぁっ、はぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0104111" ]},
		{"command":[ "SETIMAGE", "0", "still_00024301_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「そんなに焦らさないでくれ……。貴方から見れば一目瞭然のはずだ。私、私\nのおまんこは……潤んで、花開いて、貴方の肉棒を待っている……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0104112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「手のひらでの愛撫も嬉しいが……。今、私はもう……肉棒の、男根のことを\n知りたくて我慢ができないんだ。挿入てくれないか……早く、はやく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0104113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「あっ……！　そう、そうだ……そう！　私は頑丈だから……一気に肉棒を入\nれてもおそらく平気だから……奥まで……！　ふぁあああああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0104114" ]},
		{"command":[ "SETIMAGE", "0", "still_00024301_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「あっ、あぅぁあああっ……！　んぁあああっ……ああああ……！！　んぁあ\nっ！？　あふぅっ！？　あひっ……！？　うううっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0104115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「へ……？　あぅっ！？　な、に……？　なに？　お腹……内側から張り裂け\nそうなくらい大きい！　あれっ？　あれ、目で見ていたよりずっと……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0104116" ]},
		{"command":[ "SETIMAGE", "0", "still_00024301_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「あ！　なにっ！？　なに、太い……！　ああああっ！？　大丈夫、大丈夫だ\nが……！　んふぅうっ！　いや、痛みよりも……太くて、あっ、太いぃい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0104117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「あっ……！　これが、これが肉棒の感触なのか……！　やっ……あっ、これ\n……！　これ、私の剣よりスゴい……っ！　硬くて重たくて……あはっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0104118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「あッ……んんっ？　あれっ……！　すごくぴったりハマっている……！　あ\nっ……！　私の割れ目、こじあけて……中をぎちゅぎちゅこじあけて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0104119" ]},
		{"command":[ "SETIMAGE", "0", "still_00024301_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「っぅっ……♪　ドクドクいっているのは、私の粘膜なのか……。あ、貴方の\n肉棒の脈打つさまなのか……？　わ、わからない……わからない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0104120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「あっ……これが、これがセックス……！　ううう……っ。しょ、少女漫画で\n見ていたよりずっと生々しいし……。や、だ……気持ち良すぎる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0104121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「ま、待ってくれ……！　動くのはまだはや……イィイイっ……！　んひぃっ\n！　嘘だろうっ！？　嘘だろうっ……？　なに、なに、しゅごい！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「肉棒……肉棒ぉおお……！　男根、軽くにゅちにゅち前後されただけで……\n全身おかしくなるっ……！　あっ……あ！　痺れる、貫かれているぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0104123" ]},
		{"command":[ "SETIMAGE", "0", "still_00024301_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「ひぁっ、あぁ、あっ、あぁ……あぁ！　あっ！　足を押さえられて、……し\nっかり捕まれて、道具のように揺さぶられて……それが気持ちいい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0104124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「んふっ……ふぅっ……！　ふぅううっ……♪　しょ、処女は……はじめての\n女は慣れていないから、痛いだけだと聞いていたのに……違うじゃないかっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「き……もちいい、いきなり気持ち良くて、……あっ！　好きに、なる……セ\nックス、肉棒っ……肉棒が出たり入ったりすると……気持ちいい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「あっ！　あっ！　あっあっ！　わ、私……わたひぃ……！　淫乱だったのか\nぁ……！？　したことないのに、本当に自分ですらしたことがないのにぃっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0104127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「肉棒を押し込まれて……はぅっ！？　奥っ、奥をトントンされて……あっ！\n　あっ、中っ……えぐられるだけで……気持ち良さしかわからない……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0104128" ]},
		{"command":[ "SETIMAGE", "0", "still_00024301_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「んひっ……！　ひぃっ……！　え？　こうなるように……。はじめてでイキ\n狂えるように、ずーっと私を開発してきた？　あ、貴方が……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「時間をかけて、私の心と身体をほぐして……準備してきたから、こうして男\n根に反応するのは当たり前？　そうか？　ほんとうにっ……そうなのか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「なら……なら、いいのか……？　ふ、ぅっ♪　私……感じてしまって正常、\nなの、か……？　だって……だって、男性器なのに……！　っあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0104131" ]},
		{"command":[ "SETIMAGE", "0", "still_00024301_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「赤ん坊っ……子ども、作っているのにっ……それがこんなに気持ちいいなら\n人類全員おかしくなってしまうと思うが……！？　そういうものなのかぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「……ッふぁあっ！　あぁっ……ああ、あっぅっ……ふぅうう……っ！　に、\nにくぼ、う……♪　肉棒……好き、好き……♪　動かされるのすき……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0104133" ]},
		{"command":[ "SETIMAGE", "0", "still_00024301_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「セックス……きもち、いい……！　それは当然のこと、わるくないこと……\nっ。ぁ……っ、準備したから、良い事……だいじょう、ぶ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「あっ……はぁっ、は、ぁ……あぁ……！　信じられな、い……っ。膣内の、\nおまんこのどこを押されても……ひっかかれても気持ちよすぎる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0104135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「んぁああっ！　あぁ……！　こんなはしたない声、あげたくないのに……止\nめられない！　男根……好きだ、好きになってしまったぁあ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0104136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「っぅ……！　たい、ちょぉ……隊長……！　私、私はすごく……すごくイイ\n、おまんこがすごくイイ……！　貴方はどうだ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0104137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「キツくてぬるぬるで最高……？　あぁああ……♪　良かった、良かったぁ…\n…！　うれし、い……うれしい……！　もっとじっくり楽しんでくれっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「私は貴方に気持ち良くなってほし……。んっ？　あれ？　今、男根がビクビ\nクって……あっ！？　これ……は？　どういう現象なんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0104139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「射精……？　私のおまんこに、貴方が精液を注入したいということか！？　\nっうぅ……っ♪　なんていやらしい……もちろん、もちろんいいけれど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「でも、でもやっぱり恥ずかしい……！　直接……直接注入するのか？　おま\nんこに……精子……あっ！　注入っ……注入来るっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0104201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「やっ♪　やぁああああああぁ♪　あぁああああっ……！　あああああああ…\n…ッ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0104202" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024301_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「えっ？　おもらし……っ？　貴方、私の中でおしっこした……！？　あっ…\n…、違う、違う、これ……ちがう、おしっこじゃない……んんんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0104203" ]},
		{"command":[ "SETIMAGE", "0", "still_00024301_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「それよりもっと、はりつく……べったり広がってく……。あっ……こ、これ\nが精液……？　私のおまんこの中、精液で満たされていく……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0104204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「んっ……んくぅっ……！　あぅっ……ああ……！　はぁああっ……！！　ド\nピュ、ドピュって……音が聞こえるくらい激しい……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0104205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「凄まじい量……っ。あっ……注入されてる……。わたしぃ……注がれて……\nあっ……。これが射精……！　膝がガクガクしてしまう……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0104206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「んっ！？　もしかして……出しながら、……あっ♪　また、またセックスす\nるつもりなのか？　あっ、してもいい……もちろんいいが……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0104207" ]},
		{"command":[ "SETIMAGE", "0", "still_00024301_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「再開するなら少し休ませて……。ンッ……！　も、もう動くのか……！？　\nあっ……！　男根……ずっと硬いままで……あっ！　私を突いてきて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「膣内射精されている私がエロかったから……？　あっ♪　え、エロい……の\nか？　私……今、貴方から見て……魅力的なのか？　精液入れられて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「待てずに……ぃっ、セックス続けたくなるほどイイのか……！？　そうなら\n……そうならどんなに……！　あっ……ぅっ、突き上げられる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0104210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「は、ぁ……ッ♪　はぁっ……、は、ぁ……っ！　つよ……い、貴方の男根は\n、強すぎて……あぁっ！　入口から奥まで串刺しだ……ぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0104211" ]},
		{"command":[ "SETIMAGE", "0", "still_00024301_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「あ、あ、もう、もう逆らわないから……あふっ……♪　セックスっ……エッ\nチしていいけど……！　はぁっ……顔……私の顔は見ないで……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0104212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「どうしてもだらしない表情になってしまう、から……！　あっ……気持ちい\nい……ッ♪　きもち……！　くぅううっ♪　気持ちいぃ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0104213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「んっ……んっ……！　貴方は……すごい、初めての私を……ここまで快感の\n渦に叩きこんで……虜にして……っ。才能が、あ……る、すごい……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0104214" ]},
		{"command":[ "SETIMAGE", "0", "still_00024301_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「奥ぅ……っ。私の、わたしの気持ちいいところ……っ、言ってないのに全部\nわかってて……狙って……どちゅどちゅ打ち込んで……うぅう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0104215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「どうしてっ……どうして手に取るようにわかるんだぁ……っ！　あぁっ♪　\n開発……開発の成果？　私の身体、貴方に開発されて……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0104216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「貴方のっ、貴方だけのものに……！　うぅうっ♪　私……わたし、全部……\nっ。顔も胸もおなか、も……おまんこも脚もぜんぶ、ぜんぶ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0104217" ]},
		{"command":[ "SETIMAGE", "0", "still_00024301_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「貴方に開発されて……♪　っ……ど、どうしてかわからない……でも……。\n貴方のものにされたと自覚すると、私……私、おまんこが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0104218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「おまんこが肉棒にまとわりついてしまって……！　あっ♪　自分の腰も揺ら\nっ……揺らしてしまって……淫らになって……！　あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0104219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「また射精……先程の射精してほしいってねだってしまう……望んでしまう…\n…！　限界まで貴方のものにしてほしい、射精してほしい……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0104220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「あっ！　ああああああぁ……！　ああああああ～っ！　きているっ……き、\nてる……！　中に、私の膣内に……おまんこにぃい……ッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0104301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024301_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「あっ……♪　やった……、やった……ぁ。これで……これで、私は本当に！\n　貴方のものに……！　ッんんんんん～～～～……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「……あッ！？　膣内、よりもっと奥……あれっ？　し、子宮にも精液が流れ\nこんでくる？　あッ♪　肉棒が……子宮口にめりこん、で……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0104303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「そ、そんなところにまで精液というものは侵入してくるものなのか……！？\n　……あっ！　そ、そうか、子作りをするためか……！　……ふぁああ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0104304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「赤ちゃん……ッ、できてしまうようなこと……！　私……！　んぅうう……\n！　絶え間なく注ぎ込まれる貴方の精……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0104305" ]},
		{"command":[ "SETIMAGE", "0", "still_00024301_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「貴方の色に染まっていく快感……♪　ふぁああ……♪　私が求めていたもの\nは、これ、だったのか……っ。あぁ、入ってくる、入ってくるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0104306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「……うぅうっ……♪　あっ……すまない、キツく搾り過ぎてしまったかもし\nれない……。だ、だが……自分ではうまく操れなくて……それで」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0104307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「精液を、おまんこがゴクゴク飲み干しているのはわかるのに……止められな\nいんだ。ゆ……許して欲しい。あっ……まだ、搾れる……まだ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0104308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「ん、これ、で……！　……はぁあああ♪　とてつもない満足感だ……。私は\n今まで、こんな世界がある事を知らずにいた……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「でも、貴方とこれからそれを知っていけるのだな……。それが、なんだがす\nごく、すごく……幸せで、嬉しいんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「あぁっ……♪　……あ、れ……？　肉棒が抜けて……。……きゃっ！？　わ\nっ……！？　腹に……胸に精液が……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0104401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024301_02_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「そ、そこは私の中じゃないぞ……！？　やっ……！　わぁっ……！？　駄目\nだ、だめだ、そんなところに出しては……！　ンッ……ふぁああ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0104402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「濃厚な精液が……私の上にふりかけられて……！　肌が熱い……っ、あっ…\n…♪　あっ……♪　なんということを……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0104403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「あああ……。良かったのか……？　貴方は……。私の中ではなく、胸に全て\nを放出してしまって……。んっ……臭いが充満して、すごい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0104404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「そう、か……精液はこんなに強烈な臭いを放っているものなのだな……。け\nふっ……。けほっ……むせかえるほどの悪臭なのに、なぜか落ち着く……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0104405" ]},
		{"command":[ "SETIMAGE", "0", "still_00024301_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「はぁああ……♪　すぅううう……♪　……ん？　クセになる臭いだったから\n……思いきり吸い込んでみたくなって……。失礼だったか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0104406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「ああ。精液の臭いは嫌いじゃない……。それどころか、これに包まれている\nと安心して……。少し、陶酔してしまうくらいで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0104407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「……私にマゾな一面があることを知らなかった……？　そんなの、私も知ら\nないが……。そうか、私にはそういう一面があるのか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0104408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「確かに貴方に抱かれる時、ぐっと押さえつけられると興奮していたかもしれ\nない……。マゾな戦士は嫌いか……？　もし、いやでないのなら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0104409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「たまに、こうして……二人で乱れてみるのも悪くないかなと……思う。貴方\nと私とで……。テリオンにはこんなこと、とても言えないが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0104410" ]},
