{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0128" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_016" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "そして……逃げまわっていたルナテミスは、校舎内に逃げていた。", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「うううう……嫌だ、もうたくさんだぁ……いくら成績が悪すぎるからって、\nどうして私ばかりがこんな目に……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010113100001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「うわーっ！　もう、嫌だぁーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010113100002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "と、半べそをかきながら振り回したルナテミスの剣が、廊下の窓ガラスに当た\nる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「うわぁっ！　　しまった！　窓ガラスが粉々に！　ど、どうしよう……見つ\nかったら大変だぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010113100003" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「とにかく、どこかへ逃げないと……見つからなそうな場所、見つからなそう\nな場所……あった！　あの部屋！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010113100004" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ルナテミスは、丈夫な扉のついた小さな部屋へ逃げ込むと、しっかりとドアを\n閉ざした……。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0128" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_016" ]},
		{"command":[ "SETTEXT", "一方、修羅姫とエファナティカもさすがにバカバカしくなったのか、\nルナテミスを再び探し始めた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ルナテミス様ー！　どこですか！　怒らないので出てきてください！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113100001" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ったく、どこ行ったんだかなあ。おい、ジュンジロー！　匂いを追跡――あ\n、やっぱいいや。おまえにできるわけねえか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「さよう。ワタクシを、そこらのワンコと同様に扱わないでいただきたいです\nな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113100001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「扱わねえよ。さすがにそこらのワンコに失礼だ。いいからおまえは邪魔しな\nいようにどっか行って――」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「…………嫌いだ。みんな大っ嫌いだぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010113100005" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「っ！？　ルナテミス様！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113100002" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "校内放送のスピーカーから、ルナテミスの声が聞こえてくる。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「数学ができなくたって、地学ができなくたって、古文ができなくたって、英\n語ができなくたっていいじゃないか。私は王女なんだぞ、王女」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010113100006" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「王女なんだから、つきみに宿題を写させてもらったっていいじゃないかぁあ\nあああ～～～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010113100007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そんなことしてたんかい。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ルナテミス様！　なんということを……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113100003" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「っていうかルナテミス様、いったいどこにいるんだ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010113100001" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「校内放送をしてるんですから、放送室に決まってます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010113100001" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「そうか！　そうだな！　みんな、行こう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010113100002" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「早く止めてやらないと、取り返しのつかないことになりそうだしな……いろ\nんな意味で」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「学生時代にやらかした記憶って、何年か経ってから精神的に『来る』のよね\nぇ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010113100001" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "bg_0128" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_016" ]},
		{"command":[ "SETTEXT", "と、慌てて放送室前に走ると、そこには――", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「出てこい！　ルナテミス！　放送室の機材を無断で使うんじゃない！　出て\nこーい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113100001" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「お願いだから、早く出てきてぇ～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010113100001" ]},
		{"command":[ "SETCHARA", "0", "char_00001701_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "修羅姫と夜叉が先に来ていた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「またあんたらかい！　そこをどきな！　あたしがルナテミス様と話す！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113100004" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「先に着いたのはこちらだ！　こちらが先に話す！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113100002" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「なんだと！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113100005" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「なにを！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113100003" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「またかよ、いいかげんにしてくれよ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ホントよね……よけいな揉めごと起こさないでほしいんですけどぉ？　めん\nどくさいんだから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010113100002" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「うううう、姉がご迷惑を……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010113100002" ]},
		{"command":[ "SETCHARA", "0", "char_00001701_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0150" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "などと、エファナティカたちがもめている間にルナテミスは……。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「冗談じゃないぞ、まったく……！　なんでみんな、私が放送室にいるって気\nづいたんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010113100008" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「まあ、そんなことはいいか。とにかく、窓から抜け出せてよかった。あいつ\nらに捕まるまえに、どこか――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010113100009" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「やはり、窓から出てきましたか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010113100002" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「げえっ！　オボロ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010113100010" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「こんなことだろうと思ってましたよ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そう思って、エファナティカたちを放置して外に出てきた俺たちと、ルナテミ\nスが鉢合わせした。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「いた！　ルナテミス様！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113100006" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「ルナテミス！　逃がさんぞぉ～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113100004" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "放送室前でもめていたエファナティカと修羅姫も、こちらに駆け付けてくる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「ルナテミス、帰ろう？　勉強は辛いかもしれないけど、遅れを取り戻すチャ\nンスだよ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010113100002" ]},
		{"command":[ "SETCHARA", "0", "char_00001205_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「い、嫌だ！　連れ戻されてたまるか！　もう勉強なんか無理だ！　これ以上\n勉強させられたら、頭がどうにかなってしまうーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010113100011" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "と、ルナテミスが駄々をこねていると、とつぜんどこからともなく――", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「甘いぞ！　ルナテミス！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_020113100001" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「なにっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010113100012" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「な、なんだ！？　この声！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010113100003" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「誰だ！　どこにいるんだ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「なにやら、妙に聞き覚えのある声ですが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113100002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あそこ！　一本杉の上！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010113100001" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0111" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_013" ]},
		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「たゆまず勉（つと）め、励むことによって己を強める。人、それを『勉強』\nと言う！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_020113100002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「だ、誰だ！　そこにいるのは何者だ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010113100013" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「ベルガっと参上、ベルガっと解決！　人呼んでさすらいの美女、ベルガマス\nク！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_020113100003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ベルガマスクだと！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113100007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「『ベルガっと参上』ってなんですか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010113100003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「ルナテミスよ！　たしかに今のおまえは、学業面でいいとこなしの赤点ガー\nル！　そんなざまでは、卒業はおろか進級もおぼつかん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_020113100004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「なっ！？　う、うるさーい！　いったいなんなんだ貴様は！　そんなことを\n言うために、いきなり出てきたのか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010113100014" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「だがルナテミス！　おまえのその、誰にも勝てぬ成績こそが、誰にも負けぬ\n巨大な伸びしろともなりうるのだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_020113100005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「な、なに！？　いやしかし！　あんな無茶な勉強では、伸びしろどころか頭\nがどうにかなってしまう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010113100015" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「だから貴様はアホなのだぁ！　そんな今の貴様を見て、天国の母上がどう思\nう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_020113100006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「は、母上様が……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010113100016" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「そうだ！　母上に代わってＧ・ルナリアムを再興するのが、貴様の努めでは\nないか！　その使命の重さを思い知れ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_020113100007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「使命の……重さ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010113100017" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「そうだ！　見事にこの試練を乗り越え、成績を上げ、たかが小テストぐらい\n押し返してやれ！　月の紋章は伊達じゃない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_020113100008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そんなことに付き合わされる身にもなってほしいが。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そうだ……そうだったんだ！　私には、大事な使命が……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010113100018" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「ルナテミスよ。こんなことで負けるお前ではないはずだ。私はいつでも、お\n前を見守っているぞ！　では、さらばだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_020113100009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0150" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "と、言い残して「ベルガマスク」と名乗る謎の女は消えた……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010113100003" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「なんなんですか、あれは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010113100004" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「……貴様らの知り合いじゃないのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113100005" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「まあ……知り合いに変な人は多いけど……でも、あの変な人は知らないなぁ\n……あはははははは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010113100003" ]},
		{"command":[ "SETCHARA", "0", "char_00001205_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「でも、なんだか声に聞き覚えが――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010113100001" ]},
		{"command":[ "SETCHARA", "0", "char_00001406_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そうだ……！　そうなんだぁーーーーーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010113100019" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「わっ！？　なんだ！？　今度はなんだ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010113100004" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そうだったんだ……！　私は……月の女王にならなければ！　そのために…\n…あらゆる試練に打ち勝たなければならないのだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010113100020" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「ルナテミスさん……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010113100003" ]},
		{"command":[ "SETCHARA", "0", "char_00001701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「おおお……！　ルナテミス様……！　やっと次期女王としての自覚を――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113100008" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「貴様らなど、私一人で十分だぁああああああ！　うぉおおおおおおおおっ！\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010113100021" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ルナテミスはなにを思ったのか、剣を振りかざして俺たちに向かって突進して\nくる！", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「なんでこうなっちゃうのーっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010113100004" ]},
		{"command":[ "SETCHARA", "0", "char_00001701_01", "9", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「あああああ！　もうどうでもいい！　取り押さえろ！　力づくでも勉強させ\nるんだーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113100006" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}