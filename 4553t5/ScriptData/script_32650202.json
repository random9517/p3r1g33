		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「ああでるっ、またでる……っ！　精液っ、んぁっ、おちんちんおかしくなっ\nて、びゅーびゅーとまらなくなって……っ！」", "NORMAL" ]},
