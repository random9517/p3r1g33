		{"command":[ "SETIMAGE", "0", "still_00026502_02_11" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「でるっ、でるぅ……っ！　隊長様におそわった、トコロテン射精ぇ……っ！\n　い、イク……イッちゃいます……っ！」", "NORMAL" ]},
