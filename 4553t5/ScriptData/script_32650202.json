		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「これ以上は、シャナも射精できそうにありません……。隊長様、どうしまし\nょう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0204102" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「えっ、刺激を追加するのはどうか、ですか？　ホテルに入る前に買っておい\nた、バイブを使ってみれば、と……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0204103" ]},
		{"command":[ "SETCHARA", "0", "char_00026502_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「……わかりました。それも使ってオナニーしてみます。えっと、しっかりロ\nーションでぬらして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0204104" ]},
		{"command":[ "SETCHARA", "0", "char_00026502_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「ん……っ。お、お尻の穴……この辺、ですかね……？　はぁ、はぁ、バイブ\nの先端が、シャナのお尻の穴にぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0204105" ]},
		{"command":[ "SETIMAGE", "0", "still_00026502_02_01" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「こ、こうしていると……隊長様に、おちんちんを挿れてもらったときの感覚\nを思い出してしまいます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0204106" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「んっ、くぅ……っ！　スイッチを入れたら、うねうねと動いて……。あっ、\nお尻の穴の周りを、バイブの先がぐるぐるって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0204107" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「えっと……このまま、お尻に……。はぁ……はぁ……んぅ……あ、んっ、く\nぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0204108" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「ひゃふぅうううぅぅぅんっ！？　おっ、お尻に、バイブ……んぁっ、あっ、\n一気に……きっ、ひぃいいぃぃんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0204109" ]},
		{"command":[ "SETIMAGE", "0", "still_00026502_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「ま、まって、バイブがぐりぐりって、シャナのお尻の中ぁ……っ！　あっ、\nあぁ……んっ、はぁあああぁぁぁ～～～～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0204110" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「で、でる……っ！　おちんちん、しごいてないのにっ、精液ぃ……ひぃっ、\nんっ、ひぃ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0204111" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「また、おちんちんが大きくなって、た、隊長様の中を、いっぱいにしてしま\nいます……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0204112" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「あぁ……この感じぃ……。お尻が、いっぱいになって……き、気持ちいい、\nです……はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0204113" ]},
		{"command":[ "SETIMAGE", "0", "still_00026502_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「こ、このバイブを……隊長様の、おちんちんだと思って……んっ、動かして\n、オナニーします……ね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0204114" ]},
		{"command":[ "SETIMAGE", "0", "still_00026502_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「あぁっ、お、お尻ぃ……っ！　ごりごりって、バイブが、こすれる……ひぅ\nっ、腰が動いてしまいます……あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0204115" ]},
		{"command":[ "SETIMAGE", "0", "still_00026502_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「そ……そうでした、ね……。隊長様のことも、動かして……おちんちんも、\n刺激しないと……んっ、あぁ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0204116" ]},
		{"command":[ "SETIMAGE", "0", "still_00026502_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「お、おちんちん、おちんちんもぉ……っ！　んぁあっ、ああっ、また勃起し\nて、隊長様の中に、こすれてぇ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0204117" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁっ。また激しく、隊長様のこと、上下に……んあっ、動かして\n、んっ、くぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0204118" ]},
		{"command":[ "SETIMAGE", "0", "still_00026502_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「おちんちんに、隊長様の……つ、ツブツブ、ヒダヒダが、こすれる……あぁ\nっ、中すごいっ、吸いついてきますぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0204119" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「ああっ、す、すごいぃ……っ！　お尻、バイブでぐりぐりしながら、おちん\nちんしごくの、気持ちいい……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0204120" ]},
		{"command":[ "SETIMAGE", "0", "still_00026502_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「た、隊長様、シャナはぁ……っ！　んぁあっ、すごく気持ちよくて、頭の中\nが、おかしくなってしまいそうで……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0204121" ]},
		{"command":[ "SETIMAGE", "0", "still_00026502_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「こ、こんな……こんなぁ……。隊長様に、おちんちんを挿れてもらいながら\n、隊長様に、おちんちんを挿れているような……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0204122" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「シャナのお尻も、おちんちんも、いっぺんに気持ちよくしてもらえているみ\nたいで……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0204123" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「この感じ……く、癖になって、しまいそうです……。シャナは、イケナイこ\nとを、覚えてしまいました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0204124" ]},
		{"command":[ "SETIMAGE", "0", "still_00026502_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「バイブを出し入れして、お尻の穴、ずぽずぽってしながら、オナホを使って\nおちんちんをしごくの、とめられません……っ！", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0204125" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「あはぁっ、お尻の、い、いいところにぃ……っ！　ば、バイブを自分から、\nあてて……んっ、くぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0204126" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「そしたら、おちんちんがもっと膨らんで……っ！　んはぁっ、ああ……っ！\n　おちんちん、ジンジンしますぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0204127" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「き、きちゃいますっ、また……っ！　お、おちんちんに、精液がこみあげて\nきて……はぅっ、あっ、あぁ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0204128" ]},
		{"command":[ "SETIMAGE", "0", "still_00026502_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「また、射精しそう……！　また隊長様に、たくさん中出ししちゃいます……\nっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0204129" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「で、でもこれも、解呪のためですから……隊長様を、元に戻すためですから\nぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0204130" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「あぁっ、おちんちんを、オナホごとぎゅっとにぎってしまって、ごしごし乱\n暴にしごいてしまいますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0204131" ]},
		{"command":[ "SETIMAGE", "0", "still_00026502_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「ごめんなさい、苦しいかもしれませんけど、でも……隊長様は、オナホなん\nですから……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0204132" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「シャナが、このエッチな気持ちをすっきりさせるために、おとなしく使われ\nてくださいっ！　ごめんなさいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0204133" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「はぁっ、ああっ、どんどんしごいちゃいますっ、おちんちん気持ちいいっ、\nぬるぬる隊長様オナホ、最高ですぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0204134" ]},
		{"command":[ "SETIMAGE", "0", "still_00026502_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「隊長様が、シャナにしてくださったようにっ、隊長様の中にも、シャナの精\n液たっくさん注いじゃいます……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0204135" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「あっ、ああっ、くる、でちゃう……っ！　精液、はぁ、はぁ、でる……あっ\n、ああ……イッくぅううぅぅ～～～～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0204136" ]},
		{"command":[ "SETIMAGE", "0", "still_00026502_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「あああぁぁぁああぁぁ～～～～っ！！　あっ、でてっ、また精液、隊長様に\nいっぱいでてるぅ～～～～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0204137" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「きっ、気持ちいい～～～～……っ！　精液おもいっきり、びゅ～って出すの\n気持ちいいです～～～～……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0204138" ]},
		{"command":[ "SETIMAGE", "0", "still_00026502_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「お、お尻も気持ちいい……。これ、もっとバイブを強くしたら、どうなっち\nゃうんでしょうか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0204139" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「くひぃいいいぃぃぃ～～～～っ！　お尻乱暴に、ぐりぐり刺激されて……っ\n！　ま、またおちんちん……勃起しちゃいます～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0204140" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「ああ……っ！　んぁっ、イクッ、お尻……バイブずぼずぼ動かすたびに、精\n液……ぴゅくっとでちゃいますぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0204201" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、隊長様……もっと、いいですよね……？　隊長様の気持ちいい\nオナホ穴、使わせてくださいぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0204202" ]},
		{"command":[ "SETIMAGE", "0", "still_00026502_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「隊長様が、元の姿に戻ったら……今度はシャナのこと、オナホのように扱っ\nてもかまいませんので、それまでは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0204203" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「んぁっ、あっ、動かしちゃいますっ！　また、シャナのおちんちんで、隊長\n様のこと……貫いてしまいます……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0204204" ]},
		{"command":[ "SETIMAGE", "0", "still_00026502_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「な、中がぬるぬるで、隊長様の精液の匂いも混じって……こ、これって隊長\n様も、イッてるってことですよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0204205" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「シャナのおちんちんに、オナホ穴ずぼずぼされながら、射精しまくってて…\n…はぁ、はぁ、シャナと、おそろいですっ、ねっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0204206" ]},
		{"command":[ "SETIMAGE", "0", "still_00026502_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「隊長様オナホの中が、シャナと隊長様の精液ローションでいっぱい……っ！\n　ぬるぬるなのに、締まって、気持ちいい……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0204207" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「バイブも、もっと、激しく動かして……っ！　あっ、ああっ、ずぽずぽぐり\nぐり、お尻の穴ぁ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0204208" ]},
		{"command":[ "SETIMAGE", "0", "still_00026502_02_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「んぁっ、隊長様、わかりますよねっ！　シャナのおちんちんが、またイキそ\nうになってます……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0204209" ]},
		{"command":[ "SETIMAGE", "0", "still_00026502_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「隊長様の中で、また……びくんびくんと暴れて……っ！　はぁ、はぁ、隊長\n様が気持ちいいからぁ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0204210" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「んぁっ、ああっ、ますます、手がぁ……っ！　ずぼずぼとおちんちんで、隊\n長様の穴を犯すように動いて……っ！」", "NORMAL" ]},
