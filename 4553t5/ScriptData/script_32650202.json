		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……困りましたね……。あれから何度も隊長様を使ってみまし\nたが、一向に戻る気配がなく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0204101" ]},
		{"command":[ "SETCHARA", "0", "char_00026502_01", "4", "CENTER", "0" ]},
