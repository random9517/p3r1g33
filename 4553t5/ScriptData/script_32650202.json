		{"command":[ "SETIMAGE", "0", "still_00026502_02_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「そのたびに、中が……吸いついてくるようで、うねっておちんちんを搾って\nくるようで……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0204212" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「おちんちんの先っぽが、でっぱりにひっかかって、弾かれるような感覚もた\nまらないんです……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0204213" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、お尻……イキます……っ！　バイブも気持ちいいっ、自分で、\n自分の気持ちいいところにぐりぐりして、イかされて……っ！」", "NORMAL" ]},
