	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「はぁ……。隊長。呼び出すのならば、早い時間にしていただきたい。明日も\n戦闘を控えている身でな。……さて、どうした？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0103101" ]},
		{"command":[ "SETCHARA", "0", "char_00012001_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「勤勉な貴様のことだ、どうせ仕事を詰め込み過ぎてニッチもサッチもいかな\nくなっているに違いない……。と、何？　パイズリをして欲しい、だと？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0103102" ]},
		{"command":[ "SETCHARA", "0", "char_00012001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「パイズリ……。いや、知識としては聞いたことがある単語だが……。それが\n仕事に何の関係がある。ん？　男は股間にストレスが溜まると良くない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0103103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「それを定期的に解消することで、健全な作業スピードを保てるのだ……と？\n　ふむ……そういう……ものか？　女の我にはよくわからんが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0103104" ]},
		{"command":[ "SETCHARA", "0", "char_00012001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「つまりは我に、慰安をせよとの命令なのだな。マッサージのようなもの……\nととらえるべきか……。まあ、わかった。他でもない貴様の頼みだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0103105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「毎日というわけにはいかんが、たまにであれば善処しよう。それで……股間\nの調子はどうなのだ？　今見せる？　……ああ。お願いしよう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0103106" ]},
		{"command":[ "SETCHARA", "0", "char_00012001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「……ッう……！？　こか、股間……！　貴様、い、いつもの大きさではない\nぞ？　その、ズボンを履いている時の感じとまったく異なっていないか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0103107" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00012001_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「は……？　あ、ぇ……？　なにごと、だ？　これは……。何？　乳房で挟め\n？　挟めと言われても、挟まるかあやしいぞ、なにせデカすぎる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「んっ……。な、なん、とか……挟めはしたが……。これは、左右からグーッ\nと手で押さえていなければすぐに外れるな。ああ、まかせろ。固定する」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「んっ……こ、この後は……どうするものなのだ……？　うむ。てのひらで乳\n房を揺らしながら……肉圧でこの茎を刺激していくのだな……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「んっ、やってみると、むずか……しい、な……！　貴様の汗？　で乳房に茎\nがはりついて……うまく動かない……。んっ……。胸が揺れるだけだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0103111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「うむ。そういう時は、唾を谷間に垂らして滑らせる……？　わかった。その\n手があったか。では、唾を垂らすとしよう……んー……えぅ……んん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「たっぷりと唾液で胸を濡らし、て……。ふんっ！　……お、おお！　なめら\nかに動くようになった！　んん？　隊長も気持ち良くなれそうか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0103113" ]},
		{"command":[ "SETIMAGE", "0", "still_00012001_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「んっ、はぁっ、はぁ、はぁ……！　これ、は、重労働だが……んんっ！　隊\n長のモノが硬いせいか、こちらの胸のコリもほぐれるきがする……。っんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「互いに快感を、分け合えるマッサージ、ということなのだろうな……！　っ\nぁっ！　激しく揺さぶっていると、我、我も少し気持ちがいいっ、あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0103115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「んんっ……た、隊長……どう、だ……？　にゅるにゅると胸の間を往復する\nコレ……。コレの疲れはとれそう、か……？　っぁ……はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「……んっ……んっ、んっ、んん……！　緩急をつけて……はぁっ、肉の棒を\n癒すことだけを、考え……てっ、胸で、乳房で揉みほぐす……んぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「もっと強い方がいい、か……？　ああ、微調整は可能だ。なんでもいいつけ\nてくれ……。っぁっ……あっ、はぁっ、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「結構な重労働ゆえ、他の者よりは……あっ、我に頼みたいという隊長の気持\nち、よくわかる……。は、ぁ……はぁ、互いに汗もかくし……っぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「裸の胸を見せる、わけだからなっ……信頼関係のない者には無理筋だろう…\n…。そういった意味で、も……我を指名してくれて、よかっ、たぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「んぅッ……んっ、ンはッ……はぁっ、はぁ……！　ど、うした……？　じっ\nくりと我の胸を、見て……。んんっ……鑑賞？　どういうこと、だ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0103121" ]},
		{"command":[ "SETIMAGE", "0", "still_00012001_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「『クラッドの胸が綺麗だから目が離せない』だと……？　バ、バカものが…\n…！　それは股間マッサージに必要な情報か！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「っはぁっ……はぁっ、『真っ白な胸が摩擦でピンクに染まって色っぽい』？\n　だ、だから！　我の胸の評価はせずともよい！　それとも何かっ、ぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「我の胸が美しいと貴様の気持ち良さがアップするのか！？　……えっ！？　\nアップするのか！！　なら……。ん、し、仕方がない……のか？　わからん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「そういう理由であれば……、み、見てもいいが……。見られていると、少し\nこそばゆい……。だ、だから、あまりジッとは……。んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0103125" ]},
		{"command":[ "SETIMAGE", "0", "still_00012001_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「っはぁっ、はぁっ、はぁっ……。んんっ……！　ン……、んっ、んっ……。\n唾を足して……れろ……。うむ……乳房を絡めながら……ふぅっ、ふぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0103126" ]},
		{"command":[ "SETIMAGE", "0", "still_00012001_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「……え？　顔がとろんとしてきた？　か、勘違いするな！　別に我は性感を\nおぼえてなど……あっ！　こ、これは上司への健全な奉仕、だ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0103127" ]},
		{"command":[ "SETIMAGE", "0", "still_00012001_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「であるから……っ、くぅっ……！　感じて、など……。んぅっ……！？　乳\n首……？　っわっ……！？　ぅわっ、あっ、乳首が勃起して……！　あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「こ、これは……これは違うっ……！　肉茎にこすれたせいで、それだけで…\n…！　あっ……！　見、見る、な……！　おとなしくしごかれていろっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「っ……くぅ……っ、んっ、んん……！　はぁっ……はぁっ、はぁ……。なん\nだ……この感情は……。妙な……ヘン、な感じだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0103130" ]},
		{"command":[ "SETIMAGE", "0", "still_00012001_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「ただ、隊長の股間を……胸でっ、愛撫、しているだけなのに……。これは慰\n安、なのに……次第に頭がぽーっとして……うう……。ぁ、んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「おかしな声が止められない……。ぁっ……！　あっ、ぁっ……あぁっ♪　あ\nっ……ふぁっ……あっ、あっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「たい、ちょう……。この感覚は正常、なのだろうか……っ、あっ……！　そ\nれに、隊長のモノも……だんだん硬さが増してきて……んぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「『出そう』……？　何が出る、のだ……？　あっ……凝りのモトになってい\nたもの？　あぁ……毒素のようなものが出るのだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0103134" ]},
		{"command":[ "SETIMAGE", "0", "still_00012001_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「わかっ、た……。では好きな時に出して、くれ……。悪いものは排除するに\nかぎ、るからな……っ。はぁっ、このまま続けるぞ、力をこめ、て……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0103135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「んっ、んんっ、んんんっ……！　んっ、はぁっ、は、ぁ……はぁあっ！　い\nつでも……いつでもこい……！　そのための我、だ……気にするな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0103136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「っふぅっ……ふぅっ、ふぅ……出るか？　ああ、いいぞ、いいぞ……！　出\nしてくれっ……出せっ！　我の胸にっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0103137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「ッんんんんんんっ……！　うあっ！　あっ、あっ！？　ど、どれほど毒素が\n溜まっていたのだ！　真っ白な液体が……あっあっ胸に込みあがって！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0103138" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012001_01_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「ああああ……っ。とてつもない量だ……。こんなに毒が入っていたら辛かっ\nたろう……。最後まで絞り出せ、そう……そうだ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0103139" ]},
		{"command":[ "SETIMAGE", "0", "still_00012001_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「全部、出たか……？　くぅっ……相当な悪臭だ……。これはキツかっただろ\nう……。我に相談してくれて良かった……。と、ん？　まだ出せるだと？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0103140" ]},
		{"command":[ "SETIMAGE", "0", "still_00012001_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「……そ、そう、か……。一度出しただけでは身体の毒は抜けきらぬか……。\nそれもそうだ、蓄積された疲労が一度で癒えるわけもない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0103201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「うむ。では、改めて……もう一度施術しよう。わ、我の身体があたたまって\nきつつあるのが不安ではあるが……。他でもない隊長のため」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「忠臣クラッド、お仕えさせていただく……！　っ……んっ、んん……！　あ\n……！　毒のヌルみが、ちょうどいい塩梅に肉茎に絡んでいくぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0103203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「我の唾と、隊長の毒と……二つを混ぜ合わせ……んっ！　毒の根をこねるの\nだ、さすればすぐにでも、解放と安寧が訪れるはず……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0103204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「注意深く、気を抜かず……っ。極力乳房と茎との間に隙間をつく、らず……\n！　んんっ……ンッ、んっ……どうだ、心地よい、か……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0103205" ]},
		{"command":[ "SETIMAGE", "0", "still_00012001_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「ああ……こちらも、良い調子、だ……。だが、やはり……んんっ。毒を肌に\n浴びたから、だろうか……。身体が火照って、かなわん……あぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「毒が触れた場所、が……ジンジンと熱をもってしまっていて……。っあっ、\nち、乳首もますます硬く、肥大化し……うう、どういう変化なのだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0103207" ]},
		{"command":[ "SETIMAGE", "0", "still_00012001_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「えっ……！　あ、『胸を性器がわりにして愛撫しているせいで、乳房が自分\nを陰部だと勘違いしはじめている』？　あぁ……そういうことなのか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0103208" ]},
		{"command":[ "SETIMAGE", "0", "still_00012001_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「ほ、本来性器で絞り出すべき毒を……乳房っ、で、ひり出させているせいで\n……。我の胸が勘違いをしている、のだな、己が性器だと……ん、あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「納得はいく、が……この……この、き、気持ち良さはこま、る……っ。股の\nあたりがウズウズして、ひ、膝と膝とをこすりあわせて……はぁんんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0103210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「まるで性交、しているみたいに……乱れてしまう、乱されて、しまう……！\n　あっ……あっ！　あっ！　なんと恐ろしい毒なのだぁ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「あぁ……あぁ、あっ、あっ、んぁあっ、あっ……！　乳頭が肉茎にっ、触れ\nるとすごく……すごく……気持ちいい……っ、んっいいっ、いい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「隊長……、隊長……！　隊長は、どうだ……？　あっ……あぁっ、この毒に\n触れて……脳が蕩けてくる感覚はないか？　んっ……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「わ、我はだんだんとこの行為に……！　毒抜きに夢中になってきてしまっ、\nてっ……！　あっ、あぁっ、あぁっ、気持ちよすぎる……あぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0103214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「胸が止められない、あっ、腰も……動いてしまって……！　あっ……あっ、\nひどく物欲しい気持ちだ……あっ！　いや……いや、いや、だ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0103215" ]},
		{"command":[ "SETIMAGE", "0", "still_00012001_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「戦闘用アマルガメイトの我、が……っ！　戦士の我が、乳房で快感を得て…\n…乳首を硬くしているだなんて、恥でしかないぃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0103216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「卑しい自分、に耐えられない……！　も、もういやだ、早く……！　早くも\nう一度毒液を噴出してくれっ、でないと……でないと……！　っあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「我が我でなくなってしまう……！　えぅ……！　もっと唾を足すから……あ\nっ！　我の胸を、性器のかわりにしていいから……あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0103218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「この高ぶりを、高揚を殺してほしい……！　あっ！　あっ、あっ……も、も\nうダメだ……ダメだ、感じるっ、感じる……イ、く……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「んぁんんんっ！　あんんんっ……！　隊長も、毒を……毒を！　我に毒をか\nけてくれっ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「んんんんっ……！　出たぞ、毒が……溢れ出して止まらないっ……！　あ、\nあ、堰をきったかのようにドパドパと……！　ンンンンッ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0103301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012001_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「あぁっ……ど、毒素のせいで、もうこらえきれない……！　我の胸も、胸も\n……んぐぅううっ！　あうっ！　達する……達するぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「あっ、ああああっ……！　あふっ……あっ、ああああ……！　ビュル、ビュ\nルと胸の中に注ぎこまれた毒、が熱くて……何も考えられない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0103303" ]},
		{"command":[ "SETIMAGE", "0", "still_00012001_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「隊長……、この毒は……空気に触れると凄まじい臭いを発するのだな……。\nうぷ……あまり嗅いだことのないニオイ、だ……けほっ、こほっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0103304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「それに、胸だけでは支えきれないほどの量……。あっ……、乳房からへそま\nで垂れ落ちてくる異常な粘着力……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0103305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「いかにも有害だとばかりに泡立って、……ドロドロと煮詰められている……\n。だが、我がコレを出す手伝いが出来たのは僥倖だった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0103306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「……ハハ、隊長の顔色が明るくなった気がする……。コレをぶちまけると、\n気分が爽やかになるのだろうな。……だ、だから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0103307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「また……股間が凝ったら、この毒が溜まったら、誰より先に我を呼んでほし\nい。今回コツもつかめたことだし……何度でも」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0103308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「マッサージ……してやる。気楽に声をかけるといい。……しかし、この毒液\n……。こそげおとすのが大変そうだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「シャワーで落ちるだろうか……。自信がないぞ。……んっ……指で触ってみ\nても……ベタベタして、まとわりついてくる……困ったな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0103310" ]},
		{"command":[ "SETIMAGE", "0", "still_00012001_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「んぷっ！？　ぷぁっ……！　んぁっ……！！　アッ……あっ……！　お、お\nいっ……隊長ぉ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0103401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012001_01_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「あ、あ……！　頭と髪に……んぶっ、顔に毒液がかかってしまったぞ……！\n　こ、これは顔にかけても大丈夫なのか……！　けほっ、こほっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0103402" ]},
		{"command":[ "SETIMAGE", "0", "still_00012001_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「……体内にあるとイライラするもので、外に出た後は人体には無害……！？\n　ほ、本当なのだろうな……！　ものすごい臭いだぞ……んぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0103403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「うぁっ……く、口の中に入ってきた……！　なんということだ……っ！　に\n、苦い……！　トロみがえぐい……！　うぇっ、おえっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0103404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「た……隊長の毒素が無事に飛び出したのは良かったが……。これは、すぐに\nでも顔を洗いにいかないと……。……ん？　なんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0103405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「顔にかかった毒液を舐めて、飲んでほしい！？　正気か！？　……ぁ……こ\n、コレを……？　……測り知れんほど苦いのだが！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0103406" ]},
		{"command":[ "SETIMAGE", "0", "still_00012001_01_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「……わかった。わかったから、そんな目で見るな。……ぺろっ……。んッ…\n…！　ぺろ……ちゅぷ、こ、こっちも……。ぺろ……。ちゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0103407" ]},
		{"command":[ "SETIMAGE", "0", "still_00012001_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「ん、ぷ……。この苦味の素を飲み下す……。承知した。……ん、ぐ……！　\nごきゅっ……！　ごくっ……んうううう……！　ごくっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0103408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「ちゃんと飲んだぞ……。満足か？　んっ、喉に絡む……。いつまでもひっか\nかって……！　それに、舌にもべったりあの味が……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0103409" ]},
		{"command":[ "SETIMAGE", "0", "still_00012001_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「貴様は、上司思いの部下を持って幸運だったな……！　普通、こんなことは\nしてくれぬぞ！　わかっているのかっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0103410" ]},
