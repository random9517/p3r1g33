{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0036" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「はあ、はあ……ふーう。なんとか、チャイムまでに間に合ったみたい。危な\nかったね、カツマちゃん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010108040001" ]},
		{"command":[ "SETCHARA", "0", "char_00000204_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おう……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「さっきは怖かったよ、カツマちゃんがいてくれて本当に良かった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010108040002" ]},
		{"command":[ "SETCHARA", "0", "char_00000204_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "いやいや、あいつらがそもそもおまえを襲うわけがないし、狙いは俺だけだろ\nうし……。咥えていたパンを全部呑み込めなかったら、危なかったが。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "まったく……流されるまま走ったり戦ったりしてきたが、やっぱり何かおかし\nいぜ。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "なんで俺が学生になってるんだ？　カグヤだってそうだ。学生って立場でここ\nへ通っているのは、幹部の中でも――。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0071" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "学生Ａ" ]},
		{"command":[ "SETTEXT", "「ルナテミス様よ」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "んん？", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "学生Ｂ" ]},
		{"command":[ "SETTEXT", "「ルナテミス様だわ」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「今日も送ってくれてありがとう、執事。帰りもよろしくね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010108040001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "……なんとまあ。俺以外の人間に送迎させてのご登場かよ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "しかもなんだ、あの態度？　俺が送り迎えした時とは雲泥の差だな！", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0036" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「今日も綺麗ね、学生会会長のルナテミス様」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010108040003" ]},
		{"command":[ "SETCHARA", "0", "char_00000204_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "学生会会長、ね。なんだそりゃって感じでもあるが……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "それよりも、だ。今は侵略者を相手にするので手一杯で、学園どころじゃなか\nったはずじゃないか？", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「カツマちゃんも、やっぱりああいう人が好みなの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010108040004" ]},
		{"command":[ "SETCHARA", "0", "char_00000204_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はあ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「品行方正、成績優秀。実家は裕福なご家庭なのに、優しくて気配りのできる\n完璧なお嬢様だものね、ルナテミス様は」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010108040005" ]},
		{"command":[ "SETCHARA", "0", "char_00000204_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "はああ？　いやいや、あの高慢ちきな女がそんな、絵に描いたようなお嬢様の\n訳が――。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あらカツマさん、それにカグヤさんも。ご機嫌よう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010108040002" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お……おう」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「おはようございます、ルナテミス様」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010108040006" ]},
		{"command":[ "SETCHARA", "0", "char_00000204_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「おふたりとも、どうかなさったの？　制服が乱れていらしてよ。特にカツマ\nさん、私が直してさしあげますわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010108040003" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「は、はあぁ……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "こいつが俺にこんな挨拶？　しかも丁寧な扱い……なんか、企んでるんじゃな\nいかって穿ってしまうな……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "しかもなんだ？　よくよく考えてみれば、さっきからカモフラージュ用の偽名\nじゃなく、本名で呼んでるっていうのはいいのか？　おい。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピースムーンＡ" ]},
		{"command":[ "SETTEXT", "「おいこらなんだおまえ、ルナテミス様がせっかくお声を掛けて下さったのに\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_030108040001" ]},
		{"command":[ "SETCHARA", "0", "char_00000801_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピースムーンＢ" ]},
		{"command":[ "SETTEXT", "「少しは有り難いという態度を見せないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_040108040001" ]},
		{"command":[ "SETCHARA", "1", "char_00000801_01", "7", "CENTER", "-400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "あー？　なんだあ……ひょっとして、またか？", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピースムーンＣ" ]},
		{"command":[ "SETTEXT", "「学園のマドンナであるルナテミス様にお声を掛けられ、あまつさえ制服の乱\nれまで正して頂いたというのに！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_050108040001" ]},
		{"command":[ "SETCHARA", "2", "char_00000801_01", "7", "CENTER", "400" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "2", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "いやまあ、うん、それはその通りなんだが。後半部分だけはな。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "カグヤがアイドルなら、ルナテミスはマドンナ……か。で、どっちも崇拝する\n親衛隊がついている、と。はあ。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピースムーンＡ" ]},
		{"command":[ "SETTEXT", "「自分がどれほどの恩寵を与えられたか、実感出来ていないようだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_030108040002" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピースムーンＢ" ]},
		{"command":[ "SETTEXT", "「これは少し、お灸を据える必要がありそうだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_040108040002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「皆様、待って。私はただ――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010108040004" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "DISPCHARA", "2", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピースムーンＣ" ]},
		{"command":[ "SETTEXT", "「いえ、ルナテミス様はここでお待ちを。仰りたい事はよーくわかっておりま\nすので」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_050108040002" ]},
		{"command":[ "SETCHARA", "0", "char_00000801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "あー……忠犬共めえ。こっからあれだろ、主人の代わりに俺を誅伐するってか\n？", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピースムーンＡ" ]},
		{"command":[ "SETTEXT", "「我等、ルナテミス様親衛隊！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_030108040003" ]},
		{"command":[ "SETCHARA", "0", "char_00000801_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "DISPCHARA", "2", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピースムーンＢ" ]},
		{"command":[ "SETTEXT", "「不届き者にこれより天誅を加え――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_040108040003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピースムーンＣ" ]},
		{"command":[ "SETTEXT", "「ルナテミス様のご威光を知らしめす！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_050108040003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「いえ、だから、あの……嗚呼、私の為に争わないで！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010108040005" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "DISPCHARA", "2", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "いや違うから。あー……ったく。ルナテミスが俺を庇うっていう異常事態より\nも――。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "こいつらに難癖をつけられているらしい展開の方が、よっぽど「いつも通り」\nって感じで、実家のような安心感を覚えてしまう自分が恨めしいぜ……。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}