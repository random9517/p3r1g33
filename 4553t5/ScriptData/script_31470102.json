		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "147_0104111" ]},
		{"command":[ "SETNAME", "ツバメ" ]},
		{"command":[ "SETTEXT", "「やだあぁ……ぐりぐりって先っぽで子宮ぅほじられたら、あたしの頭ぁ……\n真っ白になっちゃっ、てぇ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
