		{"command":[ "PLAYVOICE", "147_0104117" ]},
		{"command":[ "SETNAME", "ツバメ" ]},
		{"command":[ "SETTEXT", "「あなたのオチンポに子宮がなびいてきちゃってるの……！　んああぁん、い\n、言うよ……あなたが喜んでくれるなら……」", "NORMAL" ]},
