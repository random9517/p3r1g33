		{"command":[ "PLAYVOICE", "147_0104113" ]},
		{"command":[ "SETNAME", "ツバメ" ]},
		{"command":[ "SETTEXT", "「あ、あたしに渡したエッチな道具、使ったのか……だなんて、こんな時に聞\nいちゃやだぁ……」", "NORMAL" ]},
