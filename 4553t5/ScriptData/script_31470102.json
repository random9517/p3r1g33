		{"command":[ "SETNAME", "ツバメ" ]},
		{"command":[ "SETTEXT", "「オチンポ……触ってもいい？　うん……あ、熱ぅい……、硬くて、んあぁ、\nドク、ドクって脈打ってる……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "147_0104103" ]},
		{"command":[ "SETNAME", "ツバメ" ]},
		{"command":[ "SETTEXT", "「あたし、その……知ってるよね？　処女だからさ……優しくして欲しいな。\nえっ？　あ、あたしが可愛いから暴走しちゃうかも！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "147_0104104" ]},
		{"command":[ "SETNAME", "ツバメ" ]},
		{"command":[ "SETTEXT", "「そっ、そういうことは真顔で言わないの、もぅ……んぁ！？　あぁっ、オマ\nンコに先っぽがこすりつけられて……うぅっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "147_0104105" ]},
		{"command":[ "SETNAME", "ツバメ" ]},
		{"command":[ "SETTEXT", "「うん……い、いいよ。来て……？　あっ、あああああ……あああぁぁ～～～\nっ！！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "147_0104106" ]},
		{"command":[ "SETNAME", "ツバメ" ]},
		{"command":[ "SETTEXT", "「入って、きちゃったぁ……はぅん！　あぅぅ！　大丈夫、ちょっと痛いけど\n、んあぁ……あぁん」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014701_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "147_0104107" ]},
		{"command":[ "SETNAME", "ツバメ" ]},
		{"command":[ "SETTEXT", "「おっぱいいじるの禁止ぃ……あたし、そこ弱いの、くりくりされたら……感\nじちゃって、あぅぅ、あぁ～っ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "147_0104108" ]},
		{"command":[ "SETNAME", "ツバメ" ]},
		{"command":[ "SETTEXT", "「おっぱい揉みながらだなんて、くっ……んうぅ！　うんっ、うん……！　痛\nくないよ、あぅぅ～～！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "147_0104109" ]},
		{"command":[ "SETNAME", "ツバメ" ]},
		{"command":[ "SETTEXT", "「ね、根元まで……ふああぁぁっ、入っ……ちゃっ、たぁ、はうぅん！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "147_0104110" ]},
		{"command":[ "SETNAME", "ツバメ" ]},
		{"command":[ "SETTEXT", "「あたしの子宮にオチンポの先がキスしてるぅ……！　はぅっ、はあぁ、あぅ\nぅ！？」", "NORMAL" ]},
