		{"command":[ "PLAYVOICE", "147_0104118" ]},
		{"command":[ "SETNAME", "ツバメ" ]},
		{"command":[ "SETTEXT", "「ローターを乳首につけてブルブル震わせながら、オマンコを指でいじってオ\nナニーしたり……うぅっ、はあぁっ」", "NORMAL" ]},
