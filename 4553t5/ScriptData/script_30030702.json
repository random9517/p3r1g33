{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000307_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「あんっ……ちょ、ちょっと……もう、何をしてるの……んっ、待ちなさいっ\nてば……んっ、こら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0704101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「確かに、誰もいないプライベートビーチで、二人で独占出来るとは言ったけ\nど……だからと言って、そんな……急に脱がして……あっ、あんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0704102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「んっ、ダメよ……もし、何かの間違いでみんなが来ちゃったら……こんな所\n見つかったら……言い訳出来ないでしょ……？　あ……はっ……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0704103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「そんな……私は、その気になってる訳じゃ……んっ、あぁっ、んくっ……指\n……あっ、ダメェ……あっ、んっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0704104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「違うの……確かに、その、全く何もないって……思ってた訳じゃ、ないわ…\n…期待と言うか、あっ、んっ、ムードとか……流れから……そういう感じに…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0704105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「今が……あっ、そのムードって……思ってたのと……違うし……あっ、やん\nっ……そんなに揉んじゃ……あぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0704106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「んくっ……やだ、上手……乳首転がされてる……あっ、そこも……よ、弱い\nの……んんっ、くぅっ……あぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0704107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「あぁ……濡れて来ちゃう……んっ、分かったわ……ちゃんと認めるから……\n私は、もう……その気になってるの……セックス……したいのっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0704108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「感じる場所……いっぱい触られて、どんどんその気にさせられて……あっ、\nオチ〇ポ……なぞられてる……んっ、あぁ……もうちょっと奥……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0704109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「もう、分かったでしょっ……したくなってるからっ、中に……あぁ……オ、\nオマ〇コに……入れてぇ……オチ〇ポハメてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0704110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「んっ……！　あぁっ、はっ、あぁぁぁ……んんっ、くぅぅ……は、入るぅぅ\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0704111" ]},
		{"command":[ "SETIMAGE", "0", "still_00000307_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「あぁぁ……中を掻き分けられて……あぁ……繋がっちゃった……こんな、外\nなのに……は……あぁぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0704112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「だ、大丈夫よね……？　本当に誰も来ないわよね……？　もし、こんな所見\nられたら私……あっ、くぅぅ……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0704113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「ち、違うわ……見られたいなんて思ってない……んっ、当たり前じゃないの\n……こんな、恥ずかしい……あっ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0704114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「見ていいのは……貴方だけよ。他の誰だって……絶対に駄目なんだから……\nあっ、ひあっ、んっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0704115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「あぁ……な、何をニヤニヤしてるの。もう一回言って欲しいって……だから\n、私の恥ずかしい所を見ていいのは……貴方だけよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0704116" ]},
		{"command":[ "SETIMAGE", "0", "still_00000307_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「もう……変な所で独占欲が強いんだから……あっ、あぁっ、うんっ、んくぅ\n……あぁ……オチ〇ポ、速くなって来てる……あっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0704117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「はんっ、あっ、あぁっ、そ、そんなに慌てなくてもっ……ゆっくりかき回し\nてくれればいいのにっ、あひっ、はっ、あぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0704118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「あぁっ……興奮したからって……そんな、あっ、欲望剥き出しにされてるっ\n……あぁっ、中っ……グリグリ……されてるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0704119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「んぁっ、そこっ、あぁっ、オマ〇コの……奥にっ、あっ、力が抜けちゃうと\nころっ……はっ、あぁぁあんっ、今のっ……場所ぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0704120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「あっ、いいわっ……んんっ、つ、続けてしてっ！　はひっ、あぁっ、オチ〇\nポ擦れるぅっ、あぁっ、か、感じるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0704121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「やっ、はっ、あぁんっ、これ以上はっ……も、もうイクっ、あひぁっ、気持\nちいいのっ、イ、イッちゃうぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0704122" ]},
		{"command":[ "SETIMAGE", "0", "still_00000307_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「んんっ……あぁぁっ……イッた……イッちゃったの……あぁ……ちょ、ちょ\nっとだけストップして……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0704123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「まさか、こんなに早くイカされるなんて思わなかったわ……んっ、身体……\n熱くなってる……もう汗だくよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0704124" ]},
		{"command":[ "SETIMAGE", "0", "still_00000307_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「仕方ないわ……これだけ身体をくっつけて……激しく動いたんですもの……\nんふっ、おっぱいも揉まれたままだし……あふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0704125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「んっ……もう大丈夫よ……また、続けて……貴方のオチ〇ポ……オマ〇コで\nいっぱい感じさせて……あっ、はぁっ、んひぁっ、あぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0704126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「あぁっ、身体が勝手に……震えちゃうっ、きゅんってっ……オマ〇コ……締\nめ付けるのっ、くっ、んぁぁぁっ、んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0704127" ]},
		{"command":[ "SETIMAGE", "0", "still_00000307_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「あっ、あぁっ、はぁぁんっ、気持ちいいっ……こんなっ、大胆なことっ……\n私らしく……ないのにっ、止まらないっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0704128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「あっ、もっとしてっ……んんっ、おっぱいも揉んでっ、あぁんっ、首筋の汗\n……舐められてるっ、ダメっ、気持ちいいのっ、ダメになるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0704129" ]},
		{"command":[ "SETIMAGE", "0", "still_00000307_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「イクっ……はぁんっ、続けてイッちゃうのっ、あっ、オチ〇ポすごくてっ、\nまたっ、あひぁっ、またイクぅぅぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0704130" ]},
		{"command":[ "SETIMAGE", "0", "still_00000307_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁっ、やだ……イクの、クセになっちゃう……止まらないの……\nんんっ、あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0704131" ]},
		{"command":[ "SETIMAGE", "0", "still_00000307_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「貴方は……まだなの……？　んっ、あひっ、まだまだ……元気っ……あぁっ\n、逞しいのはいいけど……あんっ、私の方がどうにかなっちゃいそう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0704132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「んっ、んくぅぅ……もうすぐなのね？　んんっ、分かったわ……ほら、オマ\n〇コ……もっとキュッてするから……貴方も気持ちよく射精して……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0704133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「あんっ、はぁっ、あぁんっ、そうよっ……ずりゅずりゅってオチ〇ポ動くの\nっ、あぁっ、出そうっ？　出そうなのねっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0704134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「このままっ、中に出してっ……いいわっ、何も気にせずにっ、貴方の精液っ\n……いっぱい射精してぇぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0704135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「んぁぁぁぁっ！　あぁぁ……熱いわ……精液……濃すぎる……はぁ……私も\n……お汁出しちゃってるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0704136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000307_02_05" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「んくぅ……はぁ……はぁ……熱いの……身体、トロトロにさせられて……汗\n……止まらない……んふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0704137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「こんな、原始的な快感に身を任せるのも……たまにはいいのかもしれないわ\nね……はふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0704138" ]},
		{"command":[ "SETIMAGE", "0", "still_00000307_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「はぁ……風が気持ちいいわ……日差しは強くても、カラッとしてるから……\nちょうどいい感じになるのね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0704139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「刺激的な体験だったわ……贅沢なバカンスにピッタリの……ね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0704140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「さて……少しだけ身体も落ち着いたけど、もちろんこれで終わらせる気はな\nいのよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0704201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「私をこんなにさせておいて、１回出して終わりなんて、そんなことある訳…\n…あっ、はぁんっ！　あっ、くぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0704202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「んっ……そうよね、貴方も当然その気よね……本気のオチ〇ポ……味わわせ\nて貰うわ……はぁぁぁっ、あんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0704203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「あっ、はっ、ふっ……中に出された後だから……滑る感じが、ずっとよくな\nってる……あんっ、はっ、あんっ、あっ、あひぁっ、あっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0704204" ]},
		{"command":[ "SETIMAGE", "0", "still_00000307_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「も、もっと足を上げるの？　あっ……は、恥ずかしい……これ、繋がってる\n所……丸見えになっちゃうじゃない……は、ひっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0704205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「そんな……喜んでなんか……んっ、貴方以外に見せたくないって……言って\nるでしょ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0704206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「んんっ、し、視線を感じる……？　嘘よ……また、そうやって私をからかっ\nて……悪趣味よ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0704207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「ほ、本当なの……？　嘘……だ、だったら、あっ、や、やめないと……あひ\nっ、あっ、な、何でっ……あっ、あぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0704208" ]},
		{"command":[ "SETIMAGE", "0", "still_00000307_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「やっ、はぁんっ、見せつける……なんてっ、ダメっ……あぁっ、オチ〇ポっ\n、激しくしちゃっ、はひっ、ひぃんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0704209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「あぁっ、そんなっ、待ってっ！　こんな、あっ、オマ〇コ見せちゃっ……恥\nずかしい……い、いやぁっ、あぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0704210" ]},
		{"command":[ "SETIMAGE", "0", "still_00000307_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「違うのっ、それで興奮してる訳じゃっ……はぁんっ、あぁっ、止まらないっ\n、オチ〇ポ止まらなくなってぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0704211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「あひぁっ、オマ〇コっ、そんなにされたらぁっ、あぁっ……こ、これ以上さ\nれたらぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0704212" ]},
		{"command":[ "SETIMAGE", "0", "still_00000307_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「ダメッ、イクっ！　ま、またイッちゃうっ、んぁぁぁっ、イッてる所っ……\n見ちゃダメェっ……イクぅぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0704213" ]},
		{"command":[ "SETIMAGE", "0", "still_00000307_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「んはぁぁぁ……はぁっ、はぁっ……あっ、やだ……潮吹きしちゃってる……\nもっと恥ずかしい所……見られてるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0704214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、え……視線は……冗談？　ば、バカっ……！　もうっ……本\n気にしたじゃないのっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0704215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「あぁ……でもよかった……こんな汗まみれになって……はしたない格好で、\nオマ〇コされてるところ、見せちゃってたら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0704216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「やだ……想像するだけで、んっ……身体……きゅんってなっちゃう……あっ\n、んぁっ、な、何っ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0704217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「またっ、そんなにオチ〇ポ激しくっ、こ、興奮したって……あっ、あぁっ、\nはぁんっ、で、出そうになってるのっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0704218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「んぁっ、あぁっ、そんな欲望剥き出しでっ……ズンズンされたらっ、あっ、\nあぁんっ、イッたばかりなのにっ、またっ、オマ〇コまたイッちゃうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0704219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「いいわっ、どうにでもしてっ、射精っ……オチ〇ポいっぱい出してっ！　び\nゅくっていっぱいっ……射精してぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0704220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「あぁっ、オチ〇ポ膨らんでるっ……来るのねっ、あっ、はぁんっ、あっ、あ\nぁぁっ、んぁぁぁぁぁぁーーーーーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0704301" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「はひぁぁ……中……どぷって出てる……あぁ……熱いの……また、汗が……\n滲んで来てる……んぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0704302" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000307_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、もうダメ……私……動けないわ……あっ、まだ動くの……？\n　んっ、くぅぅ……もう少しだけ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0704303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「あっ……また、流れ込んで来てる……ぴゅるって……精液……熱いの……あ\nふぁ……はぁぁぁん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0704304" ]},
		{"command":[ "SETIMAGE", "0", "still_00000307_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「落ち着いた……の……？　オチ〇ポのピストン……終わったのね……？　あ\nふっ……はぁ……はぁ……んふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0704305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「全くもう……面白がって脅かして……本当に怖かったのよ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0704306" ]},
		{"command":[ "SETIMAGE", "0", "still_00000307_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「でも……ほんの少しだけ……見られて興奮する自分がいたかもしれないわ…\n…って、私……何を言ってるのかしら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0704307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「あぁ……まだドキドキしてる……そうよ、全部貴方のオチ〇ポのせいなんだ\nから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0704308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「この太くて硬いのでされたら……もう何もかも身を任せるしかないんだもの\n……私をこうした責任取ってもらわないとよね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0704309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「ふふっ、とりあえずは……このままじっと抱き締めていて。汗まみれの身体\n……くっつけてるだけでも……気持ちいいから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0704310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「んくぁっ、出るのねっ、私もっ、またっ、あひぁっ、イクっ、はぁぁぁんっ\n！　イッちゃうぅぅぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0704401" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「んぁぁぁぁっ！　あっ、熱いの……掛かってる……びゅくびゅくっ……精液\nっ……お腹にっ……出てるのぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0704402" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000307_02_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「んふぁぁ……精液と……汗が絡んで……はぁぁ……ぬるぬるする……あぁ…\n…気持ちよすぎてどうにかなっちゃいそう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0704403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「あふっ……オチ〇ポ、まだ押し付けて来てる……まだ出すつもりなのね？　\nんっ、もういいわ……どうにでもして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0704404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「んっ、ふぁ……終わった……？　あぁ……今度こそ、ちゃんと出し切ったの\nね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0704405" ]},
		{"command":[ "SETIMAGE", "0", "still_00000307_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……もう、スリルがあるなんてレベルじゃなかったわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0704406" ]},
		{"command":[ "SETIMAGE", "0", "still_00000307_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「見つかったら、どうなってたか……全くもう、ちゃんと聞いてるの？　バカ\nなんだから……もう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0704407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「ま、まぁ……気持ちよかったのは確かだけど……もう……何もかも有耶無耶\nにしちゃう気ね？　本当に貴方って人は……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0704408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、暑いわ……汗が止まらない……もう……いつまでくっついて\nるつもりなの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0704409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「まぁ……イヤ、ではないけど……そうね……このまま暫くこうしてるのもい\nいかも知れないわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0704410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}