{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0027" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「……ダメ。ここにもいなかった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010023380001" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "4", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「そんなに遠くまで飛ばされていったとは、とても考えられないのですが……\n。困りましたね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010023380001" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「カツマさんが消えてからもう一週間……。今頃どこで、何をしているのか…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010023380002" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「無事ならいいけど、もしかしたら……敵に捕まっているのかも」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010023380002" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「だとしたら、早く助けにいかないと……。それなのに、何の手がかりも掴め\nないなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010023380003" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0046" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_013" ]},
		{"command":[ "SETTEXT", "……と、緊迫した様子でカグヤとまりあが俺を探しているとも知らず……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "俺は森の中で、繁盛しているカフェを満足そうに眺めていた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うんうん。やっぱりメイド服の威力は凄まじいな～。露出度マシマシで作っ\nて良かったぜ！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「お客の皆様、目がハートマークになっておりますぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023380001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「……ご主人様」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_010023380001" ]},
		{"command":[ "SETCHARA", "0", "char_00017302_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ん？　なんだ？　俺のメガネエルフメイド！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「ラヴリエータが、新しいパフェを開発しました。ぜひ、味について感想をお\n聞きしたいと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_010023380002" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「男の俺に、スイーツの良し悪しがわかるかどうかは不安だが……断る理由も\nない！　いいぞ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「うふふふっ♪　素直に、感じたままでいいんですよ。たくさんありますから\n、どんどん食べてくださいね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_010023380001" ]},
		{"command":[ "SETCHARA", "0", "char_00017202_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「どうぞ。パフェはこの長いスプーンで食べてください。……いえ、せっかく\nの機会です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_010023380003" ]},
		{"command":[ "SETCHARA", "0", "char_00017302_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「私たちが食べさせてあげましょう。……はい、イチゴとベリーのパフェです\n。あーん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_010023380004" ]},
		{"command":[ "SETCHARA", "0", "char_00017302_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ん。うま～い！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「こちらはパインとメロンみたいですよ。はい、あ～～ん、です♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_010023380002" ]},
		{"command":[ "SETCHARA", "0", "char_00017202_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お、こっちの方がさっぱりしてるんじゃないか！？　クリームが違うのか？\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「……フフ。それは、もっとたくさん召し上がっていただかないとわからない\nでしょうね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_010023380005" ]},
		{"command":[ "SETCHARA", "0", "char_00017302_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「ということで、あーん……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_010023380006" ]},
		{"command":[ "SETCHARA", "0", "char_00017302_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「こちらも、も～っと食べてください♪　はぁ～い、あ～ん……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_010023380003" ]},
		{"command":[ "SETCHARA", "0", "char_00017202_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ちょ、ちょ、ちょっと二人とも～。距離が近い、近～い！　困るぜ～♪」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00017202_01", "8", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "1", "char_00017302_01", "8", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「……そう言いつつも、まったく避けようとしないご主人……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023380002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そんなにくっついてきたら、お前ら、おっぱいが俺の腕に乗っちまうだろー\n♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「わざとですよぉ。それそれ、あーん♪　あーーん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_010023380004" ]},
		{"command":[ "SETCHARA", "0", "char_00017202_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「む。こちらもちゃんと見てください。……あーん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_010023380007" ]},
		{"command":[ "SETCHARA", "0", "char_00017302_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「熱いお紅茶もどうぞ。こちらは冷ましますね。ふーっ……♪　ふぅううー…\n…♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_010023380008" ]},
		{"command":[ "SETCHARA", "0", "char_00017302_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「い、至れり尽くせり……！　俺はこの国の王のようだ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「こんなところ、元の仲間に見られたら一体どうなってしまうことやら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023380003" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「見られるわけないだろ！　なんたって、俺は異世界転移したんだから！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「その、ずっと言っている異世界転移とはなんなのですか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023380004" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "ジュンジローが俺を問い詰めるより早く、ガサガサッと茂みから二つの顔が飛\nび出してきた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "「……か、カツマさん！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010023380004" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うわああああああああ！？　まりあ、それにカグヤ！？　ど、ど、どうやっ\nて異世界に！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「異世界って何……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010023380003" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「もしかしてこれは異世界転移じゃなかったってのか！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「いせかいてんい……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010023380005" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「異性……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010023380004" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「回転……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010023380006" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「淫……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010023380005" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「異性同士で、淫らに、回す……なんて……そんな、カツマさんに……酷い！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010023380007" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「あ、あなたたちは……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_010023380005" ]},
		{"command":[ "SETCHARA", "0", "char_00017202_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「……エルフ？　ここはエルフの棲む森……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010023380006" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「まさか、カツマさん。エルフに誘拐されていたんですか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010023380008" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「間違いない。カツマは誘拐され、悪いエルフに洗脳されている」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010023380007" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「そのようですね。その証拠に、エルフさんたちは卑猥なメイド服に身を包み\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010023380009" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「二人がかりでカツマを押さえつけて、何かを無理やりに食べさせている……\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010023380008" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「あっ！　こ、これは……そのぉ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_010023380006" ]},
		{"command":[ "SETCHARA", "0", "char_00017202_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「どうやら、カツマさんはいかがわしい、風営法ギリギリの怪しげな店で働か\nせられている……みたいですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010023380010" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「なら、助け出さないと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010023380009" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "ジャキン、とカグヤが武器を構える。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "と、その殺気に気付いたのか、ディーネリンドが最初にまりあ達に反応した。", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00017302_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「不審者ね。私が掃除してあげるわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_010023380009" ]},
		{"command":[ "SETCHARA", "0", "char_00017302_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「……癒しのカフェを乱す不届き者ども！　私は聖エルフ騎士団のディーネリ\nンド！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_010023380010" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「すぐにここから立ち去りなさい。でなければ……力づくで排除します！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_010023380011" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「やれるものなら、やってみるといい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010023380010" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "ディーネリンドとカグヤは、バチバチと火花を散らして睨み合っている。", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "7", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "1", "char_00017302_01", "7", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「……このエルフ、只者じゃない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010023380011" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「プロの戦闘集団？　……それならこちらも手加減はしない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010023380012" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
