{	"scriptCommands" :  [		{"command":[ "FADEIN", "NORMAL" ]},        {"command":[ "SETIMAGE", "0", "bg_0004" ]},        {"command":[ "DISPIMAGE", "0", "true" ] },		{"command":[ "FADEOUT", "NORMAL" ]},		{"command":[ "PLAYBGM", "BGM_015" ]},		{"command":[ "WAITMOVE" ]},		{"command":[ "PLAYVOICE", "102_0104101" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「……ああ、やだ、ドキドキしてます！　うう……とうとう、初めての時が来てし\nまいましたね」", "NORMAL" ]},        {"command":[ "SETCHARA", "0", "char_00010201_01", "5", "CENTER", "0" ]},        {"command":[ "DISPCHARA", "0", "TRUE" ]},        {"command":[ "SPOTCHARA", "0" ] },		{"command":[ "DISPNAME", "TRUE" ]},		{"command":[ "DISPTEXT", "TRUE" ]},		{"command":[ "WAITINPUT" ]},		{"command":[ "PLAYVOICE", "102_0104102" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「正直、こんな時が来るなんて思っても見なかったんです……もうちょっと大\n人になってからかなーって……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},		{"command":[ "PLAYVOICE", "102_0104103" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「だ、だって、その……あの……あはは、サムライテールとしての活動の方が\n優先すべきでしょう？　テストの点は犠牲に出来ませんっ」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},		{"command":[ "PLAYVOICE", "102_0104104" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「へ？　テスト勉強すればどうか……ですって？　は～～……隊長は何もわか\nってませんね……あたし、勉強とか努力とか、大ッッ嫌いなんです」", "NORMAL" ]},		{"command":[ "SETCHARA", "0", "char_00010201_01", "0", "CENTER", "0" ]},		{"command":[ "WAITINPUT" ]},		{"command":[ "PLAYVOICE", "102_0104105" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「あたしの座右の銘は『濡れ手に粟』ですから。水洗いでかでサッと取れるの\nで、やっぱり楽なのが一番って意味ですね」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},		{"command":[ "PLAYVOICE", "102_0104106" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「へ？　なんか違う……ですって？　もう、そんなことはどうでもいいんです\n！　さあ、早く挿れて下さいっ……もう覚悟は決めましたから！」", "NORMAL" ]},		{"command":[ "SETCHARA", "0", "char_00010201_01", "1", "CENTER", "0" ]},		{"command":[ "WAITINPUT" ]},		{"command":[ "PLAYVOICE", "102_0104107" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「って、ま、マジでさっさと挿れないで、く、く、下さいいぃぃ……あぐぅ、んぎ\nぃぃぃ……い、痛い、ですぅ～～……」", "NORMAL" ]},		{"command":[ "DISPCHARA", "0", "FALSE" ]},		{"command":[ "FADEIN", "NORMAL" ]},		{"command":[ "SETIMAGE", "0", "still_00010201_02_03" ]},		{"command":[ "FADEOUT", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},		{"command":[ "PLAYVOICE", "102_0104108" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「はー、はー……お、乙女の処女喪失の瞬間を、いったいなんだと心得てるん\nですかぁ……はぁ、はぁ……ビックリしたー……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},		{"command":[ "PLAYVOICE", "102_0104109" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「ううぅ、硬いのが、ぐぅ、あうぅ……お腹の隙間をこじ開けて……あ、あぁ\n、奥に、ねじ込まれてくるぅ……っ」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},		{"command":[ "PLAYVOICE", "102_0104110" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「んっ、あぁぁあ…………あ、あの隊長？　痛いん、ですけどぉ！？　うう…\n…ちょ、あっ、く、苦し……んっ、んぐぅ、うあぁぁ……っ」", "NORMAL" ]},		{"command":[ "SETIMAGE", "0", "still_00010201_02_02" ]},		{"command":[ "WAITINPUT" ]},		{"command":[ "PLAYVOICE", "102_0104111" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「はぁ、はぁ……はへぇ？　あ、ああ、奥まで……届いたん、ですかぁ……？\n　はー……ふぅ……あああ、苦しかったー……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},		{"command":[ "PLAYVOICE", "102_0104112" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「ああ、なんだか、お腹の底をコツコツ叩かれてるような感触が……うええ？\n　これ、オチンチンなんですかー……？　すごぉい……」", "NORMAL" ]},		{"command":[ "SETIMAGE", "0", "still_00010201_02_01" ]},		{"command":[ "WAITINPUT" ]},		{"command":[ "PLAYVOICE", "102_0104113" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「はぁ……はぁ……と、とにかく、あたし、これでもうバージンじゃなくなっ\nたん、ですね……ふふふ、大人の女性に向けて、一歩前進ですね……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},		{"command":[ "PLAYVOICE", "102_0104114" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「へ？　あ、ああ、どうぞ、動いて下さいっ……あたしは、今、色々人間的に\n成長することで、忙しいんで──あたたたたっ」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},		{"command":[ "PLAYVOICE", "102_0104115" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「え？　うそっ、結構痛くないですか？　あっ、あっ、あぁあぁぁぁ……あ、\nアソコが、お腹の中が、引っ張られ……んひぃぃ～～……」", "NORMAL" ]},		{"command":[ "SETIMAGE", "0", "still_00010201_02_02" ]},		{"command":[ "WAITINPUT" ]},		{"command":[ "PLAYVOICE", "102_0104116" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「はぁ、あふぅ……ビックリした……い、痛いというか、なんというか……は\nぁ、ふぅ……まあ、なんとか我慢できそうです」", "NORMAL" ]},		{"command":[ "SETIMAGE", "0", "still_00010201_02_01" ]},		{"command":[ "WAITINPUT" ]},		{"command":[ "PLAYVOICE", "102_0104117" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「え、ええ、どうぞ、動いてみて下さい……今度は無様な声など上げません。\nサムライテールは、そこそこサムライ感のあるサムライですからね」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},		{"command":[ "PLAYVOICE", "102_0104118" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「え？　意味がわからない？　いいんですっ、こんな状況なんですから、いく\nらあたしと言えど、ん、んんぁあ……わけのわからないこと、言いますよ」」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},		{"command":[ "PLAYVOICE", "102_0104119" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「あ、ああ、あぁぁあ……オチンチンが、引き抜かれ……あああん、また押し\n込まれてくるぅ……ぐっ、うぅあ、はぁ……」", "NORMAL" ]},		{"command":[ "SETIMAGE", "0", "still_00010201_02_02" ]},		{"command":[ "WAITINPUT" ]},		{"command":[ "PLAYVOICE", "102_0104120" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「少し、苦しいです……でも、ん、はぁ……あんまり、痛くは……ええ、だか\nら、もう少し激しくても大丈夫っぽいです──ひっ！？　きゃうう！」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},		{"command":[ "PLAYVOICE", "102_0104121" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「あっ、あっ、あぁぁ……ちょ、そ、そのペースで動かしますぅ？　ちょっと\n遠慮しなさ過ぎじゃ……あっ、ぐぅ、ひうう、あはぁぁ！！」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},		{"command":[ "PLAYVOICE", "102_0104122" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「ふぐぅ、あふぅ……はぁ、はぁ……あぁぁぁん……！　ちょ、ちょっと、待\nってぇ……あ、や、やだ……い、痛い……けど、ギリ、我慢できそう……」", "NORMAL" ]},		{"command":[ "SETIMAGE", "0", "still_00010201_02_03" ]},		{"command":[ "WAITINPUT" ]},		{"command":[ "PLAYVOICE", "102_0104123" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「んくぅ、あはぁ……あれ？　あれれ？　段々……楽に、なってきましたぁ…\n…はぁ、んん、あぁぁあん……」", "NORMAL" ]},		{"command":[ "SETIMAGE", "0", "still_00010201_02_01" ]},		{"command":[ "WAITINPUT" ]},		{"command":[ "PLAYVOICE", "102_0104124" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「だんだん、アソコが、オチンチンに慣れてきた、のかも……はぁ、ふぅ……\nえ？　いっぱい、濡れてる……？　あ、あはは……そう、ですか……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},		{"command":[ "PLAYVOICE", "102_0104125" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「だんだん、気持ちよく、なってきたみたい、です……んふぅ、あふぅ、はぁ\n……はぁ……きゃうぅぅ……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},		{"command":[ "PLAYVOICE", "102_0104126" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「はぁ、はぁ……ええ？　隊長も、興奮して……我慢できなくなってきた……\nですって？　うう、そ、そこは堪えましょうよぉ……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},		{"command":[ "PLAYVOICE", "102_0104127" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「あうぅ、わ、わかってます……気持ちよくならなきゃ、お、終わりませんも\nんね……はぁ、はぁ……が、がんばって、我慢します……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},		{"command":[ "PLAYVOICE", "102_0104128" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「あっ……あぁぁ……やっ、駄目ぇ……お腹の奥が、持ち上げられちゃうぅ…\n…はぁ、んふぅ、あはぁぁぁ……」", "NORMAL" ]},		{"command":[ "SETIMAGE", "0", "still_00010201_02_02" ]},		{"command":[ "WAITINPUT" ]},		{"command":[ "PLAYVOICE", "102_0104129" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「お尻が、パンパン叩かれてる……やぁん、悔しい……あたし、サムライなの\nにぃ……こんな目に、遭わされて……はぁ、はぁ……ひうぅぅぅ……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},		{"command":[ "PLAYVOICE", "102_0104130" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「うう、自分が、気の毒過ぎて……なんだか、興奮して来ました……はー……\nはー……あぁあ、なんだか、気持ち、いい～～……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},		{"command":[ "PLAYVOICE", "102_0104131" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「はぁ、はぁ……えええ？　ラストスパート？　今のこの、満身創痍のこのあ\nたしに……もっとひどいことを……あああ、だ、駄目ぇぇぇ……！」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},		{"command":[ "PLAYVOICE", "102_0104132" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「ふぐぅ、んはぁ、あっ、ひぐぅぅぅぅ！？　あっ、あぁぁ、あ、アソコ、壊\nれ、ちゃ……んぐ、きゃうぅ、や、やめ、てぇぇ……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},		{"command":[ "PLAYVOICE", "102_0104133" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「え？　自分でお尻、突き出してる……？　そんなこと、してません……ああ\n、ひどい、隊長の鬼ぃ……悪魔ぁあ！　変態おちんちん男ぉ……！」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},		{"command":[ "PLAYVOICE", "102_0104134" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「え！？　な、中に出す、ですってぇ……！　まあ、いいですけど……でも、\nひどい……あ、ああ、出される……初めてなのに、中に……んぎぃぃぃ！」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},		{"command":[ "PLAYVOICE", "102_0104135" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「あぁぁぁぁぁー……すごいすごい……中で、オチンチンが暴れてるっ！　ビク\nンビクン、震えてる……」", "NORMAL" ]},		{"command":[ "FADEIN", "NORMAL" ]},		{"command":[ "SETIMAGE", "0", "still_00010201_02_06" ]},		{"command":[ "FADEOUT", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},		{"command":[ "PLAYVOICE", "102_0104136" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「は～～……あひぃぃ……隊長の、体温が子宮の中に染み込んで、くるぅ……\nはー……はぁぁん、んくぅ……はへぇぇぇ……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},		{"command":[ "PLAYVOICE", "102_0104137" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「あ、あ、はぁ……ああああ……気持ちいい……ひやぁぁ……やだ、やだやだ\n……隊長に無理やり、中に……んんぅん、ひどぉい……」", "NORMAL" ]},		{"command":[ "SETIMAGE", "0", "still_00010201_02_05" ]},		{"command":[ "WAITINPUT" ]},		{"command":[ "PLAYVOICE", "102_0104138" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「え？　無理やりじゃない？　そうでしたっけ？　まあ、どっちでも、いいじ\nゃありませんか……あぁあ、精液が、垂れてる……」", "NORMAL" ]},		{"command":[ "SETIMAGE", "0", "still_00010201_02_04" ]},		{"command":[ "WAITINPUT" ]},		{"command":[ "PLAYVOICE", "102_0104139" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「アソコの一番深いところから、精液が滴ってる……はぁ……トロトロが流れ\nてる……んんん、ゾクゾクするぅ……」", "NORMAL" ]},		{"command":[ "SETIMAGE", "0", "still_00010201_02_05" ]},		{"command":[ "WAITINPUT" ]},		{"command":[ "PLAYVOICE", "102_0104140" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「ふぅ……隊長……思ってたより、ずーっと、ずーっと悪くなかったですよ…\n…ふふふ……また、したくなったら、呼んで下さいねー……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},		{"command":[ "PLAYVOICE", "102_0104201" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「……って、まあ終わりじゃない？　ええー？　そーなんですか……？　こー\nいうのって、普通一回で終わりません？」", "NORMAL" ]},		{"command":[ "SETIMAGE", "0", "still_00010201_02_04" ]},		{"command":[ "WAITINPUT" ]},		{"command":[ "PLAYVOICE", "102_0104202" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「え？　一回で終わると決まったわけじゃない……？　う～～……それって、\n隊長が普通じゃないからじゃありません……？」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},		{"command":[ "PLAYVOICE", "102_0104203" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「へ？　あ、いや、何も言ってません。ええ、ホントです……むしろ隊長を絶\n賛していました……ホントにホントです」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},		{"command":[ "PLAYVOICE", "102_0104204" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「えーっと、逞しくて、繁殖能力が高くて、本能に忠実な素晴らしい成人男性\nだと──あっ、あああ……はぁ、んんぅん……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},		{"command":[ "PLAYVOICE", "102_0104205" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「あ、あぁあん、やだぁ……もう……急に、ん、んん、動かさないで、下さい\n……まだあたし、話してる最中だったじゃない、ですかぁ……」", "NORMAL" ]},		{"command":[ "SETIMAGE", "0", "still_00010201_02_05" ]},		{"command":[ "WAITINPUT" ]},		{"command":[ "PLAYVOICE", "102_0104206" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「……まあ、中断して困るような内容じゃ、全然ありませんでしたけど……は\nぁ、はぁ……あっ、あふぅ……ああ、すごい……いっぱい、動いてる……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},		{"command":[ "PLAYVOICE", "102_0104207" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「はぁ……ん、中で、ひっかかる感じがする……ん、んん、でも、痛くない…\n…はぁ、んふぅ……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},		{"command":[ "PLAYVOICE", "102_0104208" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「ぬるぬるしてて、気持ちいい……これって、ん、はぁ……精液のおかげ、な\nんですか？　ん、んん……精液って、偉大ですねー……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},		{"command":[ "PLAYVOICE", "102_0104209" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「赤ちゃんできるし、ローションになるし……あとは、んーっと、エロいです\nもんねー……えへへ……はぁ、んん、あぁぁあん……♪」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},		{"command":[ "PLAYVOICE", "102_0104210" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「あはぁぁ……エッチな声、出しちゃったー……はー……はーあぁん……あた\nし、感じてる……なんだか、大人の女性になった気分……」", "NORMAL" ]},		{"command":[ "SETIMAGE", "0", "still_00010201_02_04" ]},		{"command":[ "WAITINPUT" ]},		{"command":[ "PLAYVOICE", "102_0104211" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「ん、んん……はぁ、ああああ……や、ダメ……声が、抑えられなく、なって\nきちゃったぁ……はぁ、んん、きゃうぅん……♪」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},		{"command":[ "PLAYVOICE", "102_0104212" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「はぁ、はぁ……声を出すと、余計に気持ちよくなっちゃいません？　はぁ…\n…ふぅ……あはは、男の人は、そーいうの、無いんですねー……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},		{"command":[ "PLAYVOICE", "102_0104213" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「はぁ……はぁ……もっと、激しく、して下さい……あたし、もっとエッチな\n声、出したい……もっといっぱいエッチになりたいですぅ……」", "NORMAL" ]},		{"command":[ "SETIMAGE", "0", "still_00010201_02_05" ]},		{"command":[ "WAITINPUT" ]},		{"command":[ "PLAYVOICE", "102_0104214" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「ん、あっ、んひぃぃ！？　す、すごい……お腹の中で、ゴツゴツ音がする…\n…子宮と、先っちょが、ぶつかって……ひっ、んくぅ！　はぁぁん♪」", "NORMAL" ]},		{"command":[ "SETIMAGE", "0", "still_00010201_02_06" ]},		{"command":[ "WAITINPUT" ]},		{"command":[ "PLAYVOICE", "102_0104215" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「気持ちいいのが、いっぱい溢れてる……あ、ああん、このままだと、また、\nイッちゃう、かも……？」", "NORMAL" ]},		{"command":[ "SETIMAGE", "0", "still_00010201_02_05" ]},		{"command":[ "WAITINPUT" ]},		{"command":[ "PLAYVOICE", "102_0104216" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「はぁ、はぁ……イキたい……さっきみたいに、身体をビクンッてしたい……\nはぁ、はぁ……