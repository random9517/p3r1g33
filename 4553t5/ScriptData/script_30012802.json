		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "Ｃ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「あああぁぁぁああぁぁ～～～～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2804301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000128_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｃ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「んぁっ、ああっ、イクッ、イクッ、精液ぃ、子宮に浴びながらイッくぅうう\nうぅぅぅ～～～～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2804302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｃ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「んぁっ、ああっ、二度目なのに……たっくさん、んぁっ、溢れそうなくらい\nの精液ぃ……たまらないぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2804303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｃ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「んふぅ……お前の好きという気持ちが……子宮から……全身に染みわたる感\nじだぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2804304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｃ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……たまらない……。私も、お前にこんなに射精してもらって\n、嬉しくて……あはぁ……言葉が出てこない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2804305" ]},
		{"command":[ "SETIMAGE", "0", "still_00000128_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｃ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「おかしいな。さっきまで、臆面もなく好き、好きと言っていたはずなのに…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2804306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｃ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「いまは、なんだか恥ずかしく感じてしまう……。ふふ……だが、その言葉に\n込めた気持ちは、嘘なんかじゃないんだからな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2804307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｃ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「……クリスタルのおかげで、願いはゆがんだ形で叶ってしまったが、案外悪\nくなかったかもしれないな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2804308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｃ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「この力がなければ、私は、お前から本心を聞きだす勇気など出なかっただろ\nうから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2804309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｃ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「ふふ……それじゃあ続きをしようじゃないか。いままでイチャイチャできな\nかった分を取り戻してやるからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2804310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "Ｃ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「ああぁっ、待て、なんで抜いて……あぁあっ、あはぁあああぁぁぁ～～～～\nっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2804401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000128_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｃ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ、ああっ、またすごい勢いで……精液が、あはっ、私の……全身に……\nはぁ、はぁ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2804402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｃ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「ああ……なんて濃い精液……。こんなにドロドロで、いやらしい匂いのもの\nが、私の子宮に注ぎ込まれていたと思うと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2804403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｃ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「全身がまた、燃えるように熱くなってしまう……。んふぅ……ああ……だめ\nだ……我慢ができないぃ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2804404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｃ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「んぁっ、ああぁ……っ！　二度も射精して……なお硬いオチンポに……んく\nぅ……オマンコを……こすりつけて、しまうぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2804405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｃ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁっ、ああ……んぅ……っ！　オチンポがビクビクはねて、まだ精液を噴\nきだしているじゃないか……ンッ、あはぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2804406" ]},
		{"command":[ "SETIMAGE", "0", "still_00000128_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｃ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「まだまだ、射精し足りないのだな……。ふふ、私だって、もっとお前とエッ\nチしたくて……たまらない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2804407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｃ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「いままで我慢してきたんだ……こうやって、お前とエッチすること……たく\nさん射精してもらうこと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2804408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｃ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「お互いの気持ちを知った今、それを我慢する必要なんてどこにもないよな？\nそうだよな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2804409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｃ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「お互いの身体がひとつに溶けてしまうくらい、このまま……愛しあおうじゃ\nないか……」", "NORMAL" ]},
