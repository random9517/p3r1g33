		{"command":[ "SETNAME", "Ｃ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「また……思いっきり……。私に、お前の濃厚なオチンポミルクを……んぁっ\n、たっくさん、射精して……くれ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2804217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｃ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「ああっ、あはぁっ、私も……私もまたイクから……。もう一度、一緒にイこ\nう……一緒にふたりで、大好きなオチンポとオマンコで……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2804218" ]},
		{"command":[ "SETIMAGE", "0", "still_00000128_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｃ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「いっぱい、いっぱい気持ちよくなるんだ！　ああっ、好き同士、いっぱいイ\nク、何度だって、イキまくってもいいんだからぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2804219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｃ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「ああっ、あはぁっ、だしてっ、だしてぇっ！　イクッ、イッちゃうから、私\nも……ああっ、ああっ、ああ……！　イッくぅうううぅぅぅっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2804220" ]},
		{"command":[ "SETIMAGE", "0", "still_00000128_02_07" ]},
		{"command":[ "WAITINPUT" ]},

