	{"command":[ "SPOTCHARA", "0", "1", "2", "3"] },
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「きゃぁあああああああああああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010106180001" ]},
	{"command":[ "SETCHARA", "0", "char_00000601_01", "3", "CENTER", "0" ]},
	{"command":[ "DISPTEXT", "TRUE" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「うっ……うううううっ……やられた……ダイヤナちゃん、やられちゃった…\n…！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010106180002" ]},
	{"command":[ "SETCHARA", "0", "char_00000601_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ふっ、ふふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010106180001" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ふふふふふふふふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010106180001" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ダイヤナちゃんも……ゾンビちゃんになっちゃうんだ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010106180003" ]},
	{"command":[ "SETCHARA", "0", "char_00000601_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ふふふふふふふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010106180001" ]},
	{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「うっ……うっ……うううううっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010106180004" ]},
	{"command":[ "SETCHARA", "0", "char_00000601_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「はははははははは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010106180001" ]},
	{"command":[ "SETCHARA", "0", "char_00000401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「うわぁあああああああーん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010106180005" ]},
	{"command":[ "SETCHARA", "0", "char_00000601_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYBGM", "BGM_012" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「は！？　お、おい、ダイヤナ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010106180002" ]},
	{"command":[ "SETCHARA", "0", "char_00000401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「やだ！　やだよぉ～！　ゾンビちゃんとかかわいくないのぉ～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010106180006" ]},
	{"command":[ "SETCHARA", "0", "char_00000601_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ダイヤナさん、落ち着いてください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010106180002" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「いやっ！　ゾンビちゃんのくせに話しかけないでっ！　びええええええええ\nえ～～～ん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010106180007" ]},
	{"command":[ "SETCHARA", "0", "char_00000601_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「だから落ち着けダイヤナ。私たちはゾンビではない。そもそも死んでなどい\nない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010106180001" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「だから！　死んでるのに死んでないのがゾンビなんでしょ！　うぇええええ\nええ～～～ん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010106180008" ]},
	{"command":[ "SETCHARA", "0", "char_00000601_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「いいから聞くんだ、ダイヤナ。我々は最初から死んでいないと言ってるんだ\n。あれはウソ、死んだふりだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090106180001" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「びえええええ～～～ん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010106180009" ]},
	{"command":[ "SETCHARA", "0", "char_00000601_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「これは……ダメかも。長官から説明を……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010106180001" ]},
	{"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYBGM", "BGM_018" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「仕方ないな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010106180001" ]},
	{"command":[ "SETCHARA", "0", "char_00004901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「えっ！？　長官！？　長官帰ってきたの！？　助けに来てくれたの！？　は\nっ！　まさか長官もゾンビ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010106180010" ]},
	{"command":[ "SETCHARA", "0", "char_00000601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「違う違う！　いいか、ダイヤナ。ゾンビなどここにはいない。そもそも、誰\nも死んではいない。これは訓練なんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010106180002" ]},
	{"command":[ "SETCHARA", "0", "char_00004901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ふぇ……？　くんれん？　くんれんって……えぇええええっ！？　訓練！？\n　じゃあ、全部ウソっこなのぉ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010106180011" ]},
	{"command":[ "SETCHARA", "0", "char_00000601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「そうだ。もちろんウソっこだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010106180003" ]},
	{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あ、あれ！？　でも、でも……？　えーと、最初にアナザーちゃんが爆弾で\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010106180012" ]},
	{"command":[ "SETCHARA", "0", "char_00000601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ああ……すまない。実はこの訓練、私の発案でな……。だから、一番最初の\n犠牲者役を引き受けたんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090106180002" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「でも……オボロちゃんは、アナザーちゃんの脈を診て――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010106180013" ]},
	{"command":[ "SETCHARA", "0", "char_00000601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「それはこれだ。ミス・パープルからもらった試供品の『訓練用偽装薬シンダ\nーフリデス６０』」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010106180004" ]},
	{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「しんだ……ふりです？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010106180014" ]},
	{"command":[ "SETCHARA", "0", "char_00000601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「そうだ。これを飲めばおよそ６０分の間、脈も呼吸も完全に止めつつ、安全\nに生命を維持できるという薬だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010106180005" ]},
	{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「なにそのメチャクチャな薬！　ホントに安全なの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010106180015" ]},
	{"command":[ "SETCHARA", "0", "char_00000601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「不本意ながら実験に協力しましたが、わたくしこのとおりピンピンしており\nますぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010106180001" ]},
	{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「長官が煎餅をくださるというから動物愛護の精神に目覚めたのかと思いきや\n、まさかあのようなものを混ぜるとは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010106180002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「だから昨日は街でハンバーガーをおごったじゃないか。それで勘弁してくれ\n。いやまあ、それはともかく――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010106180006" ]},
	{"command":[ "SETCHARA", "0", "char_00004901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「偽物の爆弾を破裂させた後。私はやってきたルナテミスに――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090106180003" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0089" ]},
		{"command":[ "DISPIMAGE","0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁ！？　訓練！？　死んだふり！？　なんなのだ、それはいったい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010106180002" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「静かに！　みんながこちらにくる。そういうわけだから、二人目の犠牲者役\nはおまえに頼んだぞ！　ほら、これが薬だ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090106180004" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「いきなりそんなことを言われてもだな！　おい！　おいっ！？　アナザー！\n？　おもむろに薬を飲むなっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010106180003" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「アナザーッ！！！！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010106180004" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0124" ]},
		{"command":[ "DISPIMAGE","0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「わけがわからんとは思ったが、私は、エファナティカにそのことを伝え――\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010106180005" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0094" ]},
		{"command":[ "DISPIMAGE","0", "true" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「は、はぁ……訓練で……。あたしが次の犠牲者役ですか？　わけがわかりま\nせんが、ルナテミス様がそうおっしゃるなら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010106180002" ]},
	{"command":[ "SETCHARA", "0", "char_00000301_01", "1", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0124" ]},
		{"command":[ "DISPIMAGE","0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「っていうわけで、あたしも死んだふりをしたのさ。でも、次の犠牲者役に薬\nを渡すことができなくて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010106180003" ]},
	{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「変装して、あんたらを襲ったってわけさ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010106180004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「そして私は戦闘中、スーツの回線を通してシルバスターに通信を贈った」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010106180007" ]},
	{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0094" ]},
		{"command":[ "DISPIMAGE","0", "true" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「ええっ！？　訓練！？　死んだふり！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010106180001" ]},
	{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「隙を見て、エファナティカから薬を……ですか？　わかりました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010106180002" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
