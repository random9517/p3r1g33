		{"command":[ "PLAYBGM", "BGM_018" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「そしてわたしたちも、同じようなことをカグヤに」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010106180003" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "0", "CENTER", "0" ]},
