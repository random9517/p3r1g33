{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00020601_01_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「ちょっ……ちょちょちょっ、ちょーっと待ってっ、こ、これっ……あのっ、\n身動きっ……取れないんだけどっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0103101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「確か、予定では……アタシが奉仕するって言うか……オ、オチンポ……舐め\nるって、そういう話だったよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0103102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「な、なのに……なんで、アタシ……こんな、カラダっ……拘束されて、足…\n…開かされてるのっ、何か話違わないっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0103103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「え……自分ばっかりじゃ申し訳ないから……アタシも、感じさせて……い、\nいや、お気持ちは嬉しいけど、それと拘束されるのは別だよね！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0103104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「ていうか、この近づいて来てるのはナニ！？　めっちゃ振動してるように見\nえるんですけどっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0103105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「や、ヤバいって……これ、捕まって拷問される時にされるやつじゃん！　ア\nタシ、そんな悪いことしてないよね？　待ってっ……ち、近づけちゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0103106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「ひゃふぅっ！　あっ、あぁぁぁぁぁぁっ！　はひぁっ、おっ……あぉっ、お\nぉっ……そ、そこらめっ、らめぇえ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0103107" ]},
		{"command":[ "SETIMAGE", "0", "still_00020601_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「あひぁっ、プルプルするっ……股間っ、らめっ……そこっ、オ、オマンコっ\n……オマンコぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「ひっ！？　おっぱいもっ……来るっ！　ひっ、いひっ、なにっ、これっ……\nで、電マっ！？　マ、マッサージってレベルじゃっ……はひぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「あっ、んあぁぁぁぁっ！　そごっ、強い強い強いぃぃぃっ！　オマンコっ、\nおっぱいっ！　い、いっぺんにはっ、は、反則ぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「ひぁう……あっ、あぁぁっ……とまらにゃっ……こんなのぉっ、あぉっ、お\nっ、おぉぉぉぉんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0103111" ]},
		{"command":[ "SETIMAGE", "0", "still_00020601_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「だ、ダメっ……ダメったらっ……ど、どこに力入れたら、いいのっ……んん\nっ、我慢っ……ムリぃっ、ひぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「んぁっ、はへぁっ、乳首もっ……ひぁぅっ……あっ、んぁぁっ、震えるっ…\n…！　ブルブルするのぉっ、おかしくなるからぁっ、ひぁっ、あへぁぁぁんっ\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「まっ……ど、どさくさ紛れに、カラダ撫で回すのもなしぃっ！　お、お腹っ\n……ひっ、腋とかっ……ホントにダメェっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「あっ……だ、だからってっ……あっ、電マっ……集中させるのもっ！　もっ\n、そこっ、もっ、もぉダメっ……んひぃぃぃぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0103115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「あ……はぁぁ……イ、イッてない……違うし、今のは……ちょっとびっくり\nしただけで……まだ、そんなんじゃ……はへぁっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0103116" ]},
		{"command":[ "SETIMAGE", "0", "still_00020601_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「う、ウソですっ！　ウソつきましたっ！　イッたっ！　イッたのっ！　オマ\nンコっ！　オマンコイッたからっ、連続はダメっ、あ、あへぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0103117" ]},
		{"command":[ "SETIMAGE", "0", "still_00020601_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「くひっ……あっ、あぁぁぁぁぁっ！　きっ……気持ちいいからっ！　あっ、\nまた気持ちいいの広がってるからっ！　またイクからっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「ひあっ、あっ、あへぁぁぁぁぁんっ、だめっ……いっ……ひぃっ、イクっ…\n…イクぅぅぅぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「はぁっ……んぁっ、あへぁ……はぁ……はぁっ……あ、あぁぁ……ダメって\n……言ったのに……ま、まら……はひぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「んっ、あふぁ……え……ちょ、あの……な、何して……ま、待って……マ、\nマスクは命だからっ！　それを外すのは、命を奪われるも同然で……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0103121" ]},
		{"command":[ "SETIMAGE", "0", "still_00020601_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「ら、らめっ……ホントに！　い、今の顔はっ……見せちゃダメなやつだから\nっ……あっ、あぁぁーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「あ……ぅぁぁぁ……らめらって……メ、メス顔とか、言わにゃいれ……はじ\nゅかしい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0103123" ]},
		{"command":[ "SETIMAGE", "0", "still_00020601_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「んぁ……オ、オチンポ……こ、このまま……舐めるの？　ひゃひ……あ……\nんっ、ちゅぱ……ちゅぷ、れろ……れろぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0103124" ]},
		{"command":[ "SETIMAGE", "0", "still_00020601_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「あぁ……んちゅぷ、ぴちゃ……える……えろ、れろ、れろぉ……んはぁ……\nオチンポ……ビンビンに震えてるぅ……ちゅぱ……ぴちゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「あ、アタシのメス顔で興奮したから……あぁ……そんなこと言わないれ……\nんちゅぷ、あぁ……んむ、ぴちゃ……りゅぽっ、くぷぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「あぁ……なんで……オチンポ、ぴちゃ……んっ、舐めるだけで……また、ム\nズムズ……してるふぅ……ふぐっ……んんっ……くぅんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「ひぁっ！　ま、またっ……電マっ……はっ、ふひゅっ、んりゅっ……あ、あ\nひぁっ、あぉぉっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0103128" ]},
		{"command":[ "SETIMAGE", "0", "still_00020601_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「こ、このまま舐めるなんてぇ……そんらろ……んちゅぱっ、ぴちゃ……んち\nゅ……ふぁぁ……あんむ、んりゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「な、なんれ……アタシ……はぁんむ、ちゅぷっ……舌が自然に……動いひゃ\nう……んちゅぷっ、ぴちゃっ、ちゅぷぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「やらしい顔見られてぇ……無理やり気持ちよくされてるのにぃ……オチンポ\n、ふぶっ……おしゃぶりしてるぅ……むぐっ、んふぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「んぶっ、くぽっ、りゅぷっ、んっふ……じゅるっ、んじゅるるるっ……ちゅ\nぷっ、んむ、んじゅぅぅぅぅぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「あぁ……んむっ、ふるえへる……アタシのカッコ見て……オチンポ興奮して\nる……出したがってるぅ……くぽっ、りゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「んふぅっ、の、飲まへる気なの……？　んちゅぷっ、あぁ……れも……なん\nらか……飲みたいような……んちゅぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「いいよっ……らひてっ！　ふぐっ、飲むからっ……せーえきっ、びゅくって\n……んりゅぷっ、ら、らひてぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0103135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「んぶっ……ふぐっ、んぅぅぅぅーっ！　んぐっ、んっ、こくっ、んっ、んく\nっ……んっ、こくんっ……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0103136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00020601_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「んふぁ……あぷっ、めひゃくちゃ……射精してる……ぷぁっ、アタヒ……全\n部、飲んじゃってる……んちゅぷぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0103137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「ぷぁっ……はぁ、はぁっ、んっ、はぁ……あ……ふぁ……はへぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0103138" ]},
		{"command":[ "SETIMAGE", "0", "still_00020601_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「こ、れが……奉仕で……よかったの……？　も、何が……何だか……全然分\nかんなくて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「ちゅぷっ……精液の味……する……はぁ……はぁ……はぁ……はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「ま、まぁ、とにかく、何とか無事に終わったってことで……えぇと……あの\n、これは外れるんだよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0103201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「その……それ以前に、まだ目の前にオチンポがあるのはどういうことなのか\nな……と……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「えと……つまり、まだ全然終わってないと……デスヨネー、しますよ……す\nればいいんでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0103203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「ちゃんとするから、早くこれを外して……てっ、ちょっ……何でまたこれ動\nいて来てるの？　はっ、ひぁっ、ひゃっ……んひぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0103204" ]},
		{"command":[ "SETIMAGE", "0", "still_00020601_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「ま、また……気分を盛り上げる為って……も、もう盛り上がってるからっ！\n　十分っ、十分にその気になってるって、あぃっ、ひっ、んひっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「あっ、んぁっ、これっ、あっ、逃げられないからっ、おっぱいっ！　先っぽ\n当たってるのっ、はひぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「こ、こんな状態じゃっ、ちゃんと上手くオチンポフェラしてあげられないか\nらっ、ねっ？　あっ、んぶぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「ふぐっ、おぶっ、んむぅぅぅっ……ふぐぅっ、ふぉんらっ……むぐっ、ムリ\nにっ……んんむぅぅっ、むぐっ、んぐぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「じゅぱっ、ん……むふぅ……んんっ、あぷぁっ……なんれ、メチャクチャに\nされてるのに……んふぅっ、はぷっ、んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「きもひっ……よくらってる……んじゅぷっ、くぱっ、んぁっ、あぷっ……ん\nふっ、あ、あぁっ……今、オ、オマンコらめぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0103210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「ひっ、響くのっ……あひっ、かき回されてっ……いいっ、ぎもぢいいからぁ\nっ、あっ、あへぁっ、んぁぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「くぅんっ、あっ、オマンコ集中されてるっ！　一度にされたらっ、あひぉっ\n、またっ、あぉぉんっ、またイクぅぅぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0103212" ]},
		{"command":[ "SETIMAGE", "0", "still_00020601_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「はっ、ひぁっ、あぷっ！　んむっ、ぴちゃっ……な、舐めるからぁ……せ、\nせめて……おっぱいの振動弱くしてぇ……んちゅぱっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「んふぅっ、ひゃんと……頑張ってオチンポペロペロするからぁ……ぴちゃっ\n、あぁぁぁ……また……イキそぉ……んへぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0103214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「あっ、うんっ……くぅっ……あと、ちょっと我慢するっ……んちゅぷっ、ん\nふぁっ、電マっ……気持ちいいけどっ、あっ、おぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0103215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「このオチンポもっ……気持ちよくさせるのっ、ふぶっ、んりゅぷっ、くぷっ\n、じゅるっ、んじゅぅっ！」", "NORMAL" ]},
