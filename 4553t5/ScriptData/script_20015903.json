{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0041" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「ここが……未来のミッドガルドの街なのですね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_010023820001" ]},
		{"command":[ "SETCHARA", "0", "char_00027901_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒルデガード" ]},
		{"command":[ "SETTEXT", "「街の中がキラキラと輝いています！　すごいです……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_281_010023820001" ]},
		{"command":[ "SETCHARA", "0", "char_00028101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「お、おい……裂け目を調査するんじゃなかったのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_010023820001" ]},
		{"command":[ "SETCHARA", "0", "char_00028001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「まあ、これも道中だ。多少寄り道しても罰は当たらん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090023820001" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「そんな悠長なことを言っている場合じゃ……むぐっ！　んっ……こ、これは\nぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_010023820002" ]},
		{"command":[ "SETCHARA", "0", "char_00028001_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ふふん、この街の名物の１つ、フルーツたっぷりスペシャルクレープの味は\nどうだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023820001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「バ、バカ者……そんらものには騙され……んふぅ……甘くて美味い……ふは\nぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_010023820003" ]},
		{"command":[ "SETCHARA", "0", "char_00028001_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「くくっ、メスの顔をするじゃないか。そんなにクリームの味がよかったのか\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023820002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんで、いかがわしい言い方になってるんだよ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「それにしても、活気がありますね。私たちの世界のミッドガルドも、やがて\nはこのように発展するのでしょうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_010023820002" ]},
		{"command":[ "SETCHARA", "0", "char_00027901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「まあ、こちらの世界もきらびやかな所ばかりではないがな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090023820002" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒルデガード" ]},
		{"command":[ "SETTEXT", "「あなた方のような戦士がいるということは、当然ながら戦いがあるというこ\nとですものね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_281_010023820002" ]},
		{"command":[ "SETCHARA", "0", "char_00028101_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ほれ、次は我々が誇る最強の屋台フード、たこ焼きだ。口を開けろぉ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023820003" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「ひゃめ……はふっ！　あっ、ふっ……！　熱い……！　う、美味いっ……！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_010023820004" ]},
		{"command":[ "SETCHARA", "0", "char_00028001_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「さっきからあいつらは何をやってるんだ……っあてっ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「あっ……これは失礼致しました。お怪我はありませんか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_010023820001" ]},
		{"command":[ "SETCHARA", "0", "char_00028201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あ、いや、こっちこそ不注意だったみたいで申し訳ない」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「えっ……フ、フレイア様？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_010023820003" ]},
		{"command":[ "SETCHARA", "0", "char_00027901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「あら……これはこれは、意外なところで出会うのね、レイア」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_010023820002" ]},
		{"command":[ "SETCHARA", "0", "char_00028201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「フレイア様こそ……どうしてここに……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_010023820004" ]},
		{"command":[ "SETCHARA", "0", "char_00027901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「ふふ……私にもよく分からないの。ちょっとしたご縁があったということか\nしらね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_010023820003" ]},
		{"command":[ "SETCHARA", "0", "char_00028201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「おやぁー？　見慣れた愉快なお顔に、あんまり見かけない面白そうなカッコ\nの人達が並んでるねぇー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010023820001" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒルデガード" ]},
		{"command":[ "SETTEXT", "「お、面白そうな格好……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_281_010023820003" ]},
		{"command":[ "SETCHARA", "0", "char_00028101_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「もしかして、キミたちの知り合いってヤツ？　敵？　仲間？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010023820002" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「さて、どちらでしょうね。ふふっ、もしかしたらこれからのお話次第で変わ\nってくるかも知れませんわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_010023820004" ]},
		{"command":[ "SETCHARA", "0", "char_00028201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「お前は時間帝国の……するとあの空の異変は、やはりお前らの仕業というこ\nとか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090023820003" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「異変～？　さーて、何のハナシやらさっぱり分かんないし♪　でも、もしか\nして、そっちのみんなは元の世界に戻りたいとか～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010023820003" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「元に戻る方法があるのですかっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_010023820005" ]},
		{"command":[ "SETCHARA", "0", "char_00027901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「ふふっ……私たちと一緒に参りますか？　あなた方ならいつでも歓迎ですよ\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_010023820005" ]},
		{"command":[ "SETCHARA", "0", "char_00028201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「おっ、ヘッドハンティングしちゃう？　ウチらに協力してくれるなら、いつ\nでも歓迎しちゃうケド？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010023820004" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「やめておけ、レイア。こいつらの放つ空気で、その本性は知れているだろう\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_010023820005" ]},
		{"command":[ "SETCHARA", "0", "char_00028001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒルデガード" ]},
		{"command":[ "SETTEXT", "「はい、この方はよくない気配がします。耳を貸してはいけません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_281_010023820004" ]},
		{"command":[ "SETCHARA", "0", "char_00028101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「うわー、今出会ったばっかなのにジェスタちゃんの好感度マイナスになって\nるよ～。べっぴんさん達なのに攻略対象じゃないのかな～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010023820005" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「時間帝国の皆様は、見かけによらずお優しいですよ。もう少し考えてみては\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_010023820006" ]},
		{"command":[ "SETCHARA", "0", "char_00028201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「フレイア様……申し訳ありませんが、私も、今の状況でお話を受け入れるこ\nとはできません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_010023820006" ]},
		{"command":[ "SETCHARA", "0", "char_00027901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「あら……残念。また、貴方と志を共にできるかと思ったのだけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_010023820007" ]},
		{"command":[ "SETCHARA", "0", "char_00028201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「ふん、仲間に引き入れるまでもない。貴様らには服従がお似合いだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_010023820001" ]},
		{"command":[ "SETCHARA", "0", "char_00028401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うっ、ぐっ……！　は、離せっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「カツマさんっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_010023820007" ]},
		{"command":[ "SETCHARA", "0", "char_00027901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「下僕……！　また油断して……バカがっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023820004" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「貴様らの仲間なんだろう。さて……こいつがどうなってもいいのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_010023820002" ]},
		{"command":[ "SETCHARA", "0", "char_00028401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「くっ……また卑怯な手を……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_010023820006" ]},
		{"command":[ "SETCHARA", "0", "char_00028001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒルデガード" ]},
		{"command":[ "SETTEXT", "「ど、どうしましょう……人質を取られては、今の私たちでは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_281_010023820005" ]},
		{"command":[ "SETCHARA", "0", "char_00028101_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「へぇー、面白いね。原始的な手が結構効いちゃうみたいなんだ？　さてさて\nー、どうするのかなー？　んー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010023820006" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「我々の軍門に下るというなら、こいつを解放してやらんこともないが……ど\nうする？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_010023820003" ]},
		{"command":[ "SETCHARA", "0", "char_00028401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「……そ、それは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_010023820008" ]},
		{"command":[ "SETCHARA", "0", "char_00027901_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「えぇいっ、まどろっこしいっ！　こんなものは、こうしておけばいいのだっ\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023820005" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「ぐぁぁぁぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_010023820004" ]},
		{"command":[ "SETCHARA", "0", "char_00028401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ほぐぅぅぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒルデガード" ]},
		{"command":[ "SETTEXT", "「あ、あの、今……人質ごと蹴り飛ばしませんでしたか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_281_010023820006" ]},
		{"command":[ "SETCHARA", "0", "char_00028101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「そちらの方が当たりやすいと思ったんだろうな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090023820004" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「思ったんだろうって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_010023820009" ]},
		{"command":[ "SETCHARA", "0", "char_00027901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「ば、バカな……もし、人質に何かあったらどうするつもりだったんだっ！？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_010023820007" ]},
		{"command":[ "SETCHARA", "0", "char_00028001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒルデガード" ]},
		{"command":[ "SETTEXT", "「と言うか、普通に何かありましたよね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_281_010023820007" ]},
		{"command":[ "SETCHARA", "0", "char_00028101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「こいつは、ちょっとやそっとでどうにかなるものではない。なったとしても\n、損失としては大したことはない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023820006" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「む……そう言われれば……確かに、そうかも知れん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_010023820008" ]},
		{"command":[ "SETCHARA", "0", "char_00028001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まだ出会ったばかりで納得しないでくれる！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「なーんだ、結局決裂したんだ。じゃあ、敵としてヤっちゃうしかないってこ\nと～？」", "NORMAL" ]},
