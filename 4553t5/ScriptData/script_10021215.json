		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「どうやら、そのようですねえ～。さすが陛下の息子さん。ああ見えて、意外\nと抜け目がないですねぇ～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010114610002" ]},
