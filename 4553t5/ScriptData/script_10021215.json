		{"command":[ "SETCHARA", "0", "char_00020199_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「いまは逃げるがいい。だが、いずれは連れ戻してみせるぞ。息子よ……ふふ\nふふふ……はははははははは！」", "NORMAL" ]},
