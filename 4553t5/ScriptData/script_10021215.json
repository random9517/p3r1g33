		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「ちっ！　お宝は分捕りそこねちまった！　でもまあ、楽しませてもらったか\nらいいや！　また会おうぜ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_010114610001" ]},
