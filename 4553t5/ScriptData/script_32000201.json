{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0078" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「隊・長・様……♪　こっちよ、こっち。こちらにいらして……。うふふふふ \nっ、そうよ、この岩陰。ここで私とあなたは逢引をするの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0203101" ]},
		{"command":[ "SETCHARA", "0", "char_00020002_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「あら？　何をするつもりだ、だなんてつれないのね。期待してなかったとは \n言わせないわよ。男と女の、二人っきりのアヴァンチュール……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0203102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「……私がはっきり言わなくても、あなたのここは……オチンポはすっかり理 \n解しているみたい。……ね？　もうこんなに勃起してる……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0203103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「悪の女幹部の誘いにノコノコ釣られるなんて、しつけが必要ね。さ、ズボン \nなんて脱いでしまいましょ。……いくわよ？　そぉ～れ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0203104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「あは……♪　なんて良い大きさ……！　んふふふっ、こんなに私との逢瀬を \n楽しみにしていてくれただなんて……嬉しいばかりだわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0203105" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00020002_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「ああ……たまらない、オスの臭い……♪　なんだか前に見た時よりも、更に \n立派になっている気がするわ。すん、すん……クセになる香りね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0203106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「赤黒く、隆々としたこのオチンポ。下品な色に、節くれだって反り返った卑 \n猥な形……♪　本当に、私好みでドキドキしちゃう……。美味しそう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0203107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「でも……こんなにいやらしい雰囲気をプンプンさせていたら、たくさんの女 \nの子が誘惑されてしまうでしょ？　だ・か・ら、私考えたのよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0203108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「……私のお口以外では、二度と射精出来ないように……この逞しいオチンポ \nをしつけて、独り占めしちゃおうって。ふふ、覚悟しなさい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0203109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「もう逃がさないから。……あら♪　悪いケダモノだって知ってて私に付いて \nきたんだから……同意したってことでしょ？　それじゃ、いただきまぁす」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0203110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「あむっ……んむっ、んん……♪　んッ、んっむ……フフフフ♪　いやだ、生 \nあたたかい……♪　それに……んちゅっ、少ししょっぱいわ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0203111" ]},
		{"command":[ "SETIMAGE", "0", "still_00020002_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「でも、私……この味が好きなの。男の人の、おしっこの味……♪　そして蒸 \nれた股間の湿り気、くしゃくしゃになった陰毛。それからね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0203112" ]},
		{"command":[ "SETIMAGE", "0", "still_00020002_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「んちゅっ……ちゅっ、ぴちゃっ、ぴちゃ……♪　この、亀頭のプニプニした \n感触……♪　尿道口もヒクヒク震えててすっごく可愛いわ。大好きよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0203113" ]},
		{"command":[ "SETIMAGE", "0", "still_00020002_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「んん……ちゅぷっ、くちゅっ、ちゅぅ……♪　んんっ、ちゅぷっ、ぷちゅっ \n、ちゅぷ……♪　んぁあ……、あなたの亀頭って、すごく太くて素敵だわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0203114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「カリ首の段差もすごいし……こうして咥えてね？　ちゅぱちゅぱおしゃぶり \nしているだけで興奮してきちゃう……。っちゅっ♪　ちゅっ、ちゅぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0203115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「ん、もうキスするのが止められないわ……。ちゅっ♪　ちゅっ、ちゅっ…… \n♪　……あ、ごめんなさい。ちゃんと舌先でも舐め回してあげないとね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0203116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「えぇ？　もーっと深くまでおしゃぶりしてほしい？　もちろんよ。でもそれ \nはま～だ。焦らしに焦らさないと。まずはこの先端をじっくり愛するの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0203117" ]},
		{"command":[ "SETIMAGE", "0", "still_00020002_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「んんん……ッ、ちゅむっ、くっちゅっ、ちゅっぷっ、ぷちゅ……♪　れろれ \nろっ、んれろっ……ぴっちゃっ、ぴちゃ……くっちゅっ♪　あらぁ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0203118" ]},
		{"command":[ "SETIMAGE", "0", "still_00020002_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「舌ですこーし愛撫しただけで、もう腰をガクガクさせているの？　こんなも \nのは序の口よ……がんばって耐えてちょうだいね？　っぴちゃっ、ちゅぱっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0203119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「私のフェラチオが上手すぎるから？　舌が長くて、濡れていて、あったかく \nて気持ちよすぎるから？　うふふ、褒めてくれるのは嬉しいけど、だーめ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0203120" ]},
		{"command":[ "SETIMAGE", "0", "still_00020002_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「私がイッていいって言うまではずっとこのままよ。……んちゅっ、ちゅぅう \nっ♪　ちゅっ、ちゅっ……♪　そう、射精の許可はしてないの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0203121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「……くちゅっ♪　んん～♪　生殺し状態のあなたってそそるわぁ。うんとイ \nジメたくなっちゃう……。んっ、こうやってチロチロされるのがいいのぉ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0203122" ]},
		{"command":[ "SETIMAGE", "0", "still_00020002_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「ぴちゃっ、ぴちゃ、ぴちゃ……あぁんっ♪　腰をヘコヘコさせちゃダメだっ \nてばぁ♪　我慢できないの？　根元まで咥えてねぶってほしい？　ふぅん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0203123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「じゃあ……希望通りにしてあげるけど。オチンポから魂まで吸い上げられち \nゃっても知らないわよ。いいの？　なら、限界までぐっぽりいくわよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0203124" ]},
		{"command":[ "SETIMAGE", "0", "still_00020002_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「んふっ……ぐっちゅっ！　ぐちゅっ、ぐっちゅっ……！　んん～～～♪　じ \nゅっぽっ！　じゅっぽっ、じゅぽっじゅぽっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0203125" ]},
		{"command":[ "SETIMAGE", "0", "still_00020002_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「うふふふっ……♪　突然のディープスロートに腰砕けねぇえ♪　更にここか \nら舌を絡みつかせていくわよ……。んれろっ、れろっ、じゅるっ、じゅるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0203126" ]},
		{"command":[ "SETIMAGE", "0", "still_00020002_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「じゅっぷっじゅっぷっ、ぢゅる～っ！　じゅるっ！　じゅるるるっ！　じゅ \nっぷっ！　んじゅるっ！　じゅるっ♪　はぁ、はぁ、はぁ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0203127" ]},
		{"command":[ "SETIMAGE", "0", "still_00020002_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「んぁん♪　喉奥にオチンポ突き立ててきちゃらめよぉ……♪　んっ♪　んじ \nゅるっ……じゅっぷっ、じゅるっ、じゅるぅ……じゅっぷっ、じゅぽっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0203128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「んっんっんっんっ……！　ぴちゃっ、じゅるっ……！　ぐっちゅっ、ぬちゅ \nっ♪　じゅるっ、じゅるっ、じゅるる……！　ん、ぷぁ……♪　んあ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0203129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「見てぇ……私の唾でテカテカぁ……♪　んれる……っ♪　よ～く覚えておく \nのよ？　これがあなた専用のフェラチオおしゃぶり……。んっ、じゅるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0203130" ]},
		{"command":[ "SETIMAGE", "0", "still_00020002_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「この唇と、舌と……ぴちゃっ、この口内、喉奥でしかイッてはだめ……♪　 \nんんっ、誓えるかしら？　誓えないならイカせてあげないわよ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0203131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「んっ、んっ、ほら……ほらぁ♪　従ってしまいなさい……♪　んっ、じゅる \nっ……！　私のお口以外では二度と射精しないと天に誓ってっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0203132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「そうしたら、うんと気持ちのいい射精をさせてあげるわ……。じゅるっ、れ \nろっ……れろっ、ぴちゃ……。フフフ、どうするの？　っん……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0203133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「もっと深く咥えてあげちゃおうかしら。……んっ♪　じゅるっ！　じゅるる \nっ！　イキふぁい？　……ぐちゅっ！　いいわよ……イキなひゃい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0203134" ]},
		{"command":[ "SETIMAGE", "0", "still_00020002_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「わたひのお口の中をしっかり感じながら出すの……っ！　ほらっ！　……ぢ \nゅるっ！　じゅるるるっ！　ぐっちゅっぐっちゅっずっちゅっ、じゅるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0203135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「んふッ♪　んんんんっ……んんんんぅ……っ♪　おっ♪　ぉっ♪　んぉおっ \n……おっ……♪　んふ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0203136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00020002_01_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「ごくっ……ごくっ……。あら……ごめんなひゃい？　少しお口から溢れてし \nまったわ……。でも、舐め取ってオチンポキレイにしてあげるわね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0203137" ]},
		{"command":[ "SETIMAGE", "0", "still_00020002_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「じゅるっ……ごくんっ！　ぴちゃっ、ぴちゃ、……じゅるっ、ごくっ……。 \nん～～～～っ♪　じゅるっ、じゅる、じゅるじゅる……ごくっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0203138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「ふはぁあ……♪　この味……！　あなたのって本当に濃くて美味しいわ。喉 \n奥にへばりついて、粘り気がいつまでも消えない……。最高の精子……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0203139" ]},
		{"command":[ "SETIMAGE", "0", "still_00020002_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「んんっ……んむ♪　まだ尿道に残っているじゃない……すすりとってあげる \n。じゅる……ぢゅるっ。ごくっ……♪　あはぁ、乾きが癒えるわぁ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0203140" ]},
		{"command":[ "SETIMAGE", "0", "still_00020002_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「あは……、私のお口の中、すっかり精液臭くなっちゃったぁ……♪　この臭 \nい、洗ってもなかなか取れないのよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0203201" ]},
		{"command":[ "SETIMAGE", "0", "still_00020002_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「だって、胃の中にた～っぷり溜まっているんだもの……♪　それを、何日も \nかけて消化して、自分の身体と一つにしていく……あぁ、ゾクゾクするわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0203202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「あなたの子種でとる栄養は最高よ、身体の隅々にまでしみわたるわ……♪　 \nと、無駄な話をしている場合ではなかったみたいね。ね～ぇ隊長様ぁ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0203203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「どうして射精したばかりなのに、オチンポがそそり勃ったまま元気いっぱい \nなのかしら。……一度くらいの射精じゃ全然満足できなかった？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0203204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「それとも……うふっ、もしかして。私のお口の虜になって、早く二回目の熱 \n烈フェラチオを味わいたくてそうなってるの？　だとしたら、そうねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0203205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「……オチンポにむしゃぶりついて、いい子いい子って褒めてあげないといけ \nないわ。ね～え？　答えはオチンポに聞いてみましょう。さ、おかわりよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0203206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「んぐちゅっ……♪　ふんんっ♪　あらっ、硬ぁいぃ……♪　お口の中れゴリ \nゴリひてるわぁ……♪　んっふっ♪　ほっぺたの裏側を押ひてくるぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0203207" ]},
		{"command":[ "SETIMAGE", "0", "still_00020002_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「そんなにわたひのお口が気に入った……？　いいわ、うんと可愛がってあげ \nりゅ……。っぐちゅっ、れろっ、れるっ……ぴちゃ……！　ぐっちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0203208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「んんっ♪　ぐちゅっ！　ぢゅ～っぽっ♪　ぢゅぽっ♪　じゅるっ……ごくっ \n♪　ぐちゅっ……ぢゅ～～～っ♪　じゅるっ♪　ふふふふっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0203209" ]},
		{"command":[ "SETIMAGE", "0", "still_00020002_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「カウパー、飲んでも飲んでも出てくりゅわ……♪　そんなに濡らして、感じ \nやひゅいのねぇ……♪　好きよ♪　じゅっぷっじゅっぷっぬっちゅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0203210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「んっ、太すぎて顎が外れそう……♪　んれろぉ……っ、れろっ、お口の中で \n裏筋を舐めているだけでわかるわ、このオチンポが危険なこと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0203211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「んんふぅううっ♪　お口いっぱいに広がる精液の味ぃ……。堪能しながらし \nゃぶらせて、もらうわね……。んっぐちゅっ！　ぐっちゅっぐちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0203212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「んんんん♪　美味ひぃ……♪　じゅるっ……じゅっぷっ！　ぐちゅっ、ずち \nゅっ……れろれろれろっ、じゅぷっ！　ぐっちゅっ、ぬちゅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0203213" ]},
		{"command":[ "SETIMAGE", "0", "still_00020002_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「ふぁあ♪　おしゃぶりしているだけで、濡れてきひゃう……っ。ちゅっ、ち \nゅくっ♪　ぐちゅっ！　ぐっちゅっ、ぐちゅ……んんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0203214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「わたひの舌……長くて気持ひイイれひょう……？　もっとまとわりつかせて \nあげる……♪　んれろぉ……れろっ、じゅるっ、じゅるっ、れろれろっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0203215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「んっ、ンンッ……！　オチンポ、太くて……んむっ、長すぎて上手くひゃぶ \nれないわぁ……♪　こうなったら頭を上下、させて……んんんん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0203216" ]},
		{"command":[ "SETIMAGE", "0", "still_00020002_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「いい子♪　いい子……じゅるっ♪　ぐちゅぷっ♪　じゅぷっ、じゅっぷっ、 \nぢゅる……♪　うふふふ、先走りのお汁も美味ひぃ……♪　ぐっちゅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0203217" ]},
		{"command":[ "SETIMAGE", "0", "still_00020002_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「……んふふっ♪　オチンポ、お口の中れ膨らんできてるわよ……♪　んっじ \nゅるっ、またイキたいのね♪　いいわよ、たくさんちょうらい……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0203218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「気持ち良く射精できるように、吸い取ってあげるわね♪　んっ、深く咥えて \nぇ……♪　根元から先端まですすり、あげる……！　じゅるじゅるじゅるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0203219" ]},
		{"command":[ "SETIMAGE", "0", "still_00020002_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「じゅるじゅるじゅるじゅるっ……！　んッ！　出すのね……っ！　んんんっ \n♪　すごく楽しみぃっ♪　いっぱいちょうだい……っ！　じゅるるるるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0203220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「んっくっ……！　んぐぅううっ♪　ん～っ……んんーっ……！　んぷっ…… \nごくっ……ごく……んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0203301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00020002_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「だ、め……♪　飲んでも飲んでも溢れ出してくりゅ……♪　んぁあっ、喉の \n奥に絡みついて……上手く飲めな……んんんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0203302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「んぅうっ……♪　ごくっ……ごくっ……♪　んふふふ……。んぅ！？　すご \nいわ、まだ出るのね……。んんんっ♪　ごくっ、ごくんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0203303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「あ、ふ……。この私が全力で飲み干しても、お口からこぼれる量だなんて… \n…普通の女の子なら窒息しかねないわよ。とんでもない人ね……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0203304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「ちゅぷ……れるっ、くちゅ……♪　ああん、カリ首や根元……それに肉竿に \nべっとり精液が付着してる……。全部舐め取らないと……ぴちゃっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0203305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「ぷちゅっ、ちゅむ……んんっ、美味ひぃ……♪　ちゅぷっ……♪　んっ、ん \nっ、最後の一回、大切に飲まないと……。ん、ごくっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0203306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「う、ふふ……♪　すごーく上手に飲めたでしょう？　褒めてくれてもいいの \nよ。なぁんて、私が飲みたくて、飲ませてもらったのに贅沢かしら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0203307" ]},
		{"command":[ "SETIMAGE", "0", "still_00020002_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「開放的なシチュエーションで、人の見ていないうちにゴクゴク飲み干す精液 \nって最高よ。本当に美味しいの。喉ごしも良くて、いくらでも飲めちゃう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0203308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「あぁ、そうだわ。せっかく悪の女幹部の衣装を着ているんだし……。精液を \n飲まないと生きていけない、精子から栄養を得るサキュバスになろうかしら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0203309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「……そうしたら、いつだってあなたの新鮮な精液が飲めるでしょう？　なん \nて、冗談よ。今は。ふふふ……♪　ごちそうさま……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0203310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「んッ！？　やぁんっ、んっぷっ！？　あっ……あっ、顔にかかってるぅ…… \n♪　いじわるぅ……♪　あっ、ぁっあっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0203401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00020002_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「今、わざと私のお口からオチンポを抜いたでしょう……？　んんっ、それと \nも不意打ちで、屈辱的なザーメンシャワーを浴びせるのが正解だと？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0203402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「もし、そう思って顔射してくれているのならっ……あああっ、大正解よ、そ \nの通り……！　あんっ♪　あっ♪　私はそういう酷いのが好きなのぉっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0203403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「んはぁ……♪　さっき出したばっかりなのに、ここまで濃い精液が出るのね \n……感動したわ。見てぇ……私の顔をつたって、垂れるこの粘り気……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0203404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「重たくて、たっぷり精子が入った精液……酔っちゃいそう。はぁああっ…… \nもったりとした感触……♪　鼻をつく臭いぃ……はぁ、はぁ、はぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0203405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「あっ♪　何重にも塗り重ねられた精液の栄養素が、私の肌に染みわたるわ… \n…♪　トロトロで愛おしい、隊長様の赤ちゃんの種……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0203406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「うふふふっ……。隊長様？　あなたはもうすっかり、私のご主人様気取りね \n……♪　でも、それがいいの。私……あなたが望むのならば……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0203407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「妻にでも恋人にでも、性奴隷にでもなってあげられるわ。特別良い人にも、 \nうんと悪い人……悪の女幹部にもね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0203408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「私をあなたの好きなように調教していいって言ったら……どうなっちゃうの \nかしら。私、どんな風にされちゃうのかしら……ドキドキするわ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0203409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「その妄想と、今日のこの精液だけで当分じっくり楽しめそうだわ……♪　あ \nあ、本当に隊長様って刺激的で魅力的な人……大好きよ♪」", "NORMAL" ]},
