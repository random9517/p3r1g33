		{"command":[ "SETNAME", "ピースムーンＡ" ]},
		{"command":[ "SETTEXT", "「陛下！　陛下ーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_030111190001" ]},
		{"command":[ "SETCHARA", "0", "char_00000809_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピースムーンＢ" ]},
		{"command":[ "SETTEXT", "「陛下ーっ！　ご無事でしたらお返事を！　陛下ぁ～～～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_040111190001" ]},
		{"command":[ "SETCHARA", "0", "char_00000801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピースムーンＡ" ]},
		{"command":[ "SETTEXT", "「くっ……陛下……！　いったいどこへ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_030111190002" ]},
		{"command":[ "SETCHARA", "0", "char_00000809_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「……………う……うううぅ～……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010111190001" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピースムーンＢ" ]},
		{"command":[ "SETTEXT", "「この声は……陛下！？　女王陛下っ！　っ！　玉座の裏ですか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_040111190002" ]},
		{"command":[ "SETCHARA", "0", "char_00000801_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「…………くっ……よいしょっ……。こらしょっ……と！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010111190002" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピースムーンＢ" ]},
		{"command":[ "SETTEXT", "「陛下……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_040111190003" ]},
		{"command":[ "SETCHARA", "0", "char_00000801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ぷはぁ～！！　まいったまいった！　すんごい爆発じゃったの～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010111190003" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピースムーンＡ" ]},
		{"command":[ "SETTEXT", "「女王陛下……っ！　やはり、生きておられたのですね……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_030111190003" ]},
		{"command":[ "SETCHARA", "0", "char_00000809_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「こんなこともあろうかと部屋に張り巡らせておいた、超空間魔力メッキが役\nに立ったわい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010111190004" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピースムーンＢ" ]},
		{"command":[ "SETTEXT", "「ご無事で……ほんとうによろしゅうございました！　陛下！　陛下ぁ～～～\n～～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_040111190004" ]},
		{"command":[ "SETCHARA", "0", "char_00000801_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「なんじゃなんじゃ、おぬしたち。地球に逃げろと言うたはずじゃろうが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010111190005" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピースムーンＡ" ]},
		{"command":[ "SETTEXT", "「どうして私たちが、陛下を残して逃げられましょう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_030111190004" ]},
		{"command":[ "SETCHARA", "0", "char_00000809_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピースムーンＢ" ]},
		{"command":[ "SETTEXT", "「我らピースムーン、生きるも死ぬも陛下と共に！　うっ、うっ、うわぁああ\nああああ～ん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_040111190005" ]},
		{"command":[ "SETCHARA", "0", "char_00000801_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「だから泣くなと言うに……しかしなんじゃな。おぬしたちがそこまで言って\nくれるということはじゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010111190006" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「余の人望も、まだまだ捨てたもんじゃない、っちゅうことじゃな！？　ワハ\nハハハハハハハハ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010111190007" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピースムーンＡ" ]},
		{"command":[ "SETTEXT", "「……へ、陛下？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_030111190005" ]},
		{"command":[ "SETCHARA", "0", "char_00000809_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ま、とにかくじゃ。余のことは心配いらん。しかし、まだまだ外では戦いが\n続いとる。おぬしたちはまず、自分の身の安全を確保せよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010111190008" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピースムーンＢ" ]},
		{"command":[ "SETTEXT", "「は、はあ……承知いたしました。では、ご命令がありましたらお呼びを……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_040111190006" ]},
		{"command":[ "SETCHARA", "0", "char_00000801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「うむうむ。大儀であったぞ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010111190009" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ピースムーンたちは、あまりにのん気なルナルバースに拍子抜けした様子で部\n屋を出ていく。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「…………行ったか。さて、と」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010111190010" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ルナルバースはピースムーンたちを見送ると、表情を引き締め、玉座に深く腰\n掛ける。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ルナたちはまだ戦っとるようじゃが、助太刀に行くわけにもいかんし、あっ\nちは若いもんに任せるしかないか。と、なると……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010111190011" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「……陛下」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「…………おう。おぬしか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010111190012" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「は。どうやら、うまくことが運んだようで」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「まあ、な。ひとまずは、こんなもんでよかろう。このあとどう転ぶかはルナ\nたち次第、といったところじゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010111190013" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「……余は、故あってしばらく身を隠すが、陰ながらお前たちのことを見守っ\nておるぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010111190014" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「我が娘、そして、我が腹心の幹部たちよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010111190015" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}