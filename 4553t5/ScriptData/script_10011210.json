		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「つまり、すぐには立ち直れないということです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010112190001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
