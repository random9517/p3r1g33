		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「カツマ……！　カツマと一緒なら、私、ここで死んでも――」", "NORMAL" ]},
