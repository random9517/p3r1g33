		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「おい！？　あいつ、もうダメなのか！？　立てるんだろ？　まだ戦えるんだ\nろ？　なあ！？　まさか、あいつが負けるなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010112190002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａジュンジロー" ]},
		{"command":[ "SETTEXT", "「機能停止は一時的なものと思われるが、再起動には時間を要す。現在、損傷\nの程度を診断中」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_040112190001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
