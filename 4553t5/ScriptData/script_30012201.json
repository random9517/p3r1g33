		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「直接……んふぅっ、犯されてると思うと……んぁっ、ゾクゾクするっ……は\nぁっ、んっ、まだだ……まだ動かしていくからな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2203215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁ……ん、ちゅぷっ、うめき声が漏れてるぞ……？　またチンポ汁も滲ん\nで……２発目……出そうになっているな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2203216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「これだけ……んっ、しっかりと埋め込んでいて……気が付かない訳がないだ\nろうっ……もちろん、我慢は許さんぞ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2203217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「じゅぷっ、んぷっ、りゅぷっ……んちゅぷっ……さあ、また……たっぷりと\n濃いのをぶち撒けてくれっ……んふっ、りゅぷっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2203218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「貴方の欲望を……全部……私にっ……じゅぱっ、びゅくびゅくっ、出してっ\n……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2203219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁんっ、んちゅぷっ、私も……一緒に絶頂するっ……！　だからっ、あぷ\nっ、んんっ、早くっ……出せぇぇっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2203220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「んぷぅっ……！　はぷっ……んぁっ、ちゅぷっ……あぁっ、れたっ……２発\n目ぇっ……れてっ……るぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2203301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000122_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「まへっ……んっ、ひゃんと……飲む……飲むからっ……んっ、んくっ……あ\nぷっ、んんっ……はぁっ、んふっ……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2203302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁ、まだ……出てくる……相変わらず、並外れた量を……んぐっ、こくっ\n、んちゅぷっ……はふっ、んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2203303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「んくっ、ぷぁっ……あぁ、口の中に……すごい味が広がっている……くちゅ\nっ、んっ……待ってくれ……一気には飲みきれない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2203304" ]},
		{"command":[ "SETIMAGE", "0", "still_00000122_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「こく……んっ、こくんっ……んふぁっ……はぁ……あぁ、ゆっくりと味わっ\nて飲み込んでる……はぁ、ぷぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2203305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ふぅ……止まったようだな。はぁ……ちゅぷっ、最後に……後始末だ……ぴ\nちゃ、れろ……んりゅ……んっ、よし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2203306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「さて、これだけ大量に射精したということは、私の奉仕にまんまとやられた\nと……そういうことだな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2203307" ]},
		{"command":[ "SETIMAGE", "0", "still_00000122_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ふふ、そうだろう……だが、それも当然のことだ。それが、妻たる者の務め\nだからな。これからは、催した時は必ず私に言うといい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2203308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「言っておくが、勝手に自家発電するんじゃないぞ？　もちろん、浮気も許さ\nんからな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2203309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ふふ……まぁ、そんなことを考える暇もない位常に射精の面倒は見てやる。\nその心配はいらないから、安心するがいい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2203310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「んぁぁっ！　あぷっ……あっ、顔にっ……２発目っ……あぷっ……出されて\nるぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2203401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000122_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「んんっ、あぁっ……はぷっ、あぁっ、止まらない……んふうぅっ、臭いのが\n……へばりついて……あぷっ、んちゅっ、はぷぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2203402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「うくぁぁ……私も……気持ちよくなっている……あぁ……身体がふわっとし\nて……軽くイッているみたいだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2203403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁ……あふぁ……おっぱいにも、溢れてくる……あぁ、私の身体中を精液\n漬けにする気なのか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2203404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁ……プリっとして……新鮮な精子が、私の中に染み込んでいく……身も\n心も支配されていくような……そんな気分だ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2203405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ちゅぱ……ぴちゃ……まだ、出てるな……後もう少しか……うむ、おっぱい\nで押し込めば……あぁ、最後の分が出てきたな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2203406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「これで終わりか……？　うむ、それなら、後はお掃除だ……ぺろ……れろ、\nちゃんと綺麗にするまでが奉仕だからな……ちゅぱ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2203407" ]},
		{"command":[ "SETIMAGE", "0", "still_00000122_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「うむ、これでいい。どうだ、存分に楽しんだか……？　私のおっぱいの感触\nは気持ちよかったか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2203408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「そうかそうか。ふふっ、当然だ。妻たるもの、パイズリの一つや二つ位は、\n出来て当然だからな。もし、されたくなったらいつでも言うといい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2203409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「とにかく、これで他の女に手を出す必要もなくなるだろう。貴方の射精は、\n全て私が面倒を見る……それでいいな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2203410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
