		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はひっ、中にっ……あぁっ、嬉しいっ……このまま一番深い所に流し込んで\nっ……んぅぅぅぅぅんっ！」", "NORMAL" ]},
