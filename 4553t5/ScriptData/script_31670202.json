		{"command":[ "PLAYVOICE", "v2_167_0204405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あぁ……そうだ……私はもうこのオチンポの虜なんだ……オマンコだけじゃ\nなく、お尻でも……もう完全に服従してしまった……」", "NORMAL" ]},
