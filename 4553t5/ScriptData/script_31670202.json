		{"command":[ "PLAYVOICE", "v2_167_0204407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んあぁ……終わったみたいだな。はぁ……ちゃんと私のお尻で精液を拭って\n欲しい……んっ、あぁ……御札は駄目だ。剥がれては困るからな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0204408" ]},
		{"command":[ "SETIMAGE", "0", "still_00016702_02_13" ]},
		{"command":[ "WAITINPUT" ]},

