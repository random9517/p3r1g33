		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016702_02_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はっ……あぁぁぁぁぁぁ……流れ込んでる……お尻ぃ、熱いの……どぷどぷ\nされてるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0204302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はぁぁ……イクッ……またお尻イクぅっ、ケツマンコ中出しでっ……アナル\nアクメするぅぅぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0204303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あぁっ……そんな、出したまま、まだズリュズリュされてぇ……四つん這い\nで征服される感じ……あぁ……気持ちいい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0204304" ]},
		{"command":[ "SETIMAGE", "0", "still_00016702_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「そ、そうだ……私はマゾなのかも知れない……主殿のオチンポに完全屈服\nした……いやらしい巫女の女騎士なんだぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0204305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あっ、ふっ……んんっ、射精……落ち着いてきた……あぁ、でも、まだ……\nしっかり繋がったままでいて欲しい……主殿のオチンポを感じていたい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0204306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んあぁ……動かないでいても、すごく気持ちいい……本当に病みつきにさせ\nられてしまったんだな……私のアナルは躾けられてしまった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0204307" ]},
		{"command":[ "SETIMAGE", "0", "still_00016702_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あふぁ……あぁ、お尻……まだちゃんと閉じきらない……垂れて来るぅ……\nはぁ、あぁ……すごい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0204309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あぁ、こんな風に仕込まれて……主殿……また、してくれるよな……？　\n私をメロメロにした責任……取ってもらわないと……な」", "NORMAL" ]},
