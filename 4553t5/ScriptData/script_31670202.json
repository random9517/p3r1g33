{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0045" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「済まないな……主殿……わざわざ来てもらって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0204101" ]},
		{"command":[ "SETCHARA", "0", "char_00016702_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「その、今日は主殿に開発してもらった……集大成のようなものなのだな……\nちゃんと言われた通りにしているから……よろしくお願いする……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0204102" ]},
		{"command":[ "SETCHARA", "0", "char_00016702_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あぁ、まずは見てもらわないといけないな……ま、待っていてくれ……んっ\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0204103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「これで……見えるだろうか？　あぁ……ちゃんと、オ、オマンコはガードし\nている状態だ……前貼りが……お守りのようになっているからな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0204104" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00016702_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「今日は、その代わりと言ってはなんだが……後ろの、お、お尻の穴で……\n私を開発して欲しい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0204105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あぁ、アナル……け、ケツの穴……お尻マンコを攻めて欲しい……んっ、\nこうして……広げて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0204106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「み、見えているだろうか……あぁ……こんなにお尻を広げて……一番隠して\nおくべき、恥ずかしい穴を晒している……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0204107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「そ、そうだな……最初は、多少ほぐしてもらえると……んぁっ！　た、助か\nる……はっ、ひぅっ、んんっ、んくぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0204108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あっ、おっ、お尻ぃっ……はぁっ、指が入ってきてるっ……あぅっ、あぉっ\n、くんっ、んくぅんっ、は、ふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0204109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あぁ……指……二本目ぇ……あっ、あぁぁ……まだ、オチンポより全然太く\nないのにぃ……ゾクゾクッ、するぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0204110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はんっ、ゆっくり少しずつ馴染ませてぇ……穴が、ちゃんと開くように……\n念入りに準備してぇ……あ、あぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0204111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んっ、く、喰い締める練習……？　分かった……指をキュって締め付ければ\nいいんだな……？　あっ、んくんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0204112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「どう、だろうか……ちゃんと括約筋が働いているといいんだが……あっ、\nいい具合……本当か……よかった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0204113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んふっ、もっとしっかりほぐして欲しい……えっ、これは……ひんっ……ん\nんっ、つ、冷たい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0204114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「ロ、ローション……あぁ、そうだな……確かに、これがあれば、より滑りや\nすくなって……んっ、アナルも受け入れやすくなる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0204115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「ということは……あっ、あぁっ、はっ、あはんっ、指が……ズボズボされて\nっ、あぉっ……おぉっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0204116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あひっ！　か、感じるっ……お尻の穴が……どんどん敏感になっていくっ、\nおぉっ……指で擦られるのっ、くぅんっ、い、いいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0204117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はひっ、あぁっ、お尻がっ、ぐちゅってっ！　ローションが……かき混ぜら\nれてっ、あひっ、イッ……ひぃぃぃんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0204118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁっ、んっ……今ので、もう……軽くお尻……あっ、イキかけた\n……かも知れない……んくぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0204119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「もっと、んっ、お尻に塗り込んで……あぁ、今度は……直接オチンポで躾け\nて欲しい……あぁ……私のケツの穴……お、犯してぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0204120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「そ、そう……そこっ、入り口の所っ……あっ、あぁっ……入って……んっ、\n来るぅぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0204121" ]},
		{"command":[ "SETIMAGE", "0", "still_00016702_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あっ、おぉぉぉっ……も、もう少し押し込んで……めり込んだら、一気に\n行くからぁ……あっ、はぁぁぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0204122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あぁぁ……は、入った……あぁ……オチンポッ……お尻にズッポリハマった\nぁ……あっ、ふぅぅぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0204123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「お、思っていた以上に、大きさを感じる……んむっ、中が広がって……あぁ\n……オチンポ……キツい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0204124" ]},
		{"command":[ "SETIMAGE", "0", "still_00016702_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はぁっ、んっ……んふうっ……いや、苦しさはそこまででもない……んくぅ\n、ちゃんと……受け入れられている感じはする……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0204125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「だが、大事なのはここからだからな……主殿のオチンポを、しっかりと悦ば\nせなくてはならない……どうか遠慮なく突いて欲しい……そのまま、お、ほっ\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0204126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あぉっ、おっ、おぅんっ！　め、めり込んで来るっ！　オチンポがっ、ズボ\nズボッ……お尻を抉って来るっ、くぉぉぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0204127" ]},
		{"command":[ "SETIMAGE", "0", "still_00016702_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あっ、はぁぁっ、アナルセックスしゅごいっ……くひぃっ、わ、私は……\nこうなると思っていた……？　ど、どういう意味なのだっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0204128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「巫女と……女騎士はっ……アナルが弱いのが定番っ……？　そ、そんなこと\nを言われてもっ、な、何のことだかっ、あぉぉぉんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0204129" ]},
		{"command":[ "SETIMAGE", "0", "still_00016702_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あっ、あぁっ、けどっ、あぁっ、認めるしかっ……ないっ、あぁっ、主殿の\nオチンポが……肛門を広げてっ、ズリズリ擦れてぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0204130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「その度にっ、力が抜けてっ……はぁんっ、声が出るっ……あひっ！　ムズ\nムズするっ、あっ、あぉぉんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0204131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「そうっ、んくぅっ……あぁっ、そんな……オマンコよりも感じるなんてぇっ\n、はひっ、あぁっ、オチンポが抜ける瞬間が堪らないっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0204132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あんっ、はんっ、あはぁんっ、肛門がめくれるっ、グリグリ擦れるっ！　\n逞しいオチンポ気持ちいいっ！　ケツッ、ケツ穴が燃えるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0204133" ]},
		{"command":[ "SETIMAGE", "0", "still_00016702_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「ひっ、くひぃっ！　オチンポッもうすぐっ！？　それならっ、このまま中に\n出して欲しいっ！　そ、そうっ、ケツっ……ケツマンコにぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0204134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「ぽっかり開いたっ……いやらしい穴に、どぷどぷ精液出してっ……あぁっ、\n私のアナルっ……躾けてぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0204135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「おぉぉっ、出てるっ……！　ケツ穴っ……ドプドプっ、射精されてるぅっ…\n…！　くっ……おぉぉぉぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0204136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016702_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はぁぁぁぁんっ……熱いの、流れ込んでぇ……イクッ、はぁぉっ、ケツで\nイクっ！　アナルアクメするぅぅぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0204137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んっ、あぁぁ……はぁっ……あふっ……あぁ、オチンポ……射精……落ち\n着いた……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0204138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……はぁ……んっ、あぁ、私もやっと落ち着いて来た……あふ…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0204139" ]},
		{"command":[ "SETIMAGE", "0", "still_00016702_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あぁ……これは、病みつきになりそうな感覚だ……アナルせっくしゅ……\n気持ちいいのだな……んふぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0204140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んぁっ……！　あ、主殿っ……あぁっ、ま、またっ……あっ、オチンポが\n元気にっ……は、ひっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0204201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「こ、このままっ……あっ、続けてっ？　はひっ、あぁっ、けどっ……今は\nお尻が敏感でっ……くひぃっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0204202" ]},
		{"command":[ "SETIMAGE", "0", "still_00016702_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あぉぉぉっ……今度はゆっくり……すると、い、言われてもぉ……あぁっ、\nオチンポが……太くてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0204203" ]},
		{"command":[ "SETIMAGE", "0", "still_00016702_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あぁっ、ずりゅって……抜けていく時の感じが……あっ、出てしまいそうで\nっ……恥ずかしいっ……あっ、あぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0204204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はんっ、あんっ……あぁんっ、こんなっ、あっ、私が……あっ、ここまで…\n…アナルがっ、あひっ、弱い、なんてぇっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0204205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あぉっ、カリがめり込むっ！　そこぉっ、オチンポグリってされるとこぉっ\n、いいっ、んひぃっ、オチンポがいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0204206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あぁっ、はぁんっ、あぁっ、あっという間に躾けられてるっ、お尻がっ……\n第二のオマンコになってっ、主殿のモノになってるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0204207" ]},
		{"command":[ "SETIMAGE", "0", "still_00016702_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「いいっ、アナルマンコいいっ！　あぁっ、ズコズコオチンポハメられてっ、\nひぃんっ、ダメっ……またイクっ、アナルイクぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0204208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んぁぁっ……はぁぁっ、あっ、ふっ……あぁ……またイッた……主殿のオチ\nンポ……すごすぎるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0204209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んぅっ！　あぁっ……分かっている……まだ、主殿は満足していないからな\n……しっかり満足するまで私のケツマンコを使ってくれ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0204210" ]},
		{"command":[ "SETIMAGE", "0", "still_00016702_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あぉぉっ！　あぁっ、深いっ……串刺しにされて……あぁ、身体に全く力が\n入らない……んぅっ、駄目だ……ちゃんとオチンポを締め付けないとぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0204211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んふぅっ、ふぐっ……あぁ……恥ずかしい……四つん這いで、必死にお尻の\n穴をヒクヒクさせて……主殿に見せつけてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0204212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「でも、あぁ……嬉しい……尻穴まで捧げて……主殿にお尽くし出来るなん\nてぇ……はんっ、あっ、あぁんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0204213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「オチンポがヒクヒクしてるのが分かる……あぁっ、主殿の鼻息が背中をくす\nぐってるっ……興奮してくれているんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0204214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「私もっ、はぁっ、ゾクゾクしているっ……前貼りがマン汁で剥がれてしまわ\nないか……心配なくらい濡れて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0204215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あぁっ、もどかしい……けどっ、お尻がいいからぁっ……はぁんっ、何度で\nもっ……あっ、ズボズボしてぇっ、あひぃんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0204216" ]},
		{"command":[ "SETIMAGE", "0", "still_00016702_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はんっ、あっ、あぁっ……私も揺らすっ、はしたなくお尻を振ってっ……\n主殿のオチンポを満足させるぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0204217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あぁっ、気持ちいいのがまた上がってきてるっ、またケツマンコイキそうに\nなってるっ、あ、主殿はっ？　も、もうすぐっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0204218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はぁっ、今度は一緒がいいっ……主殿のオチンポと一緒にイキたいっ、好き\nなように出していいからぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0204219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「お尻の中でもっ……掛けてもっ、どっちでもいいからっ、あぁっ、また熱い\nのっ……射精して欲しいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0204220" ]},
