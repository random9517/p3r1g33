		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あぁっ、掛かってるっ……お尻に熱いのっ……ビュクビュクっ……出てるぅ\nっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0204402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あひぁっ、私もまたイクッ！　お尻っ……イクッ！　熱いザーメンぶっ掛け\nられてぇっ、はひぃんっ、イクぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0204403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あぁっ……オチンポが直接お尻に当たってぇ……あぁ、そのまま擦り付けて\nぇ……ひゃふぅ……ヌルヌルが……んっ、気持ちいい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0204404" ]},
		{"command":[ "SETIMAGE", "0", "still_00016702_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
