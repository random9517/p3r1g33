{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「隊長、こんな所に連れ込んで、どうしたんですか？　なにをするつもりなん\nですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1303101" ]},
		{"command":[ "SETCHARA", "0", "char_00000813_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「ふふ、なーんて、分かってますよ。さっきからずっと、股間がぱんぱんにな\nってるの、分かってますから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1303102" ]},
		{"command":[ "SETCHARA", "0", "char_00000813_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「それで急かすように部屋に連れ込むんですから、本当にスケベですよね隊長\n。でも、そんな所も可愛いんですけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1303103" ]},
		{"command":[ "SETCHARA", "0", "char_00000813_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「それじゃあ、そこに座ってください。エッチでスケベな隊長のために、私が\nご奉仕してあげますから……ね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1303104" ]},
		{"command":[ "SETCHARA", "0", "char_00000813_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETIMAGE", "0", "still_00000813_01_01" ]},
		{"command":[ "SETTEXT", "「まずは、エッチな隊長のスケベなおちんちんを……すごい、もうギンギンじ\nゃないですか。ずっと想像してたんですか、私とのえっち……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1303105" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「そんなに何回も頷かなくても分かりますってば……ふふ、でも嬉しい。私の\nこと、こんなに好きだって言ってくれてるんですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1303106" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「触ってもないのにこんなに震えて……見てるだけで熱が伝わってきそう。ふ\nふ、それじゃあ……れろっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1303107" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「んっ、いつもの隊長のおちんちん……硬くて熱くて……匂いも凄くて、れる\nっ、れろっ、んふっ、びくびくしてきてる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1303108" ]},
		{"command":[ "SETIMAGE", "0", "still_00000813_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「ふふっ、隊長、こうやって裏筋舐められるの好きですよね。こうして、んっ\n、れるっ、れろっ、ほら、今すっごく気持ちよさそうな顔してます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1303109" ]},
		{"command":[ "SETIMAGE", "0", "still_00000813_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「こんなに大きくて、硬くて……これでいっつも私にエッチなことして……ん\nっ、でも今日は私が責める番ですからね。れるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1303110" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「んっ、んむっ、れるっ、れろっ……ふうっ、大きすぎて、口の中に入れるの\nも一苦労ですね、んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1303111" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「こうして裏筋を舐めながら唇で吸いついたら……ふふっ、腰がびくびく動い\nてますよ。れるっ、ちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1303112" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ、凄い、熱くなってきてる……んっ、ふっ、私の舌も気持ちよく\nなって来ちゃった、んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1303113" ]},
		{"command":[ "SETIMAGE", "0", "still_00000813_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「れるっ、ちゅっ……え？　舐めてるだけで気持ちよくなるのかって？　なり\nますよ。好きな人にしてあげるときは、気持ちよくなります」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1303114" ]},
		{"command":[ "SETIMAGE", "0", "still_00000813_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「私、隊長のこと大好きですからね……あんっ、あっ、もう、そう言っただけ\nでまたおちんちんが硬くなってるじゃないですか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1303115" ]},
		{"command":[ "SETIMAGE", "0", "still_00000813_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「嬉しいんですか？　ふふっ、私も嬉しいですよ。相思相愛ってやつですから\nね。それじゃあ、また、んっ、むっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1303116" ]},
		{"command":[ "SETIMAGE", "0", "still_00000813_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「ふうっ、んっ、ちゅっ……おちんちん、先っぽからお汁が出てきましたね…\n…んっ、れるっ、れろっ、おいし……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1303117" ]},
		{"command":[ "SETIMAGE", "0", "still_00000813_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「んっ、こんなに大きくて逞しいのに、私の口でびくびくしてて可愛い……ん\nっ、ちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1303118" ]},
		{"command":[ "SETIMAGE", "0", "still_00000813_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「それじゃあ、もっとしてあげますね。んっ、んぐっ、ちゅっ、んぶっ……ふ\nうっ、ふっ、ああ、凄い……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1303119" ]},
		{"command":[ "SETIMAGE", "0", "still_00000813_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「なんだか、熱くて湯気が立ってるみたい……熱と唾液でどろどろになったお\nちんちん……見てるだけで身体が熱くなっちゃう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1303120" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「んっ、ふふっ、私の舌も熱くて気持ちいいって？　そういう権能ですからね\n……役に立ってよかった……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1303121" ]},
		{"command":[ "SETIMAGE", "0", "still_00000813_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「気に入ったのなら、もっとしてあげますね。ほら、こうしておちんちんの先\n端を舌で揉むみたいに舐めて……んっんっんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1303122" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「先端を尖らせて、亀頭の割れ目をなぞって……あはっ、隊長、本当に気持ち\nよさそう……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1303123" ]},
		{"command":[ "SETIMAGE", "0", "still_00000813_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「吸いつきながら舐めて……んんっ、隊長、腰動かしちゃダメですよ、舌がず\nれちゃう、あんっ、ダメですってば」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1303124" ]},
		{"command":[ "SETIMAGE", "0", "still_00000813_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「もう、悪いおちんちんですね。そんなのは、こうして捕まえながら吸っちゃ\nいます、んっ、ちゅっ、ちゅうっ、れるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1303125" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「ふふ、これで気持ちいいの全部、おちんちんに行っちゃいますね。隊長の顔\n、すっごく気持ちよさそう……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1303126" ]},
		{"command":[ "SETIMAGE", "0", "still_00000813_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「先っぽからもだらだらお汁がこぼれて……んっ、唾液と混じって、竿がぬる\nぬるになってますよ、ふうっ、れるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1303127" ]},
		{"command":[ "SETIMAGE", "0", "still_00000813_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「そんなおちんちんを口の中でこねこねしたら……あはっ、またびくってなり\nましたね、好きですよね隊長、これ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1303128" ]},
		{"command":[ "SETIMAGE", "0", "still_00000813_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「それでこうやって吸いつきながら口を動かしたら、んっ、むっ、ちゅっ、れ\nるっ、れろっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1303129" ]},
		{"command":[ "SETIMAGE", "0", "still_00000813_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「ふうっ、もうそろそろ限界ですね。隊長のおちんちんなら、誰よりも分かっ\nてますから、んむっ、うっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1303130" ]},
		{"command":[ "SETIMAGE", "0", "still_00000813_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「じゃあ私もスパートかけますね、熱い口と舌でぴったりと密着して、んっん\nっんっ、んむうっ、ふっ、ちゅっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1303131" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「あっ、おちんちんびくびくしてきた。出すんですね。いいですよ。いっぱい\n出して、私の口に、いっぱい出して……んっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1303132" ]},
		{"command":[ "SETIMAGE", "0", "still_00000813_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「あっ、来たっ、おちんちんから精液来たっ、んっ、んんっ、んむううううう\nううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1303133" ]},
		{"command":[ "SETIMAGE", "0", "still_00000813_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「んんっ、んっ、んぐうううっ！！　凄い、濃い……んっ、んくっ、んっ、ん\nんんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1303134" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「ふうっ、ふっ、勢いも凄いし、粘っこいし……んっ、まだ口の中に……飲み\nこむのに時間が……んっ、んぐっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1303135" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「はっ、あっ……相変わらず、凄いですね……でもそれだけ気持ちよかったっ\nてことですし……ふふ、私としては嬉しいかな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1303136" ]},
		{"command":[ "SETIMAGE", "0", "still_00000813_01_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「あんっ、今の言葉でまたちょっと……隊長、素直すぎますよ。勿体ないから\n舐めちゃいますね、れるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1303137" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「んっ……んくっ、ふうっ、ごちそうさまでした……こんな風に言われるの、\n男の人は好きなんでしょう？　何かで見ましたよ、あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1303138" ]},
		{"command":[ "SETIMAGE", "0", "still_00000813_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「ふふ、口よりもおちんちんが反応してますね。出したばっかりなのに、まだ\n硬いし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1303139" ]},
		{"command":[ "SETIMAGE", "0", "still_00000813_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「隊長の顔も、気持ちよかったけどまだまだって表情ですよ。私は構いません\nけど、もう一回……します？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1303140" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「あんっ、またおちんちんで返事してる。もう、気持ちいいのは分かりますけ\nど、そればかりじゃ私も怒りますよ……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1303201" ]},
		{"command":[ "SETIMAGE", "0", "still_00000813_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「でも、まずはこの怒りん坊のおちんちんを綺麗にしますね……れるっ、れろ\nっ、ちゅっ、んむっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1303202" ]},
		{"command":[ "SETIMAGE", "0", "still_00000813_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「相変わらず、一回出したのにもっと硬くなって……普通の男の人はそうじゃ\nないって聞きましたよ。隊長だけって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1303203" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「まあ、私としては自分がもっと求められてるって自覚ができて嬉しいですけ\nど……んっ、ちゅうっ、れるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1303204" ]},
		{"command":[ "SETIMAGE", "0", "still_00000813_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「ふうっ、一回出したからさっきよりももっと熱くなってる……え？　私の口\nと舌のせいでもあるって？　うふふっ、そうかもですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1303205" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「太陽の力で私の体温は普通よりも高いですからね……だからこうして咥えて\n舌を巻き付けるようにしたら……んむっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1303206" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「んっ、んぶっ、んうううっ、ふうっ。ふふっ、精液と先走りが混じったのが\nとろとろって出てきましたよ……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1303207" ]},
		{"command":[ "SETIMAGE", "0", "still_00000813_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「んんっ、んっ、腰も動いて……ふうううっ、うっ、まだ、まだダメですよ。\nじゃあ口じゃなくて舌だけで……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1303208" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「れるっ、れろっ……精液で汚れてるところ、綺麗にしないといけませんしね\n……んっ、れろっ、ふふっ、びくびくしてる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1303209" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「れろろっ、れるっ……ほら、全部舐め取りましたよ……んっ、あっ、その顔\nがエロいって……もう、隊長はそればっかりですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1303210" ]},
		{"command":[ "SETIMAGE", "0", "still_00000813_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「でもお気に入りなら、何回もしてあげますよ、こうやって、れるっ……ふふ\nっ、舌が動くたびに視線が向いているのが分かります……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1303211" ]},
		{"command":[ "SETIMAGE", "0", "still_00000813_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「んっ、隊長の味が舌に広がって……ふうっ、ふっ、隊長のだから美味しいっ\nて思えるんでしょうね、これ。ちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1303212" ]},
		{"command":[ "SETIMAGE", "0", "still_00000813_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「隊長なら、なんだってしてあげるって思えますし、何を求められても応えら\nれるって思いますし……これが好きってことですよね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1303213" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「ふふ、いつも隊長のことを思うと胸の中が熱くなりますし、こうやっておち\nんちんへの奉仕も文字通り熱が入りますしね。れるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1303214" ]},
		{"command":[ "SETIMAGE", "0", "still_00000813_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「あんっ、またびくびくしてきましたよ？　さっき出したばかりなのに、二回\n目の射精したいんですね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1303215" ]},
		{"command":[ "SETIMAGE", "0", "still_00000813_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「でももうちょっと、もうちょっと我慢してください。私も隊長のおちんちん\n、もう少し味わいたいですから、もうちょっとだけ……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1303216" ]},
		{"command":[ "SETIMAGE", "0", "still_00000813_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「んっ、んんっ、んむっ、れるっ、ちゅっ……ふうっ、ふふ、隊長が我慢して\nくれてるの、分かりますよ。私のために……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1303217" ]},
		{"command":[ "SETIMAGE", "0", "still_00000813_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「本当はすぐにでも出したいのに、そういう所も好き……だからこうして愛し\nてあげたくなる、んっ、んむうっ、ふうっ、ふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1303218" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「ああ、おちんちんの根元に精液が集まってきてるの、分かります。熱が溜ま\nってきてる、隊長の気持ちいい熱が……んむっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1303219" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「それじゃあ、二回目、また私にいっぱい出してください。隊長の気持ちいい\nの、いっぱい出してくださいっ！！　んんんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1303220" ]},
		{"command":[ "SETIMAGE", "0", "still_00000813_01_07" ]},
		{"command":[ "WAITINPUT" ]},
				
		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「んぐうううううっ！！　んっ、ふうっ、んんっ！！　二回目なのに、さっき\nよりも濃くて多い……んっ、んぐうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1303301" ]},
		{"command":[ "SETIMAGE", "0", "still_00000813_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「ふうっ、ふっ、んくっ、んっ、んっんっんっ、んむっ……ふはぁっ、はっ、\n精液で溺れるかと思いました……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1303302" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「でも、気持ちよくなってくれたしるしですからね……口の中に出されたのは\n全部飲みこみましたよ、んっ、喉に絡まって……んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1303303" ]},
		{"command":[ "SETIMAGE", "0", "still_00000813_01_11" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「んぐっ……本当に濃くて……匂いも凄くて……喉からお腹まで、全部隊長に\n染められた感じがします……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1303304" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「私の体温と、隊長の熱が入り交じって……ふふっ、飲まされただけなのに、\n子供ができちゃいそう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1303305" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「ふうっ……終わったはずなのに、頭がぼーっと熱を持ってる感じ……んっ、\n目の前にこんな立派なおちんちんがあるからですね。あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1303306" ]},
		{"command":[ "SETIMAGE", "0", "still_00000813_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「口も舌も、喉もお腹も、目も全部隊長のものになっちゃってます……好きだ\nから、こんな風になるんでしょうね、きっと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1303307" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「ふふ、好きな人とこうして愛しあえるのってとても素敵なことですよね。私\nと隊長、世界で二人きりの時間って感じがします」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1303308" ]},
		{"command":[ "SETIMAGE", "0", "still_00000813_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「でも、そうですね。飲ませてくれるのもいいけど、お腹の中に出してもらう\nのも私は幸せですね……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1303309" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「だから今度は、下の方に……ね？　私、あなたとの子供、欲しいな。いいで\nしょう、隊長」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1303310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "FADEIN", "NORMAL" ]},	
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「あんっ、あっ、おちんちんが口の中から……あっ、ああっ、んんんっ、ふあ\nあああああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1303401" ]},
		{"command":[ "SETIMAGE", "0", "still_00000813_01_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「ひああああっ、顔中に隊長のが、んっ、んんっ、ふうううっ、うっ、あっ、\nんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1303402" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「凄い、粘っこくて、濃くて、匂いも……ふうううっ、鼻の中に射精されたみ\nたい……んっ、ふううっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1303403" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「あんっ！！　まだでてる……熱い……んっ、ふうっ、あっ、ああっ、んっ、\nんんぐっ、んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1303404" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「やっと終わった……もう、好き勝手にかけて、私じゃなかったら怒ってるか\nもしれませんよ。女の人は大切に扱わなきゃいけないんですからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1303405" ]},
		{"command":[ "SETIMAGE", "0", "still_00000813_01_14" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「ま、まあ、私なら顔でも胸でもお腹でも、もちろん中でも好きな所に出して\nもらっていいですけど？　私は隊長のことが好きですからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1303406" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「んっ、それにしても凄い量ですね……そんなに気持ちよかったんですね。顔\nを見れば分かりますよ。満足そうな顔をしてますから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1303407" ]},
		{"command":[ "SETIMAGE", "0", "still_00000813_01_13" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「そんな顔を見たら私も嬉しくなっちゃいます……え？　またしてほしいです\nって。もちろんいいですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1303408" ]},
		{"command":[ "SETIMAGE", "0", "still_00000813_01_14" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「隊長が求めるなら、今すぐにだって。三回目も、四回目も、いつまでも付き\n合いますよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1303409" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「もっともっと、いっぱい愛しあいましょうね隊長。できれば、ずっと一緒に\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1303410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}