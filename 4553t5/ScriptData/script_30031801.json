{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「余を呼びつけて、一体何をしようというつもりじゃ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1803101" ]},
		{"command":[ "SETCHARA", "0", "char_00000318_01", "4", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ほう……ヴァルキリーの身体が疼くだろうから、お主が鎮めてやろうと、そ\nう申すか。なるほど、なるほど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1803102" ]},
		{"command":[ "SETCHARA", "0", "char_00000318_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「それは、随分と気が利く話じゃが……お主に言われるまでもなく、余もそう\nしようと思っていたところじゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1803103" ]},
		{"command":[ "SETCHARA", "0", "char_00000318_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「つまり、余の好きにしていいということじゃな？　ならば、しっかりと主従\n関係を刷り込んでやらなくてはのう……つまり、こういうことじゃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1803104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「くくっ……いい眺めじゃな。やはり、男は上から見下ろすのが一番よい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1803105" ]},
		{"command":[ "SETIMAGE", "0", "still_00000318_01_02" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「どれ……図々しく期待していたチ〇ポはどんな状態じゃ？　ふんっ……くく\nっ、足で踏まれることを期待しておったろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1803106" ]},
		{"command":[ "SETIMAGE", "0", "still_00000318_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「その証拠に……こうして踏みつけてやれば……ほうら見ろ……どんどんチ〇\nポが膨らんで行くではないか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1803107" ]},
		{"command":[ "SETIMAGE", "0", "still_00000318_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「チ〇ポの皮が剥けたところを……こうして、指で掴んでやろう……どうだ、\n痛いか？　それとも……こんなものも気持ちいいのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1803108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ほほぅ……チ〇ポが、更に勃起して来たな……これは、余が考えていた以上\nにお主はマゾの気がありそうじゃな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1803109" ]},
		{"command":[ "SETIMAGE", "0", "still_00000318_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「そうであるならば、余も遠慮することもあるまい。もっともっと、このチ〇\nポを踏みつけてやろう。んっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1803110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「くくっ、流石にこれ位に力を込めると痛みがあるか。まあ、ただ痛いだけで\nはお主もつまらんだろう……ならば、これはどうじゃ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1803111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ふふ……今度はぐんと力を弱めて……触れるかどうかの微妙なくすぐり加減\nでチ〇ポを弄ってやる。ほぉら、この辺はどうじゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1803112" ]},
		{"command":[ "SETIMAGE", "0", "still_00000318_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「くくっ……まるで磁石のようにチ〇ポが余の足に吸い付いてくるではないか\n。もっとして欲しいと訴えておるかのようじゃな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1803113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「そんなに急かして、さっさと漏らしたら余の楽しみが薄れるじゃろう？　も\nっとじっくりと余裕を持って余の足コキを楽しむがいい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1803114" ]},
		{"command":[ "SETIMAGE", "0", "still_00000318_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「とてもそんな余裕はない？　ふふん、泣き言を聞くつもりはないぞ？　お主\nは、みっともないよがり声を上げる為にここにおるのじゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1803115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「無論、悪いようにはせぬ。お主を射精に導いてやる為に、様々な手管を使っ\nてやるからのう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1803116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「例えば……このチ〇ポの下……キンタマの方をぎゅっと足の指で掴み取る。\nふふ……腰が浮いてしまうじゃろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1803117" ]},
		{"command":[ "SETIMAGE", "0", "still_00000318_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「もう少し体重を乗せて……踏み潰すかどうかのところまで押し込む……ほれ\nほれ、これが好きなのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1803118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「くくっ、歯を食いしばって耐えておるな。じゃが、そんな中でもしっかりと\n視線は余のおっぱいを見ているな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1803119" ]},
		{"command":[ "SETIMAGE", "0", "still_00000318_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「まさか、そんなあからさまな視線で気づいていないとでも思ったか？　別に\n、存分に見て構わぬ。構わぬが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1803120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「余に対して、見ていないなどと、たばかったことは見逃す訳にはいかぬなぁ\n？　その仕置きは受けてもらわんとな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1803121" ]},
		{"command":[ "SETIMAGE", "0", "still_00000318_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「そら……またキンタマが押し潰されていくぞ……？　ダメじゃ、逃さぬ。余\nの足の感触を、全体で感じるがよい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1803122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ぐぐっとめり込ませて……もう少し体重を乗せてやるか？　くくっ……せっ\nかくの子種を作る場所……壊してしまうつもりはない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1803123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「おっと……またチ〇ポが勢いよく跳ねておるな。キンタマを責められて、し\nっかりと気持ちよくなっているという訳か」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1803124" ]},
		{"command":[ "SETIMAGE", "0", "still_00000318_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「となれば、続けてチ〇ポの方もしてやらんとな。ふふ……足の裏で、こうも\n興奮するとは……とんだ変態もいたものじゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1803125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「どうじゃ、気持ちいいか？　チ〇ポが気持ちいいですと言ってみろ。ほれほ\nれ、どうなのじゃ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1803126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「くくっ、そうか。チ〇ポが気持ちよくて仕方ないか。お主は、足でチ〇ポを\n踏まれて感じる変態だと認めるんじゃな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1803127" ]},
		{"command":[ "SETIMAGE", "0", "still_00000318_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「素直なやつには、ちゃんと褒美をやらんとな。マゾのお主にふさわしい、足\nコキ責めじゃ……ふっ、んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1803128" ]},
		{"command":[ "SETIMAGE", "0", "still_00000318_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「特にどの辺が気持ちいい？　右か？　左か？　根元か……それとも先端か？\n　くくっ、皆まで言わずともよいぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1803129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「なにせ、チ〇ポが正直に答えてくれる。またビクビクさせて……この変態め\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1803130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「さあ、どうして欲しい。このままチ〇ポを踏み潰してイカせて欲しいのか？\n　それとも、もう少し優しくして欲しいのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1803131" ]},
		{"command":[ "SETIMAGE", "0", "still_00000318_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「……！　くくっ、もう少しなら強くても……それはそれは。お主の好色ぶり\nも、大概じゃな……いいとも、叶えてやろうではないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1803132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ほぉれ……またチ〇ポを指で捏ねてやる。この震えるチ〇ポ……そろそろ、\n限界が近い筈じゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1803133" ]},
		{"command":[ "SETIMAGE", "0", "still_00000318_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「後は余に見せるがいい。このまま無様な格好で、みっともなく射精する姿を\n晒してみせよ。さあ……思い切り……イケっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1803134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「くくっ！　そうじゃ……これこそ、余の見たかった噴水よ。おうおう、派手\nに出しておるではないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1803135" ]},
		{"command":[ "SETIMAGE", "0", "still_00000318_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ビクビクチ〇ポを震わせて……こんなにも欲望を溜め込んでおったか。ふふ\n、遠慮せずにもっと出すがいい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1803136" ]},
		{"command":[ "SETIMAGE", "0", "still_00000318_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「あぁ……余の足先も、粘汁まみれにされていくねぇ……にちゃりとして……\nくくっ、随分と臭いモノを付けてくれるじゃないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1803137" ]},
		{"command":[ "SETIMAGE", "0", "still_00000318_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「それにしても、まだ止まらないのかい？　あぁ、やっと終わりか。全く、足\nでされているだけで、こんなに射精するなんてね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1803138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「さて、このドロドロをどうしてくれようか。お主自身に舐め取らせてやるか\nい？　くく……まあ、それは勘弁してやろうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1803139" ]},
		{"command":[ "SETIMAGE", "0", "still_00000318_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ふふ……余に逆らえないことが分かっただろう？　これからは、お主の忠誠\nをよく見極めさせてもらうからね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1803140" ]},
		{"command":[ "SETIMAGE", "0", "still_00000318_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「どれ……少し竿が萎んだようじゃな？　これで一息……そんな風に思ってい\nるところか？　ふんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1803201" ]},
		{"command":[ "SETIMAGE", "0", "still_00000318_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「くくっ、痴れ者め。お主の射精を一度見た位で、余が満足するとでも思った\nか？　まだまだ、奥に残しておるじゃろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1803202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「そうとも、余はもっとお主の悶える姿が見たい。分かったら、さっさとまた\nチ〇ポを硬くさせるんじゃな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1803203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ほれ……ほれ、くくっ、実に正直なチ〇ポじゃ。軽く踏んでやるだけで、あ\nっという間に力を取り戻したか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1803204" ]},
		{"command":[ "SETIMAGE", "0", "still_00000318_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「自分の出したザーメンで滑りやすくさせて、快感を増幅させるとは、どこま\nでもスキモノな奴よ。キンタマはどうじゃ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1803205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「くく……たっぷり出したから、慌てて次の分を作っているというところか？\n　足の指で揉まれて喜んでおるではないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1803206" ]},
		{"command":[ "SETIMAGE", "0", "still_00000318_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ほぉれ……また力が入るぞ？　己の弱点を支配されて、どうすることもでき\nなくなった気分はどうじゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1803207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「余に二度と逆らう気など起きぬか？　くく、ならば命令してやろうか。勿論\n、余への忠誠を見せるじゃろうなぁ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1803208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ほれ、もっと足を無様に開け。男として他の者には見せられぬ姿を、余の前\nでみっともなく晒すがいい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1803209" ]},
		{"command":[ "SETIMAGE", "0", "still_00000318_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「そうじゃ……くくっ、チ〇ポだけがしっかり上を向いて……身体は地べたを\n這いつくばって……いい眺めよのう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1803210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「この無防備なチ〇ポ……余の足で、もっとコキ倒してやろう。縦横無尽に振\nり回して……軽く爪も食い込ませる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1803211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ふふ……本当にお主の反応は余を楽しませてくれる。散々呻きを上げながら\n、しっかりチ〇ポは余の責めを享受しようとしているからのう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1803212" ]},
		{"command":[ "SETIMAGE", "0", "still_00000318_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ほぉら、また食い込んでいくぞ？　もっと腹に力を込めてチ〇ポで受け止め\nろ。このまま激しく扱いてやるからのう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1803213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「おぅおぅ、クチュクチュといい音をさせるではないか。さっき出した精液に\n……ふむ、これはまた新しい汁が滲み出しているのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1803214" ]},
		{"command":[ "SETIMAGE", "0", "still_00000318_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「全く堪え性のない男よ。もう次の射精がしたくて堪らないということか。じ\nゃが、まだ早いぞ。もう少し、いい声を聞かせてもらわんとな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1803215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ふふ……腰をビクビクさせて……足の指が食い込むのが大好きなんじゃな。\n浮き上がった血管がいよいよ破裂しそうじゃな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1803216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「よかろう、射精させて下さいとねだるがよい。みっともなく、余に媚びるこ\nとができれば、とどめを刺してやる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1803217" ]},
		{"command":[ "SETIMAGE", "0", "still_00000318_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「くくっ、そうかそうか。そんなに踏み潰されて射精したいということか。良\nかろう、後は余に無様なイキ様を晒すがよい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1803218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「そぉら、またチ〇ポを踏み潰すぞ？　グリグリとかき回して……震える亀頭\nを押し潰す……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1803219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「さあ、出すがいい。またみっともなく果てる姿を余に晒すのじゃっ、ふんっ\n……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1803220" ]},
		{"command":[ "SETIMAGE", "0", "still_00000318_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「おおっ……！　また出てきたな……あれだけ遠慮なく出した割には、変わら\nずビュクビュクと漏らしよるわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1803301" ]},
		{"command":[ "SETIMAGE", "0", "still_00000318_01_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ねっとりと生ぬるい汁が絡みついてくるわ……ふふ、足元がニチャリとして\n……独特の感触よのう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1803302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ほぉれ、今度は一滴も残すでないぞ？　今、キンタマで作ったばかりの分ま\nで余すところなく出し切ってしまうがいい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1803303" ]},
		{"command":[ "SETIMAGE", "0", "still_00000318_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「もっと踏んでほしいか？　くくっ、遠慮はいらぬ。浅ましい最後の噴水を見\nせるがいい……ほぉれっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1803304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ふむ……流石に、弱々しい噴水で終わりか。まぁ、これだけ出せたなら、と\nりあえずはよしとしておくかのう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1803305" ]},
		{"command":[ "SETIMAGE", "0", "still_00000318_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ふふ……足先が精液でべっとりじゃ。広がるにおいも堪らんな……生汁の新\n鮮さが醸し出されておる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1803306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「いやはや、余の疼きをどのように満たしてくれるかと思ったが、実にいい姿\nを見せてくれたな。満足したぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1803307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「余の身体の疼き？　ふむ……そうじゃな、まあなくもないが、その時は余の\n気が乗った時にお主に手伝ってもらうとしよう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1803308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ほう……今の言葉だけで、またチ〇ポがピクリと震えたな。くく……つくづ\nく好色な奴よのう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1803309" ]},
		{"command":[ "SETIMAGE", "0", "still_00000318_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「せいぜい期待しておくがいい。その時には、余が存分にお主のことを可愛が\nってやるからな……くく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1803310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んむっ……！　こいつはまた、二発目だというのに随分と勢いよく出すでは\nないか……余の身体にまで届かせるとはな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1803401" ]},
		{"command":[ "SETIMAGE", "0", "still_00000318_01_16" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「粘り気も申し分なし……こやつめ、まだこんなにも汁を溜め込んでおったと\nは、つくづく油断も隙もない男よ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1803402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「せっかくじゃ……全部出してしまうがいい。中途半端に残しておったら……\n許さんぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1803403" ]},
		{"command":[ "SETIMAGE", "0", "still_00000318_01_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ほれ、まだ奥に残している分があるじゃろう。思い切り踏んでやるから、出\nし切ってしまえっ……ふんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1803404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「くく……出てきたな。流石に勢いも弱いが……やはり奥に隠しておったとい\nうことじゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1803405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「どれ……ちゅぷ、んむ……まずまずの味わいよ。このコクは、お主でなけれ\nば出ないものかもしれんな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1803406" ]},
		{"command":[ "SETIMAGE", "0", "still_00000318_01_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「うむ、お主のたっぷりの痴態を見ることができて、なかなか退屈せずにいら\nれたぞ。褒めてやろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1803407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「うん……？　余の身体の疼き？　ふむ……まぁ、それはまた気が向いた時に\n、お主の身体で鎮めてもらうとするか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1803408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ふふ……なんじゃ、今から待ちきれないという風じゃな。全く、あれだけの\n恥を晒しながら、まだまだ欲望塗れということか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1803409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「よかろう、せいぜい期待しておくがいい。その時には、余が存分にお主のこ\nとを可愛がってやるからな……くく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1803410" ]},
		{"command":[ "SETIMAGE", "0", "still_00000318_01_15" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}