{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「ククク、悪魔筆頭騎士である我が、お前の願いを叶えてやろう。なあに、た\nだのきまぐれだ。だが、我が認めたお前なら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0103101" ]},
		{"command":[ "SETCHARA", "0", "char_00025801_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「こんな貴重な機会を無駄にするとは思えない。さあ、何を望む？　欲しいも\nのがあるのならくれてやる。悪魔との契約だ、遠慮なく願いを言うといい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0103102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「……我のデカすぎるおっぱいでパイズリをして欲しい？　おっぱい……？　\nああ、この胸のことか。しかし、パイズリとはなんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0103103" ]},
		{"command":[ "SETCHARA", "0", "char_00025801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「我は座学が苦手でな、戦い以外のことには疎いのだ。まあ、いい。パイズリ\nについて教えてくれ。できることであればやってみようではないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0103104" ]},
		{"command":[ "SETCHARA", "0", "char_00025801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「んっ……。まずは胸を露出するのだな。ふぅ……、普段はこんなことはシャ\nワーを浴びる時にしかせんぞ。お前の前で脱ぐのは不思議な気分だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0103105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「お？　乳房をお前が手で掴むのか。なるほど。甘えているのか……いいぞ。\n胸くらい好きにさせてやる。好きなように触ればいい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0103106" ]},
		{"command":[ "SETCHARA", "0", "char_00025801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「って、んん！？　な、なぜ陰部を胸の谷間にねじりこんでくるのだ！？　お\nっ！？　あっ……に、人間の甘え方とはなんと斬新な……驚いたぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0103107" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00025801_01_02" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「うんうん。こうして、男の股間を女の胸の谷間に挿入するのがパイズリか。\n……少し違う？　チンポを大きな胸で挟んで動かすのがパイズリ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「……チンポ！　お、おぉ、チンポか……。人間は己の陰部をそんな名称で呼\nぶのだな。なんだか卑猥な言葉だ。チンポ……チンポ……う、うむ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「わかった。チンポを挟んで胸を動かす……やってみよう。ッん……、ふぅ…\n…。ん、ん、んん……んん……。な、なんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「微妙に上下に揺らすことはできるが……。チンポのでっぱりが胸にひっかか\nって、あまりうまく動かせないな。……んっ、んん、やはり無理だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0103111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「こ、こう、か……？　難しい……。っん……なんだかこれは違うよう、な。\nあまりにチンポが太すぎて、少し動かすだけで精一杯だが？　んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「……なに？　パイズリが上手くなる薬がある？　乳首から潤滑油がわりに母\n乳を分泌する薬、ボニューデマクール？　それを飲めばパイズリできるのか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「なら飲むぞ。ああ、今手が離せないからお前が飲ませてくれ。……ぱくっ。\nごく……ごくん。うむ。出ろ、母乳出ろ……。お？　お、お、お、お？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0103114" ]},
		{"command":[ "SETIMAGE", "0", "still_00025801_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「うあっ！　ほ、本当に出てきた……！　おおおっ♪　な、なんだか妙な感覚\nだ。胸の先から、乳首からぴゅる、ぴゅる、ぴゅるぴゅると……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0103115" ]},
		{"command":[ "SETIMAGE", "0", "still_00025801_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「おおぁ♪　こ……これをチンポに塗りたくって、胸を動かす。揺らす……。\nっん！？　な、なんだかいい感じだぞ。ヌルヌルしてひっかからない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「は、ぁ……っ♪　はぁ、はぁっ、ん、ふ……ふぅっ、ふぅううっ♪　おぉお\nお……♪　これがパイズリ……、あっ、我にもできたぞ、どうだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「し、しかしパイズリが上達して嬉しいが、……んん？　なんだか身体中が熱\nくてたまらない。は、ぁ……汗をかいている、それに……んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「胸がむずがゆくてたまらん！　あっ♪　こうしてチンポを挟んで揺らすと、\n胸全てが……そして母乳を出している乳首が燃えているようにうずく」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0103119" ]},
		{"command":[ "SETIMAGE", "0", "still_00025801_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「あ、あぁ、乳首が勃起して……。気持ち良くなってきた、パイズリしながら\n母乳出すの、く、クセになりそう、だ、やめられない、なんだこれは？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「んん……！　んふ……っ、んん……！　ああ……！　チンポ、チンポをぎゅ\nーっと強く挟んで、胸を寄せると快感が強く、なるう……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「これがパイズリ……！　はぁ、はぁ、我は発情しているのか？　っあうっ♪\n　絞り取るような動きをせよと？　い、いいだろう。こうか……あっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「お前のチンポをパイズリしているこの状態を、おっぱいマンコと言うのか。\nほう……♪　お前は物知りだな。おっぱいマンコ……おっぱいマンコ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「ククク♪　確かに、しっくりくる響きだ。ほら。我のおっぱいマンコは気持\nち良いか？　我は……！　はうっ♪　おっぱいマンコして気持ちいいぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「んぁああっ♪　ふぁああっ♪　おっぱいマンコ、と発音するだけで顔が火照\nる……ゾクゾクする、もっと言いたい。おっぱいマンコ、おっぱいマンコ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0103125" ]},
		{"command":[ "SETIMAGE", "0", "still_00025801_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「はぁっあぁっ♪　初めて知ったぞ、戦い以外にこんなに気分が高揚して……\nんふぅうっ♪　楽しくなれることがあるなんて！　おっぱいマンコぉおっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「胸を激しく動かせば動かす、ほど、我も快感を得てのぼりつめていくっ……\n！　お前もっ、我もっ、パイズリで同時によろこんでいるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「すごいっ……！　あぁあっ、パイズリ、おっぱいマンコはすごい、すごいぃ\nい……！　お前がして欲しがるのも当然だ、したいに決まっているっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「あっ、あっあっ！　乳肉の圧力を高める？　いいぞ、もっとキツく絞るんだ\nなっ！　んぁああっ、だ、だめだ、我の方が限界だ……！　ああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「んああああああっ♪　うううっ♪　イッてしまったぁああ……♪　強敵を一\n撃で斬り捨てる時のような気持ち良さだ、ああ、もっと、もっとしたいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「パイズリすると母乳が溢れるっ、母乳が出るとチンポがニュルニュルになっ\nてっ、ニュルニュルでおっぱいマンコ気持ち良く、なって！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「と、止められない……！　あぁあっ♪　あぁっ、あああっ！　イクぅっ、す\nまないぃ、おっぱいマンコ中に勝手にイッてすまない！　あっあっあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「……え？　いいのか？　おっぱいマンコしながらイッて、それを見てお前も\nイク……？　な、なんだと？　男もイクのか？　チンポで？　ふぅうっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「知らなかった……男はチンポでイクのか。じゃあ見せてくれ。チンポ、チン\nポを力いっぱいこすって、絞って……イカせ、るぅっ！　んんんんぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「我もイクからお前もおっぱいマンコでチンポイカせてくれっ！　はやくっ、\nはやくぅっ！　イク……！　イクぅっ、おっぱいマンコイクぅううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0103135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「おっ！？　おおおおおっ！？　ふわっ！？　あっ！？　お前のチンポから母\n乳？　えっ！？　真っ白な液体が！？　これを精液と呼ぶのか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0103136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00025801_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「あああああああ……♪　精液、どこかで聞いたことがある。これが精液？　\nおっぱいマンコで精液出たのか！　嬉しい……嬉しいぞ、あぁっ、あっあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0103137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「我もチンポ精液でイクっ……！　んぉぁあああっ♪　イクぅうう……！　あ\nあああ、すごい、母乳の甘い匂いとは全然違う、くさいぃい……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「臭くて粘り気が強くて、胸にどんどん溜まっていく、肌に貼りつくぅ……♪\n　これがおっぱいマンコパイズリでチンポをイカせるということか……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「っああああ♪　もっとだ、もっと出せ……！　ッうぅううう♪　出た！　出\nたぁ……！　こんなにたくさん……！　ああ、精液、精液ぃい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「はーっ♪　はぁっ、はぁっ、はぁああっ……♪　お、おっぱいマンコにチン\nポ精液……出してイッてくれてありがとう。我もたっぷり果てた……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0103201" ]},
		{"command":[ "SETIMAGE", "0", "still_00025801_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「が、なんだ？　満足したはずなのに、この精液の感触……そしてこの温度に\nなおも発情してしまっている。な、なあ。これは我からの願いなのだが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「このまま……おっぱいマンコを続けてよいか？　ああ、もちろんまたチンポ\nが精液を出せるように努力する。我は努力はとても得意なのだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0103203" ]},
		{"command":[ "SETIMAGE", "0", "still_00025801_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「だから……だから！　パイズリ頑張るから、もう一度……んんっ、パイズリ\nさせてくれ……！　んんんっ、ほら、すごくうまくなっただろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0103204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「あっ♪　あっ、い、いいのか？　続けても……。んんぁあっ♪　嬉しいぞ、\n嬉しいぞ……！　あぁ、おっぱいマンコさせてもらえる！　っんんぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「お前には感謝しかないっ！　チンポ……ああああ、チンポすごいな。ずーっ\nと硬くて大きいままだ。そのまま……そのままだぞ、パイズリするぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0103206" ]},
		{"command":[ "SETIMAGE", "0", "still_00025801_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「おっぱいマンコっ……んんんっ♪　おおおお♪　精液と母乳とでさらにヌル\nッヌルで良い感じだ。すべる……なめらかにパイズリできる！　うっうぅ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「んあはぁあっ♪　ふぁっ、あぁ、ああ、ああ……！　幸せだ、だが、困った\nこともあるぞ……！　っあっ♪　胸が気持ち良すぎて……んんぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「パンッパンに腫れてきた……！　あうっ♪　我が感じると、母乳の量が増え\nるのか？　母乳がいっぱいに詰まって、く、苦しいくらいだ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「チンポで胸を刺激、して……どんどん出さなくては！　んぅううっ♪　んん\nんんっ♪　母乳出すっ、おっぱいマンコもっと白くするっ、濡らすぅうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0103210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「それ、でっ♪　乳首も胸も気持ち良くなりながらっ♪　チンポにおっぱいマ\nンコするっ！　はぁああああ♪　コレだ、そう、この感覚だぁあああ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「やみつきになるぅうう……！　こんなデカいだけの胸、戦うのにも邪魔だし\n何の意味があるかと悩んだこともある、だが、コレだったのだなっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0103212" ]},
		{"command":[ "SETIMAGE", "0", "still_00025801_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「我はお前のおっぱいマンコになるために♪　このデカブツをぶらさげて生き\nてきた！　我の胸はおっぱいマンコ専用だった、わかって良かったぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「せっかくおっぱいマンコのためにあるのだ、どんどん使うぞ！　はぁっ、は\nぁっ、気持ちいい……！　おっぱいマンコ気持ちいいッ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0103214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「お前も気持ちいいのだな、チンポが再び精液を吐き出しそうになっているぞ\n！　あっ♪　さっき覚えたのだ、お前がイク時にチンポが膨らむと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0103215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「クククッ、母乳がこれだけ出ていなければっ……！　デカすぎてまったくパ\nイズリできないところだった！　はぁっ、はぁ、太い、デカチンポ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0103216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「一度目は気付かなかったが、チンポはここまで熱くなって反り返るのだな…\n…♪　気に入ったぞ、さすが我専用のおっぱいマンコ用チンポだっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「悪魔筆頭騎士のっ♪　おっぱいマンコにふさわしいチンポ！　その素晴らし\nさをたたえ、ながら……！　我と共にまたイこうではないか、あっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0103218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「ククク、そうだ、一緒にイキたいのだ！　ほーら……！　ほらっ、もう限界\nだろうっ、我の胸の中でチンポが今にも暴発しそうだ！　いいぞぉおっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「我も……我もイクっ！　イクぞ、おっぱいマンコしながらぁ♪　母乳と精液\nまみれでイクからついてこいぃいっ！　ああああ、イクイクイクっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「んあああっ♪　きたっ、きたぞ、またチンポから精液がきたっ……！　あっ\n、ああああっ、おっぱいマンコイクっ♪　イク……ふぁあああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0103301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00025801_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「良かったなっ、同時にイけたぞ！　あぁっ♪　んああああっ♪　んんぅっ？\n　どうした！？　二度目の精液なのに量が多すぎるのではないか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「あっ！？　うぁああっ♪　我のおっぱいマンコがダラッダラになってしまう\nぅ……！　あふっ♪　んふぅっ♪　ふぅっ！　止まらぬ、止まらぬぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0103303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「お前の精液の強さで胸が弾む……！　ああああっ♪　こ、これが本気のチン\nポ精液か！　いいぞ、受けて立つ……全てこの胸に吐き出せぇえっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0103304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「ん～～～～～～～～～っ♪　す、ごい……！　チンポとおっぱいマンコから\n湯気がたちそうなくらい、激しい……！　んんぉっ、まだ出るのかっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0103305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「よしよしっ、たくさん出せ！　我もたくさんイ、ク……♪　ああああっ♪　\nおっぱいマンコにチンポ精液をぬりたくって……そうだ、そうだぁあ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0103306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「ん、ふ……♪　ふぅうううう……♪　ご、ご苦労だった……。これほどのチ\nンポ精液を出せば、身体中から水分が抜けてしまったに違いない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0103307" ]},
		{"command":[ "SETIMAGE", "0", "still_00025801_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「パイズリとは、おっぱいマンコとはとてつもない威力なのだな……。ククク\n、非常に気に入った。絶対に、この技を忘れぬと誓おうではないか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0103308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「ああ……。努力の成果が、すぐにチンポから精液として出るのはわかりやす\nくて良い。良かっただろう？　我の初めてのおっぱいマンコは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「我も、コレをまた次にする時が楽しみになってきた。必ず誘ってくれ。お前\nとならば、常に最高のおっぱいマンコができそうだ。精進するとしよう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「さあ我の胸に……！　って、んぉおっ！？　わぷっ！　んんんっ！？　胸で\nはなく顔にかかっているのだが！？　あぷっ！　んっ、んんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0103401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00025801_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「チンポ精液の勢いがすごすぎて、照準が外れたか……！？　あっ！？　く、\nくさい……！　熱い……っ、んっぷぷぷっ……！？　あぷっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「はぁあっ……♪　プリプリとした精液が我の顔に着弾して……♪　んっ、ん\nぷっ♪　口の中にまで飛び込んでくるぞ、なんという苦い味だ……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0103403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「胸の中からこの顔にまで届く精液……♪　あああ、ムワッとした悪臭と、べ\nったりとまとわりついてくる粘り気ぇ……んっんっ、もっと、もっとだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0103404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「もっとかけてくれぇ……っ♪　我の胸の中で作った精液を、我の顔にぶちま\nけるのだっ！　ああっ、ああああっ♪　垂れてくる……んぷぅうっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0103405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「ぷ、ぁ……♪　こんなに大量にかけるとは……驚いたぞ……。い、いや、嫌\nというわけではない。我から言い出したことだしな……んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0103406" ]},
		{"command":[ "SETIMAGE", "0", "still_00025801_01_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「お前の願いだったパイズリ……。おっぱいマンコには満足できたか？　まあ\n、これだけ出しまくっておいて否定できるはずもないが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0103407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「ククク、胸の中、我の顔、全てにお前の精液が付着していてすさまじい光景\nだぞ。……ん？　我の母乳もたくさんついている？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0103408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「そうだな、こんなに色んな体液でビチャビチャになったことなど無いぞ。は\nぁあっ……♪　お前はいつも、我の予想を遥かに上回る……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0103409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「だからこそ、面白くて目が離せぬのだが……♪　なあ、我がこれからもたく\nさん望みを叶えてやるから……我以外とは契約するなよ？　約束だ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0103410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}