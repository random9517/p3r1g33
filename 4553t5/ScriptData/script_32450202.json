{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0184" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「あれ……？　おにいちゃん……？　今夜はもうお仕事終わったの？　もしか\nして……わたしを待っててくれたの。かな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0204101" ]},
		{"command":[ "SETCHARA", "0", "char_00024502_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「これから？　何もないよ。お部屋に戻って寝るだけ……。今日はエスティマ\nおねえちゃんは、別の任務でいないから……一人」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0204102" ]},
		{"command":[ "SETCHARA", "0", "char_00024502_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「……え。おにいちゃんのお部屋に行って、いいの？　……うん。行く。一人\nで寝るの、さびしかったから……うれしい。えへへ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0204103" ]},
		{"command":[ "SETCHARA", "0", "char_00024502_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「……ん？　あ、あれ？　おにいちゃん……？　わたし、どうしてはだかんぼ\nにされてるの？　二人でくっついて寝るって言ってたのに……えっと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0204104" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00024502_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「ん、ぁ……なんで、だろ……。身体が熱い……。はぁ、はぁ……。ルナおね\nえちゃんとくっついててもこんな風にならないのに……どうして……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0204105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「おにいちゃんが、わたしを開発してきたから？　かいはつ……？　よくわか\nらないけど……。もじもじするのがやめられない……。ん、んん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0204106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「おっぱいを見られてると、ゾクゾクして……。お股のところがウズウズして\nくるの。服を着なくちゃいけないのに、着たくない……こうしてたい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0204107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「お、にいちゃんに……わたしの裸、見てほしい。さわってほしい。ねえ……\nいいよね？　わたしたち、今、ふたりっきりだよ……触って……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0204108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「っん……♪　そ、そう……顔……撫でて、頭も触って……はぁ、はぁ、ほっ\nぺたも、首も、肩も……。触っちゃいけないところなんて、ないよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0204109" ]},
		{"command":[ "SETIMAGE", "0", "still_00024502_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……おにいちゃんの手、おっきくて、あったかくて気持ちいい\n……。おっぱいも揉んでほしい……。んっ、そ、そう。やさしくして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0204110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「んぁ……♪　あ、ぁ、あ……頭がぼーっとする……おにいちゃんがムニムニ\nしてる胸、どんどん熱くなってきた……いいよ、もっと揉んで。……あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0204111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「あっぁっ……！　え？　お腹やお尻も触りたいの？　……う、うん。いいよ\n。ぜんぶ触って。……あっ……あっ♪　お、おまんこも……んんんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0204112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「わ、わたしのあそこ……。割れ目から、どんどんシロップが溢れてくる……\n。おにいちゃんの指でくちゅっ、くちゅってえっちな音たててるね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0204113" ]},
		{"command":[ "SETIMAGE", "0", "still_00024502_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「っうん……♪　気持ち、いいの……そこいじられるの、大好き……♪　わた\nし、えっちになっちゃったのかな。お股いじられるのすごく好き……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0204114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「……えへへ。おにいちゃんも、おちんちんすっごくおっきくなってるよ。…\n…どうしたの？　わたしのここに……おまんこにそれ、入れたいの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0204115" ]},
		{"command":[ "SETIMAGE", "0", "still_00024502_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「いいよ♪　わたしのここ……おにいちゃんにしか見せないし、触らせないし\n……んんっ、ここの穴、ちっちゃい穴におちんちん入れてもいいのは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0204116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「おにいちゃん、だけ……。はぁ、はぁ、わたしも早く入れてほしい……。お\nにいちゃぁん……ルナのおまんこに、おちんちん奥まで入れてぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0204117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「ん、あ……！　あっ……んんん……！？　あ、あれ……っ？　お、おにいち\nゃ……！　きょ、今日のおちんちん、すごく太くて……んんんっ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0204118" ]},
		{"command":[ "SETIMAGE", "0", "still_00024502_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「長い……っ！　あっ、ま、待って……！　い、入れてほしいってお願いした\nけど……あっ♪　お、おっきすぎて全部入らない、かも……んんっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0204119" ]},
		{"command":[ "SETIMAGE", "0", "still_00024502_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「うう……、ん、く……。おにいちゃん……くる、しい……。もう全部入った\n……？　う、うん。中……すごく濡れてるから痛くはない、けど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0204120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「もうこれ以上広がらないってところまで入口が広がってて……。はぁっ、あ\nっ……お腹の中がパンパンなの……。一番奥、押し上げられてるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0204121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「おにいちゃんから見てもわかる……？　わたしのお腹……ぽっこり膨らんじ\nゃってる。おにいちゃんのおちんちんの形、だよね……？　これ……うう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0204122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「んふ！？　だ、だめ……！　今、わたしのお腹……触っちゃだめ……！　う\nううっ……ミチミチに詰まってるの。すごく硬くて強いおちんちん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0204123" ]},
		{"command":[ "SETIMAGE", "0", "still_00024502_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「お尻が……あっ、か、身体が持ち上げられてるみたい……。ま、待って。動\nくのは本当に無理だよ……あっ、腰、揺らしちゃいや……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0204124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「あッ……！　んふぅうっ！　ヌブッ、ぬぶって出入りしてるぅ……！　あっ\n！　おまんこの粘膜はちゃんと拡がるからだいじょうぶ？　ほ、ほんと？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0204125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「あ、う……ううっ。ほ、ほんとだ……。ちょっと苦しいし、息がしにくいけ\nど……ゆっくり出し入れしてたら平気、かも……んっ。んん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0204126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「す、ごい……っ。あぁっ。わたし、の身体……おちんちんで串刺しになって\n、るぅ……。こんなおっきいの、本当はまだ入れちゃいけないんだよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0204127" ]},
		{"command":[ "SETIMAGE", "0", "still_00024502_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「わたし……あっ！　大人じゃないのに、おちんちん入れて欲しいって思った\nから……悪い子だから、えっちで、いやらしい子だから……あっんっんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0204128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「だか、ら……あぁ♪　こんなおっきい、長いおちんぽ受け止めきれないのか\nも……。……んん……！　ち、力を抜いてほしい？　こわいよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0204129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「リラックスしておちんちんを怖がらないように？　わ、わかった……おにい\nちゃんがそう言うなら……信じる。……すうう、はぁあ、すうう、はぁあ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0204130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「……ん！？　し、深呼吸して力をゆるめたら……。あっ！？　少し今っ……\nきもちいいのがのぼってきたかも……あっ！？　しゅ、しゅごい、何これっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0204131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「ふぁ……っ。あぅっ、んぁっ……はぁうう……！　わ、かる……っ。おにい\nちゃんのおちんちん、おまんこの中で動いているの、わかるの……ぉっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0204132" ]},
		{"command":[ "SETIMAGE", "0", "still_00024502_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「あぁああ……っ！　やだ、やだぁ……っ♪　わたしっ、全身まるごとおまん\nこになっちゃったみたい、おにいちゃんのおまんこになっちゃってるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0204133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「んぅうう……♪　ぅうう……っ！　く、るしいの、お腹くるしいの……！　\nでもやめてほしくないの、してて、ずっとしてて、おちんちんしてぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0204134" ]},
		{"command":[ "SETIMAGE", "0", "still_00024502_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「おちんちんのでっぱってるところっ、気持ちいいところにこすれるの……！\n　あっ、あっ、こんなにおっきなおちんちんおぼえちゃったら、だめだよぉ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0204135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「だめ、なのに……気持ちいい……！　あんっ、あん……あんんっ♪　おにい\n、ちゃん……おにいちゃんも気持ちいい？　わたしはすごくいい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0204136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「はぁっ、あぁ、このまま……このままちょうだい♪　おにいちゃんのえっち\nなお汁……せーし、せーし出して……だいじょうぶだから……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0204137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「んんん……！　おにい、ちゃぁんん……！　あぅうっ……！　出して……わ\nたしのお腹の中に出して……！　キツキツのおまんこをぬるぬるにしてぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0204138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「んぁあああああっ……♪　ふぁああああ、あぅっ、あうううう……！　で、\nてる……熱いのがびゅる……って、一番奥に出てる……ああああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0204139" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024502_02_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「たくさんお汁出して、おまんこを濡らしてほしい……！　あっ……♪　ドロ\nドロが、おまんこの中で暴れてる……んんっ、ま、まだ入るよね……っ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0204140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「ッぁあああああ……っ。はぁっ、はぁあああ……っ♪　おにいちゃんのお汁\nでいっぱい……♪　っんん……♪　またびゅるっびゅるって……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0204201" ]},
		{"command":[ "SETIMAGE", "0", "still_00024502_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「……おにいちゃんでお腹が、おまんこが満たされていくこの感覚……好き…\n…♪　あ、まだ抜いちゃだめだよ。今抜いたらもれちゃう……んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0204202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「このまま、おにーちゃんの精子のあったかさ、お腹の奥で感じてたい……。\nぽかぽかして、すごく気持ちいいの……って、あ、あれ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0204203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「おにいちゃん。どうしてまた、おちんちんが大きくなってきてるの……？　\nわたしがえっちな事を言うから？　そ、そんなこと言ったかな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0204204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「……ぁっ♪　う、動いちゃだめだよ……っ！　あぅっ、精子、あふれ、ちゃ\nうよぉ……！　あっ……あっ、うんっ、最初より苦しくないけど……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0204205" ]},
		{"command":[ "SETIMAGE", "0", "still_00024502_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「今度はおちんちんがニュルニュルしてて……あうっ、んんっ、んぅううっ…\n…！　こんなのだめっ、すぐに気持ち良くなっちゃう！　あっあっぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0204206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「んんんん～……！　おちんちん、ぬるぅっ、ぬるぬる～って出入りしてるぅ\n……！　あっ、あっ、だ、め……本当にだめぇ……！　んぁああ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0204207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「精子……外に漏れちゃうよぉ！　せっかくもらったのに、……あっ♪　ヌル\nヌルがかきだされちゃう……っ。んッぁっ、やだ……んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0204208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「……え？　お腹に力入れちゃダメ？　だ、だって……あああっ！　力をこめ\nて、ないと……精子が……あっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0204209" ]},
		{"command":[ "SETIMAGE", "0", "still_00024502_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「外に漏れちゃったらまた入れてやる？　ほ、ほんと？　漏らした分だけ中に\nびゅーって入れてくれるの？　はぁ、はぁ……だ、だったらいいよ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0204210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「わたしの中、真っ白な精子のついたおちんちんでたくさんニュルニュルして\n……♪　……あっ♪　ふぁああ♪　気持ちいい……気持ち、いい……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0204211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「んんんっ♪　奥ぅ……おちんちんでトントンノックして……♪　あぁっ……\nえっちな子でごめんな、さい……！　でもやめないで……ぇっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0204212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「ぐちゅぐちゅ、して……あっ♪　おにいちゃんの強いおちんちんでズプズプ\nしてっ……！　あっ♪　ぁっ、ああああっ……ふぁあああ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0204213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「きもち、いい……！　気持ちいい……っ！　好き……おにいちゃんのおちん\nちん、おっきくて気持ちいい！　あうっ、あうぅっ♪　もっとしてぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0204214" ]},
		{"command":[ "SETIMAGE", "0", "still_00024502_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「おにいちゃんはつらく、ない……？　あっ、あうっ、わたしの中……狭すぎ\nて窮屈じゃない？　あっ……気持ちいい？　よかったぁ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0204215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「おにいちゃんの精子とわたしのおまんこのおつゆ、い～っぱいまじりあって\nえっちな音、してるね……♪　身体中がトロトロになっていくみたい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0204216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「……ッあぁっ♪　お、にいちゃん♪　おちんちん強すぎるよぉ♪　あうっ！\n　くぅうっ♪　体全部っ、突き上げられてる……浮かんでるぅ……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0204217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「あっぁっ、興奮してくれてるの？　わたし、の身体きもちいい？　ぷにぷに\nで……軽くって、貧弱かもだけど……心は一番おにいちゃんを想ってるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0204218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「だから……あっ♪　赤ちゃんできちゃってもいい、からっ……もう一回精子\n出して……♪　わたし、おにいちゃんの精子好きなの、だいすきっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0204219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「ちょう、だい……♪　おにいちゃんのビュルビュル精子、欲しいよぉ……！\n　あっ♪　あっ……ルナに、ルナにご褒美くだひゃい……ぃっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0204220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「あっああああああ……ッ♪　おにいひゃんんっ……おにいひゃんんんっ……\n！　精子、精子来てるよ、わたしの中に届いてる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0204301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024502_02_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「おまんこの中に入りきらないくらい……あっあぁっ、あったかいの来てるっ\n……もっとちょうだいっ。ぜんぶ……ぜんぶわたしにちょうだいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0204302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「あ、あ～～～～～～っ……！　頭が、まっしろになってく……っ。気持ちい\nいのが上ってきて……あっ♪　チカチカするっ、ふぁあああ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0204303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「え？　これがイクってことなの……？　あぁっ、イッてるよ！　わたしっ、\nおにいちゃんの精子でイッてるっ……もっと、もっとくだひゃいぃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0204304" ]},
		{"command":[ "SETIMAGE", "0", "still_00024502_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「わたしのお腹っ……赤ちゃんできてるみたいにぽっこりさせて……！　でき\nてもいいからっ……わたしのこと、ママみたいにして……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0204305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「っうぅううう……♪　はぁ、はぁ、はぁ……びっくり、した……。一回目に\n出してもらった時より、二回目の方がずっと気持ち良くて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0204306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「わたしとおにいちゃん、二人ともがいっぱいいっぱい感じて、ドキドキして\nたから？　二人の体温が一つになって、えっちを楽しんだから？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0204307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「……初めは苦しくて、う～ってなっちゃったけど……。やっぱりおにいちゃ\nんがすることに間違いなんかないね。だって、すごく良かったもん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0204308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「ねえ。今夜は……このまま、一緒に寝てくれるよね……？　これだけたくさ\nんえっちして、すぐにバイバイとかやだよ……さみしいもん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0204309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「今夜だけは、わたしがおにいちゃんを独り占めするの。いいよね？　えへへ\n……えっちの後って離れたくなくなるね。それが、すごく心地いいの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0204310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「んっ！？　んんんんっ……ご、ごめんなひゃい……っ！　おちんちん、おま\nんこから抜けちゃった……あっ！？　んぁあっ、うううう……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0204401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024502_02_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「わ、わたしのあそこじゃおにいちゃんの大きなおちんちん、受け止められな\nかったのかな……！？　ち、違うの！？　おにいちゃんが抜いたの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0204402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「きゃっ……！　んんっ！？　精子が……精子がどんどん身体にぶつかってく\nる……。あっ♪　かけたかったの？　それなら良かった……。んっあぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0204403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「あったかいの、わたしの裸にびゅくびゅくかかってるよ……♪　重たくて、\n真っ白で……。うぅううっ……♪　おにいちゃんのにおい……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0204404" ]},
		{"command":[ "SETIMAGE", "0", "still_00024502_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「あっ……♪　こうやって何度も精液かけられちゃったら……。あっ♪　かけ\nてもらうの好きになっちゃうよ……普通じゃ満足できなくなっちゃう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0204405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「だって……これ、ヌルヌルがシャワーみたいで……身体のぜんぶ、つつみこ\nまれているみたい……。えっちなにおい、ぶわって広がって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0204406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「んっあぁ……♪　わたしの身体……おにいちゃんの白い精子で染めてもらっ\nちゃった……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0204407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「添い寝してくれるって約束したのに、こうやってわたしに精子をかけて……\nおにいちゃんはえっちだね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0204408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「でも……そうされて、喜んじゃってるわたしもわたしだよね……♪　なんで\n、精子をかけられてこんなに嬉しいんだろ……？　はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0204409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「おにいちゃんが気持ち良くなってくれた証だからかなぁ……。えへへ、おに\nいちゃんにはいつも教えてもらってばっかりだ……♪」", "NORMAL" ]},
