{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「ええっと……何か御用でござるっすか？　隊長氏……拙者は、走り込んだり\n、こっそり忍んだりで、色々忙しいでござるよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0203101" ]},
		{"command":[ "SETCHARA", "0", "char_00014802_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「はぁ？　忍術パワー向上の術……？　本当でござるっすか？　んー……そん\nな都合のいい術があるのでござるっすか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0203102" ]},
		{"command":[ "SETCHARA", "0", "char_00014802_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「な～～んだか騙されてるような気がするでござるっすなぁ……拙者はおりこ\nうだからピーンと来たでござるっすよ！　ニンニン」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0203103" ]},
		{"command":[ "SETCHARA", "0", "char_00014802_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「……無理して忍者っぽく振る舞わなくていい……？　は、ははははっ、何を\n言ってるでござるっす？　拙者は別に……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0203104" ]},
		{"command":[ "SETCHARA", "0", "char_00014802_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「で？　忍術パワー向上の術とやら、始めましょうっす！　ニンニン…………\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0203105" ]},
		{"command":[ "SETCHARA", "0", "char_00014802_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「へ……？　胸を使って……お、おお、オチンチンを気持ちよくさせる……？\n　なななな何言ってるっすか！　……じゃなくて、ござるっすか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0203106" ]},
		{"command":[ "SETCHARA", "0", "char_00014802_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「拙者、軽々しく、そんなことをする女性ではござらんっすよ……ってか、そ\nれ、パイズリ……でござるっすよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0203107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「それって、パイオツカイデーな人がすることなんじゃ……？　ウチ……いえ\n、拙者では、胸のサイズが足りないのでは……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0203108" ]},
		{"command":[ "SETCHARA", "0", "char_00014802_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「ええ？　とりあえずやってみろ……？　うう……わかったでござるっす……\n上手くできなくても、文句いいっこなしでござるっすよ～～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0203109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「せぇの……ん、んんん……はぁ………………こ、これでいいでござるっすか\n……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0203110" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014802_01_01" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「ひうぅぅ……恥ずかしいでござるっす……でも、こんなことで、忍術がすご\nいことになったりするでござるっすか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0203111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「い、いえ、文句なんて別に……拙者は、下忍……言われたことをもくもくと\nやるだけでござるっす……ん、ふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0203112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「はぁ……おちんちんが、ウチの胸にぃ～～～……あうぅ、こんなこと、させ\nられるだなんてぇ……はぁ、はぁ……あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0203113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「え？　語尾？　あ、失敬でござるっす……拙者まだまだ未熟者ゆえ、何卒ご\n容赦を……でござるっす。ニンニン」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0203114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「ん。ふぅ……あああ、おちんちんが、生暖かいでござるっす……それに、く\nんくん……おしっこの匂いがするでござるっす……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0203115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「けど……んふふ、隊長氏……気持ちよさそうにしてるでござる……えへへ、\nちょっと嬉しいでござるっすね……にんにん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0203116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「あはぁ、谷間でビクンビクンしてるでござるっす……え？　ああ、ここ、一\n応谷間なんっす……ええ、マジでござるっす」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0203117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「え？　柔らかくて、気持ちいい……？　それマジで言ってるでござるっすか\n？　いやぁ……初めて言われたでござるっす……嬉しいっす……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0203118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「そんなこと言われたら、はぁ、ふぅ……もっと気持ちよくなってもらいたく\nなるでござるっす……はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0203119" ]},
		{"command":[ "SETIMAGE", "0", "still_00014802_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「いかがでござるっすか？　はぁ……ふう……パイズリっていうか、胸板ズリ\nって感じにしかならないでござるっすけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0203120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「こ、このまま発射されると……あうぅ、拙者……どろどろにされちゃうでご\nざるっすね……うわぁ……どうしよう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0203121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「い、イヤじゃないっす……ちょっと嬉しいでござるっす。拙者の、真っ平ら\nなおっぱいが、殿方の役に立つことがあるだなんて……ふぅ、ふふふ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0203122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「はぁ……ふぅ……あぁあん……乳首が大きくなってるでござるっす……胸が\n小さいから、乳首が目立って、恥ずかしいでござるっす……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0203123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「あ、ああ……はぁ、あぁああん……動くの、結構難しいでござるっす……で\nも、ん、ふぅッ……頑張るっすよ……これも修行でござるっすから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0203124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「ん、んぁぁ、はぁ……あふぅ……あああ、隊長氏の体温が、じんわり入って\nくるっすぅ……はぁ、ふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0203125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「ん、ふぅ……人肌って、気持ちいいものでござるっすね……はぁ、あふぅ…\n…おちんちんが、ちょっと好きになって来たでござるっす」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0203126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「あぁ、はぁ……先っちょから、ネバネバした液体が溢れ出して来たでござる\n……これって、我慢汁でござるっすよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0203127" ]},
		{"command":[ "SETIMAGE", "0", "still_00014802_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「あはぁ……拙者のおっぱいで、気持ちよくなってくれてるだなんて……はあ\nぁん、テンションあがるでござるっす～～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0203128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「ん、ふぅ……この調子で、どんどん気持ちよくなってもらうでござるっす…\n…ん、ん、はぁ……あふぅ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0203129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「あぁん、ネバネバがいっぱい溢れてる……もうすぐ、射精でござるっすか？\n　はぁ……はぁ……ふぅ……んんん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0203130" ]},
		{"command":[ "SETIMAGE", "0", "still_00014802_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「わ、わかったでござるっ……これから、全力で気持ちよく、するでござるっ\nすっ！　はぁ、はぁ……ふぅ……速く動くことは得意中の得意っすから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0203131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……行くでござるっすよ～……ニンニン……忍法影走りおっぱい\nだけバージョンっ！！　はぁ……はぁ……んん、はぁぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0203132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、はぁ……おはぁ……おちんちんが、ビクビク、してる……おっ\nぱいに、気持ちいいのが流れ込んでくるみたい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0203133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……んん、んんん～～～……ああ、すごい、大きく膨らんでる\n……あああ、精液が……根本からこみ上げて、くる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0203134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「だ、出してェ……ウチに、熱いの、いっぱいぶちまけてぇ……はぁ、はぁ…\n…んん、あぁぁぁああん！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0203135" ]},
		{"command":[ "SETIMAGE", "0", "still_00014802_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「んひゃああうぅぅ……！　せーえき、すごぉぉい……ひやぁ、きゃうぅぅ…\n…こんなにいっぱぁい……んふぅ、あはぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0203136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014802_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「きゃうぅ……熱いぃ……はぁ、はぁ……肌の中に、染み込んでくる、みたい\nぃ……あはぁ、すごいっす……マジ、気持ちいいっす……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0203137" ]},
		{"command":[ "SETIMAGE", "0", "still_00014802_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「はへぇぇ……ああう、この匂い……このトロトロした感じぃ……はぁ、はぁ\n……頭がバカになるみたいっす……ただでさえバカなのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0203138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「ふ～～……ヤバいっすね……今、くのいちなの、忘れてたでござるっすよ…\n…はー……ふぅ……ああ、頭がぼーっとするぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0203139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「これで、お仕舞いでござるっすか……？　はぁ……はぁ……そうでござるっ\nすか……それじゃ拙者はこの辺で……しからばゴメン──」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0203140" ]},
		{"command":[ "SETIMAGE", "0", "still_00014802_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「へ？　ま、まだするでござるっすか？　そういうことは、早めに言って欲し\nかったでござるっす……お別れキメ言葉、言っちゃったでござるっすよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0203201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「ま、まあ……全然いいんでござるっすけどね……うわぁ、カッチカチでござ\nるっすね……はぁ……精液でドロドロなのも、超いい感じでござるっす」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0203202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「あはぁ……胸が、ジンジンするでござるっす……はぁ、精液のトロトロした\n感じが絡み合って……ん、んん……気持ちいいでござるっす」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0203203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「はぁ……んん、隊長氏の下腹部で、乳首が擦れて、ん、んん、はぁ……力が\n抜けてしまいそうなほど、感じちゃうでござるっす……はへぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0203204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……あはぁ、隊長氏より先に、ウチが……いや、拙者がイッち\nゃいそうでござるっすぅ……ん、ん、はぁ……ひうぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0203205" ]},
		{"command":[ "SETIMAGE", "0", "still_00014802_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「ん、んぁぁ、はぁ、あはぁぁ……精液の匂いぃ……ん、はぁ……肌に染み付\nいてしまいそう……はぁ、ふぅ……んんん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0203206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「あぁあん、またビクンビクンしてる……はぁ、ふぅ……気持ちいいでござる\nっすか？　隊長氏……ん、ふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0203207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「そ、そうでござるっすか……いやぁ、面と向かってそう言われると、なかな\nか恥ずかしいものでござるっすなぁ……えへへへ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0203208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「きゃうぅ、あはぁ……精液が肌を滴ってくる……お腹までビチャビチャ……\nああ……身体中が精液で汚されていく……はぁ、ゾクゾクしちゃうぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0203209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「ん、はぁ、あふぅ……こんなに小さなおっぱいで恥ずかしかったでござるっ\nす……でも、喜んでくれて、本当に幸せでござるっすぅ……んんぅん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0203210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「あはぁ……おちんちんが、ゴリゴリしてる……胸の骨が折れてしまいそうで\nござるっす……うう、胸の肉、薄すぎでツラいっすぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0203211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「ん、ふぅぅ……おちんちん、すごぉい……ああ、おちんちんに負けちゃいそ\nうでござるっすぅ……ん、あぁ、はぁ……はぁぁああん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0203212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「ふぅ……あはぁ、精液が空気に溶け込んで、鼻の中に流れ込んでくるぅ……\nはー……はへぇえ……頭が変に、なっちゃうよぉぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0203213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「ウチ、もう……駄目ぇ……あ、ああ、はぁ、はぁ……はぁぁあああん……せ\nーえき、恋しいよぉ……出したて、いっぱいぶちまけてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0203214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「んんぁ、はぁ……はぁ、はへぇぇぇ……乳首が擦れて、気持ちいい……精液\nがヌルヌルして……ん、はぁ……どんどん、気持ちよく、なっちゃうぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0203215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「あぁぁん……ウチ、ヤバいっす……はぁ、はぁ……あぁん、そんなに見ない\nで下さいっすぅ……ん、んん、くぅ……ひゃうぅん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0203216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「今、ウチ、エロい顔してるっす……わかってるっすぅ……はぁ、はぁ……ん\nっ、あぁぁあん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0203217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「あああん、おちんちん、もっと固く、大きくなってる……あ、ああん、ウチ\nの胸に収まらないっすぅ～～……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0203218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「きゃうう……んはぁ……はぁ、はぁ……おちんちん、震えてる……精液が、\n根本からこみ上げてくる……ん、ん、あはぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0203219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「出してぇ……ウチにいっぱい、ぶちまけてぇぇ……はぁ、はぁ……んくぅ、\nあはぁぁぁぁあん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0203220" ]},
		{"command":[ "SETIMAGE", "0", "still_00014802_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、ああぁぁっ……はぁぁぁぁああん……！　精液、出てる……あ\nはぁ、ぶちまけられてるぅ……ああぁ、すごぉい……どんどん、出てるっすぅ\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0203301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014802_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「はー……はぁああん……こんなに、たっぷり……あぁ、駄目……肌の上に、\nまとわりついてくるぅ……ん、んん、はぁ……あはぁぁぁん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0203302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「肌から妊娠しちゃいそう……はぁ、はぁ……あああ、じんわり温かい……精\n子が、毛穴から染み込んでくるみたい……ん、ふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0203303" ]},
		{"command":[ "SETIMAGE", "0", "still_00014802_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「はぁああん、まだ出てる……ビュクビュク溢れてる……ん、はぁ……精液が\nぶつかってくる……気持ち、いい……はぁ、はぁ……きゃうぅん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0203304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「ひうぅ……はぁ……はぁぁあん……身体が、精液で溶けちゃいそう……ん、\nふぅ……ほんとに、頭が変になっちゃいそう、です……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0203305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「はー……はぁ、やっと止まったぁ……はぁ、はぁ……ふぅ……ふえぇ？　途\n中から、くのいちじゃなくなってた……？　あわわ、しまった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0203306" ]},
		{"command":[ "SETIMAGE", "0", "still_00014802_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「ひええ……す、すみません隊長氏ぃ……。うっかりしてたでござるっす……\nふぅ……ふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0203307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「でも、おっぱいでするの、楽しすぎて……えへへへ、精液ってすごいでござ\nるっすねぇ……はぁぁ……まだ、匂いがこんなにぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0203308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「はぁ……下忍として、隊長氏の元に来てよかったでござるっす……はぁ……\nはぁ……あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0203309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「よかったら、また呼んで下さいでござるっす……できれば次はもっとエッチ\nなことを……えへへ、それじゃ今度こそ、しからば御免！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0203310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「んんぅ！？　んっ、んぶっ、んぐぅ……んっ、んんぅ、ん～～～んんん……\nゴク……ゴクゴク……んぐぅ、はへぇぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0203401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014802_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「あぁ、まだ出てる……んぁむ、んんぅっ、ちゅるる……ずずず……ゴクン…\n…あふぅ……すごぉい……こんなにいっぱい出せるんすねぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0203402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「はぁぁ……んん、んはぁ……顔いっぱいに精液、感じちゃうぅ……んん、鼻\nの中に、入っちゃったぁ……んずるるる……ゴクン……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0203403" ]},
		{"command":[ "SETIMAGE", "0", "still_00014802_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……鼻の穴から、精子が入ってくる……脳の中で受精しちゃいそ\nうっすぅ……はぁ……ふぅ……ウチ、もうおかしくなっちゃうそう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0203404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「あぁん、まだ出るっすかぁ……んんぅ、ゴク……ゴクン……はぁ……はぁ…\n…あはぁ……お腹いっぱいになりそうっすぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0203405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「あふぅぅ……うう、なんか喉に張り付いてる……んん、はぁ……ああ、ゆっ\nくり滴ってる……あぁあん、気持ちいい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0203406" ]},
		{"command":[ "SETIMAGE", "0", "still_00014802_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「はー……精液、気持ちいいっすねぇ……へ？　あ、ヤベ……くのいち設定、\n忘れてたでござるっす……へへへ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0203407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「ってか、おっぱいでするのって、結構楽しかったでござるっすねぇ……拙者\n、おっぱいちっさいから、こういうこと、諦めてたでござるっす……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0203408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「でも、えへへ……ヤレばなんとかなるもんでござるっすね～……はぁ……楽\nしかったぁ～～……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0203409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「ふぅ、それじゃ、隊長氏……またこういうことしましょ。いつでもお呼び下\nさいでござるっす……それじゃ今度こそ、しからば御免！」", "NORMAL" ]},
