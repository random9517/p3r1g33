{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0132" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "一方、ワームホールに突入したルナテミスたちと宇宙海賊は……。", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ワームホールを抜けたぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090114560001" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「やったか！　みんな、見ろ！　あそこにあるのが時間城だ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_129_010114560001" ]},
		{"command":[ "SETCHARA", "0", "char_00012901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "宇宙海賊Ｂ" ]},
		{"command":[ "SETTEXT", "「キャプテン！　ホログラム通信っす！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「来たかい……まあ、仕方ないね。つなぎな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_129_010114560002" ]},
		{"command":[ "SETCHARA", "0", "char_00012901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "フィルが指示すると、艦橋内に何者かのホログラムが投影される。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「へえ、狙いは時間城だったか。いっちょ噛みしたかいがあったな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_010114560001" ]},
		{"command":[ "SETCHARA", "0", "char_00022901_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「やっぱりスケバンサンダーかい……時間城にたどり着いたのはいいが、面倒\nなヤツに借りをつくっちまったなあ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_129_010114560003" ]},
		{"command":[ "SETCHARA", "0", "char_00012901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「スケバンサンダー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010114560001" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「デコトラ戦艦で戦場に現れては、その場を荒らすだけ荒らして去っていく、\n宇宙のトラブルメーカー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_136_010114560001" ]},
		{"command":[ "SETCHARA", "0", "char_00013601_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「つまりアタシら海賊ですら持て余す、最悪の乱暴者ってヤツさ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_129_010114560004" ]},
		{"command":[ "SETCHARA", "0", "char_00012901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「おいおい、ご挨拶じゃねえか。人を利用しといてよ。まあ、利用はお互い様\nだがな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_010114560002" ]},
		{"command":[ "SETCHARA", "0", "char_00022901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「どういうことだい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_129_010114560005" ]},
		{"command":[ "SETCHARA", "0", "char_00012901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「時間城はオレも狙ってたってことさ。でっけえ儲けの匂いがするからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_010114560003" ]},
		{"command":[ "SETCHARA", "0", "char_00022901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「こっから先は、恨みっこなしの早いもん勝ちだぜ。どんなものでも、先に分\n捕ったほうの取り分だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_010114560004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「もし邪魔しやがったら、オメーらもぶっとばす！　んじゃ、そういうことで\n！　夜露死苦！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_010114560005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そう告げると、スケバンサンダーのホログラムは消えた。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「はいはい、っと……まあ、あっちはあっちで好きにやらせとくさ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_129_010114560006" ]},
		{"command":[ "SETCHARA", "0", "char_00012901_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「って、ちょっと待っとくれ！　おしゃべりしてる間に、ずいぶん時間城に接\n近しちまってるようだが！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010114560001" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「そうだけど？　それがどうした？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_129_010114560007" ]},
		{"command":[ "SETCHARA", "0", "char_00012901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「『どうした』って……このままじゃぶつかる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010114560002" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「大丈夫。これも海賊戦法の一種」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_136_010114560002" ]},
		{"command":[ "SETCHARA", "0", "char_00012901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「海賊戦法の一種って……まさか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010114560001" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "sbg_0169" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「つっこむぞつかまれ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_129_010114560008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「やっぱりーっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010114560002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「さすがに無茶だよーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010114560001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「はははははははっ！　無茶をするのが宇宙海賊だーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_129_010114560009" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}