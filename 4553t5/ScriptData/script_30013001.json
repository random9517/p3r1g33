		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ここが部屋か……やはり、どこか独特な雰囲気だな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3003101" ]},
		{"command":[ "SETCHARA", "0", "char_00000130_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「バ、バカ者っ！　別に緊張などしていないっ。ちょっと物珍しいと思っただ\nけだっ、分かったな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3003102" ]},
		{"command":[ "SETCHARA", "0", "char_00000130_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ふん……分かればいいのだ。と言うか……貴様こそ、少し緊張しているので\nはないか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3003103" ]},
		{"command":[ "SETCHARA", "0", "char_00000130_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「何となく身体が震えているではないか。ま、まぁ……確かに、今日は一段と\n冷え込んでいるから、多少は仕方ないがな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3003104" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そ、そうだ。空調の効きを気にするよりも、もっといい方法があるだろう…\n…つ、つまり……身体を密着させて温めあうことだっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3003105" ]},
		{"command":[ "SETCHARA", "0", "char_00000130_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ……そうだ……私に回りくどい手段はいらんっ。こうして身体を密着さ\nせれば……ほ、ほら……あったかいだろう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3003106" ]},
		{"command":[ "SETIMAGE", "0", "still_00000130_01_01" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……それにしても何だ、このチンポは……いきなりこんなにガチ\nガチにさせて……よほど期待していたのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3003107" ]},
		{"command":[ "SETIMAGE", "0", "still_00000130_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「いいだろう……私のおっぱいでしっかりと包み込んでやる……んっ、あぁ…\n…あったかい……いや、熱い位だ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3003108" ]},
		{"command":[ "SETIMAGE", "0", "still_00000130_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「凄いな……とくんとくんと……心臓の鼓動と一緒に、チンポの脈動がおっぱ\nいに伝わってくる……はぁ、興奮しているのか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3003109" ]},
		{"command":[ "SETIMAGE", "0", "still_00000130_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んふ……待ってろ……気持ちよくしてやるからな……んっ、くぅ……はっ、\nんふっ、んくぅう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3003110" ]},
		{"command":[ "SETIMAGE", "0", "still_00000130_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「こうして、身体を動かせば……自然に、二人ともあたたかくなってくるだろ\nう？　んっ、どうだ……おっぱいの感触は？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3003111" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「柔らかくてすべすべ……しっとりして……気持ちいい……ふふ、当然だ。誰\nのおっぱいだと思っている？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3003112" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「このルナテミスが……んっ、自らパイズリで……チンポを扱いているんだ…\n…この、震え方を見ても、感じてないとは言わせんぞ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3003113" ]},
		{"command":[ "SETIMAGE", "0", "still_00000130_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んんっ！？　あっ……な、何をしている？　んんっ……わ、私にも……感じ\nて欲しい……だと？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3003114" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あっ……ずっと、このサンタの姿にムラムラしてたって……急に言われても\n……あ、あひぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3003115" ]},
		{"command":[ "SETIMAGE", "0", "still_00000130_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んぁぁっ……し、舌が……あっ、オ、オマンコの入り口をなぞってくる……\n！　ふぁっ……んんっ、あっ、くっ、んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3003116" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ、ふ……ちゃんと、私の……敏感な場所を見極めて……尖った舌が……\nくぅっ、突っついて……来るっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3003117" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ならば、私も……んっ、もっとおっぱいを動かしていかないと……はぁ、ん\nっ、どうだ……谷間に埋めて……擦り、上げてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3003118" ]},
		{"command":[ "SETIMAGE", "0", "still_00000130_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「少し滑りが悪いか……？　んっ、ふっ、少し唾液を足してやれば……んっ、\nはっ、これで……どうだ？　ほら……こうだ……んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3003119" ]},
		{"command":[ "SETIMAGE", "0", "still_00000130_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「おっと……チンポが分かりやすく震えたな……ふふ、この素直なところは変\nわらんようだな……んっ、はっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3003120" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「こうして揉みくちゃにされる感覚……好きだろう？　あぁ、答えなくていい\nぞ、ちゃんとチンポ自身が教えてくれるからな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3003121" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「この震え方だ……私のおっぱいに包まれて、チンポがプルプルと動いている\n……可愛いやつめ……ぁっ、んんっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3003122" ]},
		{"command":[ "SETIMAGE", "0", "still_00000130_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んっく……そうやって、余裕がなくなると……私を……んっ、責めて……ご\nまかすつもりか……ひゃ、あっ、舌が……奥にぃっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3003123" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あっ、んぁっ、あぁんっ！　そんな、音を激しくさせて吸うなんてっ……バ\n、バカっ……は、恥ずかしい……だろうっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3003124" ]},
		{"command":[ "SETIMAGE", "0", "still_00000130_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んんっ……この方がドキドキする……それは、んっく……そうかも知れない\nが……はぁう、あっ……舌がにゅるんって……あぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3003125" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ドキドキ……し過ぎる……あぁっ、身体が火照って……そんなにペロペロす\nるのはぁっ、あぁっ、んぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3003126" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ダメだ……このままだと、私が先にイカされてしまう……ならば、わ、私も\n……はっ、んちゅぷっ、くぽっ、んふうっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3003127" ]},
		{"command":[ "SETIMAGE", "0", "still_00000130_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「りゅぷっ……そうら……私も……チンポを舐めて……気持ちよくさせていく\nからな……嫌とは言うまいな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3003128" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「もちろん……パイズリも忘れてはいないぞ……この、しこった乳首をぉ……\n震えているチン先に押し付けてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3003129" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んちゅっ……チンポにキスをしながら……転がしてやる……んっ、ふっ、色\nっぽい呻きが漏れたな……かなり気持ちよかったか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3003130" ]},
		{"command":[ "SETIMAGE", "0", "still_00000130_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「いいとも……もっともっとしてやるからな……ちゅぱっ、あふっ、んんっ…\n…あぁ……はぷっ、んんっ、あんむ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3003131" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「こ、これは……シックスナインという……やつだよな……お、お互いの……\n恥ずかしい場所を舐め合って気持ちを高めていく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3003132" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁ……先端が震えてるのが可愛らしい……ちゅぷっ、これは……んっ、そ\nろそろ出そうなんだな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3003133" ]},
		{"command":[ "SETIMAGE", "0", "still_00000130_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ……いいぞ……あっ、ふっ……もうやせ我慢することはないからな\n……？　んっ……そのまま飲んでやるから……射精していいぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3003134" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ふっ、んくっ……ダメだ……ク、クリトリスを、そんなつついてっ……貴様\nより先にイク訳にはっ……せ、せめて一緒にっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3003135" ]},
		{"command":[ "SETIMAGE", "0", "still_00000130_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ、んじゅるっ、ふっ、あっ、らめらっ、も、もぉっ、はひっ、んっ\n、くうぅぅぅぅぅぅんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3003136" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んふぁっ、ぷっ……！　はぶっ、んっ、ちゅぶっ……りゅぱっ、んっく……\nあ、んぷっ、出て……るっ、んじゅ、ちゅぷぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3003137" ]},
		{"command":[ "SETIMAGE", "0", "still_00000130_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「わ、わらひもっ……イ、イクッ！　んんんんーっ……！　あっ、精液……飲\nみながら……オマンコ……イって……るぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3003138" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁぁ……じゅるっ、ちゅぱっ……ドキドキしたな……れろ、ちゅる\nっ……んちゅぱっ……まだ、チンポから精液垂れて来てる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3003139" ]},
		{"command":[ "SETIMAGE", "0", "still_00000130_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んふっ、じゅる、ちゅぱっ……はぁん……あぁ、か、かなり勢い任せにして\nしまったな……だが、身体はかなりあったまったと思うぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3003140" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ……まだ、汚れているからな……ちゃんと掃除しておかないとな……ち\nゅぱ、ぴちゃ、んちゅ、ちゅぷぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3003201" ]},
		{"command":[ "SETIMAGE", "0", "still_00000130_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「見ろ……まだ、奥にも少し残ってる……ちゅぷぅん……れろ、これも吸い出\nしてしまわないとな……じゅるるっ、ちゅぷぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3003202" ]},
		{"command":[ "SETIMAGE", "0", "still_00000130_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ところで、これは……私の気のせいではないよな……？　じゅぷっ、んちゅ\nぷっ……チンポがさっきより大きくなっているような……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3003203" ]},
		{"command":[ "SETIMAGE", "0", "still_00000130_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「全く……欲望に限りなしということか……それは、こんなもの……そのまま\nに出来る筈はないだろう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3003204" ]},
		{"command":[ "SETIMAGE", "0", "still_00000130_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「続きだ……ちゅぱ……んちゅぷっ、もう一発出すまで……パイズリフェラを\nしてやるからな……れろ、くぷっ、あんむ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3003205" ]},
		{"command":[ "SETIMAGE", "0", "still_00000130_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁ、んっちゅぷ……味が濃くなっている……舐めてるだけで涎がどんどん\n出てきてしまうぞ……ちゅぱ、んっ、ちゅぷぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3003206" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んんっ……りゅぷっ……んんっ！？　な、何をして……貴様まで続きをっ！\n？　あっ、ひぁっ、また……オ、オマンコぉっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3003207" ]},
		{"command":[ "SETIMAGE", "0", "still_00000130_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「だ、ダメではない……したいのならば……す、すればいいが……んくぅっ、\nあっ、はぁっ、んっ、あっ……前より、は、激しく……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3003208" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そ、それなら……私もっ、もっと蕩けさせてみせるっ……んっ、貴様のチン\nポを……おっぱいに埋めて……こ、こうだっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3003209" ]},
		{"command":[ "SETIMAGE", "0", "still_00000130_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はっ、んふっ……こうして、あっ、んむっ……！　ちゅぷっ……そうだ、大\n人しくしてろ……りゅぷっ、あっ、あひぉっ、はひっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3003210" ]},
		{"command":[ "SETIMAGE", "0", "still_00000130_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んんんっ……！　ぜ、全然大人しくする気はないな……？　んくぅっ……あ\nっ、また、オマンコの中ぁ……くっ、うんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3003211" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「私の舌に合わせるように……ちゅぱっ、動かしてくるなんて……はぁんっ、\nダメだ……気持ちいい……下半身が溶けてしまいそうだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3003212" ]},
		{"command":[ "SETIMAGE", "0", "still_00000130_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ、りゅぷっ……お互い様……？　んちゅぷっ、貴様のチンポも……\n余裕がないということか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3003213" ]},
		{"command":[ "SETIMAGE", "0", "still_00000130_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あふっ、んっ、確かに……また震え始めているな……ぎゅっと押し込むと、\nとくんと……鼓動が伝わってくる感じがする……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3003214" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ここが責め時ということなら……はっ、くぅんっ、はっ、んむっ……あっ、\nちゅぽっ、りゅぶっ、んじゅるるるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3003215" ]},
		{"command":[ "SETIMAGE", "0", "still_00000130_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んふぁっ……あぁ、チンポの味ぃ……舌が止まらないのら……んっ、乳首も\n……ぎゅっと押し付けてぇ……ご奉仕っ、するぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3003216" ]},
		{"command":[ "SETIMAGE", "0", "still_00000130_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あふっ……んっ、いいぞ……チンポがプルプルして……先走りも……じわじ\nわ出て……もう限界だろう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3003217" ]},
		{"command":[ "SETIMAGE", "0", "still_00000130_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はっ、んっ、はぁっ、後は……私のパイズリでっ、一気に最後まで連れて行\nってやるっ……さあ、またドピュッと出すんだっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3003218" ]},
		{"command":[ "SETIMAGE", "0", "still_00000130_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ひぁぅっ！　ま、また……オマンコぉっ！　ダメだっ……ま、まだ耐えるっ\n……貴様より後に……イクっ……からぁっ、じゅぷっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3003219" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「さあ……らせっ、せーえきっ、じゅるるるっ、んふぅっ……あっ、んぁっ、\nも、もうらめっ、イクっ！　貴様も……は、早くぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3003220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "FADEIN", "NORMAL" ]},	
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んぐぅっ……！　んんっ……まら……れへるっ……！　んぐっ、んくぅ……\nこくっ、んくっ、んくんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3003301" ]},
		{"command":[ "SETIMAGE", "0", "still_00000130_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はぷっ……あぁ、本当に２発目なのか……？　さっきより勢いも増して……\nちゅぷっ、そのまま飲み切るのも一苦労だ……んく、こくん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3003302" ]},
		{"command":[ "SETIMAGE", "0", "still_00000130_01_11" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ、あぁ……だからといって、止めようとしなくていいぞ？　ちゃん\nと……全部、飲むからな……じゅるっ、んちゅぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3003303" ]},
		{"command":[ "SETIMAGE", "0", "still_00000130_01_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そうだ……最後まで出してしまえ……じゅぽっ、んっ……はぁ……んちゅぷ\n、りゅぱ……んっ、ふぁぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3003304" ]},
		{"command":[ "SETIMAGE", "0", "still_00000130_01_11" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「出し切ったな……はぁ、んっ、あぁ……いっぱい出せたな……ふふ、ちゃん\nと全部飲んだぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3003305" ]},
		{"command":[ "SETIMAGE", "0", "still_00000130_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「元はと言えば、チンポの後始末から続けてしまったんだったな……今度こそ\n、しっかり後始末をするからな……ちゅぽっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3003306" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「れる、んちゅっ、ちゅぷぅぅ……ちゅるっ……んちゅっ、ちゅうぅぅ……あ\nっ……んっ、わ、私の方は別に後始末はしなくても……ひゃふ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3003307" ]},
		{"command":[ "SETIMAGE", "0", "still_00000130_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「な、何でもいい……もう貴様の好きにしてくれれば……オマンコ……舐めて\nくれ……はぁぁ……あっ、ふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3003308" ]},
		{"command":[ "SETIMAGE", "0", "still_00000130_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ、んっ、あぁ……後始末は終わったが……まだ、勃起はすごい\n……ままだな……私も身体が火照って……たまらない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3003309" ]},
		{"command":[ "SETIMAGE", "0", "still_00000130_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そうだ……まだ聖夜は長いんだ……今夜はもっといっぱい愛して欲しい……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3003310" ]},
		{"command":[ "SETIMAGE", "0", "still_00000130_01_01" ]},
		{"command":[ "WAITINPUT" ]},
