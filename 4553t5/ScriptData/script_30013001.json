		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ふぁぷっ！　あぁっ……チンポ、抜けてっ……ザーメンっ……顔にっ……ん\nふぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3003401" ]},
		{"command":[ "SETIMAGE", "0", "still_00000130_01_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んふぁっ……また、とんでもない量を出して……貴様の欲望は本当に底なし\nだな……は、ふぅ……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3003402" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁ、ねばねばが纏わりつく……これを味わってしまうと……れる……私も\n蕩けてしまうんだ……ちゅる……んちゅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3003403" ]},
		{"command":[ "SETIMAGE", "0", "still_00000130_01_14" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「今更遠慮するな……いいから、そのまま勢いよくチンポ汁を飛ばして、私に\nマーキングするといい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3003404" ]},
		{"command":[ "SETIMAGE", "0", "still_00000130_01_13" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁ……落ち着いてきたか。はぁ、はぁ……本当に１発目よりも多い量を出\nしたんだな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3003405" ]},
		{"command":[ "SETIMAGE", "0", "still_00000130_01_14" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「それだけ、私のパイズリに夢中だったということだろう？　ふふ……可愛い\nヤツめ……今度こそ後始末をしてやるからな……んちゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3003406" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ、あっ……ふっ……！　お前まで後始末をしなくてもいいんだぞ……？\n　いや、どうしてもしたいのなら構わんが……んっ、ちゅぱ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3003407" ]},
		{"command":[ "SETIMAGE", "0", "still_00000130_01_15" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「は、ふっ……お、終わりか……んんっ、あぁ、す、すまなかったな……こん\nな、私の方がしてもらうなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3003408" ]},
		{"command":[ "SETIMAGE", "0", "still_00000130_01_14" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「気持ちが高ぶったままで……だから、まだ終わらせたくないと……そういう\nことか……ふふっ、そんな心配は無用だ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3003409" ]},
		{"command":[ "SETIMAGE", "0", "still_00000130_01_13" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「私も、まだずっと身体が熱を求めて止まらないんだ……夜はまだ長い……私\nのことを……もっともっと愛して欲しい……」", "NORMAL" ]},
