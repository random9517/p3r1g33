		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "円盤少女Ａ" ]},
		{"command":[ "SETTEXT", "「また女幹部に負けて帰ってきたんだー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_010113830001" ]},
		{"command":[ "SETCHARA", "0", "char_00016201_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "円盤少女Ｂ" ]},
		{"command":[ "SETTEXT", "「あんなに意気込んでたのに、かっこわるーい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_010113830001" ]},
		{"command":[ "SETCHARA", "0", "char_00016301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "円盤少女Ａ" ]},
		{"command":[ "SETTEXT", "「リーダーかっこわるーい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_010113830002" ]},
		{"command":[ "SETCHARA", "0", "char_00016201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "円盤少女Ｂ" ]},
		{"command":[ "SETTEXT", "「よわよわリーダー恥ずかしくないのー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_010113830002" ]},
		{"command":[ "SETCHARA", "0", "char_00016301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "襲来者（インベーダー）の宇宙船内部。あれから帰還したリーダーは円盤少女\nたちにいびられていた、", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETCHARA", "0", "char_00090101_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「くぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010113830001" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "自分より幼い見た目の相手にボロクソ言われるのは癪だが、しかし事実なので\n反論もできない。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "しかも今回は夜中に奇襲を仕掛けるという自信のあった策だけに情けなさも倍\n増している。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "円盤少女Ａ" ]},
		{"command":[ "SETTEXT", "「毎回負けて帰ってくるけど、リーダーはなんにも考えてないの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_010113830003" ]},
		{"command":[ "SETCHARA", "0", "char_00016201_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "円盤少女Ｂ" ]},
		{"command":[ "SETTEXT", "「反省しないの？　大人なのに」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_010113830003" ]},
		{"command":[ "SETCHARA", "0", "char_00016301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「は、反省はしている！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010113830002" ]},
		{"command":[ "SETCHARA", "0", "char_00090101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "円盤少女Ａ" ]},
		{"command":[ "SETTEXT", "「反省してるの？　どんなふうに？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_010113830004" ]},
		{"command":[ "SETCHARA", "0", "char_00016201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「ど、どんなふうに？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010113830003" ]},
		{"command":[ "SETCHARA", "0", "char_00090101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "円盤少女Ｂ" ]},
		{"command":[ "SETTEXT", "「地球では、反省するときにアツアツの鉄板の上で土下座するってよ。誠意を\n見せるために！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_010113830004" ]},
		{"command":[ "SETCHARA", "0", "char_00016301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「はぁっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010113830004" ]},
		{"command":[ "SETCHARA", "0", "char_00090101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "リーダーのいない間に、この少女たちは地球の資料映像をみて影響を受けてし\nまったらしい。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "円盤少女Ａ" ]},
		{"command":[ "SETTEXT", "「反省する気があるならどこでもできる！　たとえそこがアツアツの鉄板のう\nえでも！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_010113830005" ]},
		{"command":[ "SETCHARA", "0", "char_00016201_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "円盤少女Ｂ" ]},
		{"command":[ "SETTEXT", "「灼熱地獄っ……！　リーダーが見せるっ……！　圧倒的誠意っ……！　圧倒\n的……反省っ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_010113830005" ]},
		{"command":[ "SETCHARA", "0", "char_00016301_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "円盤少女Ａ" ]},
		{"command":[ "SETTEXT", "「猛省っ……！　猛省っ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_010113830006" ]},
		{"command":[ "SETCHARA", "0", "char_00016201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "挟撃の狂気っ……！　無邪気に迫る……要求っ……！　無慈悲……無慈悲っ…\n…！", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「ま、待ってください！　それでも、ちゃんと収穫はありましたから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010113830005" ]},
		{"command":[ "SETCHARA", "0", "char_00090101_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "円盤少女Ａ" ]},
		{"command":[ "SETTEXT", "「収穫？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_010113830007" ]},
		{"command":[ "SETCHARA", "0", "char_00016201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "円盤少女Ｂ" ]},
		{"command":[ "SETTEXT", "「なーにー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_010113830006" ]},
		{"command":[ "SETCHARA", "0", "char_00016301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「お、女幹部たちの弱点を見つけてきました！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010113830006" ]},
		{"command":[ "SETCHARA", "0", "char_00090101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "円盤少女Ｂ" ]},
		{"command":[ "SETTEXT", "「弱点を見つけたの？　やるじゃんリーダー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_010113830007" ]},
		{"command":[ "SETCHARA", "0", "char_00016301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "円盤少女Ａ" ]},
		{"command":[ "SETTEXT", "「よわよわリーダーからちょいよわリーダーに成長したねー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_010113830008" ]},
		{"command":[ "SETCHARA", "0", "char_00016201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「はぁ……どうも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010113830007" ]},
		{"command":[ "SETCHARA", "0", "char_00090101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "このままだと本当に熱い鉄板の上で土下座させられていただろう。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "円盤少女たちの気が変わったようで、リーダーはほっと一息ついた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "円盤少女Ａ" ]},
		{"command":[ "SETTEXT", "「それで、弱点って？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_010113830009" ]},
		{"command":[ "SETCHARA", "0", "char_00016201_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「それは……サメです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010113830008" ]},
		{"command":[ "SETCHARA", "0", "char_00090101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "円盤少女Ｂ" ]},
		{"command":[ "SETTEXT", "「サメ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_010113830008" ]},
		{"command":[ "SETCHARA", "0", "char_00016301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "円盤少女Ａ" ]},
		{"command":[ "SETTEXT", "「サメ……！　って、なに？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_010113830010" ]},
		{"command":[ "SETCHARA", "0", "char_00016201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "円盤少女たちは真顔になってリーダーの方を見た。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETCHARA", "0", "char_00090101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "円盤少女Ａ" ]},
		{"command":[ "SETTEXT", "「でも、なんでサメが弱点なの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_010113830011" ]},
		{"command":[ "SETCHARA", "0", "char_00016201_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「あの幹部たちは、我々よりもサメの方を恐れているようでしたから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010113830009" ]},
		{"command":[ "SETCHARA", "0", "char_00090101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「おそらく、サメというのは幹部たちの天敵のような存在と思われます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010113830010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "円盤少女Ｂ" ]},
		{"command":[ "SETTEXT", "「ふーん。でも、私たちはサメのことなーんにもわからないんだけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_010113830009" ]},
		{"command":[ "SETCHARA", "0", "char_00016301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "円盤少女Ａ" ]},
		{"command":[ "SETTEXT", "「そうだよねー。サメってそんなに怖いのー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_010113830012" ]},
		{"command":[ "SETCHARA", "0", "char_00016201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「サメの生態については、こちらに資料を入手してあります」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010113830011" ]},
		{"command":[ "SETCHARA", "0", "char_00090101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "リーダーはこんなこともあろうかと、ワゴンセールで投げ売りされていたサメ\n映画のディスクを購入していた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「この星の人類はとても愚かです。こんなものを誰にでも手に取れる場所に置\nいておくのですから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010113830012" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "円盤少女Ｂ" ]},
		{"command":[ "SETTEXT", "「リーダーにしてはやるねー。ちょっと見直しちゃったかも」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_010113830010" ]},
		{"command":[ "SETCHARA", "0", "char_00016301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "円盤少女Ａ" ]},
		{"command":[ "SETTEXT", "「ちょいよわリーダーからのランクアップも近いねー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_010113830013" ]},
		{"command":[ "SETCHARA", "0", "char_00016201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「ははっ、ありがとうございます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010113830013" ]},
		{"command":[ "SETCHARA", "0", "char_00090101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そしてリーダーは少女たちと一緒にサメ映画を見始めた。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "円盤少女Ａ" ]},
		{"command":[ "SETTEXT", "「なんでサメが空を飛ぶのーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_010113830014" ]},
		{"command":[ "SETCHARA", "0", "char_00016201_01", "3", "CENTER", "0" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "円盤少女Ｂ" ]},
		{"command":[ "SETTEXT", "「このサメ、頭多くない？　５つもある！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_010113830011" ]},
		{"command":[ "SETCHARA", "0", "char_00016301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「さ、サメとタコが合体している……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010113830014" ]},
		{"command":[ "SETCHARA", "0", "char_00090101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "円盤少女Ａ" ]},
		{"command":[ "SETTEXT", "「このサメ、でかい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_010113830015" ]},
		{"command":[ "SETCHARA", "0", "char_00016201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "円盤少女Ｂ" ]},
		{"command":[ "SETTEXT", "「でかいサメが機械のサメと戦ってる！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_010113830012" ]},
		{"command":[ "SETCHARA", "0", "char_00016301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「おかしい……なぜこの資料にはサメが出てこない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010113830015" ]},
		{"command":[ "SETCHARA", "0", "char_00090101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "彼らは様々な設定で繰り広げられるサメ映画を一気に履修した。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "リーダーがワゴンセールで購入してきたサメ映画は、ひどい出来のものばかり\nだった。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "それは、実際に見なければわからない映像の深淵。２匹目のドジョウを狙うサ\nメ映画ハンターによる乱獲の残滓。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "あるときは狂気を、あるときは退屈を。真剣に見れば見るほど正気を失わせる\n映画界のバミューダ海域。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そこに迷い込んだサメ映画ビギナーの精神が、この連続視聴に耐えられるはず\nがないのだ。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「サメとは……いったい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010113830016" ]},
		{"command":[ "SETCHARA", "0", "char_00090101_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "円盤少女Ａ" ]},
		{"command":[ "SETTEXT", "「サメ……こわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_010113830016" ]},
		{"command":[ "SETCHARA", "0", "char_00016201_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "円盤少女Ｂ" ]},
		{"command":[ "SETTEXT", "「こんな生物……誰でも怖いわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_010113830013" ]},
		{"command":[ "SETCHARA", "0", "char_00016301_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "見終わった３人は、サメという生物がよくわからなくなってしまった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「この星には、不思議なことがまだまだたくさんある……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010113830017" ]},
		{"command":[ "SETCHARA", "0", "char_00090101_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そして、そのまま力尽きてしまうのだった。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}