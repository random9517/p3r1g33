{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0183" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_007" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「２人とも、本当にやりあうのか？」", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「おうよ！！　こういう奴は１発殴って分からせてやらねえといけねえんだよ\n！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023620001" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「うららを危険に晒そうなどという真似、むざむざ見過ごすわけにはいきませ\nんから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_020023620001" ]},
		{"command":[ "SETCHARA", "0", "char_00027502_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「お姉ちゃんとほむらさんが私のせいで戦うことになるなんて……ダメです、\nやめてください！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_010023620001" ]},
		{"command":[ "SETCHARA", "0", "char_00026101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0"]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「マスカレード時代から、本気でやったらどっちが強いか試してみたかったん\nだよなあ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023620002" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "400" ]},
		{"command":[ "SETCHARA", "1", "char_00027502_01", "0", "CENTER", "-400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "1"]},
		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「ふふ……私の刃の前でいつまでその言葉が続くでしょうかね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_020023620002" ]},
		{"command":[ "SETCHARA", "1", "char_00027502_01", "6", "CENTER", "-400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うらら、無理だよ。こうなったらほむらは止まらないし、見たところ静夜も\n同類だ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「そ、そんな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_010023620002" ]},
		{"command":[ "SETCHARA", "0", "char_00026101_01", "4", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「それにね～、そんなに心配するようなことでもないかもしれないわよ～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_010023620001" ]},
		{"command":[ "SETCHARA", "0", "char_00027401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「え、それって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_010023620003" ]},
		{"command":[ "SETCHARA", "0", "char_00026101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「まあまあ、私たちは安全な場所に下がりましょう～。あなたが怪我したらそ\nれこそ元も子もないわ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_010023620002" ]},
		{"command":[ "SETCHARA", "0", "char_00027401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ジュンジロー、開始の合図を頼む。お前なら開始の瞬間こっちに逃げてこら\nれるだろ」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「まったく犬使いの荒い……お二方、命に関わるような攻撃は控えられますよ\nう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023620001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「分かってるって。手加減しても勝てっから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023620003" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「それはこちらの台詞ですね……峰打ちで済ませてさしあげます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_020023620003" ]},
		{"command":[ "SETCHARA", "0", "char_00027502_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お、静夜の手首のアクセサリーが刀に変化した……ほむらの炎とかもそうだ\nけど、ああいうヒーローギミックってやっぱいいよな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「男の子ってそういうの好きよね～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_010023620003" ]},
		{"command":[ "SETCHARA", "0", "char_00027401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「それでは……始めっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023620002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「オラァッ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023620004" ]},
		{"command":[ "PLAYSE", "SE_M_009" ] },
		{"command":[ "SETCHARA", "0", "char_00003402_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「ふっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_020023620004" ]},
		{"command":[ "PLAYSE", "SE_ADV_004" ] },
		{"command":[ "SETCHARA", "0", "char_00027502_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うお……初っぱなから飛ばしてるな。ほむらの炎が全開だ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「開始直後の熱波で私の毛が焦げてしまいましたし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023620003" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「ブラックちゃんの斬撃も鋭くて、私の蔦なんか簡単に斬り裂かれそうよね～\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_010023620004" ]},
		{"command":[ "SETCHARA", "0", "char_00027401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「お姉ちゃん……強いのは知ってたけど、こんなに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_010023620004" ]},
		{"command":[ "SETCHARA", "0", "char_00026101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「オラオラどうしたよブラック！！　ちょっと見ないうちに鈍っちまったんじ\nゃねえのか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023620005" ]},	
		{"command":[ "PLAYSE", "SE_M_009" ] },
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「誰がっ……！！　先輩こそ相変わらず単調な攻撃ですね！！　いつもいつも\n相手にそれで見切られてたじゃないですか！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_020023620005" ]},
		{"command":[ "PLAYSE", "SE_ADV_004" ] },
		{"command":[ "SETCHARA", "0", "char_00027502_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「言うじゃねえか、じゃあこいつはどうだっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023620006" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「くっ！！　ならばこちらもっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_020023620006" ]},
		{"command":[ "SETCHARA", "0", "char_00027502_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「っとおっ！！　はははは、盛り上がってきたじゃねえか！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023620007" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うわ……家の前が炎と斬撃でボコボコになってるんだが」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「修繕費とかかかりそうね～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_010023620005" ]},
		{"command":[ "SETCHARA", "0", "char_00027401_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「おお、ほむら殿のあれは新技ではないですか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023620004" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「あの……これ、本当に止めなくていいんですか……？　きゃあっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_010023620005" ]},
		{"command":[ "SETCHARA", "0", "char_00026101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うーん、まあ大丈夫だろ。少なくともほむらはそういう風にやってる」", "NORMAL" ]},
		{"command":[ "PLAYSE", "SE_M_009" ] },
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「楽しそうに笑ってるものねえ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_010023620006" ]},
		{"command":[ "SETCHARA", "0", "char_00027401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「そ、そういうものなのですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_010023620006" ]},
		{"command":[ "SETCHARA", "0", "char_00026101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「うらら殿、ＥＤＯに所属するなら、こういう場面に慣れておかないといけま\nせんぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023620005" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「ひ、ひええ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_010023620007" ]},
		{"command":[ "SETCHARA", "0", "char_00026101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「どりゃああああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023620008" ]},
		{"command":[ "PLAYSE", "SE_M_009" ] },
		{"command":[ "SETCHARA", "0", "char_00003402_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「はああああああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_020023620007" ]},
		{"command":[ "PLAYSE", "SE_ADV_004" ] },
		{"command":[ "SETCHARA", "0", "char_00027502_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「くおっ……ふうっ……ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023620009" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「ふっ……はっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_020023620008" ]},
		{"command":[ "SETCHARA", "0", "char_00027502_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「膠着したな……次の１手で決まるぞこれ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「ほむらちゃん、なにか狙ってるわよね～。ブラックちゃんは気づいてるかし\nら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_010023620007" ]},
		{"command":[ "SETCHARA", "0", "char_00027401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「お姉ちゃん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_010023620008" ]},
		{"command":[ "SETCHARA", "0", "char_00026101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「やるじゃねえかブラック。やっぱり近接戦だとお前は強い」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023620010" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「それはどうも……先輩こそ、思ったよりも粘りますね。私の剣を前にして、\nこれほど耐えたのは先輩が初めてですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_020023620009" ]},
		{"command":[ "SETCHARA", "0", "char_00027502_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「確かになあ、お前は強い。でも……今の狭まった視野で俺に勝てると思うな\nよっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023620011" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「くっ！？　炎の壁！？　しかし、こんなものっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_020023620010" ]},
		{"command":[ "PLAYSE", "SE_M_009" ] },
		{"command":[ "SETCHARA", "0", "char_00027502_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「そうだな、お前は斬ると思ったよ。それができるからなっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023620012" ]},
		{"command":[ "PLAYSE", "SE_ADV_004" ] },
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「っ！！　いつのまに懐に……っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_020023620011" ]},
		{"command":[ "SETCHARA", "0", "char_00027502_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「オラァッ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023620013" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「ぐっ……はっ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_020023620012" ]},
		{"command":[ "SETCHARA", "0", "char_00027502_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「がら空きのボディに強烈な１撃……これは決まりですな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023620006" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「痛えだろ？　でもな、お前に自分の志を否定された妹はもっと痛えんだぞ？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023620014" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「なっ……なにを……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_020023620013" ]},
		{"command":[ "SETCHARA", "0", "char_00027502_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「確かにうららは弱い。でもなあ、そんなうららが恐怖心を押し殺してヒーロ\nーになりたいって、ヒーローだった姉のように皆を護りたいって――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023620015" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「勇気を出して俺たちの前に出てきたことを、考えたことがあるのかよっ！！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023620016" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「っ！！　それ……は……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_020023620014" ]},
		{"command":[ "SETCHARA", "0", "char_00027502_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おお……静夜が膝を着いた。勝負ありだな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「私……私は……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_020023620015" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「お前がうららを心配する気持ちは分かる。でもいつまでもお前が保護できる\nわけでもねえんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023620017" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「だったら、うららの決断を尊重してやるのも、姉の務めじゃねえのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023620018" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「私……私はあんなに忌み嫌っていた本家の者と同じようなことをうららに…\n…うらら……ごめんなさい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_020023620016" ]},
		{"command":[ "SETCHARA", "0", "char_00027502_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「わかりゃいいんだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023620019" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "（つうか、くっそ硬えなこいつの腹筋！！　どんな鍛え方してんだ、岩かよ！\n！)", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023620020" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「終わったみたいね～。どっちも素直じゃないんだから～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_010023620008" ]},
		{"command":[ "SETCHARA", "0", "char_00027401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "PLAYBGM", "BGM_018" ]},
		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「でもブラックちゃん、そこまで心配なら、マスカレードに戻ってくればいい\nじゃない。姉妹ヒーローとか、いい感じじゃない～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_010023620009" ]},
		{"command":[ "SETCHARA", "0", "char_00027401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「そ……それは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_020023620017" ]},
		{"command":[ "SETCHARA", "0", "char_00027502_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「でも、それができないってことは、なにか理由があるのよね～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_010023620010" ]},
		{"command":[ "SETCHARA", "0", "char_00027401_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「……春風の家は武家の末裔なのですが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_020023620018" ]},
		{"command":[ "SETCHARA", "0", "char_00027502_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「その辺は聞いた」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「むっ。では……その本家の当主が少し前に亡くなりまして。当主の条件は当\n主になる意思があることと、剣の腕が立つことなのですが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_020023620019" ]},
		{"command":[ "SETCHARA", "0", "char_00027502_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「なまじ剣が使えた私は、本家の一派に目をつけられまして……当主になれと\n。ならねば、春風の家を離散させると、そう脅してきたのです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_020023620020" ]},
		{"command":[ "SETCHARA", "0", "char_00027502_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「そうして私を当主に据え、傀儡にして本家を意のままにする。そういう算段\nでした」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_020023620021" ]},
		{"command":[ "SETCHARA", "0", "char_00027502_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「そんな……だからお姉ちゃん、私たちに何も言わずに１人で出て行ったの…\n…？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_010023620009" ]},
		{"command":[ "SETCHARA", "0", "char_00026101_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「うららに話せば巻き込むことになると思っていましたから……当主になるた\nめに、マスカレードも辞めることとなりました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_020023620022" ]},
		{"command":[ "SETCHARA", "0", "char_00027502_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「なるほどなあ。生真面目なわりに、放り投げるような辞め方だったのも納得\nしたぜ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023620021" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「皆に迷惑をかけてはいけないと……でも、それが間違いだったのですね。私\nは奴らと同じことをうららにしてしまった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_020023620023" ]},
		{"command":[ "SETCHARA", "0", "char_00027502_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「そんな、違うよ！！　お姉ちゃんは私のためを思って――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_010023620010" ]},
		{"command":[ "SETCHARA", "0", "char_00026101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「それでも、私がうららの意思を無視していたのは確かです。あれほど唾棄す\nべきものだと思っていたあいつらと同じ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_020023620024" ]},
		{"command":[ "SETCHARA", "0", "char_00027502_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「ごめんなさい、うらら。私はあなたの強さを侮っていた。あなたの心を踏み\nにじってしまっていた……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_020023620025" ]},
		{"command":[ "SETCHARA", "0", "char_00027502_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「ううん、違う、違うよお姉ちゃん。お姉ちゃんは私のことを思ってくれたの\n、分かってる……それに」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_010023620011" ]},
		{"command":[ "SETCHARA", "0", "char_00026101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「私の方こそ、お姉ちゃんがそんな辛い思いで当主になってるの、知ろうとも\nしなくてごめんなさい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_010023620012" ]},
		{"command":[ "SETCHARA", "0", "char_00026101_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「これからは、なんでも話して。お姉ちゃんの辛いこと、しんどいこと、私も\n一緒に背負いたい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_010023620013" ]},
		{"command":[ "SETCHARA", "0", "char_00026101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「だって私はお姉ちゃんの……春風静夜の妹なんだから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_010023620014" ]},
		{"command":[ "SETCHARA", "0", "char_00026101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「うらら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_020023620026" ]},
		{"command":[ "SETCHARA", "0", "char_00027502_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「お姉ちゃん……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_010023620015" ]},
		{"command":[ "SETCHARA", "0", "char_00026101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いい話だなー」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「これでうらら殿の入隊も無事に認められた、ということですかな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023620007" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「それはいいけどよ、結局うららの戦闘力に関しては解決してねえんだが……\nその辺はどうするんだ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「んー、まあ大丈夫じゃね？　俺の見立てと勘がそう言ってるぜ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023620022" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}