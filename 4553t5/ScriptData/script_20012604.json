{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0101" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「それでは、ハロウィンを開始します～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022050001" ]},
		{"command":[ "SETCHARA", "0", "char_00015702_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「さっそく１人目を見つけましたよ……トリック・オア・トリート！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022050001" ]},
		{"command":[ "SETCHARA", "0", "char_00015802_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「……とりっく・おあ・とりーと……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022050001" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「そうか！　今日はハロウィンか。年をとると、どうにも日付を忘れてしまっ\nてな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022050002" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「長官！　見てくださいっ。私達……ハロウィン特別仕様になりました！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022050002" ]},
		{"command":[ "SETCHARA", "0", "char_00015702_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「おぉ……可愛らしい装いだな。私も着てみた……、ごほっごほっ！　な、な\nんでもない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022050003" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「長官にこんなことを言っていいのかわかりませんが……。その……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022050002" ]},
		{"command":[ "SETCHARA", "0", "char_00015802_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「長官！　お菓子をください！　でないとイタズラ……しちゃいます！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022050003" ]},
		{"command":[ "SETCHARA", "0", "char_00015702_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「……ふむ。では私からはお菓子をプレゼントしよう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022050004" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ちょうど先ほど、食堂のデザートチケットをもらってな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022050005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「これで良ければ２人で食べるといい。私はほら、立場的にデザートに舌鼓を\n打つというのはな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022050006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そういうのは、長官室で隠れて食ってますもんね」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ああ、そうなんだ。……と、なぜ知っている！？　いいからチケットをもっ\nていけ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022050007" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ありがとうございます、可愛い長官さん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022050003" ]},
		{"command":[ "SETCHARA", "0", "char_00015802_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「か、かわ……！　可愛いのはお前達だろう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022050008" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "赤面する長官からチケットを受け取り、ロッテとクララは嬉しそうにはしゃい\nでいる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「１人目から大成功でした。どんどんいきましょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022050004" ]},
		{"command":[ "SETCHARA", "0", "char_00015802_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「あっ、あそこにいるのは氷華さんですね！　トリック・オア・トリートです\n～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022050004" ]},
		{"command":[ "SETCHARA", "0", "char_00015702_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「トリック・オア・トリート……。お仕事中にごめんなさい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022050005" ]},
		{"command":[ "SETCHARA", "0", "char_00015802_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「いたずらか菓子か……？　ああ、なるほど今日はハロウィンでしたか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_020022050001" ]},
		{"command":[ "SETCHARA", "0", "char_00005002_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「私はあまり、浮かれたイベントは好きではありませんが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_020022050002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「そう、ですね……。双子のお揃いコーデは可愛らしいと思いますよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_020022050003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「本当ですか！？　嬉しいです～、にゃふふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022050005" ]},
		{"command":[ "SETCHARA", "0", "char_00015702_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「ですが……お菓子……。今はお菓子の持ち合わせがありませんから、イタズ\nラをどうぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_020022050004" ]},
		{"command":[ "SETCHARA", "0", "char_00005002_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「えっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022050006" ]},
		{"command":[ "SETCHARA", "0", "char_00015802_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「ですから……イタズラをどうぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_020022050005" ]},
		{"command":[ "SETCHARA", "0", "char_00005002_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「真顔でそこまで言われるとやりづらいです～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022050006" ]},
		{"command":[ "SETCHARA", "0", "char_00015702_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「本当に、好きにやってもらって構わないのですが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_020022050006" ]},
		{"command":[ "SETCHARA", "0", "char_00005002_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「やめろやめろ。２人がすっかり怯えてるだろ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「……私は、穏やかに交流を深めるつもりで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_020022050007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「真剣な表情が怖いんだよっ！　ロッテ、クララ！　次行くぞ次！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「は、はいです～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022050007" ]},
		{"command":[ "SETCHARA", "0", "char_00015702_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「交流を……。ああ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_020022050008" ]},
		{"command":[ "SETCHARA", "0", "char_00005002_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「行ってしまった……。私なりに、優しく出来たと思ったのですが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_020022050009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ご主人、あそこにいらっしゃるのは……マスク・ザ・レッドさんではないで\nすか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022050007" ]},
		{"command":[ "SETCHARA", "0", "char_00015802_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "クララの指差す方向に見えるのは、確かにツンツン髪のほむらだった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おーい、ほむらたん～！　ＥＤＯ本部で何やってんだ？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「お、隊長か？　俺ぇ？　俺は出前でちょっと寄っただけだぜ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_010022050001" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ほむらさん！　トリック・オア・トリートです！　トリック・オア・トリー\nト！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022050008" ]},
		{"command":[ "SETCHARA", "0", "char_00015802_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「私達、ＥＤＯ本部でハロウィンのイベントをやっているんですよ～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022050008" ]},
		{"command":[ "SETCHARA", "0", "char_00015702_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ほーん。もうそんな季節だったのか。にしてもハロウィンねぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_010022050002" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「俺はシャレた菓子なんざもってないけどよ、えーっと……なんかあったっけ\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_010022050003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「酒のつまみしかねえな。小魚にアーモンド、裂きイカにチータラ……。乾き\nモンでいいか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_010022050004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「これはこれで美味しそうです。ありがとうございます、ほむらたん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022050009" ]},
		{"command":[ "SETCHARA", "0", "char_00015802_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「たんをつけるな、たんを！　それじゃあな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_010022050005" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ありがとうございました！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022050010" ]},
		{"command":[ "SETCHARA", "0", "char_00015802_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "颯爽と走っていくほむらの姿に、２人はしばらく見惚れているようだった。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0101" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "そして、次なるターゲットは……。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「トリック・オア・トリート！　ハロウィンです、探偵さん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022050011" ]},
		{"command":[ "SETCHARA", "0", "char_00015802_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「ええっ、ハロウィン……！？　それは、事件のニオイがするなぁ……刺激的\nだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010022050001" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「だけど……僕はお菓子も持っていないし、イタズラをさせてあげるわけにも\nいかないな。でも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010022050002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「で、でも……なんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022050012" ]},
		{"command":[ "SETCHARA", "0", "char_00015802_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「かわりに、大のオトナも腰を抜かすような……とびきりのイタズラの方法を\n教えてあげられるよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010022050003" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「トリック・オア・トリートのトリックを……一段階、高めてみる気はないか\nい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010022050004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「それってとってもデンジャラスで面白そうですね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022050009" ]},
		{"command":[ "SETCHARA", "0", "char_00015702_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「そうだろうそうだろう。ちょっと物陰にきてもらえるかな？　……それで…\n…ごにょごにょごにょ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010022050005" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「え～っ！　そんなこと、しちゃって本当に平気なんですか～っ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022050010" ]},
		{"command":[ "SETCHARA", "0", "char_00015702_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「いやいや、本番はここからさ。隊長に２人で……ごにょごにょごにょ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010022050006" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「数日はダメージを与えられそうな、すごいイタズラです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022050013" ]},
		{"command":[ "SETCHARA", "0", "char_00015802_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ちょっと待て！　今俺に仕掛ける話をしてただろ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「あははっ、それは秘密。秘密というものですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010022050007" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「鳳雛の話を聞くな！　ロッテ、クララ！」", "NORMAL" ]},
