{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0166" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_020" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「くそっ、また逃げられた！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010113770001" ]},
		{"command":[ "SETCHARA", "0", "char_00012701_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「アタイの縄張りを荒らしまくりやがって！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_010113770001" ]},
		{"command":[ "SETCHARA", "0", "char_00009501_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「……それにしても妙だ。あのサメに殺意はあるのか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010113770002" ]},
		{"command":[ "SETCHARA", "0", "char_00012701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「アタイもそれを感じていたところさ。どうもおちょくられてる気がして、あ\nあっ、ムカつく！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_010113770002" ]},
		{"command":[ "SETCHARA", "0", "char_00009501_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「そもそも、サメが何度も現れるのも妙なところだ。サメというのは、見えな\nいことの恐怖が……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010113770003" ]},
		{"command":[ "SETCHARA", "0", "char_00012701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「次に出てきたらぜったいにケジメつけさせてやるんだからなぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_010113770003" ]},
		{"command":[ "SETCHARA", "0", "char_00009501_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「ええい、鮫バカとバカ鮫はだまってるのです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_050113770001" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「それよりも、ここまででひとつわかったことがあります」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_050113770002" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんだよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「あのサメは、どうやら『時空を超えてきた』人物をターゲットにしているよ\nうですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_050113770003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「てことは、園子がいる限りアイツは襲ってくるってことか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「まあ、そうでしょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_050113770004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「じゃあ、私が食べられちゃったら……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_070113770001" ]},
		{"command":[ "SETCHARA", "0", "char_00000607_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「まあ、我々の問題は解決しますね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_050113770005" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「解決しないわよ～っ！　過去のディアナちゃんが死んじゃうのよ～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040113770001" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「そしたら、今の私はどうなっちゃうのよぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040113770002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「……タイムパラドックスのようなＳＦ考証は、説明が面倒なのでこの際考え\nないことにしましょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_050113770006" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「ちゃんと考えてっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040113770003" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まあ、相手の狙いはわかった。じゃあ、どうやって守るかを考えないとな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「そうよぅ！　園子ちゃんをちゃんと守って！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040113770004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「まあ、サメに襲われちゃうのも可哀そうだしな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040113770001" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「いつまで逃げられるかわからないからな。対策は取った方がいいだろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010113770004" ]},
		{"command":[ "SETCHARA", "0", "char_00012701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「ちょうど、本部から連絡があった。あのサメの名前はデッドシャークだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010113770005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「デッドシャーク？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "なんというか、大層な名前だな。おまけにＺ級映画のタイトルみたいだ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「いったい、どういうサメなんだ？　食べられるのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040113770002" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「まず、食用には適さない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010113770006" ]},
		{"command":[ "SETCHARA", "0", "char_00012701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「食い意地はってんじゃねーですよ。話の腰も折れるでしょうが、バカ犬」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_050113770007" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「私たちが実際に見た通り、時空の裂け目から出現する神出鬼没のサメだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010113770007" ]},
		{"command":[ "SETCHARA", "0", "char_00012701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「出現位置を正確に特定するのは、本部の技術をもってしても難しいらしい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010113770008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「だが、俺たちにはそのサメが狙う相手がいる」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「そういうことだ。だから、おびき寄せることはできる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010113770009" ]},
		{"command":[ "SETCHARA", "0", "char_00012701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「ちょ、ちょっとぉっ！　園子ちゃんを囮に使うなんて、許さないんだからね\nっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040113770005" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「別にそうするつもりは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010113770010" ]},
		{"command":[ "SETCHARA", "0", "char_00012701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ディアナの剣幕にたじろぐスーザン。だが、俺も園子を囮に使うのには反対だ\n。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああ。さすがにそんな作戦は危険すぎる」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ディアナならともかく、園子は一般人だ。戦いに巻き込むわけにはいかない。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「これまで通り、出てきたところを叩こう」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「あ、ありがとうございます。……だけど、どうして？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_070113770002" ]},
		{"command":[ "SETCHARA", "0", "char_00000607_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「私はそのディアナって未来の私じゃない。あなた達の仲間じゃないのに。ど\nうして守ってくれるの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_070113770003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……過去からきていても、ディアナじゃなくても、今ここでは仲間だろう？\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「カツマさん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_070113770004" ]},
		{"command":[ "SETCHARA", "0", "char_00000607_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「カツマちゃん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040113770006" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「……ラブシーンか。サメのエサにはうってつけだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010113770011" ]},
		{"command":[ "SETCHARA", "0", "char_00012701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「な、なに言ってるのよぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040113770007" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「ラブシーンだなんてそんなこと！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_070113770005" ]},
		{"command":[ "SETCHARA", "0", "char_00000607_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「だが、サメは釣れたみたいだな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_010113770004" ]},
		{"command":[ "SETCHARA", "0", "char_00009501_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "本当だ。デッドシャークがまた空間の裂け目から現れた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETCHARA", "0", "char_00022201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「よし！　とにかくあいつの狙いは園子だ！　みんな、園子を守って……」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「…………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_010113770001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "デッドシャークが俺の方を見る。それにしても、見た目はサメだけどなかなか\nナイスバディ……ってそうじゃねえ！", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「…………！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_010113770002" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんでだよぉっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "園子を狙うと思ったデッドシャークが、俺に向かって攻撃してきた。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "完全に不意を突かれた。こいつに食われる。園子の周りにいる連中も間に合わ\nない……！", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そのとき、俺とデッドシャークの間に一発の銃弾が横切った。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「助かった！　でも、こんなことが出来るやつが、どこに……」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「いるよ、ここに一人ね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010113770001" ]},
		{"command":[ "SETCHARA", "0", "char_00001801_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ひるんだデッドシャークはまた空間の裂け目に逃げていく。", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00022201_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「間に合ったぁ……エヘ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010113770002" ]},
		{"command":[ "SETCHARA", "0", "char_00001801_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}