{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0029" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「オボロの懸念は的中し、Ω（オメガ）組と居酒屋・正義（まさよし）の抗争\nは激化の一途をたどった。そして、ある夜――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_990109100001" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「お客さん、居酒屋お探しかい？　え？　鳥Ω（オメガ）？　ああ、悪いねえ\n、鳥Ω（オメガ）満員なんだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010109100001" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「よければこっちの店ならすぐご案内できるよ。ご予算おいくらだい？　ああ\n、そんなら大丈夫、こっちこっち！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010109100002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "警官" ]},
		{"command":[ "SETTEXT", "「……ちょっと。そこのあなた。客引き行為は条例で禁止されてるんですがね\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「…………え？　いやいや、別にアタシは客引きなんかしてないよ。ただの通\nりすがりの女幹部さ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010109100003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "警官" ]},
		{"command":[ "SETTEXT", "「いいから、ちょっと交番まで来てもらえます？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「え！？　いやちょっと待っとくれよ！　アタシは別にやましいことなんか―\n―ちょっと！　おまわりさん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010109100004" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テロップ" ]},
		{"command":[ "SETTEXT", "「×月■日　夜　エファナティカ　迷惑防止条例違反で逮捕」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_999_980109100001" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0121" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「エファナティカの逮捕により、正義（まさよし）陣営に激震が走った。この\n機を逃さず、お七は次の手を打つ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_990109100002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「まりあ姉ちゃんを、連れ戻す……ですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010109100001" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「ええ。いつまでもこのまま、無用な争いに首を突っ込んでいてはまりあさん\nのためにもならないでしょうし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010109100001" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「それはまあ、間違いなくそうなんですけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010109100002" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「妹さんからそういって説得していただければ、まりあさんも争いから手を引\nくでしょうし、そうなれば仲良しのカグヤさんだって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010109100002" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「そういえば、姉ちゃんとカグヤ、最近妙に仲いいんだよね……どうしてなん\nだろ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010109100003" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「でしょう？　ですからつきみさん――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010109100003" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「……かと思えば、いきなりケンカをはじめたりするし。よくわかんないなぁ\n……あの二人」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010109100004" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「つきみさん？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010109100004" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「あ！　ごめんなさい！　ちょっと考えごとしちゃって！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010109100005" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「そうでしたか。まあ、今すぐ返事を、というのも難しいかもしれませんねぇ\n。２、３日考えたうえで、お返事を下さいな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010109100005" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「は、はい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010109100006" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "bg_0101" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_011" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「って、いうことがあったんだけど……どうしたらいいのかな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010109100007" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうだなあ……そりゃまあ、たしかにあの二人まで、バカな争いに首を突っ\n込んでほしくはないけどなぁ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「しかし、なんであの二人があんなことを……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「だよねえ……それがわたしもわかんなくって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010109100008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「……カツマさんはつきみさんと同レベルですか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010109100001" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「まったく。ここまで鈍感だと救いようがないな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010109100001" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ワタクシ、もうさじを投げましたぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010109100001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「って、もしかして俺、盛大にディスられてます！？　なんでそこまで――痛\nててっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「タンコブ、まだ痛いの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010109100009" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「盛大にぶつけたからなぁ。タンコブで済んだのが奇跡ってぐらいに」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ま、おぬしの頭は頑丈だけがとりえじゃからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010109100001" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「悪かったですね！　っていうか、なぜ陛下がここにいるんですか！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「宮殿におっても退屈じゃしな。ちょっと茶ぁしばきにきただけじゃよ。お七\nとほむらの争いを見てるだけも飽きんしのお」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010109100002" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「楽しまないでくださいよ。こっちは迷惑してんですから」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「じゃろうなぁ。そろそろ、なにか手を打たんといかんよなぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010109100003" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「なにか、策がおありなのでしょうか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010109100002" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「策？　策なぁ……策と言われても、これといってなぁ……。まあ、今日の議\n題はそれにするか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010109100004" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「議題って、雑談のネタのことですか。まあ、なにか考えてくれるんなら助か\nりますけど」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「おう。考えとる。考えとるよ。うーん……そうじゃなぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010109100005" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ホントに考えてんのか、この人」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「お！　そうじゃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010109100006" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「え！？　思いついたんですか！？　っていうか、マジで考えてたんだ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「あたりまえじゃろ失敬な！　ま、それはともかく、こんな手はどうじゃ？　\n昔観た、地球の古い映画が元ネタなんじゃが――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010109100007" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ふむふむ、なるほど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010109100002" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「それはなかなか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010109100003" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「イケる気がしてきた……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010109100010" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0000" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
		{"command":[ "SETNAME", "テロップ" ]},
		{"command":[ "SETTEXT", "「その翌日」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_999_980109100002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0081" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_011" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「血桜（ちざくら）お七ー！　出てこーい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010109100011" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETIMAGE", "0", "sbg_0082" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「殴り込みです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010109100004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ω組組員Ａ" ]},
		{"command":[ "SETTEXT", "「なんだとぉっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ω組組員Ｂ" ]},
		{"command":[ "SETTEXT", "「残念だったなぁ！　姐さんは留守じゃい！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETIMAGE", "0", "sbg_0081" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「知ってるよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010109100012" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETIMAGE", "0", "sbg_0082" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「つきみさん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010109100005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETIMAGE", "0", "sbg_0081" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「おっとっと！　なんでもない！　お七がいないなら、おまえらと勝負だー！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010109100013" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}