{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00026001_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「ちょっ……ちょっとお待ちになって！　この状況は何！？　なんなんですの\nっ、いきなりぃっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0104101" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「あっ……うっ、ううっ♪　私の高貴なるお尻が丸出しではありませんのっ…\n…！　貴方が言いたいことはわかります、今日の私の敗北の事でしょう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「確かにあれはぶざまとしかいいようのない醜態でした！　でもっ……しつけ\nのためとはいえ、さすがにっ、こ、この格好はどうなのかしらぁっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0104103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「……え？　おとなしく反省して、可愛く卑猥におねだりをすれば痛くしない\n……ですって？　えっ！？　というか何に対するおねだりなんですの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0104104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「私のお尻の穴に、アナルにオチンポを挿入する！？　ま、まままま、待って\nくださいまし！　冗談ではありませんわ！　ア、アナル、アナルって！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0104105" ]},
		{"command":[ "SETIMAGE", "0", "still_00026001_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「……ちゃんと言えたら、丁寧にアナルをほぐして、ローションも使って、ゆ\nっくり挿入してやるが、抵抗するなら乱暴にする？　っくっ、くうううっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0104106" ]},
		{"command":[ "SETIMAGE", "0", "still_00026001_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「なんたる傲慢……！　貴方っ！　私を誰だと思っているのですっ、宇宙帝国\nの貴族、准将であるアンドレッテですのよ！　それを、あ、アナルって！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0104107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「普通にオマンコを犯すのならばまだしも……どうしてこんな屈辱的なポーズ\nで、おねだりまでしてアナルを捧げなくてはいけないのっ、こ、怖いわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0104108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「えええええい！　もうやめ！　おしまいです！　私を解放なさい！　今解放\nすれば貴方を断罪するのはやめてさしあげ……って、うっ？　なんです？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0104109" ]},
		{"command":[ "SETIMAGE", "0", "still_00026001_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「きゃぁん！？　え！？　い、今、私のこの世に二つとない素晴らしいお尻を\n、よ、容赦なくひっぱたきましたわよね！？　っあっ、そんな……ひぁん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0104110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「んぁっ！？　あっ、ああっ、うううっ♪　わ！　わかりました！　わかりま\nしたからやめてくださいませ！　お尻ぺんぺんしないでくださいまし！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0104111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「……ふぅうう、び、びっくりしましたわ……。え、えぇと……アナル挿入の\nおねだり……ですね。そんな卑猥なこと、考えたこともありませんでしたが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0104112" ]},
		{"command":[ "SETIMAGE", "0", "still_00026001_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「わ、私の……生意気な貴族アナルを……あ、貴方の、その、まだ何もしてい\nないのにビッキビキに勃起したオチンポで、ふ、塞いでいただけますか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0104113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「えぇ！？　この程度ではまだ足りないと！？　っぅ……。私の……アンドレ\nッテの、誰にも触らせたことすらない軍人ドスケベ未開発アナルを……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0104114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「貴方の逞しく大きな庶民オチンポっ！　ふ、太くてカリ高で絶対アナルにな\nんか入らないサイズのバキバキオチンポで蹂躙してくださいませぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0104115" ]},
		{"command":[ "SETIMAGE", "0", "still_00026001_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「はぅうっ！？　あふっ！　あっ！？　あ、あ、ほ、本当にっ……本当に私の\n初めてのアナルに！　未経験アナルにオチンポを入れちゃいましたのね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0104116" ]},
		{"command":[ "SETIMAGE", "0", "still_00026001_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「う、うぅううっ♪　ち、違うんです！　突然入れられたから驚いただけ、で\n……♪　よ、喜んでなんていませんっ！　そんなの変態ではありませんか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0104117" ]},
		{"command":[ "SETIMAGE", "0", "still_00026001_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「私はいじめられてっ、感じる変態軍人ではありま……。んぁんんっ！？　や\nっ、お、お尻の奥をぐりぐりするのはおやめなさいぃっ♪　あっあっあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0104118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「で、ですからぁ！　感じてなんておりま、せんん……っ♪　はぁあっ♪　そ\nう見えるのでしたらそれは目の錯覚ですわ、……あんっ♪　んん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「アナル挿入だなんて、貴族としてはただの屈辱……。っひぃいんっ♪　あう\nっ♪　あううっ♪　だ、だめですわ、あまりの快感に身悶えが止まらない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0104120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「あああああ……♪　お父様お母様申し訳ありませんん！　私、正直白状しま\nすとちょっとアナルが気持ちいいですっ！　初めてなのにゾクゾクして！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0104121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「んっ……うっ♪　思っていたよりすんなりとこの剛直を、極太オチンポを腸\n内が受け入れてしまっていて……あっ！　オチンポ全部入ってっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「……んんんん！？　太いオチンポで肛門をっ！　あうっ、あふっ♪　ほじく\nるようにヌポヌポ抜き差しされてぇっ♪　んあああっ、よがっています！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0104123" ]},
		{"command":[ "SETIMAGE", "0", "still_00026001_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「……あああっ♪　こ、こんなの夢です、目が覚めたら消える夢ぇ！　お腹が\nくるしいっ……♪　それなのに、なぜそれが心地いいのでしょうっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0104124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「んっんんんっ♪　んふぅ～～っ♪　ンンンッ……！　ズンッ、と腸内を突き\n上げられると……うぅんっ♪　腰のあたりがゾワゾワしてっ♪　ああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「足がガクガクし、ますぅっ♪　アナル、アナルも！　最初はオチンポが入っ\nているだけで精一杯だったのに……もう勝手に順応しはじめているっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「私の意志ではないはずなのに！　オチンポにしがみついて、もっとしてと言\nっているみたいでっ……！　ああっ、ズボズボされたいぃ、もっとぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0104127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「んッ♪　おっ♪　おぉっ……♪　あああっ♪　アナルは……ぁっ、お尻の穴\nはオチンポを入れる場所ではない、のにぃ……っ♪　んぉうぅ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「淫らな声が口から漏れ出てしまいますっ……♪　んああっ♪　だらしなくて\nいやらしい声ぇ……♪　貴族が絶対上げちゃいけない喘ぎぃいい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「んぉおっ♪　おほっ♪　あぁうぅっ、あうぅう……♪　私、アナルをほじら\nれて、腸内全部オチンポで埋められて喜ぶド変態でしたのぉっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「んんぁっ♪　そ、それ以上は入りませんわ、ちゃんと奥に届いていますから\nぁ！　ですからズブズブアナルの中をかきまわさないでくださいなぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「んふぅっ！？　か、身体が浮くくらい強いストロークぅうう……！　あっ！\n？　な、なんですの、頭がぼーっとして……あっあっあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「ま、さか……っ♪　私、アナルで達してしまいそうに……？　あっ♪　いけ\nませんわ、それはなりません！　貴族として軍人としてぇえええ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「アナルっ、でイくなんてありえません！　ありえませんのにぃいい！　んん\nんん～！　んぉお♪　な、中で急にオチンポが太くなるものですからぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「拡張……されて、イッてしまいますっ！　んあああっ！　オチンポっ、オチ\nンポでアナルイキしてしまいますぅうっ！　あ～っ♪　見ちゃだめぇえ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0104135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「んんっんぅうううう～～～ッ♪　ひぁんん！？　何か熱いモノが、マグマの\nようなドロドロが……私の腸内にぶちまけられてぇっ！　あ～～っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0104136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00026001_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「も、もしやとは思いますが、アナルっ、私の貴族アナルに精液を流しこんで\nいるのではありませんよねぇっ！？　あっ！　んあっ♪　ああああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0104137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「お尻の中っ……！　奥が焼けつくように熱いぃいいっ♪　これっ、絶対精子\nです！　精液ぃい……っ！　アナルいっぱいに注がれているぅううっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「おぉおおっ！？　んほぉっ！？　おっおっおっ！？　目の前がチカチカする\nぅ！　射精、アナルに射精されると思考がトんでっ、……んぉおおっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0104139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「頭が悪くなってしまいますわぁああっ♪　あああっ！　も、もうそんなに出\nさないでくださいぃっ♪　んああっ！　好きになってしまいます、アナルぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「あ～～～っ♪　あああああっ、んぁああああ……♪　っふ～～～……♪　ふ\nぅっ、ふぅううっ……ふー♪　ふー♪　ふぅ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0104201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「ヤ、ヤッバいですわ……。意識が完全にトんでおりました……。んんん、ア\nナルをたぷたぷに満たす精液……。心なしか下腹も膨らんで……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0104202" ]},
		{"command":[ "SETIMAGE", "0", "still_00026001_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「あ、あのっ……今気付いたのですけれど！　これって……オチンポをずるん\nと抜き出すと……腸内の精液がどぱっと溢れてきてしまいません？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「ですから私が落ち着くまでは、抜くのを少しばかりお待ちになって……。っ\nて、……おかしいですわね？　射精したのにオチンポが小さくなっていない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0104204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「むしろがっちりと、私のアナルに栓をしたまま……。っぅ……♪　も、もし\nかしたらこれは……ええと、まだ勃起したまま……なんですの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0104205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「んあッ！？　へ、返答のかわりに腰を動かすのはおやめなさいいぃ！　……\nあっ！　わ、わかりました！　まだ大きいことはよぉくわかりましたぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0104206" ]},
		{"command":[ "SETIMAGE", "0", "still_00026001_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「あっ！　せ、精液をこぼさないようにフタをしてくださっているのはぁっ！\n　はうっ！？　嬉しいのです、けどぉっ！　ま、またピストンされるとぉっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「達したばかりのアナルが……っ！　快感を逃がせずに、ずっと痙攣しっぱな\nしになって……っ！　あっあっあっ！　快楽がどんどん増してきてっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「っんんんんん……！　アホになってしまいますのでぇっ！　んぁ～～～っ♪\n　おやめになって、抜いて、抜いてくださ……！　ッあああああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「……は、はいぃ！　おっしゃる通りですぅっ！　私、抜かずの二発目でぇえ\nっ！　射精されたてホカホカの貴族アナルをえぐられて感じてますううっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0104210" ]},
		{"command":[ "SETIMAGE", "0", "still_00026001_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「オチンポ！　前後にズプズプ動かされるたびに！　どんどん知能が低くなっ\nていってますぅうっ！　おっ♪　あっ、あっあっあっ♪　んふぅうっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0104211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「……わ、わかりました、白状いたします！　私はアナルの弱いドスケベ貴族\n軍人ですわぁあっ♪　アナルほじられるのが好きで好きで仕方がないのぉっ」", "NORMAL" ]},
