{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0027" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「この地点も異常なし。これで順回路は全て確認終了ですね。それで隊長さん\n……お願いがあるのですが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0104101" ]},
		{"command":[ "SETCHARA", "0", "char_00021001_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「私に……男女の生殖行為を教えていただけないでしょうか？　その、私は戦\n士として育ったのでそういうことに疎くて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「よろしければ、今ここで……認識阻害のフィールドを張りましたので、誰も\n私たちに気づきません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0104103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「隊長さんが悪いんですよ……いつもいつもあんなプレゼントばかり贈ってき\nて……だから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0104104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「んっ、寝そべって脚を開け……これでいいですか？　それで……股間を広げ\nろ……こうですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0104105" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00021001_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「股間じゃなくておまんこ？　分かりました、そう言えばいいのですね。おま\nんこを広げて、迎える準備を……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0104106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「言い方が堅苦しいのですか？　では、教えて下さい……なるほど、んんっ、\nおまんこに隊長さんのおちんぽを入れてください！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0104107" ]},
		{"command":[ "SETIMAGE", "0", "still_00021001_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「んんっ、隊長さん、なにを……あんっ、両手で私のおまんこを……あんっ、\nほじくって……んんっ、なにこれ……ああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0104108" ]},
		{"command":[ "SETIMAGE", "0", "still_00021001_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「隊長さんの両手が動くたびに、私のおまんこがじんじんってしびれて……疼\nいて……ふああっ、あっ、それ、気持ち、いいっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0104109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「あうっ、隊長さんの裸……見てるだけでどきどきします……隊長さんのおち\nんぽも硬くなってますね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0104110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「それでは……失礼します。隊長さん、おちんぽではなく、私は隊長さん自身\nが欲しいです……んんっ、あっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0104111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ふああ、あっ、隊長さんの脚が……んんっ、身体が、入って……くあっ、あ\nああっ、私の中が、おまんこが広がってる……っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0104112" ]},
		{"command":[ "SETIMAGE", "0", "still_00021001_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「くあっ、ああっ、これがセックス……んっ、隊長さんの脚が私の純血を……\nふあっ、ああ、今、隊長さんに初めてを……んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0104113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「痛……いや、大丈夫です、隊長さんは好きに動いてくれれば……ひあっ、あ\nっ、そこ、硬くなってるところを両手でこねられたら……ひうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0104114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「あ……んっ、中が痛いのに、外は……ふああっ、クリトリス？　そこをいじ\nられたら、くああっ、あっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0104115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「んんっ、クリトリス、こねられるの、好き……ふあっ、あああっ、隊長さん\n、んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0104116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「あっ、ああっ、中で脚を動かされたら……んんんっ、あっ、なんだか、中も\nじゅわじゅわ気持ちよさが……ふああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0104117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「はあっ、あっ、外も、中も……なんだか熱くなって……これがセックス……\n隊長さんとのセックス……んうううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0104118" ]},
		{"command":[ "SETIMAGE", "0", "still_00021001_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「あんっ、ああっ、あっ、中で脚をばたばたさせるの……ふああっ、おまんこ\nがかき混ぜられてるっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「隊長さんの脚で中がぐじゅぐじゅに……ふああ、手でクリも……両方、両方\n駄目っ、駄目です……ああああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0104120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「あっ、んっ、ふああっ、あっ、これ、脚じゃなくて……おちんぽ、隊長さん\nのおちんぽが壁にごりごりって！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0104121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「やあっ、あんっ、手も脚もおちんぽも動かしちゃ駄目っ……ひああっ、あっ\n、あんっ、ああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「あおっ、おっ、隊長さんのつま先が、ふああっ、かりかりって壁を……おち\nんぽもごりごりって！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0104123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「駄目、駄目っ、頭、変になっちゃう！！　私の頭、気持ちよすぎて変になっ\nちゃう！！　ふあああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0104124" ]},
		{"command":[ "SETIMAGE", "0", "still_00021001_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「あっ、ああっ、あっあっあっ、隊長さんが動くたびに、頭の中がばちばちっ\nて、白いのがばちばちって！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「なに、これはなに……あああっ、あっ、ああっ、え？　イく？　これがイく\nってこと？　隊長さんとのセックスで、私がイく？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「んあああっ！！　中で脚をねじっちゃ駄目っ！！　ああっ、あああっ駄目っ\n、駄目ですっ！！　こんなに気持ちいいの駄目ぇっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0104127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ひうっ、イくときは言え？　ふあっ、ああっ、んんっ、分かり、分かりまし\nた、からっ、中で脚を暴れさせないでっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「あうんっ、んっ、くああっ、隊長さん、隊長さん！！　セックス、気持ちい\nいっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「隊長さんも気持ちいいですか？　ふあっ、ああっ、良かった。あっ、んっ、\nあああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「あうううっ！！　クリトリスと、おまんこ、両方責められて……あっ、ああ\nっ、あっ、駄目っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「イく！！　イく！！　私、隊長さんとのセックスでイきます、んんっ、ふあ\nああああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0104132" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021001_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「あうっ、あっ、隊長さんのおちんぽから熱いのが……んんっ、私のおまんこ\nに締めつけられて、隊長さんもイったんですね……あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ふっ、うっ、搾り取られるみたいで気持ちいい？　よかった……気持ちよく\nできて、よかった……はあっ、あっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「んんっ、これがセックス……男の人との交わり……凄く、よかった……教え\nてもらって、よかった……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0104135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「私のおまんこで、隊長さんの下半身全部を感じてます……ふふ、なんだか隊\n長さんを産んでるみたい……気持ちいい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0104136" ]},
		{"command":[ "SETIMAGE", "0", "still_00021001_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「あっ……隊長さんの精液が塗りつけられてるのが分かります……ふふ、妊娠\n、しちゃうかも」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0104137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「んんっ、ふっ、隊長さん、気持ちよかったです……私を、隊長さんの女にし\nてくれて、ありがとうございます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「やんっ、隊長さんも嬉しいって……本当ですか。だったら私たち、相思相愛\nですね、ふふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0104139" ]},
		{"command":[ "SETIMAGE", "0", "still_00021001_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「お腹の中が、とくとくって幸せに鳴っています……セックスの喜びって、こ\nういうものなんですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「あっ……んっ、隊長さん？　どうしたのですか……ひあっ、あっ、また、そ\nんな動いたら……んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0104201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「あっ、おちんぽがまた硬くなってる！！　んっ、二回、二回目？　このまま\n、ですか？　ふあっ、あああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0104202" ]},
		{"command":[ "SETIMAGE", "0", "still_00021001_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「私のおまんこが気持ちよくてまた勃起してきたって……分かりました、私も\nまだ身体が熱いので……んっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「あんっ、あっ、なんだか、さっきよりももっと気持ちよく……んんっ、それ\n、つま先とおちんぽで中をごりごりってするの、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0104204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ああっ、隊長さんの身体で私の中がぐじゅぐじゅに、んんっ、はっ、あっ、\nさっきのでもっとぬるついて……ふああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0104205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、あっ、つま先で奥をコンコンって叩かれたら……ふうっ、あっ\n、なんだかお腹が切なくなって……んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0104206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「んっ、うっ、きゅっきゅって締めつけると隊長さんの身体がびくびくってな\nってますよ。これ、気持ちいいですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ふふ、ならもっとしてあげますね……んっ、ふっ、やんっ、隊長さん、動い\nちゃ駄目です、ひあっ、あっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0104208" ]},
		{"command":[ "SETIMAGE", "0", "still_00021001_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「駄目ですってば、あんっ！！　もう、じゃあ、二人で気持ちよくなりましょ\nう、んっ、ああっ、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ふうっ、うっ、締めつけると、隊長さんの脚とおちんぽの形がより一層分か\nって……ふあっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0104210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「んんっ、私の中を、隊長さんの身体が動き回って……なんだか、これ、凄い\n幸せが……ふああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0104211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ああ、あっ、あうっ、これ、この感覚、今、隊長さんと交わってるって実感\nします！！　んううううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0104212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「はっ、あっ、んっ、来た、また来た、イく、イくのが来ました！！　隊長さ\nん、隊長さんはどうですか？　んあっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0104213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「あっ、隊長さんのおちんぽも、私の中に当たってびくびくしてます。隊長さ\nんもイきそうなんですね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0104214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「一緒に、一緒にイきましょう！！　それがセックスなんでしょう？　ふあっ\n、あっ、あんっ、あっあっあっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0104215" ]},
		{"command":[ "SETIMAGE", "0", "still_00021001_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「んんっ、隊長さんの脚とおちんぽで、中をこんこんってこづかれて、ふっ、\nうっ、ああああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0104216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「あっ、んっ、お腹、お腹の中から気持ちよさがじんじんって、頭の中まで…\n…溶ける、溶けちゃう、私、戦士なのに、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0104217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「戦士なのに隊長さんのおちんぽで気持ちよさで溶けちゃうっ！！　うあっ、\nあっ、はっ、ああああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0104218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「イく、イく、イっく、隊長さんのおちんぽで、イくうっ！！　隊長さん、隊\n長さんもイって！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0104219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ひあっ、ああっ、イっくううううううううう！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0104220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「あふっ、ああっ、あっ、また熱いのが中に……んんっ、隊長さんの精液、注\nがれてる、赤ちゃんの素、注がれてる……んっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0104301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021001_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「あうっ……んっ……なんだか、お腹の中がとくとくって鳴ってます……隊長\nさんの精液で、私のお腹が……んうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ふふ、もしも赤ちゃんができたら、戦士から母親になってしまいますね……\nんんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0104303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「地球人と私で子供ができるかわからない？　できますよ、きっと。私と隊長\nさんなら、可愛い子供ができます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0104304" ]},
		{"command":[ "SETIMAGE", "0", "still_00021001_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「やあっ、んっ、ふふ、まあ冗談はさておいて、二回目も濃いですね。なんと\nいうか、身体の中から気持ちよさがにじみ出てきます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0104305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「こんなに気持ちいいのなら、もっと早く勇気を出して誘っておけばよかった\n。セックス、もっともっと知りたいです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0104306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「また……お願いできますか？　次だけじゃなく、その次も、その次も、ずっ\nとずっとその先も……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0104307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「私、隊長さんとなら何度だってセックスできます。今日みたいな形じゃなく\nても、もっと色々と……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0104308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「隊長さんも、私にしてほしいこと、覚えてほしいことがあれば遠慮なく言っ\nてくださいね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ふふ……ですから、今後ともよろしくお願いします、隊長さん。いえ……あ\nなた」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「んあっ、あっ、なんで、隊長さん、抜かないで、行かないで、あっ、私の顔\nに……ふあっ、あああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0104401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021001_02_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「んううううううっ！！　私の顔、眼鏡に……隊長さんの精液が……あんっ、\nあっ、ふああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0104402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「あんっ、眼鏡のレンズが真っ白に……それに熱くて匂いも……んっ、味も…\n…んくっ、んっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0104403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ふうっ、あっ、悪い人ですね、隊長さんは……私の誇りでもある眼鏡をこん\nな風に汚して……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0104404" ]},
		{"command":[ "SETIMAGE", "0", "still_00021001_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「まだ出すんですか……隊長さん以外の人がこんなことをしたら、即座に殲滅\nですよ……やんっ、言ったそばからまた出して……んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0104405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ふうっ、ふっ、んん、マーキングされてるみたいで……隊長さんにされてる\nと思うと、それも悪くはないですね……んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0104406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「あっ、ああっ、んっ、私のおまんこから隊長さんの精液が……んっ……ふっ\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0104407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「んっ……気持ちよかったです……これが男女の営み……セックスなんですね\n。隊長さんに教えてもらって、幸せです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0104408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「中に出されるのも、顔にかけられるのも、どちらも嫌いではないですが……\nそれでも」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0104409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「次にするときは、やっぱり中に出してくださいね。あなたの赤ちゃんが欲し\nいですから……ね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0104410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}