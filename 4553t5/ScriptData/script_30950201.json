{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0084" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「どうだ、隊長？　このビーチは端から端までぜーんぶアタイの縄張りなんだ\nぜ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0203101" ]},
		{"command":[ "SETCHARA", "0", "char_00009502_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「まあ、つまりサメがでるビーチってことで、シーズンなのに人気がねぇわけ\nだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0203102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「そのサメってのは、アタイの舎弟のヤツらなんだけど。へへっ、そういうわ\nけだから、隊長、ここなら思いっきり……できるぜ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0203103" ]},
		{"command":[ "SETCHARA", "0", "char_00009502_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「んっ、後ろからしようってのか？　ああっ、すっごいな……隊長のチンポ、\nもうガッチガチじゃねーか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0203104" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00009502_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「まったく、ミュータント相手にこんなにチンポ勃起させやがって、とんでも\nねぇド変態ヤローだな、ははっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0203105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「んくっ、はぁっ、隊長の手が……ンッ、アタイの尻を、撫でまわして……ん\nっ、んふぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0203106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「さ、サメ肌の尻を撫でたって、気持ち悪いだけだろうが……んっ、あっ、あ\nはぁ……んふぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0203107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「な、撫でられて感じてるって！？　ば、バカ言うんじゃねーよ。これくらい\nで、アタイが感じるはず……んっ、ふはぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0203108" ]},
		{"command":[ "SETIMAGE", "0", "still_00009502_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「クソッ、テメーはどうしてこう手つきがやらしいんだよ……。はぁ、はぁ…\n…んふっ、うっはぁ……あはぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0203109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「あ、あんまり調子ノんなよぉ……？　そんなに、サメ肌が好きなら、思いっ\nきり味わわせてやるからよ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0203110" ]},
		{"command":[ "SETIMAGE", "0", "still_00009502_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「へへっ、ど、どうだぁ……？　テメーのチンポを、思いっきりアタイの尻で\nしごいてやるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0203111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「こうしてっ、ンッ、ンッ！　バッキバキの勃起チンポにっ、アタイの尻を、\n擦りつけて……ンッ、ンンッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0203112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「どうだ？　んっ、サメ肌でっ、感じてるのは、テメーの方だろうがっ！　は\nぁっ、はぁ……っ！　んぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0203113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「めちゃくちゃっ、ンッ、チンポ熱くしやがって……んぁっ！　肌に擦れるだ\nけでっ、やけどっ、しそうだぜっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0203114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁっ、んっ、んっ、ああ……っ！　クソッ、マジでとんでもねぇ\nチンポだぜ……んっ、んくぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0203115" ]},
		{"command":[ "SETIMAGE", "0", "still_00009502_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「チンポが、尻の間でビクンビクンして……ンッ、隊長の興奮が、アタイにま\nで伝わってくる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0203116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「んっ、あっ、アンッ！？　て、テメー、なに勝手に、尻を揉んでっ、んぁっ\n、あふぅっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0203117" ]},
		{"command":[ "SETIMAGE", "0", "still_00009502_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「ああっ、ん……っ！　アタイの尻を、んくっ、まるでパイズリするみたいに\nチンポ挟むのに使って……ああ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0203118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「アタイの尻肉がっ、ンッ、さっきよりもチンポに密着して……んぁっ、熱い\nのがっ、伝わってくる……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0203119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「んぁあっ、ああっ、んはぁっ！　ひ、人の尻を、好き勝手してんじゃ、ねー\nぞ！　はぁっ、はぁ……っ！　ああっ、ン……ッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0203120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「こうなったら、本気で尻ズリしてやっかんな！　そらっ、そらっ！　このっ\n、アタイの尻ズリで、チンポもっとおっ勃てやがれっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0203121" ]},
		{"command":[ "SETIMAGE", "0", "still_00009502_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「……って、本当にさっきよりも硬くっ、んぁっ、チンポが膨らんできやがっ\nたっ！　んっ、ああっ、チンポ、ますます熱い……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0203122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁっ、ンッ、ああっ！　尻にっ、ンッ、テメーのチンポっ、擦れ\nまくってるっ、ンッ、感じる……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0203123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「て、テメーは、どうなんだよっ！　ンッ、アタイの尻っ、そんなに気持ちい\nいのかっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0203124" ]},
		{"command":[ "SETIMAGE", "0", "still_00009502_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁっ、サメ肌尻ズリ、気持ちいいかって、ンッ、聞いてんだよっ\n！　ンッ、ああっ、んんぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0203125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「ははっ、そんなに気持ちいいかっ！　ンッ、ド変態めっ！　んぁっ！　アタ\nイもっ、テメーのチンポ、気持ちいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0203126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「熱くて、汗臭ぇチンポ、尻に擦りつけられてっ！　ンンッ！　アタイもっ、\n全身熱くっ、なってきた……んぁあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0203127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「隊長、もう、イキそうなのか？　ンッ、アタイの尻を掴んで、自分からチン\nポ擦りつけてきて……あんっ、射精しそうかよっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0203128" ]},
		{"command":[ "SETIMAGE", "0", "still_00009502_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「いいぜっ、射精させてやる！　アタイの尻でっ、思いっきり濃いやつださせ\nてやっからよっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0203129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「アタイのっ、尻でっ！　んっ、んんっ！　サメ肌でっ、勃起チンポ、しごい\nてっ、んっ、ああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0203130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「そらっ、射精しなっ！　射精しちまえっ！　んっ、んっ、んくっ！　ああっ\n！　ビクビクっ、チンポっ、震わせて……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0203131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁっ、思いっきり、アタイも腰振ってっ！　ンッ、隊長のチンポ\nをっ、尻で感じる……っ！　んっ、あっ、ああぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0203132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「精液っ、出そうか？　んっ、いいぜっ、隊長の精液っ、ああっ、アタイがし\nっかり、受け止めてやっからよっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0203133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「だからこのままっ！　テメーの好きなようにっ！　ンッ、アタイの尻使って\n、精液っ、ンッ、ぶちまけやがれぇ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0203134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「んんぁあっ！　ああっ、ああ……っ！　あああぁぁぁああぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0203135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009502_01_05" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「ああ……精液……っ！　隊長の精液が、出てる……アタイの、尻にたくさん\nかかって……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0203136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「こんなに……濃い……ヌタウナギの汁みてぇなネッバネバの精液……はぁ…\n…はぁ……熱い……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0203137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「ずいぶん……出したな……？　遠慮なく、どぴゅどぴゅぶっかけやがって…\n…へへっ、この変態ヤローめ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0203138" ]},
		{"command":[ "SETIMAGE", "0", "still_00009502_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「ああん？　尻に精液浴びて嬉しそうだって？　ば、バカ言ってんじゃねえよ\n！　んなわけねーだろっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0203139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「アタイはテメーみたいな変態じゃねーんだよ！　さ、これでもう満足だろ？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0203140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「……って、まだやるのかよ。まあ、テメーのチンポもまだまだ硬いままみた\nいだしな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0203201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「んんっ、なにしてんだよ。ンッ！　さ、さっきの精液っ、アタイの尻に塗っ\nてるのかっ、んんぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0203202" ]},
		{"command":[ "SETIMAGE", "0", "still_00009502_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁっ。尻が、テメーの精液でネットネトになっちまうじゃねーか\nよ……んっ、あぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0203203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「このまま、また、さっきみたいに尻ズリしてほしいのか？　……しょうがね\nえなぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0203204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「んっ、んんっ！　こうか？　んぁあっ、精液のせいで、尻がぬめって……ん\nくっ、あっ、んんぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0203205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「さっきよりも……ンッ、尻に、チンポが密着してる感じがする……んふぅ…\n…はぁ、はぁ……ああ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0203206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「んっ、んっ、このまま、もう一回……ンッ、テメーのチンポ、射精させてや\nろうじゃねーか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0203207" ]},
		{"command":[ "SETIMAGE", "0", "still_00009502_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……っ！　ンッ、テメーまた、アタイの尻を揉んだなっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0203208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「ああっ、んっ、ンン……ッ！　な、なんだよ……尻が、赤くなってる……？\n　んなっ、ことっ、ねえよっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0203209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、尻ズリしながら、発情して……ンッ、青い肌が、赤く……んん\nぅっ！　そ、そんなにジロジロ、尻を見るんじゃねぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0203210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「はぁっ、んっ、んっ、ああ……っ！　んくぅ……っ！　テメーだって、また\n……チンポが膨らんで、きてっぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0203211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「さっき射精したばっかりだってのに、また射精しそうになってるじゃねーか\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0203212" ]},
		{"command":[ "SETIMAGE", "0", "still_00009502_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「それだけアタイの尻が気持ちいいからだって、んなっ、なに言ってんだよ！\n　クソッ、口の減らないヤローだぜっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0203213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「言っておくが、いまはアタイの方が優位なんだからなっ！　イカすもイカせ\nないも、アタイ次第なんだ……って、んひぃっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0203214" ]},
		{"command":[ "SETIMAGE", "0", "still_00009502_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「て、テメー、また思いっきり尻を掴んで、自分で動いてっ、んぁあっ！　ア\nタイが動かないなら自分で動くって、くっ、クソぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0203215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁっ！　そんなにっ、ンンッ！　ズリズリ、チンポ擦りつけて…\n…んっ、ああっ、熱いの……ンッ、尻、やけどする……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0203216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「んふっ、はぁっ、はぁ……ああっ、ン……んくぅ……！　んひっ、はっ、は\nっ、はぁ……ああ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0203217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「尻っ、ンッ、ヌルヌルにっ、チンポ熱いのがっ、ああぁっ！　んくぅっ！　\nアタイの身体までっ、ジンジンしてくるぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0203218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁっ、なんだよっ、さっきから黙って、腰の動きっ、ンンッ、ど\nんどん早くなって……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0203219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「テメー、まさかこのまま……っ！　んっ、まてっ、アタイも、このままじゃ\n……ああっ、ああ……ンッ、ンン……ッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0203220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「んぁああっ！　はぁあっ、あああぁぁぁああぁぁあぁっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0203301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009502_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁっ！　またっ、アタイの尻にぃ……！　思いっきりっ、んぁっ\n、どびゅどびゅ、精液……がぁ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0203302" ]},
		{"command":[ "SETIMAGE", "0", "still_00009502_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「くぅ……くふぅ……。また、こんなに熱くて、ネバネバした精液を……ぶっ\nかけやがってぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0203303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「あ、アタイまで……イッちまったじゃねぇかよ……はぁ……はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0203304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「それにしても……ンッ、そんなに……よかったのかよ……？　アタイの肌、\nザラザラのサメ肌なんだぜ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0203305" ]},
		{"command":[ "SETIMAGE", "0", "still_00009502_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「……って、いまさら聞くことじゃなかったな。テメーがこんなミュータント\nに欲情するド変態なのは、アタイもよく知ってることだった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0203306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「なんだよ。本当のことを言ったまでだろ？　ド変態ではないって？　いやい\nや、ド変態だろうが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0203307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「そんなド変態にぶっかけられてイッたアタイはもっと変態だって！？　テメ\nー、調子に乗ってると食いちぎっぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0203308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「……ったく。ま、あながち間違いじゃねーか。ミュータントのアタイが旧人\n類をこんなところに連れてきたんだから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0203309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「だが、テメーより変態だってのは納得いかねぇ。だから、どっちが変態か、\nこれから勝負といこうぜ？　いいだろ、ド変態の隊長♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0203310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「んっ、ああっ、あはぁああぁぁっ！　あああぁぁぁあぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0203401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009502_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「んなっ、テメー、ちょっとは加減しろっての！　ああっ、こんなに……アタ\nイの身体中に……テメーの精液がぁ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0203402" ]},
		{"command":[ "SETIMAGE", "0", "still_00009502_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「くっそぉ……。思いっきりぶっかけやがったな。こんな……オス臭い汁……\nもう全身ドロドロじゃねーかよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0203403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「んっ、ああぁっ！？　て、テメーなにしやがるっ！　んくっ！　背中っ、撫\nでるな……んぁあっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0203404" ]},
		{"command":[ "SETIMAGE", "0", "still_00009502_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「や、やめろって、精液っ、ンッ、塗るのかよ……ああっ、全身、テメーの臭\nいに包まれちまうだろうが……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0203405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「水の中に潜ればとれるだろうって？　ば、バカッ、そういう問題じゃねーだ\nろ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0203406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「サメ乙女心はまだわかんねーんだな、テメーはよぉっ！　んっ、だから、塗\nるなって……んっ、んくぅううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0203407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「か、身体をビクビクさせて、イッたかって！？　い、イクわけねーだろっ！\n　こんな……ことでよぉ……ンッ、んふぅうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0203408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「テメー……いい加減にぃ……。ンッ、クソッ、しっかり尻を掴んで……んぁ\nっ、ああぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0203409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「くっそぉ……。アタイの反応を見て面白がってやがるな……。テメー、覚え\nてろよっ！」", "NORMAL" ]},
