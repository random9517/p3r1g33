		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「え……まだ、出そうなのね……？　んっ、いいわ……もっとシコシコして…\n…射精のお手伝い、してあげるから……あんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1103405" ]},
