{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000211_01_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「今日は、予行練習に付き合って欲しいの。何のって……それは、つまり……\nほら……私達、結婚しているでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1103101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「そしたら、そのうち子供が出来る訳で……そうしたら……やっぱり、母乳で\n育ててあげたいじゃない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1103102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「でも、いきなりぶっつけ本番で上手く出来るか分からないし……だから、あ\nなたに協力して欲しいの……もちろん、ちゃんとお礼はするから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1103103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んっしょ……これで、いいわ……ほ、ほら……おっぱい……好きでしょう？\n　今日は、遠慮なく吸っていいから……あんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1103104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んっ、そう……んっ、ぱくって咥えて……ゆっくり……ちゅうって吸ってみ\nて……んぁっ、ふっ……んんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1103105" ]},
		{"command":[ "SETIMAGE", "0", "still_00000211_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「その、ちゃんと母乳が出たらいいんだけど……気分だけなのは、ごめんなさ\nい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1103106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あ、ただ……その代わり……こっちの方……して、あげるから……んっ、ふ\nっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1103107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「そう……オチンチン……扱いてあげる……ほら、ドレスの手袋の感触……い\nつもと違うでしょ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1103108" ]},
		{"command":[ "SETIMAGE", "0", "still_00000211_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あぁ……むくむく大きくさせて……興奮してるのね……うん、任せて……じ\nっくり時間を掛けて、優しくシコシコしてあげるから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「じゃあ……本格的に練習、ね……はぁい……おっぱい、飲みましょうね……\nんっ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ちゃんと上手く飲めたら……いっぱいオチンチン……気持ちよくしてあげる\nから……うん、好きなように飲んでみて……あっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1103111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んんっ、あぁっ……唇がっ……乳首……柔らかく、挟み込んでる……ん、ふ\nっ、そう……あっ、あんっ、はんっ……んっ、あっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1103112" ]},
		{"command":[ "SETIMAGE", "0", "still_00000211_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「え……か、硬く……なって来てる……？　そ、それは……だって、こんな風\nに刺激されたら……自然に、尖って来ちゃうもの……あっ、んくっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「そ、その方が……出やすくなったり、するのかな……んっ、赤ちゃんが飲む\n時も……こんな気持ちになっちゃうのかしら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あ、ご、ごめんなさい……うん、ちゃんと……オチンチンの方も忘れないで\n動かすわ……んっ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1103115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あぁ……こっちも、ビンビンに大きくさせて……小さく震えてる……すごく\n、生々しいのね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1103116" ]},
		{"command":[ "SETIMAGE", "0", "still_00000211_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「手袋越しでも……こんなに熱を感じるなんて……血が集まって来てるから…\n…？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「だったら、もっと……よくしてあげないとね……さすさす……こすこす……\nんっ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「どう？　オチンチン……気持ちいい？　ふふ……よかった。うん、リラック\nスしててね……焦らず、じっくりしていくから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「でも、こうして……さすると……くちゅって……オチンチンから音がしてく\nるのね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「この音……何だかとってもイヤらしい……んっ、私も……ドキドキしてきち\nゃうの……あっ……はぁんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あぁっ、音なら……こっちもって……あんっ、それは……あなたの、口がさ\nせてる……音ぉっ、ひ、ぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「そんな、あっ、舌が……れろれろって……あ、赤ちゃんは……そんな風に乳\n首……し、しませんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「えっ……わ、分からない？　それは……確かに、絶対にしないとは……言い\n切れない、けど……あっ、んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1103124" ]},
		{"command":[ "SETIMAGE", "0", "still_00000211_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「し、刺激に慣れないと……失敗するかも……？　わ、分かったから……あっ\n、ちょ、ちょっとだけ……手加減して……は、ひっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あ……やだ……ドキドキする……おっぱい……舌先で転がされちゃうの……\nあんっ、変な感じっ……はっ、ひっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「先が……硬くなって……あっ、コリコリを刺激されるの……ムズムズして、\nひゃっ、ひぅんっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「い、今……歯が……当たったのっ？　やっ、そんな噛むなんて……あっ、ダ\nメ……そんなの……母乳飲むのと関係ないのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あんっ、あぁっ、でも……今の、いい……かもっ、はんっ、んんっ……私も\n……するっ……オチンチン……ぎゅってっ……しちゃうのっ……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んっ、ここの……血管が浮き上がってる所……やっぱり気持ちいい……？　\n何度も何度もさすってあげて……気分高まって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「はんっ、あぁっ、もっと吸ってぇ……あぁ……おっぱい、すごく感じちゃう\nっ……乳首……あぁっ、気持ちいいのっ、あんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「こんな、あぁっ、母乳をあげる練習の筈なのにっ、乳首……はぁんっ、良す\nぎてぇっ……あっ、変になっちゃいそうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あぁっ、あなたのオチンチンもビクビクしてるっ、気持ちよくなってっ……\n射精したくなってるのね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「いいよ……我慢しないで……いっぱい、ぴゅっぴゅって……射精しちゃって\n……大丈夫だからっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1103134" ]},
		{"command":[ "SETIMAGE", "0", "still_00000211_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ね……手袋の感触……気持ちいいんでしょう？　我慢しないで……思いっき\nり出してっ……射精……してぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1103135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あんっ！　出て来たっ……こんなにいっぱいっ……あっ、噴水みたいに……\nびゅくびゅ……出てるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1103136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000211_01_04" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んふっ……手でしてあげてるだけなのに……こんな元気よく出すなんて……\nふふ……いい子いい子……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1103137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あ……ごめんなさい、何だか本当に赤ちゃんをあやしてるような気分になっ\nちゃって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1103138" ]},
		{"command":[ "SETIMAGE", "0", "still_00000211_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「こんな立派なオチンチンを持ってるのに……でも、たまにはこういう風に甘\nえてみるのもいいでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「うん……私もあやし方の練習と思ったら……何だか気分が出てきちゃったか\nも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「えっと……そういう訳で、もう少し……続き……しちゃう感じで……いいか\nな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1103201" ]},
		{"command":[ "SETIMAGE", "0", "still_00000211_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「まだまだオチンチンはビンビンのままだし……おっぱいも、もうちょっと吸\nいたいって思ってるんじゃない……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ふふっ、うん……分かったわ。さ……赤ちゃん……また、おっぱい飲みまし\nょうねぇー、いい子、いい子～、ふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1103203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あらあら……またヌルヌルの先っぽから、ミルクがもれて来ちゃったねぇ…\n…全部出しきれなかったのかなー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1103204" ]},
		{"command":[ "SETIMAGE", "0", "still_00000211_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「やっぱり、ちゃんとママがシコシコして……全部、搾り出してあげないとダ\nメよね……んっ、オチンチン……シコシコ……シコシコ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んぁふっ……イッたばっかりだから、いつも以上に感じやすくなっちゃって\nるのね……ずっとビクビク跳ねてるの……可愛い……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ひゃんっ……あっ、ふふっ、ごめんなさい。男の子に可愛いなんて、ちょっ\nと拗ねちゃうわよね……もう、おっぱいに悪戯しちゃうなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1103207" ]},
		{"command":[ "SETIMAGE", "0", "still_00000211_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んっ、でも、ママもとっても気持ちいいから……もっと悪戯してちょうだい\n……はぁんっ、おっぱい……はむってしてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あっ、ふっ……舌がチロチロ動いてる……んくっ、エッチな動き……させて\nるの……あんっ、乳首……どんどん立って来ちゃう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んふぁっ、くぅんっ……あぁ、おっぱい……赤ちゃんのよだれまみれになっ\nて……んんっ、でも……気持ちいい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1103210" ]},
		{"command":[ "SETIMAGE", "0", "still_00000211_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「えと……も、もうちょっと……強めに吸っても……いいのよ？　あ……そう\nして欲しいっていう意味じゃ……んぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あっ……あんっ、はっ、歯がっ……あ、当たるぅっ！　あっ、ちょっ……は\nんっ、あぁっ、乳首っ……ぎゅって潰されるぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「はっ、うんっ……い、痛く……あっ、ない……けどっ、はぁんっ、これぇっ\n……変にっ……変になるのっ、はひぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「わ、私もっ……負けて、られない……ぎゅうってっ……オチンチンっ……握\nって……ぐりぐり、シコシコしてっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1103214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「はんっ、あぁっ、どう……？　んっ、出したく……なって来てるっ？　オチ\nンチン……また我慢できなくなってるんでしょっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1103215" ]},
		{"command":[ "SETIMAGE", "0", "still_00000211_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「また……んふっ、ママに見せて……あなたが、いっぱい……ぴゅっぴゅって\n……射精してるところっ、んっ、はぁっ、あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1103216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「好きな所に出して……いいからっ、顔でも……おっぱいでも……どこでもい\nいのよっ、どうしたいっ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あぁんっ、オチンチンビクビクさせてるっ、興奮してるのね……っ、本当に\n……エッチな赤ちゃんなんだからぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1103218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「でもっ……頼もしいわっ……とっても元気なオチンチン射精っ……ママに見\nせてっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ママのおっぱい吸いながらっ……新しいオチンチンミルクっ……ビュクって\n出してぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1103220" ]},
		{"command":[ "WAITINPUT" ]},

