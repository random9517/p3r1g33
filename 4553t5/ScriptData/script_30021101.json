		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あぁっ、おっぱいがいいのっ……？　分かったわっ……あなたの好きに出し\nてっ、はぁっ、あぁぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1103301" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んぁっ……びゅくって……おっぱいに精液出てるっ……熱いのっ……びゅく\nびゅくしてるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1103302" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000211_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「はぁぁぁ……んっ、やんっ……それでも、おっぱいから口を離さないの……\n？　もう……本当に甘えん坊さんなんだから……ふふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1103303" ]},
		{"command":[ "SETIMAGE", "0", "still_00000211_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「でも、それだけママのおっぱいが好きってことよね……？　あっ……ふふっ\n、オチンチンも、そうだって言ってるみたい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1103304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「まだ、ちょっと奥に残ってるんでしょ……ほら、出しちゃって……びゅびゅ\nって……んっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1103305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あんっ……ふふっ、本当に元気なのね……もう、手袋がすっかりベトベトに\nなっちゃった……れろ……ちゅぷっ……んっ、濃い……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1103306" ]},
		{"command":[ "SETIMAGE", "0", "still_00000211_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「はぁ……乳首も、まだジーンって痺れてる……んっ、あぁ……もういい？　\nごめんなさい、離すわね……んっしょ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1103307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「はふ……私も、ちょっとイッちゃった……んっ、少し……クラクラする……\nはぁ……深呼吸して、気持ち……落ち着けないと……はふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1103308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「その、今日は……付き合ってくれて、ありがとう……何となく感覚は掴めた\n気はするけど……実際にやるとどうなるか分からないから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「だから、また本当に母乳が出るようになったら……その時は、改めて……お\n願いしてもいい……？　ふふっ、よろしくね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あぁっ、えっ……顔に……掛けるつもりなのっ？　い、いいけど……そんな\nに飛ばせるの……大丈夫……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1103401" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ひぁんっ！　あぁっ、ほ、本当に届いてるっ……んんんっ！　わ、分かって\nる……よけたり……しないわっ……んっ、ちゃんと……浴びればいいのよね…\n…？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1103402" ]},
