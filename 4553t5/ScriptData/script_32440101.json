{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「セリオンです。今、お時間よろしいでしょうか……？　ああ、良かった。ど\nうやら、お暇を持て余していらっしゃったご様子……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0103101" ]},
		{"command":[ "SETCHARA", "0", "char_00024401_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「え？　私がなぜ訪ねてきたのか、ですか？　賢く強い貴方のことです。大方\n察しはついているでしょうに……。言わせるのですか？　ふふふ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0103102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「私も……皆様と同じく、貴方に日頃のお礼をしに参りました。でも……私の\nお礼は、他の女の子達とは一味も二味も違いますよ？　お覚悟を……ふふ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0103103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「さ。目を閉じてください。そうです……そうして、私に全てを委ねてくださ\nい。力を抜いて……まだですよ？　まだ……。はい、良いですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0103104" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "sbg_0000" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「……驚きましたか？　お口や胸での奉仕ではなく……私はほんの少し、邪道\nな……しかし、刺激的な提案をさせていただきます。そうです、脚……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0103105" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024401_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「それも、太腿で貴方をうんと癒して、ほぐしてさしあげますね。下品な言い\n方をすれば……ええ。太腿コキ、と言うんでしょうね。これは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0103106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「ふふふッ……♪　なかなか、こんなことをしてくる人はいなかったんじゃあ\nありませんか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0103107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「あら……もう、こんなに興奮してくれているのですね。いけない人……。女\nのこんな部分に……性器でもない場所に昂って、期待をして……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「でも、そうやって欲望に素直な貴方のことを……私は慕っているのですよ？\n　とても純粋で……その分欲望の強い貴方のことを……。ですから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「好きなだけ、楽しんでいただけるように尽力します。さて……それでは、始\nめましょうか。じっくりと、私の太腿の感触に集中してください……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「んんっ……ふふふっ……♪　ふぅっ……体温が、肉棒に伝わってきますよね\n……？　そして、ほどよく鍛えられた柔らかな肉の感触……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0103111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「肉棒を包みこむ女の肉……。んんっ……いいえ、ここは劣情を煽るためにも\n卑猥な単語に置き換えましょうか。私の太腿にまとわりつかれたオチンポ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「オチンポ様が、硬く硬くこわばるほどに……んっ、太腿の弾力が直接伝わっ\nてくるでしょう？　どれだけ押しても跳ね返り、吸いつく柔肉……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「しっとりモチモチした質感には、自分でも自信があるんです……。ふふ、右\n足、左足……両側からぎゅ～～～っとオチンポを挟みこんで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「んふっ……♪　どうしたんですか？　今……ピクピクと肉茎が反応しました\nよ？　こうしてキツ～く締めつけられるのがいいんですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0103115" ]},
		{"command":[ "SETIMAGE", "0", "still_00024401_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「変態なんですね……？　え？　私の太腿にこうされたら、誰でもそうなる？\n　そうでしょうか？　ここまで硬くする方はなかなかいませんよ、きっと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0103116" ]},
		{"command":[ "SETIMAGE", "0", "still_00024401_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「貴方がヘンタイさんだから、太腿なんかで勃起しちゃうんです……♪　でも\n、安心してください……私も興奮しています」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「貴方の、屹立したオチンポを……女の恥ずかしい場所のすぐ近くに押し付け\nられて……。んッ……少し動かせばアソコに触れてしまう近距離で……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0103118" ]},
		{"command":[ "SETIMAGE", "0", "still_00024401_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「こんなにバキバキに勃起を感じたら……ドキドキして……ムラムラします。\nこれが、貴方のモノなんだって……うふふふ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「はい。すべすべでプニプニの太腿を、自由に使ってくださいね。……そうで\nすよ？　私の両脚とエッチする気持ちで……この、脚の隙間に……ンッ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「オチンポを出し入れして……肉が引っかかるのを楽しむんです。……あっ…\n…！　前後に腰を揺すって……！　ふふっ、いいです……上手です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「パンパンと音をたてながら……セックスしているみたいに、……んっ。私の\n太腿を犯すんです……。ふはっ……♪　んふっ……やぁだ、くすぐったい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「でも、気持ちいいですよ……？　オチンポの熱がどんどん上がって……あっ\n、オマンコに伝わってきます、……んっ……そしてこの強引な……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「強引な、肉を描き分けるピストン……っ♪　はぁっ……はぁ、はぁ……なん\nだか、本当にセックスをしているみたいじゃないですか……？　っぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「いけないオチンポです、ねぇ……♪　ヤンチャで、イタズラっ子で困ってし\nまいます……。っふ……♪　こんなにコチコチにして……悪いオチンポ様♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0103125" ]},
		{"command":[ "SETIMAGE", "0", "still_00024401_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「んぁっ……！　んん……！　ズリッ……ズリッてお肉が動かされる感覚……\nこれ、クセになりますね……。はぁっ、必死で、可愛くて……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「あんっ、んっ……はい♪　大丈夫ですよ……もっともーっと締めてあげます\n……。キツくて動けなくなりそうなくらい……限界まで。そぉれ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「あっ♪　キュウキュウに締まった太腿を、こじあけるようにして……突くん\nです♪　……んぁふぅっ！　あっ……私の全身が揺れる、くらい……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「あっんっ……いいですよ……あっ……！　もっと揺らしてください……。あ\nっ……！　すごい、太腿がめくれます……この力強さ……はぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「男らしくて素敵です……っ。あっ♪　透明なお汁が滲み出してきていますよ\n……？　私の太腿に塗り塗りと……ふふふっ、気持ちいいです……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「先走りのお汁で滑りが良くなって……ますます熱が入ってきましたね……？\n　上手、上手、……っひぅっ！？　ヌルンッと滑って……緩急がついて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「予測不可能な動きで、太腿……ふとももが描き回されて……！　あっ……い\nいっ……いいです、私も気持ち良くなってきました……もっと♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「欲望のままにっ……！　あぁっ♪　あぁ、あぁ……！　いいっ……いい……\n！　ニュルニュルで掻き回されて、突かれて……頭がぼうっとします！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「は、ぁ……♪　あぁっ……！　太腿が熱い……、ぁっ……！　ヌルヌルが拡\nがってく、私の脚からチュプチュプ卑猥な音が聞こえて……響いて……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「貴方のケダモノみたいな腰使い……とても気に入ってしまいました♪　孕ま\nせたいんですか？　私の太腿……あっあっ、そこは妊娠しないのに♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0103135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「太腿に精子を放出して……種付けするおつもりですか？　いいんですね？　\n足にびゅるびゅるおもらししちゃうんですね？　……してください？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0103136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「っきゃぁあああっ……♪　あぁ♪　まるで噴水ですっ……！　私の太腿に圧\n迫されて……勢い良く飛び出す精子……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0103137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024401_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「あふっ♪　んふっ……ふぅううっ……。プルプルの、ゼリーみたいな白濁液\nが……自由気ままに撒き散らされて……ああ、もう制御不能です……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「まだですよね？　まだ尿道に残っていますよね……それを全て、私が脚で絞\nりとりますよ……♪　そぉれ……出しちゃってください、ぜんぶ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「びゅるびゅるびゅる♪　びゅるびゅるびゅる……♪　っはぁあああ……♪　\n床に水たまりが出来そう♪　ねちゃねちゃの水たまり……うふふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「あたり一面がすごい臭いに包まれていますよ……。はぁっ、もちろん……私\nの下半身にも……。精液って本当にすごいんですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0103201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「ただのお水かと思っていたのに、こんなに存在感があって……♪　ネバネバ\nと私の太腿にくっついてきます。……んっ、いやらしいお汁……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「……あら？　こんなに精子を出したのに……オチンポがまたヒクヒクして…\n…？　一度では満足できませんでしたか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0103203" ]},
		{"command":[ "SETIMAGE", "0", "still_00024401_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「えっ？　射精してからも私がお股に挟んだままだから、その感触とぬくもり\nでまた勃起してしまった？　あら……あらあらあら。確かに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0103204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「ふふ……まだ、スッキリし尽くした感じはしませんね……？　残りの欲望も\n、この足に解き放ってしまいたい……違いますか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0103205" ]},
		{"command":[ "SETIMAGE", "0", "still_00024401_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「自分の青臭い臭いをふんだんにつけた私の脚……。白濁液でねっとりとデコ\nレーションしたこの太腿を、再び堪能したい……間違いありません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「でしたら、このまま……甘い時間を続けようではありませんか。私もお手伝\nいしますから……。ん……２人で共同作業です、助け合って……。はぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「太腿でぐにぐにとオチンポを良くしますね……♪　あら……あらあらあら…\n…？　言葉よりも早く……下半身が答えてくれていますよ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「たくさん気持ち良くなりたい、って……お望みのままに。私もあなたの興奮\nを、ずっと感じていたいです……。は、ぁっ……♪　来てください……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「……ぁ……っ♪　あらあら……さっきより、更に腰使いが荒々しくなって…\n…私好みです……♪　うふふっ、余裕のない貴方って庇護欲をそそられます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0103210" ]},
		{"command":[ "SETIMAGE", "0", "still_00024401_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「ん、庇護欲というのは～……甘やかしてよちよちしたくなっちゃうってこと\nですよ……♪　母性よりも、もっと利己的で……。っふ……♪　うふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「私で感じている貴方を、メロメロのトロットロに溺愛して……。あっ♪　可\n愛がって、私のものにしてしまいたいという感情です……。っん、ふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「んぁあっ♪　ママの太腿がちゅきなのぉ……？　っふっ♪　いくらでもオチ\nンポこすりつけていいんですからねぇ……♪　な～んて……。あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「きゃっ♪　お……怒りましたか？　あっ♪　だって……脚に、強くオチンポ\nがぶつかってきてます……！　あっ……あっあっ……ごめんなさい……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0103214" ]},
		{"command":[ "SETIMAGE", "0", "still_00024401_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「お詫びにきゅ～～っと締めつけますね……♪　っふ……♪　これくらいです\nか？　もっと……？　んっ……すごい、振動でお尻が揺れちゃいます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0103215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「はぁっ♪　あっ、あっ……あぁ♪　気持ち、いいですか……？　あっ……、\nたまには……脚でするのもいいでしょう？　はぁっ♪　あっ……ぅ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0103216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「貴方がコレにハマってしまって……はぁっ、私の脚でしか射精出来ないよう\nになったら……すごく面白いのに……♪　ふふふ、冗談です、……あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「はぁっ……♪　はぁ、はぁ、はぁぁっ……！　す、みません……っ。私のお\n尻……掴んで持っていてくださいっ……。でないと、でないとぉ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0103218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「意識がトんでしまいそうで……！　あぁ……！　熱い……あついぃ……！　\nオチンポ……太腿にめりこんで……！　あっ♪　こんなの、こんなの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「もうセックスです……！　っあぁんっ……！　腰が浮いちゃいます……！　\nッあぁ……！　あああんっ……！」　", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「出ました……ぁ♪　出て……ふぁあぁッ……！？　いいんですか……？　ふ\nふふっ、こんなに大盤振る舞いして……あああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0103301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024401_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「私の脚に……太腿に、貴方の生命の雫がドロドロと……♪　あぁ、シャワー\nみたい……！　とびきり貴重で特別なシャワー……んんん……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「うふっ、ふふふ、うふふふっ♪　びゅーびゅー……びゅーびゅー上手ですね\nぇ……♪　貴方の臭いを撒き散らしてください……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0103303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「二度と消えないように……あっ、私の腿に……太腿に、貴方の臭いを、貴方\nの種汁を注いでください……！　ああっ、熱い……凄まじい生命力……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0103304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「んんんぁぁああ……♪　はぁ……はぁ、どうですか……？　２回も私の脚に\n射精して……。ここが性器の１つだと認識してくださいましたか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0103305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「ふふ……♪　私の脚でこれだけ気持ち良くなれることを知ってしまったから\nには、貴方はこれから大変ですよ……？　だって、脚ですから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0103306" ]},
		{"command":[ "SETIMAGE", "0", "still_00024401_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「戦いの時にだって、普段暮らしている時にだって……いつでも貴方の目に映\nるではありませんか？　チラチラと、どこでものぞく太腿……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0103307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「貴方はそれを目撃する度に、オチンポがウズウズしてこらえきれなくなっち\nゃうんです……♪　すぐに勃起して、この脚にこすりつけにきて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0103308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「……ふふふふ♪　そんな日常って、とても刺激的でエロティックでしょう？\n　私？　私はいつでも大歓迎ですから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「したくなったら、教えてくださいね……？　この脚は今、貴方のマーキング\nで……貴方の物になりました。何度でも挟んでさしあげます……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「きゃっ……！　きゃあっ……ひゃんっ！？　はぁああんっ！？　あんっ……\n！？　ど……どうして胸に……胸に射精を……！？　ああんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0103402" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024401_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「あつっ……！　熱いですよっ……、あっ……！　飛沫が……顔にまで飛んで\n、……あっ！　胸に大量の白濁液が……あっ♪　あっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0103403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「あはははっ……あはっ♪　なんですか、これは……っ♪　すごぉい……脚か\nら胸にまで精子をほとばしらせてしまうなんて……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0103404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「とんでもない飛距離と勢いですね……あっ！　まだ出るんですか？　あっ…\n…あっ！　どこまで凄いオチンポなんですか……感心しました♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0103405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「あああああ……♪　不意打ちでこんなにたくさん……♪　素敵……。トロト\nロと身体の上をすべる、なめらかな粘液に満たされて……私……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0103406" ]},
		{"command":[ "SETIMAGE", "0", "still_00024401_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「太腿だけではなく、胸まで貴方のものになったんですね……。ふふふ、貴方\nはいつも私の予想を遥かに超えて、覆す人……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0103407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「だから、私も貴方の事を……。と、そんなことは今……どうでもよろしいで\nすよね。はぁっ……♪　見てください、この白濁液の量……この色」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0103408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「そんなに、私の太腿でするのは良かったですか……？　ふふ、それなら良か\nった……。日々のお礼が出来て、こんなご褒美までいただける……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0103409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「これから、私もご奉仕にハマってしまうかもしれませんね。色んなご奉仕を\n考えて……貴方に喜んでもらいたいと思います。お楽しみに……♪」", "NORMAL" ]},
