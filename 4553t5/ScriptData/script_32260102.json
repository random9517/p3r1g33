		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「……ま、待て！　落ち着け……！　本当にこんなこと、する必要があるのか\n？　あたしを騙そうとしてないか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0104101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「心配にもなるだろう！　こんな、押し倒されて……し、しかもチンポ……\n突き出してくるし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「そうだ。それは間違いない……最近やけに身体が火照って困ってたから……\nそのことを相談したが……だからって、どうしてこうなる？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0104103" ]},
		{"command":[ "SETIMAGE", "0", "still_00022601_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「本当か？　本当に必要か？　だって……！　セックスすればいい、なんて\n信じられるわけないだろ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0104104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「や、やめろっ！　それを近づけるな！　とりあえず、おまえは服を着ろ……\n任せろ、じゃないっ！　お、おいってば……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0104105" ]},
		{"command":[ "SETIMAGE", "0", "still_00022601_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「気持ちいいとか、そういうことじゃなくて……なにしてっ……！　んっ！　\nあっ、ああっ……待てっ、ま、んっんんぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0104106" ]},
		{"command":[ "SETIMAGE", "0", "still_00022601_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「やめ、んっ……！　チンポ、押し込む、なっ、あぁぁ……くっ、くううっ！\n　んっ！　はっ、んっ……じわじわ、挿入って、くるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0104107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「はあっ……くっあっ、あぁっ……い、痛い、アソコが……裂けるっ……くう\nうっ……こ、これがセックス……な、のか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0104108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「ひっ、あっ……はぁはぁ……だ、大丈夫、だけど……ちょっと、あぐっ……\nやっぱり、ダメだ……それ以上、奥は……あぁぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0104109" ]},
		{"command":[ "SETIMAGE", "0", "still_00022601_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「くひぃいっ！　はっ、はひっ……お、おく、まで……挿入った？　んっ、\nあぁあ……は、初めてに決まってるだろ……くうっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0104110" ]},
		{"command":[ "SETIMAGE", "0", "still_00022601_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「身体の火照りを、どうにかしたいって思っただけなのに……なんで、こんな\nことにっ……くっ、うっ、ううっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0104111" ]},
		{"command":[ "SETIMAGE", "0", "still_00022601_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「セックスして、アクメ……すればいい、って簡単に言ってくれるけど……\nひっ、ぐっ……い、痛ぃ……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0104112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「まだ……痛みは、ある……んああっ！　動かすなっ……！　ゆっくり、でも\n……あっ、ああっ……ンっ！　んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0104113" ]},
		{"command":[ "SETIMAGE", "0", "still_00022601_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「はっあっ！　あっ……あんっ！　チ、チンポで、かき回されてるっ……中で\n、動いてるの……わかる……くひぃいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0104114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「た、確かに……ゆっくりしてるだけなら、そこまで痛くない、が……んっ、\nんっ……チンポで腹の中から、撫でられてるみたいで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0104115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「はんっ、あっあぁっ！　なんだ、この感覚……今まで、味わったことない…\n…ンあっ！　あぐっ、あっ……あふうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0104116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「だんだん慣れてきてる……のか……？　わから、ないっ……自分の身体なの\nに……なにが起こってるか、全然っ……あぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0104117" ]},
		{"command":[ "SETIMAGE", "0", "still_00022601_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「待てっ……！　力を入れるな……あぁ、あっあんっ！　ゆっくりしろ……\nゆっくりぃ……ひぃいっ！　はっ、ひぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0104118" ]},
		{"command":[ "SETIMAGE", "0", "still_00022601_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「ちょ、ちょ、とっ……待てって、言ってるのに……！　腰、強い……んんっ\n！　擦れてるっ……チンポが擦れてるぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「はあっ？　これで、優しく……してる方のか？　んっ、んんっ……！　あっ\n、あっ……くはぁっ、あぁあんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0104120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「おまえのチンポが……腹の中でぇ……んひぃっ！　は、腹……ではなく……\nマンコ？　地球では、そう呼ぶのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0104121" ]},
		{"command":[ "SETIMAGE", "0", "still_00022601_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「ンうっ……そ、そのマンコ、だ……マンコが、チンポでいっぱいになってて\n……擦れるたびに、身体が痺れてぇ……んんぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「はぁあっ、はっ……あんっ！　はっンっ……！　痛み、は……多少マシに\nなってきたが……あっ、あふう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0104123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「それより、今は……身体が火照って……んあっ！　身体が……全身が熱くて\n堪んないっ……！　んっあっ……んはぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0104124" ]},
		{"command":[ "SETIMAGE", "0", "still_00022601_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「セックス、したら……火照りは、おさまる……んっ……じゃ、なかったのか\n……はっあっ……はぁあっ……あんっ、あんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「アクメ？　絶頂……？　それはどうすれば……んぅンっ……こ、このまま…\n…おまえに任せてればいいのか？　わ、わかった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「んっあっ！　あっ、はぁあっ……なんか、どんどん……腰、速く、なってな\nいか……？　やっぱり……あっああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0104127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「い、痛みも……完全になくなったわけじゃないが……んっ、くひっ……最初\nよりは……マシになって、る……んぅうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「はぁあっ……！　あんっ！　こ、声……出てる、のは……んあっ！　勝手に\n……あっ、ああっ！　マンコ……かき回されてるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「あんっ……！　あっ、あっ……またチンポ、おっきくっ、なってっ……ひぃ\nいっ！　ひっ、くはっ……はっあぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「はっ、はひっ！　待て……チンポ、激しいっ……！　あっ、あっ！　チンポ\nっ……すごっ、いいっ！　チンポっ……チンポっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「あっんっ！　あはぁんっ！　ひっ、ひぐっ……マンコが、熱いっ！　ああっ\n……！　あっ、あっ……はぁぁぁぁぁぁぁぁぁ～～～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0104132" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022601_02_05" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「ひいっ！　あっあひっ……ひぃいぃぃぃんっ！　出てっ……！　中で、出て\nるぅぅぅっ！　熱いのがぁっ……あっあぁぁっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「な、なにが……起こって……なんだ、これはぁ……あぁあっ……ザーメン？\n　これが……子種汁、なのかっ……んっ、んううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「あっくぅぅっ……！　すご、いぃぃっ……マンコが、ザーメンで満たされて\nいくっ……んっああっ！　はっ、はぁぁあっ……くふぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0104135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「あ、あぁ……あ、あっという間で……はぁ……はぁはぁ……気持ちいいとか\n、そういうのでは……んっ、あぁぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0104136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「そもそも、身体は火照ってままだし……むしろ火照りは強くなってる……\n見ろ、身体中が汗でぐちょぐちょだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0104137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「全然、話が違う……だろ……はぁあ……身体、どんどん熱くなってる……\nはっ、あっ……はーっ……はぁはぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0104138" ]},
		{"command":[ "SETIMAGE", "0", "still_00022601_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「……もっと？　もっとセックスしまくって……アクメしないとダメ？　てこ\nとは……まだ続けるわけ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0104139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「いや、痛みはもうそれほどでも……あっ、ちょっと待てっ……！　まだ身体\nがふわふわしてて……あっ、ああんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「そもそも……んっ……お、おまえは……射精したばっか、なのに……続けて\nできるのか？　んっ……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0104201" ]},
		{"command":[ "SETIMAGE", "0", "still_00022601_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「男は、一度射精したら……チンポが萎えると聞いたが……？　全然、話が\n違う……ようだな……あっ、あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「はっ、あはぁっ……！　気持ちよくて……興奮してるから……連続で、でき\nる？　そういう、もの……なのか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「あ、あたしとのセックスが特別……？　急に、恥ずかしいこと言い出すなっ\n……！　これは……火照りを冷ますためにっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0104204" ]},
		{"command":[ "SETIMAGE", "0", "still_00022601_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「くぅんっ……あっ、あぁんっ！　だから、強いっ……腰、いきなり激しく\nぶつけるなぁ……ひぁあっ、あっあっ……ひぃいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0104205" ]},
		{"command":[ "SETIMAGE", "0", "still_00022601_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「ンあっ……！　チンポが……またマンコの中をかき回してるっ……！　ひっ\n、んひっ！　ああぁっ、あはぁぁぁっ……！」", "NORMAL" ]},
