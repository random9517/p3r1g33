		{"command":[ "SETTEXT", "「あっはっ……！　ま、またさっきと同じっ……頭、変になるっ……い、いく\nっ？　んっああっ……！　しゃせぇ、するのかっ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0104215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「いい、いいぞ……出してっ……！　出し、てっ……あっ、あっあぁぁっ……\n！　あたしの中にっ……んっ、はああぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0104216" ]},
		{"command":[ "SETIMAGE", "0", "still_00022601_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「は、あはぁっ！　激しいっ……！　チンポっ、チ、チンポぉ……すごいっ…\n…あっ、んっンンっ！　あぁんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0104217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「あ、たしも……もうっ！　もおっ……おっ、おおっ！　んっおっ……ア、ア\nクメ……！　チンポアクメくるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0104218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「ンンううっ！　おっ、おほぉおっ……！　いくっ……い、いくっ！　はっ、\nあぁあぁっ！　ダメっ……だっ……頭が真っ白にぃっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0104219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「お、おまえも……出してっ……！　ひっ、あっ、ああぁっ！　んっあぁぁっ\n！　あっ、あひぃぃいぃぃいぃ～～～～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0104220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「はっあぁぁぁあっ！！　あっあああっ！　出て、るぅぅっ……！　またっ…\n…奥に、熱いのがぁっ……んっ、ンはぁぁぁっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0104301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022601_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「ひっひぃっ……はひぃ、あひぃいっ……！　あぁっ……マンコが、ザーメン\nで……満たされてるっ……くっ、ひぃいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「おくっ……マンコの奥まで……ザーメン、注がれてぇっ……あはぁっ、はっ\nあっ……あぁっ……チンポ、中で暴れてるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0104303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「はぁあ、はぁっ……はぁぁっ……さっきより、出てるっ……どれだけ、射精\nしたら気が済むんだ、おまえは……あぁ、んあぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0104304" ]},
		{"command":[ "SETIMAGE", "0", "still_00022601_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「お、おまえ……まさか、あたしを孕ませるつもりか……？　ンっ……好き放\n題、射精してぇ……くっ、ひぃぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0104305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「あっ、あぁ……はーっ、はーっ……はぁあっ……け、結局……身体の火照り\n、は……おさまってないし……どうしてくれるんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0104306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「すっきり……？　まあ……言われてみれば……少しすっきりしたかも……\nふうっ……不思議な感覚だな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0104307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「身体はまだ火照ってるけど……なんか、ちょっと心地いいっていうか、ホン\nトすっきりした気分かも……もう少ししたら火照りもおさまる？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0104308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「そ、そうか……じゃあ、おまえの言った通りだったんだな……う、うん……\n正直言って、気持ちよかった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「本当か？　じゃあ、また身体が火照ってどうしようもなくなったら、おまえ\nに頼むから……セックス、してくれ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「あぁあっ！　あっ、あはぁっ！　な、なんでっ……！　チンポ、抜けっ……\nあっあぁぁっ！　はっ、あぁぁぁ～～～～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0104401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022601_02_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「ひぃいいっ！　はあっ、あひっ……！　あ、熱いっ……なんでチンポ抜いて\nんだっ……くひっ！　ひぃああっ、あぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0104402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「ザーメンっ……あぁっ……かかって、るっ……ひぃうっ、んぅんっ！！　お\n、おいっ……てばっ……ひあっ！　あはぁぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0104403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「んっあっ……！　ザーメン……ひぃうっ……！　か、顔にまで……飛んで、\nきて……あっ、あふっ……はぁ……あっ……あぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0104404" ]},
		{"command":[ "SETIMAGE", "0", "still_00022601_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「はぁ、あぁ……どれだけ出すんだ、おまえは……はあ……はぁっ……あ、あ\nふっ……クサい……鼻がおかしくなりそうだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0104405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「これで……終わり、か……？　ンっ……身体が熱い……最初よりずっと火照\nってままだぞ……話が違う……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0104406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「アクメしたらおさまるんじゃなかったのか？　ああ、まあ……気持ちよかっ\nた、けど……関係あるのか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0104407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「ふぅ……そうだな……すっきりした気分だ……もう少し落ち着いたら、熱も\n引いていくのか……わかった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0104408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「はぁあ……それにしても、身体がベトベトだ……すぐシャワー浴びたいが…\n…疲れて、しばらく動けないな……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0104409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「……そうだな。これでおさまるなら……また火照ってどうしようもなくなっ\nたら、おまえに頼むから……セックスしてくれ」", "NORMAL" ]},
