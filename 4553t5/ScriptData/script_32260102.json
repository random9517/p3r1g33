		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「ぐちゅぐちゅいってるっ……んあっ！　そんなに激しく突いたら……中から\n、溢れるっ……んっ……はあぁあっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0104208" ]},
