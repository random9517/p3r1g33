		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「熱い……オマンコ……いっぱいでぇ……あぁぁ……満たされるの……あぁぁ\n幸せぇ……は、ひぁぁ……あ、んぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2004302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あふっ、もう一滴も残さないで下さい……全部中に……私の奥……いっぱい\nにして下さい……んぁぁ……ふぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2004303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「んくっ！　今……びゅるって出して下さいました……はい、分かります……\nんんっ……今はオマンコ……特に敏感ですからぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2004304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
