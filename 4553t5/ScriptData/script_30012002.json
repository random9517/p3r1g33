	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「ご主人さま、バレンタイン特別のフルコース料理……いかがでしたか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2004101" ]},
		{"command":[ "SETCHARA", "0", "char_00000120_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「はい、本日はメイドの姿ですので、ご主人さまとお呼びさせていただくのが\n自然かと……でも、綺麗に完食して下さいましたね。私も嬉しいです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2004102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あの……それで、ですね……もし余裕がありましたら、食後のデザートなど\n……いかがかなと思いまして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2004103" ]},
		{"command":[ "SETCHARA", "0", "char_00000120_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「えっ、フルコースの中にチョコムースのデザートが……ええ、それは確かに\nありましたけど……つまり、それとは別に……こういうことで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2004104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「んっ……は、はい。食欲を満たした後の……性欲を満たすためのものとして\n……ど、どうぞ、私を……ご賞味いただければと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2004105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「ほら……そのよく見えるでしょうか……私のオマンコ……もう、お給仕の時\nから……ずっと疼きを持て余していたんです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2004106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00000120_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あぁ……はしたないのは承知で……オチンポ擦り付けさせていただきます…\n…んっ……あふっ、ご主人さまのも……もうこんなにビンビン……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2004107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あっ……はい、どうぞ……おっぱいもご自由になさって下さい……もう、乳\n首も……その気になってしまっていますので……あんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2004108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「はぁんっ……指でぎゅっとされるの……気持ちいいです……ご主人さまにモ\nミモミされるの……とても、ドキドキして……好き……ですっ、んっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2004109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あぁ……オチンポもビクビク震えて……私も、もう……ウズウズして、我慢\n……そろそろ限界です……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2004110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「どうか、このまま入れて下さい……ご主人さまのオチンポ……オマンコの奥\nにずぶっと挿し込んで、中をグリグリって……かき回して下さい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2004111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「はっ、あぁぁっ、あぁぁぁんっ！　あぁ……入る……んんっ、奥に……あっ\n、ふっ……入って……来ますぅっ、んぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2004112" ]},
		{"command":[ "SETIMAGE", "0", "still_00000120_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「はぁぁ……太い……あぁっ、オチンポ……みっちり埋まって……たまらない\nです……あふぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2004113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「くぅぅんっ……お願いします……このまま、動かして下さい……ご主人さま\nのオチンポ……いっぱいオマンコで感じたいです……はぁ……んっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2004114" ]},
		{"command":[ "SETIMAGE", "0", "still_00000120_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あくぅっ……あっ、はぁっ、んぁっ、あっ、あひぁっ、あぁっ、かき回され\nるっ、んくぅっ……こ、これぇっ……あっ、い、いいですぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2004115" ]},
		{"command":[ "SETIMAGE", "0", "still_00000120_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「はい……食後のデザートと同時に……運動によって、身体を引き締める役割\nも果たして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2004116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あっ、な、何より……あっ、オチンポ……気持ちよくなって頂いて……うん\nっ、はっ、あんっ、あぁっ、ずりゅずりゅっ……されてますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2004117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「どうか……隅々まで、私のいやらしい身体を……ご賞味下さい……あっ、あ\nぉっ、そ、そこはっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2004118" ]},
		{"command":[ "SETIMAGE", "0", "still_00000120_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「んんっ！　あぁっ、乳首……硬くなってしまいます……は、恥ずかしいです\nけど……あっ、今みたいにギュッとされるの……あっ、気持ちいいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2004119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「はいっ、いっぱい握り締めてっ……あぉっ、どんどん腰を速くさせて下さい\nっ……あひっ、あんっ、止まらないのっ、ああっ、い、いいです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2004120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「はっ、んっ、あぁっ……も、もっと足を開くんですね……？　こ、こうで…\n…よろしいですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2004121" ]},
		{"command":[ "SETIMAGE", "0", "still_00000120_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あぁ……くぱっとオマンコが広がって……オチンポを咥えこんでいる所が丸\n見えになってしまってます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2004122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「は、恥ずかしいです……恥ずかしいに決まっています……こんなはしたない\n姿で……誘惑して……ご主人さまのオチンポをおねだりするなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2004123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「ですが、メイドとして……喜んで頂きたい……その気持ちでいっぱいですか\nら……あっ、決して、自分ばかり気持ちよくなりたいからではっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2004124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あぁっ……あぅんっ、はぁんっ、ご主人さまのオチンポが激しくっ、あくぅ\nんっ、絡みついて来るのっ、あっ、あひぁっ、すごいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2004125" ]},
		{"command":[ "SETIMAGE", "0", "still_00000120_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あっ、あぁっ、はいっ……ご主人さまのオチンポにっ、何度もオマンコをグ\nリグリされてっ、流々那はっ……とても気持ちいいですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2004126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「もっとっ、あぁっ、オチンポ欲しがってしまいますっ……腰が自然に動いて\nっ……オマンコ……キュンってしてしまいますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2004127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あぁっ、はいっ……して下さいっ……！　もっと激しくかき回してっ……私\nの中を……いっぱいご賞味下さいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2004128" ]},
		{"command":[ "SETIMAGE", "0", "still_00000120_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「私の身体は隅から隅までっ……全部ご主人さまのものですからっ……お好き\nな所を……存分に味わってっ……あぁっ、オチンポッ……そこぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2004129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「ダメです……腰が砕けてっ……はひっ、あぁっ、まだオチンポが膨らんで…\n…中で大きくなって来てるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2004130" ]},
		{"command":[ "SETIMAGE", "0", "still_00000120_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「こんなっ、かき回され続けてっ、あぁっ、申し訳ありませんっ……このまま\nされたらっ、私っ……もう我慢がっ……出来なくっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2004131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「はいっ、あぁっ、でもっ、後少しですからっ……ご主人さまと一緒にイキた\nいですっ……！　それまでは、頑張ってオマンコ締め付けますからっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2004132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あぁっ、ビクビクしてますっ、はいっ、いつでも大丈夫ですっ……！　ぎゅ\nっとおっぱい揉み潰してっ！　あっ、んぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2004133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「イキますっ！　一緒にイキますっ！　出して下さいっ……オマンコいっぱい\nっ……中にっ、してぇぇぇぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2004134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「んぁぁぁぁぁっ！　あぁっ、熱いのっ……出されてっ……イクッ……イッて\nますぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2004135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000120_02_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「はぁぁ……んっ、びゅくびゅくして、お腹……いっぱいになっていきます…\n…あ、あぁぁ……気持ち……いい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2004136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あぁ、子宮が熱い……こんな風に直接送り込まれたら……そのまま赤ちゃん\n出来てしまうかも知れません……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2004137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「そうなったら、私はメイドなのに……あぁ、でも……ご主人さまの赤ちゃん\n……孕んでみたいかも……んっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2004138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あぁ……終わりましたか……射精。はい、沢山出して頂いてありがとうござ\nいました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2004139" ]},
		{"command":[ "SETIMAGE", "0", "still_00000120_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「私のとっておきのデザート……たっぷりとご賞味頂けたようで何よりです…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2004140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あっ……今……中でオチンポがビクって……んっ……これは……んふっ、ま\nだ完全にご満足頂けていないということでしょうか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2004201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「いえ、皆まで仰る必要はございません。元より、私もこれで十全なサービス\nをとは考えておりませんでした」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2004202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「まだまだ、私の中……オマンコも、ご主人さまのオチンポを欲しがったまま\nウズウズとしておりますので……あんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2004203" ]},
		{"command":[ "SETIMAGE", "0", "still_00000120_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「はい……どうか、このままオチンポを動かして……あっ、んくぅんっ、続け\nて……私の身体をご賞味下さいっ……はぁんっ、んぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2004204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「はぁっ、あぁっ、あんっ、あふぁっ……ずっとオチンポ硬いままで……また\n、中を……ぐりぐりっ……あっ、していますっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2004205" ]},
		{"command":[ "SETIMAGE", "0", "still_00000120_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「んっ！　あぁっ……でも、ご主人さまと一番深く繋がってることが実感でき\nて……んぁっ、とても……満たされた気持ちになりますっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2004206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あふっ、んっ……！　あぁ……また、内側から熱いお汁が出てきちゃいます\n……ご主人さまの精液と混ざって……ぐちゅって……してぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2004207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「はぁん……あぁっ、おっぱいも揉んで下さい……あぁっ、そこですっ、んん\nっ、乳首摘まれながら……転がされてぇっ……は、ひぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2004208" ]},
		{"command":[ "SETIMAGE", "0", "still_00000120_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「指に……ぎゅって力が入ってぇ……あっ、ピンって弾かれるとっ……腰がビ\nクってしちゃいます……あっ、はぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2004209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「はぁんっ！　むぎゅっと押し潰されるのも好きっ……モミモミしながら……\nあっ、オチンポも一緒に突き上げられるのっ、いいですぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2004210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「はんっ、あぁっ、はいっ、私もっ……いっぱいキュウッてしますっ……んん\nっ、どうですかっ……ちゃんとオマンコ……締まってますかっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2004211" ]},
		{"command":[ "SETIMAGE", "0", "still_00000120_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「ずりずりっ、リズムに合わせてっ……いっぱいオチンポシコシコしますねっ\n、あんっ、特別メニューの最後の一品……隅々まで味わってっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2004212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あ、はぁんっ！　あぁっ、またオチンポッ……ズボズボっ……激しくなって\n来てますぅっ！　下からグイグイ来るのっ……気持ち良すぎますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2004213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「はんっ、あっ、あぁっ……ぐちゅぐちゅっ、いやらしい音してっ……はぁぁ\nっ、あ、頭がボーッとなってきてっ……はぁんっ、これぇっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2004214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「ダメ……メイドとしてっ、ちゃんとお務めしきらないといけないのにっ……\nオマンコッ、良すぎてっ……奥にっ……届いてぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2004215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「はひぁっ、またイキそうにっ……あぁっ、ご主人さまぁっ……後もう少しだ\nけっ……頑張りますからっ、あぉっ、イ、イッて下さいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2004216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「んぁうっ、はいっ、私も一緒にお供しますっ！　オチンポとオマンコ擦り合\nわせてっ……一緒に最後っ……イキますからぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2004217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
