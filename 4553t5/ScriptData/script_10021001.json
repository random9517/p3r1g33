{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0138" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "朝早く。誰もいない教室。", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "誰よりも早く登校して、そんな教室で本を読むのが、私の密かな楽しみ。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130114190001" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "みんなが教室に来るまで、あと３０分ぐらい。それまでここはとても静かで、\n読書に集中するにはちょうどいい。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「………………！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130114190002" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "今読んでいる小説はとても面白くて、読み終えて物語の世界にお別れするのが\nもったいなく思えて――", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロックの部下" ]},
		{"command":[ "SETTEXT", "「おはようございます、流々那さん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_010114190001" ]},
		{"command":[ "SETCHARA", "0", "char_00001902_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「え？　あ、おはようございます……。ど、どうしたんですか？　こんな時間\nに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130114190003" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロックの部下" ]},
		{"command":[ "SETTEXT", "「ふふっ、流々那さんいつも早いから。この時間に来てみたら、いるかもしれ\nないって思って」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_010114190002" ]},
		{"command":[ "SETCHARA", "0", "char_00001902_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「ふふっ、そうですか……私、この時間の教室が好きなんです。静かで、空気\nも澄んでいて、読書にぴったりで――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130114190004" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーンの部下" ]},
		{"command":[ "SETTEXT", "「あ、いたいた。流々那さんたち」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_030114190001" ]},
		{"command":[ "SETCHARA", "0", "char_00002302_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラの部下" ]},
		{"command":[ "SETTEXT", "「おはようございま～す」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_020114190001" ]},
		{"command":[ "SETCHARA", "0", "char_00002102_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロックの部下" ]},
		{"command":[ "SETTEXT", "「と、いうわけで皆さんも誘って来てみました！　せっかくなので、おすすめ\n小説の交換会をしようと思いまして！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_010114190003" ]},
		{"command":[ "SETCHARA", "0", "char_00001902_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あ、ご、ごめんなさい。この前お借りした本、まだ読み終えていないんです\n。でも、もう少しで――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130114190005" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロックの部下" ]},
		{"command":[ "SETTEXT", "「あ、それはいいんです！　ゆっくり読んで！　だけど……先週出た新刊が…\n…またまたすごい傑作で！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_010114190004" ]},
		{"command":[ "SETCHARA", "0", "char_00001902_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロックの部下" ]},
		{"command":[ "SETTEXT", "「是非とも！　流々那さんにおすすめしたくって！　むふーっ！　ぶふーっ！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_010114190005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラの部下" ]},
		{"command":[ "SETTEXT", "「ちょっと落ち着いて！　鼻息荒いですから！　流々那さん引いてますから！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_020114190002" ]},
		{"command":[ "SETCHARA", "0", "char_00002102_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「い、いえ！　そんなことは……。あの、もう読まれたんですか？　どんなお\n話なんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130114190006" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロックの部下" ]},
		{"command":[ "SETTEXT", "「よっく聞いてくれました！　実はですね！　いまお貸ししてる本と、舞台は\n同じ男子校なんですが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_010114190006" ]},
		{"command":[ "SETCHARA", "0", "char_00001902_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーンの部下" ]},
		{"command":[ "SETTEXT", "「おーい、顔近いぞー。落ち着けー。流々那さん、また引いてるぞー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_030114190002" ]},
		{"command":[ "SETCHARA", "0", "char_00002302_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロックの部下" ]},
		{"command":[ "SETTEXT", "「あ！　ごめんなさい！　でも気にしないで！　読みながら聞いててもらって\nいいですから！　とにかくですね。今回の攻めは――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_010114190007" ]},
		{"command":[ "SETCHARA", "0", "char_00001902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラの部下" ]},
		{"command":[ "SETTEXT", "「彼女、推し作品の話になると、いつもこうなっちゃうんですよね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_020114190003" ]},
		{"command":[ "SETCHARA", "0", "char_00002102_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「だ、大丈夫……大丈夫ですから……！　え、えと、えと、えと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130114190007" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0138" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「――と、いうことをつづった文章ですね。そして、ここに出てくる単語です\nが……ルルーナさん？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020114190001" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「うひゃいっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070114190001" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「この場合『すきずきし』という単語は、どのような意味になりますか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020114190002" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「す、すき！？　そんな、明日楽先生……わたくし、急にそのようなことを言\nわれても――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070114190002" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「……なにか勘違いしていませんか？　この単語を、現代語に訳せと言ってい\nるんですが？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020114190003" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「は、はいっ！　すきずきし、すきずきし……ですわね？　え、えーと……逆\nさに読んでもすきずきし……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070114190003" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「…………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020114190004" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「では、なくてですね……あの……えーと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070114190004" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「ルルーナさん……ルルーナさん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130114190008" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「ルルーナちゃん！　流々那ちゃんが呼んでるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010114190001" ]},
		{"command":[ "SETCHARA", "0", "char_00001205_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「っ！　流々那が……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070114190005" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「ルルーナさん！　この場合の『すきずきし』は、『風流である』という意味\n……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130114190009" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「ありがとう、流々那……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070114190006" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「ルルーナさん？　どうかしましたか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020114190005" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「いえっ！　なんでもありませんわ、先生！　わかります！　わたくしにもわ\nかりますわ！　『すきずきし』の意味が！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070114190007" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「そうですか。それではルルーナさん、答えてください。この場合の『すきず\nきし』とは？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020114190006" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「はい！　『すきずきし』、それは……『貧乳である』という意味です！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070114190008" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「ちょ、ちょっとルルーナさん！？　あなたいったい、なにを――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020114190007" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「あははははっ！　違うってばルルーナ！　全然違うじゃないの！　あははは\nはははっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020114190001" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「え？　え？　え！？　な、なんですの！？　違うってどういうことですの！\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070114190009" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「流々那は『貧乳』なんて言ってないわ！　『風流』って言ったの！　それじ\nゃ、最後の『う』しか合ってないじゃない！　あははははっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020114190002" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「マ、マーガレットさん！　大声でそんなこと言ったら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130114190010" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「ちょっとあなたたち、授業中ですよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020114190008" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "みんと" ]},
		{"command":[ "SETTEXT", "「なんですって！？　それじゃルルーナさんに流々那さん、カンニングをした\nっていうんですか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_020114190001" ]},
		{"command":[ "SETCHARA", "0", "char_00001502_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「カ、カンニング！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070114190010" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「そ、そんな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130114190011" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「あなたたち、静かにしなさい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020114190009" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「ちょっと待ってよ、みんとちゃん！　カンニングって、テストじゃないんだ\nから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010114190003" ]},
		{"command":[ "SETCHARA", "0", "char_00001205_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「そうよ！　私はただ、先生に当てられただけ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070114190011" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "みんと" ]},
		{"command":[ "SETTEXT", "「同じことです！　授業中に当てられただけとはいえ、まずは自分の力で答え\nるべきでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_020114190002" ]},
		{"command":[ "SETCHARA", "0", "char_00001502_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「あなたたち……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020114190010" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「もちろん答えようとしたわよ！　たまたまわからなかっただけじゃない！　\n　そこにたまたま流々那が教えてくれて――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070114190012" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「あなたたち……本当に……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020114190011" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0138" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「いいかげんにしないかぁああああああーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010114190001" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "みんな" ]},
		{"command":[ "SETTEXT", "「ひいいっ！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "9", "CENTER", "-600" ]},
		{"command":[ "SETCHARA", "1", "char_00000113_01", "9", "CENTER", "-200" ]},
		{"command":[ "SETCHARA", "2", "char_00002402_01", "9", "CENTER", "200" ]},
		{"command":[ "SETCHARA", "3", "char_00001502_01", "9", "CENTER", "600" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "DISPCHARA", "2", "TRUE" ]}, 
		{"command":[ "DISPCHARA", "3", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「おまえら全員、廊下に立ってろーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010114190002" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "DISPCHARA", "2", "FALSE" ]}, 
		{"command":[ "DISPCHARA", "3", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0126" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「さーて。校内に異常は、っと……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "sbg_0155" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「おっとご主人。今時珍しい光景ですぞ。地球防衛科の皆様が、廊下に立たさ\nれております」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010114190001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ホントだ。なにやらかしたんだかなぁ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「今時珍しいと同時に、あまりにベタすぎる光景でもありますな。さすがのワ\nタクシも、ツッコむ気力が湧きません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010114190002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まったくだ。女幹部のくせに、廊下に立たされるとかなぁ……ふふふっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "まあ、あれだけ大勢で廊下に立ってるんなら、なにかあったら気づくだろ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ここはなにも見なかったことにして、回れ右、っと……。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0159" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「さて、校舎内も校庭もひと通り見回った、っと。まあ、特に変わったことは\nないな」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「あとは戸締りをして帰るだけですな。それにしてもご主人……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010114190003" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ん？　なんだ。っていうか、そのツラ！　またなんか、ろくでもねえことを\n言おうとしてるツラだな？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「心外ですな！　ワタクシはただ、ご主人をほめてさしあげようと思っただけ\nですぞ！　たまには！　珍しく！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010114190004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ほぉ？　なんて言おうとしたんだよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「『ご主人もすっかり、まともな勤労者のふりがうまくなりましたな』という\n、たいへん暖かく思いやりのこもった言葉をかけようと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010114190005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「『暖かい』通り越して、脳が煮えてんじゃねえのか。なんだったらマイクロ\n波であっためなおしてやろうか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「おや、ご主人。教室に、まだ残っている学生がおりますな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010114190006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おまえ、そういうごまかし方だけは一級品だよな……って、あれ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0162" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130114190013" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "流々那がひとり教室に残って、じっと外をながめている。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130114190014" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "あれから明日楽に怒られでもしたのか？　と一瞬心配になったが、微笑みを浮\nかべているところをみると、そういうわけではないようだ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そんな彼女の様子に、こちらもつい見入ってしまったが――", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「あー、ご主人。年甲斐もなく純情男子ムーブをキメているところ大変申し訳\nございませんが、警備員兼教員といたしましては――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010114190007" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うるせえ！　わかってるよ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ジュンジローに余計なツッコミを入れられ、現実に戻って流々那に声をかける\n。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あー、流々那？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「え……？　ああ、カツマ……先生」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130114190015" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「下校時間、過ぎてるぞ。学生は寮に戻らないとな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「そ、そうですね……ふふっ、ごめんなさい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130114190016" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まあ……なるべく早めにな。ところで、こんな時間まで教室に残って、なん\nかあったのか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「ううん……別に。そういうわけじゃないの……。ただ、ちょっと……考えて\nたの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130114190017" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「こんなふうに、落ち着いた気持ちで暮らせるのは……ほんとうに久しぶりだ\nって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130114190018" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああ……そうか……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「もちろん、こんなことをしている場合じゃないのは、よくわかっています。\nでも私はここでようやく、平凡な日常というものを体験できた……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130114190019" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「だから私はいま、とても幸せだな……って」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130114190020" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そ、そうか……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「そう。ふふふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130114190021" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010114190008" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「え、えーと……な、なんだ？　流々那のいう幸せって、例えばみんなで廊下\nに立たされること、とかか！？　ははははっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "なんだか気恥ずかしくなって、ついそんなことを言ってしまう。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「え！？　み、見てたのですか……？　は、恥ずかしい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130114190022" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「でも……そうかもしれない。あれも、みんなとの暮らしの一部だから。大好\nきなみんなとの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130114190023" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうかぁ……まあ、そうかも知れないな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「そうよ。ふふふふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130114190024" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「くっ……静まりなさい、わたくしの右前脚……！　この空気感の中、ツッコ\nミの力を発動するわけには……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010114190009" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人はともかく、平和を噛みしめておられる流々那殿のお気持ち……それ\nを乱すような野暮は、紳士にあるまじき行いですぞ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010114190010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なにブツブツ言ってんだこの駄犬」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "と、ジュンジローのほうを振り向いた瞬間、教室のドアが開いた。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「誰ですか？　教室に残っているのは。下校時間はとっくに過ぎていますよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020114190012" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130114190025" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「っ！？　あ、あなたたち……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020114190013" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お、おう……どうも……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「そ、そうですか……あなたたちですか。まあ、あなたたちは、学生と教師と\nいえども、他の皆さんとは事情が違いますし、なんといいますか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020114190014" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "……？　なにを言ってんだ？", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「まあ、つまりは普通の大人として扱うべきであって、こうしたことにも特に\n問題はないのかもしれませんが、しかし……しかしですね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020114190015" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130114190026" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「と、とにかく！　大人同士と言えども、学園内で不純異性交遊は許しません\nっ！　そういうことは、どこか他の場所で――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020114190016" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "なにを勘違いしてるんだ、このムッツリ鬼教師っ！", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いきなりなにを言い出すんだよアンタはっ！！　違う違う！　してないして\nない！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「そ、そうなのですか！？　す、すみません。私はてっきり……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020114190017" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「誤解です！　誤解なんです！　私とカツマは、まだそんな――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130114190027" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽＆カツマ＆ジュンジロー" ]},
		{"command":[ "SETTEXT", "「『まだ』！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010114190011" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "9", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "1", "char_00001602_01", "3", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「え……？　あああっ！？　違うの！　違います、違うんです！　私はそうい\nう意味で言ったのではなくて、ただ、その、えーと！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130114190028" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "9", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「と、とにかく、違うんです間違いなんです忘れてくださーいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130114190029" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "流々那がパニックに陥っている。あまりの混乱ぶりに、俺もジュンジローも助\nけ舟の出しようがない。どうしようかと、こちらも慌てていると――", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「姫さま、にいさま、大変です！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010114190001" ]},
		{"command":[ "SETCHARA", "0", "char_00001101_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "もうひとり、大慌てで教室に飛び込んでくるヤツがいた！？", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「翔生子！？　いったいなにが――」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者" ]},
		{"command":[ "SETTEXT", "「追い詰めたぞ！　逃がすな！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「襲来者（インベーダー）が追ってきただとぉっ！？　いったいなんなんだよ\n！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0162" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「わからん！　だがごまかせて好都合――い、いや！　このまま見過ごすわけ\nにはいかん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090114190001" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「そうだな！　学園内で襲来者（インベーダー）に好き勝手はさせん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010114190003" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
