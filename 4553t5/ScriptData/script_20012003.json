	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「それで……？　どうしてもお目通りしたいってのが、そちらさんだって……\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010021630001" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「は、はぁ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「ウチがどういう所か分かってて、それでも尚、連れてきたってことになるん\nだよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010021630002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「は、はい、こちらの次元旅団オーヴァーハングの皆さんが、どうしてもレッ\nドさんに会いたいと……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「レッドってのは、アレかい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010021630003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「マスク・ザ・レッド……ほむらのことかと……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「随分と、面倒事を持ち込んでくれたみたいだねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010021630004" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そ、そういう感じになっちゃいますかね」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「何だかごちゃごちゃしてるけど……結局のトコ、どうなってるのかなぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_010021630001" ]},
		{"command":[ "SETCHARA", "0", "char_00019701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「あいにく、気の長い方じゃないんでねぇ……多少力ずくでもご案内してもら\nうことになりそうなんだが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_010021630001" ]},
		{"command":[ "SETCHARA", "0", "char_00019901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "組員Ａ" ]},
		{"command":[ "SETTEXT", "「なんだとぉっ！　てめぇら、ウチのシマがどこだか分かって話をしてんのか\nぁっ？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「やめな、見苦しい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010021630005" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "組員Ａ" ]},
		{"command":[ "SETTEXT", "「し、しかし……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「話は分かった。とりあえずほむらを呼んできな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010021630006" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "組員Ｂ" ]},
		{"command":[ "SETTEXT", "「え……？　あ……で、ですが」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「二度は言わないよ、早くしな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010021630007" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "組員Ｂ" ]},
		{"command":[ "SETTEXT", "「は、はぃいっ！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「にひひっ♪　よーく、躾が行き届いてるじゃん、感心感心♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_010021630002" ]},
		{"command":[ "SETCHARA", "0", "char_00019701_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「大したことじゃありません。当たり前のことですから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010021630008" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "……うぅぅ……ピリピリするぜ……この一触即発の空気……勘弁して\nくれよな……", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そ、そうだ、俺……お茶でも淹れて……」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「構わないよ、すぐに来る。そこに座ってな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010021630009" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「は、はい」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「それにしても……そちらさん、随分とマスク・ザ・レッドにご執心で」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010021630010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「んんー？　まぁねぇ、こう何ていうか、迸るパワーっていうの？　アレはと\nっても刺激的でさぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_010021630003" ]},
		{"command":[ "SETCHARA", "0", "char_00019701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「やっぱり、戻ったからには、またバチッとヤリたい……なーんて思うのはト\nーゼンだよねぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_010021630004" ]},
		{"command":[ "SETCHARA", "0", "char_00019701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「ふむ……果たして、お望みに添えるかどうか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010021630011" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「ん？　どーいうこと？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_010021630005" ]},
		{"command":[ "SETCHARA", "0", "char_00019701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「何だよ、誰がアタシに用事があるんだって？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020021630001" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「来たっ……！　って……あ、あれ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_010021630006" ]},
		{"command":[ "SETCHARA", "0", "char_00019701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ん？　お前は……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020021630002" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「貴方……マスク・ザ・レッド……だよね？　えと……合ってる……よね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_010021630007" ]},
		{"command":[ "SETCHARA", "0", "char_00019701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「あぁ……マスカレードのことか。まぁ、そんなこともあったかな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020021630003" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「そんなこともって……えっ、あの……どーいう……イミ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_010021630008" ]},
		{"command":[ "SETCHARA", "0", "char_00019701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「どういうって……いや、まぁ……昔の話だしな。もうやってねぇんだよ、や\nめたってことだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020021630004" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「え……えぇぇぇぇーーーっ！　なんでぇっ？　なんでやめちゃうのぉっ！？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_010021630009" ]},
		{"command":[ "SETCHARA", "0", "char_00019701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「いや、なんでって言われても……まぁ、色々あるからなぁ……一口には言え\nねぇよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020021630005" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「やだっ、やだよぉっ、やめちゃ、やだぁぁぁぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_010021630010" ]},
		{"command":[ "SETCHARA", "0", "char_00019701_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「やだって言われてもなぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020021630006" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「ダメっ、ダメだよぉっ！　そんなの絶対ダメなんだからぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_010021630011" ]},
		{"command":[ "SETCHARA", "0", "char_00019701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「な、何だ……？　急に見た目通りのお子ちゃまモードになったぞ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「あぁ……始まっちまったか。こいつは、ちょっとマスク・ザ・レッドに憧れ\nてたみたいでな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_010021630002" ]},
		{"command":[ "SETCHARA", "0", "char_00019901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「あれで、結構ワクワクしてる所があったんだろうが……ハシゴを外されちま\nったって感じだろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_010021630003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、それにしたって、ギャン泣きじゃねぇか……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「ちょっと待っていただけます？　レッドはんがやめはったのは分かりました\nが……グリーンは、グリーンはどうなってますの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_010021630001" ]},
		{"command":[ "SETCHARA", "0", "char_00019801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「そうだ、それなら私も確認させてもらわないと。ブラックはどうなっている\nんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_010021630001" ]},
		{"command":[ "SETCHARA", "0", "char_00020001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「やだぁっ、戻ってきてぇっ、レッドじゃないとダメなんだからぁっー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_010021630012" ]},
		{"command":[ "SETCHARA", "0", "char_00019701_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「お、おい……ファンタズマ、あんまり困らせるようなこと言うなって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_010021630004" ]},
		{"command":[ "SETCHARA", "0", "char_00019901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「だってぇっ！　だってぇっ！　うわぁぁぁぁぁぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_010021630013" ]},
		{"command":[ "SETCHARA", "0", "char_00019701_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「収拾がつかなくなる気はしてたが……まさか、こんな形でそうなるとは……\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「やれやれ。いくらウチらでも、泣く子には勝てませんなぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010021630012" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「参ったな……こんな泣かれてもなぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020021630007" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「あんたのせいや、ほむら。どうにかしぃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010021630013" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「どうにかって……こんなの、どうすりゃいいんだよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020021630008" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}