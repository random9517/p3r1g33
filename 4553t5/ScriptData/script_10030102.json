{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0185" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_005" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「……騒々しいですよ。いいかげんにしてくれませんか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_090114640001" ]},
		{"command":[ "SETCHARA", "0", "char_00000609_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「貴様は……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114640001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局員" ]},
		{"command":[ "SETTEXT", "「申し訳ありません、レディ・ホープ。しかし――」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「ええ、事情は把握しています。あとはわたしが処理します」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_090114640002" ]},
		{"command":[ "SETCHARA", "0", "char_00000609_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局員" ]},
		{"command":[ "SETTEXT", "「は、はあ……よろしくお願いします」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "レディ・ホープはうなずくとルナテミスに歩み寄る", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「ルナテミスさん。話が違いますね。決してトラブルは起こさないと約束して\nくれたはずですが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_090114640003" ]},
		{"command":[ "SETCHARA", "0", "char_00000609_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「なにを言っている！　そもそも貴様たちが私の下僕をこのような目に合わせ\nるのが悪いんだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114640002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「どのような目に合わせたというんです？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_090114640004" ]},
		{"command":[ "SETCHARA", "0", "char_00000609_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「どのようなって……そ、それは、その……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114640003" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「どうかしたんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_090114640005" ]},
		{"command":[ "SETCHARA", "0", "char_00000609_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「い、いや、考えてないぞ！　受けだの、攻めだの、なんとか管理だのと……\nそのようなことはっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114640004" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「……思った通り、とんでもない誤解があるようですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_090114640006" ]},
		{"command":[ "SETCHARA", "0", "char_00000609_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ＡＩ" ]},
		{"command":[ "SETTEXT", "「測定の結果は以下の通りです。ひどい早とちり。おっちょこちょい。暴力ヒ\nロイン及びツンデレの傾向が顕著」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「うるさいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114640005" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「わかりました。誤解を解くためには、カツマさんの様子を見ていただいたほ\nうが早いでしょう。ただし、いいですか？　暴れないように」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_090114640007" ]},
		{"command":[ "SETCHARA", "0", "char_00000609_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「う……わ、わかった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114640006" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「うるさくしないように。他の房にも収容されている方がいます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_090114640008" ]},
		{"command":[ "SETCHARA", "0", "char_00000609_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「わかった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114640007" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「帰ったら手洗い、うがい、戸締りを忘れないこと。寝る前の歯磨きもです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_090114640009" ]},
		{"command":[ "SETCHARA", "0", "char_00000609_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「わかった……って、なんでそこまで言われなきゃならないんだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114640008" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「約束できないのなら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_090114640010" ]},
		{"command":[ "SETCHARA", "0", "char_00000609_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「わかった！　約束する！　宿題もちゃんとやるから！　早く案内しろ～～～\nっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114640009" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "sbg_0000" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "と、いうわけでレディ・ホープに案内され、ルナテミスは牢内に入る。そこで\nは……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0172" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「カツマ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114640010" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「カツマ！　大丈夫か！？　カツマ―っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114640011" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「返事もできないのか……！　こんなになるまで、なにをされた！？　さては\nグレーテル秘蔵のマンガみたいなことを……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114640012" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「いや、無理はするな。待っていろ、必ず助けてやるからな！　おい！　レデ\nィ・ホープ！　どこだ！　レディホーーーープ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114640013" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETIMAGE", "0", "sbg_0173" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ん、んんん……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「……カツマ！？　意識が戻ったのか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114640014" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ううん……勘弁して……もう勘弁してくれよ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「カツマ……？　カツマッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114640015" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「勘弁してくれってば……こんなにうるさくちゃ、おちおち寝てらんねぇじゃ\nねぇか……ぐぅ～……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「…………！？　こ、こいつ……！　起きろ、このボケナスビ～～～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114640016" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「んぁ……？　あひっ！？　ひ、姫様！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「なにをのんきに眠りこけているっ！　しかも、昭和のギャグマンガみたいな\n寝ぼけ方をしてるんじゃなぁ～～～～いっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114640017" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「痛ぇええええっ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}