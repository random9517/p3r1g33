{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0164" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "放課後の職員室。", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "明日の授業の準備をしている中で、グレーテルがふとこんな話をはじめた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「ねえ、最近生徒たちの間で流行ってる噂話……知ってる？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_020113680001" ]},
		{"command":[ "SETCHARA", "0", "char_00001802_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「なんだ？　何の話だ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040113680001" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「どんな話かしら～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040113680001" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「ある生徒が……忘れ物を取りに学園に忍び込んだんだって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_020113680002" ]},
		{"command":[ "SETCHARA", "0", "char_00001802_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「すぐに帰ろうとしたんだけど……そしたら、タッタッタッターって足音が聞\nこえてきて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_020113680003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「おかしいなー？　だって、学園にいるのは自分だけのはず。ほかの人の足音\nがするはずない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_020113680004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「気になってその生徒は足音を追った」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_020113680005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「ええ～、それダメなやつじゃない～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040113680002" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「廊下のつきあたりで、ついにその生徒は足音の正体に出会ってしまった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_020113680006" ]},
		{"command":[ "SETCHARA", "0", "char_00001802_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「なんとそこには、スーツ姿の女性が立っていて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_020113680007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「立っていて？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040113680002" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「さらに、その生徒の後ろからは……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_020113680008" ]},
		{"command":[ "SETCHARA", "0", "char_00001802_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「後ろからは……っ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040113680003" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「サメ……ッ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_020113680009" ]},
		{"command":[ "SETCHARA", "0", "char_00001802_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "２人" ]},
		{"command":[ "SETTEXT", "「ぎゃぁ～～～～っ！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00001802_01", "0", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_004_040113680003" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "3", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "1", "char_00000604_01", "3", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "聞き耳を立てていたが、なんだその怪談は。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「なんですかそのうさんくさい噂は」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_050113680001" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まあ、噂なんて往々にしてうさんくさいもんだがな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「いやはや……学園を舞台にした怪談とは、実に学園ものらしいですな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113680001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そういうジュンジローの声は震えている。お前もかなりビビってるのか？", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「でも、いろんな生徒が女の幽霊を見たって話をしているんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_020113680010" ]},
		{"command":[ "SETCHARA", "0", "char_00001802_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「調理室とか、体育館とか、あとは女子トイレとかでも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_020113680011" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「そして、その女性とセットで現れるのが、サメ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_020113680012" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「きっと、この学園で非業の死を遂げた女教師がサメをひきつれて生徒に仕返\nしを……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_020113680013" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「ひぃいいい～～～～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040113680005" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「なーんでサメなんですか。幽霊ってだけでも、うさんくさいのに、サメって\n。Ｚ級映画みたいな設定ですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_050113680002" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "『学園に現れる女の幽霊』ってだけならよくある怪談だが、サメの存在がすべ\nてを台無しにしているというか……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "噂には尾ひれがつくものだが、尾ひれどころか魚が丸ごと一匹ついてきてるじ\nゃねーか。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "sbg_0139" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「話は聞かせてもらったわ……！　この学園は滅亡する！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010113680001" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0140" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "全員" ]},
		{"command":[ "SETTEXT", "「な、なんだってーーー！！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040113680004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「突然やってきて、なんですかあなたは」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_050113680004" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETIMAGE", "0", "bg_0164" ]},
		{"command":[ "SETTEXT", "「私はスーザン。サメを殺すことを生業にしている」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010113680002" ]},
		{"command":[ "SETCHARA", "0", "char_00012701_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "なんだ、自己紹介から物騒だな。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「この学園でサメが目撃されたと聞いてやってきた。サメは放っておくと大変\nなことになるからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010113680003" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「サメってそんなに危険なのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040113680005" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「危険だとも。サメの頭はひとつ見つけたら三十個はあると思っていい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010113680004" ]},
		{"command":[ "SETCHARA", "0", "char_00012701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「頭が三十個かよ！　なんだそのバケモノ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「バケモノ？　いや、サメはバケモノよりもずっと脅威的な存在だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010113680005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「だからこそ、サメの現れたところには徹底的に『除サメ』をしなければなら\nない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010113680006" ]},
		{"command":[ "SETCHARA", "0", "char_00012701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「除サメ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040113680007" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「除霊みたいな感覚で言うね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_020113680015" ]},
		{"command":[ "SETCHARA", "0", "char_00001802_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「除霊といえば、女の人のお化けについては、放っておいていいのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040113680006" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「ん？　女の人のお化け？　サメじゃないなら無害だろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010113680007" ]},
		{"command":[ "SETCHARA", "0", "char_00012701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ええ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「とにかく、いま必要なのはサメ退治だ！　教師のみなさんにも協力していた\nだきたい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010113680008" ]},
		{"command":[ "SETCHARA", "0", "char_00012701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「手遅れになってしまう前に、サメをこの学園から根絶しなければならないん\nだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010113680009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「サメはとても危険な生き物だ。放っておけば重大な事件に繋がってもおかし\nくない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010113680010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「生徒たちの安全を守るのは教師の使命！　そうだろう！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010113680011" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「そう言われると……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040113680007" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「そうかもしれないけど～……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040113680008" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「ウチは事務員なんですが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_050113680005" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「これは、みんなで見回りの流れ……ふふ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_020113680016" ]},
		{"command":[ "SETCHARA", "0", "char_00001802_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「みんなってことは、俺も含まれるのか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「当たり前でしょう。本来なら、教師じゃなくて警備員のあなただけでやる案\n件です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_050113680006" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「どうやら、逃げ場なしですな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113680002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はぁ、わかったよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "どうせ噂だろう。なにも出ないに決まっている。徒労になるだろうが、見回り\nはしておくことになった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0128" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_020" ]},
		{"command":[ "SETTEXT", "真夜中の学園。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "俺たちはそろって廊下を歩いていた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「それで、サメが出たっていう場所は？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010113680012" ]},
		{"command":[ "SETCHARA", "0", "char_00012701_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「サメじゃなくて、幽霊なんだけど……うん、この階の女子トイレだって……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_020113680017" ]},
		{"command":[ "SETCHARA", "0", "char_00001802_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「女子トイレか……中に入るのか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「バカですか。あなたは外で見張りです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_050113680007" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "あーはいはい。そんなことだろうと思ったよ！", "NORMAL" ]},
