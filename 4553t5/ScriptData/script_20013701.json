{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0101" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_011" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「失礼しまーす」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ああ、君が最後だ。席についてくれ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022550001" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うぇっ……さ、最後ですか。は、はい」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「だから、もう少し早く行こうと言ったではありませんか、ご主人」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022550001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お前がモタモタしてたんだろうが！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ああ、もうそれは気にしなくていい。それよりも、よく集まってくれたな、\n皆」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022550002" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「冴島長官の呼び出しとあれば、何より優先されることだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010022550001" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「ま、ちょうどヒマだったし？　いいタイミングだったかもー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_010022550001" ]},
		{"command":[ "SETCHARA", "0", "char_00017001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「ですが、珍しいですね……私達全員が呼び出されるのは」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_010022550001" ]},
		{"command":[ "SETCHARA", "0", "char_00016901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ふむ……インクレディブル・スクワッドとしての呼び出しということか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022550001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「その通りだ。君たちインクレディブル・スクワッドに来てもらったのは他で\nもない。新たな特別任務にあたってもらう為だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022550003" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「特別任務……ですか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「うむ。次元管理統制局のレディ・ホープから、水の惑星ビキニにて、謎の遺\n跡が見つかったという報告を受けた」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022550004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「水の惑星ビキニ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010022550002" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「へぇー、水にビキニなんて、夏っぽい名前じゃん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_010022550002" ]},
		{"command":[ "SETCHARA", "0", "char_00017001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「そうですね。偶然なのかも知れませんが、何だか爽やかな雰囲気を感じます\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_010022550002" ]},
		{"command":[ "SETCHARA", "0", "char_00016901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうか……？　何か微妙な胡散臭さを感じなくもないが……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「静かに。この惑星は遥か数万光年を越える彼方にある恒星系にあるが、次元\n座標が安定している為に特殊なポータルでの移動が出来る」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022550005" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「そこで君たちには、この惑星ビキニへ赴いての調査を命ずる！　そして、古\nより伝わる伝統の鎧とやらを手に入れるのだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022550006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「古の……伝統の鎧ですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010022550003" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「うむ。レディ・ホープの話では、この地には昔からの言い伝えがあり、伝説\nの戦士が纏っていた鎧が眠っているという」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022550007" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「どの時代のものであるとか、どのような形状だとかは不明だが、何やら素晴\nらしい力を秘めていたらしい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022550008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「素晴らしい力……ですか。何か鎧に魔力が込められているとか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_010022550003" ]},
		{"command":[ "SETCHARA", "0", "char_00016901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「単純に、メチャクチャ硬い鎧なんじゃないの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_010022550003" ]},
		{"command":[ "SETCHARA", "0", "char_00017001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「詳しいことは実際に確かめなくては分からんだろう……だが、調べてみる価\n値はある」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022550009" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「もし手に入れることができれば、恐らくこれからの我々の戦いに大きな力と\nなってくれるかも知れないということだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022550010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「伝統の鎧か……ふふん、なかなか興味深い代物じゃないか。私に相応しいモ\nノかも知れないな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022550002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「武人としては、武器ほどではないが、多少なりとも気になるものであること\nは確かだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010022550004" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「結構。それでは、これから赴くその惑星ビキニがどのような場所か、改めて\n説明しよう。これを見てくれ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022550011" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「おぉ……ここが……水の惑星ビキニか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022550003" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「確かに一面が海に囲まれているな。所々に島があって……なかなか美しい場\n所じゃないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010022550005" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「大気は地球と大きく変わることはなく、気候は通年を通して温暖。危険な生\n物も少ないそうだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022550012" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……こんなとこなら、任務なんかより海水浴でもしたいぜ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「確かに～！　めっちゃ気持ちよさそうだし！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_010022550004" ]},
		{"command":[ "SETCHARA", "0", "char_00017001_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「そうですね。ゆっくりと日光浴をするなど……とても魅力的に感じます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_010022550004" ]},
		{"command":[ "SETCHARA", "0", "char_00016901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁ……しばらくバカンスにも行ってないな。何というか……急にそんな気\n分になって来たな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022550004" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「君たちの言いたいことは分からんでもないが、我々は決してバカンスに行く\nのではない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022550013" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「あくまでも重要な任務として、この星へ向かうのだ。気を引き締めて行け！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022550014" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「……そうですね。少し自覚が足りませんでした」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_010022550005" ]},
		{"command":[ "SETCHARA", "0", "char_00016901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「まぁ、お仕事だもんね。仕方ないかー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_010022550005" ]},
		{"command":[ "SETCHARA", "0", "char_00017001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「私からは以上だ。各自、今から出発の準備を整えるように。では、解散！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022550015" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「むぅ、さすがはＥＤＯの長官。こんなワクワクする風景でも任務第一とする\n姿勢は人の上に立つ者として見習うべきだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022550005" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「私達も気を引き締めて行きましょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_010022550006" ]},
		{"command":[ "SETCHARA", "0", "char_00016901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「でもさ、それでも任務がパパーっと終わったら、ちょっとくらいは遊んでも\nよくない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_010022550006" ]},
		{"command":[ "SETCHARA", "0", "char_00017001_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「全く……今から遊ぶことばかり考えて仕方ないやつだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010022550006" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「いーじゃん。ちゃんと仕事した後ならさー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_010022550007" ]},
		{"command":[ "SETCHARA", "0", "char_00017001_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「遺跡ってのが何かイヤな予感するんだよな……って……何だこれ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「先程、長官が立ち去る時にこぼれ落ちていたような気がしましたが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022550002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「チラシか。なになに……？　今が絶対に狙い目、これから来る夏の新作水着\n、最大５０％オフ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「めちゃくちゃバカンス気分満々だったようですな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022550003" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}