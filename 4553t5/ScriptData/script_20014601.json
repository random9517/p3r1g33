{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0149" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お、終わったぁ……」", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "次から次へと舞い込んでくる雑務がようやく一息ついて、俺はそのまま机に突\nっ伏した。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「このクソブラック組織……いい加減、何とかしねぇとマジで早死にするんじ\nゃねぇか？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "残業につぐ残業を通り越え、最近は泊まり込みも当たり前のようになってきた\n。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うぅ……目が霞む……なんか、前にもこんなようなことがあった気がしたが\n……ダメだ限界だ……」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「とにかく一回寝よう。後のことは目覚めてスッキリした俺がやってくれる…\n…他に誰もいねぇしな……うぅ……ｚｚｚ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0000" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "………………", "NORMAL" ]},
		{"command":[ "DISPNAME", "fALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "…………", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "……", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0144" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_009" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……うぅぅ……んっ、ん、むっ……」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ふぁぁ……何か、ぐっすり寝ちまった気がするな……もう、起きなきゃ……\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……はっ……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「な、何だ？　ここはどこだ……？　俺は確か寝てて……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "目を覚ました途端、飛び込んできた景色は全く知らない場所だった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「この大仰なイスに……か、身体が……縛られてるっ！？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "徐々に頭が本格的にはっきりしてくると、何やら教会のような……厳かな雰囲\n気の場所のど真ん中でイスに縛られていることに気がついた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「どうなってやがる……誰かいないのか……？　ん……？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そう思って辺りを見渡した途端、端の方に見えた司会席のような場所にスポッ\nトが当てられた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「レディースアンドジェントルメン！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023090001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「花婿ロワイアルの世界へようこそお越しくださいました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110023090001" ]},
		{"command":[ "SETCHARA", "0", "char_00000514_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "正面にあった巨大モニターに、ジュンジローとハルノブの姿が映し出される。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「な、何だ……花嫁……ロワイアル？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「えぇ、今日は大勢の皆様にお集まりいただきまして、誠にありがとうござい\nます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023090002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「このような盛会を迎えられますこと、我々は深く感謝いたします」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110023090002" ]},
		{"command":[ "SETCHARA", "0", "char_00000514_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「感謝って……いや、誰もいねぇじゃねぇか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ちちち、そう慌てない。既に準備は整っていますからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023090003" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「という訳で……本日は、みなさんに、ちょーっと花婿争奪戦をしてもらいま\nす」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023090004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はぁ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「舞台は泣く子も黙るブライド時空！　たった一人の男性を巡って争われる、\n花嫁たちの華麗なる戦い！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023090005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「もちろん、優勝賞品はこの方……ごしゅ……カツマ殿！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023090006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "スポットライトが俺の方に集中し、モニターにも俺の姿がアップで映される。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「少し見た目は冴えませんが、そこはブライド時空。多少の粗も、花嫁たちは\n見逃してくれます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023090007" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「クソっ……動けねぇと思って言いたい放題言いやがる……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「早速ですが、まずは基本的なルールから説明してまいりましょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023090008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「選ばれし精鋭は３チーム、３名ずつの合計９名。チームから代表者が１人ず\nつ選ばれ、３人対戦で各種競技をしていただきます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110023090003" ]},
		{"command":[ "SETCHARA", "0", "char_00000514_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「競技は全部で３種類。それぞれチームから１人ずつメンバーを選択して得点\nを競い、上位１チームのみが決勝へ進出」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023090009" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ポイントの最も高いチームの３名が、最後に唯一の花嫁となるべく争い、勝\n者を決めることになります」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110023090004" ]},
		{"command":[ "SETCHARA", "0", "char_00000514_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「正しく昨日の友は今日の敵！　勝ちのこれるのはたった一人の厳しい戦い！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023090010" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ドロドロの女の醜い一面が見られると思うと、なかなか楽しみですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110023090005" ]},
		{"command":[ "SETCHARA", "0", "char_00000514_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「そんな訳で、早速ですが全ヒロインっ……入っ場っ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023090011" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「まずは、オリジナル部門チームの３名です！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023090012" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「先陣を切るのは、不遇ながらも持ち前の積極性で、今や押しかけ妻の筆頭候\n補！　亡星の巫女姫、アン＝クァー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023090013" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「初手から微妙に犯罪臭が漂いますが……言うだけ無駄でしょうね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110023090006" ]},
		{"command":[ "SETCHARA", "0", "char_00000514_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「子供は何人にしましょうか。旦那さま……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_010023090001" ]},
		{"command":[ "SETCHARA", "0", "char_00022101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「続きましては、我らがＥＤＯの日本支部長官！　忙しい中、無理を押しての\n登場です。今日はフルネームでの参戦、冴島美鈴！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023090014" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「年齢としてはギリギリのラインでしょうか。余裕のない必死さが見ものかも\n知れません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110023090007" ]},
		{"command":[ "SETCHARA", "0", "char_00000514_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「大人の魅力……存分に発揮してみせる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010023090001" ]},
		{"command":[ "SETCHARA", "0", "char_00004908_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「更に更に、花嫁に名乗りを上げるのはありなのか？　時間帝国を統べる女王\nにして、カツマ殿の母を名乗るはこの方、刻の女王！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023090015" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「余りにも節操がありませんね。しかし、ターゲットとの距離感を気にしない\n強さはあるでしょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110023090008" ]},
		{"command":[ "SETCHARA", "0", "char_00000514_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「母と花嫁が重なることに何の矛盾もない。どちらも母が、務めて見せようぞ\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010023090001" ]},
		{"command":[ "SETCHARA", "0", "char_00020103_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「さあ、次のチームは、歴史の重さが違う原作部門チームの３名、その先頭は\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023090016" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「いきなり反則級のラスボスの一人！　我らが月の王国グレート・ルナリアム\nの女王にして永遠のカリスマ！　ルナルバース１３世！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023090017" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「本来なら死んでいるという設定の筈だった気がしましたが……いよいよもっ\nて選考基準が不明ですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110023090009" ]},
		{"command":[ "SETCHARA", "0", "char_00000514_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ふん、人気が全てじゃ。ここはブライド時空なんじゃからな。メインシナリ\nオの話など知らんわ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_040023090001" ]},
		{"command":[ "SETCHARA", "0", "char_00000703_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「続いて出てきましたのは、安定の人気常連！　分かりやすいツンデレは結局\nは大正義！　式神マスター、オボロ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023090018" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ここ最近は人気にあぐらをかいて雲行きが怪しくなっていますが、今回はど\nうなるでしょうね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110023090010" ]},
		{"command":[ "SETCHARA", "0", "char_00000514_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「下らない……ウチに敵などいる筈もありません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010023090001" ]},
		{"command":[ "SETCHARA", "0", "char_00000518_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ここで意外な伏兵が登場！　ブラックメルヘンの刺客、アンハッピートリガ\nーの真髄はいかに？　グリムロック！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023090019" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「一見場違いなのではという人選ですが、下馬評を覆す活躍をするのか、普通\nに埋没するか興味深いですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110023090011" ]},
		{"command":[ "SETCHARA", "0", "char_00000514_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「フ……フフ……！　また、あることないこと適当に言われてる気がするよ…\n…慣れてるけどね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010023090001" ]},
		{"command":[ "SETCHARA", "0", "char_00001801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「最後に待つチームは、圧倒的強者っ殿堂入り部門チーム！　こちらの先頭を\n務めるのは……」」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023090020" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「そう、このはち切れんばかりのバストの正体は間違いない！　溢れんばかり\nの母乳と母性！　癒やされたいです、牛神様！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023090021" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「女の武器もここまで来ると、凶悪な兵器ですね。少しは持たざる者の気持ち\nも考えやがれです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110023090012" ]},
		{"command":[ "SETCHARA", "0", "char_00000514_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あらまぁ……よく分かりませんが、精一杯頑張ります」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_020023090001" ]},
		{"command":[ "SETCHARA", "0", "char_00003004_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「お待たせしました。もう一つの可能性は、今や組織きっての良心とまで！　\nヒロインの風格も十分、アナザー・ルナテミス！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023090022" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「オリジナルのポンコツがいいという向きもありますが、花嫁ということを考\nえると妥当な選択かも知れませんね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110023090013" ]},
		{"command":[ "SETCHARA", "0", "char_00000514_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「万全を尽くす！　私にできるのはそれだけだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090023090001" ]},
		{"command":[ "SETCHARA", "0", "char_00000122_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「そして、大トリに控えしは、愛の重さは誰にも負けない！　幼馴染という最\n強属性を備えた、圧倒的強者……カグヤ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023090023" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「これだけの優位ポジにありながら、未だ決め手に欠けるここ一番の弱さ……\n今回はどう働きますかねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110023090014" ]},
		{"command":[ "SETCHARA", "0", "char_00000514_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「カツマのお嫁さんは絶対に……譲れない……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010023090001" ]},
		{"command":[ "SETCHARA", "0", "char_00000214_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「さて、全出場者が出揃ったところで、改めまして進行はおなじみジュンジロ\nー。そして、解説は……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023090024" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「前回人気投票、圧倒的『１位』のハルノブがお送りします」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110023090015" ]},
		{"command":[ "SETCHARA", "0", "char_00000514_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「はてさて、男１人しか存在が許されないこのブライド時空。一体、どのよう\nな結末が待ち受けているのか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023090025" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「そして、そんな設定の割には、どうして私はしっかり存在できているのでし\nょうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023090026" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「まあ、作ってる人もそこまで深く考えてないと思いますよ。ブライド時空も\n、それなりに進化しているという感じでいいでしょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110023090016" ]},
		{"command":[ "SETCHARA", "0", "char_00000514_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「或いは、深遠な秘密が隠されているかもしれませんが、それはここでは明か\nされないということでご了承ください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023090027" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「…………ブライド時空……くそ……前にも似たようなことがあったような…\n…」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "縛られたまま、俺は一連の流れを呆然と見守るしかなかった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「それでは、早速第一競技……の前に、一旦ここでバトルをしていただきまし\nょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023090028" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ＣＭみたいに入れるんじゃねーです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110023090017" ]},
		{"command":[ "SETCHARA", "0", "char_00000514_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「では、レッツバトルですぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023090029" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}