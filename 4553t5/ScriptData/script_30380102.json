		{"command":[ "PLAYVOICE", "038_0104305" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「隊長さんのお汁、ぜーんぶぜんぶゴクゴクしたくテ……オマンコのヒダヒダ\n、きゅうきゅう締まってるのヨ……アッ♪　ほら♪　ほらッ♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0104306" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
