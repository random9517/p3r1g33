		{"command":[ "PLAYVOICE", "038_0104309" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「私のコトここまで狂わせるの、隊長さんだけ……。オチンポも、カラダも超\n一級……♪　私、決めたヨ♪」", "NORMAL" ]},
