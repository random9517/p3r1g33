		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0104303" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「イクぅううう……っ！　イク、イクイクぅう……！　しゅごいィ……♪　今\n、隊長さんと私、溶け合って……一つにあって、昇ってクぅ……♪」", "NORMAL" ]},
