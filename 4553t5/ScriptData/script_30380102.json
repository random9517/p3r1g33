		{"command":[ "PLAYVOICE", "038_0104216" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「んぁっあああああっ！　あーっアアッ！　バリバリ、バリバリ雷が落ちてる\nみたいニっ……オマンコの中、気持ちイイが渦巻いて大変んん……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0104217" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「あーっ！　おかしくなっちゃウ、おかしくなってくゥ……！　Ｈ好きっ、Ｈ\n好きィ……！　隊長さんのオチンポ大好物ぅう～～っ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0104218" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「もー大好きな肉まん食べられなくなってもイイから……このまま、このまま\nＨしテ、Ｈしまくって、私とＨしてェエエエ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0104219" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「ハメハメッ、ハメハメ最高ヨ！　隊長さんとする子作り、禁断の味すぎるア\nルぅ……！　あーっ、アッ♪　アッ♪　美味しいぃい……っ♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0104220" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「このまま、このままず～～～っと二人デ……二人でずっと……ぉっ！　Ｈす\nるアル、Ｈし続けたいアルぅ……あっ！　あっ、あぁああっ！」", "NORMAL" ]},
