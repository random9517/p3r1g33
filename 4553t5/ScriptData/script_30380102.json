		{"command":[ "PLAYVOICE", "038_0104308" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「っあぁあああああ……♪　陶酔状態ヨぉ……。極上のお酒に酔ったみたいな\nノ……♪　隊長さんって底知れないネ……♪」", "NORMAL" ]},
