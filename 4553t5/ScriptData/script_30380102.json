{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003801_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "PLAYVOICE", "038_0104101" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「フフフッ……♪　お招きありがとーアル。さすがに、にぶーい天然娘の私で\nも……ここに呼ばれた意味はわかるヨ……？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0104102" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「今日は私と……Ｈしたいんでショ……？　アノネぇ……私も、隊長さんと同\nじキモチ……。だから、ホラ……見て？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0104103" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「ここに来る前に、おぱんつ脱いで……来たノ。すぐに出来るよーに……。チ\nャイナの裾、短いからめっちゃ興奮しちゃっタ……♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0104104" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「……ごくっ……。隊長さん、むっちゃチンチンおっきくなってル……。嬉し\nイ……。でも、私も負けてないヨ……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0104105" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「もうすぐ隊長さんとシちゃう、て考えただけで……ネ？　お股がヌルヌルト\nロトロになっちゃった……。初Ｈなのにおかしーネ……淫乱かナ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0104106" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「ン……。こやって……。お股のぷっくりした肉で、隊長さんのオチンチンを\nぷにゅっぷちゅってこするとネ……想像しちゃって気持ちイーの……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0104107" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「こんなデッカイチンチン入れたら、どーなるのかナぁって……。あっ♪　だ\nって……アソコにあてがうとわかっちゃウ……お腹のどこまで来るのカ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0104108" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「おへその裏までずっぷり入っちゃうナぁって……。んっ……。怖いアル。め\nっちゃビビてる。でも……ここでやめるのはもっとイヤ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0104109" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「ネ……。私とＨしヨ？　はぁ、はぁ……いいよネ？　乳々飯店の看板ムスメ\n、戦神の蚩尤を独り占めできるのヨ。史上初、歴史に残るヨ、きっと」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0104110" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「……私をオンナに出来るのは隊長さんだケ……。私のココ、処女のオマンコ\nにずぶぅってオチンチン入れられるの……アナタだけ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0104111" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「アア、もう我慢できナイ……。入れちゃうネ？　入れるアルよ？　イイネ？\n　……っは……ッ、はぁ、っ……あああああ……来る、ぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0104112" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「んあっ、アアアアアッ！？　入っ……タ、入っちゃったァ……！　アッ♪　\nこ、コレっ、チンチンて感じじゃないヨ、お……オチンポ……だヨぉ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003801_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0104113" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「隊長さんの大人オチンポ、スッゴい……！　や、やぁあっ、勝手に腰がクネ\nクネしちゃうノぉ……！　私のオマンコ、キュウキュウくっついてくぅ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0104114" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「あっ！　アッ、あっ、あっ、アッ……！　ナニッ！？　何コレっ……！　あ\nあっ……ああっ、こ、これがオチンポっ……隊長のオチンポなのカ……っ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0104115" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「な、なんか、オマンコのヒダヒダにぴったりくっついて……ェ、お腹の奥、\n切なくなル……。お尻モジモジして、ジッとしてらんナイ……っ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0104116" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「っはぁっ……！　ハァッ、ハァッ……！　恥ずかしいのニ……！　まだ慣ら\nしてもいないのニ……もっと、もっと深く繋がりたくなルぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0104117" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「アッ……！　オマンコの行き止まりっ、この野太いゴツゴツチンポでえぐっ\nて欲しくなル……！　私、どうかしてしまたアルぅ……ああああっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003801_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0104118" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「ひゃっ、ひゃぁっ！　アッ！　あっ、あっあっ……！　ダメ……っ、だめ、\nダメぇ……！　まだ入れたばかり、なのに……なのニ……動かしたラ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0104119" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「あっアアアアアッ！　敏感な粘膜にぐりゅぐりゅこすれて……ェ！　アッ！\n　目の前がチカチカ、して……アッ！　あっ！　あっ！　あっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0104120" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「腰、振ったらダメぇ……お尻揺らしたら気持ちいいの来るゥ……！　アッ！\n　わかってるのに、やめられないノぉ……あっあっ隊長さん！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0104121" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「はしたないオンナて思わないでェ……！　違うノぉっ、私、Ｈな女の子じゃ\nないのヨぉ……！　でも……あっああああっ、やめられないっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0104122" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「ちょっとでも、ちょとでもオチンポでオマンコずこずこしたくてたまらない\nアル……！　ヒダヒダでオチンポヌルヌルしてたいアルぅ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0104123" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「っ……あぅっ！？　あっあっあっあふっ……！　なんで……ナンデ、なんで\n……！　ただのお肉の棒、オチンポが入っただけでぇ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003801_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0104124" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「私のＨスイッチ完全に入ってしまたヨ……っ！　隊長さんのチンポ、媚薬で\nも塗ってあるのカ！？　アッ！　猫にまたたびヨ、痺れるアルぅ～～！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0104125" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「あっアアアアッ……！　気持ちいいっ、気持ちイイ、気持ちイイ……っ！　\nは、初めては痛いて聞いてたのに、こんな良くていいものなノ……！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0104126" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「頭、ジンジンして……あーっ！　お股もビクビクして……アッアッ！　ちょ\nと角度変えてゴシゴシするだけ……で、全身に電気ビリビリィ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0104127" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「ビリッ、ビリッて電気走って何も考えられなくなっちゃうゥ……っ！　あっ\n！　モット！　もっと、色んな部分押し付けたい、突かれたいィ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0104128" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「アヒッ、あひっ、あひっ……！　やだぁ……ッ、オチンポのことしか考えら\nれなくなっちゃうゥ、オチンポ狂いになっちゃうヨぉ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0104129" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「お……おかしいでショ？　赤ちゃん作るのに、アッ！　こんな気持ち良すぎ\nたら……アァアンッ！　お母さんラリっちゃうでショぉおお……っ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0104130" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「アヘアヘになったら、も、赤ちゃん育てられなくなっちゃうじゃなィ……ッ\n、それとも、隊長さんのオチンポだけが良すぎるアルかぁあ……！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0104131" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「私のアソコにぴったりフィットして……アッああああっ！　ちょうどイイと\nこっ、好きなとこ刺激してくるのっ……あひっ、ひぃっ、ヒィッ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003801_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0104132" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「上手すぎるのヨ、このオチンポ……っ、私をよがり狂わせるのに特化しすぎ\nてるノ！！　やめっ……もう、もうやめてェ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0104133" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「アッ！　アッ！　アッ！　私のオマンコの中でどんどん太くなって、膨らん\nで……これでもかこれでもかって貫いてくるノぉ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0104134" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「あっ！　イヤッ！　イヤッ、いやヨ、いやぁ……！　そんなにおっきくしな\nいデ……！　もう充分よ、お腹いっぱいィ……！　えっ……！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0104135" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「イキそうだから膨らんでル……？　イ、……イクて……ダメぇ！　このまま\nここに出すつもりアル！？　な、中出し、中出しなんかされたらァ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003801_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0104136" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「私死んじゃうヨ、イキまくって死んじゃうヨ！　そりゃ、ハジメテは最後ま\nで一緒にて思ってたけど、ケドぉ……予想外なノ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003801_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0104137" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「こんっ、な、こん、な、ここまで気持ちよくて、アッ！　こんなスゴいなん\nて知らなかったかラ……っ！　あーっ！　ダメダメダメぇえっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0104138" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「だ、出さないデ、今出しちゃダメ……ダ、ダ、メ……あっ！　出す！？　出\nすノっ！？　あーっ！　あーっ！　あーっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0104139" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「ッアアアアアアアアーッ！！　ホントに出しちゃタぁああああっ……！　ア\nーッ！　ダメダメダメぇええええ！　イっちゃう、イちゃうゥウウ！」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003801_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0104140" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「アーッ！　私、わたひぃい……アソコがスパークしちゃってェエエ……！　\n死んじゃうッ、死んじゃうぅうーーーーーっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0104201" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「……ッ……っはっ！？　や、ヤダ……。私、今、気絶してタ……。意識なく\nしてタ……はぁ、はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003801_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0104202" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「すごい眩暈……。頭、グラングランするゥ……。コレが、コレが中出しなの\nネ……。降参、降参アル……。あー、恥ずかしィ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0104203" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「私だけ乱れまくって、お尻振って……中出しされて失神しテ……。とんだ初\nＨヨ……って、コラッ！　隊長さん、な、なにしてるアル……！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0104204" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「アッ！？　ちょっ、ちょ、ま、まさかとは思うアルが……。休憩なしでこの\nまま、二回戦行くつもりなノ……！？　アッ、無理っ、無理よ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003801_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0104205" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「さっきの見てたでショ……！　隊長さんのオチンポ、チンチンってレベルじ\nゃないノ！　私にむっちゃ効いて、ヤバイのォオ……っ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0104206" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「イッて気絶した直後に、ンッ、チンポそんな風に出し入れ、したラ……っあ\nっ！？　アアアアッ！？　アーッ！　あーっ、あーッほらァアア！！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003801_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0104207" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「わた、ひ、わたひ、またスグっ……！　スグ飛んじゃう、スグおかしくなっ\nて……オチンポ大好きになっちゃウ……ひぁああああんんんっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0104208" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「それっ、それナシっ！　私のオマンコ、下からほじくるの無しィイイ……！\n　あっ、あっぐっ……！　あっふっ、ファッ……ふぁあああっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0104209" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「串刺しっ……串刺しになっちゃっテ……る……！　隊長さんの、お汁たっぷ\nりついた危険なオチンポ……私のオマンコに入ったり出たり、あーっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0104210" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「さ、さっき私が一人でしてた時よりエグい動きしてるゥウウ……！　どっち\nゅんどっちゅん、容赦なくピストンッ、してる、あぁああんっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0104211" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「隊長さん、隊長さぁん！　隊長さんってやっぱスゴいよぉ、スゴすぎィィ…\n…！　Ｈの天才なのォ……！？　あっ！　あふぁあっ、あぁっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003801_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0104212" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「私が戦場でがんばってたトキぃ……隊長さんはＨの練習してたノぉ……！？\n　でないと説明つかないくらい気持ちイイのヨぉ、どゆことぉ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0104213" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「……ンッ！？　わ、私がエロいだけ……！？　私がＨ大好き娘なダケ……！\n？　あっ……ち、違うアル！　そじゃなくてッ……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003801_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0104214" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「私は隊長さんが好きだからッ、Ｈも気持ちイイかもて思ってたケドっ……！\n　それだけじゃ説明つかないくらいイイのっ、おかしーのヨぉおおっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0104215" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「ンッアアアアアーッ！！　反則、反則ヨぉ！　オチンポぐりぐり回さ、ない\nで……私のオマンコ掻き回したら危ないィ……！」", "NORMAL" ]},
