		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「と、いうわけで特訓を始める！　準備はできたか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_020116570001" ]},
		{"command":[ "SETCHARA", "0", "char_00000702_01", "6", "CENTER", "0" ]},
