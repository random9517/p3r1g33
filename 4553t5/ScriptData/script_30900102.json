		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "090_0104104" ]},
		{"command":[ "SETNAME", "セラフィックスター" ]},
		{"command":[ "SETTEXT", "「わたしのおまんこ、早くほしいってヒクついてるんです……お願い隊長さん\n、わたしにその太いおちんちんを下さい」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "090_0104105" ]},
		{"command":[ "SETNAME", "セラフィックスター" ]},
		{"command":[ "SETTEXT", "「んっ、はぁっ、はぁっ……あっ！　隊長さんのおちんちん、すごく熱い……\nこれが今からわたしの中に……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "090_0104106" ]},
		{"command":[ "SETNAME", "セラフィックスター" ]},
		{"command":[ "SETTEXT", "「ドキドキしますね……はい、お願いします。んっ、んんんんっ！　あ、くぅ\nっ、き、きつい……っ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "090_0104107" ]},
		{"command":[ "SETNAME", "セラフィックスター" ]},
		{"command":[ "SETTEXT", "「隊長さんのおちんちん、想像以上に大きくて……んぁっ、あっ、んんんっ！\n　大丈夫、そのまま一気に……んぁぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009001_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "090_0104108" ]},
		{"command":[ "SETNAME", "セラフィックスター" ]},
