		{"command":[ "SETNAME", "セラフィックスター" ]},
		{"command":[ "SETTEXT", "「見て下さい、わたしのおまんこ……。ほら、こんなに奥まで濡れちゃってる\nでしょ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "090_0104103" ]},
		{"command":[ "SETNAME", "セラフィックスター" ]},
