		{"command":[ "PLAYVOICE", "090_0104111" ]},
		{"command":[ "SETNAME", "セラフィックスター" ]},
		{"command":[ "SETTEXT", "「んぁっ、ふぁぁぁぁっ！　す、すごい……きついのに、んっ、んぁっ、んん\nんっ、すごく感じちゃう！」", "NORMAL" ]},
