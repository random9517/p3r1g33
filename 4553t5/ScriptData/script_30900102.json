		{"command":[ "PLAYVOICE", "090_0104115" ]},
		{"command":[ "SETNAME", "セラフィックスター" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、あんっ、あんっ、あんっ！　いいっ、すごくいいですっ！　襞\nが擦れてっ、気持ちいいの、どんどんせり上がってきます！」", "NORMAL" ]},
