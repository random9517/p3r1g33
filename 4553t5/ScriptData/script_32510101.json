		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「ぬ、脱ぎました……その、前……オ、オチンチン……挟ませて……頂きます\nね……んっ、んふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0103106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00025101_01_02" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、こ、これで……いいですか？　うぁぁ……は、恥ずかしい…\n…これぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0103107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「あ、当たり前ですっ！　こんな……胸を見せて……恥ずかしくないわけない\nじゃないですかっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「こ、これからが本番……そ、そうですよね……え、ええと……それでは……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「今から……お仕置きとして……あなたのオチンチンを、パイズリさせて頂き\nます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「パ、パイズリ経験なんて……ないですっ、けどっ、とにかく……動かして、\nオチンチンを気持ちよくさせれば、いいんですよね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0103111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「とにかく、やってみます……んっ、んしょっ、んふっ、あっ、んっ……んく\nっ、あっふ……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「うぁ……これ、硬い……けど……や、柔らかいところも……あって……不思\n議な……感じが……あっ、んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「これを……寄せて、いけばいいんですか……？　んっ、しょっ……こういう\n……感じ……？　あふっ……んんっ……ん、くっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0103114" ]},
		{"command":[ "SETIMAGE", "0", "still_00025101_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「んぁっ……オチンチンに、重なって……めり込んでいく……感じ……はっ、\nんふぁっ……あっ、んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0103115" ]},
		{"command":[ "SETIMAGE", "0", "still_00025101_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「もっと寄せる……は、はい……こう……でしょうか……？　んくぁっ……熱\nい……あふっ、すごく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「はぁっ、んんっ……あぁ……これで気持ちよくなるんでしょうか……？　自\n分だと……よく、分からなくて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「あ……でも、その肌の感触は……すごく……はっきりと分かります……それ\nが、何となく……気持ちいいのかもとは……思います……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「もっと、大きく……身体全体を使って……揺らしていく……は、はい。んっ\n、ふっ、あふっ……んんっ、あっ、んぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「確かに……んっ、ちょっと……あっ、変な感じが……しています……んんっ\n……胸とオチンチンが……こ、擦れる程……熱くなってるような……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「えっ……言い方……？　お、おっぱい……ですか。は、はぁ……そう仰るな\nら……その、おっぱいと……オチンチンが擦れて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0103121" ]},
		{"command":[ "SETIMAGE", "0", "still_00025101_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「んっ、あっ、先端……乳首……んっ、今……くっつけるんですか……？　は\n、はい……ひっ、んぅっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「あっ……こ、これ……あっ、何だか……すごい、です……あっ、んくぅ……\nはっ、やだ……ドキドキ、するっ……んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0103123" ]},
		{"command":[ "SETIMAGE", "0", "still_00025101_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「はっ、んふっ……あぁっ……オチンチンも、そうなんですか……？　わたし\nの、んっ、パイズリで気持ちよくなってるんですね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「はい、もっと……めり込ませて……上下に動かして……あっ、あぁっ……ん\nんっ、こういう……感じ、ですよねっ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「はぁっ、あふっ、んぁぁっ……すごい……あっ、オチンチン……ビクってす\nるの、分かります……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「ここにもっとおっぱいをくっつけて……スライドさせて……んっ、あふっ！\n　滑ると……ドキドキ……します……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「唾液を足すと……もっと滑る……わ、分かりました……んっ、えろ……これ\nで……どうでしょうか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「はっ、んんっ……あぁっ……本当です……んっ、さっきよりおっぱいが……\nぬるっとして……気持ち……んっ、いいですっ、んぁっ……」", "NORMAL" ]},
