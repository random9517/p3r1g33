		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「これは、わたしが負けたせいであって、そのお仕置きなんですから、遠慮し\nないでっ……一生懸命……パイズリしますからっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0103216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「あぁっ、オチンチンっ……ビクビクしてますっ……んっ、あぁっ、もうすぐ\n……ですよねっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「分かりますっ……だって、そんな口元をぎゅっとさせて……腰も震えさせて\nいるのに……んふっ、あふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0103218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「はいっ、どんな……形でも構いませんっ……おっぱい……ずっとコスコスし\nますからっ、あぁっ、出してっ……下さいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「また……思いっきり射精してっ……ぴゅるって……精液っ……いっぱいっ、\n出して下さいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「ひぁっ！　あっ……んんっ……また……おっぱいの中にっ……いっぱい……\n出てますっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0103301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00025101_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「あぅ……んっ、熱い……さっきのと同じくらい……いえ、もっと……あぁ、\nお肌が……ヌルヌルにされてます……はふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「はい……あぁ……たくさん出して下さい……私のパイズリで……オチンチン\n、いっぱい気持ちよくなってくれたんですよね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0103303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「はぁぁ……んっ、あぁ……またぴゅるぴゅる……精液……漏れて来てますね\n……んふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0103304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「やっぱり、出てる時が一番気持ちいいんですか？　その……すごくうっとり\nした顔をされてて……んふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0103305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「えっ……わ、私も……？　あ……嘘……今、私……そんなうっとりしてまし\nたか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0103306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「やだ、恥ずかしい……でも、無我夢中で……自分のこと、気にしてる余裕が\nなくて……ただ、ちょっと気持ちよかったかも知れません……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0103307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「あ……射精……終わりましたね。ふぅ……これでお仕置きは終わりというこ\nとでいいんでしょうか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0103308" ]},
		{"command":[ "SETIMAGE", "0", "still_00025101_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「そ、そうですね……次は、こんな風にならないように気をつけなくちゃいけ\nませんね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「あ……で、でも、また負けてしまったら……その、その時は……お手柔らか\nにお願いします……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「んぁぁっ！　はぷっ……やっ、か、顔にっ……いっぱい……んぁっ、んんん\nんんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0103401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00025101_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「んんっ……あぁっ、濃いのが……頬にドロってへばりついて……あぁぁ……\nこんなにぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「いえ……大丈夫です……んっ、ふっ……これはお仕置きなんですから……甘\nんじて、お受けします……んぁ、ぷ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0103403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「はぁぁ……すごい量……でも、わたしのパイズリで……こんなに出してくれ\nたんですよね……んふぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0103404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ……んっ、えろっ……んくっ、お、美味しい……ものじゃない、で\nすね……これは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0103405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「慣れたら……この味も好きになる……？　ほ、本当でしょうか……その、試\nしてみたくは……ないですけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0103406" ]},
		{"command":[ "SETIMAGE", "0", "still_00025101_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「でも、んっ……絶対無理ではない気がします……んっ……もう一口だけ……\nちゅぷ……んっ、あふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0103407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「あ……終わりました？　えっ、いえっ……その、夢中で味わっていた訳では\n……な、ないですっ……ほ、本当ですっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0103408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「とにかく、これでお仕置きは終わりですね？　はい、今度は……負けないで\nす。絶対に……負けませんから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0103409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「でも、そうしたら……今回のも終わり……えっ？　あ、い、いえっ、何でも\nないですっ、はい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0103410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
