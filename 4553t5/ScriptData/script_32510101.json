		{"command":[ "SETIMAGE", "0", "still_00025101_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「はい……今度は、もう少し上手く出来るような気がします……んっ、ふっ、\nはっ……あっ……あぁっ、はっ、んっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0103204" ]},
		{"command":[ "SETIMAGE", "0", "still_00025101_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「不思議です……んっ、あなたの気持ちよさそうな顔を見てると……わたしま\nで……なんだか気持ちよくなって来てしまって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「はぁっ、んっ、オチンチン……もっとしてみたいです……んふぅっ、はっ、\nんっ……あぁっ……精液……ドロっとしてる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「ぐちゅぐちゅって……おっぱいからすごい音……あぁ……恥ずかしい……ん\nんっ、くぅっ……あっ、ふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「……この辺……気持ちいいんですね？　カリ首……って言うんですね……\nはぁぁ……そこと……乳首を、重ねて……ひぁぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0103208" ]},
		{"command":[ "SETIMAGE", "0", "still_00025101_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「あっ……わたしの乳首も……すごく、今……感じやすくなってるみたいです\n……オチンチンに擦れると……ピクってして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「はぁっ、んっ……先っぽ同士のキスぅ……エッチで止まらなくなってるぅ…\n…はぁっ、んぁっ、あっ、くぅんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0103210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「うぁっ……はぁんっ……出された精液がベトベトで……あぁっ、塗りつけて\n……いいんですか？　気持ち悪くないですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0103211" ]},
		{"command":[ "SETIMAGE", "0", "still_00025101_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「んっ……もっと、して欲しい……は、はい……それなら……オチンチン……\n精液まみれにしちゃいますっ……はぁっ、んぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「あぁっ、おっぱい……揺れてるっ……わたし、こんな大胆なことしちゃって\nるっ……あっ、あぁっ……こんなのお姉ちゃんにも見せられないっ……」", "NORMAL" ]},
