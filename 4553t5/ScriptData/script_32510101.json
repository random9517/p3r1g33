		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「あぁっ……熱っぽくて……それに、このむわっとするにおい……んんっ、嗅\nいでると……ますます……疼いて……はぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「んんっ……あぁ、自然に身体……動いちゃいます……んっ、乳首を……オチ\nンチンの先っぽに……押し付けて……あっ、はぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「んくぅっ、あぁっ……こんなことっ……いやらしいのにっ……手が止まらな\nいっ……あぁっ、はっ、あぁぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「オチンチンも……震えてますっ……んぁっ、はっ、あぁっ……これ……この\nまま、するとどうなるんですかっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0103133" ]},
		{"command":[ "SETIMAGE", "0", "still_00025101_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「イク……？　射精……するって……ことですよね？　えっ……も、もうすぐ\nっ？　あっ、で、でもっ……そんな急に言われても心の準備がっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0103134" ]},
		{"command":[ "SETIMAGE", "0", "still_00025101_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「んっ、あぁっ、とにかく……いっぱい扱くっ？　は、はいっ、んっ、あっ、\nはっ、こ、こうですかっ、あっ、はっ、んぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0103135" ]},
		{"command":[ "SETIMAGE", "0", "still_00025101_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「ひぁぁぁぁんっ！？　あっ、いっぱい出てきてっ……んぁっ、おっぱいにっ\n……精液っ……あぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0103136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00025101_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「あふぁ……すごい……ドロドロになってます……んぅっ、すごい……におい\n……はぁぁぁ……こんなにぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0103137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「あ……やっと……収まって来ました……でも、まだ溢れてる……すごい……\n谷間の中がドロドロです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0103138" ]},
		{"command":[ "SETIMAGE", "0", "still_00025101_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「粘っこい……でも、パイズリが……上手くいってくれたということでしょう\nか……それなら良かったですけど……」", "NORMAL" ]},
