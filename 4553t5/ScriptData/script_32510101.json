		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「は、はい……分かっています。負けたらお仕置きを受ける……そういう約束\nでしたし、それを違えるつもりはありません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0103102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「その……ただ、あまり慣れてませんから……できれば……お手柔らかにして\nいただけると……どうすればいいんでしょうか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0103103" ]},
		{"command":[ "SETCHARA", "0", "char_00025101_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「あ……は、はい……えと……っ……！　そ、そういうことを……し、しなく\nてはならないと……い、いえ、分かっていますっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0103104" ]},
		{"command":[ "SETCHARA", "0", "char_00025101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「あの……ぬ、脱ぎますから、少しだけ向こうを向いて頂けると……うぅっ…\n…ど、どうせ見せるから……？　わ、分かりました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0103105" ]},
