		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「はぁ……こんな射精量……初めてです……びっくり……しました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「あぁ……まだ、オチンチン……おっぱいの中でとくんとくんって……蠢いて\nます……んっふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0103201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「その、もしかして……まだ、ご満足いただけてない……感じでしょうか……\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0103202" ]},
		{"command":[ "SETIMAGE", "0", "still_00025101_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「いえ、何となくですけど……でも、それなら……このまま続けても……いい\nでしょうか」", "NORMAL" ]},
