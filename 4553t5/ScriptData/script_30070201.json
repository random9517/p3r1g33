{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000702_01_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「どれ……んっ……ふふー、お主の勃起チンポが、すっぽりと私のオッパイの\n中に収まってしまったぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0203101" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「ほれほれ、どうだー？　柔らかいだろう？　一応、これでも形にはそれなり\nの自信を持っているのだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0203102" ]},
		{"command":[ "SETIMAGE", "0", "still_00000702_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「サイズも、まあ規格外の連中には敵わんかも知れんが、なに、大事なのは何\nよりもこのチンポを満足させてやれるかどうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0203103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「その点においては、間違いなくお主を満足させてやれると……それはしかと\n保証しておこう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0203104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「ふふ……それにしても、遠慮なくじぃっと見てくれるものだな。やはり、女\n体の中でもオッパイというのは格別なものか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0203105" ]},
		{"command":[ "SETIMAGE", "0", "still_00000702_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「確かに、欲望に忠実なその顔を見ていると、何となく母性本能のようなもの\nをくすぐられる気はしなくもない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0203106" ]},
		{"command":[ "SETIMAGE", "0", "still_00000702_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「よし、それなら今日の私は、お主の……いや、あなたのママになって、甘や\nかしてあげましょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0203107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「ん？　ママはパイズリなんかしない？　そんな細かい正論とかどうでもいい\n！　いいから、素直に身を任せて甘えればいいのだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0203108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「さあ……どうして欲しいのか、言ってみなさい？　今なら、どんな我儘でも\n聞いてあげちゃいますよ～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0203109" ]},
		{"command":[ "SETIMAGE", "0", "still_00000702_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「ふふっ、そう……この元気なオチンチンを、オッパイでシコシコして欲しい\nのねぇー、可愛いボクちゃんの為だもの、ママは頑張るわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0203110" ]},
		{"command":[ "SETIMAGE", "0", "still_00000702_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「んんっ……ほら……こうして、むにゅぅぅって……あはっ、オチンチン……\n震えてる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0203111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「サイズは立派だけど、この反応……やっぱり可愛いものじゃないの……いい\nのよ、ママのオッパイでたっぷり感じてちょうだい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0203112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「んっ、こうして……縦にズリズリって擦ってあげると……オッパイの形……\nすごーくいやらしく見えちゃうでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0203113" ]},
		{"command":[ "SETIMAGE", "0", "still_00000702_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「乳首があっちを向いたり、こっちを向いたり……柔らかいから、ぎゅうって\n押し潰れて……あったかいの伝わるじゃない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0203114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「他にも……こうして、ふぅぅぅーって……息を吹きかけてあげたら……オチ\nンチンの先っぽ……ビクンってなっちゃう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0203115" ]},
		{"command":[ "SETIMAGE", "0", "still_00000702_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「ちょっとだけ舐めてあげちゃおうかしら……ぺろっ……ちゅぱっ、ふふっ…\n…ほら、敏感でいい感じ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0203116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「でも、今日はママのオッパイが主役なの……だから、あなたはとにかくオッ\nパイのこと……しっかり意識して感じてね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0203117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「んっ、んふっ、うんっ……ふっ、もし……腰を振りたくなったら、いつでも\nママのオッパイを犯してもいいんだから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0203118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「ふふっ、まだ大人しくしてるみたいね？　いいのよ、じっとしていても、ち\nゃーんと気持ちよくしてあげるから……うんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0203119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「あっ……んふっ、どう……？　このオチンチンの皮の継ぎ目の所……ツンっ\nてつつくようにすると、気持ちいいでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0203120" ]},
		{"command":[ "SETIMAGE", "0", "still_00000702_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「ここを乳首でしてあげたら……んふっ！　ほら、ドキドキする……つんつん\nって……あっ、はぁんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0203121" ]},
		{"command":[ "SETIMAGE", "0", "still_00000702_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「ええ……もちろん、ママのオッパイもとっても感じてるわ……あなたのオチ\nンチンの熱が、近くに伝わるから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0203122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「とっても敏感な所同士が重なって……興奮して……もっともっといい事して\nあげたくなっちゃうの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0203123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「あんっ、はっ、んふんっ、あぁ……オチンチンの皮がめくれて……ピンクの\n割れ目が丸見えになって……すごくいやらしい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0203124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「ほら、ボクちゃんの気持ちいい所……まだまだ、いっぱいあるわよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0203125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「ふふ、とぼけてもダメよ。ママは何でもお見通しなんだから……しっかり全\n体を包み込んで……この辺とか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0203126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「ね、腰が突き出ちゃうでしょう？　あらあら……先っぽから、お汁も滲んで\n来ちゃったわ……ぺろ……ちゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0203127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「んふっ、気持ちよくなってオチンチンミルク、ぴゅっぴゅしたくなっちゃっ\nたのよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0203128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「もちろん、出していいのよ？　ママのオッパイの中に、熱いオチンチンミル\nク……いっぱい出したいわよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0203129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「ほら、そうして欲しかったら、正直に頷いてご覧なさい。もちろん、ムリは\nしなくてもいいわ。イヤなら首を横に振っていいのよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0203130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「……ふふっ、はい、素直に頷けたわねぇ、いい子いい子。それじゃあ、ちゃ\nんとぴゅっぴゅさせてあげないといけないわよね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0203131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「じゃあ、ちょっとだけママの本気を見せてあげるわ……んっ、はっ、んんっ\n、あっ、はっ、んくっ、はんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0203132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「ふふっ、我慢しなくていいからね……んっ、ママの本気のパイズリ……気持\nちよくてたまらないでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0203133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「さあ……出しちゃいなさいっ……力を抜いて……あなたの元気なオチンチン\nミルク……このままオッパイの中にぴゅっぴゅしてっ……んんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0203134" ]},
		{"command":[ "SETIMAGE", "0", "still_00000702_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「はぁぁぁぁんっ！　あっ……出たわっ……！　元気な射精っ……始まってる\nぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0203135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000702_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「んっ、熱いのがオッパイマンコに中出しされてる……んっ、すごい量……あ\nぁ……元気いっぱいのオチンチンミルク……逞しいわね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0203136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「あんっ……先っぽがビクビクして、一生懸命オチンチンミルク搾り出して来\nてる……あぁ、オッパイもっとドロドロにしてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0203137" ]},
		{"command":[ "SETIMAGE", "0", "still_00000702_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「んふっ……少し落ち着いてきたかしら……？　いっぱい頑張ったわね。ほら\n、いい子いい子……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0203138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「え……普通は頭を撫でる？　そうね、せっかくならそうしてあげたいけど、\n今はちょっと手が届かないから。だから、オチンチンを撫でてあげるの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0203139" ]},
		{"command":[ "SETIMAGE", "0", "still_00000702_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「勿論、後でちゃんと頭も撫でてあげるから……心配しないでもいいわよ。マ\nマの可愛い息子のお願いなら、何でも聞いてあげちゃうんだから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0203140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「なーんて……くくっ、どうだ？　中々ママプレイというのも悪くないだろう\n？　っと……スマンな、まだ終わりには早かったか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0203201" ]},
		{"command":[ "SETIMAGE", "0", "still_00000702_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「んふふ……だって、ボクちゃんのビンビンオチンチン……まだ出し足りない\nってピクピクしてるんだもの……ふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0203202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「ああ、何も言わなくていいのよ。大丈夫、さっきより、もーっと気持ちよー\nくしてあげるから……んっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0203203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「んふふ、ほぉら……今出したばかりのオチンチンミルクがねとねとして……\nずっとヌルって滑るようになったでしょ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0203204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「この状態で、オッパイ……ずりゅずりゅしてあげると……あんっ……いっぱ\nい滑って、さっきよりもっと気持ちいい感じ……あふぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0203205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「さっきしてあげた所も、感じが違うでしょ……にゅるってミルクがへばりつ\nいて……んっふ……いやらしい眺めになってるわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0203206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「もっとプレスしてあげる……んんっ、こうしてぎゅうっ……あんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0203207" ]},
		{"command":[ "SETIMAGE", "0", "still_00000702_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「はっ、んっ、んふっ……お肌がさっき以上に密着して……ボクちゃんの脈打\nったオチンチンの感じも……すごくよく分かる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0203208" ]},
		{"command":[ "SETIMAGE", "0", "still_00000702_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「ぐにゅって……押し潰しちゃう感じにすると……はぁんっ、私のオッパイも\n……ずっと気持ちいいっ……はん、あぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0203209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「んふふっ……またじっと見てる……ママがオッパイ感じてる所……ドキドキ\nしちゃう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0203210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「隠さなくてもいいの……分かってるもの。ママも同じ……あなたが気持ちよ\nさそうにしてる顔を見てるだけで……すごくドキドキするんだから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0203211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「ほら……もっとよく顔を見せて？　オッパイはここよ……いやらしく乳首を\nしこらせた、オッパイ……好きなだけ見ていいんだから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0203212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「あんっ……んふふっ、またオチンチンが元気になって来た……んっ！　あっ\n……腰……振り始めたわね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0203213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「いいわ……んくっ……あなたの好きなようにママのオッパイを犯しなさい…\n…あっ、そうよっ、元気にオッパイマンコ、ズボズボするのっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0203214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「ママも……んっ、ぎゅうってしてあげるっ、あっ、ふっ……！　あぁっ、い\nいわっ……もっと激しくっ、はぁんっ、そ、それぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0203215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「あっ、はぁっ、ひっ、オッパイすごいっ、オチンチンされてっ……ママもっ\n、感じてっ……イキそうになっちゃってるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0203216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「はんっ、あっ、んぁぁぁぁっ……オチンチンも震えて来てるわっ……出るの\nねっ、いいのっ、出しなさいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0203217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「ママのオッパイの中でもっ、顔でもっ……どこでもいいわっ、あなたの欲望\nを全部……好きなようにしてっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0203218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「あぁっ……オチンチン激しいっ、そうっ、もっと腰を振ってっ……オッパイ\n熱いっ、んぁ、気持ちいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0203219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「あぁっ、来てるっ……凄いのっ……はぁんっ、出してっ！　あなたの熱いの\nっ……ビュクって全部っ……ぶち撒けてぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0203220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「んはぁぁぁんっ！　あぁっ……また、オッパイに中出しっ……んふふぅっ…\n…そう、ママオッパイの中に出すの……気に入ってくれたのね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0203301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000702_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「嬉しいわ……んっ、ふふっ、残さず出しちゃいなさい……ちゃんとママが最\n後まで面倒を見てあげますからね……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0203302" ]},
		{"command":[ "SETIMAGE", "0", "still_00000702_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「んっ、オチンチン震えてる……一生懸命出して……もうちょっとよ、頑張っ\nて……はぁい、いい子……よく出来ました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0203303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「あぁ……谷間に熱いのがねっとりしてる……はぁぁ……男の子の濃い匂い…\n…んふぅ……これでイケるぅ……ん、はぁぁぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0203304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「ふふ……ええ、ママもイッたのよ……あなたのオチンチンが元気に射精して\nる所を見て、そのままイッちゃった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0203305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「待ってね、んちゅっ……先っぽ、舐めて綺麗にしてあげますから……ぴちゃ\n……んちゅぷっ、ほら……これでよし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0203306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「さて……ふふっ、私のママっぷりはどうだった？　いつまでも余韻に浸って\nいたいかも知れんが、何事にも終わりはあるからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0203307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「なりきりと言えば、それまでだが……中々感慨深いものがあったな。少し、\n昔のことを……ああ、いや、何でもない。こちらの話だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0203308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「それで、どうする？　もし、気に入ったというなら、またこのようなプレイ\nをするのもいいが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0203309" ]},
		{"command":[ "SETIMAGE", "0", "still_00000702_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「ふふっ、そうかそうか。正直で結構。では……また、ママになった時は……\nいっぱい可愛がってあげるわ……ね、ボクちゃん……ふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0203310" ]},
		{"command":[ "SETIMAGE", "0", "still_00000702_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「ひぁぁぁんっ！　あっ……オチンチンミルクっ……顔にっ、あぁんっ、マス\nクに掛かっちゃうっ、あひんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0203401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000702_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「もう、いたずらっ子ね……そんなにママの顔に掛けたかったの？　でも、い\nいわ……やんちゃでも元気な子はママ大好きよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0203402" ]},
		{"command":[ "SETIMAGE", "0", "still_00000702_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「さあ、遠慮しないで残りも出しちゃいなさい……そうよ、奥に残ってるのも\n搾っちゃいましょう……んっ、ふっ……んんっ！」", "NORMAL" ]},
