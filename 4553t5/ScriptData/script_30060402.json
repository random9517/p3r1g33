{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000604_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「とうとうダーリンと結ばれる時がやってきたのね♪　ディアナちゃん、超絶\nハッピーよ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0404101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「はぁ、ドキドキする……ディアナちゃんの全てを捧げちゃうね。たーっぷり\n味わってちょうだい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0404102" ]},
		{"command":[ "SETIMAGE", "0", "still_00000604_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「……はぁ、やだぁ、緊張して来ちゃった。ディアナちゃん、あんまり慣れて\nないから優しくしてね……、ダーリン♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0404103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「やだぁ……こんな体位でエッチをするの？　ああぁん……恥ずかしい……。\nでも、ドキドキしちゃうぅ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0404104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「ディアナちゃん、オマンコをこんな風にジロジロ見られるの、初めてかも…\n…はぁ、緊張する……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0404105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「やぁん……そんな風に、太ももスベスベしないでぇ……くすぐったいじゃな\nい。ん、んん、はぁ……感じちゃうぅ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0404106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「おっぱい越しに見下ろすダーリンの顔……なんだか赤ちゃんみたいで、か～\nわいい♪　うふふ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0404107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「見てぇ、ディアナちゃんの乳首、ビンビンになっちゃってる……もう、ただ\nでさえ大きいのに……恥ずかしいぐらい目立っちゃってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0404108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「あはぁ、おっぱいとオマンコ……ダーリンの視線を感じて、チクチクしちゃ\nう♪　はぁ……だんだん見られてるだけで、感じてきちゃった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0404109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「え？　オマンコが濡れて、トロトロになってる？　ふふ……そろそろ挿れ時\nかも……？　はぁ、緊張しちゃう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0404110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「ん……んんんっ、はぁ……キツいぃ……オマンコの入り口が、引き伸ばされ\nてる……あああ、破れちゃうそう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0404111" ]},
		{"command":[ "SETIMAGE", "0", "still_00000604_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「少し痛い……かも？　でも、ん、ふぅ……平気よ。だって、ダーリンを感じ\nてる証拠なんだもの……嬉しい……だから、このまま続けてくれる？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0404112" ]},
		{"command":[ "SETIMAGE", "0", "still_00000604_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「あっ、あああ……はぁ、んんん……お腹の中が、少しずつこじ開けられて…\n…あっ、ぐぅ、んんぅん……オチンチンが……あ、あ、あああ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0404113" ]},
		{"command":[ "SETIMAGE", "0", "still_00000604_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「はぁ……中でゆっくり動いてる……オマンコの内側がよじれて……オチンチ\nンに持っていかれちゃうぅ……はぁ、んん、はぁぁぁん……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0404114" ]},
		{"command":[ "SETIMAGE", "0", "still_00000604_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「あんなに大きなオチンチンが、私の中に入って、くる……んぐぅ、あはぁ…\n…はぁ、お腹の中身が持ち上がっちゃうぅ……少し、苦しい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0404115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「ううん、痛くはないの……お腹が圧迫されてる、だけ……でも、ん、んん、\nこの苦しさが愛おしい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0404116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「この苦しさ、ダーリンと繋がっている証拠なのよね？　はぁ……あはぁ、な\nんだかこの感覚って、すごく愛おしい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0404117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「ねえ、ダーリン♪　もっと動いてぇ……もっとオチンチンを、アタシの一番\n深いところで感じたいの……はぁ、んん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0404118" ]},
		{"command":[ "SETIMAGE", "0", "still_00000604_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、あぁぁぁ……今、ぶつかってる……ダーリンの先っちょが、デ\nィアナちゃんの大事なところ、ツンツンしてる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0404119" ]},
		{"command":[ "SETIMAGE", "0", "still_00000604_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「はああぁん……すごぉい……繋がってる……ダーリンとディアナちゃん、今\n、最強のベストカップルって感じ～～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0404120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「はぁ……あはぁぁ、苦しいのも、痛いのも、気にならなくなって、きちゃっ\nたぁ……ん、んん、はぁ……あはぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0404121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「ねえ、ダーリン。もっと動いてくれていいのよ？　ディアナちゃんの可愛く\nてセクシ～なオマンコ、じゅぼじゅぼしてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0404122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「あ、でも……あんまり激しくし過ぎちゃ、イヤよ？　ん、ふぅ……女の子は\n、やさしく丁寧に扱わなきゃ、ね……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0404123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「あっ……あぁぁあ……オマンコが、オチンチンに持っていかれちゃうぅ……\n動作に合わせて、くっついていっちゃうよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0404124" ]},
		{"command":[ "SETIMAGE", "0", "still_00000604_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「子宮が……熱い……はぁ、んん、ダーリンの体温、感じちゃう……あっ、こ\nれ、すごい……気持ち、いい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0404125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「ふふふ、ディアナちゃんなら、全然平気……だから、もーっと激しくしても\n、いいかもよ～？　でも、いきなり全力は……禁止だからね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0404126" ]},
		{"command":[ "SETIMAGE", "0", "still_00000604_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、ひやぁぁぁあ……オチンチン、すごい……ダーリンが、いっぱ\nい入ってくるぅ……ん、んんぁ、あぐぅ、きゃうぅぅん……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0404127" ]},
		{"command":[ "SETIMAGE", "0", "still_00000604_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「あっ、あぐっ、はへぇぇぇぇ……ゴツンゴツン、音がする……ダーリンった\nら、力強いんだからぁ……はー……ひうぅぅん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0404128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「でも、乱暴過ぎない……優しさ、感じちゃうぅ……はぁ、ふぅ……んぐぅ、\nきゃうぅん……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0404129" ]},
		{"command":[ "SETIMAGE", "0", "still_00000604_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「は、はぁ……あはぁぁ……気持ちいい……オチンチンで、気持ちいいの、い\nっぱいに……なっちゃ、あっ、ぐぅ……ひゃぐぅぅぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0404130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「はぁ……ああああ……ダーリンの腰使いが、どんどん激しく、なっちゃうぅ\n……駄目ぇ、そんなにされたら、壊れ、ちゃ……あ、あ、あひぃぃ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0404131" ]},
		{"command":[ "SETIMAGE", "0", "still_00000604_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「イ、イキ、そう……。え？　ダーリンも、イキそうなの？　あはぁ……相性\nバッチリね、アタシ達……んっ、はぁ……はへぇぇぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0404132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「ダーリンと、一緒にイキたい……はぁ、ふぅ……きっと、心も体ももーっと\n深く繋がっちゃうじゃない？　あはぁ……楽しみぃ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0404133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「え？　イキそうなの？　いいわよ～……いっぱい出してぇ……ディアナちゃ\nんも、もう我慢できない、かも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0404134" ]},
		{"command":[ "SETIMAGE", "0", "still_00000604_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「あっ、駄目……イク、イキそう……あ、駄目、イク……ッ、イッチャうぅ…\n…んはぁ！　あっ、きゃひぃぃぃぃぃ……ッ！！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0404135" ]},
		{"command":[ "SETIMAGE", "0", "still_00000604_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「ひゃぐぅ！？　あはぁぁ……はぁ、はぁ……あぁぁぁぁん♪　ダーリンが、\n子宮の中に入って、くるぅ……ぐぅ、うううあ、あはぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0404136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000604_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「はー……はぁぁん……熱いぃ……ダーリンの体温で、アタシの中が塗り替え\nられていく……すごぉい……気持ち、いい……んひぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0404137" ]},
		{"command":[ "SETIMAGE", "0", "still_00000604_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「オチンチン、中でビクビクしてる……精液がうねってる……はー……はー…\n…あぁぁ、今ダーリンと、ディアナちゃん……一つになってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0404138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「はー……すごかったぁ……ダーリンとのセックスって、最高ね～……♪　頭\nが、ぼーっとしちゃう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0404139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「ねえ、もうしばらく、このまま繋がったままでいていい？　ね、いいでしょ\n？　ディアナちゃんのお・ね・が・い──」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0404140" ]},
