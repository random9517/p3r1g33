		{"command":[ "PLAYBGM", "BGM_007" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "ドラグソードと円盤娘たちは、アイザモフの衛星に降りて戦っているが、どう\nも形勢が不利だ。というわけで――", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ドラグソードが押されている！　みんな、援護に向かうぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090116320001" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「いつもいつも言ってることだが、私を差し置いて指示を出すなーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010116320001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いつもいつも言ってることですが、隊長は俺！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "とか言いながら、俺たちも円盤娘を地上から攻撃する。しかし――", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "円盤少女Ａ" ]},
		{"command":[ "SETTEXT", "「だーかーら！　ザコのこーげきなんか効かないんだってば！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_010116320001" ]},
		{"command":[ "SETCHARA", "0", "char_00016202_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "円盤少女Ｂ" ]},
		{"command":[ "SETTEXT", "「ムダムダ！　きゃははははっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_010116320001" ]},
		{"command":[ "SETCHARA", "0", "char_00016302_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "円盤娘たちは笑いながら、ドラグソードを痛めつける。攻撃を受け続けたドラ\nグソードは、ついにがっくりと膝をついた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "SETCHARA", "0", "char_00016302_01", "8", "CENTER", "500" ]},
		{"command":[ "SETCHARA", "1", "char_00016202_01", "8", "CENTER", "-500" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「おい、どーすんだ！　ドラグソードが動かなくなっちまったぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_010116320001" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "SETCHARA", "0", "char_00022901_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "宇宙船から降りてきたスケバンサンダーも焦っている。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「やっぱ、アタシの船とダイアンサスで砲撃したほうがいいんじゃねえのか？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_010116320002" ]},
		{"command":[ "SETCHARA", "0", "char_00022901_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おいおい、やめてくれよ。砲撃は効かなかったじゃねえか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「じゃあ、どうするんだ。なんか手はねえのか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_010116320003" ]},
		{"command":[ "SETCHARA", "0", "char_00022901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そうだ！　おい、隊長！　なにか考えろ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010116320002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「またそうやってざっくりした無茶振りを！　なんかいい手がありゃ、とっく\nにやってますよ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「あったろ！　前はよ！　ほら！　なんだっけ、あの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_010116320004" ]},
		{"command":[ "SETCHARA", "0", "char_00022901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0206" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「そうだ！　惑星ヒ＝ホーカンのときにさ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_010116320005" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0113" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「っ！　そうか、たしかにあのときは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090116320002" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああ……あったよな、そんなこと……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「だろ！？　あんときみたいにさ、ドカーンと！　新技はねえのかよ、新技は\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_010116320006" ]},
		{"command":[ "SETCHARA", "0", "char_00022901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「無茶いうなっつーの！　あのときだって、どうしてああなったのか、俺にだ\nって見当つかねえんだから！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「見当つかないとか言ってないで考えろーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010116320003" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090116320003" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「だからわかりませんって！　でも、あのとき『多元宇宙に危機が迫るとき、\n勇者は新たな力を得るだろう』とか妙な声が……ありゃいったい……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「そうか……よし……試してみる価値はありそうだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090116320004" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「え？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「なんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_010116320007" ]},
		{"command":[ "SETCHARA", "0", "char_00022901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「なにか思いついたのか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010116320004" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「説明している時間はない！　ルナテミス、やるぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090116320005" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「え！？　な、なんだ！？　ヤルってなんだ！？　いきなりこんなところで…\n…お、おお～いっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010116320005" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「いいか！？　いくぞ！　んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090116320006" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0222" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「んんんん！？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んんんんんんんん～～～～ッ！！？？？？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010116320006" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ、んんっ……んっ……いまだ……！　いくぞ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090116320007" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「フュー、ジョン！」", "NORMAL" ]},
