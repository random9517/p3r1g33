{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0137" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「はぁ～……あっ、ごめんね。溜息なんかついて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0104101" ]},
		{"command":[ "SETCHARA", "0", "char_00011101_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「燃料タンクにもうあまりガソリンが残ってなくて、お腹がすいちゃって……\n全身に力が入らなくなっちゃったの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「スタンドに連れて行ってくれるの？　ふふっ。助かるわ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0104103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「セルフサービスのお店なのね。カツマちゃん、悪いけど給油してもらえるか\nしら？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0104104" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00011101_02_02" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「給油ノズルを給油口に入れるときは、静電気を除去してから、ゆっくりと入\nれてね。あと私の給油口はキャップレスだから、そのまま……ああんっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0104105" ]},
		{"command":[ "SETIMAGE", "0", "still_00011101_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「へ、変な声を出してごめんね……！　えっと、ノズルをそのまま奥まで挿入\nすると、閉じてるフラップが開くから……ふああぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0104106" ]},
		{"command":[ "SETIMAGE", "0", "still_00011101_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「ああぁんっ！　あっ、はぁん……！　ノズルの挿入感触で思わず感じちゃっ\nたわ……い、今の声は忘れて頂戴……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0104107" ]},
		{"command":[ "SETIMAGE", "0", "still_00011101_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「はぁはぁ……いくらカツマちゃんがしてくれてるとはいえ、これはただの給\n油……だから、感じるなんて……ふぁっ……ふぁあああんっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0104108" ]},
		{"command":[ "SETIMAGE", "0", "still_00011101_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「給油口のふちにノズルがガンガン当たって……くぅっ、うあっ……あんっ、\nああんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0104109" ]},
		{"command":[ "SETIMAGE", "0", "still_00011101_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「きゃ、キャップレスは……入れるところが塞がってるように見えるから、分\nかりにくかったかしら……だ、大丈夫よ。カツマちゃんは悪くないわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0104110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「ええ、そうよ……穴の真ん中に、入れられそうなところがあるでしょ……？\n　そこにノズルをあてがって、ゆっくりと挿入して……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0104111" ]},
		{"command":[ "SETIMAGE", "0", "still_00011101_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「あ、あ……あぁぁ……ハァハァ、いいわ……奥までゆっくり入ってきて……\nんっ！　あっ、ああっ……ふぅぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0104112" ]},
		{"command":[ "SETIMAGE", "0", "still_00011101_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「はあーっ、あはぁんっ……も、もっと奥まで挿入して頂戴……ううっ……あ\nっ、ひあああぁぁ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0104113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「カツマちゃんの手でしてもらってると思うと……んっ、駄目……！　気持ち\nよすぎて、声が出ちゃうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0104114" ]},
		{"command":[ "SETIMAGE", "0", "still_00011101_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「はぁああぁ……ちゃ、ちゃんと奥まで挿入できたわね……とっても上手よ…\n…それじゃあ、このまま給油を……んんんっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0104115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「ちょ、ちょっとカツマちゃん……！？　早くガソリンを……あああーっ！？\n　あっ、あっ、やっ！　だ、駄目えぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0104116" ]},
		{"command":[ "SETIMAGE", "0", "still_00011101_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「中でノズルをガチャガチャしないでぇ！　そんな激しくぐりぐりって動かさ\nれたら……ひぃぃぃぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0104117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「うあっ、ああっ……挿入口がかき回されて……あひぃぃぃぃ！？　うううっ\n、やっ、やめて……カツマちゃん、手を止めてぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0104118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「おっ、おほ……あはぁん、うはん……な、何かに突っかかって、奥まで入っ\nてないの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0104119" ]},
		{"command":[ "SETIMAGE", "0", "still_00011101_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「そんなことないはずだけど……ああぁっん！　あっ、あはぁん！　そ、その\nガチャガチャと乱暴に挿入するのをやめ……ああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0104120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「乱暴にされると、ノズルがいろんなところにぶつかって……！　あっ、あっ\n、はぁああん……！　か、感じちゃううぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0104121" ]},
		{"command":[ "SETIMAGE", "0", "still_00011101_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「私の超ＡＩが壊れちゃう……！　バッテリーが放電して、車体全体が蕩けち\nゃうような感覚が……んっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「この感触を覚えたら、給油してもらうたびにこのことを思い出して……んん\nっ！　そ、そんなの駄目ぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0104123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「あっ、はあはあ……の、ノズルの先っぽから、ぽたぽたと雫みたいにガソリ\nンが垂れて……お腹に、届いてるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0104124" ]},
		{"command":[ "SETIMAGE", "0", "still_00011101_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「ひっ、ひゃあぁ……！　やっ、こんな……焦らされてるみたいな給油……ん\nっ！　で、でも……もし一気に燃料タンクを満たされたら、私……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0104125" ]},
		{"command":[ "SETIMAGE", "0", "still_00011101_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「だ、駄目よ、カツマちゃん……！　ガソリンを入れるときも、ゆっくりと丁\n寧に……！　じゃないと、ガソリンが給油口から溢れて大惨事に……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「そ、そうよ……給油ノズルのレバーを引いて……そうすると、ノズルの先端\nからガソリンが出てくるから……止める時は、指を離して……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0104127" ]},
		{"command":[ "SETIMAGE", "0", "still_00011101_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「ノズルを奥まで入れてたら、満タンになったときに自動で給油が止まるから\n安心して……うううっ！？　あっ、ひゃうっ！　ひああああっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0104128" ]},
		{"command":[ "SETIMAGE", "0", "still_00011101_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「一気にドバドバ給油されてるぅ！？　そんな乱暴にしないでぇっ！　も、も\nっとゆっくり……あっ、んくううぅ～～～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「あっあっ……んああぁ……！　そ、そうよ……うっ、うひん……それぐらい\nの速度が、一番安定するわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0104130" ]},
		{"command":[ "SETIMAGE", "0", "still_00011101_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「あっはん、はぁはぁ……いつもは人に頼らないで、機械にやってもらってる\nから……今日は感じ方が、全然違うわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「そ、それに……カツマちゃんにしてもらってるって思うだけで……私、嬉し\nくて……んっ、あっ、ふああぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「ううーっ、はひぃん……！？　あっ、あっ……こ、コツを掴んだからって、\nそんな一気に……！　駄目っ、そんな勢いで大量に中に出されたら……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0104133" ]},
		{"command":[ "SETIMAGE", "0", "still_00011101_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「ふわ……くあああぁっ！？　か、カツマちゃん……！　私、イッちゃう……\n！　中出しされながら、イッちゃうううううぅ～～～～～！！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「はぁああん……ああ……たくさん……！　燃料タンクをレギュラーで満タン\nにされて、ひいぃぃ……イクッ、イクッ……いくうううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0104135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00011101_02_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「あはあぁ、はぁはぁ……はあああん……燃料タンクが直接燃えてるような感\n覚が……！　給油中は、火気厳禁なのにぃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0104136" ]},
		{"command":[ "SETIMAGE", "0", "still_00011101_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「う、うああ……とっても満足したわ……こんなにたっぷり給油されて……お\n腹いっぱいになるくらい、ガソリンを中に出されて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0104137" ]},
		{"command":[ "SETIMAGE", "0", "still_00011101_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「給油口からガソリンが溢れ出てるの……？　た、大変っ！　気持ちよすぎて\n、逆流させちゃったのかも……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0104138" ]},
		{"command":[ "SETIMAGE", "0", "still_00011101_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「もう一回給油する……！？　だ、駄目よ！　給油の前に従業員さんを呼んで\n、処理してもらわないと……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0104139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「それにボディについたガソリンを拭かないと、シミになっちゃう……！　カ\nツマちゃん……！　焦るのはわかるけど、話を聞いて……ふあああぁん！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「はぁああん、またノズルが入ってきてぇ……！　あっ、うくっ……ううう、\nこの挿入される感じ……本当に駄目ぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0104201" ]},
		{"command":[ "SETIMAGE", "0", "still_00011101_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……んっ、ふああぁ……！　あ、あのね、カツマちゃん……！　\n燃料タンクの中は外から見えないけど、ちゃんと満タンになってるの……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0104202" ]},
		{"command":[ "SETIMAGE", "0", "still_00011101_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「だから、もう本当に入らなくて……！　えっ……？　給油口にちゃんとノズ\nルは入ったし、まだレバーを引けば出るって……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「あのね、カツマちゃん……！　セルフスタンドの給油は、オートストップ機\n能っていうのがあって、満タンになったら終わりにしないといけないの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0104204" ]},
		{"command":[ "SETIMAGE", "0", "still_00011101_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「今カツマちゃんのやってる継ぎ足し給油は……禁止事項なの……！　しちゃ\nいけないって、明言されてるの……！　わ、悪いことなの……だから……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0104205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「ふあああぁん！　だ、だから駄目って言ってるのにぃ！　継ぎ足し給油しな\nがら、ノズルで奥をぐちゅぐちゅかき回さないでぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0104206" ]},
		{"command":[ "SETIMAGE", "0", "still_00011101_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「ぐわんぐわんってお腹の中で硬いものが動いて……！　こ、こんなに注ぎ口\nが泡立ってる……！　ごぷごぷって、エッチな音が鳴ってるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「燃料がノズルの奥でうねっているのを感じて……んんっ！　ふえぇ……？　\nま、まだ全開で出してないの……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「やっ、やああぁ……！　今でこんなに感じてるのに、レバーを全力で引かれ\nたら……！　一気にガソリン流し込まれたら、壊れちゃうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「カ、カツマちゃん……！　私、怖いわ……！　しちゃいけないことしてて…\n…今まで感じたことない気持ちになってるのに……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0104210" ]},
		{"command":[ "SETIMAGE", "0", "still_00011101_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「な、なのに……！　カツマちゃんの手で、もっとして欲しい……乱暴でもい\nいから、カツマちゃんに給油して欲しいって思っちゃってるの……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0104211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「はぁああん、やっ……あああぁん！　レバーを全開にして、一気にガソリン\n流し込まれてるぅ！　ガチャガチャしながら、抜き差しされてるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0104212" ]},
		{"command":[ "SETIMAGE", "0", "still_00011101_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「超ＡＩがおかしくなっちゃうっ！　給油口の浅いところをズポズポされてる\nと、電源回路がショート寸前になっちゃうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0104213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「く、クセになっちゃう……！　カツマちゃんの給油、大好きになっちゃうう\nうぅ～～～～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0104214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「もっ、む、無理っ……立ってられない……！　気持ちよすぎて、タイヤがパ\nンクしちゃいそうだわ……んくううぅっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0104215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「くあああぁ……！？　た、タンクの中がかき混ぜられて……っ！　ど、どれ\nだけ入ったか、確認しちゃ駄目えええぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0104216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「もう本当に入らないのっ！　継ぎ足し駄目なのぉ！　ガソリンが溢れ出て、\n大惨事になっちゃうからぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0104217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「んひいぃん！？　の、ノズルの先端がビクビクって……！？　最後の継ぎ足\nしをしようとしてるのっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0104218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「お腹たぷたぷなのっ！　これ以上されたらイッちゃうっ！　超ＡＩが狂っち\nゃうううぅ～～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0104219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「あああっ！？　くっ、くるっ……！　きちゃうううぅ！　あっあっあっ！　\nイッ、イクっ！　イクっ！　イクううううぅ～～～～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0104220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま","LABEL2","はずして","LABEL1" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「うううっ……んぐうううぅ～～～～！？　ま、また逆流して……ううううっ\n！　あっ、はああぁ！　あっはあああん！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0104301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00011101_02_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「勢い余ってノズルが外に……！　ひゃああんっ！　あっ、うあ、ああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「ガソリンが揮発して、全身が燃えてるみたいになってるぅ！　こ、このまま\nエンジンに火を入れたら、本当に炎上しちゃうううぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0104303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「タンクからもたくさん逆流して……んんっ！　クジラの潮吹きみたいに、ピ\nューピューって溢れて……だ、大惨事になっちゃってるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0104304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「ノズルからもたくさん燃料が漏れてる……！？　か、カツマちゃん！　早く\nレバーから手を離してっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0104305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「わ、私のことはいいから！　ガソリンで全身ベトベトになっても、気にしな\nいわ！　カツマちゃんが無事でいることが、なにより大切なの！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0104306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……はあああぁ……な、なんとか最小限の被害で抑えられたわね\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0104307" ]},
		{"command":[ "SETIMAGE", "0", "still_00011101_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「ううん……気にしないで。セルフスタンドでの給油は、慣れていないと失敗\nしちゃうもの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0104308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「それに、乗りなれない車だと、余計に給油で困ったりするものね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「だからカツマちゃん……これからも私に乗って、たくさん給油して、一緒に\n慣れていきましょう……ふふっ。約束よ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「ああぁあっ！　で、出てるぅ！　タンクにじゃばじゃば燃料が……うっ、ぐ\nうううぅ！　いっ、いっぱい出てぇ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0104401" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00011101_02_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「あ、溢れ出ちゃうっ！　限界の限界まで、継ぎ足し給油されちゃってるぅ！\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0104402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「カツマちゃん、はやく手を止めてぇ！　本当に危険だから……きゃあああぁ\n！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0104403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「ひはああぁん！　あ、溢れてるぅ！　給油口から燃料が漏れて……！　んん\nんっ～～～～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0104404" ]},
		{"command":[ "SETIMAGE", "0", "still_00011101_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「はぁはぁ……あっ、はああぁ……な、なんとか最小限の漏れで抑えられたわ\nね……これぐらいなら、拭けばなんとかなるわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0104405" ]},
		{"command":[ "SETIMAGE", "0", "still_00011101_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「んっ、くうぅ……燃料タンクが重たいわ……！　お腹がたぷたぷして……う\nっ、くっ……動きにくいわね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0104406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「カツマちゃん……燃料は入れれば入れるほどいいというものじゃないの……\n少量のガソリンをこまめに入れた方が、燃費がいいときもあるの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0104407" ]},
		{"command":[ "SETIMAGE", "0", "still_00011101_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「Ｆ１マシンだって、ガソリンによって車重が増えると、タイムに影響が出る\nでしょう……？　それと同じよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0104408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「特に私は普通の乗用車とは違うから……燃料タンクが満タンだと、動きづら\nいときもあるわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0104409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「ふふっ……ちゃんと反省したみたいね。なら、その経験を次に活かしましょ\nう。大丈夫。カツマちゃんなら出来るわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0104410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}