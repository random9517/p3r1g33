{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0155" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「襲来者（インベーダー）が作戦を開始したころ、カツマ率いるインクレディ\nブル・スクワッド軍は市街地へとやってきていた」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_999_010114070001" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「Ｍ．Ｏ．Ｅのやつ、いったいどこまで行ったんだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「実家って言ってたね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020114070001" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「その実家ってのがわからないんだが……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「カツマさん、外を見てください！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010114070001" ]},
		{"command":[ "SETCHARA", "0", "char_00001406_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんだ……って、なんだぁ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「これは……！　周りをぴったりと車が並走しております！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010114070001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「集団で煽り運転ね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020114070001" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「それにしては様子がおかしいような……って、この車、人が乗ってないよ！\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010114070001" ]},
		{"command":[ "SETCHARA", "0", "char_00001205_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんだって！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「いつの間にＡＩカーが普及していたのでしょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010114070002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「んなわけねーだろ！　なんでか知らんが、車が勝手に動いて暴走してるって\nことだ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「目の前で起きてることを言っただけだね、それ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020114070002" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「いったいどういうことなの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010114070002" ]},
		{"command":[ "SETCHARA", "0", "char_00001406_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「こんな異常事態が起きているのに、本部はなにやってんだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「とにかく、このままじゃＭ．Ｏ．Ｅを追いかけるどころじゃないな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「Ｍ．Ａ．Ｍ．Ａ、この車たちを振り切れるか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「まかせて～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114070001" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「わおっ、スピードが上がっているわ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020114070002" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「なのに、車内は全然揺れてない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020114070003" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「大型バスなのに車の隙間をスイスイ縫って走るなんてすごい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010114070002" ]},
		{"command":[ "SETCHARA", "0", "char_00001205_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いいぞＭ．Ａ．Ｍ．Ａ！　あいつらを引き離したし、もう大丈夫だぞ。スピ\nードを落として……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「そうしたいんだけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114070002" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「どうした、Ｍ．Ａ．Ｍ．Ａ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「そ、それが……スピードを落とせなくなってるみたいなの～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114070003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「どういうこと！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010114070003" ]},
		{"command":[ "SETCHARA", "0", "char_00001205_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「ブレーキが効かなくなってるのよ。ハンドルは動くんだけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114070004" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「つまり、Ｍ．Ａ．Ｍ．Ａも暴走してしまっているってことか……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「ごめんね隊長さ～ん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114070005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「ふははははっ！　間抜けなインクレディブル・スクワッドめ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010114070001" ]},
		{"command":[ "SETCHARA", "0", "char_00015601_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お前は襲来者（インベーダー）！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「こちらが罠を仕掛ける前にハマってくれるとは！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010114070002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「あらあら、お客さんかしら？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114070006" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「車を暴走させているのはあなたたちの仕業だったんですね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010114070003" ]},
		{"command":[ "SETCHARA", "0", "char_00001406_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「今更気づいても遅い！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010114070003" ]},
		{"command":[ "SETCHARA", "0", "char_00015601_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「でも、私たちの前に現れたってことは、あなたを倒せば解決よね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020114070003" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「そうだね。向こうから出てきたわけだし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010114070004" ]},
		{"command":[ "SETCHARA", "0", "char_00001205_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「お、おっと！　いいのかそんなことして！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010114070004" ]},
		{"command":[ "SETCHARA", "0", "char_00015601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「あいにく、私を倒しても車の暴走は止まらないぞ！　むしろ、コントロール\nを失って自爆する！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010114070005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「この暴走バスだって例外じゃない。私の言う通りにしないと……ドカーン！\n！　バス爆発だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010114070006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ここは、言う通りにしないといけないみたいですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010114070004" ]},
		{"command":[ "SETCHARA", "0", "char_00001406_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「話が早くて助かる。さあお前ら武器を捨てろ。繰り返すが車たちのコントロ\nールは我々の手の中だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010114070007" ]},
		{"command":[ "SETCHARA", "0", "char_00015601_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「卑怯な……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130114070001" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「はははははっ！　いやぁ、私、今すっごい悪役っぽいことしてる！　悪の女\n幹部より悪い？　まいっちゃうなぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010114070008" ]},
		{"command":[ "SETCHARA", "0", "char_00015601_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「私メインヒロインで『悪の女幹部３』作られちゃうかもなーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010114070009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「こっちが下手に動けないからって、すっかり調子にのってやがる……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「というか、メインヒロインはお仕置きされる側ですぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010114070003" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「それじゃあ、楽しい遠足の始まりってことで、みんなで歌おう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010114070010" ]},
		{"command":[ "SETCHARA", "0", "char_00015601_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「歌だぁ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「カラオケセットならあるわよ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114070007" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「お、用意がいいな。それじゃあさっそく」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010114070011" ]},
		{"command":[ "SETCHARA", "0", "char_00015601_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「こげこげこげよ～♪　ボート漕げよ～♪　ほらみんな歌え！　歌わないか！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010114070012" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お前、意外と歌がうまいな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「歌わされることが多くてな……って、黙ってないでみんな歌え！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010114070013" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、歌ネタはセンシティブなんだよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「私も隊長さんの歌が聞いてみたいわ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114070008" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「Ｍ．Ａ．Ｍ．Ａなに言ってんだ、こんなときに！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「おっ、バスだけにノリがいいのか？　ちょうどいい、お前が隊長に歌わせる\n曲を選べ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010114070014" ]},
		{"command":[ "SETCHARA", "0", "char_00015601_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「そうしたいのは山々だけど、運転で忙しいの～。代わりに番号を入力してく\nれる？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114070009" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「しょうがないなぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010114070015" ]},
		{"command":[ "SETCHARA", "0", "char_00015601_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「じゃあ、番号を言うわね……い、ま、よ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114070010" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー＆バッケンハンター" ]},
		{"command":[ "SETTEXT", "「隙ありっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_010114070001" ]},
		{"command":[ "SETCHARA", "0", "char_00002801_01", "7", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "1", "char_00002401_01", "7", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}