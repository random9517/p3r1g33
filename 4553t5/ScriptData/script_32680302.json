{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00026803_02_01" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁっ……♪　隊長……♪　私の方は、もういつでも準備ができて\nるわ……。隊長だって、そろそろ我慢できないわよね？　うなずいて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0304101" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「っふぅっ……♪　すごい……。隊長のオチンポ、いつもに増してギンギンで\n、今にも私に襲いかかろうとしてる。逞しくて、ミチミチに膨張してて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0304102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「そんなモノを見せつけられると……はぁっ、腰が疼いて仕方ないの。隊長か\nらも見えるでしょ？　私のオマンコ、ヒクついてよだれを垂らしてる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0304103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「ねえ……あまり焦らさないで。早く、この中にオチンポ入れてほしい。大丈\n夫よ、奥の奥までとっくにヌルヌルになって濡れているから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0304104" ]},
		{"command":[ "SETIMAGE", "0", "still_00026803_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「このまま……。あっ♪　そう、そこ……その穴っ……。そこにオチンポの先\nをあてがって……。……あっ♪　そのままっ、そのまま入れて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0304105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「は、ぁっ♪　あああああっ、んああああああ……っ♪　んふぅっ♪　んぅう\nっ♪　入った、オマンコに太くて硬い隊長のオチンポが入ってきたぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0304106" ]},
		{"command":[ "SETIMAGE", "0", "still_00026803_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「……あっ♪　えっ？　やっ……？　い、いつもこんなに硬かったかしら？　\n……んんっ、大きくて太くて熱かったのは覚えているけど、……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0304107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「きょ、今日のオチンポはいつも以上に……！　っぁっ、ビキビキに硬くて…\n…あっ、オマンコの中の存在感がとてつもないの、き、気持ちいい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0304108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「ええ、形もくっきりわかる……。オチンポの角度も……！　あっ♪　あっあ\nっ♪　だめ、もうだめっ、オマンコヒクヒクしてすっごくもどかしい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0304109" ]},
		{"command":[ "SETIMAGE", "0", "still_00026803_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「……このまま動いてっ。私のニュルニュルのオマンコの中、めちゃくちゃに\n突いて、掻き回して、めちゃくちゃにして……！　あっ、ごめんなさいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0304110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「オマンコが勝手に動いて、……あっ♪　隊長のオチンポを締めつけちゃう…\n…！　んんぁっ、腰も落ち着かなくて、モジモジしちゃって……。んあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0304111" ]},
		{"command":[ "SETIMAGE", "0", "still_00026803_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「わ、私ってこんなにオチンポ好き、だったかしら……っ？　あっ、隊長の熱\nを……体温を、ぬちょぬちょの粘膜で感じると耐えていられなくなるの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0304112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「理性をかなぐり捨てて、ケダモノみたいに乱れたい、喘ぎたい、オチンポを\n貪って信じられないくらい気持ち良くなりたいって気持ちに支配されるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0304113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「……んぁあっ……♪　あぁっ……♪　私も動く、から……隊長も動いてぇっ\n♪　……んんっ、この硬いので私のオマンコ独り占めして……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0304114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「……ッあああああっ♪　あぁっ！　んふぅうっ♪　いきなり激し……！　あ\nぁんんっ♪　あんっ、あんっ、あぁんっ、いいっ、イイのぉっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0304115" ]},
		{"command":[ "SETIMAGE", "0", "still_00026803_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「ひゅごいぃいっ♪　私の気持ちいいところばっかりっ♪　えぐるように攻め\nたてて、くりゅっ……♪　んふぅっ♪　こんなの最高に決まってるわっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0304116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「あっ！　あぁっ！　一番奥ぅう……！　どっちゅっどっちゅって突き上げら\nれて……！　ああああっ！　オマンコ拡げられて、ゾクゾクしちゃうぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0304117" ]},
		{"command":[ "SETIMAGE", "0", "still_00026803_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「素敵ぃい……っ♪　腰から下が蕩けて、まともに立っていられないぃ……！\n　あひぃいっ、ひぃっ、うううっ♪　響くぅっ、オチンポ強すぎよぉおっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0304118" ]},
		{"command":[ "SETIMAGE", "0", "still_00026803_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「あぁっ！　あっ！　あっ、あっ、あぁあああっ……！　な、なんてことなの\n……っ。隊長とすればするほど、どんどん相性が良くなっていく気がする！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0304119" ]},
		{"command":[ "SETIMAGE", "0", "still_00026803_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「……っあっ！　私のオマンコがっ♪　隊長のオチンポを好きすぎて隊長専用\nに変わってきたのか……っ、あんっ♪　隊長のオチンポが私の弱点っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0304120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「全部覚えてイジってきてるのか……っ、あっ♪　わからない、わからないけ\nど……あっあっあっ、腰が抜けそうなくらいイイのっ、あっ！　あっぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0304121" ]},
		{"command":[ "SETIMAGE", "0", "still_00026803_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「私っ……！　自分から腰をヘコヘコ、させて……っ、んぁんんっ！　オチン\nポに媚びてしまってる……！　あっ♪　あっ、隊長のオチンポが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0304122" ]},
		{"command":[ "SETIMAGE", "0", "still_00026803_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「世界で一番強くて逞しいオチンポだって、身体が、オマンコが認めてしまっ\nてる……！　っううぅうっ♪　好き……好き、このオチンポが好きぃいい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0304123" ]},
		{"command":[ "SETIMAGE", "0", "still_00026803_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「赤ちゃんっ、作りたくなってきちゃったぁああ……♪　んぁっ、ひぃんんっ\n♪　隊長っ、隊長ぉおおっ♪　いいっ？　子作りしちゃってもいいっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0304124" ]},
		{"command":[ "SETIMAGE", "0", "still_00026803_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「……ぁああああっ♪　子宮が降りてくるっ、隊長の赤ちゃん欲しがって、精\n液を絞りとろうとしてるぅううっ♪　はぁっ、はぁ、欲しい、欲しいぃっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0304125" ]},
		{"command":[ "SETIMAGE", "0", "still_00026803_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「隊長のネバネバ精子で赤ちゃん受精して、妊娠したいぃいっ……♪　あんっ\n♪　あんっ、ま、まだ、しなくちゃいけないこともたくさんあるのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0304126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「本当は赤ちゃん作っちゃいけない、のにっ♪　我慢できないの！　オチンポ\nに負けちゃう……勝てないのぉおお……！　あぁあああああっ♪　んぁあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0304127" ]},
		{"command":[ "SETIMAGE", "0", "still_00026803_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「隊長……！　お願いだから私のこと、孕ませてぇ……♪　あっ、隊長に強引\nに孕ませられたいっ！　ひ、ぁあっ、オチンポの一番太いところっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0304128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「太いところが私の感じるところ……あうっ！？　こすってる、だめ♪　だめ\n、だめっ、それキくぅうっ♪　そこ、そこをぐちゅぐちゅされると……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0304129" ]},
		{"command":[ "SETIMAGE", "0", "still_00026803_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「理性が飛んじゃうっ、本能が目覚めるぅっ……！　あ～っ♪　あっぁっあっ\n♪　なんでそんなにいやらしい腰使い、で、オチンポ動かせるのぉおっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0304130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「おかひくなっちゃうっ♪　気持ちイイ、気持ちイイっ……！　んぉおおっ！\n？　おぉっ♪　い、いやぁ、ヘンな声が出ちゃうぅうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0304131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「おッ！？　おっ♪　おっ、おぉおおんっ♪　ひゅきっ♪　しゅきぃいっ♪　\nオチンポ好きっ、好きぃいいっ♪　もっと！　もっともっとちょうだいぃっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0304132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「……あんっ♪　隊長……！　オチンポの硬さ、増してきてる……！　精液出\nそうなのっ？　嬉しい、もっと溜めて、ギリギリまで耐えて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0304133" ]},
		{"command":[ "SETIMAGE", "0", "still_00026803_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「限界になったら出していいからっ……、あっ、一番濃いのをちょうだい！　\nまだよぉ……まだっ、あと少しがんばって……っ♪　あああああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0304134" ]},
		{"command":[ "SETIMAGE", "0", "still_00026803_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「イキそうっ……？　わ、わかったわ……！　全部受け止めるからっ……出し\nて！　隊長の精液欲しいの、私にいっぱい出してぇええっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0304135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「んっおおおぉおっ♪　んぉおおっ、おぉおおおおっ♪　オマンコの中にあっ\nたかいのが……！　あっついのがキたぁああっ、あっぁっあっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0304136" ]},
		{"command":[ "SETIMAGE", "0", "still_00026803_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「子宮目指して精液っ、上ってきてりゅっ……きてりゅよぉおおおっ……！　\nおっ♪　ビュッ、ビュルッ、ビュッて何度も中に出てるのっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0304137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「あっ、ああああっ……！　腰が浮く、くらいの勢いでオチンポから精液が発\n射されてくる……っ。んんっ！　オマンコの中に出されながら……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0304138" ]},
		{"command":[ "SETIMAGE", "0", "still_00026803_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「受精しながらイクっ……！　イッちゃうぅうっ……！　あ～～～っ♪　いや\nぁっ♪　赤ちゃん作るの気持ちいい、子作り気持ちいい……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0304139" ]},
		{"command":[ "SETIMAGE", "0", "still_00026803_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「イクイクイクイクイクぅうううっ……！　うぅううっ♪　うううぅう～っ♪\n　ドクドク精子注ぎこまれて、ママの自覚が生まれちゃうぅううっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0304140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「ああああっ……♪　はぁ……、はぁ、あぁ～……♪　ああああ……♪　あり\n、がとぉ……。精液全部、オマンコの奥に注入してくれて……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0304201" ]},
		{"command":[ "SETIMAGE", "0", "still_00026803_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「でも……まだ足りない。確実に赤ちゃん孕ませられるには、まだまだ精子が\n必要なの……！　だから……。んっ、このままオチンポ抜いちゃイヤ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0304202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁっ、いいわよね？　続けても……♪　んんっ……。フフフ、オチ\nンポはその気でいてくれているみたい。強く抱きしめて、それから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0304203" ]},
		{"command":[ "SETIMAGE", "0", "still_00026803_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「あっ♪　ンンッ♪　オチンポ、思いっきり中で動かしてっ……♪　んぉおっ\n♪　おっ♪　おぉっ……♪　い、いやらしい音して、るっ、あっ、ああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0304204" ]},
		{"command":[ "SETIMAGE", "0", "still_00026803_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「ぬっちょぬっちょぐっちょぐっちょって！　あっ♪　精液まみれの私のオマ\nンコの中っ……！　隊長のオチンポが掻き回してる音がしてるぅうっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0304205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「あ～っ♪　ああああっ……♪　爪先からっ、頭のてっぺんにまで響くぅうっ\n……！　オチンポが動く、たびにっ、ぐちゅっぐちゅって！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0304206" ]},
		{"command":[ "SETIMAGE", "0", "still_00026803_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「オマンコから太い快感の電流がほとばしるみたいにっ……！　んんんんんっ\n……♪　あぁっ、なんて理想的な動き、なのっ……！　天才だわっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0304207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「あんっ♪　あんっ♪　私の身体……どこもかしこも全部隊長のモノになっち\nゃったわ！　わかるっ？　さっきより更に子宮が降りてきて……あっあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0304208" ]},
		{"command":[ "SETIMAGE", "0", "still_00026803_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「自分からオチンポの先端にキスしてるっ、精液のおかわりをおねだりしてる\nぅうっ♪　はーっ♪　はーっ♪　気持ち良すぎてこらえきれないのっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0304209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「私の本能が、隊長の赤ちゃんを孕みたいって訴えかけてくりゅのっ……♪　\nあぁああっ♪　隊長！　隊長の赤ちゃん作ってくださぁいいっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0304210" ]},
		{"command":[ "SETIMAGE", "0", "still_00026803_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「私のオマンコは、隊長専用です！　隊長の赤ちゃんを産むために待っていた\nんですっ……！　んぁっ、そんなにオチンポが好きなのかって……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0304211" ]},
		{"command":[ "SETIMAGE", "0", "still_00026803_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「好き……！　好きぃっ♪　隊長のオチンポも、こうやって赤ちゃん作る時の\n隊長も好き！　好きっ、だから赤ちゃん孕むのぉおおおお♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0304212" ]},
		{"command":[ "SETIMAGE", "0", "still_00026803_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「あっ……ああああっ！　激しくぅっ……、オマンコの中がかき混ぜられてる\nっ♪　隊長の大きなオチンポで突き上げられて、おかしくなっちゃうぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0304213" ]},
		{"command":[ "SETIMAGE", "0", "still_00026803_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「あ……っ♪　オマンコが、ビクビク痙攣して……隊長のオチンポ締めつけて\nる、精液もらうまで絶対に離さないって言ってるぅううっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0304214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「んふっ……、気持ちいい？　腰の動きがどんどん早くなってきてる……っ♪\n　これって赤ちゃんを作りたいってことなのよね？　あっ、いいわよっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0304215" ]},
		{"command":[ "SETIMAGE", "0", "still_00026803_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「そのままっ……私の一番奥で熱い精液をビュルビュル出して……！　いいか\nらっ、余計なことは何も考えなくていいからっ！　お願いぃっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0304216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「あっ……あっ、んっ、んふっ♪　おぉっ♪　おっ♪　くるっ……あの気持ち\nイイ波が来るぅっ……！　イク時たくさん締めつけてあげるからっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0304217" ]},
		{"command":[ "SETIMAGE", "0", "still_00026803_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「だからたくさん出してね……っ♪　はぁっ、はぁあっ、まだイクのは我慢…\n…我慢しなきゃ、あっ♪　隊長と同時の方がいいっ♪　あっあっんんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0304218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「隊長ぉお……っ♪　腰の使い方、すっごくいやらしくなってきてる……！　\n精液、精液溢れそうなのっ……？　んぁっ、あぁ、この動き好き……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0304219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「子宮っ、子宮に直接届くようにぃっ！　オチンポぴったりくっつけて出して\n……！　あああああっ、イクっ！　今イクからこのままぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0304220" ]},
		{"command":[ "SETIMAGE", "0", "still_00026803_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「ひぅううううっ♪　あうっ！？　あふっ♪　んふぅっ♪　ふぅうううっ♪　\nイイっ♪　イイっ……！　イクイクっ、今イッてるぅうううっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0304301" ]},
		{"command":[ "SETIMAGE", "0", "still_00026803_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「隊長の精液、一番奥に広がってく……！　あっ！　あっ、がっちり腰を打ち\nつけられて！　オマンコ喜んでる、すっごくオチンポに甘えてるぅうっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0304302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「あ～～～～っ♪　あああああっ♪　隊長、隊長……！　精液出しながら腰っ\n……私のお尻にぐいぐい押し付けてきて……あっあっあっ、密着してる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0304303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「こんな状態で出されたら……んひぃいいいっ♪　入ってくるぅっ、赤ちゃん\nの種、精子が子宮に流れこんでくるぅううっ♪　あっ、あっ、もっとぉっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0304304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「優しくなんてしなくていいからっ、隊長の全てをぶつけてっ……！　あっ♪\n　熱い……！　身体が燃え上がりそう、隊長の精液熱いわ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0304305" ]},
		{"command":[ "SETIMAGE", "0", "still_00026803_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「ん～～～～っ♪　んんんっ……まだよ、まだ……！　私が最後まで絞り上げ\nるまで……逃がさないぃっ♪　んんっ、もっと、もっとよぉっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0304306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「……ふぅううううっ……♪　子宮の中に、みっちり精液が詰まってるのがよ\nくわかる……♪　これ以上は入らないくらい出してくれたのね……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0304307" ]},
		{"command":[ "SETIMAGE", "0", "still_00026803_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「んん……。逆流させてしまうのはもったいないから、もう少しだけこのまま\nじっとしていて……？　フフ、そう。受精するまで待ってるの……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0304308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「今まであまり知識がなかったのに、するたびに少しずつ覚えてきてる、って\n……。当然じゃない。私だって隊長のすることには興味があるし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0304309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「隊長としてること、知りたかったんだもの。だから……これからも、するた\nびにいやらしくなっていくつもり。楽しみにしてていいからね……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0304310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「んっあぁんんんっ！？　オチンポは！？　オチンポどこにいっちゃったのっ\n……！？　あっ……！？　いやっ♪　身体にかけるんじゃなくて中にぃっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0304401" ]},
		{"command":[ "SETIMAGE", "0", "still_00026803_02_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「ああっ♪　赤ちゃん欲しいって言ったのに、隊長ぉっ……！　いじわるぅう\n……！　あっ♪　隊長の精液……こんなに濁ってドロドロなのにっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0304402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「濃くて熱くて、ネバネバしてて……最高の精液なのにぃっ！　ひぅうっ♪　\n外に出すなんてぇ……！　あっ、約束が違うわよぉ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0304403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「……んんっ♪　え？　外出しされてるのに、気持ち良さそうに感じてる？　\nんぅっ♪　そ、それとこれとは別よ……あんっ！　浴びるのも好きよっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0304404" ]},
		{"command":[ "SETIMAGE", "0", "still_00026803_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「だけど……、あっあっあっ♪　栄養たっぷりの精液を、子宮に注いで欲しか\nったって思うのも本心で……。あああ、もうわけがわからなくなっちゃうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0304405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「……んんん！　んんんっ！　精液っ、隊長の精液ぃっ♪　中にも外にも、両\n方同時に出してもらえたらいいのにっ、あっ♪　どっちにも欲しいのぉっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0304406" ]},
		{"command":[ "SETIMAGE", "0", "still_00026803_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「……はぁ、はぁ、はぁ……。……隊長？　私の言いたいこと……もうわかっ\nているわよね……？　ええ、気持ち良かったわ。最高に良かった。でも」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0304407" ]},
		{"command":[ "SETIMAGE", "0", "still_00026803_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「不意打ちみたいに、１人で外に出すのを決めたことには複雑な気分だわ。…\n…ま、まあ、一度は中に注入してくれたから、今回は許してあげる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0304408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「……心が広いって？　褒めてくれてるの？　でも、それは早とちりかもしれ\nないわよ？　私、狙った獲物は逃がさないの。だから……フフフッ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0304409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「赤ちゃんできるまで、隊長のオチンポ……何度でも気持ち良くするつもりだ\nから。いいわよね？　何度でも付き合ってもらうわよ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0304410" ]},
		{"command":[ "SETIMAGE", "0", "still_00026803_02_13" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}