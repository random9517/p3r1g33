{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000709_02_01" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ふふ……さてさて長い夜……オチンポの具合は……と……んー、これはまた\n頼もしいのう。ビンビンもビンビンではないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0904101" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「まあ、かくいう余も、ずっとハメて欲しくてウズウズしておった。もうオマ\nンコは、この上なく準備万端のトロトロじゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0904102" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「さ……これから余をどのように可愛がってくれるのか……おっ？　おっ、お\nおおぉっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0904103" ]},
		{"command":[ "SETIMAGE", "0", "still_00000709_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「なるほど、余の身体を持ち上げてバックからとは……ガラリと雰囲気を変え\nてきおったな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0904104" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ママプレイでたっぷり甘やかされた後は、男気を見せる恋人プレイをしたい\nということじゃな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0904105" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ふふ……よいぞ、余のオマンコも早くズブっとして欲しいと疼いておる。さ\nあ……思い切り貫いてみよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0904106" ]},
		{"command":[ "SETIMAGE", "0", "still_00000709_02_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「どうした、まさか今更入り口が分からぬなどということもあるまい？　そう\n、そのまま余の腰を落としてしまえば……おぁっ、ひぃっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0904107" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「あっ、あぉぉぉぉぉっ……は、入るぅっ！　おっ……太いのっ、ずぶっと…\n…奥までっ……来るぅぅぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0904108" ]},
		{"command":[ "SETIMAGE", "0", "still_00000709_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「はっ、あぁぁぁぁぉ……これは、オ、オチンポの膨れ方が……予想以上じゃ\n……んくぅっ……腹に勃起が……広がるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0904109" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「んふぅぅ……な、何のこれしき……せっかくの若いオチンポ……ちゃんと受\nけられずして、何が女王か……ん、むっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0904110" ]},
		{"command":[ "SETIMAGE", "0", "still_00000709_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「構わぬ……う、動かすがよい……お主の思うままに余のオマンコをかき混ぜ\nてみよ……ふひっ、あっ、はひっ、あひぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0904111" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「はっ、おぉぉっ、おぉんっ！　あっ、うんっ、ゆさゆさっ……揺れるっ！　\nし、振動が……オ、オマンコに響くぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0904112" ]},
		{"command":[ "SETIMAGE", "0", "still_00000709_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「んぁっ、こ、これは……思ったよりも、す、ごい……かも知れんっ……太い\nオチンポがっ……余の肉襞をこそぎ取ってっ……あぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0904113" ]},
		{"command":[ "SETIMAGE", "0", "still_00000709_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「あっ、あぁっ、欲しかった……オチンポの芯がっ……子宮を突いてっ、ふひ\nっ、くひぃんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0904114" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「腰をっ……一突き揺らされるごとにっ、あひっ、おひっ、あっ、ジーンと…\n…痺れてっ、んひぃっ、こ、これはぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0904115" ]},
		{"command":[ "SETIMAGE", "0", "still_00000709_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「はっ、んんっ……ちょっ、ちょっと……強すぎる、かもっ……知れんっ……\nこのペースだとっ、あぉっ、す、すぐっ、イってっ、ひっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0904116" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「好きなだけっ……イケば……いいっ、いやっ、だがっ、それはっ、はぁんっ\n！　オチンポっ……あっ、ずぶってっ、ほぉぉぉおんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0904117" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ダメじゃっ、あっ、太いのに貫かれる度にっ……頭が蕩けてっ、おかしくっ\n、なってっ、はっ、ひぃぃぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0904118" ]},
		{"command":[ "SETIMAGE", "0", "still_00000709_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「イクっ……はひぉっ！　もうイッてしまうっ、オチンポっ……激しくてっ、\nおぉんっ、オマンコッ……ひぃっ、イクッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0904119" ]},
		{"command":[ "SETIMAGE", "0", "still_00000709_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「んんんんんっ……はぁっ、あっ、ふぁぁ……イ、イカされてしまった……は\nひっ、はぁっ、はっ、んんっ……あぉっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0904120" ]},
		{"command":[ "SETIMAGE", "0", "still_00000709_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ま、まだ……これからが本番じゃとっ？　んくぁっ！　あっ、前よりもっ…\n…もっとオチンポが跳ねるっ、あっ、はひぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0904121" ]},
		{"command":[ "SETIMAGE", "0", "still_00000709_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「はうっ、んんっ……！　イ、イッたばかりのオマンコにっ、太いのがっ、出\nたり入ったりっ、してぇっ、ふひぃっ、あっ、ぉぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0904122" ]},
		{"command":[ "SETIMAGE", "0", "still_00000709_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「いつもとっ、違うっ……！　んふぅっ、オチンポが奥を突く度にっ……腰が\n浮いてぇっ、尻が……震えるぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0904123" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……絞り込むような締め付けが気持ちいい……？　んっ、む、無\n意識にしてしまっているかも知れん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0904124" ]},
		{"command":[ "SETIMAGE", "0", "still_00000709_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「じゃが、んっ、お主も……オマンコで感じてくれているのなら……何よりじ\nゃ……あふっ、少し余裕がないが……つ、続けてよいからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0904125" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「んあぉっ！　あぁっ、食い込むぅ……深いところに届いてっ、チン先が……\n子宮をコンコン……ノックしてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0904126" ]},
		{"command":[ "SETIMAGE", "0", "still_00000709_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「んくぁっ、何度もされるとっ……オマンコ……ジンジン痺れてっ、んぁぁっ\n、そ、それじゃっ、今のとこが弱くてっ、はひっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0904127" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「あっ、あぉっ、んぁぁっ、ま、待てっ……！　その弱いところっ、あひぉっ\n、何度もズンズンされたらぁっ、ま、またぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0904128" ]},
		{"command":[ "SETIMAGE", "0", "still_00000709_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「またイクっ……あひっ、すぐにイクッ！　続けてっ、こんなっ、ひっ、オマ\nンコッ……またぁっ、あっ、んぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0904129" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「はぁっ、あっ、ふぁぁぁ……つ、続けて……イカされた……はぁぁ……んっ\n、ピストンされる度に……気持ちいいのが広がってるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0904130" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「こんなにも……メチャクチャにされる感覚……あぁ……ずっと忘れていたが\n……はぁぁ、堪らぬっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0904131" ]},
		{"command":[ "SETIMAGE", "0", "still_00000709_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「あぁっ、もっと……激しくしてもよいっ！　あひぁっ、もっと余を狂わせて\nっ……んぁぉっ、イカせてっ、くれぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0904132" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「そうっ、あぁおっ、ズボズボがいいっ！　余も、オチンポにご奉仕するっ…\n…！　揺れに合わせてっ、腰を振るぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0904133" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「はぁっ、んぁっ、また……いっぱい擦れてっ！　あひっ、はひぃっ！　お主\nもっ……あっ、イキたくなって来ておるかっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0904134" ]},
		{"command":[ "SETIMAGE", "0", "still_00000709_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「余もっ……もう３回目がっ、すぐそこまでぇっ！　あぁっ、次はっ……中出\nしされてっ……イキたいぞっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0904135" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「そうじゃっ、激しくズボズボしてぇっ！　うひぃっ、イグッ……！　またイ\nグからっ、中ぁっ、ぎてぇぇぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0904136" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「うひぃぃぃぃぃんっ！　イグッ……おおぉっ、まらイグっ！　中出しされて\nっ、オマンゴッ、まらイッてるぅぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0904137" ]},
		{"command":[ "SETIMAGE", "0", "still_00000709_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ふへぁぁあ……びゅくびゅくっ……あぁぁ……熱いので……オマンコいっぱ\nいになってるぅ……はぁぁ、着床する……子種……浴びてるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0904138" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ふひぁぁ……はぁ、はぁ……あぁ、しっかり奥に届けられたぁ……熱い精液\n……いっぱいじゃ……ふひぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0904139" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……あぁ、こんなにも続けてイカされたのは……久しぶり……い\nや、初めてかも知れん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0904140" ]},
		{"command":[ "SETIMAGE", "0", "still_00000709_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「んふ……あぁ、まだオマンコの中でオチンポがうねっておる……こんなに出\nしたのに……やる気がありすぎる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0904201" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「これは、まだまだ男気を見せてもらえると……そういうことでいいのじゃな\n……？　ここから、お主の本気が始まると……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0904202" ]},
		{"command":[ "SETIMAGE", "0", "still_00000709_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「あぁ……余の奥を、もっともっとかき混ぜて欲しい……お主のオチンポで、\n余がメスであることを分からせて欲しいのじゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0904203" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「はぁぅんっ！　んぁぁっ、またピストン来たっ、ズリズリっ……オチンポ凄\nいのっ……始まったぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0904204" ]},
		{"command":[ "SETIMAGE", "0", "still_00000709_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ふぁひっ、あっ、くぅぅぅんっ……こんなにも軽々と……余を持ち上げてっ\n……あぁっ、オマンコ串刺しにしてぇっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0904205" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「はっ、ひっ、あぁっ、腰が……回っておるっ……上下だけじゃないっ……あ\nぁっ、前後左右っ……ぜ、全部っ、かき回されるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0904206" ]},
		{"command":[ "SETIMAGE", "0", "still_00000709_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ふひぁっ、あぁっ……グチュグチュしているっ、あぉっ、ザーメンが……掻\nき出されてっ、ふひぁっ、ポタポタ落ちてっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0904207" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「余の……マ、マン汁も……こぼれてしまうっ……は、恥ずかしいシミが広が\nっていくっ……んぁぁっ、そこぉっ、気持ちいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0904208" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「はっ、あんっ、あぉっ……このオチンポ……前よりも膨らんでいる……逞し\nいなんてものじゃない……こんなの他に味わったことはないっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0904209" ]},
		{"command":[ "SETIMAGE", "0", "still_00000709_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「はひっ、あひぃんっ！　さ、最高じゃっ……このオチンポにならっ、余の全\nてを捧げてもよいっ、あっ、あぉっ、あぉぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0904210" ]},
		{"command":[ "SETIMAGE", "0", "still_00000709_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ダメじゃっ……またイクっ！　あひぉっ、我慢なんか出来る筈がないっ！　\nオチンポズリズリされてっ、オマンコまたイグぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0904211" ]},
		{"command":[ "SETIMAGE", "0", "still_00000709_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ふはぁぁ……んっ、こんな腹ボコにされて……完全にオチンポに屈服させら\nれてぇ……それを喜んでしまっておる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0904212" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「もう余は、お主のオチンポなしには生きていけんのじゃ……あぁ……後もう\n少し……オチンポ続けてぇ……んぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0904213" ]},
		{"command":[ "SETIMAGE", "0", "still_00000709_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「はぅっ、うんっ、くぅんっ、んふっ……何も、しなくてもっ……自然にオマ\nンコがヒクついてしまうっ……んぉっ、あっ、あぉぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0904214" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「はぁ……これが、いいのかっ？　余の……イキマンコでっ、ちゃんとオチン\nポっ……イクところまでできそうかっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0904215" ]},
		{"command":[ "SETIMAGE", "0", "still_00000709_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「このままっ、激しく突き続けたらっ……ならば、迷うことはないっ！　お主\nがイクまでっ、余のオマンコを突きまくってくれっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0904216" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「んぁひぃっ！　あぉぉぉっ、これがっ……お主のラストスパートっ！　ぶっ\nといオチンポがっ、跳ね回るぅぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0904217" ]},
		{"command":[ "SETIMAGE", "0", "still_00000709_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「あぅっ、あぁっ……こんなにも求められてっ……余の全身が……嬉しくてっ\n、震えるっ……はひぁっ、また、イキマンコが上がってくる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0904218" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「またオチンポっ……震えてっ、あぁっ、出るのかっ？　出るんだなっ？　射\n精っ……するんだなっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0904219" ]},
		{"command":[ "SETIMAGE", "0", "still_00000709_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「はんっ、あぁっ、出せっ……お主の欲望をっ……またっ、余にっ……思いっ\nきりぶち撒けてくれぇぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0904220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "FADEIN", "NORMAL" ]},		
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ふぁぁぁぁぁぁっ！　イグッ！　イグぅっ！　中出しされてイグっ！　オマ\nンコいっぱいにされてイグぅぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0904301" ]},
		{"command":[ "SETIMAGE", "0", "still_00000709_02_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「はへぁぁぁぁ……溢れておる……いっぱいになりすぎて……溢れてしまう…\n…あぉぉ……まだ流れ込んで来るぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0904302" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「聖夜に種付けたっぷりされてぇ……孕ませザーメンが気持ちよすぎて連続ア\nクメぇ……最高すぎるじゃろぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0904303" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「はへぁ……ダメじゃ……顔が緩む……今の余のだらしない表情……他の誰に\nも見せることはできぬ……んふぁぁ、あへぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0904304" ]},
		{"command":[ "SETIMAGE", "0", "still_00000709_02_12" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「はぁ、ふはぁ……流し込まれたぁ……腹の中が……お主のザーメンでいっぱ\nいになってしまった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0904305" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「んむ……あぁ、満足じゃ……これ以上ない位に逞しいところを見せつけられ\nて……満足しない筈がない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0904306" ]},
		{"command":[ "SETIMAGE", "0", "still_00000709_02_11" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「余の身体も最高じゃった……？　ふふ……当然じゃ。これだけ欲望任せに動\nかれて、大したことがなかったとは言わせぬぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0904307" ]},
		{"command":[ "SETIMAGE", "0", "still_00000709_02_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「とは言え、今回は完全に余の方がしてやられたわ。まだ余の奥にハマったオ\nチンポがうねって……オマンコを広げ続けておる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0904308" ]},
		{"command":[ "SETIMAGE", "0", "still_00000709_02_11" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……もう、余のオマンコは、お主のオチンポの形にされてしまっ\nたようなもの……他のものは受け付けられぬ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0904309" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「じゃから、これからも責任を持って……余のオマンコを躾けてくれ……んふ\nぅ……頼んだぞ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0904310" ]},
		{"command":[ "SETIMAGE", "0", "still_00000709_02_10" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「あひぃぃぃぃっ！　オチンポ……抜けてっ、ザーメンがっ……あぉぉっ、飛\nび散ってイグぅっ、あっ、おぉぉぉぉぉぉんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0904401" ]},
		{"command":[ "SETIMAGE", "0", "still_00000709_02_17" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「はぁぁ……んっ、今度は身体に、ザーメンシャワー……はぁぁん……こんな\nにマーキングされるなんてぇ……気持ちよすぎるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0904402" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「んふぁ……なんて勢いじゃ……顔にまで届くなんて……んちゅぱっ、この生\n臭さがクセになるのじゃ……ちゅぷぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0904403" ]},
		{"command":[ "SETIMAGE", "0", "still_00000709_02_16" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「もっと欲しい……もっと掛けてよいぞ……んふぅ、あったかい……お主のザ\nーメンで余をべとべとにしてくれぇ……ふぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0904404" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「あふっ……あぁ、出し終えたか……？　はふぅ……全身がべっとりじゃ……\n赤いサンタが白濁まみれで……雪のようじゃな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0904405" ]},
		{"command":[ "SETIMAGE", "0", "still_00000709_02_15" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「まだ、ほわほわした気分が心地いい……んっ、疲れてはおらぬか？　いくら\n軽いとは言え、ずっと余を持ち上げ続けて大変じゃろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0904406" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「大切な人を支えるのに何も苦労は……バ、バカ者……そんな真顔で歯の浮く\nようなことを……全く、そういうとこじゃぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0904407" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ふふ……全く、本当にお主にはしてやられっぱなしじゃ……今日も、最初は\nリードしていたつもりだったのにすっかり躾けられてしまったわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0904408" ]},
		{"command":[ "SETIMAGE", "0", "still_00000709_02_14" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「そうじゃ、もう余は身も心もお主のモノになってしまったのじゃからな……\n後戻りはできぬぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0904409" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「そうとも、これからもしっかりその逞しいオチンポで、余を支配するのじゃ\n。頼りにしておるからな？」", "NORMAL" ]},
