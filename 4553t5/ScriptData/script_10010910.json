		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「さすが……ルナルバースとインクレディブル・スクワッド……！　やるやな\nいか……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010109190001" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「二人とも、もうええじゃろ、このへんで。これ以上アホな争いを続けてもな\nんにもならん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010109190001" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ちっきしょぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020109190002" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「…………アンタがそこまで言うからには、それなりの考えってもんがおあり\nなんでしょうねえ？　そうでなくて、ただ止めろってんじゃぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010109190002" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「そうだ。頭ごなしに言われたって、あたしもお七も言うことなんざ効きゃし\nねえぜ。おめぇらに勝つまで、何度だって立ち上がるぞ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020109190003" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「へぇ……言うじゃないか。ほむらさんよ。アンタ、根性すわってるよ。まあ\n、知ってたけどさ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010109190003" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「あんたもな。Ω（オメガ）組の親分だけのこたぁあるよ。知ってたけどな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020109190004" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「ふっ……ふふふふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010109190004" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ははっ！　はははははっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020109190005" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ふふふふっ……安心せい。余を誰だと思うとるんじゃ。九姉妹（ナインシス\nターズ）、影の宴会部長とは余のことじゃぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010109190002" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「懇親会のことはきっちり考えてあるわい。おぬしら、ちょっとこっちゃ来い\n――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010109190003" ]},
