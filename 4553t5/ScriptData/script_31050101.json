{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010501_01_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ] },
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "PLAYVOICE", "105_0103101" ]},
		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「あ、あのー……こ、これでいいんですか……？　パワーアップの為の儀式？ \nこれが……ですか？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "105_0103102" ]},
		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「私の目を見て下さい。本当にこれがパワーアップの為なんですか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "105_0103103" ]},
		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「……ですよね、違いますよね。そ、それならそうと最初から言って下さい。\n断られると思ったから、って……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "105_0103104" ]},
		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「本当にイヤなら、その……こ、こんな風におっぱいで、おち……お、オチン\nチン……あぁ、言っちゃった……はうぅ、挟んだりしません……っ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010501_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "105_0103105" ]},
		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「あなたのこと、その……すっ、好きだから……！　するんです。あなたに気\n持ち良くなって貰いたいから……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "105_0103106" ]},
		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「おっぱいでゴシゴシってオチンチンしごいて……気持ち良くして欲しいんで\nすよね？　ぱ、パイズリ好きなんですか？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010501_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "105_0103107" ]},
		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「うぅ……パイズリも、おっぱいの大きな子も好き、なんですか。やっぱり私\nのことそんな目で見てたんだ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "105_0103108" ]},
		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「やり方、分からないから教えて下さい。こ、こうかな……ふあぁ、オチンチ\nンがビクビクって震えてるっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "105_0103109" ]},
		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「すごく熱い……んっ、んんっ。知識と、体験するのでこんなに違うなんて…\n…えっ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "105_0103110" ]},
		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「私っ……だ、男性との経験もないですし、付き合ったこともありません。だ\nからキスだってしたことないのに……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010501_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "105_0103111" ]},
		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「つ、つまりですね。こんな間近でオチンチン見たことないんですっ……こん\nな、あぁっ……！　勃起して大きくなったオチンチンは……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "105_0103112" ]},
		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「おっぱい寄せて、ぎゅって挟んだら気持ち良さそうに跳ねてます……んっ、\nんっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "105_0103113" ]},
		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「私にこうやってして貰おうと思ってた……！？　わ、私のおっぱい見ながら\n妄想してたんですか……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "105_0103114" ]},
		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「やっぱり男の人は信用できません……んっ、んんぅ。えっ……？　男が嫌い\nなのか、ですか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "105_0103115" ]},
		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「あの、私……小さい頃からおっぱい大きくなるのが早くて、気付いたらこん\nな風になってて……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "105_0103116" ]},
		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「ジロジロ見られるし、だから好きな本を一人で読んでるのが一番だって思っ\nてました……あ、あなたに会うまでは……はぁっ、はあぁ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "105_0103117" ]},
		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「あなたは、エッチで……変態、なのにぃ……んんっ、私の心の中にどんどん\n入ってきて……あうぅ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010501_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "105_0103118" ]},
		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「気付いたら、その……す、好きになっちゃってたんです。こんな人、初めて\nで……はぁ、はあぁっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "105_0103119" ]},
		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「じゃなきゃ、こんな……おっぱい揉んで、ゴシゴシオチンチンしごいたりし\nません……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "105_0103120" ]},
		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「あぁっオチンチンがビクビクって跳ねてる……！　んんっ、気持ち良くなっ\nてくれてるんですね……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "105_0103121" ]},
		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「はあぁ、はぁっ、もうイキそう？　い、イクんですか？　この場合どうすれ\nば……え、ええっ！？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010501_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "105_0103122" ]},
		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「そのまま射精する……！？　でも、それじゃ私の顔が精液まみれに……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "105_0103123" ]},
		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「そ、それが気持ちイイん、ですか……あうぅっ。もう……本当に変態なんで\nすから……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "105_0103124" ]},
		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「どうしても出したい？　わっ、私の顔もおっぱいも、精液まみれにしたい…\n…！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "105_0103125" ]},
		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「うぅぅ……はぁ、あぁっ、分かりました。出して……下さい」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "105_0103126" ]},
		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「私の顔にたくさんっ……精液を出して、顔にも、おっぱいにもかけて下さい\n……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "105_0103127" ]},
		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「あ、あぁぁ！　オチンチンがビクビクしてる……やっ、あああ……！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "105_0103128" ]},
		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「ひゃううぅ……！！？　ああぁ！？　顔に、かかって……んああぁん！　お\nっぱいにも……あ、熱ぅぅい……」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010501_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "105_0103129" ]},
		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「んあぁ、すごい量ぉ……それに、なんて匂い……とっても臭いのに、嫌いに\nなれない……です」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "105_0103130" ]},
		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「ふあぁ、はぁっ、え……ええっ！？　舐める？　精液をですか？　し、しか\nも飲んで……欲しい！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "105_0103131" ]},
		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「でも、そんなの……わ、私が喉を鳴らして飲む姿を見たい……？　うぅ、あ\nなたって本当に変態なんですね……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "105_0103132" ]},
		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「はぁ、はっ……でも、あなたが喜んでくれるなら……あぁ、ネバネバしてる\n……ちゅっ、ちゅる」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010501_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "105_0103133" ]},
		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「ちゅぱ、ちゅっ……！　ごきゅ、ごくっ、んあぁぁん……苦くて、ネバネバ\nしてて、熱くて……んっ、んんぅ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "105_0103134" ]},
		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「とっても……とってもいやらしい味、です……あっ。え？　えっ？　どうし\nてまたオチンチン勃起してカチカチに……！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "105_0103135" ]},
		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「ま、まだまだ射精したりないんですか？　もぅ……分かりました」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "105_0103136" ]},
		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「そ、それじゃあ……パイズリ、続けますね……？　私が嫌い続けた……私自\n身の巨乳……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010501_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "105_0103137" ]},
		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「あなたが悦んでくれるなら……私も、好きになれそうな気がするから……ま\n、またスペルマ飲めっていうんでしょう？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "105_0103138" ]},
		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「こ、今度はパイズリしたままフェラして欲しい！？　うぅっ……あ、あなた\nの要求に応えていたら……私っ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "105_0103139" ]},
		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「とってもエッチな子になっちゃいそうです……あなたに出会うまでは、考え\nられないような……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "105_0103140" ]},
		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「と、とっても……いやらしい、子に……はうぅん……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}