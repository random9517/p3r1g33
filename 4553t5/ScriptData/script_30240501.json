		{"command":[ "SETNAME", "バッケンキャリバー" ]},
		{"command":[ "SETTEXT", "「んっ、んっ、んむっ、んふぅ……。んっ、本当に、おっきくて……ンッ、咥\nえるの、大変なんだから……んっ、んんっ」", "NORMAL" ]},
