		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バッケンキャリバー" ]},
		{"command":[ "SETTEXT", "「んぁっ、あなたも……あなたも一緒に……んっ、じゅぷっ、精液……いっぱ\nい射精しながら……んじぷっ、んっ、んむっ、んん……っ！」", "NORMAL" ]},
