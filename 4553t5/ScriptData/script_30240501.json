		{"command":[ "SETNAME", "バッケンキャリバー" ]},
		{"command":[ "SETTEXT", "「むぐっ、またたくさん、ザーメン……射精されながらぁ……！　お、オマン\nコもイッてるの……イッてるの……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0503302" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バッケンキャリバー" ]},
		{"command":[ "SETTEXT", "「んはぁ……はぁ……また潮ぉ……いっぱい、でちゃったぁ……。んっ、ふぅ\n……んはぁ……んっ、ふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0503303" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バッケンキャリバー" ]},
		{"command":[ "SETTEXT", "「２回目なのにすごい量だなって、それはお互い様でしょ。んふぅ……口の中\nから溢れちゃうくらい、射精して……もう……」", "NORMAL" ]},
