		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バッケンキャリバー" ]},
		{"command":[ "SETTEXT", "「舌がジンジンするような、熱い……オチンポ……んっ、んむっ、咥えて……\n口の中で、舐めて……んっ、ふぅ……」", "NORMAL" ]},
