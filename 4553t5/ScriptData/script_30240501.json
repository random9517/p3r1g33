		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バッケンキャリバー" ]},
		{"command":[ "SETTEXT", "「今度は、んっ、こうやって……んじゅるっ、オチンポ咥えて、し、しごいて\nあげるんだから……んっ、んむっ、んむっ！」", "NORMAL" ]},
