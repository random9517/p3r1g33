		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バッケンキャリバー" ]},
		{"command":[ "SETTEXT", "「ひゃっ、ひゃめっ、オチンポまだ、ビクビクしながら精液噴きだしてっ、ん\nっ、熱いのがいっぱいなの……！」", "NORMAL" ]},
