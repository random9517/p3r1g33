		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バッケンキャリバー" ]},
		{"command":[ "SETTEXT", "「んっ、んふっ！　あなたの舌も……ンッ、激しくぅ……んっ、んじゅるっ、\nオマンコ舐めてる……じゅるっ、んふぅ……！」", "NORMAL" ]},
