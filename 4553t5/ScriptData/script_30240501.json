		{"command":[ "SETIMAGE", "0", "still_00002405_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バッケンキャリバー" ]},
		{"command":[ "SETTEXT", "「……んんっ！？　まっへ、あ、あなた、なにひて……んんっ！　ひょ、ひょ\nこっ、ンッ、オマンコ……な、舐めへるっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0503114" ]},
		{"command":[ "SETIMAGE", "0", "still_00002405_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バッケンキャリバー" ]},
		{"command":[ "SETTEXT", "「んっ、ひゅふっ、んんぅっ！　んはっ、あなたの舌が……ぁ……っ！　ひゃ\nっ、お、オマンコ……んっ、ペロペロって……んふぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0503115" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バッケンキャリバー" ]},
		{"command":[ "SETTEXT", "「ぬ、濡れてたって……？　んっ、そんなこと……あんっ、オチンポ、咥えな\nがら……オマンコから、お汁垂らしてなんかぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0503116" ]},
		{"command":[ "SETIMAGE", "0", "still_00002405_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バッケンキャリバー" ]},
		{"command":[ "SETTEXT", "「そ、そんなに……舌……ンッ、やらしく動いて……んくっ、オマンコなぞる\nみたいに、ねっとり刺激してぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0503117" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バッケンキャリバー" ]},
		{"command":[ "SETTEXT", "「どんどん溢れてきてるとか、恥ずかしいこと言うな……んっ、ああっ、仕方\nないでしょ、あなたの舌……き、気持ちいいんだからぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0503118" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バッケンキャリバー" ]},
		{"command":[ "SETTEXT", "「舐められて……んっ、すっごく感じちゃうの……。はぁ、はぁ、オマンコか\nら、お汁……溢れるの止められないんだから……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0503119" ]},
		{"command":[ "SETIMAGE", "0", "still_00002405_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バッケンキャリバー" ]},
		{"command":[ "SETTEXT", "「んっ、自分ばかり気持ちよくなってないで、オチンポを……？　わ、わかっ\nてるわよ……んっ、んむっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0503120" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バッケンキャリバー" ]},
		{"command":[ "SETTEXT", "「ちゃんと、ンッ、あなたのことも気持ちよくしてあげるんだから……んっ、\nんくっ、んふっ」", "NORMAL" ]},
