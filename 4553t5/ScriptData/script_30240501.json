		{"command":[ "SETTEXT", "「このまま、また……あなたのこと、イかせちゃうんだから……んじゅるるっ\n、んっ、んんっ！　あ、あなたの舌も……また、激しくぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0503214" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バッケンキャリバー" ]},
		{"command":[ "SETTEXT", "「オチンポ、イッちゃいそうだから……んっ、また私のこと、イかせようと、\nしてるのね……んぁっ、ああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0503215" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バッケンキャリバー" ]},
		{"command":[ "SETTEXT", "「舌……オマンコに入ってる……！　んっ、ああっ！　そ、それ反則っ、ズル\nいぃ……！　ああっ、すぐ、イッちゃいそう……！」", "NORMAL" ]},
