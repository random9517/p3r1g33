		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バッケンキャリバー" ]},
		{"command":[ "SETTEXT", "「こうすると、ンッ、気持ちいい、のよね……？　んっ、じゅるっ、ちょっと\nよだれ、でてきちゃった……じゅぷ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0503112" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バッケンキャリバー" ]},
		{"command":[ "SETTEXT", "「んっ、んじゅっ、じゅるっ、んふぅ……。どんだけ興奮してるのよ、オチン\nポ、大きくしすぎ……んっ、じゅるっ、じゅぷぅ……」", "NORMAL" ]},
