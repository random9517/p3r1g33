		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バッケンキャリバー" ]},
		{"command":[ "SETTEXT", "「あはぁああ～～っ！！　ひゃぁっ、い、いっぱいザーメンが、かかってる…\n…んぅっ、んひぃいっ！」", "NORMAL" ]},
