		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バッケンキャリバー" ]},
		{"command":[ "SETTEXT", "「わ、私だって……んじゅぷっ、イクなら、一緒なんだから……じゅるるっ、\nあなたのことも、イかせるの……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0503217" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バッケンキャリバー" ]},
		{"command":[ "SETTEXT", "「思いっきり、オチンポ、しごく……。んっ、んんっ、ビクビクしてる、オチ\nンポ……んじゅぷっ、もう、限界なんでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0503218" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バッケンキャリバー" ]},
		{"command":[ "SETTEXT", "「じゅるるるっ、んじゅっ、んじゅぶっ、じゅぶぅっ！　もう、もう……だめ\nぇ……んじゅぷっ、イクッ、イッちゃう……！」", "NORMAL" ]},
