		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バッケンキャリバー" ]},
		{"command":[ "SETTEXT", "「……は？　その中にエッチな思い出もあるんじゃないかって？　人が思い出\nに浸ってるとき、そんなこと言う？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0503103" ]},
		{"command":[ "SETCHARA", "0", "char_00002405_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バッケンキャリバー" ]},
		{"command":[ "SETTEXT", "「本当、デリカシーないんだから。……そのときのことを聞かせてほしいわけ\n？　な、なに考えてるのよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0503104" ]},
