		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バッケンキャリバー" ]},
		{"command":[ "SETTEXT", "「まったく……。まあ、あなたにだったら話してもいいかしら。そんなに、た\nいしたことはしていないわよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0503105" ]},
