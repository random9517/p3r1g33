		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バッケンキャリバー" ]},
		{"command":[ "SETTEXT", "「ん……わ、わかってる……ちゃんと残さず、飲む、わよ……。ん……んくっ\n、んじゅる……じゅるる、じゅぷぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0503305" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バッケンキャリバー" ]},
		{"command":[ "SETTEXT", "「んぅ……いつまで、オマンコ見てるのよ……。んぁっ！？　ま、まって……\nまた、なに舐めて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0503306" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バッケンキャリバー" ]},
		{"command":[ "SETTEXT", "「こっちも残さず舐めとってやるって、バカ！　そういう余計な、恥ずかしい\nことはしなくていいってばぁっ、んひゃぁっ、あぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0503307" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バッケンキャリバー" ]},
		{"command":[ "SETTEXT", "「お潮吹きながらイクの、本当に気持ちよくって、頭の中真っ白になりそうで\n……クセになりそうだからダメなのっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0503308" ]},
		{"command":[ "SETIMAGE", "0", "still_00002405_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンキャリバー" ]},
		{"command":[ "SETTEXT", "「だから……んぁっ、人の話をききなさいってば！　んぁっ、も、もう……ん\nひゃぅっ、オマンコ、ダメだってばぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0503309" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バッケンキャリバー" ]},
		{"command":[ "SETTEXT", "「もうっ、知らないっ！　私のオマンコにへんな癖ついたら、みーんなあなた\nのせいなんだからぁっ！」", "NORMAL" ]},
