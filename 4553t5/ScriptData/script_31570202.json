{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015702_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふふ♪　ご主人様、つーかまーえたー♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0204101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「突然押し倒してきて何のつもりか、ですか？　……そんなの、ご主人様のお\nちんちんからお宝を搾り取りに来たにきまってるじゃないですかぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0204102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「知ってるんですよ？　そうやってパンパンに張り詰めたおちんちんの中に、\n熱ーいドロドロの精液――お宝をた～っぷりため込んでるんだって♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0204103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「それを私のオマンコで奪い取ってあげちゃおっかなと思いまして♪　――っ\nて、何ですかその慌て方は？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0204104" ]},
		{"command":[ "SETIMAGE", "0", "still_00015702_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「流石に突然すぎる？　身体に何か異常があるんじゃないかって？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0204105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「おお、素直に心配された、ちょっと嬉しいかも……じゃなくて！　別に何か\nステータス異常が出てメンテナンスが必要とかはありませんって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0204106" ]},
		{"command":[ "SETIMAGE", "0", "still_00015702_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ほら、今の私は『いたずら好きのドロボウ猫』ですから♪　ご主人様にえっ\nちないたずらを、と思いまして♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0204107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「おー、一気に呆れた表情になりましたねぇ。でもでも、ご主人様だって満更\nじゃないでしょ？　おちんちんこーんなに勃起させちゃってるんですから♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0204108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「おまんこで勃起おちんちんをすーりすりぃ♪　んにゃん♪　我慢なんてしな\nいで、私のいたずらを受け入れてくださいよぉご主人様♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0204109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「こうやって、乳首もツツツッ、って弄ってあげちゃいます♪　この手の知識\nもインプットしてきましたからね、とっても気持ちいいでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0204110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「乳輪の回りをツーってなぞって……乳首をグリグリ、グリグリ……にゃふふ\n、蕩け切った様なそのお顔、ご主人様とっても素敵です♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0204111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「――受け入れるまで早かったですねぇ♪　でも、許可が出たなら遠慮はしま\nせん。じっくりねっとり、おちんちんを飲み込ませてもらますね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0204112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んんんっ……ほーら、ゆっくりです、ゆっくりとじわじわと……んあぁんっ\n！　おまんこにおちんちんを沈めていきますよ……あぁんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0204113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふふ、そんな急かすような顔をしてもダメですよご主人様。折角のお宝\nさがし、早く終わっちゃうと、もったいないじゃないですか♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0204114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「時間をかけておちんちんを飲み込んで……んぁんっ……いっぱいいたずらを\nしながら、お宝探しをするのが楽しいんです♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0204115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んんっ……あっ、んあぁんっ♪　分かりますか、おちんちんの先っぽ……ご\n主人様の亀頭がパックリ飲み込まれちゃいましたよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0204116" ]},
		{"command":[ "SETIMAGE", "0", "still_00015702_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「このままぐりぐりって腰を回しながら……あっ、んんっ！　これで半分……\nにゃふふ、まだです、まだまだゆっくりです♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0204117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ほーら、また乳首もぐりぐり、ぐりぐり……そうして上に気を取られた隙に\n……んにゃぁんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0204118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「こ、これで全部ですね！　ご主人様のおちんちん、ぜーんぶ私のおまんこに\nはいっちゃいました♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0204119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んにゃぁんっ！？　あっ、ふあぁんっ！　ちょ、ちょっとご主人様、勝手に\n腰を突き上げないで下さいよ、あぁんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0204120" ]},
		{"command":[ "SETIMAGE", "0", "still_00015702_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「もうっ……いたずらするのも、お宝を探すのも私の役目です！　ご主人様は\nされるがままになっちゃっててください！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0204121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「挿入はじっくりいきましたからね、ココからは激しく――あっ、んあぁんっ\n！　んにゃんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0204122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「すごいでしょ、このパーツを装着した時の私のおまんこの中の感触。ご主人\n様のおちんちんにぴったりフィットする様になってるんですよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0204123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「こうやって、腰を前後にふってあげれば、あっ、あぁんんっ！　ご主人様の\n敏感な括れが、ぎゅーって搾り取れて、んにゃぁんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0204124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んにゃんっ♪　ふあぁんっ♪　おちんちん、びくびくしっぱなしで、あぁん\nっ！　これならお宝もあっという間に頂けちゃうかもしれませんね♪」　", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0204125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「そういえば、この体位って、スパイダー騎乗とかっていうんですよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0204126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「色々インプットしてきた知識の中にあったんです。男性を視覚的にも興奮さ\nせるには、この体勢がぴったりだって♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0204127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふふ♪　どうですか、ご主人様？　いい眺めですか？　……って、聴こ\nうと思いましたけど、その蕩けたお顔を見るに、返事はいりませんねぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0204128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ほーら、また乳首の時間ですよ～。今度はちょっと痛い位の力で指で摘まん\nで、ぎゅ～、ってしてあげます♪　ぐりぐり、ぎゅ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0204129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ふあぁんっ！　お、お腹の中でまたおちんちんが大きく跳ねてっ、んにゃん\nっ！　こ、こら、だからご主人様は腰を動かしちゃ駄目ですって！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0204130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「いたずらするのは私です！　こーやって……んんっ！　腰をぐっと押さえつ\nけて、腰を回してっ……んあぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0204131" ]},
		{"command":[ "SETIMAGE", "0", "still_00015702_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふふっ、分かりますよ、ご主人様、もう限界なんですよね？　おちんち\nんが大暴れしちゃってますもんね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0204132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ほらほら、我慢なんてさせませんよ♪　このまま、おまんこぐちゃぐちゃに\n動かして、ご主人様のお宝を搾り取っちゃいます♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0204133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふふ、たまにはいいですねー、こうやって私がご主人様を見下ろすのも\n♪　ご主人様の蕩けたお顔、とってもかわいいです♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0204134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「あっ、んんっ、んあぁんんっ！　――にゃふふ、もちろんお宝を受け止める\nのは私のオマンコの中で、です！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0204135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ぜーんぶ搾り取ってあげちゃいますからね！　ご主人様の大事な子種という\nお宝を、私のおまんこにびゅーびゅー射精しちゃってください！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0204136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んにゃあぁあぁ～～っ♪　ご主人様の精液、すごいっ！　内部機構が焼き付\nくほど熱くてっ、あっ、んにゃあぁんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0204137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015702_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「こ、これ、私も軽くイッちゃってます！　思考に心地いいノイズが走ってっ\n、あっ、んにゃあぁぁんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0204138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふふっ♪　ご主人様ってば、こんなにもお宝を溜め込んじゃって……あ\nぁんっ……にゃふふ、宝探しの甲斐がありますねぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0204139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「まだまだ本番はここから♪　『いたずら好きのドロボウ猫』の本気、お楽し\nみくださいな♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0204140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んあぁんっ♪　にゃふふ、ご主人様、いい反応ですねー♪　こうしておまん\nこを動かしてあげると……あぁんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0204201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「――何をしてるのか、ですか？　それはもちろん、もっと効率よくお宝を搾\nり取る機能をオンにしたんですよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0204202" ]},
		{"command":[ "SETIMAGE", "0", "still_00015702_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「おまんこの締め付けが強くなったのが分かりますか？　このパーツはぎゅう\nぎゅうって、おちんちんに吸い付く機構を搭載してるんです♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0204203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「それにほら、こうしておちんちんを深くまで挿入した状態でぐりぐりってし\nてあげれば……あっ、んにゃぁんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0204204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「一番奥が……機械の子宮が亀頭をぐりぐり撫で回すんです♪　もちろんご主\n人様が大好きな動きのパターンもインプット済みですよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0204205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「根元から先端まで、ゆ～っくりズボズボしながら、んあぁんっ♪　括れの部\n分をぎゅって圧迫して、ぐりぐり振り回して、んふぅんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0204206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「え？　刺激が強すぎるから一度休ませてくれって？　――にゃふふ、そんな\nお願い、もちろん却下に決まってるじゃないですか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0204207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「何度も言いますが今の私は『いたずら好きドロボウ猫』。ご主人様にえっち\nないたずらをするのが大好きなんですから！　んあぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0204208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「乳首だって逃がしませんよ♪　乳輪をなぞる様にすりすりぃ、って撫でて―\n―からの、ぎゅ～ってつまみ上げちゃいます♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0204209" ]},
		{"command":[ "SETIMAGE", "0", "still_00015702_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「おちんちん、おまんこの中で大暴れじゃないですか。そんなに気持ちいいん\nですか？　私に好き放題いたずらされるのがそんなに嬉しいんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0204210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふふ、この調子なら残りのお宝もあっという間に頂けてしまいそうです\nね～♪　ご主人様ってば、ちょろちょろですね～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0204211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「って、ご主人様？　な、なんですかその目つき？　……へ？　調子に乗り過\nぎだ、エロ猫って――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0204212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「え、あっ、ちょっ、まってっご主人さ――んにゃあぁんっ！？　あっ、ふあ\nぁんんっ！？　　だ、ダメ、いきなりそんなっ、あひゃぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0204213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「だ、ダメですご主人様、お臍の裏のソコ、ぐりぐりしちゃダメですって！　\nんにゃぁんっ！？　あっ、ふあぁんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0204214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ほ、ほんとに激しすぎっ、にゃぁんっ！　あぁぁんっ、んひぃんっ！　お腹\nボコってなるぐらいゴリゴリ削られてっ、あひぃぃんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0204215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ノイズとエラーが一気にきてっ、んやぁんっ！　――そ、そんなにお宝が欲\nしいなら、遠慮なくぶちまけてやる、って、ふあぁんっ！」　　", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0204216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「あっ、ふあぁんっ！　にゃあぁんんんっ！　おちんちん、ビクビクしてきた\nっ！　あっ、んにゃぁんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0204217" ]},
		{"command":[ "SETIMAGE", "0", "still_00015702_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「いたずらは私がするはずなのに！　私がお宝を搾り取るはずだったのにぃ！\n　あぁんっ、あっ、ふにゃぁんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0204218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「――でも、嫌じゃないのっ！　ご主人様から頂けるのであれば、それはぜー\nんぶ私の宝物でっ！　あひっ、ふあぁんんっ！　だから、だからぁ――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0204219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「私もイクからっ、ご主人様のお宝を受け止めていっしょにイきますからぁっ\n、ふあぁんんっ♪　ご主人様の精液を、いっぱいぶちまけてくださいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0204220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んにゃぁあぁぁんんっ～～っ！！　あっ、ふああぁんっ！　あ、熱いっ、お\n腹の奥に精液びゅーびゅーってきてっ、イクっ、イクゥゥゥっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0204301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015702_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「射精中のおちんちんに、いっぱいいたずらしたいのにっ、あひっ！　こんな\nの、だめっ、頭の中エラーだらけでっ、んにゃぁんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0204302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んやっ、あっ、んあぁんんっ♪　おまんこの中、宝物でいっぱいだぁ……♪\n　ご主人様の精液いっぱい、嬉しくてっ、あっ、んにゃぁん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0204303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んんっ……あっ、んあぁんっ……こ、これで全部、ですか？　ご主人様の隠\nしてるお宝、全部出し切ってくれましたか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0204304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ほんとーなら、もっともっと私からいたずらして、ご主人様には気持ち良く\nなって欲しかったんですけど――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0204305" ]},
		{"command":[ "SETIMAGE", "0", "still_00015702_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふふ♪　ご主人様にいたずらされるのも、それはそれで、中々悪くなか\nったですよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0204306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「それにしても……んっ……ご主人様ってば、ほんとーに溜め込みまくってま\nしたねー。ほら見てください、精液がどんどん逆流してきちゃってます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0204307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「このパーツに換装した私のこと、気に入ってくれたみたいで、とっても嬉し\nいです♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0204308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「――さて、次はどんなロッテをご所望でしょうか。ドＳな私？　ドＭな私？\n　シックな私？　ゴスロリな私？　清楚な私？　淫乱な私？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0204309" ]},
		{"command":[ "SETIMAGE", "0", "still_00015702_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ご主人様が望むのならば、全てのパーツを換装して、どんな私にだってなっ\nてみせましょう。だって私は、ご主人様の所有物、なんですからね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0204310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ふにゃあぁぁぁんっ♪　ああ、もったいないっ！　ご主人様のお宝が、おま\nんこの中じゃなくて私のおっぱいにいっぱいかかってっ、あぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0204401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015702_02_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「あっ、んん、んにゃぁんっ……！　でも、これはこれでいいかもっ、んふぅ\nんっ！　精液のかかったパーツが熱をもってっ、んにゃぁんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0204402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んんっ、あっ、あぁんんっ！　小さいエラーがいっぱい出てっ、ノイズもす\nごくてっ、あっ、あぁぁんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0204403" ]},
		{"command":[ "SETIMAGE", "0", "still_00015702_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「あっ、んあぁんっ！　ご主人様の精液で、全身のパーツがぐちゃぐちゃの、\nドロドロでっ、んあぁんっ！　イクのっ、止まらないっ、ふあぁんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0204404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「あぁ……ご、ご主人様のお宝がこ～んなにもたくさん……んっ……にゃふふ\n、とっても幸せ、かも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0204405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「――こうしてみると、射精を終えたばかりのおちんちんって、びくびくして\nて、なんだか可愛いですよねー♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0204406" ]},
		{"command":[ "SETIMAGE", "0", "still_00015702_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふふ♪　ツンツンってつついて、いたずらしたくなっちゃいます♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0204407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「出したばっかりで敏感になってるからやめてほしい？　さーて、どーしまし\nょーかねー？　ツンツン、ツンツン……にゃふふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0204408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「さて、次はどんなロッテをご所望でしょうか。激しい私？　大人しい私？　\n水着な私？　浴衣な私？　巨乳な私？　貧乳な私？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0204409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ご主人様の好みに合わせて、どんなパーツでもお試しくださいな。私の全て\nはご主人様のモノなんですから♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0204410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}