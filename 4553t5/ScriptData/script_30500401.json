{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「あなたがなぜここに呼び出されたのか、わかりますよね？　そう、今回の任\n務の件です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0403101" ]},
		{"command":[ "SETCHARA", "0", "char_00005004_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「もしかして、変身が失敗した程度で私が負けるとでも思っていたんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0403102" ]},
		{"command":[ "SETCHARA", "0", "char_00005004_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「あなたが悪の組織に手引きしたことはわかっているんです。裏切り者には、\n更生が必要ですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0403103" ]},
		{"command":[ "SETCHARA", "0", "char_00005004_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「さて……押し倒されたあなたはどうしてペニスを膨らませているのですか？\n　これからお仕置きだというのに」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0403104" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00005004_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「これはあなたが今回の任務において、私を貶めようとしたことへのお仕置き\nなのですよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0403105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「……ふむ、この期に及んでまだ白を切るつもりですか。では仕方がありませ\nんね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0403106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「自身の悪事を白状したくなるよう、このペニスをしごいてあげましょう。も\nうすでにガチガチになっていますね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0403107" ]},
		{"command":[ "SETIMAGE", "0", "still_00005004_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「こうやって、ぎゅっと握って……。手の中でビクンと跳ねましたね。気持ち\nよくなっているのですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0403108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「これはお仕置きなので、悦んでもらうわけにはいきませんね。それではしご\nかせていただきますよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0403109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「んっ……んんっ……。相変わらず、勃起したペニスのなんて大きいこと……\n。それに、とても熱い……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0403110" ]},
		{"command":[ "SETIMAGE", "0", "still_00005004_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「こんなに、太く……。んっ、根元から、先端まで……握る手を押し返すほど\nに膨張しています……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0403111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「どうしました？　握る力が強すぎる？　それなら、こんなにペニスを勃起さ\nせなければいいではありませんか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0403112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「これはお仕置きなんです。このように、私の……露わになってしまった胸を\nぎゅうぎゅうと押しつけられようと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0403113" ]},
		{"command":[ "SETIMAGE", "0", "still_00005004_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「ガチガチのペニスをごしごしとしごかれようと。勃起、しなければいいので\nすよ？　簡単でしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0403114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「ふふっ、黙秘するのは結構ですが、どこまで耐えられますか？　ペニスはも\nう辛そうにしていますね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0403115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「策士策に溺れるとはまさにこのこと。私に破廉恥なスーツを着せたことで、\nかえって自分の首を絞めているんですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0403116" ]},
		{"command":[ "SETIMAGE", "0", "still_00005004_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「さあ、早く白状してしまいなさい。それとも、まだまだ刺激が足りませんか\n……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0403117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「それなら、あなたの乳首も……んちゅっ、ちゅぅ……責めてあげましょうか\n……んっ、ちゅぱ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0403118" ]},
		{"command":[ "SETIMAGE", "0", "still_00005004_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「ペニスと同じように、こちらも硬くなっているようですね……んれろっ、舌\nで舐めてあげましょうか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0403119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「れろ……れろれろぉ……。んっ、れろぉ……ちゅぷっ、ちゅぱ……。少し舐\nめただけで、ペニスも震えていますね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0403120" ]},
		{"command":[ "SETIMAGE", "0", "still_00005004_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「お仕置きとして責めているのに、悦んでしまっているのですか？　んっ、ち\nゅぷ、なら、もっと容赦なく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0403121" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「んちゅるるっ、ちゅぷっ、んれろ、れろぉ……んっ。尖った乳首を舐め溶か\nすように、舐ってあげましょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0403122" ]},
		{"command":[ "SETIMAGE", "0", "still_00005004_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「そして、ペニスのほうも……。ごし、ごし、ごし……。ふふっ、力いっぱい\nしごいてあげますよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0403123" ]},
		{"command":[ "SETIMAGE", "0", "still_00005004_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「ちゅ、ちゅぶっ、ん……ちゅりゅぅ……。どうしました？　先ほどまで悦ん\nでいたではありませんか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0403124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「乳首とペニスを一緒に責められて、苦しそうですね……。んちゅっ、れろれ\nろぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0403125" ]},
		{"command":[ "SETIMAGE", "0", "still_00005004_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「これはお仕置きです。んっ、手を緩めることはありませんよ。ほら、もっと\nペニスも、しこ、しこ、しこ、しこ……」　", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0403126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「ますますペニスが硬くなっているようですね。んちゅっ、こうやって乳首を\n舐めながら、身体を寄せ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0403127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「胸を押しあてられる感触が、よりあなたを昂らせているようですね……。ふ\nふ、さあ、どうです？　観念しましたか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0403128" ]},
		{"command":[ "SETIMAGE", "0", "still_00005004_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「……ええ、たとえ観念したところで、お仕置きは終わりませんよ？　んっ、\nちゅぷ、このまま最後まで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0403129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「ペニスから、先走りの汁が溢れているようですね。んちゅっ、手がぬるぬる\nになってしまいます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0403130" ]},
		{"command":[ "SETIMAGE", "0", "still_00005004_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「これを竿全体に塗るように、しこ、しこ、しこ……。ンッ、激しくしごいて\n、イかせてしまいましょう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0403131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「ごし、ごし、ごしと……思いっきり、先端から根元までしごいて。んちゅ、\n乳首も責めながら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0403132" ]},
		{"command":[ "SETIMAGE", "0", "still_00005004_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「速度をあげて……んっ、腰をビクつかせようと、ペニスから手を離しません\nから。さあ、正義の手でイッてしまいなさい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0403133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「んっ、んんぅっ！　手の中でペニスが暴れ、びゅくびゅく、精液が……っ！\n　ああっ、すごい勢いで……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0403134" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00005004_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「熱い精液で、手がベトベトですね……。こんなに射精するなんて、本当にお\n仕置きになっていないようです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0403135" ]},
		{"command":[ "SETIMAGE", "0", "still_00005004_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「そんなに私の手が気持ちよかったのですか？　ふふ、そうですか……そうい\nうことなら、もっとしてあげましょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0403136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「勘違いしないでくださいよ？　ご褒美ではありませんからね。そもそも、ま\nだ目的を達成していません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0403137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「あなたには、たっぷり反省してもらわないといけないんですから。私にこの\nようなスーツを着せたことについても」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0403138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「さあ、もっともっとしごいてあげますから。このヌルヌルの手で、あなたの\nペニスを……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0403139" ]},
		{"command":[ "SETIMAGE", "0", "still_00005004_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「すぐに回復したようですね。先ほどと同じくらいの硬さまで、すぐに戻って\nきたようです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0403140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「これは一体どういうことですか？　あなた、私にお仕置きされることを望ん\nでいるのではありませんよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0403201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「……この質問にも黙秘ですか？　なら、改めてお仕置きをして、聞きだして\nみましょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0403202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「えらの部分をしっかりと持って、小刻みに、しごいて……。ふふ、さっきと \nはまた違った刺激を与えてみましょうか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0403203" ]},
		{"command":[ "SETIMAGE", "0", "still_00005004_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「乳首も責めてあげます……。んっ、ちゅぶっ、あなたが、素直に自白するよ\nうに……れろ、れろぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0403204" ]},
		{"command":[ "SETIMAGE", "0", "still_00005004_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「ペニス……しこしこしこ……。んっ、ちゅぷぅ……。腰が震えているようで\nすね……んちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0403205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「乳首も……ンッ、こんなに……。女性でもこんなにビンビンになることはな\nいのでは……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0403206" ]},
		{"command":[ "SETIMAGE", "0", "still_00005004_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「このようにお仕置きされて、興奮しているようなあなたには……もっと苛烈\nな責めが必要でしょう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0403207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「ぎゅぅ……っと、ペニスの根元を握り……。んちゅっ、乳首だけ……責めて\nあげます……れろ、れろ、れろぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0403208" ]},
		{"command":[ "SETIMAGE", "0", "still_00005004_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「射精できないでしょう……？　んっ、んちゅ、ちゅぱっ。でも、乳首を責め\nられて、精液がこみあげてきているようですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0403209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「れろれろ、れろぉ、ンッ、ちゅぱっ。勃起した乳首にお仕置きされて……れ\nろぉ、腰が暴れていますが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0403210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「こちらが許すまで、根元はぎゅっと握られたまま、射精させませんからね…\n…れろ、れろれろれろぉんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0403211" ]},
		{"command":[ "SETIMAGE", "0", "still_00005004_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「ちゅ、ちゅぱっ、さあどうですか？　まだまだ我慢を続けますか？　んっ、\nちゅぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0403212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「乳首を、舐められまくり……射精を封じられ……んっ、ちゅぱっ。もう限界\nではありませんか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0403213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「自分の非を認めるなら、射精をさせてあげましょう……んっ、ちゅるるっ、\nちゅぱっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0403214" ]},
		{"command":[ "SETIMAGE", "0", "still_00005004_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「こんなスーツを着せて、私を辱めたことも、ひとまずは許してさしあげます\nよ。んっ、ちゅぶっ、れろれろぉ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0403215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「ふふっ、そうですか。しっかりと反省してくれたようですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0403216" ]},
		{"command":[ "SETIMAGE", "0", "still_00005004_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「いつもは容赦のない私ですが、今回は特別に情けをかけてあげますよ。さあ\n、こうやって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0403217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「思いっきり、先走りと精液にまみれたペニスを、高速でしごいてあげますか\nら……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0403218" ]},
		{"command":[ "SETIMAGE", "0", "still_00005004_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「しこしこしこしこ、しこしこしこしこ……！　さあ、イッてしまいなさい。\n思いっきり射精して反省の色をみせなさい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0403219" ]},
		{"command":[ "SETIMAGE", "0", "still_00005004_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「さあ、正義のヒーローが、あなたのペニスを成敗してあげますから……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0403220" ]},
		{"command":[ "SETIMAGE", "0", "still_00005004_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「んぁあっ！　あはぁっ、あああぁぁぁ～～～～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0403301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00005004_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「また大量に、んっ、手に……精液が……！　んっ、びゅくびゅくと噴きあが\nって、かかって……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0403302" ]},
		{"command":[ "SETIMAGE", "0", "still_00005004_01_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「ああ、すごいですね……。２度めだというのに、まだこんなに精液をため込\nんでいたんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0403303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「私の責めが気持ちよくて、また大量に射精してしまった、と……。ふむ、そ\nういうことですか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0403304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「……残念ながら、あなたにはまだお仕置きが必要なようですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0403305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「てっきりちゃんと反省してくれたと思ったら、お仕置きされながら精液を作\nっていたとは。呆れます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0403306" ]},
		{"command":[ "SETIMAGE", "0", "still_00005004_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「こうなれば、あなたの精液が空になるまで、私が搾るしかありませんね。さ\nあ、覚悟してください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0403307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「今の私は、力の制御が困難な状態……。抵抗すると、大変なことになってし\nまいますよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0403308" ]},
		{"command":[ "SETIMAGE", "0", "still_00005004_01_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「ふふ、大人しくお仕置きされてくださいね、隊長。ペニスは、どうやらお仕\n置きを待ち望んでいるようですし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0403309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「みっちりしごいて、反省してもらいますよ?」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0403310" ]},
		{"command":[ "SETIMAGE", "0", "still_00005004_01_13" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「ああっ、んっ、精液が……あ……ああ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0403401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00005004_01_20" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「すごい、勢いで……っ！　んっ、私の顔にまで届くほどに、射精が……あっ\n、ああ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0403402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「まったく……これは全然反省してませんね……。射精の許可をだしましたが\n、顔にかけるなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0403403" ]},
		{"command":[ "SETIMAGE", "0", "still_00005004_01_17" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「さあ、どうなんですか隊長？　まだまだ搾りだせそうですね。こうやって、\nペニスをぎゅっと握って……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0403404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「上下にしごけば、竿の中に残った精液の残りが搾りだされてますよ……。ん\nっ、ごし、ごし、ごしと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0403405" ]},
		{"command":[ "SETIMAGE", "0", "still_00005004_01_19" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「どうなんですか？　本当に反省したんですか？　今の私の前で、これ以上ウ \nソを重ねるのはやめた方がいいと思いますよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0403406" ]},
		{"command":[ "SETIMAGE", "0", "still_00005004_01_16" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「ふふっ、その表情……。反省しているのは本当のようですね。ですが、まだ\n解放するわけにはいきません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0403407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「今度は、私に精液をぶっかけたことに対するお仕置きをしなければならなく\nなりました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0403408" ]},
		{"command":[ "SETIMAGE", "0", "still_00005004_01_18" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「隊長がこんなことをするから、私も我慢できなくなってしまったんですよ？」", "NORMAL" ]},
