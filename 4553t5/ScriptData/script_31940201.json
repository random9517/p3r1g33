		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「隊長……隊長！　こっちだ、こっち……！　路地裏の……奥。早く来てくれ\n……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0203101" ]},
		{"command":[ "SETCHARA", "0", "char_00019402_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「……急に呼び出してしまってすまなかった。きょ……今日は、貴方にこの服\nを……見て欲しくてな。ここに誘いをかけたわけだ。……何？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00019402_01", "0", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_194_0203102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「これは、アトロポスが買ってきた童貞を殺す服というやつで……。着方が違\nう？　前と後ろ、表と裏が逆……？　な、なんだと！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0203103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「あっ、あっ……。ち……違う！　ワタクシはあえてそういう着こなしを選ん\nだのだ！　決して間違ったわけではなく！　わかっていてだからな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0203104" ]},
		{"command":[ "SETCHARA", "0", "char_00019402_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「うむ……おかしいな。これを着て男に会えば、誰もが魅了され飛びついてく\nるという話だったが……。まあいい。貴方を今日呼び出したのは他でもない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0203105" ]},
		{"command":[ "SETCHARA", "0", "char_00019402_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「最近……姉妹に邪魔をされてなかなか２人になれなかったからな。たまには\nワタクシが、２人になれる場所を探してやろうと思ったのだ。そして」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0203106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「せっかくこのような、いやらしい服を手に入れたから……。ワタクシの胸を\n貴方に使わせてやってもいい。貴方は胸が……いつも好きだから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0203107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「フフ……反論できまい。よーくその目で見て、確かめるのだな。セクシー度\nが増して妖艶な乳房を晒したこのワタクシを……。……ん？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0203108" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00019402_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「に、ニオイを嗅ぐのはやめろ。こらっ、舐めようとするのも無しだ！　触る\nのもっ……と、優しく揉むくらいなら……いいぞ。想定の範囲内だ。」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0203109" ]},
		{"command":[ "SETIMAGE", "0", "still_00019402_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「んっ！？　躊躇なくチンポを挟んでくるやつがあるかぁ！　っはぁっ……私\nは手で胸を揉めと……。っぁっ！　も、揉みながらパイズリをする、だと？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0203110" ]},
		{"command":[ "SETIMAGE", "0", "still_00019402_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「んふっ……んん……！　そ、そうか……。それほどまでにこの服とワタクシ\nの胸に魅了されて……。い、いいぞ。本日この胸は貴方だけのものだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0203111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「す……好きに揉み、好きに扱え。だが、一つだけ事前に言っておくことがあ\nる。妹からもらった物がもう１つあってな……。それが母乳を出す薬」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0203112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「ボニューデマクールというものらしい。これは……。んっ……！　そ、そう\nやって……貴方が私の胸を、乳房を激しく揉みほぐし続ける、と……ぉ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0203113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「あひっ！　んぁああ！　こ、こんな風にぃ！　母乳がっ……！　母乳が胸か\nら染み出す薬なのだ！　ッあっ……！　す、すごいだろう……。うぁあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0203114" ]},
		{"command":[ "SETIMAGE", "0", "still_00019402_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「……こ、これは思っていたより大量に出て来るな……！　っあっ！？　それ\nに……噴射する時……乳首が、乳首がビクビク震えて絶大な快感が……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0203115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「ッうううっ……？　お……おかしいぞ、貴方を喜ばせようとして飲んだ薬な\nのに……。ワタクシが、感じて……快楽と刺激でどうにかなりそうで……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0203116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「んん！？　こらっ、い、今強く胸を揉むんじゃないっ……あああっ！　いつ\nもより感じすぎてしまう……！　ひぃっ！　チンポを動かすのもダメだっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0203117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「なに……！？　あ……、ぁ……！？　んぁっ！？　き、気持ちいい！？　ア\nトロポス……だ、騙したな！　これでは媚薬以上ではないか！　っああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0203118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「だ……めだ、あぁ……っ。ぼ、母乳が溢れ出すと……私が私でなくなってし\nまう……！　それに、母性本能が疼き出して……んぁああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0203119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「貴方のチンポに対しても、愛おしい気持ちが湧いてきて……。あっ♪　あっ\n、なんでもさせてやりたくなってしまう……！　くぅうう……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0203120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「んひっ！　母乳……母乳が乳首から染み出して……あんんっ、母乳が出ると\n感度が上がる……！　あっ……あっ、その上貴方の手が卑猥に動いて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0203121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「チン、ポ……♪　太いチンポが胸の谷間を犯すから……！　ワタクシは、ワ\nタクシはもう……もう、気をやってしまいそうだ……！　止められないぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0203122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「あふっ！？　ひっぅっ、んはぁっ！　あああっ！　パ、パイズリ！　パイズ\nリをしてもいいが……少し、少し待ってくれ、優しく……でないと！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0203123" ]},
		{"command":[ "SETIMAGE", "0", "still_00019402_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「ワタクシはイッ……♪　あぁっ！　はしたなくイッてしまう、乳首と乳房で\nイキちらしてしまうから……だから優しく、優しくして……。んんぁっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0203124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「ひああっ！？　い、痛い……いたいっ！　胸を容赦なく揉むなどと……！　\nなぜ……！？　それにグイグイ腰を打ちつけてくる……やっ、あっ、やっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0203125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「ふぁあああっ！　知らない……っ、こんな快感、知らないぃ……！　あっ…\n…あああああっ！　ひどくされると感じるだなんて……あっ、ダメだぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0203126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「乳首……乳首がビンビンになって……！　あっ、チンポにまとわりついてし\nまう……あぁっ！　母乳でぬかるんだ谷間に硬く熱いものが挟まって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0203127" ]},
		{"command":[ "SETIMAGE", "0", "still_00019402_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「ワタ、クシ……ワタクシのおっぱいがオマンコのように犯されている……！\n　あっ♪　それが……それがたまらなく良いのだ、これはなんだぁ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0203128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「あふっ！　あぅっ、くぅうっ、くふぅうう……っ！　い、や……ぁ、いやっ\n♪　おっぱいマンコ、おっぱいマンコ犯されたら……犯されたらぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0203129" ]},
		{"command":[ "SETIMAGE", "0", "still_00019402_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「ワタクシ、もう我慢ができないぃ……！　あっ！　こんな場所で……ここま\nで乱れるつもりがなかったから、貴方を誘ったが……しかし、しかしぃっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0203130" ]},
		{"command":[ "SETIMAGE", "0", "still_00019402_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「大きな声で喘いでしまってっ……あぁんんっ！　聞かれてしまう、ワタクシ\nが母乳を撒きながら絶頂するのを誰かに見られるぅ……！　ふああああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0203131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「イくっ……イクぅっ！　おっぱいマンコ犯されて絶頂……っ！　あふっ！？\n　情けない……っ、ワタクシは長女なのに、胸を犯されて簡単に絶頂して！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0203132" ]},
		{"command":[ "SETIMAGE", "0", "still_00019402_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「でも、でも気持ち良すぎて……あぁううっ！　イクのがやめられないのだぁ\n……！　あっ！　あっ、そうです……そうです、ワタクシは……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0203133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「貴方にこうして胸を犯してほしくて、野外で、外で淫らなパイズリをされた\nくて……！　母乳っ、母乳で絶頂したくて誘いました、淫乱です……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0203134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「貴方のせい、で……ワタクシはおっぱいが淫乱になってしまいました、胸の\nっ……谷間を容赦なく犯されて、突かれて、感じている痴女ですぅう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0203135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「おねが、いします……お願いします、ワタクシっ、また激しく絶頂しますか\nら、おっぱい犯されてイキますから貴方の精液をください、くださいぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0203136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「あぁああああっ……！　ああっ、おぉおおっ♪　んぉおおお……♪　なぜ、\nだ……胸に注がれる白濁の勢いが、ぬめりが、熱さがいつもより……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0203137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019402_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「これがボニューデマクールの力なのか……っ？　あっ、もっとだ、もっと出\nしてくれ……注いで、胸が真っ白になるまで……精液にまみれるまで……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0203138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「ふぁっ……ああ、あぁ……ああ！　そうだ、強く胸を揉んで、精子をなすり\nつけろ……！　っあっ……乱暴に、物のように扱ってくれ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0203139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「んふーーーーっ♪　ふぅうっ、ふぅ～～～っ♪　イ、くぅ……イクぅ！　射\n精されながら種汁を浴びて絶頂す、る……！　ああああああっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0203140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「はぁあああ～～……♪　ふはぁああ……♪　あっ……。な、なんだ……？　\n今一瞬、気が遠くなってしまった……この陶酔、危険すぎる快感だ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0203201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「ククク……。貴方も相当良かったみたいだな……。はぁ、はぁ、精液の量が\nとてつもない。それに……。んぅ♪　臭いも濃くて、いやらしくて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0203202" ]},
		{"command":[ "SETIMAGE", "0", "still_00019402_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「そんなに路地裏でするパイズリがお気に召したか……？　って、な、何をし\nている……。私の胸を持ち上げるな、私はもう平静を取り戻した」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0203203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「貴方のように強烈な余韻に浸ってなど……。何！？　であればこのままパイ\nズリを続ける、だと！？　いやっ、あ、あの、そ……それは……そのっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0203204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「確かに！　ワタクシは先程のパイズリで何度も絶頂に達したが！　だからと\nいって性欲が終わったわけではなく……まだ乳房も乳首も敏感なままで」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0203205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「こんな状態で胸を掘られ、貫かれ、ピストンを食らえばひとたまりも……！\n　うぁああっ！　や、やめっ……やめろと言っているのにぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0203206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「腰っ……腰を動かすな、チンポをぶつけるなぁ……！　あぁああっ！　無理\nだ、普通にしていても母乳が出てしまうのに、精液まみれの状態で……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0203207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「あっ、くぅっ！？　くふぅっ、んあああっ！　つ、突くなぁ……！　あうっ\n、あうぅううっ……♪　感じるっ、感じすぎてしまうから……ぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0203208" ]},
		{"command":[ "SETIMAGE", "0", "still_00019402_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「はぁッ……♪　あぁ、あぁあっ……ああぁああ……！　む、ね……胸が熱い\n、精液でヌルヌルになって……卑猥に照り輝いて……ああああッ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0203209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「ひぁああっ！　また、また母乳が……！　あっ！　貴方のチンポにかかって\nしまう……あっ！　恥ずかしい……こんなにたくさん出すつもりじゃあ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0203210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「んんんん～～～～～ッ！　し、信じられないくらい母乳が噴き出すぅ……！\n　これではワタクシが完全に変態みたいではないか、いやだ、い、やっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0203211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「あふぅうううっ！？　ふぅううっ、くぅううう～～～～っ、くふぅうっ♪　\n母乳……母乳が止まらないっ、感じすぎてしまうぅ……またイクっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0203212" ]},
		{"command":[ "SETIMAGE", "0", "still_00019402_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「あっ♪　あっ、一突きされるたびに絶頂、するなんて……いやっ、いや、だ\n……姉として示しがつかない、恥ずかしい……！　なのに……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0203213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「もっと、もっとしてほしい……続けてほしい、……ああっ！　もう、もうど\nうなってもいい……！　恥も外聞も、誇りも全部捨ててもいいからっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0203214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「もっとしてくれ……！　ワタクシのおっぱいマンコをめちゃくちゃに突いて\n、掻き回して……ああああっ！　いいっ……良いっ、感じる……ぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0203215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「あっ、あぁ……あっ！　あっ！　上に、下に、左に、右に……跳ねちらかす\n乳房と……チンポにこすれる乳首……あっあっあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0203216" ]},
		{"command":[ "SETIMAGE", "0", "still_00019402_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「イ……イクぅっ！　胸で……母乳を出しながらまた絶頂する、するぅ……！\n　あぁあああっ……！　あ～っ……♪　はぁッ♪　あ～～～～～っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0203217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「ん……？　ワ、ワタクシの胸が感じすぎで熱くなって気持ちいい、と……？\n　そうだ、イキすぎてトロトロのフワフワになってしまっているんだ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0203218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「どうか、この……スケベすぎる淫乱ダークエルフのワタクシの胸に……新鮮\nな精液を、ザーメンミルクを注入してくれ……お願いするぅ……早く……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0203219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「あッ……！　だ、ダメだ……耐えきれない……！　またイクッ……イク、チ\nンポ大きすぎる……！　気持ちいいっ……気持ちいい……トぶぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0203220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「あッ……♪　あふぅうっ！　イクイクイクぅ……！　熱い……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0203301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019402_01_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「あっんっんっンッ……！　濃厚な精液の臭い、べっとりとまとわりついてく\nるこの粘液ぃ……胸が、包みこまれて幸福感で満たされてしまう……ッ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0203302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「あっ！　全部……全部出るまで絞りきるんだぞ……！　あっ！　ワタクシの\n胸で搾っていいから……！　あぁっ！　そうだ、そうやって圧迫して……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0203303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「尿道から一度に絞り上げて……！　あふっ♪　びゅるっ、びゅるドクッドク\nッと注ぎ込まれる熱い液体……貴方の子種、種汁……ああああ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0203304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「胸がジンジンと熱い……痺れる、腫れあがる……！　あっ……白濁の水たま\nりのようになってしまったが……それが、いいんだ。これが欲しかった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0203305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「あはぁああ……♪　はははっ……、絶頂しすぎて胸がドクドク脈打っている\n……。そこに、褒美のように注がれた大量の白濁液……子汁……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0203306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「こんな量……胸でなければ確実に妊娠していたぞ。本当に貴方は、規格外と\nしかいいようがない……。はぁ、はぁ……汗をかいた……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0203307" ]},
		{"command":[ "SETIMAGE", "0", "still_00019402_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「見てくれ。母乳も精液に負けじと、まだしつこくぴゅるぴゅると染み出して\nいるぞ……。刺激すればするだけ無限に溢れ出す母乳……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0203308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「最初は戸惑ったが、今までにない新しい快感の数々にワタクシはすっかり夢\n中になってしまっていた……。ボニューデマクール……買い占めなければ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0203309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「そうして、次は貴方とどういう服で、どこで、どんな風に淫らに交わるのか\nを楽しみに出来るとしたら……ここに来た甲斐があったというものだ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0203310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「あッ……♪　か、は……♪　あうっ、あふっ、あぁ……。……ん！？　んん\nっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0203401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019402_01_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「か、お……？　まさか、ワタクシの顔に精液をかけているのか！？　達する\nのに夢中で気が付かなかった……！　こらっ、な、なにをしているぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0203402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「ワタクシはその子種を乳房に……胸に注げと命じたのだぞっ、顔に……かけ\nるなどと……と、ええいっ！　話の途中でぶっかけるな……！　あぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0203403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「く、くさ……いぃ……！　んむっ、口に入ってきた……馬鹿者が……っ！　\n不意打ちもいいところだ、心の準備もしていなかったのに……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0203404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「あぷ……んぷぁ……。あ……、胸の方にも垂れてき、た……さっき出したの\nにどうして二度目でこれほどの量をひり出せるのだ……！　んんんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0203405" ]},
		{"command":[ "SETIMAGE", "0", "still_00019402_01_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「……しかし……。はぁ、はぁ……貴方もこのプレイを心行くまで楽しんだ…\n…というのなら、大目に見ない事もない……かもしれないぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0203406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「このワタクシを騙して顔射する、その反抗的な態度……。正直に言って嫌い\nではない。ただ……予告がなかったせいでかなり驚いた。反省しろ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0203407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「ふぅうう……♪　貴方の射精に反応してか、まだぷちゅぷちゅと乳首から母\n乳が滲み出している……。性的興奮と連動して垂れてくるのだろうか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0203408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「ボニューデマクール……恐ろしい薬だが、悪くない。……ん？　それに、こ\nの童貞を殺す服が良かった？　そ、そうか……フフフ、そうだったか♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0203409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「私の誘惑の仕方は、やはり正しかったのだな！　ククッ、大変気分がいい。\n貴方が望むなら、またコレを着てやるからいつでもリクエストするのだぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0203410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
