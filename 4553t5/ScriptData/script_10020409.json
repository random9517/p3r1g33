{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0147" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「できた……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010113640001" ]},
		{"command":[ "SETCHARA", "0", "char_00001701_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「おおっ、止めましたね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_060113640001" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「見事なキャッチだ！　重心を落として勢いを受け流す。お手本のような受け\n止め方だよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040113640001" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "お前たちはなにをやっているんだ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「ルナテミス！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010113640002" ]},
		{"command":[ "SETCHARA", "0", "char_00001701_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "すぐさま外野のルナテミスへパスを渡す。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「炎の外野バスター！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010113640001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "また必殺技の名前を変えてやがる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "しかし、襲来者（インベーダー）にボールを当ててルナテミスが内野に復帰し\nた。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「しかし、内野に一人増えたところで、試合のペースは襲来者（インベーダー\n）が握ったままですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_060113640002" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "たしかに、劣勢なことに変わりはない。ルナテミスは夜叉をかばうので精一杯\nになっている。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「くぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010113640002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "4", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "なんとかボールを受け止めたルナテミス。しかし、このまま投げてもまた襲来\n者（インベーダー）にボールを渡すだけだ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「真正面から必殺技を放っても、最初のように止められてしまう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010113640003" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「くっ、いったいどうすれば……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "その時。奇妙な踊りを披露している学園長と牛神様。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETCHARA", "0", "char_00002602_01", "0", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "1", "char_00003002_01", "0", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なにやってるんだ……？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「ルナテミスさん……夜叉さん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020113640001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「私たちの動きに合わせるのです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_020113640001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「えっ、ええぇ～っ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010113640003" ]},
		{"command":[ "SETCHARA", "0", "char_00001701_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そんなことができるなんて！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010113640004" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「で、でも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010113640004" ]},
		{"command":[ "SETCHARA", "0", "char_00001701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「やってみましょう。今は、それしか手がない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010113640005" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "コートの中で、ふたりが並ぶ。", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "1", "char_00001701_01", "7", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「今！　必殺の！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010113640006" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「ツープラトンフィニッシュ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010113640006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス＆夜叉" ]},
		{"command":[ "SETTEXT", "「ツープラトンフィニッシュ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010113640007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「月面っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010113640008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「鬼面っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010113640007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス＆夜叉" ]},
		{"command":[ "SETTEXT", "「フラッシュシュート！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010113640009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "なんだこの技は！", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「すごいっ！　ぐわーんでバシューンでズバババーっとしてドカーンだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040113640002" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「見事な、ぐわーんでバシューンでズバババーっとしてドカーンです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_060113640003" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お前ら実況解説やめちまえ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "とにかく、急に曲がったり増えたりする謎の技のおかげで、襲来者（インベー\nダー）チームを一気になぎ倒した。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "しかし、これではまだ終わらない。敵の増援がやってきた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「学生たちの試合を邪魔させません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020113640002" ]},
		{"command":[ "SETCHARA", "0", "char_00002602_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「そうですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_020113640002" ]},
		{"command":[ "SETCHARA", "0", "char_00003002_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「ここは教師の出番だな。迎撃にむかうぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113640001" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「俺、ずっと生徒の連中に付き合わされてばかりなんだが」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「頭で考えてはいけません。心で、身体で感じるのです。なにしろスポーツな\nのですから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_020113640003" ]},
		{"command":[ "SETCHARA", "0", "char_00003002_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "なんでこんなことになっているんだ……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}