		{"command":[ "PLAYVOICE", "099_0103302" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「あらまー？　二回目なのにこんなに出るんだね～？　精液いっぱい溜まって\nたんだね～？　それってやっぱり変態だからぁ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0103303" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「ほら見て、あーしの手、もう隊長さんの精液でドロドロ～。きったないなぁ\n～、もう。えへへへへ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0103304" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「それにしても、二回目だって言うのに量もすごかったけど、濃厚さもすごい\nねえ？　こんなの出して大丈夫ぅ？　干からびない？」　", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0103305" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「ま、かわいいシャラクちゃんにあんなことしてもらったんだから、濃いぃの\nが出ちゃうのも無理ないけど？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0103306" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「でも、隊長さんったらだらしないよねえ？　お手手で刺激されただけで、こ\nんなにだらしなく、しかも二回もイッちゃうなんて」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0103307" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「強化が必要なのは、あーしよりも隊長さんなんじゃないのぉ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0103308" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「もし隊長さんがその気なら、そのうち隊長さんの特訓に付き合ってあげても\nいい――え！？　もうお願いしてきちゃうの？　早っ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0103309" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「ふふふふ、しょうがないなあ。それじゃあ特訓、つきあってあげるね。その\nうち、暇なときに！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0103310" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「さーて、どんな風にいじめてあげちゃおっかなぁ？　楽しみだなあ？　えへ\nへへへへへへ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},
		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "PLAYVOICE", "099_0103401" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「ん？　どうしたの？　隊長さん。いきなり腰を引いて――わわわわわわわわ\nっ！？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009901_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0103402" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「ちょ、ちょっとなぁに！？　いきなりこんな――わわわわわわわっ！？　何\nぶっかけてんのよー！」", "NORMAL" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009901_01_09" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0103403" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「うわ……まだ出てる、まだ隊長さんの熱くてくっさいのが、あーしの顔に…\n…ふわあああ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0103404" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「なによー、隊長さん。もしかしてこれ、仕返しのつもり―？　あーしをびっ\nくりさせようと思ったってことぉ？　ふぅん……いい度胸じゃなーい？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0103405" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「このシャラクちゃんに、こんなくっさくてドロドロした汁をぶっかけたりし\nて、また逆に仕返しされるとか思わなかったのぉ？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009901_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0103406" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「あ！　今、チンポがピクッってした！　さては、あーしのお仕置きを期待し\nたなぁ？　ははーん、それでいきなりこんなことを……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0103407" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「ふふふふ、それじゃあ、お望み通りお仕置きね～？　今日はもう、『おあず\nけ』！　今日はもう、してあげなーい！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0103408" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「隊長さんが反省するまで、もう気持ちいいことしてあげないんだからねー！\n　それが、あーしの仕返し！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0103409" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「しっかり反省して、ちゃんと謝るつもりになったらまたいらっしゃーい？　\nそしたらまた……してあげるかもよ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0103410" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「あ、でも、ただ謝るだけじゃだめだよ～？　反省文、百枚提出だからね？　\nがんばってー！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}