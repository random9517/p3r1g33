		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "PLAYVOICE", "099_0103101" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「訓練。訓練か。これがねえ……？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0103102" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「隊長さんのこれを手でしごくことで、ニンジュツの上達するエキスが出る？ \nへえ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0103103" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「まあ、隊長さんがそう言うならそうなんだろうね～。そういうことにしてお\nいてあげてもいいよ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0103104" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「そのエキスってのは、こういう風にすると出てくるのかなあ？　ほら？　ほ\nらほら？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009901_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0103105" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「ん？　もうちょっと早くした方がいい？　こんな感じかなあ？　ほれほれほ\nれ？　しこしこしこしこ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0103106" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「なあに？　隊長さん。だらしない顔して気持ちよさそうな声上げちゃって。\nふふふふふふふふっ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0103107" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「そかそか。隊長さんはこのへんが好きかあ……ほらほらほらほら？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0103108" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「えへへへへ、みっともなく膨れ上がってた臭いチンポが、ますます真っ赤に\n腫れあがってくるねえ？　キモーい！　あははははっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0103109" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「もしかして隊長さん、もうイッちゃいそうなの？　もう精液発射しちゃいそ\nうなの？　えへへへへ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0103110" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「え？　精液じゃなくニンジュツ上達エキス……？　あー、そういうの、もう\nいいから」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009901_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0103111" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「ほらほら、精液出したいんでしょ？　だから、あんな見え見えのウソついた\nんでしょ？　ほらほらほら？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0103112" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「隊長さぁ～ん？　正直に言っちゃいなよ～？　正直に言ったら、気持ちよく\nしてあげるかもよぉ～？　ほらほらほらぁ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0103113" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「きゃははははは！　よくできましたあ！　それじゃあ、次はこう言ってごら\nん？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0103114" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「『四姉妹の中で一番かわいいシャラク様、この卑しい粗チンをお手手でしご\nいて、天国にイカせてください。プリーズ』って！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0103115" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「あははははは！　また言った！　ホントに隊長さん、恥とか節操とかそうい\nうのないんだねえ！　あーし、そういうの好きー！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0103116" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「それじゃあ、ちゃんと言えたごほうびに、イイことしてあげるからね？　ほ\nらほら……しこしこ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009901_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0103117" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「しこしこ、こすこす。どう？　気持ちいい？　よかったらイイって言っちゃ\nいな？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0103118" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「そうなんだぁ？　これでも気持ちいい？　ぎゅっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009901_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0103119" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「あははははは！　チンポ握って引っ張ったら、隊長さん『ひぃいい！』だっ\nて！　ビックリした？　ねえ、ビックリしたんでしょ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0103120" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「大丈夫大丈夫。もう、痛いことしないから。ほらほら、しこしこしこしこ…\n…」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009901_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0103121" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「ほうら、また気持ちよくなってきたでしょお？　ほらほらほら？　こすこす\nこす……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0103122" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「え？　もっと手の動きを早くしてほしいって？　ふうん？　だったらほら、\nちゃんとお願いしてみたらぁ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0103123" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「『シャラク様、どうか私めのオゲレツなチンポを激しくいじめてください。\nプリーズ！　オー、プリーズ』って！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009901_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0103124" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「はははははは！　ホントに隊長さん、なんでもあーしの言う通りに言っちゃ\nうんだねえ！　オーケー！　グッボーイ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0103125" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「それじゃあ、いくよぉ！？　ほーら！　しこしこしこしこしこしこっ！　気\n持ちいい？　気持ちいいでしょ？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009901_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0103126" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「こうすると、もっと気持ちよくなるでしょお？　こすこすこすこすこすこす\nっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0103127" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「あれえ？　隊長さん、もうイッちゃうのぉ？　いいのかなあ？　そんなこと\nで訓練になるのぉ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0103128" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「ほらほら、もっとがんばって。お尻の穴、きゅって締めて。まだまだ出さな\nいの～。だからって、手はゆるめないけどねぇ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0103129" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「ねえ、気持ちいい？　気持ちいいでしょ？　でもまだ出しちゃだめだよぉ？\n」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009901_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0103130" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「しこしこ、こすこす、しこしこ、こすこす……えへへへ、隊長さん苦しそう\nだねえ？　出したい？　出したい？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0103131" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「えへへへ……しょうがないなあ。じゃあね、出していいよ？　ほら、出して\nごら――」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0103132" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「わわわっ！　出た！　ホントに出ちゃった！　あはははははは！　カッコわ\nるーい！」", "NORMAL" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009901_01_04" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0103133" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「あーしにチンポしごかれて、出していいよ、って許可されたとたんアヘ顔さ\nらして、くっさい精液吹き出しちゃうとか！　　あははははは！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0103134" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「カッコ悪いなあ～！　みっともないなあ～隊長さん！　あははは！　そんな\nんで、生きてて恥ずかしくないのぉ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0103135" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「おまけにこの量！　どんだけ溜め込んでたの～？　ねえねえ、これ全部、あ\nーしのこと妄想しながらタマタマの中にため込んでたわけ？　この変態！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0103136" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「それにしても、くっさ！　ホントくっさ！　隊長さんの変態汁、臭くてたま\nんないわ～！　鼻につーんとくるわ～！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0103137" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「まったくもう。変態の上にすぐにイッちゃうだらしなチンポの持ち主で、お\nまけに精液も臭いなんて、隊長さんまるでいいとこなしじゃな～い！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0103138" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「でもね、えへへへ……そんな隊長さんって、とってもかわいいよ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0103139" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「これからも、あーしが隊長さんのこと、かわいがってあげちゃおうかなあ？\n　ねえねえ、かわいがってほしい？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0103140" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「そっかそっかあ。それじゃあ、隊長さんはこれから、あーしのおもちゃだよ\n？　えへへへ、大事にしてあげるから、いっぱいあーしを楽しませてね？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009901_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0103201" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「えへへへ、隊長さんの、まだ硬いね？　もしかして、あーしに罵られて、興\n奮しちゃった？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0103202" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「あははははは、あんなにネバネバで臭いの、ドバドバ出しといて！　まだ出\nし足りないんだー！　あははははは！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0103203" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「どんだけスケベなのよ、隊長さん！　この変態！　頭の中、エッチなことし\nかないんじゃないの？　あはははははは！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0103204" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「それでぇ？　もう一回出させてほしいの？　ほしいんでしょ？　だったら、\nどうすればいいかわかるよねー？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009901_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0103205" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「はいはーい、そうでーす！　そうやって、ちゃんとお願いすればいいんでー\nす！　わかってきたねー？　隊長さん」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0103206" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「こうやって、ほぉら……しこしこしこしこ……こすこすこすこす……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009901_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0103207" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「あはははは、さっき出した精液でヌルヌルしてるから、感触が変わって面白\nいねえ♪　滑りが良くてしごきやすいし」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0103208" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「そかそか。ヌルヌルしてて気持ちいいか。これは、さっきよりも早くイっち\nゃうのかなあ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0103209" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「それはなんかもったいないからぁ……えい。ぎゅっ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009901_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0103210" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「そうそう。まだまだ我慢だよ？　こうやって、ぎゅーって握ってあげるから\n、こらえるんだよ？　ふふふふふ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0103211" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「はーい、それじゃあまたしごいてあげようねー？　しこしこしこしこ♪」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009901_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0103212" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「こすこすこすこす。あらあら、また隊長さんのチンポが、みっともなく赤黒\nく膨れ上がってきちゃったねー？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0103213" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「うわあ、赤黒チンポがドクドク脈打ってる。シャラクのお手手が気持ちいい\nからかなあ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0103214" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「そろそろかな？　もう限界？　もうもたない？　それじゃあねー？　こう言\nってみてー？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0103215" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「『シャラク様、早漏チンポが二回目にも関わらず暴発してしまいそうです。\nどうかどうかイカせてください』って」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0103216" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「もちろん最後に『プリーズ』ってちゃんとつけなきゃダメだよー？　はーい\n、言ってみてー？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0103217" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「はいはーい！　よくできましたぁ！　ホントに素直な早漏隊長くんですねえ\n？　それじゃあ、天国にイカせてあげちゃおうかな？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0103218" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「じゃあ、イクよぉ？　えーいっ！　ラビット・パワーっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0103219" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「ほらほらほらほら？　すこすこすこすこ、しこしこしこしこ、こすこすこす\nこす～♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0103220" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「イク？　イク？　いいんだよぉ？　ほぉら？　いっぱい出してもいいんだよ\nぉ？　出しちゃいなー？　えへへへへへへへ」", "NORMAL" ]},
