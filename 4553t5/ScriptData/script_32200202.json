{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0098" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「は、入っちゃいましたね……ホテル。こんなの……久しぶりで、ちょっと緊\n張しちゃいます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0204101" ]},
		{"command":[ "SETCHARA", "0", "char_00022002_01", "2", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「あの、もちろんこのことは誰にも……娘にも内緒ですからね？　ごめんなさ\nい、なんだか口うるさくて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0204102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「でも、こんな風に秘密を共有するのは……ちょっとドキドキしますね……あ\nっ、待って下さい……ちゃんと準備しますから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0204103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「もう待ちきれませんよね？　シャワーも後にしましょう……ベッドに寝そべ\nって下さい。はい、では私も失礼して……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0204104" ]},
		{"command":[ "SETCHARA", "0", "char_00022002_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「んっ……上から失礼します。あら……もうオチンポこんなにさせて……待ち\n切れませんでしたか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0204105" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00022002_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「顔に出てしまっていますよ。でも……私も同じです。若い男の人のオチンポ\nをこれから頂いちゃうんですから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0204106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「今日は、私がリードしちゃいますから……ふふっ、構いませんか？　多分、\nいっぱい動きたいと思いますけど、そこは我慢です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0204107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「はい、お任せされました♪　それじゃあ……これ以上焦らさずに、オチンポ\n失礼します……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0204108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「あっ、はぁぁぁっ、あっ、あぁんっ……！　うんっ……オマンコ……ゆっく\nり入っていきます……はぁぁぁっ、おっきぃ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0204109" ]},
		{"command":[ "SETIMAGE", "0", "still_00022002_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「もう少し腰を落として……あふっ……！　ずぶずぶって……オチンポ飲み込\nんじゃってます……あっふぅ……うくぅん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0204110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「あぁっ……オマンコ……一番奥まで埋まっちゃいましたね……やっぱり、貴\n方のオチンポ、すごく立派で……大きいです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0204111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「まだ動かしてないのに……お腹の中で、とくんって蠢いていて……して欲し\nいって駄々をこねてるみたいです……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0204112" ]},
		{"command":[ "SETIMAGE", "0", "still_00022002_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「ふふっ、もうちょっとだけお預けですよ。まず、ゆっくりオマンコにオチン\nポを馴染ませてあげますから……はぁ……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0204113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「あふっ……こうして、ちょっとだけ……きゅんっ、きゅんって……んふふ…\n…オマンコが吸い付いてくるの……分かりますか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0204114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「ふふっ、そんなに何度も頷いてもらってありがとうございます……。あぁ…\n…私の恥ずかしいエッチなお汁がじゅわって出てきました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0204115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「そろそろ良さそうですね……じゃあ、腰を動かしていきますね……よい、し\nょっ……あっ、うんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0204116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「はっ、んっ、あっ、はぁっ……あぁっ、太いのが……うんっ、オマンコ……\nいっぱいに擦れていきますっ……んくぅ、あひんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0204117" ]},
		{"command":[ "SETIMAGE", "0", "still_00022002_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「よいしょっ、うん、しょっ、はっ、んっ……あんっ、あっ、はっ……どう、\nですかっ……？　んふっ、いい感じ……ですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0204118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「もうちょっと動かしやすくしないと……あぁ……やだ、私……こんなにはし\nたなく足を広げて……恥ずかしい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0204119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「あんっ、そんなじっと繋がってるところを見つめて……あぁ……オマンコが\nオチンポを食べてるところ……丸見えです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0204120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「うんっ、んふっ……あっ、お、おっぱいも揺れて……あぁっ……そうなんで\nす……このチャイナドレス、すぐにずれちゃって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0204121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「今日は特別なんですよ……？　おっぱいもオマンコも……全部見せちゃって\n……貴方のオチンポにご奉仕する日なんですから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0204122" ]},
		{"command":[ "SETIMAGE", "0", "still_00022002_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「はふっ、んふぅっ……もうちょっと速く動きますね？　あんっ、あっ、太く\nて硬いのがっ……グリグリっ……来ますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0204123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「うくんっ、あんっ、はぁんっ、ウサギみたいにぴょんぴょん……跳ねちゃい\nますっ……だって、私バニーですからっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0204124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「よい、しょっ……んっ、しょっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0204125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「あんっ、あぁっ……オチンポが食い込むぅっ……んふぅっ、あひっ！　ご、\nごめんなさい……ちょっと弱いところに当たって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0204126" ]},
		{"command":[ "SETIMAGE", "0", "still_00022002_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「んっ、ふぅ……ちょっとだけ休憩……ずっと動き続けるのも大変ですね……\nもっと普段から運動しないと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0204127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「よい、しょっ……また、動いていきますね……今度は、ゆっくり腰を回して\n行きます……円を描くように……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0204128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「んぁっ……あぁっ、さっきと違うところに当たって……あふっ……これも、\nんぁっ、気持ちいいですね……んくっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0204129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「繋がってる場所が……ぐにゅってよじれて……あぁっ、やだ……こんなにい\nやらしいことしちゃってる……恥ずかしいですわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0204130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……でも、ちゃんと我慢して動かないでいるの……えらいです。\nオチンポにいい子いい子してあげちゃいます……んふっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0204131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「ふふ……オマンコの天井で……亀頭をナデナデしてるの、分かりますか？　\nもう、ぴくんってちょっと震えちゃってますね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0204132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「後少しだけ出すのは我慢して下さいね……また、本気のオマンコピストン…\n…しちゃいますから……えいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0204133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「はっ、うんっ、あんっ、また、いやらしくぴょんぴょんしちゃいますっ、あ\nんっ、あぁっ、オマンコめくれちゃうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0204134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「ふぁっ、はっ、あんっ、あぁっ……オチンポっ、どんどん膨らんでっ、あひ\nっ、あんっ、はぁっ、もう……出ちゃいますかっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0204135" ]},
		{"command":[ "SETIMAGE", "0", "still_00022002_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「あっ、あぁっ、ダメですっ、腰が止まらないっ、もう出ちゃいそうなのにっ\n……あひっ、はっ、あっ、あぁんっ、イ、イクっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0204136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「はぁぁぁぁぁんっ！　あぁっ……で、出ちゃってますっ……中にっ……あぁ\nっ、どぷって……いっぱい出て……ますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0204137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022002_02_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「あぁぁ……子宮に届いちゃう……あの子の妹か弟ができちゃうかも……そん\nなことになったら……あぁ……でも、気持ちいい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0204138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……はふぁぁ……あぁ……イッちゃいます……んくぅ……オマン\nコ……また、イキますぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0204139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「んふぅ……はぁ、はぁっ……んっ、止まりましたね……もう、こんなに遠慮\nなく中に出して……仕方ないんですから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0204140" ]},
		{"command":[ "SETIMAGE", "0", "still_00022002_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「あふっ……でも、これじゃ足りませんよね……？　貴方のオチンポは絶対に\n一回で満足できないんですから……続けちゃいましょう……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0204201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「あっ、んふっ！　私もイッたばかりで、感じやすくなってますから……満足\nしていただける動きが出来るか分かりませんが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0204202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「はっ、んっ……オマンコの中の精液を……かき混ぜながら……また、オチン\nポ気持ちよくしていきますね……うんっ、くんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0204203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「んふっ、あぁ……ぐちょぐちょです……いやらしい音ぉ……聞いてるだけで\n、オマンコジンジンしちゃいます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0204204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「でも、やっぱり逞しいですね……オチンポ全然萎える気配がなくて……いつ\nでも、そんなに絶倫なんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0204205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「私のエッチな格好で興奮するから……？　あらあら……もう、調子のいいこ\nとばっかり……でも、それなら責任を取らないとですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0204206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「はっ、んぁっ、うんっ、エッチなバニーママが……元気なオチンポから、た\nっぷり精液を吸い上げちゃいます……はんっ、あふっ、あんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0204207" ]},
		{"command":[ "SETIMAGE", "0", "still_00022002_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「んふぅ……視線を感じます……もう、おっぱいばかり見て……本当に大好き\nなんですね……うん、んふっ……あっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0204208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「後でいっぱい揉んでいいですから……今は、オチンポに集中ですよ……？　\nもっともっと、オマンコピストンしちゃいますからぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0204209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「はふっ、あんっ、うんっ、オチンポいいっ、はひっ、気持ちいいところに当\nたって……また新しいお汁……出ちゃってます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0204210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「でも、こんな硬いオチンポで擦られたら……誰だってそうなっちゃいます…\n…んふっ、オマンコヌルヌルになっちゃいますわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0204211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「は、はい……そうですわ……バニーママのオマンコは、貴方のオチンポにズ\nリズリ擦れてっ……とっても気持ちよくなっていますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0204212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「あふっ、あんっ、はっ、あぁんっ、もっと……オチンポ締め付けますからっ\n、貴方もいっぱいオマンコ感じて下さいっ、あっ、あひっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0204213" ]},
		{"command":[ "SETIMAGE", "0", "still_00022002_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「んぅっ、あふっ、ぴょんぴょん跳ねてっ、おっぱいもエッチに揺らしてっ、\nあひっ、オマンコぱっくり開いてぇっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0204214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「娘にも夫にも見せちゃいけない姿っ、全部貴方の前で見せちゃっているのっ\n、あぁっ、恥ずかしいのにっ、止まらないぃんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0204215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「そうですっ、このチャイナバニー姿はっ、もう貴方だけのものですからぁっ\n！　んぁぁっ、今っ……下から突き上げられたらっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0204216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「そんなっ、ダメ……ダメですっ、あぁっ、ズンズンって……オチンポっ、子\n宮に届いてっ、突くのはっ、イ、イッちゃいますからっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0204217" ]},
		{"command":[ "SETIMAGE", "0", "still_00022002_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「んぁっ、あ、貴方もっ……もう止められないんですかっ？　オチンポ跳ねて\nっ！　あぁっ、イキそうなんですかっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0204218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「あひっ、それならっ……どんな風にでもなさって下さいっ！　私も一緒にイ\nキますからっ、もう……オマンコイキますからぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0204219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「あんっ、あぁんっ、最後にオチンポ締め付けてっ、あひぃんっ、もうダメで\nすっ、んぁぁぁぁぁぁっ、イキッ……ますぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0204220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「んんんんんーーーーーっ！　あぁ……また、中に……どぷって……精液っ…\n…いっぱい出てきてます……んっ、あ、はぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0204301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022002_02_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「あぁ……子宮に……直接打ち付けられるの……良すぎます……んくぅ……イ\nクぅぅぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0204302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……あっふ……んんっ……あぁ、まだ出て……あぁ、もうオマン\nコ……いっぱいです……これ以上は溢れちゃいますわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0204303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「でも……あぁ……このびゅくって出される感じ……好きです……あふぅ……\n着床しちゃう……赤ちゃん出来ちゃいそうです……あぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0204304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「あふ……終わりましたか……？　また、いっぱい出してくださって……本当\nにお疲れさまでした……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0204305" ]},
		{"command":[ "SETIMAGE", "0", "still_00022002_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「まだ、身体の余韻がすごいです……お腹の中にあるオチンポが……みっちり\n食い込んでて……たまらないです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0204306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……んっ、よかったですか？　ふふ……そう言ってもらえたな\nら……私も、頑張った甲斐がありましたわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0204307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「あっ、でも忘れないでくださいね？　これは、本当に秘密なんですから……\n約束……してくれますよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0204308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「えっ……また次があるか……ですか？　そうですね……ふふっ、それはその\n時になってみないと分かりませんが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0204309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「でも、もしそういうことになったら……今度はもっとすごいこと……してし\nまうかも知れませんわ……ふふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0204310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「きゃあんっ！　あぁっ……オチンポ……抜けてっ！　はぁんっ……身体に…\n…いっぱい掛かってますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0204401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022002_02_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「んぁっ、おっぱいにも……顔にまで届いて……んぷっ……すごい量が出てま\nす……はぁぁぁ……こんなにぃ……あふっ、あぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0204402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「ねとねとの熱いのが……あぁ……お肌に染み渡って……この匂いを嗅ぐと…\n…はぁぁ……頭がボーッとして……蕩けちゃう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0204403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「あふっ、まだ……どぴゅって出てる……本当に若い男の人の凄さが……いえ\n、これは貴方だからでしょうか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0204404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「んっ、あぁ……やっと、治まりましたか……？　本当にいっぱい出しました\nね……んふぅ……お疲れ様でした……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0204405" ]},
		{"command":[ "SETIMAGE", "0", "still_00022002_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「あぁ……粘っこい……にちゃって糸を引いて……ちゅぷっ、生命力に満ち溢\nれてる感じがします……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0204406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「この衣装……お好きでしたか？　ふふっ……喜んでいただけたのなら、私も\n頑張った甲斐はありましたわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0204407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「でも、こんなこと……いつでもするわけじゃありませんからね？　本当です\nよ？　貴方にだけ……それだって今日は特別なんですから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0204408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「でも……今日のは、とても素敵でしたから……もし、次があるのなら……ふ\nふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0204409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「そうですね……それなら次は、いっぱいリードしてもらうのもいいかも知れ\nません……その時は、よろしくお願いしますね♪」", "NORMAL" ]},
