		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「おお、隊長どの。済まないな、忙しい中、わざわざ来てもらって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1003101" ]},
		{"command":[ "SETCHARA", "0", "char_00010010_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「うむ、まぁ……何やら、今は、世間は『ばれんたいん』とやらで、大変盛り\n上がっているではないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1003102" ]},
		{"command":[ "SETCHARA", "0", "char_00010010_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「聞くところによれば、それは好きな人にチョコをあげる儀式と聞いた。そこ\nに至るまでに紆余曲折あったが、間違っていないな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1003103" ]},
		{"command":[ "SETCHARA", "0", "char_00010010_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「うむ、ならばいい。それでだな……まぁ、その改まっていうのも何と言うか\n、多少照れくさいというか、皆まで言うなという感じだが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1003104" ]},
		{"command":[ "SETCHARA", "0", "char_00010010_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「私も、こうした祭りは好きな方でな……特別なチョコを渡すなら隊長どのに\n決めているから……どうだ、受け取ってくれるか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1003105" ]},
		{"command":[ "SETCHARA", "0", "char_00010010_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「おお、そうか……よし、ならば、早速準備させてもらうとしよう。んっしょ\n……ほら……たんと召し上がれ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1003106" ]},
		{"command":[ "SETCHARA", "0", "char_00010010_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふふ、どうしたそんな驚いた顔をして。もう、私のおっぱいはそれなりには\n見慣れているのではないか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1003107" ]},
		{"command":[ "SETIMAGE", "0", "still_00010010_01_01" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「普通と違う……？　まぁ、そうだな……これは、私が隊長どのの為に用意し\nた特製のチョコレートニプレスだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1003108" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「こーてぃんぐというのだったか。たっぷり塗りつけてあるから、いっぱい味\nわって欲しい。あっ、んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1003109" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んぁふっ、これは……また、んふっ、腹をすかせた赤ちゃんだな……そんな\nにチュウチュウ、ペロペロがっつきおって……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1003110" ]},
		{"command":[ "SETIMAGE", "0", "still_00010010_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「喜んでくれるとは思ったが……これほどまでに夢中になってくれるとは……\nんんっ、思わなかったぞ……あ、んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1003111" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふふ……美味しいようだな？　全く、とんだ甘えん坊だな、隊長どのは……\nだが、それがまた可愛らしくて愛おしい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1003112" ]},
		{"command":[ "SETIMAGE", "0", "still_00010010_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んっ、コリコリの乳首の触感……悪くないだろう？　んむっ、隊長どのの鼻\n息がどんどん荒くなっているのが分かるぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1003113" ]},
		{"command":[ "SETIMAGE", "0", "still_00010010_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「さて……こうなったら、もう隊長どののペニスは……やはりきかん坊で、か\nなり駄々をこねているようだな……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1003114" ]},
		{"command":[ "SETIMAGE", "0", "still_00010010_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「つくづく隊長どのはおっぱいが大好きなんだな。ならば、そんなおっぱいで\n……ほら……こうして……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1003115" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あふっ……柔らかさを感じてもらえるかな……？　このギンギンで疼きに疼\nいたペニスを、存分にシコシコしてやろう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1003116" ]},
		{"command":[ "SETIMAGE", "0", "still_00010010_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ほら、こうして……んっ、ふっ、ぎゅむっと……挟む……そうして……ずり\nずりっと……扱いていく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1003117" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「これはまた……一段と火照って……おっぱいの中が一気に熱を持って……は\nぁんっ、熱くなっているぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1003118" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「よしよし、待っていてくれ……隊長どのの好きな所……隅々まで全部してや\nるからな……はっ、ふっ、んぁふっ、んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1003119" ]},
		{"command":[ "SETIMAGE", "0", "still_00010010_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「やはり最初は縦にするのが分かりやすくていい……ペニスの長さを実感でき\nる……ここから、ここまでぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1003120" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「残さず擦り上げようとすると……結構な運動になるくらいだな……んっ、ふ\nっ、んぁ……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1003121" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「続けて、ぎゅっと……圧迫させて……乳首を……つんっと……押し付ける…\n…ふふっ、溶けかけのチョコが、ちょっと付いてしまったな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1003122" ]},
		{"command":[ "SETIMAGE", "0", "still_00010010_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「れろ……ちゅぱっ、んっ、甘いな……ふふ、自分の分をおすそ分けしてもら\nった気分だ……んっ、あふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1003123" ]},
		{"command":[ "SETIMAGE", "0", "still_00010010_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「おっと……注意が逸れてしまったな……あくまでも、今日の主役は隊長どの\nと……そのペニスだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1003124" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んっ、続けてパイズリしていくぞ……んふっ、もっともっと揉みくちゃにし\nてやるからな……は、んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1003125" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「エッチな眺め……？　ふふ……そうだな、我ながら……かなりエッチなこと\nをしているという自覚はあるぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1003126" ]},
		{"command":[ "SETIMAGE", "0", "still_00010010_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「今も……乳首がジンジンと痺れて……こうして、コリコリと擦り付ける度に\n、はふっ……思わず息が漏れてしまう……んんっ、ふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1003127" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「もっとして欲しい場所はあるか……？　やはり先端が嬉しいみたいだな……\nいいとも、この割れ目のところを中心にして……うんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1003128" ]},
		{"command":[ "SETIMAGE", "0", "still_00010010_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふふっ、元気に跳ねているな……今のをもっとだな？　よしよし……このお\nっぱいは、隊長どののモノだからな……ん、むっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1003129" ]},
		{"command":[ "SETIMAGE", "0", "still_00010010_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ご命令の通りに……鈴口を……集中的にこね回す……そして、幹を……ずり\nゅずりゅっと……何度も扱き上げてやるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1003130" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「はぁっ、んっ、隊長どのも……悩ましい吐息をこぼすじゃないか……その色\nっぽい呻きをもっと聞いていたい……こうだな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1003131" ]},
		{"command":[ "SETIMAGE", "0", "still_00010010_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んっ、あふっ、あぁ……おっぱいとペニスが……よじれあって……どんどん\nムラムラが高まってくる……気持ちいいな……最高だ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1003132" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「はっ、んんっ、先端が……ビクビクとしてきた……我慢汁も浮いている……\nこれは、そろそろ出そうになっているな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1003133" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んふっ、もちろん遠慮することはないからな……私のおっぱいの中にどっぷ\nりと射精して欲しい……よし、ラストスパートだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1003134" ]},
		{"command":[ "SETIMAGE", "0", "still_00010010_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「はっ、んっ、はぁっ、んふっ、あっ、んむっ、さぁっ……我慢しないで……\n出してしまえっ、射精する瞬間を見せてくれっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1003135" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「はふっ、んぁっ、ズリズリするっ……ほらっ、このままっ……ドピュッと…\n…イッて……しまえっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1003136" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んんっ！　あぁっ……出た出た……ふぁっ、おっぱいの中に……精液がどぷ\nどぷ……流れている……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1003137" ]},
		{"command":[ "SETIMAGE", "0", "still_00010010_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あぁ……いいぞ、ペニスが震えているのがよく分かる……その調子でたっぷ\nり出してしまおうな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1003138" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んぁ……あぁ……吐き出したな……ふふ、乳首のチョコに……白いミルクが\nたっぷり掛かってしまったな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1003139" ]},
		{"command":[ "SETIMAGE", "0", "still_00010010_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「私からのばれんたいんパイズリ……堪能してくれたようで何よりだ。私も…\n…しっかり気持ちよくなってしまったぞ……あふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1003140" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「さて……どうする？　隊長どののことだ。これで満足したなどとは到底言わ\nないと思うが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1003201" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふふっ、案の定だな。このペニスは、まだまだ私のおっぱいで甘えたいとい\nうわけだ。うむ、もちろん私に異存はない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1003202" ]},
		{"command":[ "SETIMAGE", "0", "still_00010010_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「このまま続けて可愛がってやろう……精液でぬめったおっぱいを……まだま\nだ楽しんでくれ……んふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1003203" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、それにしても、たっぷり射精したものだ……いつ浴びても、\n隊長どのの射精量には驚かされる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1003204" ]},
		{"command":[ "SETIMAGE", "0", "still_00010010_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「それだけ、私のパイズリで気持ちよくなってくれたんだと思うと嬉しくてな\n……ついついサービスもしてしまいたくなる。例えば……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1003205" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んふっ、ほら……もう溶けてドロドロのチョコを……乳首でツンツンと……\nんっ、塗りつけてみたり……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1003206" ]},
		{"command":[ "SETIMAGE", "0", "still_00010010_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「震える亀頭のところがいいのか？　おっと……腰が浮いてしまってるな。ふ\nふっ、目を細めて……表情豊かで飽きないぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1003207" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「こうなれば、もっと色々な表情を見てみたくなるものだ……んっ、ふっ……\n強く押し込んで……大きく身体を上下させるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1003208" ]},
		{"command":[ "SETIMAGE", "0", "still_00010010_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「はぁん……どうだ……ペニスがすっかりおっぱいの中に埋もれてしまった状\n態だ……血管が軽く震えているのがよく分かる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1003209" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んっ、んくぅ……擦れば擦るほどに……愛おしさが増してくる……おっぱい\nとペニスが一つになっていくような不思議な感覚だ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1003210" ]},
		{"command":[ "SETIMAGE", "0", "still_00010010_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あふ……隊長どのも興奮しているのだな……分かるとも……この谷間の中の\n震え……ごまかせるものではないぞ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1003211" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「私のおっぱいが揺れ動く度に視線も泳いで……やはり乳首が一番気になって\n仕方がないという雰囲気だな……んふ……図星か？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1003212" ]},
		{"command":[ "SETIMAGE", "0", "still_00010010_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ならば、この乳首を……もっと……コリコリと亀頭に押し付けて刺激して…\n…精液と……チョコを入念に混ぜ合わせて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1003213" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「はっ、ふっ……あぁ……本当に、このパイズリ奉仕というのは……私自身に\nも強い快楽をもたらしてくれる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1003214" ]},
		{"command":[ "SETIMAGE", "0", "still_00010010_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「おっぱいに広がるじんわりとした心地よさがたまらない……あぁ……ずっと\nこうして蕩けさせていたい気分だ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1003215" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「はっ、ふっ……んんっ……あぁ……また、射精が近いんだな？　後、もう少\nしだけ我慢してくれ……最高の射精を約束しよう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1003216" ]},
		{"command":[ "SETIMAGE", "0", "still_00010010_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ラストスパートだ……んっ、強く……おっぱいをめり込ませて……激しく…\n…扱くっ！　はっ、んふっ、ふっ、あぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1003217" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あぁ……後もう少しで私も……イキそうだっ……んっ、可能ならば……一緒\nにイキたいっ……はっ、んくっ、うんっ、んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1003218" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「さあ……もういいぞっ、あっ、好きなだけ……ドピュッと射精っ……してく\nれっ……隊長どのっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1003219" ]},
		{"command":[ "SETIMAGE", "0", "still_00010010_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「私も……んんっ、おおっ……イクからっ、たっぷりおっぱいを……感じてく\nれっ、んぁっ、あぁぁぁぁぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1003220" ]},
		{"command":[ "WAITINPUT" ]},
						
		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あふっ……！　んふっ……出た出た……あぁ、また……ドロリとしたのが、\nどんどん溢れ出して来る……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1003301" ]},
		{"command":[ "SETIMAGE", "0", "still_00010010_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふふ……いいぞ、この勢いならまだまだ出てくるだろう……？　全部おっぱ\nいに出し切ってしまってくれ……んっ、くふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1003302" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「そうだ……おっぱいに中出しして……おっぱいを孕ませてくれ……あぁ……\n熱いので谷間がドロドロになっていく……心地いいぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1003303" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んっ、もう少し搾り出してやらないとな……こうしてぎゅうっと……んふっ\n、ほぉら……出てきた……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1003304" ]},
		{"command":[ "SETIMAGE", "0", "still_00010010_01_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あふ……たっぷりと出せたな……よしよし、本当によく頑張ってくれたな。\nいい子だ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1003305" ]},
		{"command":[ "SETIMAGE", "0", "still_00010010_01_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んんっ、あぁ……濃密なにおいが漂ってくる……すぅぅ……これを吸い込む\nだけで……んふっ、軽くイッてしまいそうだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1003306" ]},
		{"command":[ "SETIMAGE", "0", "still_00010010_01_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「まだ、おっぱいの中でペニスがびくびく蠢いている……まったく元気のいい\nことだ……よしよし、甘えたりなかったのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1003307" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふふ……流石に少しお疲れのようだな。後は、ちょっと先端を綺麗にしてし\nまおう……ぴちゃ……ちゅぱっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1003308" ]},
		{"command":[ "SETIMAGE", "0", "still_00010010_01_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「うむ、どちらにしても、しっかりと湯を浴びなければスッキリはしないだろ\nうからな。ひとまずの処置ということだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1003309" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「さて……ばれんたいんパイズリ……楽しんで貰えたようで何よりだ。次は何\nの記念日でご奉仕しようか……楽しみなことだな♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1003310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んむぅっ！　あぷっ……顔の方に……出てるっ……そうか……こっちに掛け\nる方がお好みだったか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1003401" ]},
		{"command":[ "SETIMAGE", "0", "still_00010010_01_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ああ……もちろん構わない。今日のご奉仕パイズリは、隊長どのの特権なの\nだからな……遠慮なく浴びせてくれ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1003402" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あぁんむ、ちゅぷっ……あったかいミルクだ……ちゅぱっ、んふ……これは\n私へのご褒美と思っていいのかも知れないな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1003403" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ならば、もう少し頑張って……奥に残った分を搾り出してしまわないとな…\n…んんむっ……これで……どうだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1003404" ]},
		{"command":[ "SETIMAGE", "0", "still_00010010_01_13" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んふっ、最後に残っていた分がびゅびゅっと顔に掛かったぞ……ふふ、隊長\nどのの元気な射精……とくと味わわせてもらった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1003405" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「はぁぁ……んっ、さっきのチョコの甘みと……この粘った精液のコクが入り\n混じって……中々に味わい深いな……ちゅぱっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1003406" ]},
		{"command":[ "SETIMAGE", "0", "still_00010010_01_12" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふふ……甘えられたか……？　隊長どのの反応は本当に甘やかしがいがある\nからな。私もついつい張り切ってしまったな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1003407" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「どれ、ちょっと綺麗にしておこう。また後で、しっかりと汗を流す時に念入\nりに掃除はさせてもらうが……ちゅぷっ、ぴちゃっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1003408" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「とりあえずは、これでいい。あぁ……おっぱいも、まだピリピリと張り詰め\nて、高揚した気分のままだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1003409" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「うむ、ばれんたいんパイズリ……満足してくれたか。まだまだ甘やかし足り\nないからな……次はどんなご奉仕をしてみようか……♪」", "NORMAL" ]},
