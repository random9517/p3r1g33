		{"command":[ "PLAYVOICE", "050_0104101" ]},
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「あっ……あ、あ……隊長……！　どうしてこんなこと……！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "050_0104102" ]},
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「今夜は作戦についての相談があるとおっしゃったから……私は部屋にうかが\nったのです。なのに……突然押し倒したりして……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "050_0104103" ]},
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「このマスクとスーツでわかりそうなものではありませんか……私は今、氷華\nではなくマスク・ザ・ブルー……これは仕事なの、だと……はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "050_0104104" ]},
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「……え……？　こうして隊長の性欲を受け止めるのも、正義のヒロインのお\n役目だ……と？　困ります、そんな定義はどこにもな……、あっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "050_0104105" ]},
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「おちんちん……おちんちんをチラつかせないでください……。私……私、隊\n長のそれを見ていると……身体の力が抜けてしまっ、て……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "050_0104106" ]},
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「どうしてか、それに従わなければいけない気がしてしまうん……です。何が\n正しいことかわからなくなって……それに依存してしまって……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "050_0104107" ]},
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「……あっ……！　ダメ……！　ペニスをおまんこの入口に、スリスリさせる\nのは……あああ……！　い、いいわけが……ないでしょう……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "050_0104108" ]},
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「た、隊長……あなたもちっとも懲りないお方、ですね……！　あっ！　私な\nんかに……ヒロインスーツに劣情を抱いて……あああんっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "050_0104109" ]},
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「せ……正義のっ……あっ！　正義の味方に挿入をしたいだなんて、そんな願\nいを口にして……んんっ！　お、襲いかかってくるなんて……っ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "050_0104110" ]},
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「犯罪ですよ、悪ですよ……ぜった、いぃ……正しくありません、だってこれ\nは……レイプです……あああっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "050_0104111" ]},
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「あ……、あ、あっあっあッ……！　いや……いけません、これだけはだめ…\n…なのに、どうして……？　抵抗する力が出ない……あああっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "050_0104112" ]},
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「まるで私が、あなたに犯されることを……。だ、抱かれるっ、ことを……望\nんでいたかのよう……。変です、おかしいです……こんなこと……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "050_0104113" ]},
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「私はマスク・ザ・ブルー……ああんっ、仮面戦隊マスカレードのリー……ダ\nー……ぁああああっ、あああああっ、あああっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "050_0104114" ]},
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「いやっ……いや、いやっ……入っちゃった……入ってしまい、ました……あ\nああっ、隊長のちんぽ……悪のおちんぽが……中に……ぃい……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00005001_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "050_0104115" ]},
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「ん、ぁ……あっ、あぁ……！　ゴリュゴリュして……る……私の中を……膣\n内を掻き分けて、ズンズン奥に割り込んできて……あぁ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "050_0104116" ]},
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「頭がぼーっとして……何も考えられない、だめ……。正義の心が……おちん\nぽに負けちゃ……あ、あああ、ああああ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "050_0104117" ]},
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「隊長、隊長……お願いです、動いてください。動いて、掻き回して……あぁ\nあ、氷華のおまんこちゅぷちゅぷして、いっぱい突いてくださ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "050_0104118" ]},
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「ん……ッ！　あぁ！　あぁ、あぁっ！　そうです、そうです、そこです……\nっ！　そこ、を……ピストンして、ずぽずぽと……んんん……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "050_0104119" ]},
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「あふ……！　脳天を貫くような……一撃……っ……あ、あ、あ、あ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "050_0104120" ]},
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「ぐっちゅぐっちゅ、ぐっちゅぐちゅって……膣内でいやらしい音がして……\n痺れます、しびれ……る……ぅう……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "050_0104121" ]},
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁっ、はぁ、はぁ……胸も、胸も揉んでください……。はい、ス\nーツの上からでいいです……強く揉みしだいて……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "050_0104122" ]},
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「んんぅっ……！　そう、です……そうです、お上手、です……！　隊長はい\nつも、私の弱いところばかり……狙うのがお得意で……。あっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "050_0104123" ]},
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「あっ……、『違う』？　『氷華がいやらしい身体つきで、スーツなんて着て\n誘惑するから』……？　そん、な……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "050_0104124" ]},
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「ヒロインスーツを見て欲情する隊長に、そこまで言われる筋合いは……。ん\nっ、あっ！？　何……今、膣内で太くなって……。あ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "050_0104125" ]},
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「隊長……まさか、ヒロインスーツに説教をされて興奮しているのですか……\n？　なんという特殊性癖……あっ！　ふ、太すぎます……ああっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "050_0104126" ]},
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「わ、わかりました、認めます……認めますから、そんな太いもので私を責め\nないでください……。マスク・ザ・ブルーは……ぁあ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "050_0104127" ]},
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「表情がわからないマスクの下……で、い、いやらしいことを考えていました\n……。スーツの下で……身体をずっと疼かせて……いました」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "050_0104128" ]},
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「隊長に呼び出されるのが、だ、だんだん……楽しみになって……。あっ……\nこうやって強引に抱かれるのを、本当は……あああっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "050_0104129" ]},
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「本当は待ち望んで、いました……犯されたくて、スーツの中で乳首を勃起さ\nせ……あっ！　股間を濡らして……いました……戦いながら……っ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "050_0104130" ]},
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「いつこうして無理やり種付けしていただけるのか……指折りお待ちして、ま\nした……あっ……あー……っ！　認めます、認め……ます、だから……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "050_0104131" ]},
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「精液注いでください、戦隊ヒロインの淫乱まんこに正義の精液流し込んでく\nださい……ドクドクって……ドプドプって……あ、あ、あ、あ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "050_0104132" ]},
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「一緒に私も……イキますから……。マスク・ザ・ブルーもイキ、ますから…\n…絶頂敗北しますから……お願いします、お願いしま、す……ぅ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "050_0104133" ]},
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「……んッ……んんん……イクっ！　イク、イク、イク……っ！　イキますっ\n、イッてます……だから……く、ください……精液ぃ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "050_0104134" ]},
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「……あっ……！？　イクイクイクッ……！　そして……隊長のペニスがビク\nビクして……あああっ、イキながらイかせちゃう……んんんっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "050_0104135" ]},
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「っあぁああ……ッ……！？　精液、精液、隊長の精液……ぃ……！　スーツ\nの奥に精液放出して……いただけて……あぁあ……っ」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00005001_02_03" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "050_0104136" ]},
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「氷華、は……いいえ、マスク・ザ・ブルーは……ヒロインスーツ受精します\n……。おちんぽに負けて、スーツのまま孕みます……っ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "050_0104137" ]},
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「っ……！　はぁ、はぁ、はぁ、はぁ……。あああ……まだ出てる……このし\nつこくて長い、長い射精……たまりません……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "050_0104138" ]},
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「隊長……。スーツセックスで赤ちゃん出来たら……。産まれて来た子にも…\n…スーツ、着せて……いいです、か……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "050_0104139" ]},
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「あぁ、あぁああ……正義の味方が受精したら……。腹ボテスーツになってし\nまいます……。みっともない……恥ずかしい……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "050_0104140" ]},
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「なのに、私今……想像で感じてます。絶対妊娠しますから……。はぁ、はぁ\n……来月をお楽しみ、に……」", "NORMAL" ]},
