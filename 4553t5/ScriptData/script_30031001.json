{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000310_01_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「これ、なにを逃げ出そうとしてるんだい？　せっかく余がお主に付き合って\nやるというのに」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1003101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「もうこんなにチ○ポがおおきくなってるじゃないか。お主も、余に奉仕され\nることを期待していたのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1003102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「でもねぇ、余は奉仕される側の存在。余に奉仕するのはお主じゃ。なに、\nちょっとチ○ポで遊ばせてくれればよい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1003103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「まずは……お主が途中で逃げ出さないように、四肢の動きを封じておくかね\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1003104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「余の力により、お主の自由を奪う……。チ○ポはちゃんと反応するから安心\nするがよい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1003105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「今、余に必要なのはお主の顔とチ○ポだけじゃからな。それ以外は不要じゃ\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1003106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「にしても……こんな状況でもビンビンに勃起しているとは。並みの男なら\nここから無理やり勃起させるのじゃが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1003107" ]},
		{"command":[ "SETIMAGE", "0", "still_00000310_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「お主にはその必要がないようじゃ。くくっ、やはり余が見込んだ男だけは\nあるな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1003108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「じゃあ、お主のチ○ポにこれからローションを垂らすぞ……。亀頭めがけて\n、たら～りと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1003109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「アツアツの勃起チ○ポに冷たいローションが効くだろう？　ふふっ、軽く\nチ○ポになじませて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1003110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ここからが本番だよ。余のふんどしにも、たっぷりとローションを含ませて\nな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1003111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「これを……お主のチ○ポにかぶせて……擦る……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1003112" ]},
		{"command":[ "SETIMAGE", "0", "still_00000310_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「どうじゃ……？　ヌルヌルのふんどしに、亀頭が包まれておるぞ？　それで\n擦られて……気持ちいいか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1003113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「そ～れ、ごし、ごし、ごし、ごし……っと。くくっ、腰が跳ねておるでは\nないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1003114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「もっとたっぷり擦ってやろう。ごし、ごし、ごし、ごしと、ヌルヌルスベ\nスベの布の感触をチ○ポで味わうがよい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1003115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「どうした、情けない声をあげて。もう射精しそうだというのか？　情けない\nねぇ、もっと余を楽しませてみよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1003116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「それ、それ、それ、それ。少し激しく亀頭を擦ってやろうかね。ほらどうだ\nい？　ンッ、腰が暴れてるね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1003117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「……っと、危ない。どうした？　余がこのまま、お主に射精をさせるとでも\n思ったか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1003118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「そんなにあっさりと射精をさせるはずなかろう。そら、ローションを追加\nだよ。もっとヌルヌルのネトネトじゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1003119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「そらそら、また一気に激しく、ごしごしとチ○ポをしごいてやるぞ。腰を\nビクつかせて感じるがよい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1003120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「じゃが、射精はさせぬ。こうして亀頭を擦られるだけで射精しそうになる\nじゃろうが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1003121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「余が許すまで、お主にはたっぷりと射精を我慢してもらうからの。そら、\nまた亀頭を磨くようにこするぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1003122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「それにしても、情けない声をあげまくってるねぇ。そんなにビクンビクンと\n腰を震わせて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1003123" ]},
		{"command":[ "SETIMAGE", "0", "still_00000310_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「チ○ポ気持ちいいだろう？　でも、射精は絶対にさせないからね。お主の\nチ○ポは余が掌握しておるからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1003124" ]},
		{"command":[ "SETIMAGE", "0", "still_00000310_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「それそれ、もっともっとごしごし擦るぞ。ローションまみれのチ○ポがテラ\nテラになっていやらしいねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1003125" ]},
		{"command":[ "SETIMAGE", "0", "still_00000310_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「勃起チ○ポもガッチガチだよ。亀頭も充血して、限界まで膨れ上がっちゃっ\nているじゃないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1003126" ]},
		{"command":[ "SETIMAGE", "0", "still_00000310_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ふふっ、射精したくてたまらなそうにして。ほらこうやって、裏筋を擦られ\nるのも気持ちいいじゃろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1003127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ああ、気持ちよすぎて、女みたいな声がでちゃっているじゃないか。ふふっ\n、いいねぇ。余の好きな声じゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1003128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「どうじゃ？　このまま射精させてやろうか？　ほれほれ、チ○ポを擦る速度\nをどんどんあげて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1003129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ヌルヌルのふんどしで亀頭磨かれてイキそうか？　イキそうになっている\nようじゃなぁ。ふふっ、我慢の限界か？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1003130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「もう我慢できないか。お主もよう耐えたのう。褒美に思いっきりチ○ポを\n擦ってやろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1003131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ほれほれほれほれ、ごしごしと亀頭を高速摩擦じゃ。ははっ、さっきよりも\n大きく腰が跳ねておる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1003132" ]},
		{"command":[ "SETIMAGE", "0", "still_00000310_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「イクか？　イッてしまうか？　いいぞ、余が許そう。チ○ポから情けなく\n精液を放ってしまえ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1003133" ]},
		{"command":[ "SETIMAGE", "0", "still_00000310_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んんっ！　ああっ、さっそく一発目じゃな。ふんどしを貫通する勢いの射精\n……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1003134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「びゅっくん、びゅっくんと……よくもまあこんなに射精できるのう。これが\nそんなに気持ちよかったのか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1003135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000310_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「魂まで抜けたような顔で、射精の余韻に浸っておるな。呆けてないで、余の\n問いに答えよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1003136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「そうか。気持ちよかったか。余も、お前の反応を愉しませてもらったぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1003137" ]},
		{"command":[ "SETIMAGE", "0", "still_00000310_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「……どうした？　これで終わりだと誰が言ったか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1003138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「お主には、余が満足するまで付き合って貰うつもりじゃからな。一度で終わ\nるはずがなかろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1003139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「お主の射精のおかげでさらにヌルヌルになった余のふんどし……もっと味わ\nうがよい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1003140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ふふっ、なんじゃ？　なにがだめなのか言ってみよ。一度射精したあとの\nチ○ポはさぞ敏感であろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1003201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「そこをこうして、またふんどして磨くようにこすって……くくっ、また情け\nない声をあげておるなぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1003202" ]},
		{"command":[ "SETIMAGE", "0", "still_00000310_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「それそれ、今回は最初っからごしごし擦ってやるからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1003203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ローションとお主の精液とでヌメヌメになった布で、亀頭をごしごし擦られ\nて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1003204" ]},
		{"command":[ "SETIMAGE", "0", "still_00000310_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んっ、腰がびっくんびっくん跳ねているではないか。よっぽど気持ちいいん\nじゃなぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1003205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「本当はだめじゃないんじゃろう？　お主のチ○ポはこんなにビクビクと悦ん\nでおるのだからなぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1003206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「それそれ、もっとヌルヌルにするか？　ローションを足して、べちょべちょ\nになったふんどしで」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1003207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「まだまだ勃起しっぱなしのチ○ポをごしごし擦って……っと。ふふっ、辛そ\nうな顔じゃなぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1003208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「女みたいな喘ぎ声も止まらなくなっているようじゃ。ふふっ、情けないねぇ\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1003209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「じゃが、男のそういう姿……たまらなく興奮するぞ。お主のチ○ポをもっと\nいじめたくなってくる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1003210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「じゃからこうして、お主が悲鳴をあげようと、余は手を止めることなく\nチ○ポを擦り続けるのじゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1003211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ごしごしごし、ごしごしごし……とな。テッカテカになった亀頭をふんどし\nで執拗に責めてやろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1003212" ]},
		{"command":[ "SETIMAGE", "0", "still_00000310_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ははっ、どうしたどうした。情けない声をもっと余にきかせんか。それそれ\n、もっとスピードをあげてこするぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1003213" ]},
		{"command":[ "SETIMAGE", "0", "still_00000310_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「今度はもう我慢なんかさせぬぞ。お主が情けない顔で射精するところをじっ\nくり観察させてもらうとしよう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1003214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「本当、面白いくらいに喘ぐのう。腰はビクビク、口はパクパク。陸にあげら\nれた魚みたいだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1003215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ふんどしの中で、ガッチガチのチ○ポが暴れているよ。ふふっ、このまま\n射精するまで逃がさぬからなぁ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1003216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「それそれそれそれっ、ラストスパートじゃっ！　泣こうが喚こうがチ○ポを\n擦りつづけてやるぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1003217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「どうした？　だめなのか？　だめじゃなかろう。お主はまた、余の前で無様\nに射精してしまうのじゃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1003218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ああ、いいぞ。射精寸前の無駄に我慢している表情……。ぞくぞくする……\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1003219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「さあ、さあ、放ってしまえ！　布っ切れにしごかれて無駄うち射精をさらし\nてしまえぇええっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1003220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んぁあっ！　ああっ、出ておるっ！　んっ、チ○ポからすごい勢いで……っ\n！　んっ、ああぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1003301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000310_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「勃起チ○ポから勢いよく、精液ではなく潮を噴いてイッてしまうとは……\n本当に面白い男よ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1003302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「まだ絶頂の余韻に浸っておるのか？　腰をヒクヒクと震わせて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1003303" ]},
		{"command":[ "SETIMAGE", "0", "still_00000310_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「二度も余のふんどしにイカされたチ○ポ……。ふふっ、ビクンビクンと震え\nておるなぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1003304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「たっぷり我慢したうえでの絶頂……。たまらなかったじゃろう？　ふふっ、\nお主の呆けた顔がそう告げておるわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1003305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ほれほれ、まだ始まったばかりなのじゃから、寝てもらっては困るぞ。余は\nまだ満足しておらぬ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1003306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「言ったであろう？　これは、潮吹き、であると。お主はまだ二度目の射精を\nしておらぬのだからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1003307" ]},
		{"command":[ "SETIMAGE", "0", "still_00000310_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ふふっ、またこうして、動けないお主のチ○ポをヌルヌルのふんどしで擦っ\nてやろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1003308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「今夜はずっと……お主の亀頭がすり減るまでチ○ポを磨いてやろうかねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1003309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「お主は簡単に壊れる男じゃないようじゃから。ふふっ、せいぜい余を楽しま\nせるのじゃぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1003310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ああぁっ！　出ておるっ！　びゅくびゅくと勢いよく精液が噴き出ておるな\nぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1003401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000310_01_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「余の肌に……んっ、ああっ、お主の精液がひっかかって……！　あはぁん、\nなんて粘り気じゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1003402" ]},
		{"command":[ "SETIMAGE", "0", "still_00000310_01_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「二度目の射精だというのに、こんなにたくさん精液をだすなんて……。量も\nすごいけど、臭いもすごいねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1003403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「濃厚な男の臭いに包まれて……はぁ、はぁ、たまらないねぇ、ぞくぞくする\nよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1003404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「それにしても……お主のチ○ポはまだまだ勃起したままなんじゃなぁ。精液\nを出し切ってないんじゃないかい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1003405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「どうなんだい？　まだまだチ○ポの中に精液を隠しているんだろう？　だか\nら勃起が収まらないんだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1003406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ふふっ、射精を二度させて余が満足すると思ったか？　残念だけど、夜は\nまだまだこれからだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1003407" ]},
		{"command":[ "SETIMAGE", "0", "still_00000310_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「お主がため込んでいた精液を全部出し切るまで、余に付き合ってもらうから\nな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1003408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ふふっ、チ○ポをビクビクさせて返事をするなんて、お主はかなり変態の\nようじゃなぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1003409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「やはり、余が見込んだ男よ。一晩射精しまくったくらいで、おかしくなるで\nないぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1003410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}