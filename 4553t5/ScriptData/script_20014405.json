{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0116" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_019" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「アイドル……ってのはどうだ？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「あいどる……？　とはなんだ。初めて聞く言葉だな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_030022980001" ]},
		{"command":[ "SETCHARA", "0", "char_00019401_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まず、お前らの人気を一度に上げるとなるとユニット売りは必須だと思うん\nだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスＤ" ]},
		{"command":[ "SETTEXT", "「……そうでしょうね。誰か一人が抜け駆けをして、という気分でもありませ\nんし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_270022980001" ]},
		{"command":[ "SETCHARA", "0", "char_00000119_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「もちろん、全員の人気が上がるのが一番いい……。でも、どうしてアイドル\nなんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_150022980001" ]},
		{"command":[ "SETCHARA", "0", "char_00000210_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「んー、別にアイドルに限定はしないんだが、他にウリに出来るものってない\nだろ？　たとえば……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「バンドをすると決めたとしたって、どうだ？　誰も楽器なんか弾けないだろ\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「これから一生出来ないかどうかは、やってみなければわからないが……そう\nだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_030022980001" ]},
		{"command":[ "SETCHARA", "0", "char_00010003_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「今すぐプロに匹敵するほどのウデマエになれと言われてもたぶん、無理だと\n思う」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_030022980002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「……ハープくらいなら弾けそうなのだが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_030022980002" ]},
		{"command":[ "SETCHARA", "0", "char_00019401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「私も楽器のワザマエはない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_150022980002" ]},
		{"command":[ "SETCHARA", "0", "char_00000210_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「なんならフルートくらいなら吹けそうだが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_030022980003" ]},
		{"command":[ "SETCHARA", "0", "char_00019401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスＤ" ]},
		{"command":[ "SETTEXT", "「歌うことは出来ても、バンドらしい演奏……。たとえばギターやベースのた\nしなみはありませんね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_270022980002" ]},
		{"command":[ "SETCHARA", "0", "char_00000119_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「トライアングルは叩けるが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_030022980004" ]},
		{"command":[ "SETCHARA", "0", "char_00019401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうだろう？　誰も楽器なんかできやしないんだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「…………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_030022980005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「それに、今、皆が前面に出していきたいのは楽器の腕じゃない。自分たち自\n身の魅力だろ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「ううう、全ての提案を無視されてしまった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_030022980006" ]},
		{"command":[ "SETCHARA", "0", "char_00019401_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「それなら、単純に自分たちをドーンと見せてやればいいんだよ。アイドルな\nら、それが可能だ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスＤ" ]},
		{"command":[ "SETTEXT", "「なるほど……。歌を歌う私たち、踊りを踊る私たち、ファンサービスをする\n私たち……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_270022980003" ]},
		{"command":[ "SETCHARA", "0", "char_00000119_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「全部が全部、自分達をアピールするのに最適ってワケか。なら、その意見に\n賛成だ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_030022980003" ]},
		{"command":[ "SETCHARA", "0", "char_00010003_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「あとは、その……アイドルをするのが少し恥ずかしい。それを克服できれば\n……やれると思う」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_150022980003" ]},
		{"command":[ "SETCHARA", "0", "char_00000210_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスＤ" ]},
		{"command":[ "SETTEXT", "「あらあら？　何も恥ずかしいことなどありませんわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_270022980004" ]},
		{"command":[ "SETCHARA", "0", "char_00000119_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「そ、そうだろうか……。人前に出て目立つのは、苦手で……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_150022980004" ]},
		{"command":[ "SETCHARA", "0", "char_00000210_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスＤ" ]},
		{"command":[ "SETTEXT", "「アイドルは可憐ですし、エレガントですし、愛らしく、上品です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_270022980005" ]},
		{"command":[ "SETCHARA", "0", "char_00000119_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスＤ" ]},
		{"command":[ "SETTEXT", "「そしてこれは最も大切なことですけれど……カグヤ・ダークさん？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_270022980006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「は、はい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_150022980005" ]},
		{"command":[ "SETCHARA", "0", "char_00000210_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスＤ" ]},
		{"command":[ "SETTEXT", "「アイドルとはグループなのです。つまり、私たちは仲間。あなたは一人では\nありません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_270022980007" ]},
		{"command":[ "SETCHARA", "0", "char_00000119_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「私は一人じゃない……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_150022980006" ]},
		{"command":[ "SETCHARA", "0", "char_00000210_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「当然だな。誰か１人をハブにするアイドルなんて、客が喜ぶハズないし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_030022980004" ]},
		{"command":[ "SETCHARA", "0", "char_00010003_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスＤ" ]},
		{"command":[ "SETTEXT", "「そして、助け合うその姿こそが！　ファンの目を楽しませることができるの\nです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_270022980008" ]},
		{"command":[ "SETCHARA", "0", "char_00000119_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「オマエが失敗したところを、他のヤツらでサポートする。そういうのもアイ\nドルの醍醐味」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_030022980005" ]},
		{"command":[ "SETCHARA", "0", "char_00010003_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ありのままの姿で人気もアップする、となれば……なかなか良い案だと思う\nぞ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「わかった。私やってみる。……アイドル、してみたい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_150022980007" ]},
		{"command":[ "SETCHARA", "0", "char_00000210_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「……そのアイドル……というものは、ワタクシのような熟女でも……やれる\nのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_030022980007" ]},
		{"command":[ "SETCHARA", "0", "char_00019401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うっ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "俺は一瞬言葉に詰まったが、いやいやいや、と脳内で自分を必死に納得させた\n。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そういうのも新しくてウケると思う……」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「やはり熟女ではキビシいのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_030022980008" ]},
		{"command":[ "SETCHARA", "0", "char_00019401_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うううっ！？　い、いや、フツーならそうかもしれないが」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「…………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_030022980009" ]},
		{"command":[ "SETCHARA", "0", "char_00019401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「クロートーは美形だし、色気もあるし……売れると思う」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「び、美形……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_030022980010" ]},
		{"command":[ "SETCHARA", "0", "char_00019401_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ぽぽぽ、とクロートーの頬が赤くなり、幸せそうな空気があたりに広がった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「わかった。ワタクシもその案に乗ってやろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_030022980011" ]},
		{"command":[ "SETCHARA", "0", "char_00019401_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「決まりだな、決まり！　よぉーっし。いっちょアイドル、やってみっかあ！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_030022980006" ]},
		{"command":[ "SETCHARA", "0", "char_00010003_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「心強い仲間がいれば４倍有利……お前達には期待している」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_150022980008" ]},
		{"command":[ "SETCHARA", "0", "char_00000210_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスＤ" ]},
		{"command":[ "SETTEXT", "「私が参加する以上、上手くいかないはずがありませんから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_270022980009" ]},
		{"command":[ "SETCHARA", "0", "char_00000119_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "……そうして、混迷を極めた『正義』での飲み会は幕を下ろし……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "sbg_0000" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "その晩、俺は夢を見た。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0031" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_016" ]},
		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「みんなー！　盛り上がってるか～っ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_030022980007" ]},
		{"command":[ "SETCHARA", "0", "char_00010009_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスＤ" ]},
		{"command":[ "SETTEXT", "「まだまだカッ飛ばしてまいりますわよ～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_270022980010" ]},
		{"command":[ "SETCHARA", "0", "char_00000127_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「ワタクシたちは今日、ここで。今までの努力の成果を発揮して！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_030022980012" ]},
		{"command":[ "SETCHARA", "0", "char_00019403_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「お前たちを夢のような世界に誘う！　乗り遅れずについてくるがいい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_150022980009" ]},
		{"command":[ "SETCHARA", "0", "char_00000215_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "４人の姿はさんさんと輝く太陽に照らし出され、まばゆく光り、煌めいている\n。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「この混沌の世を正すため！　人気を爆発させるため！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_150022980010" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「刻の国からやってきた、戦えて強い４人組！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_030022980008" ]},
		{"command":[ "SETCHARA", "0", "char_00010009_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "２人" ]},
		{"command":[ "SETTEXT", "「究極アイドル☆タイム４」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_270022980011" ]},
		{"command":[ "SETCHARA", "0", "char_00000127_01", "8", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "1", "char_00019403_01", "8", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "……実際、４人がアイドル活動をしてどうなるのか、は今の俺にはわからない\n。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "けれど、そこまでして人気が欲しいと願う４人の気持ちが誰かに……伝われば\nいいな、と思わないでもない夜なのだった。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}