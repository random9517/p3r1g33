{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「――皆まで言うな。わかっている。私にスケベなことをしようというのだ\nろう？　昔はさんざんその視線を浴びたものだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0203101" ]},
		{"command":[ "SETCHARA", "0", "char_00001002_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「ほう？　なんだと？　恥じらいを感じさせて、パワーアップをさせるつも\nり……だと？　はぁ……随分と浅知恵なことだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0203102" ]},
		{"command":[ "SETCHARA", "0", "char_00001002_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「長い時を生きたこの私が、少々のことで恥じらいを感じると思ったのか？\nまあいい……今の指揮官はおまえさんだからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0203103" ]},
		{"command":[ "SETCHARA", "0", "char_00001002_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「仕方ないから、その計画に乗ってやろう。ほら、ちんぽを出せ。なぁに…\n…慣れている。随分ご無沙汰ではあるがな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0203104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「精神も若返っているせいか、いささか緊張するな……まるで生娘に戻った\nような気分だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0203105" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00001002_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「ふむ……それにしても、随分といやらしいな……充血したちんぽが弾けて\nしまいそうだ……ふふふ、愛おしく感じて来たぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0203106" ]},
		{"command":[ "SETIMAGE", "0", "still_00001002_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「この手であらゆる相手を引き裂いて来たが、こうして乳の間で他人を感じ\nることなどめったになかったな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0203107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「なんだか弱点をさらけ出しているようで気恥ずかしいな……若返った甲斐\nがあるというものだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0203108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「おっと……こうして、谷間に挟んでいるだけでは、おまえさんがいつまで\n経っても射精できんな……今から動かしてやろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0203109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「心配するな……体を動かすことに関して、私に勝る者は早々居ない。性技\nであろうと例外ではない……では行くぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0203110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「ん……んん、ふぅ……ふふふ、ちんぽが谷間の中で、ずるずる擦られてい\nるぞ……そうそう、この感触だ……何百年ぶりかな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0203111" ]},
		{"command":[ "SETIMAGE", "0", "still_00001002_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「メスであったことを、体が思い出すようだ……はぁ、なんだか興奮してき\nたな……はふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0203112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「ん？　気持ちいい？　そうかそうか……正直で結構なことだ。さて、もう\n少し激しくしてやるか……んんん……ッ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0203113" ]},
		{"command":[ "SETIMAGE", "0", "still_00001002_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「ふむ？　ふむふむ……思ったより難しいな……体がまだ本調子ではないよ\nうだ……ん？　充分気持ちいいのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0203114" ]},
		{"command":[ "SETIMAGE", "0", "still_00001002_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「ほぅ。この程度で気持ちよくなるとは……ろくな女と遊んでいないみたい\nだな……ふふふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0203115" ]},
		{"command":[ "SETIMAGE", "0", "still_00001002_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「まあ、あの女王を仰ぐような価値観の持ち主だからな……美的感覚も女の\n趣味もいまいちなんだろう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0203116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「おやおや、ここまで言われても怒らないのか？　だとしたら相当な腑抜け\nか、本当に気持ちいいのか……いや、その両方かもしれんな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0203117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「まあいい……このまま続けさせてもらうとしよう……ほら、どうだ？　私\nの乳は？　柔らかさも、大きさも申し分ないだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0203118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「ふん……まあ、乳自慢はこれぐらいにしておくか。問題は乳の使い方だか\nらな……ふふふ、もっと気持ちよくしてやるぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0203119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「んふふ……どうだ？　締め付けながら、こうして上下に……胸を揺らすよ\nうに、谷間で刺激してやると……気持ちいいだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0203120" ]},
		{"command":[ "SETIMAGE", "0", "still_00001002_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「過去、これで何人の男がここで果てたことか……はぁ、ふぅ……あの頃が\n懐かしいな……ふふ、ふふふふふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0203121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「おっと、思い出に浸っている場合ではないな……もっと、おまえさんを楽\nしませてやらないと、バチがあたってしまう……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0203122" ]},
		{"command":[ "SETIMAGE", "0", "still_00001002_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「ほら、ほらほら……どうだ？　はぁ、ふぅ……私の乳さばき、最高だろう\n？　自分でも惚れ惚れしてしまうぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0203123" ]},
		{"command":[ "SETIMAGE", "0", "still_00001002_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「はぁ……ふぅ、自分で自分に興奮してしまいそうだ……なんだか、体が熱\nくなってきたぞ……んん、あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0203124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「おまえさんも、よっぽど気持ちいいみたいだな。ちんぽが、爆発寸前だぞ\n……さて、そろそろラストスパートといこうか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0203125" ]},
		{"command":[ "SETIMAGE", "0", "still_00001002_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「ふん……ふぬぅ……ッ！　ふふふ、ちんぽが波打っておる……！　乳がい\nい具合に動いている証拠だな……はぁ、ふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0203126" ]},
		{"command":[ "SETIMAGE", "0", "still_00001002_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「さっきより気持ちいいだろう？　おまえさんのその顔……見ているだけで\n笑えてしまうほど、だらしなくなっているぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0203127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「さて、そろそろトドメを刺してやる……この左右の乳を互いに上下させる\n妙技……これに耐えられた男はいない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0203128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「見てみるがいい……ちんぽがビクンビクンと震えて……こんなにも気持ち\nよさそうに涎を垂らしているじゃないか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0203129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「なに？　イキそう……？　愚か者が……はぁ、はぁ……我慢せずにとっと\nとイケ。耐えるなどと無益なことはするな。わかったな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0203130" ]},
		{"command":[ "SETIMAGE", "0", "still_00001002_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「よしよし、素直な返事だ……はぁ、はぁ……ああ、ぴちゃぴちゃ音がする\n……我慢汁が溢れ出して、谷間をドロドロに……はぁ、んん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0203131" ]},
		{"command":[ "SETIMAGE", "0", "still_00001002_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「オス汁をたっぷり出して、私に精液の感触を思い出させてくれ……んん、\nふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0203132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……ああ、こんなにも震えて……ちんぽが……私のメスの本\nが、激しく脈動して……あ、ああ……はぁ、んんんん……ッ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0203133" ]},
		{"command":[ "SETIMAGE", "0", "still_00001002_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「ひぐぅぅ！？　んはぁ……はぁ、あはぁぁ……おおお、凄まじい射精だな\n……はー……はー……こ、こんなに出すとは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0203134" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001002_01_05" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「見ろ。どこもかしこも真っ白だ……こんなに飛び散らせるとは、よっぽど\n溜まっていたみようだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0203135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「んふぅ……谷間が、精液で埋まってしまったな……ああ、熱い……乳が溶\nけて、流れ出してしまいそうだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0203136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「はぁ……ふぅ、最後の一滴まで、乳圧で搾り出してやるぞ……覚悟するが\nいい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0203137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「ふぅ……はぁ……あああ、精液の味……そして、この匂い……ふふふ、長\nらく忘れていたぞ……たまらんな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0203138" ]},
		{"command":[ "SETIMAGE", "0", "still_00001002_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「こうして時には精液を浴びないと、獣の本能を忘れてしまいそうだ……な\nかなか楽しかったぞ、おまえさん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0203139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「ああ、こんなに滴っていては、子宮が疼いてしまうな……だが、今回はこ\nれぐらいにしておいてやるとするか――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0203140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「……む？　まだ終わってない？　ほう、随分傲慢な物言いだな。この私に\nそんなことを言うとはな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0203201" ]},
		{"command":[ "SETIMAGE", "0", "still_00001002_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「いいだろう。今私は最高に気分がいい……自分勝手な言い分の一つや二つ\n、サラリと聞き流してくれよう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0203202" ]},
		{"command":[ "SETIMAGE", "0", "still_00001002_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「それで？　続きをすればいいのか？　なるほど……よっぽど私の乳が気に\n入ったのだな……まあ仕方あるまい。男子は皆、乳が好きだからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0203203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「よいしょっと……ああ、谷間がヌルヌルする……これはこれで、なかなか\n気持ちがいいものだな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0203204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「精液で、ちんぽがトロトロになっているぞ……ふふふ、いやらしい見た目\nだな……このままむしゃぶりついてやりたい気分だ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0203205" ]},
		{"command":[ "SETIMAGE", "0", "still_00001002_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「前歯で甘噛みしたり、奥歯でカリを擦ったり……ふふふ。人狼族ならでは\nの体験をさせて、私の虜にしたいぐらいだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0203206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「はぁ……それにしても、こうもオスのニオイを感じていると、若い頃を思\nい出すな……こうして男が満足するまで、夜通し肌を重ね合ったものだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0203207" ]},
		{"command":[ "SETIMAGE", "0", "still_00001002_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「肉体的にはあの頃に戻ってはいるが……なんだか精神の方も、肉体に引き\nずられて若返っているみたいで、少し妙な気分だな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0203208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「おっと、そんなことはどうでもいいな。それよりも……ほら、どうだ？　\nこの乳の締め付け具合は……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0203209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「どうせなら、さっきよりたっぷりと搾り出してやりたいものだ……はぁ、\nふぅ……むふふふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0203210" ]},
		{"command":[ "SETIMAGE", "0", "still_00001002_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「どうした？　ちんぽがビクビクと脈打っているぞ……もうイキそうなのか\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0203211" ]},
		{"command":[ "SETIMAGE", "0", "still_00001002_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「おまえさんが早漏というわけではない……私の乳使いが上手すぎるだけだ\n　。だからそう悲観することはないぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0203212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「ふふふ……私の乳に責められて嬉しいだろう？　あの女王では、こんな真\n似できまい……？　やはり私の方があらゆる面において上だ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0203213" ]},
		{"command":[ "SETIMAGE", "0", "still_00001002_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「はぁ……あふぅ、気持ちが高ぶっているせいか、乳首がビンビンだ……あ\nああ、乳が熱い……子宮も疼いて、止まらなくなってしまう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0203214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「まるで戦場に出るときの高揚感だ……はぁ、はぁ……いかん、自分が抑え\nられん……これは早くイッてもらった方が良さそうだな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0203215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「んくっ、はっ、ふうう……！　はぁ、はぁ……これが私の全力だ……戦い\nの時でも、ここまで気合を入れたりしないぞ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0203216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「ふぅ……あふぅ……おまえさんを真の男として、認めたということだ……\nはぁ、はぁ……喜んでいいぞ……ん、ぐぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0203217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「ほれ、どうだ……この動かし方、気持ちいいだろう？　私も乳がジンジン\nして、気持ちいい……はぁ、はぁ……あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0203218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「おっ、おほぉ……ちんぽがビクンビクンして、精液が根本に集まって来て\nいるのが伝わってくるぞ……そろそろみたいだな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0203219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「はぁ……ふぅ……ほら、とっとと出せ……！　好きなところに、好きなよ\nうに、好きなだけ……！　はぁ、はぁ……ん、んんん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0203220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL2","外して射精","LABEL1" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「なに？　私の顔を汚したいのか……？　はぁ、はぁ……好きにするといい\n。ほら、遠慮するな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0203301" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……あああ、出る……出される……はぁ……あふぅ……ちん\nぽが……脈打って……あっ、あひぃ……ひぐぅぅうぅぅ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0203302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「んはぁ！？　うっ、くぅ……はぁ、ああああん……こ、これは……なんと\n、見事な射精だ……はぁ、はぁ……あはぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0203303" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001002_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「顔が溶けてしまいそうだ……うぅ、前がよく見えん……はふぅ……遠慮す\nるなとは言ったが、ここまで豪快に発射するとは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0203304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「うぶ……鼻が、塞がれておる……うう、精液の匂いで、肺の中が妊娠して\nしまいそうだ……はー……はー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0203305" ]},
		{"command":[ "SETIMAGE", "0", "still_00001002_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「ん、んん……口の中に精液がたっぷり滴って……んんん、ゴクン……ふぅ\n……舌が焼けそうな味だな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0203306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「あぁぁ……顔全体が精液で覆われて、五感を犯されたような気分になるな\n……はぁ、あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0203307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「やれやれ……私のかわいい顔が台無しだ……ふぅ、ふぅ……顔も、乳も…\n…おまえさん色に染め抜かれてしまったな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0203308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「ふむぅ……だらしない隊長だと思っておったが、オスの本能部分は悪くな\nい。今後も期待させもらうとしよう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0203309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「さて、と……そろそろ戻らせてもらうぞ。久しぶり過ぎて、いささか疲れ\nてしまったからな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0203310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「ほう。もう一度、このまま出したいのか？　ふむ……よっぽど私を汚した\nみたいだな……まあよい、遠慮はするな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0203401" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……さあ、いつでも、いいぞ……はぁ、ふぅ……ああ、すご\nい、ちんぽが、熱いぃ……はぁ、はぁ……あっ、あはぁぁあん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0203402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「んっ！　んっ、くぅ……はぁ、あはぁぁぁ……！　精液が、こんなにぃ…\n…凄まじい、射精だな……はぁ、んん、あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0203403" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001002_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「顔と胸がドロドロだ……ふぅむ、乾き始めた精液が、一気に潤ってしまっ\nたな……ん、んん、おほぉ……まだ溢れ出してくるぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0203404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「まったく……胸が重たくなってしまったじゃないか……いったいどれだけ\n射精したら、こうなってしまうんだ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0203405" ]},
		{"command":[ "SETIMAGE", "0", "still_00001002_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「んん、はぁ……おまえさんの体温が、肌の中に染み渡ってくる……ああ、\nそのまま子宮にまで入り込んでしまいそうだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0203406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「ふぅ……やっと収まったようだな……はぁ……ふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0203407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「全身精液でビチャビチャだ……これを腟内に出されたら、どうなってしま\nうやら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0203408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「少々頼りない隊長だと思っていたが……おまえさんは子作りの能力に長け\nておるのかも知れないな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0203409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「さてと……今回はこれぐらいにしておくとしよう。男女の営みは久しぶり\nだったからな……予想以上に疲れてしまったよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0203410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
