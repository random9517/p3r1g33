		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「えっ。わ、私……？　私は……えぇと。家で夫と娘が待っている……んです\nけど。帰る前に、どうしてもあなたに会いたくて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0303102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「もう。これ以上言わせないでください。私からのクリスマスプレゼントです\n。あまり時間はとれませんが……めいっぱい楽しみましょう……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0303103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「ン……♪　ふふふ、こ・れ。あなたが私からもらって、一番喜ぶものってな\nんだろうってずーっと考えて……決めたプレゼントです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0303104" ]},
