		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「んぷっ……ぷぁっ！　あぷ……！　くぅう……♪　す、すごい命中力ですね\n……んぁっ……！　顔中がヌルヌルで重たいです……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0303302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「はいっ♪　お好きなだけかけてください……。あっ♪　んんっ……お、お口\nはだめです、息ができなくなっちゃいます……！　っんんむっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0303303" ]},
		{"command":[ "SETIMAGE", "0", "still_00018403_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「ふぁっ♪　あっ……苦いのが舌に乗っかってきました……。んはぁ……♪　\nあんっ、髪にもべっとりついちゃって……精液の臭いがキツすぎます♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0303304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「あーっ♪　あっ、ぁっ、んぁああ……！　ぷぁ……！　あ、あなたはいつも\nこんなに……射的みたいに射精をしているんですか……？　んぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0303305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「元気すぎるオチンポさんでうらやましいです……！　っあんっ♪　家の人も\n、これくらいエネルギッシュだったら……。い、いえ、なんでもありません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0303306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「あはは……♪　私、こんな風に顔いっぱいに精液を塗られた経験なんてはじ\nめてですよ……♪　まだまだ、未経験のことってたくさんあるんですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0303307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「あなたはいつだって、私に初めてを教えてくれます……。はじめての浮気、\n不倫エッチ、……刺激的すぎることばかり。火傷してしまいそう……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0303308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「私、いつもは真面目に暮らしていたいって思うタイプです。でも、本当にご\nくたまに……火遊びをしたくてゾクゾクする時も、あって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0303309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「そういう時、あの……呼び出したりしたら、一緒に遊んでくれたりしますか\n？　もちろん、エッチ込みで。その時はぜひお願いしますね……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0303310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「ん～っあっあっ！　あぁんっ！　あっぁッ……♪　あは……っ♪　今度は胸\nの谷間にドクドクすることにしたんですね……嬉しい……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0303401" ]},
