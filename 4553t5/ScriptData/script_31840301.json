		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「私のＪカップおっぱいを、一番活用してくれるのは……堪能してくれるのは\n、やっぱりあなたです……！　あっ！　いい、いいの、もっとぉお♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0303402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「どくっ、どくって精液が注がれるたびに……私の心臓の音に重なって、すご\nく満ち足りた気分です……♪　あぁ、大量の精液が胸に溢れて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0303403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「パイズリ上手だったよって、満足できたよって褒められているみたいでとっ\nても嬉しい……！　あっ……二度目なのにこんなにくれるのぉ……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0303404" ]},
		{"command":[ "SETIMAGE", "0", "still_00018403_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「最高のクリスマスプレゼント……！　ありがとうございますっ……あっ♪　\n全部、全部いただきます……あぁんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0303405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「あっ！　あっ、精液が当たるたびにおっぱいがプルプル震えて……。私、こ\nの瞬間がとっても好きです、真っ白に染めてください……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0303406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「……ん、ふ……♪　さすがにこれ以上は出ない……ですよね？　はぁっ……\n♪　一度目ならまだしも、二度目の射精でこんなにたくさん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0303407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「最高のクリスマスになりました。あなたにはいつも、頼りっぱなしで……ふ\nふふ、いつも本当にありがとうございます……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0303408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「あなたに私がしてあげられることなんて、エッチなことくらいしかありませ\nんけど……それでもよければ、また誘ってもらえると嬉しいです」", "NORMAL" ]},
