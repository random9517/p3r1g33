		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「クリスマスに、こんなところに呼び出したのに……来てくれるなんて、本当\nに嬉しいです。いいんですか？　他の女の子達は……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0303101" ]},
		{"command":[ "SETCHARA", "0", "char_00018403_01", "6", "CENTER", "0" ]},
