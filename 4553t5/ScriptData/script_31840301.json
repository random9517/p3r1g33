		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「は、ぁ♪　はぁっ……。あ……あっ♪　んん……♪　だ、め……。どんどん\n気持ち良くなってきました……。あっ♪　胸でご奉仕しているだけなのに」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0303212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「なん、でこんなに興奮しちゃうんでしょうか……。あン……♪　だって、オ\nチンポまったく萎えなくて……こすればこするほど逞しくなって……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0303213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「ごくって生唾飲んじゃいます……。あっ……♪　どうしてこんなに、理想的\nなチンポなんですか……あっ♪　私の胸も喜んで、ます……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0303214" ]},
		{"command":[ "SETIMAGE", "0", "still_00018403_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「っんんんん……！　あ、あの……っ。ご奉仕パイズリなのに、私……わたし\nぃ、ちょ、ちょっと胸で……おっぱいでイッちゃうかもしれま、せん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0303215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁあ……♪　み、見ないでください……。んんぁっ♪　恥ずかしい\nと思えば思うほど、すごく感じるぅ……あっぁっあっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0303216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「おっぱい！　おっぱい気持ちいいです……っ！　あぅっ♪　チンポで刺激す\nるの、やめられません……！　あっあっあっ、チンポ、チンポ気持ちいい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0303217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「んんん……！　あぁ、あぁ……イ、ってしまいそう、です……あっ♪　はし\nたない女でごめんなさい……！　っぁっ……んん、イッちゃうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0303218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「んぁああっ♪　あぁあ……♪　わ、私だけ気持ちいいのは、ダメです……。\nあっ♪　あなたも良くなってください、んっ、もう一度出してぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0303219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「一緒に……一緒にイッてくださいっ。じゃないと私……恥ずかしすぎてどう\nにかなっちゃいます……。あっ♪　あっぁっイクぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0303220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「きゃぁんんっ♪　んふ……っ♪　に、二回目の射精なのにまた顔に飛ばせる\nなんて……！　どれだけ元気なオチンポなんですかぁ……っ！」", "NORMAL" ]},
