		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「おっぱい。大好きですもんね。今日はゆっくり……。あっ、そうでした。時\n間はあまりないですけど……じっくりこの胸を楽しんでくださいね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0303105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「ん……ふふふ、人妻の胸ってとても柔らかくて優しい感触でしょう？　若い\n女の子の、ツヤツヤプルプルで張りつめた肌もいいけれど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0303106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「年齢を重ねて、しっとりなめらかになったおっぱいもまたとっても良いもの\nだと私は思うの。……あなたはどう思う？　なーんて。動かすわね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0303107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「ん……ん、んっ……♪　はぁあ……♪　こうやって、近くで見るとあなたの\nチンポの凄さを思い知りますね。あっ……なかなか無いですよ、このデカさ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0303108" ]},
		{"command":[ "SETIMAGE", "0", "still_00018403_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「長くて挟みきれないチンポ……。んぅ♪　私の胸、相当に大きい方だと思う\nんですけど……それでも全然足りないんですよね。丸ごと包み込むと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0303109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「ヤンチャに谷間からハミ出してきちゃって……っ、んんっ♪　若くて、ナマ\nイキですっごく素敵……。見ているだけでうっとりしちゃう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0303110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「え？　感触もいいだろうって？　……ぁ……♪　もう、そんなこと言わせな\nいで……♪　ンッ……。そう、ね……すごくエッチな形してる、から」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0303111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「あなたのチンポをおっぱいでくにゅくにゅ刺激してると……わかっちゃう。\nこのでっぱりが、オマンコのあそこをえぐってくるのよねぇとか……。あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0303112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「このくぼみに何度も泣かされちゃうのよね、とか……。あっ……♪　カリ首\nの段差がスゴくて女殺しだとか……。んっ、このデコボコがいいだとか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0303113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「……っや、やだ……♪　本当に、口にしてたら恥ずかしくなってきちゃった\n……。と、とにかく私は好きな感触だし、……良いチンポだと思ってるわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0303114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「じゃなくちゃこんなこと、しないでしょう……？　あっ……♪　クリスマス\nに、家を抜け出して……こんな服を着て、おっぱいでご奉仕だなんて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0303115" ]},
		{"command":[ "SETIMAGE", "0", "still_00018403_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「んっ……んっ♪　ひ、人妻としてあるまじきことよ……。でも、したくなっ\nちゃうの。コレを見せられるともう、止まらなくなっちゃうのぉ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0303116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「んんっ……んっ、ん～っ……♪　若い男の子のオチンポ触って、シゴいて興\n奮しちゃう悪い人妻でごめんなさいね……♪　はぁっ、はぁ、はぁ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0303117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「だけど私だってたまにはうんと気持ち良くなりたいの……♪　は、ぁ♪　お\nっきなチンポで頭トロトロにしちゃいたい♪　って思っちゃう……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0303118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「おっぱいたくさん突かれて感じたい……♪　っねぇ……？　腰、動かしてぇ\n……？　私のおっぱい、突き上げてほしい。このチンポで。お願いぃ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0303119" ]},
		{"command":[ "SETIMAGE", "0", "still_00018403_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「あっ♪　二人で力を合わせて……んんっ♪　一緒に気持ち良くなりましょう\nよぉ……っ。あっ♪　あっ、私も頑張ります、から……。ああぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0303120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「はぁんんっ♪　そ、う……それっ……突いて、突き上げて……♪　あっ♪　\n私のおっぱいとエッチしてるみたいに、やらしく腰を動かしてぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0303121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「は……♪　ぁ、あっぁ……♪　んんんぅ♪　気持ちいい……っ。あんんっ♪\n　私っ……お、男の人の感じ方なんてわからない、けど……あっ♪　あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0303122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「おっぱいをズボズボズコズコ犯される時の気持ち良さはわかるの……♪　っ\nんんんぃっ……♪　あっ♪　あっ、硬くておっきいチンポで突かれると！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0303123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「私のおっぱい♪　いつも子どもに母乳をあげてたこのおっぱいって、性器だ\nったんだって……いやらしいところなんだって思い出しちゃうの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0303124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「こう、やってぇ……っ。あっんっ♪　男の人の大切なところ、気持ち良く出\n来るお肉なんだって、意識して昂っちゃう……はぁ、はぁ、はぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0303125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「おっぱい……柔らかい？　たくさん押しつけて、オチンポズリズリしてあげ\nるね……。っあっ……♪　あぁっ……ん～……っ、どうかしら……っ」", "NORMAL" ]},
