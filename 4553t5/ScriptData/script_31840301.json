		{"command":[ "SETIMAGE", "0", "still_00018403_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「これ、くらいの力加減でいい？　やっ♪　もっと？　んもぉ……エッチなの\nね……。あッ……♪　こ、れくらいかしら。強すぎる？　っあっ、んぅ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0303127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「あなたの腰、すっごく情熱的に動いてる……♪　ふふっ♪　真っ白なお餅を\nこねこねしてるみたいでしょ？　たぷたぷ揺れて、オチンポを包んで」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0303128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「あッ♪　んっ……もっとこね回していいのよ♪　っはぁっ……あんっ♪　強\nくされると感じるの……♪　っあっ♪　あっぁっあぁんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0303129" ]},
		{"command":[ "SETIMAGE", "0", "still_00018403_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「やだ……ぁ♪　本気で感じてきちゃった……。お股のあたりがヌルヌルです\nごいの……。あっ……♪　いやっ♪　くぅう……やぁだ♪　もっと♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0303130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「もっと熱いオチンポでこすってぇ……♪　んっ、はぁっ♪　ふぁああ……♪\n　あぁ♪　私のおっぱいにあなたのカウパーいっぱいつけて♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0303131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「この胸をあなたのモノにして……♪　んんんんっ♪　いいのよっ……！　あ\nなたの印を思いっきりつけて、塗りたくって……あああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0303132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「……きゃっ♪　やぁだ……♪　チンポがグイグイ存在をアピールしてくるぅ\n……♪　えぇ、ええ。よーくわかってまちゅよぉ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0303133" ]},
		{"command":[ "SETIMAGE", "0", "still_00018403_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「精子ピュルピュルぴゅっぴゅしちゃいそうなんでちゅよねぇ～？　っあっ♪\n　いいんですよ……私のおっぱいにぜひ発射してください……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0303134" ]},
		{"command":[ "SETIMAGE", "0", "still_00018403_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「うんうん♪　今日くらいは私にうんと甘えていいんです……♪　さ、あるだ\nけビュッビュしちゃってくださいね。出して♪　ねぇ……出してぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0303135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「んッ！？　あっ……あっ、す、すごい……っ！　あぁあんっ！　チンポっ、\nオチンポの先っちょからドロドロの精液が……ビュッビュッてっ！　んぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0303136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018403_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「次々に噴き出してくる……！　あぁ……！　あつぅい……♪　やだ♪　こん\nなに……？　んっ、んっ……♪　随分溜め込んでいたんですね……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0303137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「きゃ……！　まだまだ出せるんですか？　ふふっ……なんて勢いでしょう…\n…♪　あんっ♪　飛び散らかって、顔中が精子まみれです……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0303138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「んっ……んっ、ンッんんっ……！　あ、動かないでくださいね。尿道に残っ\nた分も絞りあげます……。んー……っ、こう、ですよね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0303139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「うふふっ……。鈴口から真っ白な残り汁が溢れてきました。はぁ……♪　は\nぁ、はぁ……♪　最後の一滴までちゃんと臭くてすごく優秀です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0303140" ]},
		{"command":[ "SETIMAGE", "0", "still_00018403_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「こんなに粘り気が強くて臭い精液を出せるなんて……あなたは本当に若いん\nですね。お肉をたっぷり食べているから、なんでしょうか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0303201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「女の人をめちゃくちゃにするぞ～、妊娠させるぞ～っていう強い意志を感じ\nる、特別に卑猥な精液……私の顔に出しちゃってよかったんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0303202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「これ……オマンコの中に出していれば、絶対着床させられたのに。もったい\nないと思わないですか？　……え？　この顔を妊娠させたかった？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0303203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「んもぉ……♪　ふふふ、私のお顔は妊娠なんかしませんよ。でも……貴重な\n精子を外に出したこと、後悔していないみたいで何よりです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0303204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「えっと……。受精はさせられませんけど……無駄撃ちで良ければ、もう一度\n……私の胸の谷間にびゅるびゅるしちゃいますか？　……え？　ぜひ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0303205" ]},
		{"command":[ "SETIMAGE", "0", "still_00018403_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「何度でもこの胸で出したい？　あっ……♪　も、もう……♪　年上を喜ばせ\nるのが、あなたは本当に上手……。そこまで言われたら、断れませんよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0303206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「わかりました。何度でも、私のおっぱいで抜いちゃってください。スッキリ\nしてください……。私も、情念を込めてシコシコしていきますね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0303207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「ん……ぁ、ふぅっ……んん……っ。あは……♪　精液のぬちゃぬちゃが、お\nっぱいに絡んで不思議な感じがします……。っん……良くぬめりますね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0303208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「あっ、んぁっ……♪　粘液でトロトロにしてからチンポをこすると、何もつ\nいていない時とはまた違った感触で……んっ、とてもいやらしい気分に♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0303209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「は、ぁっ……♪　はぁっ、あっ……ぁっ、あっ……♪　え？　私がお尻を揺\nらしてモゾモゾしてる、ですか？　そ、それは……言わせないでください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0303210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「大好きなオチンポを精液まみれのおっぱいでシゴいているんですよ？　そり\nゃあ、感じちゃいます……火照っちゃいます。っあんっ、んん……♪」", "NORMAL" ]},
