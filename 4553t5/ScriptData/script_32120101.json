{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021201_01_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「うふふっ。隊長さんの運転で洗車できるなんて、とっても嬉しいわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0103101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「それに私のために新しい洗車機を用意してくれたんでしょう？　大型車両だ\nから幅も取るのに……なんだか、申し訳ない気分だわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0103102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「Ｍ．Ａ．Ｍ．Ａが綺麗になってくれると嬉しい……？　や、やだ、もう……\n！　隊長さんったら、おだてるのが上手いんだから……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0103103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「それにしても、この洗車機は本当にすごいわね……ブラシも今まで見たこと\nないくらい立派だわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0103104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「私の車体を全てカバーしてくれてるし……こんな大きなモノで思いっきり洗\nわれたら、どうなっちゃうのかしら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0103105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「きゃあああぁ！？　な、なにっ！？　急にヌルヌルしたお汁が全身にかかっ\nて……！　こ、これ、洗車液なの……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0103106" ]},
		{"command":[ "SETIMAGE", "0", "still_00021201_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「窓やフレームにいっぱいかかって……ふああぁ……！　やっ、あんっ……！\n　全身洗車液まみれになっちゃうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0103107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、んんっ！　今までいろんな洗車液を味わってきたけど、こんな\nにヌルヌルしてるのは初めてよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「今日のために特別に用意した、特注の洗車液なの……？　そんな……私のた\nめに、特注してくれるなんて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「もしかして隊長さん……私がこうやって洗車液まみれで、ぐちゃドロになる\nところが見たかったの……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「できれば毎日こんな姿を見たいだなんて……そ、それはダメよ……！　んっ\n、あっ…くふうぅん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0103111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「毎日洗車すると、コーティングに傷がついてボディの劣化を招くことになる\nわ……！　私の身体がボロボロになっちゃうの……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「隊長さんが乗る車だから綺麗にしておきたい……？　そんな俺のモノだなん\nて言い方……あああぁん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「私はバスで、みんなの乗り物なの……！　隊長さんをもっと贔屓してあげた\nい気持ちはあるけど、それは許されないことなの……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0103114" ]},
		{"command":[ "SETIMAGE", "0", "still_00021201_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「だからどんなに優しくされても、旅客輸送という使命に抗うワケには……あ\nああああぁんっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0103115" ]},
		{"command":[ "SETIMAGE", "0", "still_00021201_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ！　そんなぁ！？　いきなりブラシが全身を激しく撫でまわして\n……あっ、やっ！　んふうううぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0103116" ]},
		{"command":[ "SETIMAGE", "0", "still_00021201_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「回転ブラシで車体が責められてるぅ……！　こ、こんなに激しいだなんて、\n聞いてないわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「最新式だから、ブラシの回転は今までの洗車機と比べ物にならないだなんて\n……！　やっ、あっ！　んっ、あっ、か、感じすぎちゃうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「ふあああぁ……！？　フロントガラスにもブラシが伸びてきて……私のビン\nカンなとこ、めちゃくちゃにされてるのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「きゃあぁ！？　そ、そこはタイヤのホイール……！？　足回りの奥の方まで\n洗って来るなんて……やっ、そこ、ダメぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「やあああぁ！？　タイヤのグルーブまでしっかり洗われてるぅ！？　詰まっ\nてる汚れ、全部綺麗にされちゃってるからぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「見ないで、隊長さんっ！　タイヤについてた汚れなんて見られたら……私、\nタイヤ交換したくなっちゃうわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「んんっ！　やああぁ……足回りから黒ずんだ液体がどんどん溢れて来るぅ…\n…！　もうこれ以上、私の汚いお汁見ないでぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「まだタイヤの溝もあるし、ひび割れや亀裂もないから交換しなくていい……\n？　それより、私が綺麗になってるところを見れて嬉しい……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「本当に、こんな私を見て幻滅しないの……？　すごく汚れたタイヤで、今ま\nで隊長さんを乗せてたのよ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「そんなの関係ないから、もっと綺麗になって欲しいだなんて……！　あああ\nっ！　嬉しいわ、隊長さんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「綺麗になるから、もっとパワーを強めてっ！　私のフレーム、ブラシでゴシ\nゴシして擦ってぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「あっ、んぐっ、くうううぅんっ……！　あっ、あっ！　このパワーすごいわ\nっ！　塗装が剥げちゃいそうなくらい、パワフルよっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「んひああぁ！？　普段手の届かないルーフもしっかり洗われてるのぉ！　車\n体の上から、汚れがどんどん落ちてきちゃうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ！　ダメ、こんなのダメぇ！　ヌルヌルした車体に激しくブラッ\nシングされるの、本当に無理だからぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「んあっ、あぐっ……んひいぃ！？　こんなの、我慢できないわっ！　洗車中\nはエンジンを切ってるのに、勝手にエンジンが動いて……あふぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「さ、サイドブレーキも降りてきちゃうのぉ！　ダメ、ダメよぉ！　このまま\nじゃ、誤発進しちゃうからぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「ひっ、くっ、ああああぁ！　洗車液のせいで、路面が滑るぅ！　私の身体か\nら垂れたお汁で、勝手に進んじゃうのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「あああっ！　行くっ、行くぅ！　アクセルペダルを踏み込んで、前に進んじ\nゃううううぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「事故だけはダメっ！　絶対にダメえええぇ！　止まって……私のブレーキペ\nダル、ちゃんと作動してえええぇ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0103135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「ふああああぁん！？　急ブレーキを踏んだせいで、ウォッシャー液が吹き上\nがっちゃってるぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0103136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「私のウォッシャータンクから、びゅるびゅるお汁が溢れて……あああっ！　\nブラシで擦られてる最中なのにぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0103137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「やっ、あっ！　ま、待ってっ！　ウォッシャー液がついてるフロントガラス\n、ブラシでゴシゴシしないでぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「あとでバンパーで拭くから……！　ちゃんと自分で処理するから……あっ、\nやっ！　あああああぁあんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「また出るぅ！　びゅるびゅる出るうううぅんっ！　ダメっ！　本当にダメぇ\n！　もうこれ以上、ウォッシャー液出てこないでぇ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0103140" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021201_01_05" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……な、なに……？　急に身体からヌルヌルの洗車液が洗い流\nされてるわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0103201" ]},
		{"command":[ "SETIMAGE", "0", "still_00021201_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「お、終わったのね……ああっ、よかったわ……ちゃんとブレーキも効いたし\n、事故にはならずにすんだようね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「それにこのお水のおかげで、エンジンも冷却されて……はああぁ……私の汚\nれが、全部洗い流されていくわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0103203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「隊長さん……私の車体、どうかしら……？　ちゃんと綺麗になってる……？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0103204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「えっ……？　まだ終わりじゃない……？　それって、どういう……きゃああ\nあぁん！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0103205" ]},
		{"command":[ "SETIMAGE", "0", "still_00021201_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「やっ、あっ！　ま、また洗車液をどぴゅどぴゅかけられて……！　今度はど\nこを洗うっていうの……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「フロントもサイドも洗い終わったのに……！　タイヤだって、全部隅々まで\n綺麗にしたのにぃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「ま、まさか……前や横だけじゃなくて、後ろも洗うっていうの……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「やっ、あっ、あああぁん！　リアガラスとマフラーは、一番ビンカンなとこ\nろなのっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0103209" ]},
		{"command":[ "SETIMAGE", "0", "still_00021201_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「そこをパワーのあるブラシでゴシゴシされたら……ダメっ、想像しただけで\n、前に進みそうになっちゃうぅ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0103210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「ひあああああぁん！？　来てるぅ！　ブラシが私の後ろをズリズリ擦ってく\nるのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「リアバンパーもゴシゴシされて……あっ、そこ、弱いのぉ！　柔らかいから\n、激しくされたらヘコんじゃうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「んひっ、くっ、はあああぁ！　テールパイプに洗車液が入りこみながら、ブ\nラッシングされて……んくううぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「そんなに刺激されたら、排気ガスが出ちゃうわっ！　あっ、あっ！　イヤっ\n、隊長さんっ！　耳を塞いでぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0103214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「やっ、ああああっ！　聞かないでっ！　私のマフラーから出る汚い排気音、\n聞いちゃイヤあああああぁっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0103215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「あっあっあっ！　ぐっ、んんんん～～～～～っ！　またウォッシャー液がび\nゅるびゅる出てるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0103216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「マフラーを綺麗に洗浄されて、ピカピカにされながらヌルヌルのお汁を吹き\n出すなんて……は、はしたないわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「やっ、あああっ！　違うのっ、隊長さんっ！　いつもはこんなに感じたりし\nないのっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0103218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「きょ、今日は隊長さんと一緒に洗車してるから、いつもと違う感じがしてる\nだけで……！　あっ、あんっ、本当よっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「ふっ、んふっ、ひあああぁ……！？　あっ、あああぁ……た、隊長さん……\n！　もう、終わりよね……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "もっと洗ってみる","LABEL1","ワックスがけをする","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「きゃああああぁんっ！？　ど、どうして、またさっきのヌルヌルした洗車液\nがたくさん出てるの……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0103301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021201_01_05" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「大型車両だから、一回の洗車じゃ不安……？　そ、そんなことないわっ！　\nちゃんと綺麗になってるわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「ほら見て……！　窓ガラスも、タイヤも、バンパーも……全部ピカピカでし\nょう……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0103303" ]},
		{"command":[ "SETIMAGE", "0", "still_00021201_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「だから早くこの洗車液を止めて……あっ、あああっ！　やっ、ダメっ……も\nう全身ヌルヌルになってるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0103304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「自分でブラシを操作しながら、より重点的に洗浄することができるって……\nそれって、隊長さんの手で洗車されるってこと……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0103305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「隊長さんが操作してくれるのは嬉しいけど、これ以上はダメよっ……！　洗\n車は１日１回にした方がいいわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0103306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「お願いだから操作させて、洗わせて欲しいだなんて……！　うううぅ、そん\nな顔して頼まれたら、断れないじゃない……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0103307" ]},
		{"command":[ "SETIMAGE", "0", "still_00021201_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「わ、わかったわ……もう１回だけ洗車させてあげる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0103308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「でも、ブラシは最弱にしてっ……！　じゃないと、気持ちよすぎて、今度こ\nそ誤発進しちゃいそうだから……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「あっ……やっ、この回転速度はさっきと同じ……！　た、隊長さんっ！　お\n願いだから、ちゃんと取扱説明書を読んでぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「きゃっ……！？　こ、今度はなに……！？　さっきと違うヌルヌルした液体\nが、全身に広がって……んっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0103401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021201_01_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「せっかく綺麗になったんだから、ワックスコーティングをしたい……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「もう、隊長さんったら……全身ワックスまみれにして、私をどうするつもり\nなの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0103403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「ツヤが出ればもっと綺麗に見えるし、走ってて気持ちがいい……？　た、確\nかにそうね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0103404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「でもね、隊長さん……ワックスはちゃんとボディ用とガラス用で使い分けて\n欲しいわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0103405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「ボディは今のワックスでいいんだけど、フロントガラスにはもっと撥水性の\n高いワックスを……あああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0103406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「やっ、ダメ……！　ガラスにワックスがついて……んんっ、あっ、あっ……\n！　変な気分になってきちゃうわっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0103407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……！　洗車液とは違う、オイルのヌルヌルが……くっ、ああ\nあぁん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0103408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「な、なにこれっ……！　車体にどんどんツヤが出てきて……やっ、ああっ…\n…！　ボディがスベスベになっちゃうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0103409" ]},
		{"command":[ "SETIMAGE", "0", "still_00021201_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「た、隊長さん……もっと、もっとしてぇ……！　私のボディ、いっぱいツヤ\nツヤのスベスベにして、いっぱい輝かせてぇ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0103410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}