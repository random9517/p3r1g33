{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002403_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「くっ、ああっ……！　いつ見てもたくましいオチンポね……！　熱くて、カ\nタくて……んんっ！　お、男らしいわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0304101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「今日はえらく積極的だなんて……！　そ、それはあなたが、毎日イヤらしい\nことをするからよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0304102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「あなたに開発されたせいで、ずっとオマンコが疼いて……はぁ、ああっ……\n！　エッチなこと、したくなっちゃうの……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0304103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「それにあなたも、私とエッチしたいでしょ……？　オマンコやお口にオチン\nポ挿れて、気持ちよくなりたいでしょ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0304104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ふふっ。正直ね……あなたのそういうとこ、嫌いじゃないわ。ご褒美に、い\nつもと違うところを刺激してあげる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0304105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「んんっ……！　乳首を弄ると、オチンポがビクって反応するわね……どんど\nん大きくなってるわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0304106" ]},
		{"command":[ "SETIMAGE", "0", "still_00002403_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「オマンコでオチンポスリスリされながら、乳首弄られるの……そんなに気持\nちいいの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0304107" ]},
		{"command":[ "SETIMAGE", "0", "still_00002403_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「……ふーん。もっとして欲しいんだ……でも、あなたばっかり気持ちよくな\nるのは、不公平だと思わない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0304108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ほら……私のオマンコ、もうエッチなお汁でトロトロなの……オチンポ挿れ\nたくて、仕方ないの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0304109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「気持ちよくなるなら、一緒に気持ちよくなりましょ……オチンポ、挿れるわ\nね……！　んっ、あっ……あああっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0304110" ]},
		{"command":[ "SETIMAGE", "0", "still_00002403_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「このオマンコが掻き分けられていく感じ……本当にたまらないわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0304111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「私の膣内、もうすっかりあなたのカタチになってるし……子宮口なんて、挿\nれられただけで開いちゃう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0304112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「あっ……んっ、ふぐっ……！　エッチなお汁も溢れて止まらないわ……！　\n本当に、悪いオチンポね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0304113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「こんな悪いオチンポは……正義のヒロイン、レイジョーローズのオマンコで\n、コウセイさせてあげないとね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0304114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「コウセイさせるより、堕ちる方が早いですって……？　そんなの、やってみ\nないとわからないじゃない……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0304115" ]},
		{"command":[ "SETIMAGE", "0", "still_00002403_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「いいわ……！　なら、勝負しましょ……！　あなたが先にイッて、悪いオチ\nンポをコウセイするか……それとも、私がイッて堕ちるのが先か……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0304116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「な、なによ、その余裕そうな顔は……！　あなたのオチンポの弱点、私が知\nらないとでも思ってるの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0304117" ]},
		{"command":[ "SETIMAGE", "0", "still_00002403_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「こうしてオチンポを根本からぎゅーってすると……全体が締め付けられて、\n気持ちよがるくせに……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0304118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「それに体勢的にも私が上だし、乳首をクリクリすると……あああぁん！　オ\nチンポが、ビクビクして暴れてる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0304119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ふふっ……！　こんな簡単に感じるなんて、これはもう楽勝ね……！　この\nレイジョーローズに、敗北はありえないんだから……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0304120" ]},
		{"command":[ "SETIMAGE", "0", "still_00002403_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「あっ、あっ！　んっ、くああぁ……！　ど、どう……！？　私の腰使いは…\n…！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0304121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「上下に動くたびに、オマンコのヒダがオチンポに引っかかって……ぐっ、ん\nくっ……！　き、気持ちいいでしょ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0304122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「強がりを言ってもムダよ……！　主導権は私にあるんだから……！　ほら、\n乳首も弄ってあげるから……早くイキなさい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0304123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「んふっ、はっ、あひっ……！　オチンポだけじゃなくて、乳首もカタくなっ\nてるわよ……！　これなら、すぐにイキそうね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0304124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「オチンポの先端から、エッチなお汁もどぴゅどぴゅ出てるし……この調子で\n、溜め込んでるザーメンも吐き出しなさい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0304125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ほらっ……ほらっ……！　子宮口の周りで、オチンポの先端グリグリされる\nの……す、好きでしょう……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0304126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「んんっ……！　あっ、あっ！　はひっ、んおぉ……！　こ、こうやって……\n奥をトントンされるの、気持ちいいでしょ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0304127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「Ｇスポットだって……！　ぐっ、うぐぐっ……！　このオマンコの浅いとこ\nろ、カリの部分でズリズリされると……あっ、あああぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0304128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「な、なによ、その意味深な笑いは……！　気持ちいいなら、気持ちいいって\n言えばいいじゃない……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0304129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「え……？　今言ったところは全部、私の弱点……？　そ、そんなことあるわ\nけ……ああっ、ひあああぁん！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0304130" ]},
		{"command":[ "SETIMAGE", "0", "still_00002403_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「やっ、あっ！　なんであなたが動くのよっ！　そんな勢いで奥を刺激された\nら……ひぎっ、んんっ！　あっ、あっ！　ふあああぁ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0304131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「あっ、んっ！　ひゃうっ、ひぐうううぅ！　そこ、ダメっ！　奥はダメぇ！\n　そんなにされたら、イクッ！　イッちゃうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0304132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「あああぁ！　やっ、あああぁ！　負けるなんて、絶対にダメなんだからっ！\n　私だけイクなんて、許さないんだからぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0304133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「こうして乳首をつねりながら、オマンコを締め付ければ……！　んんっ！　\nあ、あなたのオチンポも、我慢できないでしょ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0304134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ほらっ！　イキなさいっ！　私より先に……あっ、あああっ！　イッ、イク\n……！　イクイクッ、イクぅぅぅぅぅ～～～～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0304135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ひゃああああぁ……！　あっ、あああぁ……！　イッ、イッてるぅ……！　\nオマンコ、ヒクヒクしてるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0304136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002403_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「き、気持ちいいところに……ザーメンがたくさん流れ込んできて……！　あ\nふっ、んんっ……！　あっ、ダメ……感じすぎるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0304137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「オマンコが勝手に締まって……ザーメン吸い上げてきちゃう……！　ヒダが\nオチンポに絡んで、離れないわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0304138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「はぁ……あああぁ……！　気持ちいい……！　子宮にザーメン注がれるの、\nすっごい幸せぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0304139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「あ、あなたもザーメン出せて嬉しいでしょ……！？　あっ、あっ……！　ん\nぐっ、はひっ……！　くあああぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0304140" ]},
		{"command":[ "SETIMAGE", "0", "still_00002403_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「はあ……はあ……お互い、イッちゃったわね……これじゃあ、どっちが勝っ\nたかわからないわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0304201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「イッたけどオチンポはまだカタいままだから、この勝負はあなたの勝ち……\n？　な、なによそれ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0304202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「確かにオマンコはエッチなお汁でトロトロになって、ヒクついてるけど……\n私はまだ全然動けるわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0304203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「さっきの勝負は引き分けにして、二回戦をしようですって……？　い、いい\n度胸じゃない……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0304204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「今度こそ、この正義のヒロイン、レイジョーローズがあなたを倒してあげる\n……！　私はオチンポに負けたりなんて、しないんだから……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0304205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「あああぁ！　はあ、ああっ！　んっ、ひぐっ……あっ、ひあああぁ！？　い\nきなり、浅いところを責めるなんて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0304206" ]},
		{"command":[ "SETIMAGE", "0", "still_00002403_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「か、勝手に動くなんて卑怯よ……！　私が上なんだから、私に主導権を譲り\nなさい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0304207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「んんっ！　おっ、おほおおおぉ……！？　ちょ、ちょっと……人の話を聞い\nて……！　んひっ、あああぁ！　そこ、ズリズリしちゃダメぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0304208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「はあ、んんっ、ふぎゅ……！　あ、あなたなんかに、負けないんだから……\n！　乳首を弄って、反撃してあげるわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0304209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「こうやって……先端を摘まれながらクリクリされるの、好きなんでしょ……\n！？　否定しても、ムダなんだから……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0304210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「このまま思いっきり引っ張って……だらしない乳首にしてあげる……！　ん\nっ、はふっ……！　あっ、んんっ……！　あっ、やっ、あああぁん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0304211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ちょ、ちょっと……！　奥を乱暴に突かないでっ……！　そんなことされた\nら、身体が痺れて……んひっ、ゆ、指が動かなくなるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0304212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「な、なによ……！　仕返しのつもり……！？　気持ちいいなら、素直に感じ\nてればいいじゃない……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0304213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ふあっ、あっあっ……！　やっ、あああぁ！　私が責めてるはずなのに、こ\nんなに感じさせられるなんて……！　ほ、本当に悪いオチンポね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0304214" ]},
		{"command":[ "SETIMAGE", "0", "still_00002403_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ひぐっ、んんっ！　あっ、ひあああぁん！　トドメをさすみたいに……お、\n奥までオチンポが刺さって……！　おっ、おほおおおぉ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0304215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「だ、ダメ……！　こんなの、またイッちゃうっ……！　オマンコ、負けちゃ\nうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0304216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「き、気持ちよすぎて……オマンコ締まるぅ……！　あああぁ……！　オチン\nポのカタチがはっきりわかるぐらい、ギチギチに締まって……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0304217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ひあああぁ……！？　オチンポ、子宮口に当たりながらビクビクしてるっ…\n…！　あ、あなたもイキそうなのね……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0304218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「さ、先に、イキなさ……あああぁん！　あっ、あっ！　ひっ、んひいいいぃ\n！　ダメっ！　ダメぇ！　イクッ！　イクぅん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0304219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「先にイカされちゃうっ！　もう我慢できないわっ！　あっあっあっ！　イク\nッ！　イクイクイクッ！　イグうううううぅ～～～～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0304220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「くあああああぁ！？　ま、また膣内に……！　子宮にザーメン流し込まれて\nるぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0304301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002403_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「オマンコが悦んで、子宮口が完全に開いてるからぁ！　こんなの、絶対に孕\nんじゃう！　妊娠しちゃうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0304302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「私、ゴレイジョーなのに……！　正義のヒロインなのにぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0304303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「悪いオチンポに負けて……！　は、孕まされて……！　こんなの、絶対ダメ\nなのにぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0304304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「あああぁ！　ダメなのに、嬉しくてイッちゃうぅ！　あっ、あっ！　気持ち\nいいっ！　気持ちいい～～～～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0304305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「あっ……あああぁ……！　子宮に入らなかったザーメンが、溢れてきてるわ\n……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0304306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「レイジョーローズは……悪いオチンポに負けちゃったわ……完全に堕ちちゃ\nったみたい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0304307" ]},
		{"command":[ "SETIMAGE", "0", "still_00002403_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「これからは……あなたのオチンポが大好きな、エッチで悪いヒロインになる\nわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0304308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「だから……もう一回、エッチしてもらうわね……あなたがイヤって言っても\n、射精してもらうわよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0304309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「三回目はさすがに無理……？　ふふっ……悪に堕ちたレイジョーローズにそ\nんなこと言っても、ムダなんだから……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0304310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「あっ、やっ！　お、オチンチンがオマンコから抜けて……ふああああぁ！？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0304401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002403_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「身体にザーメン飛んできてるっ！　膣内だけじゃなくて、膣外も穢されて…\n…！　あああぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0304402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「全身を悪いザーメンに染められるなんて……！　こんなの、ニオイが染み付\nいちゃうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0304403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「エッチなニオイをさせる、悪いヒロインになっちゃうっ！　ああっ、ダメっ\n！　そんなのダメぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0304404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「でも、気持ちいいの止められないのぉ！　もっと出してっ！　ザーメンで私\nの身体、いっぱい汚してえぇーーーーー！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0304405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「んっ……おっ、おおおぉ……！　もう、こんなに出して……これじゃあ、服\nにニオイとシミが付いちゃうわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0304406" ]},
		{"command":[ "SETIMAGE", "0", "still_00002403_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「でも、これってなんだか……レイジョーローズがザーメンに負けた証拠みた\nいね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0304407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「あなたのザーメンで穢されて……オチンポに負けて、堕ちちゃったって感じ\nだわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0304408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「こういうのって、悪堕ちっていうんでしょ……？　ふふっ……あなたに堕と\nされるなら、悪い気はしないわね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0304409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ねえ……よかったら、もっと私のこと堕として……？　あなたのオチンポに\n逆らえなくなるぐらい、エッチで悪いゴレイジョーにして……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0304410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}