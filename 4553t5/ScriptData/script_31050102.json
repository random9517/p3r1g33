		{"command":[ "PLAYVOICE", "105_0104138" ]},
		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「まだ、頭のナカがぼーっとして……あうぅ、現実感、ない……ですっ。ふぇ\n……？　もっとしたい……ですか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
