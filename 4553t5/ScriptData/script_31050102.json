		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "105_0104102" ]},
		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「今すぐにでもオチンチンをオマンコに入れたい……？　あ、ああっ……か、\n可愛いだとか言わないで下さい……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "105_0104103" ]},
		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「恥ずかしがる顔も、とか……そんなの、私っ……あなたのカチカチに勃起し\nたオチンチンでオマンコをこすられてるだけで……あぁっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "105_0104104" ]},
		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「興奮しすぎて、頭が変になっちゃいそうなんです……！　入れる？　い、入\nれちゃうんですか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "105_0104105" ]},
		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「ごくっ……！　わ、私の初めて……あなたに、捧げます……ん、んんん……\n！？　あっ、あああ……あああぁぁ～～～！！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "105_0104106" ]},
		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「はぅぅ！！　入って……ます、オチンチンが窮屈そうにビクビクって跳ねて\n……！　くぅぅっ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010501_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "105_0104107" ]},
		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「あっあうぅ……！？　お、おっぱい吸わないで、くだ……さいっ、そこ、ん\nあぁ！？　乳首……か、感じすぎ、ちゃう……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "105_0104108" ]},
		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「ふあぁ、はぁ、は……はい、乳首、弱くて……んあぁ、はぁ、はぁ！　昔か\nら……布がこすれただけで感じちゃうんです……くぅぅ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010501_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "105_0104109" ]},
		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「だから乳首は……やあぁ！？　吸っちゃダメぇ、感じすぎて私っ……私ぃ、\nおっぱいだけで変になっちゃいます……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010501_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "105_0104110" ]},
		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「えっ、ええ……？　は、はいっ。乳首ぃいじめられて、お……オマンコがき\nゅんきゅんきちゃって……ふあぁっ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010501_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "105_0104111" ]},
		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「いやらしい汁、流れてきちゃって……ます、あぅぅ！　んあぁ！！　お、オ\nチンチンでがつ、がつって突かれてるぅ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "105_0104112" ]},
		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「い、痛くない……ですよ？　愛液っ、んっ、ん～～～っ！　分泌ぅされちゃ\nって、滑っちゃってるからぁ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "105_0104113" ]},
		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「奥に……えっ？　あっああああ……！！　根元まで入れ、んああぁぁっ、入\nって……くるぅぅ！！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010501_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "105_0104114" ]},
		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「子宮ぅ、こつん、こつんって当たって……ます、はぅ、はぅぅっ！　くぅぅ\nん……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "105_0104115" ]},
		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「あっああぁ……激しくしないで下さい、ひゃうぅ！？　がつ、がつってオチ\nンチンの先っぽ当たってます……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "105_0104116" ]},
		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「ふあぁ、名前、知ってます……亀頭、ですっ。亀頭が子宮口ぉにキスして…\n…こじ開けようとしてるんですぅ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "105_0104117" ]},
		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「も、貰ったエッチな道具……んあぁ、使ったかって……そんなこと聞かなく\nても、んあぁ、言えっていうんですね……！？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010501_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "105_0104118" ]},
		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「はいぃ、はいっ……つ、使いましたぁ、んあぁぁん……！　それまでオナニ\nーしたこともなかったのに……っ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "105_0104119" ]},
		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「ローターくっつけて乳首いじめながら、クリトリスにもローターつけて、ん\nんっ……あああぁぁ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "105_0104120" ]},
		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「こ、こうやってあなたにオチンチン入れられて……はぁっ、はぁぁ！　そう\n……です、レイプされるの想像しながらイッちゃってたんです……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "105_0104121" ]},
		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「も、もっと言え？　あぁぁ！　恥ずかしくて……興奮しすぎて、私おかしく\nなりそう……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "105_0104122" ]},
		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「言わないとやめちゃうんですか？　精液ぃ子宮にドクドクッて出して欲しく\nないのか、だなんてぇ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "105_0104123" ]},
		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「ま、まるで私があなたに孕まされたがってるみたいな言い方……んっ、んん\n！　ちゅっ、ちゅるる……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010501_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "105_0104124" ]},
		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「んふあぁぁ、あぁ、ちゅぱ、ちゅっ……んうぅ、私がパイズリしたあの日か\nら、え、エッチな妄想止まらなくて……っ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "105_0104125" ]},
		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「あなたにレイプされる妄想しながら、じ、自分の部屋でオナニーざんまい、\nだったんです……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "105_0104126" ]},
		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「はい、はいぃ、縛られて、首輪をつけられて……んあぁ！　後ろからがつ、\nがつってオチンポで子宮ぅ突き上げられて……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "105_0104127" ]},
		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「はうぅ！？　そう……こ、こんな感じ、です……あふうぅ！？　頭の奥ぅビ\nリビリって痺れてきちゃって……ますぅ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "105_0104128" ]},
		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「やあぁっ、初セックスなのに……ば、ヴァージン捧げたばかりなのにぃ……\nくぅぅ！？　イッちゃいます……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010501_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "105_0104129" ]},
		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「こんなに激しく腰を振られて、やうぅ！？　おっぱい……揉まれて、やあぁ\n！？　乳首、吸われて……ひぃぃ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "105_0104130" ]},
		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「イキそうになって……ます、イキます、もうすぐイッちゃいます、んあぁぁ\nん！　お願い……き、来て、下さい」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "105_0104131" ]},
		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「あなたの子種汁ぅ私の子宮ぅにドクドクッて出して下さい……んあぁぁ～～\n！？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010501_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "105_0104132" ]},
		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「来てっ、来てぇ……！　ああぁ！？　オチンチンがナカでビクビク跳ねてま\nすぅ……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010501_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "105_0104133" ]},
		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「頭ぁ真っ白に、も、もぅ何も考えられないですっ……んあぁぁ！　あっ、あ\nあぁぁ……ああぁ～～～！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "105_0104134" ]},
		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「私っ私ぃ……もう、イクッ、イクぅぅ……あああっ、あっああ……ああぁぁ\n～～～～！！！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "105_0104135" ]},
		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「やうぅ！　んあぁ！　あっあうぅ、ナカに……い、いぃっぱい出て……るぅ\n、熱ぅぅい……んあぁん……！」", "NORMAL" ]},
