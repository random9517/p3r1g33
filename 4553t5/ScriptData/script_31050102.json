		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「スペルマ、ドク、ドクって注がれて……ふあぁ、あっ、あうぅ……子宮ぅ、\nたぷたぷになっちゃって……ます……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "105_0104137" ]},
		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「ふあぁ、はぁぁ、ほ、本当に……あなたに抱かれて、あなたにオンナにされ\nちゃったんですね……わ、私……っ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010501_02_08" ]},
