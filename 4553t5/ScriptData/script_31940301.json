{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0034" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、はぁ……。ど、どうした。ライブ直前だというのに、舞台袖に\n急に呼び出すなんて……！　よほど大変なことでも起きたのか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0303101" ]},
		{"command":[ "SETCHARA", "0", "char_00019403_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「……な、何……？　突然ムラムラしてきたから今すぐ解消してほしい？　し\nかもここで？　ワタクシの口で咥えて射精させろ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0303102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「あ、ぁ……そ、それはさすがに無理というものだ。すぐに他のアイドルも来\nるだろうし……。ど、どうしても今でなくてはいけないのか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0303103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「……スッキリした状態で、ワタクシの歌を聞きたい？　せっかくの晴れ姿だ\nから？　う、うう……。そ、そうか。それならば仕方ないか……来い」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0303104" ]},
		{"command":[ "SETCHARA", "0", "char_00019403_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「ん……。よ、よくもまあ、こんな人気の多い場所でこんなに硬く勃起できる\nものだ……。……ん？　ステージの熱気にあてられて？　馬鹿な……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0303105" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00019403_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「そんなことで毎回大きくしていたら、身体がおかしくなってしまうぞ。……\nっはぁっ、く、咥えにくい……。なんだかいつもより太い、ような……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0303106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「……ワタクシの衣装に興奮したから、だと？　んッ……！　う、ウソをつく\nな。どうせ他の……若い女に欲情しているに決まっている……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0303107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「だが……もし本当に、この硬さが、大きさがワタクシのせいならば……。う\nむ。しずめてやるのはワタクシでなければ、というのは……わかる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0303108" ]},
		{"command":[ "SETIMAGE", "0", "still_00019403_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「んむ……っ。はむ、んむ、むぅ……んむ……っ。こ、こら……あまり暴れる\nな、口からはみ出してしまう……っ。んっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0303109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「顎が外れそうなくらいに昂っているな……。それに、ビクッ、ビクッ、と震\nえて逃げる。……待て。亀頭が唇から離れてしまう。じっとしていろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0303110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「んーー……ちゅぷっ。くちゅ……ちゅぷっ、ぷちゅ……ちゅむ……。くぷっ\n、ぐっちゅっ……！　ぬちゅっ、にゅるっ……ぐっちゅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0303111" ]},
		{"command":[ "SETIMAGE", "0", "still_00019403_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「なんという規格外の男性器……。凶悪なチンポだ……。んむっ、必死に吸い\nついていなければ弾力に跳ね返されてしまう……っ。むぅっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0303112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「そ、それに……。しゃぶっているだけで、妙に胸が疼く。……はぁ、っはぁ\nっ……♪　な、なんだ？　身体が熱い。乳房が……乳首がむずがゆい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0303113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「あっ……んんっ……！　ゆ、指でいじらずにいられない……っ。あっ♪　こ\n、これは一体……？　貴方、ワタクシに何かしたのか……？　んぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0303114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「楽屋の……控室の水を、ボニューデマクールとすり替えた！？　な、なぜそ\nんなことをしたのだっ……あっ！　そ、それで胸がかゆいのかぁ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0303115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「はぁッ……♪　あぁ……！　ぼ、母乳が……！　乳首から母乳が溢れる……\nっ。本番前だというのに、衣装が濡れてしまうではないかぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0303116" ]},
		{"command":[ "SETIMAGE", "0", "still_00019403_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「こ、このままでは舞台で踊れない……！　息をするだけで感じてしまう、胸\nが疼く、ジンジンして我慢できない……！　あっ♪　あっぁっ、ンン……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0303117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「この薬の効力を消すには、あ、貴方のコレを……オチンポを満足させて、私\nも何度か胸で達するしかないのか……っ。んっ……んん……！　もう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0303118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「このような小細工をしなくとも、いつだってワタクシは貴方のしたいことを\nさせてやるし、して欲しいことをしてやるというのに……っ、んん～っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0303119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「貴方はいつもイジワルだ……。……えっ？　困った時の顔が好き？　アイド\nル姿が可愛くてからかいたくなった？　く、くぅう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0303120" ]},
		{"command":[ "SETIMAGE", "0", "still_00019403_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「それ以上言うな……っ。わ、わかった！　もうわかったから……っ。しょう\nがないやつだ。すでにこうなってしまったのだから仕方ない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0303121" ]},
		{"command":[ "SETIMAGE", "0", "still_00019403_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「全力で、オチンポにこの口でご奉仕して……胸の疼きもおさめるぞ。そうと\n決まれば……はむっ！　じゅる……ぐっちゅっ！　じゅるっ、じゅるるるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0303122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「んっぁっ♪　チンポ……っ、オチンポ舐めながら、おしゃぶりしながら乳首\nを……じゅるっ♪　刺激して……じゅっぽっ！　じゅっぽっじゅっぽっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0303123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「あぁっ♪　い、いやだ……♪　気持ちが良くて頭がボーッとする……♪　勝\n手に腰が、揺れてひまう……♪　んれろっ、れろ……れろっ、じゅるるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0303124" ]},
		{"command":[ "SETIMAGE", "0", "still_00019403_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「ふぁ……っあっぁっ♪　んん……っ！　れろっ、れろ、れろ……！　ちゅぷ\nっ！　くっちゅっ……レロッ♪　ぴちゃ……ぴちゃ、じゅぷっじゅぷぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0303125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「愛しい貴方……♪　この衣装、も……！　ワタクシも……っ、全て貴方だけ\nのモノ……♪　好きに使ってくれてかまわない、が……♪　んれろっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0303126" ]},
		{"command":[ "SETIMAGE", "0", "still_00019403_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「貴方の前では綺麗で……、んっ♪　可愛くありたいと思うワタクシの女心も\n、わかってくれるととても嬉しい……っ。ん……じゅぷっ、ぢゅるっじゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0303127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「んっ、うぅ……♪　母乳が……母乳が止まらない……あぁ♪　オチンポにむ\nしゃぶりつきながら、乳首をいじるワタクシを見ないでくれぇ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0303128" ]},
		{"command":[ "SETIMAGE", "0", "still_00019403_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「んんっ、恥ずかしい……っ。あっ♪　ぁ……。くっちゅっ！　んんっ……！\n　ぐちゅっ！　ぐっちゅっ！　れろぉ……れろっ、れろ……じゅるるるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0303129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「裏筋を舌でなぞりあげると、興奮ひゅる……♪　んむっ……！　なんと巨大\nなチンポ……。あっ♪　ぁっ、逞しい……好き、好きだ……♪　ぐちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0303130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「もっと……腰を突き出してくれぇ……！　喉の奥にまでチンポ、欲しくてた\nまらないのら……っ♪　ぢゅるっ……先走りの汁も、おいひい……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0303131" ]},
		{"command":[ "SETIMAGE", "0", "still_00019403_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「んんっ、ふぁ……あむっ♪　くちゅ……れろっ、ぴちゃ……くちゅ……♪　\nはぁ……はぁっ、ワタクシの母乳の甘い香りが広がっていくぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0303132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「……ん！　どうやら他のアイドルたちの準備が整った、ようだ……。早く射\n精しないと、出しそびれてしまうかもしれないぞ……。ンッ、んん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0303133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「ワタクシも舐める速度を上げる、から……精液を、出せそうならすぐに……\n出ひてくれ……！　っぢゅるっ！　じゅぽっ！　じゅっぽっじゅっぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0303134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「あッ♪　あああっ、チンポをしゃぶりながら乳首をいじっている姿、なんて\n誰にも見せられないぃ……！　早くぅ、早く出してくれ、はやくぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0303135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「んんんんんむっ……！？　んぷっ……ンンンッ……んんんんぅううう……！\n　んん……！　ンッ……！　んっ、んんんんん……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0303136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019403_01_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「い、いいぞぉ……♪　だいじょうぶら、足音は遠ざかっていった……！　口\nで絞りとるから、遠慮せずに全部出せ……！　ッん～～～～～～～っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0303137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「ごくっ……ごくっ……♪　あッ、あぁ♪　一度では飲みきれないほどの大量\nの精液ぃ……♪　どうか喉奥に流しこんでほしい……。っんんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0303138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「ごくっ……ふぅうっ……♪　ごきゅ……んんん……っ♪　な、なんという勢\nいだ……身体の中が白濁汁で満たされていく……。んっ、ごくっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0303139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「っふ……♪　吐息すら精液の臭いになってしまったではないかぁ……♪　あ\nぁ……♪　それに……ますます乳首の疼きが強くなってしまった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0303140" ]},
		{"command":[ "SETIMAGE", "0", "still_00019403_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「この、いつまでも口の中で粘り続ける精液がいけないのだ……。いつもこの\n感触が、この熱さが……ワタクシの胸をかき乱す……。はぁ、はぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0303201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「すまない……。人が来るから早く射精しろ、などと急かしておいてなんなの\nだが……。まだ母乳が止まりそうにない。乳首も硬く尖ったままだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0303202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「これを解消するために……そして、いまだ勃起しつづけている貴方のオチン\nポをなぐさめるために、もう一度おしゃぶり……してもかまわないか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0303203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「あっ……♪　そ、そうか。いいのなら、さっそくいただくとしよう。……あ\nむっ……れろ……あぁ♪　精液の味が残っている……美味しい……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0303204" ]},
		{"command":[ "SETIMAGE", "0", "still_00019403_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「フフフ、まだまだこの中には精液が残っているのか……。ちゅっ、それとも\n、今まさに……睾丸で新しく作られているのか……。っくちゅっ、ちゅぷ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0303205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、どちらでもいい♪　見てくれ……♪　んちゅっ♪　貴方のオチ\nンポにキスしながら、自分の胸をネチネチいじくっているワタクシを♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0303206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「くちゅっ、ちゅぷぷぷ……♪　んぁ♪　貴方は尿道に残った精液と、新しい\nカウパーを……ワタクシは母乳をしみ出させて……なんと卑猥な二人」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0303207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「舞台袖、で♪　本番前にこうして盛り合っているワタクシたちを誰かに見ら\nれたら……♪　あぁ、でも見て欲しい、ような……♪　んんんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0303208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「あうぅうっ♪　あっ……！？　すまないっ、母乳がぁっ♪　あぁっ！　いや\nらしい妄想をしただけで、蛇口が壊れたかのように母乳が噴き出して！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0303209" ]},
		{"command":[ "SETIMAGE", "0", "still_00019403_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「んんんぁッ♪　気持ち良すぎる……ぅっ♪　オチンポお口でねぶりながら、\n母乳発射するの、やめられない……やめたくない、気持ちいい……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0303210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「あぁ……♪　あぁ、あぁ……♪　メスとして、ダークエルフとして最高の喜\nびだ……。愛する人のチンポを咥え、母乳を何度も撒き散らしながら！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0303211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「ッんんんっ♪　何度も何度も絶頂して♪　んくっ……くぅっ♪　おかしなク\nセがついてしまう……っ♪　母乳を出すとイくクセが……あああ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0303212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「っくちゅっ♪　ぐっちゅっ、ぬちゅっ……♪　れるぅうっ、じゅるっ！　じ\nゅるっ、じゅるる……♪　れろッ、れろ……ぴちゃっ、ぴちゃ、じゅるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0303213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「あぁ……、いけない……♪　しゃぶっているとどんどんうっとりしてしまっ\nて……。性欲が抑えきれなくなる……。っじゅぷっ♪　ぐっちゅっじゅるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0303214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「貴方も……感じてくれているか？　ワタクシの長い舌がチンポを這い回り、\nすぼめた唇がチンポを吸い上げ、あたたかな口内がチンポを包みこみ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0303215" ]},
		{"command":[ "SETIMAGE", "0", "still_00019403_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「卑猥な水音をたてながら、ぐちゅぐちゅフェラチオするこの姿……♪　これ\nは貴方だけに見せる、ワタクシの特別な姿なのだからな……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0303216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「っちゅっ♪　くちゅ♪　ちゅぷ……んれろっ、れろッれろ……♪　んんんっ\n……♪　ぐちゅっ♪　グッチュッ、ぐちゅっ……じゅぷぷぷぷ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0303217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「あっ♪　チンポが膨らんできたぞ。咥えきれない……♪　んぅっ♪　どうし\nた、また出したくなってきたのか？　フフフ、恥ずかしがらなくていい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0303218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「ワタクシ、も……あっ♪　またイキそうだ、乳首と、口と……敏感なところ\nがどちらも、疼いて疼いて辛抱できない……♪　だ、出してくれ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0303219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「誰にも気づかれないよう、一滴残らず飲み干してみせる……♪　じゅるっ、\nお願いだ、ワタクシの顔を見ながら、出して……出してくれ♪　ぐっちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0303220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「ッん……！　んんんんぅっ……！　んぅ！　んん！　ん～～～～～っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0303301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019403_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「に、苦い……っ♪　濃い……♪　ああっ、これだ、これが欲しかったんだ…\n…っ♪　飲むぞ……あっあっ♪　母乳をこぼしながら精子を飲むっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0303302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「ゴク……♪　ごくっ、ごく……ごっくんっ……♪　んぁ、口の端からこぼれ\nてしまう……。ちゅるっ♪　ごく……♪　ん、これで良し……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0303303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「いいぞ、あるだけ出しきってくれ……。っじゅるっ、ワタクシはまだまだ精\n液を飲める……飲みたいから……♪　ぢゅる……じゅるじゅるっ、んん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0303304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「もっと！　もっともっとだ！　れろっ、れろ……もっとぉ♪　精液……精子\n♪　口の中にドクドクと……ふぁっ♪　きたきた、注がれてきたぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0303305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「ごくっ♪　ごくっ……ごく♪　んん、ぁ、んぅ……♪　舌に絡みつくぅ……\n♪　なかなか、飲みこめない……。んん、それでも飲む！　……ごくんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0303306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「ふぅううう……♪　どうだ？　ワタクシは、貴方をスッキリさせることがで\nきたか……？　あ、ああ、衣装は大丈夫だ。二度目も口に出してくれたから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0303307" ]},
		{"command":[ "SETIMAGE", "0", "still_00019403_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「少しは精液の臭いが残ってしまうかもしれないが……。人に気付かれるほど\nではあるまい。それより、ひどいのがワタクシの母乳であって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0303308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「……うむ。母乳のシミと、ワタクシの股間……そのあたりが濡れて湿ってし\nまっているのは、その……隠しきれないかもしれない……。困ったな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0303309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「こ、こら！　何を笑っている！　笑いごとではないぞ！　……だが、満足し\nてくれたのは嬉しいし……。なんとも複雑なキモチだ。うう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0303310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「ああああっ♪　乳首イクぅっ……♪　っんん！？　く、口からチンポが抜け\nてしまったぞ……！　んぷぁあっ！？　ど、どこにかけているのだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0303401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019403_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「あっ♪　あっ……♪　イキすぎて敏感になった胸に、身体に……精子がぶち\nまけられている。真っ白な精液が、垂れて、流れて……こんなことって♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0303402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「あっ、熱い……ッ♪　すごすぎる、二度目の発射だというのにこの量、この\n飛ばしっぷり……♪　も、もう！　ライブ前にアイドルの服にかけるなど！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0303403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「衣装がドロドロになって、とても着れたものではない……っ♪　それなのに\n、本当は困ることのはずなのに……どうしても胸がときめいて止まらない♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0303404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「あっあっ♪　ワタクシもどうせ母乳を噴き出して絶頂してしまっているのだ\n♪　胸も、身体も、アソコも濡れて手遅れならもう気にしない……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0303405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「かけてくれっ、精液でびちゃびちゃになりたい……！　あああっ、貴方の臭\nい……♪　精液の臭いのする汁アイドル……♪　はぁ、はぁ、はぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0303406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「こんなアイドル、もはや誰も推せないではないか……♪　だって、ワタクシ\nは、貴方だけのモノだって……所有物だって知られてしまう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0303407" ]},
		{"command":[ "SETIMAGE", "0", "still_00019403_01_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「でも……それを貴方が望むのなら、ワタクシは喜んで貴方専属のアイドルに\nなろう……。なんて……。もしかして、熟女すぎて……イヤか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0303408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「それなら、なんでもいい。どんな服でも着る……。ん？　……アイドルのま\nまでいい？　そ、そうか。他の者たちに比べれば少々年増かもしれないが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0303409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「貴方が喜んでくれるのなら……もう少し続けてみる。ああ、そうだ。貴方の\n役に立つことこそが、ワタクシの一番の夢なのだからな……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0303410" ]},
