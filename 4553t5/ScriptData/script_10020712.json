{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0167" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_020" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「それじゃあ、段取りを確認するぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010113790001" ]},
		{"command":[ "SETCHARA", "0", "char_00012701_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "スーザンが作戦を説明する。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「サメには爆弾か高圧電流が効くんだ！　この配電盤にワイヤーをつないであ\nる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010113790002" ]},
		{"command":[ "SETCHARA", "0", "char_00012701_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「エサ……隊長につられてサメがでてきたら、そのワイヤーを食わせてやれ！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010113790003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そう。俺はエサになっている。校門前に用意された柱に括りつけられている。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "一緒にいるのはジュンジローと園子。ただ、園子とディアナはこの作戦にあた\nり衣装を入れ替えている。", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000901_01", "0", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "1", "char_00000607_01", "0", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "つまり、ここにいる園子は中身がディアナだ。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「とくにヤツは時間を越えて現れる。となれば、１．２１ジゴワットの高圧電\n流が効くはずだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010113790004" ]},
		{"command":[ "SETCHARA", "0", "char_00012701_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ジゴワット？　電力単位ならギガワットなのではないですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010113790001" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「あ、あれは映画のネタだから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010113790001" ]},
		{"command":[ "SETCHARA", "0", "char_00001801_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「サメの弱点を突いた完璧な作戦だ。ま、さすがアタイのライバルってとこだ\nな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_010113790001" ]},
		{"command":[ "SETCHARA", "0", "char_00009501_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ついでに質問いいかー！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "俺は少し高いところから声をかける。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「なんだ、隊長」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010113790005" ]},
		{"command":[ "SETCHARA", "0", "char_00012701_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「サメに効くのはいいが、俺は無事で済むんだろうなー！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「……サメには効くはずだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010113790006" ]},
		{"command":[ "SETCHARA", "0", "char_00012701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いやサメのことは聞いてねーよ！　人体への影響を聞いてるの、俺は！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「……直ちに影響はない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010113790007" ]},
		{"command":[ "SETCHARA", "0", "char_00012701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「不安しかねえ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ですが、このような役目を園子殿にやらせるわけにはいかないでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113790001" ]},
		{"command":[ "SETCHARA", "0", "char_00000901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ま、まあそうだが！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「難しい話はよくわかんないよー。要は、出てきたところをバチーンとぶっ飛\nばせばいいんだよな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040113790001" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「ま、そういうこったな！　アイツが出てきたところをガブッて食い破ってや\nる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_010113790002" ]},
		{"command":[ "SETCHARA", "0", "char_00009501_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "なんていうか、俺の身の安全がかかっているってのに相変わらず緊張感がない\nっていうか……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040113790001" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「大丈夫。みんなで考えた作戦だもん。絶対うまくいくんだから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_070113790001" ]},
		{"command":[ "SETCHARA", "0", "char_00000607_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「……はい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040113790002" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0167" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_020" ]},
		{"command":[ "SETTEXT", "そんなミーティングを終えてそれぞれ持ち場についた。しかし、サメは一向に\n現れない。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「おい、全然サメが出てこねーぞ！　さっきまでいっぱい出てきてただろーが\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_010113790003" ]},
		{"command":[ "SETCHARA", "0", "char_00009501_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「そもそもサメは頻繁に出るものじゃない。２時間経っても姿をみせないこと\nもあるぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010113790008" ]},
		{"command":[ "SETCHARA", "0", "char_00012701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「やっと出てきても背びれだけということもあるからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010113790009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「……そろそろ映画のネタはいい加減にするのです。……きますよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010113790002" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "俺の目の前で空間に裂け目ができた。そしてぬるりとデッドシャークが現れる\n。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「来ましたぞ、ご主人！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113790002" ]},
		{"command":[ "SETCHARA", "0", "char_00000901_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「縛られてるから手も足も出せねぇっての！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}