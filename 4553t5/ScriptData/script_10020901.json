		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「一方そのころ、大戸岐学園では」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_999_010114050003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そういえば、今日はＥＤＯから新戦力が投入される日だっけか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「そういえば、先日そのようなことを長官殿が言っておられましたな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010114050001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「でも、新戦力ってことは転校生ってことだろ？　そんな話、学園にも来てな\nいようだが……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「あっ、カツマ先生！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010114050001" ]},
		{"command":[ "SETCHARA", "0", "char_00001205_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「カツマ先生、こんにちは」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010114050001" ]},
		{"command":[ "SETCHARA", "0", "char_00001406_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああ……って、なんだ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「これは驚きました。バスですな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010114050002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「どうやら、これがＥＤＯの新戦力のようね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070114050001" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「まさか大型バスが学園に寄贈されるなんて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020114050001" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうだな。しかし、なんだかゴツいバスだなぁ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「みんなこんにちは～。私はマキシマム・オートメーション・メカニカル・ア\nームス」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114050001" ]},
		{"command":[ "SETCHARA", "0", "char_00021201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「頭文字をとって、Ｍ．Ａ．Ｍ．Ａ（ママ）よ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114050002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「このバス喋るのか！　もしかして、お前もＭ．Ｏ．ＥみたいなＡＩ搭載型車\n両なのか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「その通り、私もＡＩ搭載車両なの～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114050003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「こいつは驚いた。てことは、運転技術とか、車内の居心地の良さは折り紙付\nきだな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「うふふ、隊長さんは褒めるのが上手ね～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114050004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「せっかくだから、乗ってその辺をドライブしてみるか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「お安い御用よ～。さ、乗って乗って～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114050005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「カツマちゃん、迎えに来たわ～……って、カツマちゃん！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114050001" ]},
		{"command":[ "SETCHARA", "0", "char_00011101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「な、なにあのバス！　カツマちゃんを乗せて、どこへ行くつもりなの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114050002" ]},
