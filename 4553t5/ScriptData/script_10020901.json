		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "円盤少女Ａ" ]},
		{"command":[ "SETTEXT", "「ちょっとリーダー、真面目にやってよ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_010114050013" ]},
		{"command":[ "SETCHARA", "0", "char_00016201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "円盤少女Ｂ" ]},
		{"command":[ "SETTEXT", "「リーダー！　アへ顔して～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_010114050013" ]},
		{"command":[ "SETCHARA", "0", "char_00016301_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「それは後でしてやるから！　いい作戦を思いついたから、今から準備をして\nくるぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010114050024" ]},
		{"command":[ "SETCHARA", "0", "char_00015601_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「今度の作戦は私至上最高傑作だ！　これなら、連中をギャフンと言わせられ\nるぞ！　ははははは！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010114050025" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "円盤少女Ａ" ]},
		{"command":[ "SETTEXT", "「ああっ、リーダー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_010114050014" ]},
		{"command":[ "SETCHARA", "0", "char_00016201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "円盤少女Ｂ" ]},
		{"command":[ "SETTEXT", "「んも～。ああやってフラグを立てるからいつも失敗するんだよ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_010114050014" ]},
		{"command":[ "SETCHARA", "0", "char_00016301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
