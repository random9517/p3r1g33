		{"command":[ "SETCHARA", "0", "char_00015601_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "円盤少女Ａ" ]},
		{"command":[ "SETTEXT", "「へいかは今度いつ会えるの～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_010114050004" ]},
		{"command":[ "SETCHARA", "0", "char_00016201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "円盤少女Ｂ" ]},
		{"command":[ "SETTEXT", "「へいかはこっちこないの～？　いっしょにすいーつ食べようよ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_010114050004" ]},
		{"command":[ "SETCHARA", "0", "char_00016301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「ああ、余のお仕事が終わったらな。それまではリーダーに遊んでもらってい\nなさい」", "NORMAL" ]},
