		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「すみませんっ！」", "NORMAL" ]},
