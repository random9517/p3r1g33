		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「さて、今日の悪の女幹部ペリジーニュームーンは襲来者（インベーダー）た\nちの母艦からはじまる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_999_010114050001" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「リーダーよ。お主たかが次元一つの侵略にいつまで時間をかけているのじゃ\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100114050001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「も、申し訳ございません。インクレディブル・スクワッドが手ごわく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010114050001" ]},
		{"command":[ "SETCHARA", "0", "char_00015601_01", "4", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「その話はもう聞き飽きたわ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100114050002" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「申し訳ございません！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010114050002" ]},
		{"command":[ "SETCHARA", "0", "char_00015601_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「これ以上、失態を重ねるようならば、余としてもお主の処分を考えなければ\nならぬ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100114050003" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「そ、それは……つまり……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010114050003" ]},
		{"command":[ "SETCHARA", "0", "char_00015601_01", "4", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「退職？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100114050004" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「ここでの退職は、すなわち『死』を意味するのだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_999_010114050002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「で、ですが我々も、実績はありますので！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010114050004" ]},
		{"command":[ "SETCHARA", "0", "char_00015601_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「確かに、お主にしては大きな実績が一つある。ルナルバースを自爆させたの\nは素晴らしい成果じゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100114050005" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「ありがとうございます……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010114050005" ]},
		{"command":[ "SETCHARA", "0", "char_00015601_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「だが、いつまでも過去の実績にすがっていていいと思うでないぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100114050006" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「き、肝に銘じておきます……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010114050006" ]},
		{"command":[ "SETCHARA", "0", "char_00015601_01", "4", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "sbg_0150" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "円盤少女Ａ" ]},
		{"command":[ "SETTEXT", "「リーダー、お話終わった～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_010114050001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "円盤少女Ｂ" ]},
		{"command":[ "SETTEXT", "「ざこざこリーダーなのに私たちを待たせるなんていい度胸」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_010114050001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「お、お前たち！　まだ通話は終わってない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010114050007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "円盤少女Ａ" ]},
		{"command":[ "SETTEXT", "「あっ、へいかー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_010114050002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「おほ～。少女たち、元気にしてたか～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100114050007" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "円盤少女Ｂ" ]},
		{"command":[ "SETTEXT", "「元気だよ～。へいかも元気～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_010114050002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "円盤少女Ａ" ]},
		{"command":[ "SETTEXT", "「あのね、この星には美味しいものがいっぱいあるの～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_010114050003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "円盤少女Ｂ" ]},
		{"command":[ "SETTEXT", "「和菓子、駄菓子、こんびにすいーつ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_010114050003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「甘いものばかりじゃないか。ちゃーんとバランスよく、お肉やお野菜も食べ\nないとメッだぞ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100114050008" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「本当、こいつらには甘いんだから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010114050008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
