		{"command":[ "SETCHARA", "0", "char_00016301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「これから私は次の作戦を考えないといけないのだ！　こんどこそ、連中を倒\nしてやる！」", "NORMAL" ]},
