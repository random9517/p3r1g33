		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「こうやってオシャレをして出かけた先で、エッチな視線を向けられたことが\nあるのか知りたかった？　はぁ……まあ、そうですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0303102" ]},
