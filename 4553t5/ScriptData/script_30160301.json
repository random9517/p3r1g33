		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「んっ♪　んんっ、んっ、んん……！　フフフ……♪　いつ見てもすごい量…\n…。見て。浴衣もドロドロになっちゃってる……。はぁああ……っ♪」", "NORMAL" ]},
