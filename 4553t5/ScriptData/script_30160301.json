		{"command":[ "SETIMAGE", "0", "still_00001603_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「私も、それに応えるように……いいえ、それを凌駕するほどに激しくお返し\nしてみせます。んふっ♪　強く乳圧をかけて……胸をまとわりつかせて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0303120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
