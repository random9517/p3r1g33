		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「どおっ……？　これくらい？　そうよね、あなたはこうやって強引に絞られ\nるのが大好きよね……♪　もっともっとしてあげる……堪能しなさい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0303213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「んぁっ……♪　あぁっ、はぁ、はぁ、はぁっ……！　くふっ♪　んん……ん\n－っ……んんっ♪　あんっ♪　んっ、んん～っんん……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0303214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「どんどん腰が速くなってきている、わよ♪　あっ♪　煮えた鉄の棒みたいに\n熱いオチンチンっ……もっと打ち付けて、激しく突き上げて……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0303215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「可能な限り限界までザーメン溜めて、一気に解き放つのよ……？　いいわね\nっ……！　あぁっ♪　すごいっ……胸とオチンチンがぶつかりあって♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0303216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「今にも胸肉が弾け飛びそうっ……！　はぁっ♪　なんて強いオチンチンなの\n……っ！　どんどん好きになってくる、欲しくなってくる……ああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0303217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「あぁ……♪　やだ、胸でしてるだけなのに、私の方がイッてしまいそう……\n！　ねえっ、あなたも一緒にイッて……！　一緒にイキましょ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0303218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「あっ♪　あっ、そうしてくれるなら……射精する場所を好きに選ばせてあげ\nるわ。あっ♪　どこに出したいの……？　特別に濃いあなたの精子♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0303219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「どこにビュルビュル注ぎこんで、真っ白に染めてくれるのか……。あっ♪　\n本当に楽しみ♪　あんっ、んんっ、聞かせて……どこに出すつもり……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0303220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「んっ……もう一度、私の胸に出したいの……？　いいわよ。全力で射精して\n……♪　私の胸の中にあなたのザーメンを炸裂させてぇ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0303301" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「んっあああああっ♪　あああああっ……！　来たわっ……また、胸の中に…\n…！　奥にまでしっかりザーメン届いてるぅうっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0303302" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001603_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「ドクッドクッて脈打って……熱いザーメンをまきちらして……！　ああぁあ\nっ！　胸に二回も中出しされたら……あぁっ！　私だってイクぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0303303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「んんんんん～っ、んん……！　あは……♪　どういうことなの？　二回目の\n方が量が多いみたいだけど？　あんっ、まだ出てる……すごく元気だわ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0303304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「あふっ♪　んふっ、んぁんんっ……んん……！　はぁあああ……♪　本当に\n、胸の谷間をオマンコがわりにしてくれちゃって……すごすぎるわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0303305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「あぁっ……♪　こんなにザーメン臭い胸をした女……このお祭りのどこにも\nいないわよ。帰り道で絶対にバレてしまうわ。んふ……♪　胸に……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0303306" ]},
		{"command":[ "SETIMAGE", "0", "still_00001603_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「何度も何度も、執拗に中出しされたんだって。精液で何重にもマーキングさ\nれてきたんだって……。変態女だと思われてしまうかもしれない……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0303307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「……そこまで言うのなら、すぐにこれを拭きとらないのか？　それは愚問よ\n。私にとってはこの精液は……お祭りより、おろしたての浴衣より」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0303308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「ずっと価値があるものなの……。しばらくは、この臭いと熱に浸ってうっと\nりさせてもらえるかしら……。あぁ……これよ、あなたの臭い」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0303309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「今日、祭りに来て本当に良かったわ。そうね、たまには……こうやって、普\n段とは違う場所と服で、ハメを外すのもいいかもしれないわね……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0303310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「あらやだ……♪　あなた、私の顔をザーメンで汚したいの……？　はぁっ、\nはぁ、いいわよ。やってみせなさい。私をこのまま喜ばせてっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0303401" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「んぅっ……♪　熱いザーメンシャワー……すごいわっ……！　もっとよ、も\nっとかけて……浴びせて♪　んんっ、ありったけちょうだいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0303402" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001603_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「んぷ……っ、顔中をベトベトにされて……。せっかくセットしてきた髪にも\nザーメンを注がれて、あっ♪　困るはずなのに……私、私っ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0303403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「顔にかけられながら絶頂しちゃうわ……！　はぁっ♪　あぁあああ……！　\n気持ちいいっ、あなたの体温に包まれるのが最高にいいのぉっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0303404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「あんっ♪　んんっ……びちゃびちゃかけてっ……！　溺れてしまうくらいっ\n……！　あっ♪　あぁっ……目の前が真っ白になっていく……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0303405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「んっ……んふっ……♪　心から満たされていくこの感じ……クセになってし\nまいそう……♪　あっ♪　口に入った精液が苦くて……おいしい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0303406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「ぴちゃ……ちゅぷ、くちゅ……ごくっ……。ぷは……♪　まったく、外だと\nいうのにこんなに大量に射精して……怖いもの知らずね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0303407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「それとも、良い意味でとらえれば……大物なのかもしれないわ。恐れを知ら\nず、皆から恐れられる私にこれだけの精液をぶちまけて……フフ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0303408" ]},
		{"command":[ "SETIMAGE", "0", "still_00001603_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「今日は浴衣だったけど、もっと別の服でしたら……またその時も違う反応が\n見られるのかしらね？　そう思うと、イベントごとって楽しいわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0303409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「これからも、私に色んな射精を見せてちょうだい。そうやって、二人で時を\n重ねていけば……って、ゴホン。これはまた、べ、別の話ね……」", "NORMAL" ]},
