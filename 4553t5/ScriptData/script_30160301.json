		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「こ、こんな場所に呼び出して……浴衣を褒めるのかと思えば、おっぱいが気\nになって、ですか。まったく……性欲の強い人ですね」", "NORMAL" ]},
