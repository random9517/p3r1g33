		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「それなのにオチンチンをパンパンに腫れあがらせて……。わ……私の胸があ\nたたかくて心地いいから？　んっ……そ、そうなんですね……」", "NORMAL" ]},
