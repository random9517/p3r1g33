		{"command":[ "SETIMAGE", "0", "still_00001603_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「祭りの間中、ずっとそうして大きくしていたんですか？　私がお祭りを……\n。あっ♪　純粋な気持ちで楽しんでいる時に……。あっ、ンッ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0303112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「卑猥なことを考えて、股間を膨らませて……。んっ、んんっ……。ほ、本当\nにどうしようもない人ですね……。んぅっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0303113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「あぁっ、太くて、長くて……力を緩めるとボロンと胸の谷間から逃げ出しそ\nう……。はぁ、はぁ、こうなることを期待して勃起していたなんて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0303114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「その時のあなたのことを想像すると、私も……っ、ふぅっ♪　少し興奮……\nします。ずっとこの胸を見て、オチンチンを入れることを考えていたなんて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0303115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「せっかく着付けてきた浴衣をっ……あっ♪　性的な目でジロジロと眺めまわ\nされて、視線で犯されていたなんて……♪　はぁっ、あっ、ぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0303116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「恥ずかしい……。なのにどうして？　身体が熱くてたまらないんです。んっ\n……あっ♪　あっ、あっ……♪　んんっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0303117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「私に胸でしごかれるだけじゃなくて、自分でもこの穴を突きたい、ピストン\nしたいんですか？　別にいいですけど……。そうですか……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0303118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「フフ……♪　そぉんなに私の胸が好きだなんて……♪　少しサディスティッ\nクな気分になってきてしまいました。どうぞ、好きに犯してください？」", "NORMAL" ]},
