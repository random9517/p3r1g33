		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「どうしましょうっ……！　この肉と肉とのぶつかり合いがだんだんっ……気\n持ち良くなってきてしまいました……はぁっ、声を抑えないと……っ♪」", "NORMAL" ]},
