		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「あなたの出したての精液、ホカホカして気持ちいいわ……♪　この、立ちの\nぼる青臭いニオイ……♪　こんな臭いさせて祭りを歩けないでしょうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0303138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「ああ……もったりした重くて粘り気の強い精液……♪　私の胸から離れたく\nないって、べーったり張りついてる……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0303139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「この、しつこくて真っ白なザーメン……私の胸に思う存分出した罰を与えな\nくちゃいけないみたいね。えぇ？　私が出せって言った？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0303140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「そんな昔のこと、もう忘れたわ。ねえ……？　あなただって、一発ドクドク\n放出しただけじゃあ、不完全燃焼でしょう……？」", "NORMAL" ]},
