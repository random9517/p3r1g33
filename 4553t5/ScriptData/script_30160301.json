		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「これでも清楚に見えるように、色々工夫したんですよ？　でも……仕方あり\nません。あなたがこの胸でしてほしいと願うのなら……。んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0303105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「してあげないこともありません……。でも、誰にも言わないでくださいね。\n私は教員。乱れてばかりでは、生徒にしめしがつきませんから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0303106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「んっ♪　ほ、ほら……どうですか？　って、いやだ♪　どうしてそんなに硬\nくしているんです。まだ、谷間にギュッと挟んだだけじゃないですか」", "NORMAL" ]},
