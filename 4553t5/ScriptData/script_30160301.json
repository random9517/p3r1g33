		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「すぐ近くに人の気配がする、のに……♪　はぁっ、はぁ、すぐ裏で胸を丸出\nしにして……オチンチンを気持ち良くしているところを見られたら……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0303129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「困ります、困るのに……！　っんんんっ……！　だめ、火照って……っ！　\nやめられないです、あんっ♪　あんっ、とっても気持ちがよくて……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0303130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「あっ、あっ♪　自然に前のめりになって……胸でオチンチンをぎゅうぎゅう\nに締め付けてしまう……！　っんっ……！　あぁ、あっ、あっあっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0303131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「オチンチン、だいぶ気持ち良くなってきたんですね？　お見通しですよ……\n先走りの汁がヌチャヌチャ音をたてて、います……！　はぁあっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0303132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「本当に……射精したがりの悪いオチンチン……っ！　でもいい、ですよっ…\n…あっ♪　限界まで快感を溜め込んでください……そしてっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0303133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「この胸に思いっきりぶちまけて……♪　ね……？　びゅるびゅるしたいんで\nしょう？　私の胸の肉に覆われて、熱い脂肪に絡みつかれて……あっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0303134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「この野蛮なオチンチンから精液っ……白濁液をビュクビュク放出したいんで\nしょうっ！　さあ……さあ、早く♪　早くかけて……♪　んああああっ♪」", "NORMAL" ]},
