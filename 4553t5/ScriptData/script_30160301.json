		{"command":[ "SETIMAGE", "0", "still_00001603_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「私、今のあなたの射精で完全に火がついちゃったの。このまま二回戦……お\n願い出来るわよね？　……あっ♪　ほら、オチンチンも応えてくれてるわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0303202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「もう一度したい、私の豊満なおっぱいでニュルニュルされたいって……♪　\n交渉成立ね。ん……、ザーメンをたっぷり潤滑油代わりにして……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0303203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「今度は最初から本気でいくわよ？　ほぉら……ほら、萎えるなんて許さない\nから……。無理やりにでも完全に勃起させて……フフフフッ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0303204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「こう、やって♪　前後左右に胸を揺らしてあなたのオチンチンを丸呑みしち\nゃうのっ♪　あっ♪　あぁっ、難点は私も感じてしまうことだけどっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0303205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「今更やめるだなんて言わないでしょう……？　っんんんんぅうう……♪　あ\nなたの精液が私の胸に塗りこまれて……不思議な感じ、だわ……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0303206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「まるでこの胸で……あんっ、本番行為を……セックスを、子作りをしている\nみたいっ……！　ぐちゅっ、ぐちゅってかきまぜられて……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0303207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
