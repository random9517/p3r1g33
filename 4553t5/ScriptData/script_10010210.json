		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「んなこと言われましても！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "ただでさえ全員、俺の指示を聞くようなタマじゃねえし！　異世界のウサ耳姉\n妹と張り合ってる今は、特にそうなんですけど！？", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「だいたい、なんでオレたちがこいつらと連携しなきゃならねえんだよ！　マ\nッポーサムライはこっちの獲物だって言ったろうが！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "PLAYVOICE", "097_010102160003" ]},
		{"command":[ "SETCHARA", "0", "char_00009701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「なにを言うか！　我々の脚を引っ張ってばかりのくせに！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010102160004" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「あー！　なにその言い方ー！　さすがのあーしもカチン！　と来るよー！？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "099_010102160003" ]},
		{"command":[ "SETCHARA", "0", "char_00009901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「本当のことじゃないか！　お前たち、ない頭をちっとは使ったらどうだい！\n」", "NORMAL" ]},
