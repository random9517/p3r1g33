		{"command":[ "SETIMAGE", "0", "still_00000512_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ……んふっ、貴方の出し残しはありませんか……？　後から言うの\nは駄目ですよ？　ちゃんと、出し切っちゃうです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1203305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んぁっ……！　あふっ……やっぱり残してました……ちゅぷ、れろ……今日\nの精液は全部ウチのですからね……ぴちゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1203306" ]},
		{"command":[ "SETIMAGE", "0", "still_00000512_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「れろ……ぺろ、終わりましたか……？　ふふ……２回目のイタズラも、無事\nに完了です……あ、ちゃんと綺麗にしますからね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1203307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ぺろ、れろ……いっぱい精液をくれたオチンチンにお礼です……れろ、ちゅ\nぷっ……はい、綺麗になったです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1203308" ]},
		{"command":[ "SETIMAGE", "0", "still_00000512_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ふはぁ……はぁ……んっ、それにしても、いっぱいイタズラしたのに、お菓\n子以上のものをいっぱい貰ってしまいました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1203309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
