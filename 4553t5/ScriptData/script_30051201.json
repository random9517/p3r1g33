{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ちゃんと来た……ですね。いい度胸です……褒めてあげる……ですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1203101" ]},
		{"command":[ "SETCHARA", "0", "char_00000512_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「用件なんて……決まってます。ハロウィンの挨拶をしたというのに、お菓子\nを用意してなかった貴方にイタズラするですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1203102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「さあ、分かったでしょう。分かったなら、いいからとっととズボンを脱ぎや\nがれですっ、オチンチン……見せるですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1203103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ひぁぁっ！　しっかり……大きくさせてるじゃないですかっ。全く……準備\nのいいオチンチンですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1203104" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00000512_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「どんな風にイタズラするか……もちろん、分かっていますよね？　んっ……\nそうです……このやんちゃな勃起オチンチン……舐めてやるですよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1203105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「れろっ、んっ……えろっ……れろ……ぴちゃ……んっ、ちゅぱっ……れろっ\n、えろぉっ……れろんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1203106" ]},
		{"command":[ "SETIMAGE", "0", "still_00000512_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んふふ……どうですか？　ウチの舌のザラッとした所が……オチンチンの敏\n感な場所に当たりますよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1203107" ]},
		{"command":[ "SETIMAGE", "0", "still_00000512_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ちゅぷっ、ぴちゃ……んちゅぷっ、れろ……んんっ……まずは、この剥けて\nる所を……満遍なく舐めますから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1203108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「れろぉ……んりゅっ、れるっ……えろっ、れろんっ……んふぅ……あぁ……\nくんっ、くんくんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1203109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「うぅ……それにしても、いつ嗅いでも……すごいニオイです……こんなの嗅\nいで、まともな神経でいられる訳ありません……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1203110" ]},
		{"command":[ "SETIMAGE", "0", "still_00000512_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「はぁぁ……んっ、くんっ……くんくんっ……あぁぅ……おかしくなるです…\n…トロトロになるですぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1203111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、駄目です、こんなことではいけません。今日は、ウチがちゃ\nんとイタズラするんですからぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1203112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「オチンチン……ちゅぱっ、れろ……んんっ、えろ……れろ……んりゅっ、れ\nる……んぁ、はむ……んちゅぷぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1203113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「亀頭……全部濡れましたね……？　じゃあ……もっと深く咥えひゃいまひゅ\n……んちゅぷぅ……れるぅ、りゅぷう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1203114" ]},
		{"command":[ "SETIMAGE", "0", "still_00000512_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んぐぅ……はぁ、大きいです……このおちんちん……全部……食べきれない\nれふぅ……くぽっ、んむぐぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1203115" ]},
		{"command":[ "SETIMAGE", "0", "still_00000512_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んむっ……じゅぷりゅっ……くぽっ、れる……んりゅう……れる……れろぉ\nんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1203116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「味も……んっ、やっぱり複雑れふね……ちゅぱっ、くぷっ、何か……いい例\nえが見つかりませんが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1203117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ただ、じゅぱっ、んっ……慣れるまではクセが強くて……慣れたらハマるよ\nうな……珍味のように思えます、りゅぱっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1203118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んふっ、別に本当に食べたりはしませんです。舌でイタズラはいっぱいする\nですけど……れろ、んりゅ……れるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1203119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んんぅ……あぁ……おしゃぶりしてるうちに……ウチも疼いて……仕方なく\nなってます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1203120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「はぁ……あぁっ……オマンコがウズウズするです……はぁんっ、指……中に\n……入れちゃいますぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1203121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んぁぁ……ちゅぷっ……あぁ……ジンジンしてます……んんぅ……オマンコ\n……オチンチン舐めてるだけで痺れてますぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1203122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んっ、駄目です。あまり見ないで下さい……それでなくても、この格好……\n大胆で恥ずかしいんですからぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1203123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「それでも……こうして、見せてるのは……貴方だから……本当に特別なんで\nすからぁ……んっ、ちゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1203124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「はぁん……な、何ですか……ウチが素直になったら、何かおかしいですかっ\n……いいじゃないですか……ちゅぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1203125" ]},
		{"command":[ "SETIMAGE", "0", "still_00000512_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「余計なことを言わないで……りゅぷっ、ちゃんとオチンチンに集中して下さ\nいっ……りゅぱっ、じゅぽっ、くぷぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1203126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んんっ、はぁ……んくっ、でも……やっぱりドキドキします……こんな、オ\nナニーしながらフェラチオなんてぇ……やらし過ぎます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1203127" ]},
		{"command":[ "SETIMAGE", "0", "still_00000512_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「こんなに大胆になったのも……ハロウィンのせい……いえ、やっぱり貴方の\nせいですからね……ちゅぷっ、責任取って欲しいです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1203128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あっ……オチンチン、ピクンって……今の言葉に反応したですか？　なら、\nれろっ、ぴちゃ……もっと……んくぷぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1203129" ]},
		{"command":[ "SETIMAGE", "0", "still_00000512_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「はぁぁ……んっ、んりゅっ……れろっ、あぁ……出てきましたね……我慢汁\n……ちゅぷっ、んんっ、少ししょっぱいです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1203130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んふっ、こうなったらもう……近いですよね？　りゅぷっ、分かってますよ\n……れろ、んちゅぷっ……ほら、腰もビクビクして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1203131" ]},
		{"command":[ "SETIMAGE", "0", "still_00000512_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ、じゅぽっ、くぷっ、んじゅるるっ……あむ、ぴちゃっ……観念し\nて、精液……出すですっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1203132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ウチもっ……んふっ、一緒に気持ちよくなりまひゅからっ……んんっ、ほら\nぁ……オマンコ、クチュクチュですからぁっ、貴方も……んぱっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1203133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「さあ……んじゅるるるっ、のまへてっ……くらひゃいっ、じゅぽっ、んじゅ\nぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1203134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んんんんーっ！　んふっ、れてっ……きまひたっ……濃いのっ、んくぅぅぅ\nっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1203135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000512_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「こくっ、んくっ、んんっ……ふごく……おいひぃれふぅ……精液ぃ……んち\nゅぷぅっ、んく……んっ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1203136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ぷぁっ……はぁ、はぁっ、はぁっ……一息に、飲んじゃいまひた……ちゅぷ\nっ、れろっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1203137" ]},
		{"command":[ "SETIMAGE", "0", "still_00000512_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んっ、まだ少し残ってまひゅ……ちゅぱっ……綺麗にしちゃいまひゅからね\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1203138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「れろ、ぴちゃ……んちゅぷっ、んえろぉっ……はい、これで大丈夫ですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1203139" ]},
		{"command":[ "SETIMAGE", "0", "still_00000512_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ふふ……オチンチン気持ちよかったですか？　ウチのご奉仕がダメだったな\nんて言わせないですけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1203140" ]},
		{"command":[ "SETIMAGE", "0", "still_00000512_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「それにしても……んっ……いっぱい出したクセに、まだまだオチンチン……\n元気いっぱいですね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1203201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「いえ、分かっています。これはウチのイタズラが、十分ではなかったという\nことでしょう。ですから、このまま続きをしちゃいます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1203202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あっ……オチンチンが跳ねましたよ？　ふふん……やっぱり期待していたん\nじゃないですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1203203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「慌てないでも大丈夫です。じっくりしてあげますから……ちゅぱ……んちゅ\nぷ、ぴちゃ……んちゅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1203204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んふぁ……精液のにおいがいっぱい残ってますぅ……このオチンチン……間\n違いなくさっきより美味しくなっちゃってます……ぴちゃ、ちゅぱ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1203205" ]},
		{"command":[ "SETIMAGE", "0", "still_00000512_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……はぁぁ……くんっ、くんくんっ……こんなの駄目です……発\n情するに決まってるじゃないですかぁ……んふぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1203206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んっ、あっ……また手が……動いちゃいます……んんっ、あぁ……ウチのオ\nマンコも……ヌルヌルになっちゃってますぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1203207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あっ……だからじっと見るのはぁ駄目ですってばぁ……ウチがエッチなこと\n……全部バレちゃいますからぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1203208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「貴方は……ちゅぷっ、ぴちゃっ、もっとオチンチンのことだけ意識して下さ\nい……ちゅぱっ……れる、れろぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1203209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んちゅぱっ、この裏筋のところとか……カリのところとか……ぺろっ、れろ\nぉ……弱い所だらけですよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1203210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ぴちゃ……んふぅ……ウチのイタズラ……気持ちいいですか？　んちゅぅぅ\n……えへへ、もっとしてあげるですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1203211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「れろっ、んちゅぱっ……れろぉ……んふっ、あぁ……ウチも気持ちいいです\n……オマンコが……ウズウズしちゃいますぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1203212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んふぁ……あぁ……れろ、ぺちゃ……んちゅぷぅ……先っぽから汁が垂れて\n……はぁぁ……ウチのオマンコもじゅくじゅくしてます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1203213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「はぁっ、こ、このままだと……ウチ……オマンコイッちゃいます……んふぁ\n……指ぃ……止めないと駄目なのにぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1203214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あっ、んぁっ、いいんですか？　貴方も……また出そうだから……一緒に…\n…は、はいッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1203215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んっ、じゃあ……一番気持ちいいとこするれふっ、じゅぽっ、ちゅるるるっ\n……貴方のオチンチンの好きなとこぉ……チュッチュするれすぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1203216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ちゅるっ……また、お汁溢れてぇ……くんくんっ……はぁぅっ……ウチの指\nもっ……止まらなくてぇっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1203217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「じゅぱっ、あぁっ、オチンチンも限界でひゅかっ？　先っぽ、ピクピクして\n……出したがってますっ……んちゅぷっ、りゅぷっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1203218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「はいっ……イッて下さいっ……！　ウチも一緒にイキますからぁっ！　んっ\n、ちゅぷぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1203219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「おくひでもっ……顔れもっ、いいとこにっ……びゅびゅって出してくらひゃ\nいぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1203220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ころまま……口にっ……ひゃひっ、お願いひまひゅうっ……んっ、ちゅぷっ\n、りゅぷっ……じゅるるるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1203301" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んふぅぅぅっ！　んむっ……れてっ……まひゅっ！　んくっ、こくっ、んっ\n、んくんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1203302" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000512_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んっぷ……二発目らのに……んんんっ、まら……こんらに出るなんへぇ……\nんっ、ちゅぷっ、こくんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1203303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「はぁ、んんっ……はい……ウチも一緒に、イキましたぁ……今も……ちゅぷ\nっ、精液の味でぇ……はぁ、オマンコヌルヌルになってますぅ……」", "NORMAL" ]},
