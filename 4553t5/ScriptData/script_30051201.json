		{"command":[ "PLAYVOICE", "v2_005_1203401" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んぁぅんっ！　あぷっ……出たですっ！　元気いっぱいの射精っ……また来\nてまひゅうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1203402" ]},
