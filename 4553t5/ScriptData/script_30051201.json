		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あふぁっ……あぁ……濃いのがヌルってぇ……はぁぁ、むわっとするこのニ\nオイ……ずっと嗅いでたらだめれふ……イ、イキますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1203403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んふぁぁ……あぁ……ウチもイッちゃいました……こんな、貴方のニオイで\nマーキングされたらぁ……オマンコぐずぐずになっちゃうですぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1203404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んっふ……まだ出るですか？　はい……残しておかないで、スッキリして下\nさい……オチンチンほっぺにくっつけてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1203405" ]},
		{"command":[ "SETIMAGE", "0", "still_00000512_01_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あふっ……最後の出てきました……んちゅっ、はぁぁ……ドロっとしてます\n……こくっ、ぺろっ……ウチはこの味が病みつきなんですぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1203406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んっ、ちゅぱ……今度こそ、終わりですか……？　待って下さいね、お掃除\n……ちゃんとしちゃいますからぁ……れろ……」", "NORMAL" ]},
