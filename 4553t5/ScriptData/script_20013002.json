{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0126" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ほらほら、どうしたのよ！　いいから、何を困ってるのか教えなさい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020022310001" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、実はな……バレンタインのことをセレインが知らないって言うから、\nどういう風に説明したものかとな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「バレンタイン……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020022310002" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「けどまあ、マーガレットが教えてくれるってんなら、女同士その方がいいか\nらな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「せっかくだし、ぜひセレインに教えてやってくれ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人、上手く逃げおおせましたな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022310001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うるせ。結果オーライならいいんだよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「なーんだ、そういうことだったのね！　えっと、バレンタインっていうのは\n……多分……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020022310003" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ん……？　多分？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「そう、きっとバレンタインは武器のことよ！　なんか言葉もそれっぽくてカ\nッコいいし！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020022310004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「へっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「えっ、武器のことだったのか！？　私はてっきり敵のことだと思ってたぞ！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_030022310001" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「その気持ちは分からなくもないわ！　でも、わたしは知ってるの！　ゲーム\nとかでもバレンタイン武器とか出てた気がするし！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020022310005" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「武器！？　どんなタイプのヤツなんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_030022310002" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「えーっとね、多分剣とか斧とか、そーいうやつじゃないかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020022310006" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人……これは」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022310002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「言うな……そういや、マーガレットも底なしのアホだった……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「っていうか、何だよバレンタイン武器って……！　何のゲームしたら、そん\nなモンが出てくるんだ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「何も分からないまま、あれだけ話を発展させられるのも才能ですな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022310003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「うーん……剣に斧かー。使えなくもないけど、私はやっぱり棒が一番しっく\nり来るからなー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_030022310003" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「あら、棒でもいいんじゃない？　確か、色々パワーアップもするって聞いた\nことあるし！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020022310007" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「ホントか！？　じゃあ、バレンタインってので、私の『王王棒』も強く出来\nるかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_030022310004" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「出来るでしょー！　なんか、そういう雰囲気ありそうだし！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020022310008" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「おぉぉー！　『王王棒』が強くなったら、いよいよ私は無敵じゃんか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_030022310005" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「あら、強くなるの！？　なんか、すごいことになりそうね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020022310009" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「きっとすごいぞ！　うーーっ、そうとなったら、こいつはじっとしてらんな\nいな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_030022310006" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「やべぇな……これ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ツッコミがいないと、果てしなく暴走を続けるということが今証明されてし\nまいましたな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022310004" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「あ……そう言えば……バレンタインには、どうやらチョコが関係してるらし\nいって話も聞いたことあるわ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020022310010" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「急に軌道修正した！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「チョコ？　チョコって、チョコレートのチョコか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_030022310007" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「そうよ！　甘くて黒いチョコレート！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020022310011" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「うーん……でも、武器とチョコがどういう風に関係してくるんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_030022310008" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「そうね……確かに直接的な関係はなさそうだし、不思議な話ね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020022310012" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「不思議にしてるのはお前だろうが……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人、聞こえないように言っても伝わりませんぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022310005" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「そうだわ！　とりあえずチョコは黒いんだし……ということは、流々那が詳\nしいはずね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020022310013" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「どういう理屈だ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「とりあえず、流々那に聞いてみれば万事解決する筈よ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020022310014" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「そっか！　よしっ、それじゃ早速流々那に聞いてみるか！　って……どこに\nいるんだっけ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_030022310009" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「今の時間なら、まだ教室じゃないかしら。せっかくだし、チョコのこと色々\n聞いてみましょう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020022310015" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「おっし、行くか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_030022310010" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「バレンタインのことじゃなくてチョコのことを聞くのか……あぁ……もう何\nが何やら……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人。あの二人を野放しにしてはいけませんぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022310006" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「くそっ、やっぱり面倒なことになりやがった。このままだと、あいつら果て\nしなく暴走しやがるからな。追うぞ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}