{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0150" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「乱杰李威（らんじぇりい）だ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_020113930001" ]},
		{"command":[ "SETCHARA", "0", "char_00002502_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「乱杰李威だ、乱杰李威だ、乱杰李威だ！　お前は乱杰李威仏斗暴羅亜（らん\nじぇりい・ふっとぼうらあ）になるのだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_020113930002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「ウオォォォォォォーン！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113930001" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「まさか、暴走？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010113930001" ]},
		{"command":[ "SETCHARA", "0", "char_00001701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「勝ったな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_020113930003" ]},
		{"command":[ "SETCHARA", "0", "char_00002502_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「はああぁぁぁーっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113930002" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0150" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「はあ、はあ、はあ……はあ……わ、私は、これは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113930003" ]},
		{"command":[ "SETCHARA", "0", "char_00001604_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「なんという……内から漲る力！　私は、新たな力を手に入れられたのかっ！\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113930004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「そうだとも。よくぞ目覚めたな修羅姫よ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_020113930004" ]},
		{"command":[ "SETCHARA", "0", "char_00002502_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「お前は真の乱杰李威仏斗暴羅亜（らんじぇりい・ふっとぼうらあ）として目\n覚めたんだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_020113930005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「これが……！！　この力が、真の乱杰李威仏斗暴羅亜（らんじぇりい・ふっ\nとぼうらあ）……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113930005" ]},
		{"command":[ "SETCHARA", "0", "char_00001604_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「ははっ！！　はは、やったぞ！！　私はついにやったんだ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113930006" ]},
		{"command":[ "SETCHARA", "0", "char_00001604_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「乱杰李威（らんじぇりい）の穴に籠もり、特訓を続けた甲斐があった……！\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113930007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「そうだ。お前は今まさに、乱杰李威（らんじぇりい）のしなやかさ・心地よ\nさ・美しさ、そのすべてを兼ね備えた……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_020113930006" ]},
		{"command":[ "SETCHARA", "0", "char_00002502_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「明日はその力を思う存分、エファナティカにぶつけ、しのぎを削ると良い」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_020113930007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒサイレーン" ]},
		{"command":[ "SETTEXT", "「おや？　明日は学園も休日のはず。エファナティカにぶつけるというのは…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010113930001" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「貴方たちが特訓に音を上げている間に、カツマの居場所を特定したんだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_020113930008" ]},
		{"command":[ "SETCHARA", "0", "char_00002502_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「なのでそこに、果たし状を置いてきたのさ。明日、あの者たちはここへ来る\n。必ずね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_020113930009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「居場所を突き止めたのであれば、助けに行けば良かったのでは？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_010113930001" ]},
		{"command":[ "SETCHARA", "0", "char_00002002_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「そんな簡単に解決しては、私たちの気が晴れないだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_020113930010" ]},
		{"command":[ "SETCHARA", "0", "char_00002502_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「いいかい？　前回と同じ場所、同じ競技、ついでに同じく休日返上までして\nこそ――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_020113930011" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「完全に雪辱を果たせるというものさ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_020113930012" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「リベンジマッチ……という名目で、私怨を晴らしたいだけ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010113930001" ]},
		{"command":[ "SETCHARA", "0", "char_00001801_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「カツマの身柄より私たちの面子なんだよ！　ブラックメルヘンが負けたまま\nでなるものかい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_020113930013" ]},
		{"command":[ "SETCHARA", "0", "char_00002502_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「つまり……私たちはカツマのせいで、貴重な休日を返上させられるのですね\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010113930001" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「そう考えると、やっぱり全部あいつが悪いんじゃねえか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010113930001" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ダイヤナちゃん、明日はゆっくりお休みしたかったんだけどなあ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010113930001" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「各々（おのおの）、腹に抱えた怒りは明日までとっておけ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113930008" ]},
		{"command":[ "SETCHARA", "0", "char_00001604_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「この私についてこい！　その鬱憤、すべて晴らしてやろう！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113930009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「お姉ちゃんがいつになく強気だ……すごい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010113930002" ]},
		{"command":[ "SETCHARA", "0", "char_00001701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「それぞれ理解したね？　では最後の仕上げだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_020113930014" ]},
		{"command":[ "SETCHARA", "0", "char_00002502_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「あの木人形を対戦相手と思って、全力でぶち当たってごらん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_020113930015" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「お任せあれ！　いくぞ、皆！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113930010" ]},
		{"command":[ "SETCHARA", "0", "char_00001604_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「お、おー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010113930003" ]},
		{"command":[ "SETCHARA", "0", "char_00001701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}