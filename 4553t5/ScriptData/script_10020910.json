		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「はははっ、どうやら我々の援軍がきたようだな！　これでお前たちもおしま\nいだー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010114140001" ]},
		{"command":[ "SETCHARA", "0", "char_00015601_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
