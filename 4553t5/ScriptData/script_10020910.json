		{"command":[ "SETCHARA", "0", "char_00002801_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「Ｍ．Ａ．Ｍ．Ａ、このままじゃまずい。なんとか方向転換できないか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「したいんだけど、道幅が狭すぎて……」", "NORMAL" ]},
