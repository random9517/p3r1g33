		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「どうした！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「あらやだ。うっかりしていたわ。出来るわよ、変形」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114140003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「変形までできちゃうの！？　すごいわ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_010114140001" ]},
		{"command":[ "SETCHARA", "0", "char_00002401_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「出来るのかよ！　というか、今まで忘れてたのか！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「バスでいる時間が長いと、つい忘れちゃうのよね～。変形ロボットあるある\nよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114140004" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「知るか！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「でも……ひとつだけ問題があるの。変形すると、中のみんなが放り出されち\nゃうの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114140005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「回収は出来ないから、各々着地してくれるかしら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114140006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「かまわない。いまは一刻を争うからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090114140001" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター" ]},
