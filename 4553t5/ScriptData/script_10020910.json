		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「そういえば、Ｍ．Ｏ．Ｅはロボットモードに変形していたけど、Ｍ．Ａ．Ｍ\n．Ａはそういうことできないの？」", "NORMAL" ]},
