{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ふふっ、トリックオアトリート。楽しい楽しいハロウィンの時間じゃな。さ\nあ、存分に選ぶがいい、トリックか……トリートか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1703101" ]},
		{"command":[ "SETCHARA", "0", "char_00000317_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「こら、どこへ行く。イヤな予感じゃと……？　ふん……甘いな。余から逃げ\nられると思っておるのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1703102" ]},
		{"command":[ "SETCHARA", "0", "char_00000317_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「いや……違うか。逃げるということは、トリックとトリート……両方味わい\nたいということじゃな？　全く、素直じゃない男よ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1703103" ]},
		{"command":[ "SETCHARA", "0", "char_00000317_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "「よかろう、それでは早速、お主のチ〇ポにトリック……たっぷりとイタズラ\nをしてやろうではないか……んっ、むっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1703104" ]},
		{"command":[ "SETIMAGE", "0", "still_00000317_01_01" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ほうら……余のおっぱいに、お主のチ〇ポがズッポリじゃ……生意気なこと\nを言いながら、しっかりチ〇ポは勃起しているようじゃのう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1703105" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「まずは、この正直なチ〇ポに極上の肉圧を与えてやろう……んんっ、谷間の\n中にめり込んでいくぞ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1703106" ]},
		{"command":[ "SETIMAGE", "0", "still_00000317_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んふっ……ビンビンで、しっかり熱くなっておるのう。どうじゃ、お主の大\n好きなおっぱいじゃ……気持ちいいじゃろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1703107" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「くくっ、いつでも本当に正直なチ〇ポじゃな。少し強がろうとしても、分か\nりやすい程に感じて腰砕けになっておる……ほうれ、こうじゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1703108" ]},
		{"command":[ "SETIMAGE", "0", "still_00000317_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んふっ、ずりゅずりゅと……亀頭がズル剥けになっていくぞ？　この調子で\n扱いていたら、あっという間に余のトリートが出そうじゃのう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1703109" ]},
		{"command":[ "SETIMAGE", "0", "still_00000317_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ほれ、ほれ……街もハロウィンで騒がしい……こんな時は、余の血も普通で\nは満足出来ぬと滾ってくるのじゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1703110" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「お主の顔を見ながら、じっくりとパイズリをしてやろう……こうして……ん\nっ、むっ……ふふ……まだ大きくさせるつもりか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1703111" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「よかろう……ならば、もっと蕩けさせてやろう……んむっ、れろ……少し滑\nりやすくして……縦ズリからじゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1703112" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ふっ、はっ、んふっ……あぁ……いい擦れ具合じゃ……おっぱいの中でチ〇\nポの脈動をしっかり感じるのう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1703113" ]},
		{"command":[ "SETIMAGE", "0", "still_00000317_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「じゃが……意外に踏ん張るようじゃな。漏らす時は、あっけなく出す時もあ\nるが……今日は、そう簡単には折れぬというつもりか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1703114" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「いいじゃろう……パイズリだけじゃもの足りぬということならば……このチ\n〇ポ……もう少し可愛がってやろうかのう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1703115" ]},
		{"command":[ "SETIMAGE", "0", "still_00000317_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ふふ、例えばこんなのはどうじゃ？　余の指で……このチ〇ポの先の亀を…\n…グッと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1703116" ]},
		{"command":[ "SETIMAGE", "0", "still_00000317_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「おっと、いい跳ね方をしたのう……そうそう、そういうのじゃ。余は、お主\nが思わぬ快感に腰を浮かせる瞬間を見るのが好きなのじゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1703117" ]},
		{"command":[ "SETIMAGE", "0", "still_00000317_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「爪の先を軽く食い込ませて……ふふ……痛いか？　なぁに、血が出るような\nことはない。ちょっとめり込む程度じゃからな……ほれ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1703118" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「くくっ、ビクビクしておる。可愛い奴め……この正直なチ〇ポの反応こそ、\nお主の魅力よ……ちゅっ、んちゅっ、ちゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1703119" ]},
		{"command":[ "SETIMAGE", "0", "still_00000317_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「こうして優しくしてやるのもよし、少しキツくしてやるもよし……その一つ\n一つに、全部チ〇ポが答えてくれるのじゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1703120" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ、はぁっ……んっ……むっ……本当に元気なチ〇ポじゃ……余の\nおっぱいも、お主の熱でどんどん乳首が凝っていくのが分かるぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1703121" ]},
		{"command":[ "SETIMAGE", "0", "still_00000317_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「この硬くなったところを……んっ！　程よくチ〇ポに押し付けてやると、変\n化があっていいじゃろう？　余も、実に気持ちいい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1703122" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「どうじゃ、何か注文があるなら遠慮なく言うがいい。して欲しいところや、\n気に入らぬところがあったりせぬか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1703123" ]},
		{"command":[ "SETIMAGE", "0", "still_00000317_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「柔らかい感触をもっと味わいたい？　なるほど……例えばこんな感じが好き\nということか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1703124" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「温泉に浸かってるような気持ちよさか……なかなか面白いことを言う。なら\nば、こうして……チ〇ポ全体を湯船に浸してやらんとな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1703125" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「癒やされるか？　じゃが、そうそうホッとさせたままというのも面白くない\nからのう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1703126" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「今度は……また、鈴口をカリカリと……ふふっ、指でくすぐってやるぞ。ど\nうじゃ、このもどかしい感覚……ムズムズするじゃろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1703127" ]},
		{"command":[ "SETIMAGE", "0", "still_00000317_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「触れるかどうかの微妙な感覚……くくっ、またチ〇ポが跳ねたのう。どうし\nた、もっと強く押し付けて欲しかったか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1703128" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「そうじゃ、もっと腰を突き出してみるがいい。欲しかった刺激が得られるか\nも知れんぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1703129" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「おっと、ふふ……お預けじゃ。代わりに根元の方を、じっくりとおっぱいで\nしてやろう……んっ、あふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1703130" ]},
		{"command":[ "SETIMAGE", "0", "still_00000317_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「こうして焦らされながらも、少しずつ快感が溜まっていくと……さっきのく\nすぐったい感じもまた変わってくるぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1703131" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「もう一回、カリカリと……くくっ、同じ強さなのにさっきよりいいじゃろう\n？　チ〇ポ全体が敏感になった証拠じゃ……ここまで来たら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1703132" ]},
		{"command":[ "SETIMAGE", "0", "still_00000317_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ、チ〇ポ全体を大きく扱きながら、亀頭をギュッとしてやろう…\n…ふふっ、いいぞ……我慢汁が溢れてきたのう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1703133" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ほぅら、このままグリグリ扱いてやったらどうなる？　我慢汁が溢れて……\nいよいよ限界のようじゃな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1703134" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「おっと……簡単に漏らすことは許さん。まだじゃ、出したかったら、ちゃん\nとおねだりをする……当然じゃなあ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1703135" ]},
		{"command":[ "SETIMAGE", "0", "still_00000317_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ドプドプ射精したいんじゃろう？　だったら、その通りに言ってみろ。ドピ\nュドピュ射精させて下さいとな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1703136" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "「くくっ、あっさり口にしおって……我慢の効かない奴め。よかろう、ほうれ\nっ、出せっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1703137" ]},
		{"command":[ "SETIMAGE", "0", "still_00000317_01_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んんっ……！　ふふっ、いいぞ……どんどんぶち撒けてしまえ。余のおっぱ\nいが全部受け止めてやろうぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1703138" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ちゅぷっ……ふぅぅ……んむっ、フレッシュで味も申し分ない……これこそ\n、余が求めていたトリートよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1703139" ]},
		{"command":[ "SETIMAGE", "0", "still_00000317_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ふう……ふふ、一気に出したのう。どうじゃ、溜め込んだ分を思い切り吐き\n出した気分は？　たまらなかったじゃろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1703140" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「さあ……調子も出てきたところで、このまま続きと洒落込もうではないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1703201" ]},
		{"command":[ "SETIMAGE", "0", "still_00000317_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ふふ……お主が情けなく射精した時の顔……実に可愛らしかったからな。余\nはアレをもっと見たい。トリックの続きじゃ……んふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1703202" ]},
		{"command":[ "SETIMAGE", "0", "still_00000317_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ほれほれ、ちょっとおっぱいで扱いてやれば……見ろ、またすぐにビクビク\nとチ〇ポを反り返らせて……分かりやすい奴め」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1703203" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「さて……一発出した分、今度はもうちょっと頑張って貰うぞ？　すぐに泣き\n言を言わずに耐える……出来るかのう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1703204" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「なんて……くくっ、出来る、出来ないじゃなく、するんだがの……そら、ま\nた指を食い込ませてやるぞ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1703205" ]},
		{"command":[ "SETIMAGE", "0", "still_00000317_01_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ほぅら……ぎゅうっと……どうじゃ、痛いか？　それとも、この食い込む感\nじが気持ちいいか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1703206" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「くふふっ、少し痛いけど気持ちいいか。やはり、お主には責めだけじゃなく\n、マゾの素質も備えておるようじゃな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1703207" ]},
		{"command":[ "SETIMAGE", "0", "still_00000317_01_11" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ただ痛いだけでなく、その奥に少しだけ残るギリギリの快感……それを、し\nっかりと楽しませてやろう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1703208" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ほれ、ほれ……ぐいぐいと……亀頭にめり込んでいく感じ……どうじゃ？　\n周りはおっぱいの肉で優しく包まれて……先端がピリッと痺れる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1703209" ]},
		{"command":[ "SETIMAGE", "0", "still_00000317_01_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「おっと、腰を揺らしてもムダじゃ。がっちりチ〇ポを挟んでおるからな……\n逃げられんぞ？　ふふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1703210" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ムズムズする感触を、もっと堪能するがいいぞ。れろ……ぴちゃ……ちゅぱ\nっ、ちゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1703211" ]},
		{"command":[ "SETIMAGE", "0", "still_00000317_01_11" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「くくっ、突然舐められてビックリしたか？　今日はフェラはちょっとだけじ\nゃ。それであっさり出されてもつまらんからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1703212" ]},
		{"command":[ "SETIMAGE", "0", "still_00000317_01_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「その代わり、お主にはもっともっと、余のおっぱいの柔らかさを味わっても\nらおう……ほれ……この揉みくちゃにされる感じ……どうじゃ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1703213" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ふふ……また顔が歪んでおる。いいのう、ゾクゾクするぞ、その我慢しきれ\nずに悶えてしまう感じ……実に余の好みじゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1703214" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んふっ、もっと声を出してみろ……ぎゅっと、亀頭イジめをしてやるからの\nう。んむっ、また我慢汁が浮いてきた……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1703215" ]},
		{"command":[ "SETIMAGE", "0", "still_00000317_01_12" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「着々とチ〇ポが、二発目の準備を整えているということじゃな……この震え\n方……漏れる吐息……バレバレじゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1703216" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「どうじゃ、また出したいか？　余のおっぱいマ〇コが目当てか？　それとも\n……余の顔にぶっ掛けることが望みか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1703217" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「くくっ、構わぬ。これはトリック……イタズラじゃなからな。当然お主にも\n、その権利はあるという訳じゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1703218" ]},
		{"command":[ "SETIMAGE", "0", "still_00000317_01_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んっ、先端責めもそろそろ限界じゃろう？　根元はしっかりとおっぱいで抑\nえておる。後はお主次第じゃ……さあ、射精までもう少しじゃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1703219" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ほれ……ほぉれっ、お主の欲望をぶち撒けろっ！　さっき以上の濃いのを、\n思いっきり吐き出すのじゃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1703220" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "「んんんんっ……！　ふふっ、出ておる……！　また余のおっぱいに出す方を\n選んだか……あぁ……熱いのがドロドロに溜まっておる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1703301" ]},
		{"command":[ "SETIMAGE", "0", "still_00000317_01_15" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「おぉ、本当にさっきよりもドロっと濃いのが出てるではないか。こんなもの\nを隠しておったとは、お主もなかなかの胆力よの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1703302" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んふぅ……あぁ、そうじゃ……どんどん根元をしっかり締め付けておったか\nらな……せき止めた分、全部出してしまえ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1703303" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んんっ……！　ふふっ、そうじゃ……余の谷間を満たしていいぞ。もっと…\n…この濃い臭いを染み付かせるのじゃ……はふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1703304" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んはぁ……出したのう……こんなにも余をドロドロにさせて……どうじゃっ\nた、余のパイズリは？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1703305" ]},
		{"command":[ "SETIMAGE", "0", "still_00000317_01_13" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「そうかそうか、ふふ……こういうイタズラも悪くないか。ならば、もう少し\n貰おうかのう、ほれ……最後の一発を出してみろ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1703306" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「もう枯れた……？　らしくないことを言う……こうして、タマを刺激してや\nれば……ほぅれっ、ビクビクして……また出るぞ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1703307" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んふっ……見ろ、奥にしっかり残っていたではないか。これだけ隠しておい\nて、よくも枯れたなどと言ったものじゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1703308" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ちゅぷっ……うむ、なかなかの美味。これを味わえるなら、いくらでもイタ\nズラしたくなるというもの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1703309" ]},
		{"command":[ "SETIMAGE", "0", "still_00000317_01_14" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「む……どうした？　ぐったりして……こらっ、このまま寝てしまうやつがあ\nるか！　うむぅ、流石に一気に搾り取り過ぎたか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1703310" ]},
		{"command":[ "SETIMAGE", "0", "still_00000317_01_13" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},
		
		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "「ふぁぁっ！　チ〇ポを顔に向けて……んんっ！　浴びせて来たか……んはぁ\nぁっ、ちゅぷっ、んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1703401" ]},
		{"command":[ "SETIMAGE", "0", "still_00000317_01_18" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「今度も凄い勢いじゃ……この粘り、臭い……オスの生命力に満ち溢れて……\nちゅるっ、んむっ、堪らんな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1703402" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「れろっ、うむ、この味じゃ……さあ、もっと出せ。遠慮はいらんぞ……じゅ\nるっ、ちゅぷっ……んちゅぅぅぅっ……はぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1703403" ]},
		{"command":[ "SETIMAGE", "0", "still_00000317_01_17" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ふふっ、べっとりじゃな……頬がザーメンのぬめりでツルツルになりそうじ\nゃ……そのうち固まる……？　まぁ、その時はその時よ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1703404" ]},
		{"command":[ "SETIMAGE", "0", "still_00000317_01_16" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ふぅ……収まって来たな……ちゅぷっ、たっぷり出せたようじゃが……余の\nトリック、楽しめたか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1703405" ]},
		{"command":[ "SETIMAGE", "0", "still_00000317_01_17" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「そうか、満足したのなら何よりじゃ。もっとも、余としてはまだ出せると踏\nんでおるからな……ほれ、もうひと扱きじゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1703406" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「もう出ない？　いやいや、お主のチ〇ポはそう言っておらんからな。こうし\nて、ぎゅっと根元を抑えて、押し込むようにしれやれば……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1703407" ]},
		{"command":[ "SETIMAGE", "0", "still_00000317_01_16" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ほうら見ろ、ドロっとしたのが奥に残っていたではないか。ふふ……搾れば\n、ちゃんと残っておるということじゃな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1703408" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んふ……このねっとりした指ざわり……いつまでも戯れていられるのぅ……\nハロウィンはやめられんな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1703409" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「む……どうした？　ぐったりして……こらっ、このまま寝てしまうやつがあ\nるか！　うむぅ、流石に一気に搾り取り過ぎたか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1703410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}