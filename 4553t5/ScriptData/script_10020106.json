{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0138" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_016" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「おまえたち……いい加減にしろ！　いったいなにをやってるんだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010113060001" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「っ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "めんどくさい連中のバトルもたけなわ、といったところで突然、冴島長官が現\nれた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「長官！？　どうしてこんなところに！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010113060001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「おまえたちの学園生活を見に来たんだが……なんなんだ、この有様は！　先\n生情けなくって涙出てくるよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010113060002" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、あんたは先生じゃないでしょ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「んなことはどうでもいい！　皆さんにお話があります！　全員体育館に集合\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010113060003" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「すっかり先生気分なんですね、長官……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010113060001" ]},
		{"command":[ "SETCHARA", "0", "char_00001205_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「この人、けっこう雰囲気に流されやすいからなあ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0153" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "……と、いうわけで体育館に場所を移し、長官のお説教は延々と続く。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「そんなことだから、おまえたちは毎回毎回よけいなトラブルばかり引き起こ\nすんだ！　少しは協調性というものをだな――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010113060004" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ううう……私、なんにもしてないのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010113060001" ]},
		{"command":[ "SETCHARA", "0", "char_00001406_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「なんでダイヤナちゃん、先生になってまでお説教されなきゃいけないの……\n！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010113060001" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「それを言いたいのはこちらだ……！　なんで教師の私まで説教をされなけれ\nばならんのだ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113060001" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「決まっているではないか！　貴様がよけいなことを言うから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010113060002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「なんだと！？　また蒸し返すつもりか！　だいたいあれは貴様らがだなぁ！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113060002" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「そっちこそ蒸し返すのかい！？　自分たちの手際の悪さを棚に上げて！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113060001" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「やるか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113060003" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「おお！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113060002" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「って！　おまえたちいいかげんにしろーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010113060005" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫＆エファナティカ" ]},
		{"command":[ "SETTEXT", "「だってこいつが！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113060003" ]},
		{"command":[ "SETCHARA", "1", "char_00000301_01", "7", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "7", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「あーもう！　子供じゃないんだからさあ！　ケンカするにしたって、やり方\nってものがあるだろうが！　もっとこう……学園らしいのが！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010113060006" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「学園らしい……ケンカ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010113060003" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「そう言われても……どうしろって言うんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113060005" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「いや、どうしろって、それは……えーと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010113060007" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "あんたもわからんのかい。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「だからその、学園らしいといえば……あ！　そうだ！　勉強だ！　勉強で決\n着をつけるんだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010113060008" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「おべんきょう～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010113060002" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「勉強で決着って……どうするんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010113060001" ]},
		{"command":[ "SETCHARA", "0", "char_00001701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「試験で対決するとか？　でも先生と学生の混成チームが、試験で対決するの\nは無理があるような……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010113060002" ]},
		{"command":[ "SETCHARA", "0", "char_00001406_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「その通りだ。だから、この子で勝負をしてもらう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010113060009" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そういって長官は、ルナテミスの手を引いて自分のほうに引き寄せる。", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「お、おい？　なんだ？　なんなんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010113060004" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ルナテミス様で……勝負？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113060004" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「それは……どういうことでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010113060002" ]},
		{"command":[ "SETCHARA", "0", "char_00001701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「うむ。まずは、学園長に渡そうと思って持ってきた、この資料を見てもらお\nう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010113060010" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ひっ！　こ、これは！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010113060005" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「転校前の……成績表ですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010113060003" ]},
		{"command":[ "SETCHARA", "0", "char_00001406_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「どれどれ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113060006" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「お、おい！　バカよせやめろ！　やめないか！　やめて！　イヤっ！　お願\nい助けてそれだけは！　それだけはやめてぇええええーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010113060006" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0110" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「ルルーナちゃんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010113060002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "その内容を誰よりもよく知っているつきみが、目頭を押さえて目を背ける。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「……うわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113060007" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「ひどい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010113060003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「だろう？　いくらなんでもこれはない。お前たちもそう思うだろう！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010113060011" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「まったくだ……あまりにも無残な……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113060008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「お姉ちゃん！　それはいいすぎ！　で、でも、これは……本当に」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010113060004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「なんだ！？　『本当に』なんだと言いたいんだーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010113060007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「で、だ。私からの提案は、このルナテミスの成績を上げられるのはどちらの\nチームかを競うこと！　つまり『教育バトル』だ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010113060012" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0153" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「教育……バトル！　なるほど……って、いやいや！　ちょっと待て！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113060009" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「どうした？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010113060013" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「そのルールでは、相手側のメンバーに勝負をゆだねることになるじゃないか\n！　いくらでもインチキができるということだぞ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113060010" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「あー、失礼。ちょっとよろしいですかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113060001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「ん……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113060011" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "どこからともなくやってきたジュンジローが、修羅姫に声をかける。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「修羅姫殿が心配されているのは、姫様があなたがたの科目で、わざと悪い成\n績を取るのではないか、ということですな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113060002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「ああ。そういうことだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113060012" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ほっほっほっほ！　そんな心配は、万が一にもございませんぞ。よろしいで\nすか？　これをごらんください！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113060003" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ん……？　ま、待てっ！　それは！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010113060008" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「さよう。姫様が大事に隠しておられた、この前の定期試験の答案用紙ですぞ\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113060004" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「お、おい！　やめろ！　それをどうするつもりだ！　返せ！　返さないかこ\nのボケナスビーッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010113060009" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「さ、ご遠慮なくご覧ください。これを見ていただければ――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113060005" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「いただければ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113060013" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「姫様が！　決して！　わざと解答を間違えたりできる方ではないと、わかっ\nていただけるはずですぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113060006" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「どれどれ……？　うっ……！　これは……また……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113060014" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「うわぁああああああーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010113060010" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「え……？　どうしたら、こんな答えが……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010113060005" ]},
		{"command":[ "SETCHARA", "0", "char_00001701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「夜叉ぁあああああーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010113060011" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「ご、ごめんなさいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010113060006" ]},
		{"command":[ "SETCHARA", "0", "char_00001701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「なるほど……そうか、わかった。貴様の言いたいことは理解した」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113060015" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「おわかりいただけましたかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113060007" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「これはただ授業の内容が理解できていない、というだけじゃない……自分が\n、内容を理解できていないことすら理解できていない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113060016" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「そうでしょうそうでしょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113060008" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「これでは、インチキのしようがない。質問が理解できていないのに、わざと\n間違えることなど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113060017" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「よく理解した！　ルナテミスの学力では、インチキすらできん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113060018" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そこまで言うかぁあああああああー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010113060012" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「そういうことだ！　つまり、この超ド級問題児のルナテミスを対象にすれば\n、完全に公正な勝負が――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010113060014" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「う、う、う、うわあああああああああああーん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010113060013" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「あ！　おい！　ルナテミス！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010113060015" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ルナテミスが、押さえていた長官の手を振り切って逃げ出した！　そして――", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「私なんか！　私なんか！　私なんかぁああああああーっ！　うわぁああああ\nあーん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010113060014" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "大声で泣き叫びながら、剣を振り回して暴れ出した！", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「グレてやる！　スケバンになってやる！　不良王女とよばれてやるぅーーー\nーー！　うぁああああああああーん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010113060015" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まずい！　みんな！　姫様を止めろ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「ええい！　手間をかけさせおって！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113060019" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「ルナテミスさん、落ち着いて！　落ち着いてぇーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010113060007" ]},
		{"command":[ "SETCHARA", "0", "char_00001701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}