		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「はぁ……海で泳ぐなんて、なにが楽しいのかさっぱり理解できません」", "NORMAL" ]},
