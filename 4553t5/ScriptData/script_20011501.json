		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「そうだね……わ、私もこんな格好で……人前に出るなんて……！　あっ、ダ\nメ……！　か、身体が熱くなってきてる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_050021520001" ]},
