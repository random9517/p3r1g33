		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「はっ、ふっ、あぁっ、まだ激しくっ……もうすぐ出るからっ……？　な、中\nにっ……でも、赤ちゃんが……」", "NORMAL" ]},
