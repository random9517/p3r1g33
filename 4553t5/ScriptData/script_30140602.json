		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「あぁっ、もっと……身体密着させてっ……あなたの温もり感じてっ……ま、\nまた私もイキますっ、続けてオマンコイッちゃいますからっ！」", "NORMAL" ]},
