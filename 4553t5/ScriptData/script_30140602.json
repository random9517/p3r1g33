		{"command":[ "SETIMAGE", "0", "still_00001406_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「んんっ、あぁっ……こんな乱れたところ……つきみに見られたら……私……\nあぁっ、はっ、そんなのダメ……あひっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0604133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「そ、想像して興奮……あぁっ、それはっ……ほ、本当は見せたいなんて……\nち、違います……あっ、はひぃっ！」", "NORMAL" ]},
