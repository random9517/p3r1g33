		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「はぁぁ……あふっ、また……イッてます……子宮が熱くなって……くぅぅん\n……気持ち……いい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0604139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……んっ、あぁ……止まった……あぁ、いっぱい中に出されちゃ\nいました……はぁ、はぁ……すごかった……です……」", "NORMAL" ]},
