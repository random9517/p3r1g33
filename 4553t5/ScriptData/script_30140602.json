		{"command":[ "SETIMAGE", "0", "still_00001406_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「あっ……！？　ど、どうしたんですか……またそんな……身体くっつけて…\n…えっ、まだ足りない……はっ、うんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0604201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「んぁっ、はっ、ひっ……このまま……続けてしちゃうんですかっ……あっ、\nあぁっ、でも、続けてしたら……あっ、んんっ！」", "NORMAL" ]},
