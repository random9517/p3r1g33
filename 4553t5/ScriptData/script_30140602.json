		{"command":[ "PLAYVOICE", "v2_014_0604204" ]},
		{"command":[ "SETIMAGE", "0", "still_00001406_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「はぁぅ……あぁっ、さっきより……もっとオチンチン大きくなってる気がし\nます……んくっ、じゅくって……中……混ぜられて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0604205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「んんっ、またおっぱいも……はふっ……吸われてる……はぁ、すごく感じや\nすくなってるのに……くぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0604206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「あっ、んくっ、はいっ……もっと突いて下さい……オマンコのヒダ……めく\nり返してぇ……先でグリグリ引っ掻いてぇっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0604207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「あひっ、はひぃんっ！　オチンチン暴れてますっ……ダメっ、あっ、声が…\n…出ちゃうっ……はぅんっ、んっ、んひぃぃんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0604208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ダメ……あぁっ、誰か来ちゃうかも知れないのにっ……こんな、教室で……\nおっぱいもオマンコも全部丸出しにしてっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0604209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「オマンコの中っ……かき混ぜられてっ、はぁっ、でもダメっ……ゾクゾクし\nますっ、いけない場所でするセックスっ、いいですぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0604210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「はんっ、あっ、あぁっ、んちゅぷっ……んふぅっ、あぁ……キスぅ……ちゅ\nぽっ、うれひぃ……れろ、舌……もっろぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0604211" ]},
		{"command":[ "SETIMAGE", "0", "still_00001406_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「んちゅぱっ……あふぁっ、すごい……こんな、すごいの……初めてぇっ……\nんぁふっ、オマンコの奥ぅっ……自然に震えるぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0604212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「あっ、くっ……あぁっ……またムズムズが上がってきてますっ……わ、私の\nオマンコ……またイッちゃいそうですっ、はっ、んんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0604213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「イッても……いいっ、はひっ、イキますっ、ごめんなさいっ……またっ、先\nにっ……イッちゃいますぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0604214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「んっ、はぁぁっ、あぁっ、んふっ……あぁ……まだオチンチン……止まらな\nいっ……もっと激しくなってっ、んくぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0604215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「あなたも……またイキそうなんですねっ？　嬉しいっ……私で……イッて下\nさいっ……オマンコっ……もっと感じて下さいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0604216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「もう誰かに見られちゃってもいいっ、知られちゃってもいいっ！　あぁっ、\nあなたとっ……もっと深く繋がってっ、また……イキたいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0604217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「あっ、はぁっ……オチンチン、そろそろですねっ？　あぁっ、どこでもいい\nですっ、あなたがしたいことっ、して下さいっ！」", "NORMAL" ]},
