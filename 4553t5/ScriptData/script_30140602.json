		{"command":[ "PLAYVOICE", "v2_014_0604114" ]},
		{"command":[ "SETIMAGE", "0", "still_00001406_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「あっ……はぁぁぁぁんっ……！　そんなっ、いきっ、なりぃぃぃっ、あっ、\nひっ、あひぃぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0604115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「はぁぁぁう……ふ、不意打ちで……一番奥に入れちゃうなんて……はぁっ、\nんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0604116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「は、はいぃ……ちょっとイッちゃいました……オチンチン……気持ちいい所\nに当たって……んくっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0604118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「でも、大丈夫です……その、びっくりしただけですから……続けてください\n……このまま、オチンチン……動かして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0604119" ]},
		{"command":[ "SETIMAGE", "0", "still_00001406_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「はっ、あっ、あんっ、はぁっ、あくっ、んくんっ……！　あぁっ……太いの\nが、お腹の奥を……グッて押し込んで来ています……」", "NORMAL" ]},
