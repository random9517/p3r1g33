		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「んんっ……あっ、お、おっぱい……んっ、吸うんですか……？　んふっ、あ\nぁ……こんな激しくされてるのに……そんな甘え方ぁ……」", "NORMAL" ]},
