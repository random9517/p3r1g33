		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「はぁっ、うんっ、すごいっ……こんな……立ったまましちゃうなんて……は\nっ、ひっ、んんっ、ふっ……んくぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0604121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「逞しいオチンチンが……中っ……オマンコの奥っ……かき分けてっ……くぅ\nんっ、ずりゅずりゅっ、擦ってぇっ……」", "NORMAL" ]},
