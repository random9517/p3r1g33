		{"command":[ "PLAYVOICE", "v2_014_0604108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「見間違い……そ、そうですよね……も、もう……びっくりさせないで下さい\n……あっ、んっ、あぁっ、はぁ……んふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0604109" ]},
		{"command":[ "SETIMAGE", "0", "still_00001406_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「見られるかもって、興奮したなんて……んっ、も、もう意地悪しないで……\nオチンチン欲しいです……ちゃんと、おねだりしますからぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0604110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「お願いします……私の……興奮して、ぐしょぐしょに濡れてる……オ、オマ\nンコに……オチンチン……入れて下さい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0604111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「あなたのオチンチンをハメて欲しくて……私のオマンコは……こんなにウズ\nウズしているんです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0604112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「逞しいオチンチン……ぎゅっと締め付けて、いっぱい気持ちよく出来るよう\nに頑張りますから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0604113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
