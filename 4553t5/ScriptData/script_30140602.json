		{"command":[ "PLAYVOICE", "v2_014_0604125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「はぁっ、あっ、おっぱいとオマンコ……あぁ……一緒にされてっ……あひっ\n、気持ち……んっ、いいですっ、はぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0604126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「くっ……んぁっ、あぁっ……もっと、強く握ってもいいんですよ……？　少\nし荒っぽい位の方が……ドキドキしちゃうんです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0604127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「い、イジメられたいとか……そ、そこまででも……ないんですが……でも、\n力強く抱き締められるのが……好きなんです……んっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0604128" ]},
		{"command":[ "SETIMAGE", "0", "still_00001406_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
