{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0027" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ミュワッ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_010022280001" ]},
		{"command":[ "SETCHARA", "0", "char_00021001_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うおっ、なんだ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「な、何事だ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022280001" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人、あれを」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022280001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんだってんだ……うおおおっ、でかいっ！！　説明不要！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「いや説明は必要だろう。というか何者だっ！？　敵の新手か！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022280001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「地球の皆さん、私はマム。奇跡の星（ミラクルスター）からやってきた、マ\nムという者です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_010022280002" ]},
		{"command":[ "SETCHARA", "0", "char_00021001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「奇跡の星……？　どこかで聞いたことがあるような」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090022280001" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「知っているのかアナザー？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「うむ。遥か銀河の遠くに巨人族が住む奇跡の星があるという話を聞いたこと\nがある」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090022280002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「もっとも、私のいた世界の話だが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090022280003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「その知識で間違いありません。私は、あなた方に味方するためにやってまい\nりました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_010022280003" ]},
		{"command":[ "SETCHARA", "0", "char_00021001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マミ" ]},
		{"command":[ "SETTEXT", "『ミラクルマム、敵があなたに狙いをつけている！！』", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_010022280001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「長々と喋っている場合ではありませんね。私が味方ということを行動で示し\nます。トアァッ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_010022280004" ]},
		{"command":[ "SETCHARA", "0", "char_00021001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「地球を脅かす侵略者たちよ、覚悟なさい！！　ハアアアッ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_010022280005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マミ" ]},
		{"command":[ "SETTEXT", "『これがマムの……ヒーローの力……すごい！！』", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_010022280002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「すげえ……動くたびに敵を倒してるぞ！！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「敵も突然現れた彼女に動揺している。長官、今がチャンスだ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090022280004" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「うむ。彼女を仮の味方と認定する。側面を突き崩す彼女の動きに合わせて前\n線を上げるぞ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022280002" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「任せろっ！！　今まで耐えた分の全てを倍返ししてやろうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022280002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「崩れたところを押し込め！！　行くぞっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090022280005" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「よし……いいぞ、また押し返してきてる。このままいけるんじゃないか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「いや、そう都合よくはないようです。ご主人、敵の新手が」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022280002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うお、なんだありゃ。でかくて、見るからに硬そうなのが出てきたぞ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「怯むな！！　攻撃を集中させろ、撃てーっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022280003" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「駄目だ、全然効いてないぞ。やばい、敵があれを前面に据えたらまた押し返\nされる！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「あれは私に任せてください。トアァッ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_010022280006" ]},
		{"command":[ "SETCHARA", "0", "char_00021001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マミ" ]},
		{"command":[ "SETTEXT", "『ふわ……なに、これ、身体に力がみなぎってくる！！』", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_010022280003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんだ、彼女の身体が赤くなってるぞ」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0027" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「パワッ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_010022280007" ]},
		{"command":[ "SETCHARA", "0", "char_00021002_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おわっ、衝撃波がここまで来た！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「凄まじい威力の一撃ですな。見たところ、パワー重視のスタイルに変化した\nということですかな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022280003" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「みたいだな。さっきより下半身もむっちりしてるし」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「さすがご主人、女体の変化に目ざとい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022280004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「下僕……お前はどうしてそう、残念なのだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022280004" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、いやいや姫様、あんなすごい身体が目の前で動いてたら、男なら見て\nしまうって。なあジュンジロー？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「このジュンジロー、戦いにおいて煩悩に迷わされることはありえないと申し\nておきましょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022280005" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「こいつ……いつもこういうときに裏切りやがる！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「下僕、戦いが終わったあとにスペシャル訓練フルコースな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022280005" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うう……姫様、スタイルが敵わないからってそんな酷い……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「模擬戦も追加だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022280006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「キジも鳴かずば撃たれまいに」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022280006" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「二人とも、じゃれ合ってないで火力を出せ！！　彼女があれを抑えてくれて\nいるうちに！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022280003" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ぐぐぐ、分かってるよちくしょう！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「トアッ！！　デヤァッ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_010022280008" ]},
		{"command":[ "SETCHARA", "0", "char_00021002_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「連打でひるんだな、今だ、ダークドラゴニックパワー！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090022280006" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マミ" ]},
		{"command":[ "SETTEXT", "『アナザーが突っ込んでくるわ！！　マム、合わせて！！』", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_010022280004" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「！！　タアアアアッ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_010022280009" ]},
		{"command":[ "SETCHARA", "0", "char_00021002_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「いい崩しだ！！　感謝する！！　もらったぞ、でやあっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090022280007" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おお、でかいのが倒れた！！　よし、長官、今ならいけるぞ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ああ。全員で突撃だ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022280004" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マミ" ]},
		{"command":[ "SETTEXT", "『押し返してきてる。マムのおかげよ！！』", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_010022280005" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「いえ、敵はまだ余力を残しているようです。後方から高速の反応があります\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_010022280010" ]},
		{"command":[ "SETCHARA", "0", "char_00021002_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「むうっ、また新手か！！　しかも今度は素早いタイプだ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022280005" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「次から次へと、ロボットアニメじゃあるまいしよ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「愚痴を言うな！！　下手に動けば削られる、足を止めて受け止めろ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022280006" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「くそ、せっかく勢いがついたというのに！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022280007" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ここもお任せを。ヤアッ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_010022280011" ]},
		{"command":[ "SETCHARA", "0", "char_00021002_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マミ" ]},
		{"command":[ "SETTEXT", "『わ、わ、また身体に力が……！！　んんっ！！』", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_010022280006" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0027" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「テヤアッ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_010022280012" ]},
		{"command":[ "SETCHARA", "0", "char_00021003_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おお、今度は紫色に。それにスタイルもほっそりとして……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「スピードフォルムですな。頭の上の突起がまるで猫の耳のようです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022280007" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「尻尾まであるしな。これはこれでさっきと違って……なんかいい」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「下僕……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022280008" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、姫様、これは純粋な分析だって！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ゼイヤァッ！！　トアアーッ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_010022280013" ]},
		{"command":[ "SETCHARA", "0", "char_00021003_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「凄まじい連撃……まるで暴風だな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022280007" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああ。敵も対抗しようとしているが、ついていけていない。あまりの素早さ\nにまるで二人いるみたいだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「というより、本当に分身しているな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090022280008" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「え？　あ、マジだ。二人で攻撃してる。どうなってんだありゃ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「なんとお強い……もうあの方だけでいいのでは？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022280008" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「んなわけあるか。長官、あの敵を抑えてもらっているうちに押し込もう」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「そうしたいが……相手も分裂したな。抑えられるのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022280008" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ならばあの素早いやつの片割れは私が抑える」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022280009" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「うむ。ならばアナザーを先頭にして我々は突撃だ。行くぞっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022280009" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マミ" ]},
		{"command":[ "SETTEXT", "『ミラクルマム、今度はルナテミスがこちらに加勢してくれる。合わせましょ\nう！！』", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_010022280007" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ハッ、タアッ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_010022280014" ]},
		{"command":[ "SETCHARA", "0", "char_00021003_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ドラゴニックパワー！！　喰らえ侵略者ども！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022280010" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「よっしゃ、倒した！！　さすが姫様！！　皆、押せ押せっ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「敵が崩れたぞ！！　一気に行け！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090022280009" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}