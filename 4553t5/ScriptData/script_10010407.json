		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はぁ……どうにか外の連中は追い返したぜ」", "NORMAL" ]},
	{"command":[ "DISPTEXT", "TRUE" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "疲れた……なんなんだ、あいつらのあの無駄な情熱は。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「大丈夫？　カツマ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010104070001" ]},
	{"command":[ "SETCHARA", "0", "char_00000201_01", "2", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まあ、これからしばらくは客席内の警備だからな。たいしたことも起きねえ\nだろ。試合を見物しながらのんびりやろうぜ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "どれ？　ルナテミスとアナザーはどうなってるかな。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ルナテミス様たちは、一次予選を突破したようですね。今は……第二次予選\nですか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010104070001" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「第二次予選？　どれどれ……？」", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0119" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_022" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「うぉおおおおおおおおっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010104070001" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「急げ！　ローラーが迫ってくるぞぉおおおおっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090104070001" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "金髪のプリンセス" ]},
		{"command":[ "SETTEXT", "「きゃぁあああああっ！？」", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "筋肉質なプリンセス" ]},
		{"command":[ "SETTEXT", "「いやぁあああん！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "実況" ]},
		{"command":[ "SETTEXT", "「競技場では現在、第二次予選『ローラーレース』が行われております！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "実況" ]},
		{"command":[ "SETTEXT", "「ローラースケートを履いたプリンセスたちは、迫りくる巨大ローラーから、\n逃げ切ることができるのかーっ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0119" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんだ？　これ……」", "NORMAL" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「第二次予選だってよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010104070001" ]},
	{"command":[ "SETCHARA", "0", "char_00000401_01", "0", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「第二次っつーより大惨事じゃねえのか？　これ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "競技場のトラックの上で、プリンセスが次々とでけえローラーに轢かれていく\nんですけど……！？", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「まあ、安全には充分配慮しているそうですから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010104070002" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まあ、たしかに轢かれたプリンセス、自力でコース外に出てはいるけど……\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "これ、安全に配慮してるというより『プリンセス』たちが異常に頑丈なだけな\nんじゃねえのか！？", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「てか、プリンセスってなんなんだ……」", "NORMAL" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「あ！　見て！　ルナテミスとアナザーさん、予選通過したみたいだよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010104070001" ]},
	{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああ……そか」", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「マジでわからなくなってきた……プリンセスって、こういうもんだっけ……\n？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0119" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "あれから予選はさらに進み、出場者がどんどん絞り込まれていく。ルナテミス\nとアナザーは今のところ勝ち残っているが、その競技というのが……。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「早押しクイズにホットドック早食い、おまけに武器使用ＯＫの棒倒しって…\n…プリンセスとどういう関係があるんだよ！」", "NORMAL" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「いいじゃんか別に。細かいヤツだなあ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010104070002" ]},
	{"command":[ "SETCHARA", "0", "char_00000401_01", "0", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「細かくねえよ！　一般的なプリンセスのイメージってもんがあるだろ！　イ\nメージが！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「お前、いまさら何を言ってるんだい。あれだけ長いこと、ルナテミス様と一\n緒に働いてて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010104070001" ]},
	{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、だって姫様は姫様であって別にプリンセスとは――あ、あれ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "あ、そっか……ルナテミスは姫だし、姫ってことは……つまりプリンセス？　", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},


		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あれ？　あれ？　あれ……？　あ、そうか……いいのか」", "NORMAL" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "つまり、プリンセスって、もともとこういうものだってことか。そうか……。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はぁ……」", "NORMAL" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「カツマ？　どうしたの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010104070002" ]},
	{"command":[ "SETCHARA", "0", "char_00000201_01", "6", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや……。なんかまたひとつ、つまらねえ大人になっちまった気がしてなぁ\n……。現実ってのは、苦いもんだよなあ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「…………？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010104070003" ]},
	{"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "実況" ]},
		{"command":[ "SETTEXT", "「さあ！　休憩を挟んで次はいよいよ最終予選！　皆様お待ちかねの『美王\n女コンテスト』です！」", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「美王女ね……ま、せいぜい腕回りの太さで決めるとか、そんなだろうなぁ…\n…」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "実況" ]},
		{"command":[ "SETTEXT", "「予選ではありますが、ある意味これが、今大会最大の目玉！　ここまで勝ち\n残ったプリンセスたちが、水着姿で美を競い合います！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なぬっ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「どうしたの？　カツマ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010104070004" ]},
	{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「どうしたもこうしたもあるか！　今の聞いただろ！　水着だぞ！　み・ず・\nぎ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「聞きましたが、それがどうしたっていうんです……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010104070001" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「まりあの言う通り。別にどうでもいい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010104070005" ]},
	{"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お前らわかってねえな！　いや、わかるはずがねえか！　無駄にガチな試合\nの中に現れる一服の清涼剤！　美しきプリンセスたちの水着審査！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「これこそが男のロマン！　これこそが男の夢！　そうだよ！　これこそが俺\nの求めていたプリンセストーナメントのあるべき姿なんだよ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「あなたの勝手なロマンと夢を押し付けないでください！　だいたい、どうし\nてわざわざ水着になる必要があるんですが！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010104070002" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「カツマ、どうしてそんなに水着が見たいの？　水着だったら、いつでも私が\n――はっ！　まさか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010104070006" ]},
	{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「な、なんだよ……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ル、ル、ル、ルナテミス様の水着姿が見たかったの……？　これまでずっと\n？　あるいは、アナザーの……？」", "NORMAL" ]},
	{"command":[ "SETCHARA", "0", "char_00000201_01", "9", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_002_010104070007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「なんですって……！　カツマさん！　あなたって人は……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010104070003" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ち、違うって！　そうじゃねえ！　二人とも落ち着け！　なんでお前らそん\nなに怒ってんだ！　怖い顔で詰め寄るんじゃねえ！　お願いやめてーっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「やれやれ……どうやったらここまで鈍感になれるのやら。血の巡りの鈍いご\n主人を持つと苦労しますぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010104070001" ]},
	{"command":[ "SETCHARA", "0", "char_00000901_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａジュンジロー" ]},
		{"command":[ "SETTEXT", "「同意」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_040104070001" ]},
	{"command":[ "SETCHARA", "0", "char_00000904_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "bg_0119" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_022" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "実況" ]},
		{"command":[ "SETTEXT", "「さあ、始まりました『美王女コンテスト』！　セクシーかつダイナマイト！\nそしてプリティな水着姿で、美しきプリンセスたちが続々入場してきます！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「なにがセクシーかつダイナマイトだ。どこのバカがこんな競技を考えたのだ\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090104070002" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "1", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ふふん、どうしたアナザー。貴様にしてはずいぶん弱気ではないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010104070002" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「弱気、というわけではないが、正直気は進まんな……お前はずいぶん自信が\nあるようだが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090104070003" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ふふん！　当たり前だ！　日ごろ鍛えたこのボディラインを見ろ！　このス\nタイルをもってすれば――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010104070003" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「マグナシアなど物の数ではない！　ははははっ！　はーっはっはっはっは！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010104070004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「すごい自信だが……本当に大丈夫なのか？　なにか、とんでもない落とし穴\nがあるような気がするが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090104070004" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "審判" ]},
		{"command":[ "SETTEXT", "「はい！　それでは審査を始めまーす！　プリンセスの皆さん、こちらに並ん\nでくださーい！」", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「お、始まったようだな。それでは――って、ちょっと待て」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010104070005" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「どうした？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090104070005" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「……審査場に身長計があるのはまだわかる。百歩譲って、体重計もよしとし\nよう。だが……なぜバリウムを飲んだり血圧を測ったりしているのだ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010104070006" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "審判" ]},
		{"command":[ "SETTEXT", "「え？　だってこれは美しさを競うコンテストですよ？」", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「いや、ちょっと待て！？　どう見てもあれは健康診断にしか見えんぞ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010104070007" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "審判" ]},
		{"command":[ "SETTEXT", "「でしょうねえ。美しさを競っているわけですから」", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「いやいやいや！？　話が見えん！　美しさと健康診断と、どういう関係があ\nるのだ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010104070008" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "審判" ]},
		{"command":[ "SETTEXT", "「はははは、やだなあ。見た目の美しさを競うと思ってたんですか？」", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「違うのか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010104070009" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "審判" ]},
		{"command":[ "SETTEXT", "「見た目の美しさなんて、次元ごとに基準が変わってしまいますからね。全次\n元共通で美しく素晴らしいもの、誰もがうらやむものといえば――」", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "審判" ]},
		{"command":[ "SETTEXT", "「やはり健康ですよ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁああああああ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010104070010" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「まあ、そういうことならわからんでもないな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090104070006" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「おいアナザー！　貴様なにを納得しているのだ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010104070011" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "審判" ]},
		{"command":[ "SETTEXT", "「あー……もしかして、棄権されるということですか？」", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「棄権だと！？　馬鹿を言うな！　誰が棄権などするか！　たかが健康診断！\n　いいだろう！　受けて立とう！　私の健康さを見せつけてやろう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010104070012" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "8", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "審判" ]},
		{"command":[ "SETTEXT", "「はい、ではまずあちらから。体重測定からお願いします」", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「た、体重……！　いや、それは待ってくれ、せめて他のものから……できる\nだけ、長い距離を歩ける検査から……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010104070013" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "審判" ]},
		{"command":[ "SETTEXT", "「そうですか？　では……向こうの血圧測定があいているようですね。そちら\nからお願いします」", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「お、おう。承知した。で、では、できるだけカロリーを消費できるよう高く\n足を上げてだな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010104070014" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "1", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ルナテミス……お前……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090104070007" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "実況" ]},
		{"command":[ "SETTEXT", "「さあ！　全員の測定結果が出そろい、いよいよ判定に移ります！　この最終\n予選を通過した１６人が、本戦へ進出することになるわけですが――」", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「よくわからん勝負ではあったが、健康には自信がある。ここで負けることも\nあるまい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010104070015" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "6", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "実況" ]},
		{"command":[ "SETTEXT", "「では！　判定を待つ間に選手の測定データを発表していきましょう！　まず\nは、ルナテミス選手から！」", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「なにっ！？　ちょっと待てそれはどういうことだ！？　測定データを発表だ\nと！？　まさか今ここで――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010104070016" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "実況" ]},
		{"command":[ "SETTEXT", "「ルナテミス選手。身長１６９ｃｍ、スリーサイズは上から９２！　５８！　\n８９！　そして気になる体重ですが――」", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「おい！　なぜそれを発表する！　やめろ！　やめないか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010104070017" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "実況" ]},
		{"command":[ "SETTEXT", "「視力、聴力、肺活量がこの数値！　これはかなりの健康体ですねえ！　上位\n入賞が期待できます！　さらに、気になる体脂肪率は――」", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「うぉおおおおおっ！？　だから、なぜそこまで発表する必要があるのだ！　\nやめろぉ！　もうやめろぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010104070018" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "実況" ]},
		{"command":[ "SETTEXT", "「採血の結果も全て正常値ですが、食生活に改善の余地があるのでは、との意\n見も審判団からは出ておりまして、どうやらこれは間食の習慣が――」", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「大きなお世話だぁああああああっ！　もうやめてくれぇぇぇぇぇ～～～っ！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010104070019" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
	{"command":[ "EXIT" ]}
	]
}