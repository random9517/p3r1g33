		{"command":[ "SETIMAGE", "0", "still_00003004_02_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んんっ……！　あぁっ、母乳も出てますっ……！　んくぁ……ザーメンと母\n乳が……一緒になって……はぁん、濃密な匂い……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0404402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あふっ……旦那様……いっぱい母乳を飲んで頂いて……あぁ、私も……ちゅ\nぷっ、旦那様のザーメンを味わっております……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0404403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「れろ……んちゅぷ……んぅん……口の中に広がる、このまろやかな味わい…\n…あぁ……肌に染み渡るザーメン……素敵です……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0404404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あふっ……あぁっ……気持ちいい……んぁっ、私……今、母乳と一緒に……\n軽い潮吹きまでしてしまっていますわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0404405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んっ、あぁ……旦那様……もっと浴びせて下さい……発情しきったいやらし\nいメスの身体に……ザーメンを染み込ませてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0404406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んっ、ふぁ……はぁぁ……これで最後ですか……？　ありがとうございます\n……本当にお疲れ様でございました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0404407" ]},
		{"command":[ "SETIMAGE", "0", "still_00003004_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はい、私も……まだ強い快感の余韻が残っておりますが、大丈夫です……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0404408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「ずっと気持ちよくて……素敵な子作りでした。旦那様のお情けを頂けて、私\nはとても幸せです……」", "NORMAL" ]},
