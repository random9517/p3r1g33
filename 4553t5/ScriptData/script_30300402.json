{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003004_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「お待ちしておりました、旦那様……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0404101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「今夜は……私が積極的に動いて……旦那様へのご奉仕を致したいと思います\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0404102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「拙いかも知れませんが、心を込めてお尽くししますので……どうか、身体を\n楽になさってお楽しみ下さいませ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0404103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はい、そちらのベッドに横になって頂いて……あぁ……もう、オチ○ポはそ\nの気になっていらっしゃるみたいですね……とても、熱くて逞しいです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0404104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「それでは、上から失礼致します……んっ、あっ……ふっ……んくっ……まだ\n入れませんから……少しだけご辛抱下さいませ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0404105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んふ……目の前のおっぱいが気になりますか……？　ええ……もちろん、こ\nのおっぱいも旦那様のモノですから……どうぞご随意になさって下さい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0404106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あんっ……あふっ……やはり吸うのがお好きですか……んんっ、はい、私も\n……旦那様におっぱいを吸っていただくのは大好きです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0404107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はい、もう少し刺激していただいたら、もっと母乳も出てくると思いますの\nで……あはぅっ、あぁっ、それです……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0404108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あっ、あぁっ、おっぱい……出ますっ……んんっ！　あふっ、どうぞ……お\n飲みになって下さい……んっ、ふぁっ、あぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0404109" ]},
		{"command":[ "SETIMAGE", "0", "still_00003004_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んっ……オチ○ポの方もお世話しないといけませんでしたね……太ももに挟\nませて頂いて……ゆっくり動かして参りますね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0404110" ]},
		{"command":[ "SETIMAGE", "0", "still_00003004_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あっ、はぁっ、おっ……んふっ、あふっ、くぅっ……んんっ……あぁ……反\nり返ったオチ○ポが、オマ○コの入り口に擦れて……んくっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0404111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「とても切ない痛痒感が……太ももにも広がって参ります……んっ、オチ○ポ\nの方は……いかがですか？　柔らかくて気持ちいいですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0404112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んふっ……焦らず、じっくりとするのがいいのですね……はい、優しく……\nオチ○ポを挟んで参ります……あっ、あふっ、あぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0404113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はんっ、ビクビク……震えております……血管が軽く浮き上がって……私の\n太ももにも微かに脈動が伝わって参ります……あっ、くふぅぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0404114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んっ、私の……ぬめりも伝わりますか……？　はい、こうして……オチ○ポ\nを間近に感じて……はぁっ、んくっ、胸を高鳴らせております……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0404115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「ゆっくりと皮をお扱きしながら……あっ、乳首を吸われて……あふっ、その\n……そろそろ準備も整って来たのではないかと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0404116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んっ、いかがしましょうか……そろそろ……オチ○ポ……入れてしまっても\nよろしいでしょうか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0404117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「もっと気分を出したおねだりを……は、はい……確かに、私ばかりその気に\nなっていては申し訳ありません。その、では……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0404118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「お願い致します……旦那様。私のオマ○コは……旦那様のオチ○ポに素股ご\n奉仕をしているうちに、じゅくりと涎を垂らし始めております……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0404119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「もっと、じっくりご奉仕をしようと思っていましたが、淫らなオマ○コがも\nう待ちきれないと、旦那様のオチ○ポを欲しがっております……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0404120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「どうか、旦那様のぶっといオチ○ポを……じゅくじゅくに潤んだ私のオマ○\nコにお恵み下さい……オチ○ポが欲しい……欲しいのです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0404121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「どうか、おハメになって……恥ずかしいオマ○コを、ズコズコなさって下さ\nいっ……逞しいオチ○ポ様を咥え込むことをお許し下さいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0404122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あぁっ……ありがとうございます……それでは……失礼させて頂きます……\nあっ、んんんっ、くおぉっ、オチ○ポ、ハマりますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0404123" ]},
		{"command":[ "SETIMAGE", "0", "still_00003004_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はぁぅっ……んくっ……あぁ、こうしてみっちりとオチ○ポを咥え込むと、\n己の至らなさに恥じ入るばかりです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0404124" ]},
		{"command":[ "SETIMAGE", "0", "still_00003004_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「素股で悦んでいただくなど……まだまだ私には至らない技……精一杯にオマ\n○コを使って、旦那様にご奉仕するのがせめてもの……務め……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0404125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んっ、おっぱいを吸って頂いているので……少し揺れてしまうかも知れませ\nんが、腰を使わせて頂きます……あっ、んふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0404126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、いかがでしょうか……こうして、ゆっくりと円を描き……す\nりこ木のようにして、オチ○ポを擦り上げます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0404127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あうんっ……はぁっ、どうでしょうか……濡れ濡れオマ○コの襞肉が……し\nっかりとオチ○ポに吸い付いていると思います……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0404128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はい……んっ、この太い感触がとても気持ちよくて……ゆっくり動くだけで\n……足先まで快感が広がっているのです……あふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0404129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あぁっ、乳首も……はい、より敏感になっているようで……ちゅぱっと吸わ\nれると……あひっ、また母乳が溢れますっ……おふぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0404130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はい……お好きなだけ味わって下さい……お乳を飲みながら……私のオマ○\nコを感じて頂ければ……それが妻として、何より幸せです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0404131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はぉっ、あぁっ、私も……ずっとオマ○コが気持ちいいです……入り口から\n……奥まで……どこでもオチ○ポをいっぱいに感じて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0404132" ]},
		{"command":[ "SETIMAGE", "0", "still_00003004_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「こんなにゆったりした動きでも……あぁっ……腰が抜けそうな位……あふっ\n、あぁ……旦那様のオチ○ポが震えています……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0404133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はい……分かります……そろそろお射精が近いのですよね？　もし……よろ\nしければ、このまま……オマ○コの奥に出して下さいませ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0404134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「濃いザーメンをたっぷり中に出して頂いて……旦那様の赤ちゃんを身ごもり\nたく思います……どうか、このまま……オマ○コにぃ……あぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0404135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「くぅぅぅんっ……！　あぁっ、ありがとうございますっ……あふぅっ、中出\nしされてっ……イキますっ、あぉぉっ、オマ○コいいですぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0404136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003004_02_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はぁぁ……んっ、あくぅ……この量……勢い……オマ○コがあっという間に\nいっぱいにされてしまいました……はぁ……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0404137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はい……きっと受精したのではないかと思います……んふぅ……あぁっ、ま\nた母乳が溢れて……は、んぅぅんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0404138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……んっ……あぁ……素敵なお射精でした。また、私の方が……\n気持ちよくなってしまいました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0404139" ]},
		{"command":[ "SETIMAGE", "0", "still_00003004_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「そんなことはない……ですか？　ありがとうございます……少しなりとも旦\n那様が楽しんで頂けたのなら、本当に何よりですわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0404140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んくっ……あぁ……また、オマ○コの中で……旦那様のオチ○ポ、存在感を\n増している気がいたします……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0404201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んふ……続きですか？　はい、私も……もっと旦那様にオマ○コして頂きた\nいと思っておりました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0404202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「どうか、このオチ○ポは抜かずにこのまま、んっ……続けてオマ○コして下\nさいませ……あっ、はぁっ、んっ、あぁぉっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0404203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はい、んふっ……今度はもう少し勢いをつけて、出し入れを致します……ヌ\nルヌルのザーメンも手助けになるでしょう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0404204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はぁっ、あぉっ、おふっ……あぅんっ……はぁぁっ……くぅ……はぁっ、あ\nひっ、あっ……はっ、あぁんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0404205" ]},
		{"command":[ "SETIMAGE", "0", "still_00003004_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あぁ……恥ずかしい声が出てしまいます……オチ○ポがオマ○コの襞にじっ\nとりと纏わりついて……腰を揺らすと、強く響いて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0404206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「いやらしい音が……ぐちゅぐちゅ……聞こえてしまいます……あぁっ、オマ\n○コから漏れる音……恥ずかしいですわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0404207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んんっ、あっ、ふっ……また、乳首……張ってますか？　はい……吸って下\nさい。旦那様におっぱいを吸われるの……とても好きです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0404208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「強く……チュウっとされながら、んっ、腰を一緒に回して……オチ○ポを意\n識するだけで、あぁ……またお汁が溢れてしまいます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0404209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はぁっ、濡れやすい女は……お好きですか……？　あぁ……ありがとうござ\nいます……旦那様好みの……淫らな女になりたく思いますわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0404210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あぁっ、はぁぉっ！　今のっ……突き上げぇっ、あくぅっ、オマ○コに響い\nてっ……くひぃっ、感じっ……ますぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0404211" ]},
		{"command":[ "SETIMAGE", "0", "still_00003004_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はいっ、あぁっ、私も……もっとオチ○ポに、感じて頂きますっ……あふぁ\nっ、んっ、あぉっ、はぁっ、んひぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0404212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あぁっ……おっぱいがはしたなく揺れてっ……恥ずかしいっ……あぁっ、し\nっかり乳首を支えて下さいっ……母乳っ……吸ってぇっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0404213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はひっ、あひぃんっ！　あぁっ、オチ○ポっ……ぐぐっと……奥に来ますっ\n！　ズリズリ擦れてっ……あっ、抜けていくっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0404214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「くぁぉっ……！　ま、また……ハマってぇっ……！　あぁっ、激しいオチ○\nポピストンっ……！　熱いっ……ですっ……はぉぉぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0404215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あぁっ、オチ○ポっ……またそろそろですねっ？　はいっ、私のオマ○コも\n、また……イキそうになっておりますっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0404216" ]},
		{"command":[ "SETIMAGE", "0", "still_00003004_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「母乳もっ……奥からこみ上げている分がっ、あふれそうでっ……また、お顔\nを汚してしまうかもしれませんがっ……あっ、ひぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0404217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あぁぁぁぁっ、奥ぅっ！　そんなにグリグリなされたらっ、またイキますっ\n、オマ○コイッてしまいますからっ……旦那様もっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0404218" ]},
		{"command":[ "SETIMAGE", "0", "still_00003004_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はいっ、出してっ……出して下さいっ……！　大好きな旦那様とっ、一緒に\nイってっ……お射精っ……浴びたいですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0404219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「私もっ、おっぱい出ますっ……あぁっ、ダメですっ……もうイキますっ、オ\nマ○コっ……イクっ……イキっ、ますぅぅぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0404220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んはぁぁぁぁぁっ！　中出しっ……２発目ぇぇっ……あぉぉぉっ、出てます\nっ……奥にっ……子宮に熱いのまた届いてますぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0404301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003004_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「くぅぅぅぅっ……んぁぁっ、母乳も溢れてっ……はぁぁぁんっ、止まらない\nっ……あぁっ、射精しているみたいにっ……旦那様のお顔にぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0404302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あぁっ、そんなに夢中で飲んで頂いて……はひっ、私のオマ○コも……くぱ\nっと開いて……旦那様のザーメンを飲ませて頂いております……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0404303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「おふぅ……種付け気持ちいい……あぁぉ……オチ○ポの脈動を感じながらオ\nマ○コ満たして頂けるの……蕩けきってしまいます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0404304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んっ、あぁ……私……潮吹きまで……はぁぁ……中出しされたままお漏らし\n……あぁ……母乳と一緒に……恥ずかしいお汁が出て……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0404305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「旦那様ぁ……あぁ……はい、最後の一滴までお恵み下さい……この世で一番\n幸せなオマ○コに……もっとザーメン満たしてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0404306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はぁ……んふぁ……あぁ……終わり……ましたか……？　はぁ、はぁ……は\nひ……お疲れさまでした……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0404307" ]},
		{"command":[ "SETIMAGE", "0", "still_00003004_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あ……いえ、呼吸は乱れておりますが……私の方は大丈夫です……腰はガク\nガクになっておりますが……何とか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0404308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はい、本当に素敵な交尾……まぐわいのひとときでした……今も、オマ○コ\nから全身に幸せな快感が広がり続けております……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0404309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「きっと可愛い赤ちゃんを授かったと思います……ありがとうございます……\n旦那様……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0404310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はぁぁぁぁんっ！　あぁっ、オチ○ポ……抜けてっ……おっぱいっ、びゅく\nびゅくっ……出て……いますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0404401" ]},
