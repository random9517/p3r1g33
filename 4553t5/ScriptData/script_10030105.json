{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0185" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「まったく！　せっかく様子を見に来てやったというのに、なんだあの態度は\n！　なにが『うるさくて眠れない～』だ、このボケナスビっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114670001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「だから謝ってるじゃないですか！　まさか姫様が来るなんて、それこそ夢に\nも思ってなかったんですよ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「うるさいうるさ～い！　そもそも私がここに面会に来るために、どれだけめ\nんどくさい思いをしたか知らんだろう！　だいたいだな――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114670002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そしてルナテミスは愚痴を語り出す……。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0101" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「終わったようですね。皆さん、ご苦労様です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_072_010114670001" ]},
		{"command":[ "SETCHARA", "0", "char_00007201_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「『ご苦労様』じゃないよ！　ヤバいと思ったら、さっさと自分だけ逃げたく\nせに！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010114670001" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「まあまあ。先ほども申し上げた通り、いろいろと大人の事情もありまして」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_072_010114670002" ]},
		{"command":[ "SETCHARA", "0", "char_00007201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「なんなんだ、あいつら。めっちゃ強かったぞ！？　あっという間にカツマを\n取り囲まれて、そのまま連れて行かれちゃって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010114670001" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あいつら！　このままでは済まさんぞ！　今度はこちらから向こうに乗り込\nんで、下僕を取り返す！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114670003" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「いや、待ってくれ。おまえがカツマを心配するのはわかるが、強引に乗り込\nんでも――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090114670001" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「な、なにを言っている！？　下僕のことを心配しているわけではないぞ！？\n　あんなのでも一応隊長だから、このままでは業務がだな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114670004" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「いや、だからそういう話じゃなく、力押しではどうにもならない、と言いた\nいんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090114670002" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「そうです。次元管理統制局は、その名の通り異次元間の平和維持を任務とす\nる、いわば多元宇宙の警察です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_072_010114670003" ]},
		{"command":[ "SETCHARA", "0", "char_00007201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「力押しで勝てる相手ではないでしょう。しかし警察とは言え要するにお役所\n。カツマ隊長は罪を犯したわけでもありませんし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_072_010114670004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「やりようによっては、交渉で身柄を取り戻すこともできるのではないかと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_072_010114670005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「なにか方法でもあるのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010114670002" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「幸い、私どもクリスタル・コンツェルンは多元宇宙のあちこちに太いパイプ\nを持っています。そのへんをナニしてアレしてですね――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_072_010114670006" ]},
		{"command":[ "SETCHARA", "0", "char_00007201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「なるほど。コネを使って手をまわそうってわけかい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010114670001" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「…………有料？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010114670003" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「いえいえ！　これぐらいのことは、サービスでやらせていただきますよ？　\n皆さんとのお付き合いも３シーズン目に突入するわけですし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_072_010114670007" ]},
		{"command":[ "SETCHARA", "0", "char_00007201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「お申し出、大変ありがたい。よろこんでお受けする。しかし……メタなネタ\nは控えたほうがよくないか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090114670003" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「まあまあ、硬いことを言わないで。それはともかく、交渉の窓口として臨時\nの隊長代理を立てた方がいいかと思うのですが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_072_010114670008" ]},
		{"command":[ "SETCHARA", "0", "char_00007201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「隊長か！　隊長だな！　ついに私が隊長になるときが来たな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114670005" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "sbg_0175" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「『代理』ですけどね。では、隊長代理はルナテミスさんということで……こ\nちらをお願いします」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_072_010114670009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「え……？　なんだ？　この書類の山……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114670006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「なにって、カツマさんとの面会の申請書に、臨時入局許可証の登録、それか\nら再調査の依頼書と各種書類の閲覧希望……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_072_010114670010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「え？　え？　え？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114670007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「先ほども言った通り、相手はお役所ですからね。交渉も話し合いも、まずは\n書類から始まりますので」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_072_010114670011" ]},
		{"command":[ "SETCHARA", "0", "char_00007201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「え？　あの……えーと……書くのか？　私が？　これ全部？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114670008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「ええ。すべて責任者の自筆でなければなりませんので。よろしくお願いしま\nす。明日までに」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_072_010114670012" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「え？　え？　えええええええええーーーーーーーっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114670009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0185" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「それから連日、何十枚も書類を書かされて、ここが違う、そこが抜けてると\n、何度も何度も何度も書き直しをさせられて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114670010" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「は、はぁ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「もういやだ！　あんな仕事はもうごめんだ！　早く戻れカツマ！　そして溜\nまった書類を片付けろ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114670011" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まだあるんすか書類！　どんだけ溜め込んでるんですか！　嫌だ！　だった\nら俺も帰りたくないっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「だから！　私だってもう嫌なんだよ！　いっそ私がここに入りたいぐらいだ\nぁ～～～～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114670012" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局員" ]},
		{"command":[ "SETTEXT", "「あの……面会時間終了なんですが……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ううう……嫌だ、本部に戻りたくない……早くあのバカを釈放してもらわな\nいと、書類が……書類の山がぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114670013" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「ルナテミスさん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_090114670001" ]},
		{"command":[ "SETCHARA", "0", "char_00000609_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ふぇ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114670014" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「お話があるのです。カツマさんを釈放する条件について」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_090114670002" ]},
		{"command":[ "SETCHARA", "0", "char_00000609_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「え……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114670015" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}