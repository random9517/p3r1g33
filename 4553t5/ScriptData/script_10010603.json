		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ルナテミス様！　どうなさいました！？　ルナテミス様！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010106060005" ]},
	{"command":[ "SETCHARA", "0", "char_00000301_01", "3", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「返事がない！？　しょうがねえ、セレーナ、ドアを壊せるか！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「おうっ！　せいやぁああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010106060002" ]},
	{"command":[ "SETCHARA", "0", "char_00000401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0094" ]},
		{"command":[ "DISPIMAGE","0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ルナテミス様！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010106060006" ]},
	{"command":[ "SETCHARA", "0", "char_00000301_01", "7", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「っ！　ルナ……テミス！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010106060003" ]},
	{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "俺たちが部屋に駆け込むと、ルナテミスは頭から血を流して床に倒れている。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYBGM", "BGM_012" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「そんな……！　まさか……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010106060007" ]},
	{"command":[ "SETCHARA", "0", "char_00000301_01", "3", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010106060002" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ルナテミスの首筋に手をふれたオボロが、黙って首を横に振る。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "おいおいおいおい……いったいどうなっちまってるんだ！？　ルナテミスも…\n…死んでいるなんて！", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010106060003" ]},
	{"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0123" ]},
		{"command":[ "DISPIMAGE","0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "カツマ", "NORMAL" ]},
		{"command":[ "SETTEXT", "「っ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「…………寝かせてきたよ。ルナテミス様を。ベッドに」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010106060008" ]},
	{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「…………そうか。悪いな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「いいんだ。あたしの役目だよ。ルナテミス様が、少しでも安らかに眠れるよ\nうに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010106060009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010106060004" ]},
	{"command":[ "SETCHARA", "0", "char_00001201_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「に、しても……いったい、どういうことなんだい！　なぜ、どうして！？　\nルナテミス様が……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010106060010" ]},
	{"command":[ "SETCHARA", "0", "char_00000301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「後頭部に、鈍器で殴られた打撲傷がありました。直接の死因はそれです……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010106060003" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「そんなことは見りゃわかるんだよ！　あたしが言いたいのは――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010106060011" ]},
	{"command":[ "SETCHARA", "0", "char_00000301_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「……なぜ、ルナテミスが殺されなければならなかったのか。アナザーに続い\nて。そういうことよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010106060002" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010106060012" ]},
	{"command":[ "SETCHARA", "0", "char_00000301_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「ホントだよ……。ルナテミスが、なんでこんなことに……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010106060005" ]},
	{"command":[ "SETCHARA", "0", "char_00001201_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「しかし……こりゃまずいぞ？　アナザーの件は事故って可能性もあったが、\nルナテミスは……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「っ！　そうですね……何者かが、明確な殺意を持ってルナテミスを……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010106060003" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「えええええええっ！？　じゃあ、このホテルの中に犯人がいるってこと！？\n　やだやだやだっ！　ダイヤナちゃん怖いっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010106060001" ]},
	{"command":[ "SETCHARA", "0", "char_00000601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「そう考えると……まずいですよ。あのルナテミスをあっさり倒せるほどの\n『殺人犯』が、今、ここにいる、ということですから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010106060004" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010106060004" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「このまま、ホテルににいちゃまずいんじゃないか？　みんなでここから出よ\nう！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「バカだね。この大雨の中をテクテク歩いて出ていくつもりかい！　車は長官\nが乗ってっちまったんだよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010106060013" ]},
	{"command":[ "SETCHARA", "0", "char_00000301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「……ここから最寄りのバス停までは徒歩で５０分。道は、交通量の少ない県\n道１本だけです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010106060005" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「おまけに電話はない、携帯もつながらない……助けを呼ぶ方法もないってこ\nとだね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010106060006" ]},
	{"command":[ "SETCHARA", "0", "char_00001201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「大丈夫。助けは来るわ。長官が、警察なりＥＤＯなりを連れて戻ってきてく\nれれば……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010106060005" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「戻ってくるにしても、雨が止んでからになる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010106060004" ]},
	{"command":[ "SETCHARA", "0", "char_00000201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「どうしよう……どうしよう……あ！　そ、そうか！　こういうときは！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010106060002" ]},
	{"command":[ "SETCHARA", "0", "char_00000601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「どうした？　ダイヤナ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "sbg_0061" ]},
		{"command":[ "DISPIMAGE","0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_020" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「みんな！　こういうときは、絶対一人になっちゃダメ！　みんなで固まって\n助けを待つの！　連続殺人のときはそうしないとダメ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010106060003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「いきなりなにを言い出すんだい、あんたは」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010106060014" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「大丈夫！　ダイヤナちゃんの言う通りにすれば助かるから！　ダイヤナちゃ\nん、こういう映画いっぱい見てるから詳しいの！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010106060004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「映画……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010106060007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「たしかにそういうのは吹雪の山荘もののミステリーとか、スラッシャー映画\nなんかでは定番だけど、でも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010106060006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「そう！　定番なの！　基本なのよ！　わかったらみんな！　ダイヤナちゃん\nの言うことを聞きなさい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010106060005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ダイヤナ。あのなあ、おまえなあ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0122" ]},
		{"command":[ "DISPIMAGE","0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_005" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「エファナティカ？　どうした？」", "NORMAL" ]},
	{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
 		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「へん！　バカバカしい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010106060015" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「って、エファ？　どこ行くんだ？」", "NORMAL" ]},
