		{"command":[ "SETTEXT", "「！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010106060002" ]},
	{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「……雷のようね。さっきまで晴れてたのに、あっというまにあたりが真っ暗\nになっちゃったわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010106060001" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「雨も降りだしたよ。うわ……！　すっごい土砂降り！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010106060001" ]},
	{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「…………あ～あ。あたしたちゃいったい、なにやってんだい？　こんなとこ\nろで。土砂降りの中で」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010106060003" ]},
	{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そりゃ俺が聞きてえよ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「どうやら皆さん、だいぶ神経がピリピリしているようですね。いったん落ち\n着きましょう。お茶でも入れて――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010106060001" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYBGM", "BGM_023" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「うわぁああああああああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010106060001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
