		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ルナテミス様の声だよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010106060004" ]},
	{"command":[ "SETCHARA", "0", "char_00000301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「なにかあったのかも！　行ってみよう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010106060002" ]},
	{"command":[ "SETCHARA", "0", "char_00001201_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

