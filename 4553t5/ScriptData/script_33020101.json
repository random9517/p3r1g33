{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「あら……来てくれたのね。ふふ……入って。なに緊張してるの。自分の家だ\nと思って楽にしてくれていいのよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0103101" ]},
		{"command":[ "SETCHARA", "0", "char_00030201_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「今日はね、お店の売上がとっても良かったの。だから、今のあたしは……す\nごーくいい気分だったりして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0103102" ]},
		{"command":[ "SETCHARA", "0", "char_00030201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「そんなわけだから……特別にいっぱいご奉仕してあげようかなって……んっ\n、着物も……邪魔になっちゃうわよね？　ふふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0103103" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「あら……あなたもすっかりその気になってくれてるみたい……嬉しいわ……\nじゃあ、こっちも邪魔なモノは脱がしちゃいましょうね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0103104" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「なぁに……もうこんなに大きくさせちゃって……ずいぶんとやらしい子ねぇ\n？　もう呼び出しされた時から楽しみだったのかしら？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0103105" ]},
		{"command":[ "SETIMAGE", "0", "still_00030201_01_02" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「でも、それならあたしも期待に応えてあげなくちゃ……このビンビンに勃起\nしたオチンポ……最高のご奉仕をしてあげるわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0103106" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「ふふ……じゃあ……やさーしく……両手で包み込んであげますからねぇ……\n　あぁ……震えちゃって、かーわいい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0103107" ]},
		{"command":[ "SETIMAGE", "0", "still_00030201_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「どうしたの？　まだちょっとオチンポを触っただけよ？　今からそんなにビ\nクビクさせちゃって……大丈夫かしら？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0103108" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「ちょっと止める？　ええ、いいわ。いきなり漏らしちゃったらもったいない\nものね……しっかり深呼吸でもしてみましょうか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0103109" ]},
		{"command":[ "SETIMAGE", "0", "still_00030201_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「息を吸ってぇ……大きく吐いてぇ……気持ち……立て直すことができた？　\nそれじゃ、改めて……むにゅっと触っちゃうわねぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0103110" ]},
		{"command":[ "SETIMAGE", "0", "still_00030201_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「ふふっ、また可愛い声を漏らしちゃって。ちょっと指を絡ませただけじゃな\nい。あなたのオチンポ……本当に敏感なのね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0103111" ]},
		{"command":[ "SETIMAGE", "0", "still_00030201_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「でも、すごく逞しいのが……指先から全部伝わってくるわ……　左手にちょ\nっと力を入れると……どくんって脈打ってるのが……伝わるの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0103112" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「それで根元をぎゅっとしてあげて……右手でオチンポの先端をつぅーっと…\n…あんっ！　ふふっ、ビクンってしちゃったわねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0103113" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「どう？　今のだけでも気持ちいい？　オチンポがムズムズして、切なくって\n……身体の力が抜けちゃうでしょう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0103114" ]},
		{"command":[ "SETIMAGE", "0", "still_00030201_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「もうちょっとだけ強くしてあげましょうか。根元を……むぎゅーっと握って\n……くびれの所……後は裏スジを……こちょこちょ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0103115" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「ふふっ、腰が浮き上がっちゃうわよね？　あんまり力入れない感じでも、し\nっかりオチンポの奥に気持ちいいのが届いちゃうでしょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0103116" ]},
		{"command":[ "SETIMAGE", "0", "still_00030201_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「オチンポの感じやすい場所……指だけでもメロメロにできちゃうから期待し\nててねぇ……　んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0103117" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……次は、割れ目のところ……ほんの少しだけめり込ませようか\n……。大丈夫……痛くしたりはしないからねぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0103118" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「でも、あんまり暴れたら、ヘンなことになっても知らないわよ？　そう……\n全部身を任せて……身体を楽によ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0103119" ]},
		{"command":[ "SETIMAGE", "0", "still_00030201_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「いいわ……おっぱいをじっと見ておけば安心するかもね……あたしのお客さ\nんでも、簡単に見られるわけじゃないんだから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0103120" ]},
		{"command":[ "SETIMAGE", "0", "still_00030201_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「ふふ、触りたいなら触ってもいいのよ？　んんっ……いきなり乳首からなん\nて……その図々しさ……嫌いじゃないわね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0103121" ]},
		{"command":[ "SETIMAGE", "0", "still_00030201_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……気持ちいい所同士……もっと撫でっこしましょうか……あた\nしも、もっとオチンポ可愛がってあげる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0103122" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「ほーら……くちゅくちゅ……いやらしい音がしてきたみたいね……オチンポ\nが、着実に射精したいって準備を始めてる音……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0103123" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「でも、まだちょっと勇み足かしら。もう少し、じっくり楽しんで貰ってから\nでも遅くないでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0103124" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「そろそろ……こうやって……ふふ、亀頭をコリコリされるの……もっと速く\nして欲しい？　いいわよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0103125" ]},
		{"command":[ "SETIMAGE", "0", "still_00030201_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「オチンポのとっても敏感な先っぽを～コリコリ～くちゅくちゅ～　あふっ…\n…いい音鳴らしちゃってるわねぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0103126" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「男の無防備な弱点を握りしめられると、とっても心細くなっちゃうじゃない\n？　あたしの気がいつ変わるかも分からないし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0103127" ]},
		{"command":[ "SETIMAGE", "0", "still_00030201_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「でも、そんな心配な状態なのに、優しくよしよしされたら……オチンポもす\nっかり安心しちゃって……ぴゅっぴゅしたくなっちゃうのよね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0103128" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「ふふ……一生懸命ガマンしようとしてる？　でも、もうオチンポの方は出し\nたいって気持ちが出ちゃってるみたいなのよねぇー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0103129" ]},
		{"command":[ "SETIMAGE", "0", "still_00030201_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「ほら……この先走り……ちゅぷっって言ってるでしょ？　これはねぇ、もう\n待ちきれないってオチンポが泣いちゃってるの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0103130" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「だから……あたしは、しっかりよしよししてあげてぇ……いーっぱい、どぴ\nゅっとさせてあげたいの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0103131" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「んっ、ふふ……後はもう、シコシコするペースも上がっちゃうからねぇ……\nずりゅずりゅさせてぇ……一緒に亀頭もギュッとして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0103132" ]},
		{"command":[ "SETIMAGE", "0", "still_00030201_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「今は根元を抑えてるから何とかなってるけど……これを離したらもう出ちゃ\nうでしょ？　じゃあ……そのままイッちゃおう……ね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0103133" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「ぐりぐり……ずりずり……はぁい、ビクビクしてぇ……イッちゃえっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0103134" ]},
		{"command":[ "SETIMAGE", "0", "still_00030201_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「んふっ……！　あぁら、全然ガマンできなかったわねぇ……　どぷどぷ、噴\n水みたいに溢れてきてる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0103135" ]},
		{"command":[ "SETIMAGE", "0", "still_00030201_01_05" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「思った以上にしっかり溜め込んでいたのねぇ……ふふっ、こんなに手を汚し\nてくれちゃって……だぁめじゃなぁい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0103136" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「ま……あたしのご奉仕を踏ん張れる男なんて、そうそういないから、心配し\nなくてもいいわよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0103137" ]},
		{"command":[ "SETIMAGE", "0", "still_00030201_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「れろ……んちゅぷっ……んふふ……味見　うん、新鮮で美味しい　ちゅぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0103138" ]},
		{"command":[ "SETIMAGE", "0", "still_00030201_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「ほぉら見て、指のとこ……にちゃってしてる。どう、あなたも舐めてみる？\n　ふふっ、さすがにイヤみたいねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0103139" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「冗談よ……これは、ちゅぷっ、こうして……あたしが代わりに頂いちゃうか\nら……んっ、れろ、ちゅぱっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0103140" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「さて……普通ならこれでおしまいだけど……今日は気分もいいし、もうちょ\nっとご奉仕を続けちゃおうかしら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0103201" ]},
		{"command":[ "SETIMAGE", "0", "still_00030201_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「もちろん、お金なんて取らないわ。あなただから、特別にしちゃうんだから\n……ねっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0103202" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「ふふっ、オチンポちゃんは大歓迎してくれてるみたいね。すぐに、ビクンっ\nて上向きになっちゃって……可愛らしいこと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0103203" ]},
		{"command":[ "SETIMAGE", "0", "still_00030201_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「さ……そうと決まれば、今度はどんな風にしてあげましょうか。やっぱり、\nもっと徹底的にオチンポを甘やかしてあげるのがいいかしらね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0103204" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「そう、難しいことはしないの。ただ、ひたすら優しく甘やかしてあげるだけ\n……オチンポの感覚を研ぎ澄ませてやるように、こうして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0103205" ]},
		{"command":[ "SETIMAGE", "0", "still_00030201_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「んふふ……どう？　イッたばかりのオチンポは、まだびっくりしてるから、\nそっとしてあげるのがいいのよね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0103206" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「でも、じっくりじわぁーっと気持ちいいのが広がるように……指でさすって\nあげるから……ふふ、精液がヌルヌルしてるわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0103207" ]},
		{"command":[ "SETIMAGE", "0", "still_00030201_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「いいのよ、おっぱいも？　もっと遠慮なく触って大丈夫だから……あんっ、\nふふ、上手ね……そう、優しく触って……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0103208" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「あたしもお返し……ふふっ、ぎゅうっと……キンタマさんを握りしめてあげ\nる……　あら……くにくにして、可愛いわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0103209" ]},
		{"command":[ "SETIMAGE", "0", "still_00030201_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「また鼻息が荒くなって来ちゃったわね。もうちょっと強くして欲しい？　い\nいわ……オチンポの休憩も終わったみたいだし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0103210" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「本格的にオチンポ……トロトロにさせてあげましょうね……　んっ、ふふ…\n…指をいっぱいに絡ませてあげる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0103211" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「はーい、ぎゅっ　ぎゅーっと……オチンポの脈打ってるところ……しっかり\nと押し付けて……指をつぅっと這わせて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0103212" ]},
		{"command":[ "SETIMAGE", "0", "still_00030201_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「亀頭は……ムズムズしてるとこをやさしーくタッチして、はぁん……あたし\nもどんどん興奮してきたみたい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0103213" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「このビクンって震えるオチンポを触ってると……んっ、おっぱいがムズムズ\nしてきちゃう……あんっ、乳首……弄ってぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0103214" ]},
		{"command":[ "SETIMAGE", "0", "still_00030201_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「はふっ、んふぅっ……いいわ……ここから、またペース上げていくから……\nいっぱい皮を捲り返して……シコシコしてあげる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0103215" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「あぁ……すっかり熱くなって……また我慢できないってお汁がぴゅっぴゅし\nかけてる……　後もうちょっとガマンしましょうね～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0103216" ]},
		{"command":[ "SETIMAGE", "0", "still_00030201_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「そうしたら、飛んじゃう位気持ちいーい、射精が待ってるからねぇ……　ほ\nら、弱い所が腰砕け～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0103217" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「さあ、ビクビクがどうしようもなく止まらなくなったところで……そろそろ\n、派手なの飛ばしちゃいましょうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0103218" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「もういいのよ、後はあたしの指に身を任せて……オチンポから力を抜いて…\n…そのままドピュって出しちゃいましょ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0103219" ]},
		{"command":[ "SETIMAGE", "0", "still_00030201_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「ほぉら……またイッちゃえ……　あたしの指で蕩けきって、エッチな噴水…\n…びゅびゅって出しなさいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0103220" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「んんんっ……んふっ……いっぱい出てる……　最初の時より、もっと元気に\n溢れてきてるんじゃない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0103301" ]},
		{"command":[ "SETIMAGE", "0", "still_00030201_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「そのまま、どんどん出しちゃいましょ……　ほぉら……シコシコする度に、\nまたビュルって飛んじゃうわねぇ……いやらしい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0103320" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「気持ちよさそうなトロ顔しちゃって……れろっ、そんな顔見せられたらつい\nつい舐めたくなっちゃうじゃない……んふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0103303" ]},
		{"command":[ "SETIMAGE", "0", "still_00030201_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「そろそろ、射精も収まりそう？　じゃあ、一番最後に奥に残ってる分……ピ\nュってしましょ……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0103304" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「あふっ……出てきたわね。精一杯に搾り出した、残りザーメン……んっ、い\nいお味……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0103305" ]},
		{"command":[ "SETIMAGE", "0", "still_00030201_01_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「脱力しちゃった？　ふふっ、あたしも、少し張り切りすぎたかも……あなた\n……経験豊富な割には、反応がすごく新鮮なんだもの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0103306" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「あらあら……もう指がネトネトになって、ほら見て……あなた、こんなに出\nしちゃったのよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0103307" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「ふふ……まだオチンポが硬いから、更に搾り尽くそうと思ったらできなくも\nないのかしら？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0103308" ]},
		{"command":[ "SETIMAGE", "0", "still_00030201_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「冗談よ……　そんなにあからさまに腰を引かないで、今日はずっと優しいま\nまなんだから……心配しないでも、ね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0103309" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「ええ、少し休みましょうか。綺麗に拭き取って……オチンポスッキリさせて\n……落ち着いたら、また続きを考えましょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「んぁんっ！　すごいじゃない……こんなに飛ばして……んっ、おっぱいに…\n…顔にまで届いて来てる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0103401" ]},
		{"command":[ "SETIMAGE", "0", "still_00030201_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「ふふ……まさか、こんな所で顔に浴びせられちゃうなんて……逞しいわ……\nねっ、もう一回飛ばしてみせて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0103402" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「ほら、思いっきりシコシコして……んんっ！　んふっ、あぁ……素敵よ……\nこんなに元気な射精してくれるなんて……嬉しい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0103403" ]},
		{"command":[ "SETIMAGE", "0", "still_00030201_01_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「オチンポ痺れちゃった？　無理もないわね……ちゅぷっ、こんなに飛ばした\nら、オチンポもさぞ気持ちいいんでしょうね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0103404" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「んふ……止まったわね……お疲れ様……元気いっぱいの射精を見せてもらっ\nて、ちゅぷっ、あたしも嬉しいわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0103405" ]},
		{"command":[ "SETIMAGE", "0", "still_00030201_01_12" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「あら……肩で息しちゃって……あたしの手コキご奉仕、そんなに気持ちよか\nったのかしら？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0103406" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「そう、まだお口も……オマンコも使ってないんだけど……でも、これだけ喜\nんでくれたのなら、ご奉仕してよかったわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0103407" ]},
		{"command":[ "SETIMAGE", "0", "still_00030201_01_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「ふふっ、脱力して返事をする気力も残ってない？　でも、まだオチンポはし\nぼみ切ってないし……意外にできなくもないのかも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0103408" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「冗談よ……　さすがに少しくたびれたわよね。分かっているわ、とりあえず\nは一息入れないとね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0103409" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「オチンポを綺麗にするから待ってて。それで、もし本当に余裕が残ってるな\nら……ちょっと続きをするのもいいかも知れないわね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0103410" ]},
		{"command":[ "SETIMAGE", "0", "still_00030201_01_12" ]},
		{"command":[ "WAITINPUT" ]},
