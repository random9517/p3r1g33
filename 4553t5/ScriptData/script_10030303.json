{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0027" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「おっしゃ！　こっちの勝ちぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_010114970001" ]},
		{"command":[ "SETCHARA", "0", "char_00022601_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "敵の襲来者" ]},
		{"command":[ "SETTEXT", "「だーっ！　負けた！　いや、今日もいい試合でした！　んじゃ、こっちの負\nけなので、今回もウチら帰りますんで。お疲れっしたー！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お、おう、お疲れ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「お疲れ～。次はいつ来んの～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_010114970001" ]},
		{"command":[ "SETCHARA", "0", "char_00022801_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "敵の襲来者" ]},
		{"command":[ "SETTEXT", "「えーと、ウチの班が次に地球担当になるのは……あ、来週だね～。またその\nときよろしく～」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「と、言いながら彼女たちは帰っていきます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_010114970001" ]},
		{"command":[ "SETCHARA", "0", "char_00022701_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「っていうか、あの子たちシフト組んで侵略に来てたのね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010114970001" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「バイトのノリで侵略に来られてもなぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_020114970001" ]},
		{"command":[ "SETCHARA", "0", "char_00001302_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ええい！　まったく！　襲来者（インベーダー）どもでは話しにならぬ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100114970001" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「やべえ！　今度はガチなのが来た！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「今度こそオレが、おまえらにとどめを刺してやる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080114970001" ]},
		{"command":[ "SETCHARA", "0", "char_00000408_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「やぁ～ん……温度差が激しすぎぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010114970002" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「へっ！　偽者が本物に勝てるかよ！　どっからでもかかって――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010114970001" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あいかわらず、えらい自信です。根拠がないのも相変わらずですが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010114970001" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「っ！　オボロ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010114970002" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「お久しぶりですね、バカ犬」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010114970002" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「うるせえ！　この裏切者！　どの面下げて出てきやがったんだ！　今日とい\nう今日は、もう絶対許さねぇーーーーーーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010114970003" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「セレーナ！　待て！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090114970001" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「待てねーーーーーーっ！　うがぁああーーーーーーーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010114970004" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「さあ！　また、縄張りをめぐる戦いの始まりです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_010114970002" ]},
		{"command":[ "SETCHARA", "0", "char_00022701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「ちょっーと待った！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_040114970001" ]},
		{"command":[ "SETCHARA", "0", "char_00015604_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「なんですか、元リーダー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_010114970003" ]},
		{"command":[ "SETCHARA", "0", "char_00022701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「セレーナが短気で無謀なのはいつものことだけど、今日はいつもにも増して\n短気で無謀じゃない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_040114970002" ]},
		{"command":[ "SETCHARA", "0", "char_00015604_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「おや、いいところに気づきましたね、元リーダー。実はセレーナさん、オボ\nロさんに裏切られたばかりなんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_010114970004" ]},
		{"command":[ "SETCHARA", "0", "char_00022701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「裏切られた、だって？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_040114970003" ]},
		{"command":[ "SETCHARA", "0", "char_00015604_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「はい、それはこういう事情なんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_010114970005" ]},
		{"command":[ "SETCHARA", "0", "char_00022701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0101" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_011" ]},
		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「私が『宇宙の始発駅』に取り残されてしまったときです。オボロさんを見か\nけて駆け寄っていくと、彼女が突然攻撃を……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010114970001" ]},
		{"command":[ "SETCHARA", "0", "char_00001102_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「まさかオボロさんが裏切るなんて思っていなかったから、とてもショックで\nした……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010114970002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「セレーナさんはオボロさんとの付き合いも長いし、きっと、わたしなんかよ\nりもずっと傷ついたんじゃないかと思います……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010114970003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0027" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「と、いうことなんです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_010114970006" ]},
		{"command":[ "SETCHARA", "0", "char_00022701_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「いまの証言ＶＴＲなに？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_040114970004" ]},
		{"command":[ "SETCHARA", "0", "char_00015604_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「だーかーら！　お前ら、遊んでないで戦えーっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}