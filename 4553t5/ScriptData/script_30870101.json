{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "PLAYVOICE", "087_0103101" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「……はぁ、はぁっ……どうした！？　こんな夜更けに私を呼び出して……！ \n敵襲か！？　すぐに出撃可能だ！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00008701_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "087_0103102" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「……ん……？　敵の気配がない……。それに、貴様のその余裕綽々な態度…\n…。どうやら、私の勘違い……か？　ならばなぜ呼んだ」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00008701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "087_0103103" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「貴様もアホではあるまい。仕事で忙しい中、わざわざ私を呼びつけて酒でも\n飲もうというわけではないのだろう？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "087_0103104" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「ふむ。さらなる戦力増強のために、ここでパワーアップの儀式をしている…\n…。そうか、この殺風景さは研究室だからなのか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "087_0103105" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「ようやく合点がいった。それで？　今日は私の番というわけか。いいだろう\n、どうすればいい？　フ……多少の痛み苦しみには耐性がある」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00008701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "087_0103106" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「薬物の投与か？　黒魔術か？　それとも、機械を使った改造か？　強くなれ\nるのならば……私はかまわん。……は？　パイズリフェラ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "087_0103107" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「パイズリ、フェラ……！？　き、貴様ァアア……！　ついに頭が沸騰したか\n！？　パイズリフェラがなぜ戦力に影響する！？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00008701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "087_0103108" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「……何？　他の女幹部たちは全員これを受け入れ、強くなっている……？　\nそれなのに、私には意気地がなくて逃げるのか、弱虫、だと……！？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00008701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "087_0103109" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「よ、わむし！？　私は弱虫と卑怯者が大嫌いだ！　いいだろう……何が怖い\nものか、恐ろしいものか！　はっ、人体改造でなくて残念だったくらいだ！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00008701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "087_0103110" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「パイズリフェラなど恐れるに足らん！　……やってやろうじゃないか……。\nそらっ！　剣でその衣服、切り裂かれたくなくば……自分から差し出せ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "087_0103111" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「幾千の闘争に勝利したこの私、ダークエルフのアーリッドが肉の棒の一本や\n二本でおじけづくとでも……って、あッ！？　ああっ！？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00008701_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "087_0103112" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「な、なんだ……こ、これがチンポ……？　貴様の肉の、棒……！？　っ……\nごくっ……想像より、なんというか……こわ……。い、いやっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "087_0103113" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「怖いわけがあるか！　とっとと始めるぞ……！　そこになおれ！　……そ、\nそうだ……そうして……私に己の弱点を晒せ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "087_0103114" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「んっ……。ん……？　なんだ？　この、鉄の棍棒のような硬さ……なぜ股間\nに、こんな凶器を隠していた……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "087_0103115" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「うわ、わわ、しかも動くぞ……！？　醜悪な……！　赤黒く、青筋のたった\nグロテスクな見た目といい、……うぷ……すえた臭いといい……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "087_0103116" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「確かに、これを大事な胸で刺激し……慰めるのは……人体改造に匹敵するダ\nメージかもしれない……。ううう……っ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "087_0103117" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「も、もっと小さくて可愛くて、ぷるぷるした形なら良かったのだが……。こ\nこまで禍々しくもそそり勃ち、天を仰いでいるとなると……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "087_0103118" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「……。ま、まあいい。これを胸部で挟み込んで……。ん……、ぅ……ユサユ\nサと揺らしながら圧迫すればいいのだな……。フェラはまだだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "087_0103119" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「まずは、小手調べ……。ふっ、ふっ……！　貴様の男根を……ふぅっ……胸\nで覆い……揺らす……ぅっ……！　はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "087_0103120" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「こんなことの何が楽しいんだ……！　それにパイズリをさせたいだけなら…\n…んっ！　もっと適した女がそこかしこに、ふぅっ、いるだろう！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "087_0103121" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「もっと肌がなめらか、で……はぁっ、柔らかく、肉づきのいい……はぁ、は\nぁ……私のような筋肉質で、力ばかり強い……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "087_0103122" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「ダーク、エルフ……に……っ。ん、呪われた色の肌をもつ、私なんかにさせ\nてどうする……っ。そ、それとも、嘲笑って、いるのか……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "087_0103123" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「女としての魅力がな、く……はぁっ、バストサイズばかり肥大した男日照り\nの私、を……ダークエルフの、私、を……だとしたら許さ……。何？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "087_0103124" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「私の胸を見て、いつも挟んで欲しいと思っていた？　あっ……あ、あ、き、\n貴様……貴様！　戯言を……！　か、甘言、甘言はやめ、ろ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "087_0103125" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「……っふぅっ……ふぅ、ふぅっ……。パイズリにいきなり熱がこもった？　\n真剣にやっている？　馬鹿が。勘違いだ。勘違いするなよ……はぁっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00008701_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "087_0103126" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「す、少し性欲を向けられただけで……褒められただけで、パイズリを熱心に\nしてやるほど……このアーリッド、甘くはない……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "087_0103127" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「甘くないと言っているだろう！　っ……少し黙っていろ。貴様はいつもそう\nだ、やかましくて……わ、私なんかの身体に欲情して……。んっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "087_0103128" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「そんなやつのチンポはこうしてやるっ……！　それっ、それ、それ……！　\nんっ……んんっ、んん……んぅ……んん！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "087_0103129" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「ハハ……興奮しているのか？　チンポが破裂寸前だぞ。指でつついたら……\nん、弾けてしまいそうだな。だが、攻撃の手は緩めん……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "087_0103130" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「ほら、苦しいか？　キツいか？　私の屈強な乳房にこすられて、しごかれて\n……んんっ……！　悲鳴の一つもあげたくなったか？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00008701_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "087_0103131" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「この重みが、……傲慢なまでの胸づかいこそが、戦場に生きる私のパイズリ\n……。……ん？　すごく気持ちいい……だと！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "087_0103132" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「ぁ……。そ、そう、か……。では続ける……。すまない。しゃべり過ぎてい\nたのは私の方だったようだ……。き、緊張して……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00008701_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "087_0103133" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「こんなことを望まれたのは初めてだったのでな。つ、ついつい戦いのノリで\n……べらべらと口上を……。すまない……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "087_0103134" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「ふっ……ふっ、ふっ、ふぅっ……んッ！　んっ、んっ、んっ……。んっ、ん\nっ……んっ、ンッ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "087_0103135" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「はぁっ……はぁ、はぁ……角度はこのままでいいか？　もっと先端を……私\nの乳房に突き刺すように埋めて……ああ、そうだ、そうだっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "087_0103136" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「せっかく私がしてやっているんだ、得られる快感は全て得ていけ……。ん…\n…んっ……んっ、ん……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "087_0103137" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「温かい……？　そうか。私は熱い……。貴様のチンポが熱をはらみ、んっ…\n…ぐりぐりと押し付けられるものだからな……んっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "087_0103138" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「だんだん……ん、ん……妙な気分に……くぅう……、ぁっ……あぁ……な、\nなんでもない……っ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00008701_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "087_0103139" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「そ、そうだ、パイズリフェラだったな。フェラ……してやろう。なあに、今\n日の私は機嫌が、いい、のだ……いくぞ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "087_0103140" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「はむっ……んんん……れろっ！　れろっ、れろ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00008701_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "087_0103201" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「ぢゅるっ、ぢゅるるっ！　ぢゅるっ、ぢゅるるっ……れるんっ……れる、れ\nる、れる……ぴちゃっ！　ちゅぷっ、ちゅぷぷぷ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "087_0103202" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「ん、は、ぁ……っ……！　見た目だけじゃにゃく……んん、味も強烈だにゃ\n……っ。れろ……れろ、れろ……れろ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00008701_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "087_0103203" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「んぁっぷっ！　ほ、頬を突き破られるかと思った……あふ……。本当に、貴\n様のチンポは凶悪だにゃ……んっ、んむぅ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "087_0103204" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「あぷ、あぷ……れるっ……ぢゅる……じゅるっ……んんぅ……。んぷ……ぢ\nゅっ、ぢゅっじゅる……じゅる……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00008701_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "087_0103205" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「はむっ……んむっ……んむぅ……！　ちゅるるる……ちゅるっ、んっんぐっ\n……ぐぷっ！　ぐっぷっぐぷっ……れるれる……っ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "087_0103206" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「んっ……んぢゅるっ……じゅるっ、じゅるるっ、じゅるっ……あふ……っ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "087_0103207" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「んぁ……唾が溢れて……。チンポの方に……んんん……啜りとらねば……。\nんっ……れろぉ……れろっ、ぺろ、ぺろ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "087_0103208" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「あむ……んむ……んむ……ぢゅるっ、じゅっぷっじゅっぷっじゅっぷっじゅ\nぷ……はぁああ……♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "087_0103209" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「フフ……永く生きたものだが……れる……私にここまでさせたのは貴様だけ\nだ……。その度胸、かってやるとしよう……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "087_0103210" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「好きなところに出していいぞ……。っ……ど、うせ胸と口、程度……はぁっ\n……汚されたところでかまいはしない……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "087_0103211" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「だ、が……んん……！　あまりにも貴様の肉棒が尖るもので、な……んん…\n…！　乳房がこすれて、あっ、おかしな感じだ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00008701_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "087_0103212" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「口の中にも、チンポの味が広がって……あぁ……なぜか鼓動が早く、なって\n……くそ……くやしいが、少し感じる……ンンン……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "087_0103213" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「わ、私がどうにかなる前に早く出せっ……本気を出してしゃぶってやるから\n……一秒でも早く解放、してくれ、ん、ぁ、ぁ、あ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "087_0103214" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「ぐ、ぷ……！　ぐちゅっ！　ぐちゅっぐちゅっぐっちゅっ！　ぬるぅ……れ\nるっ、れるぅ、れる……じゅっぽじゅっぽじゅっぽじゅっぽっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "087_0103215" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「ずっちゅっ！　ぐっちゅっぐっちゅっ！　ぢゅるるっ、んぢゅるるるっ……\nぷぁ……！　ぐっぷっ！　ぐっぷっ！　ぐちゅっぐっちゅっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "087_0103216" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「あぁ……顔があちゅい……ッ、胸も、ヒリヒリする……んん……酸素が薄く\nなって、頭がくらくら……して……。ううう、早くイけぇ！」", "NORMAL" ]},
