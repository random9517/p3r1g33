		{"command":[ "PLAYVOICE", "087_0103306" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「胸でチンポの根元からぁ……んんん、精液を絞り上げて……ぢゅるるるるっ\n……口の中に、溜めた濃い汁を……」", "NORMAL" ]},
