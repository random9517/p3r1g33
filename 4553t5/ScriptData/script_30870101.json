		{"command":[ "PLAYVOICE", "087_0103410" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「フフ……。別に褒めてほしいわけではないが……また、パワーアップが必要\nになれば呼べ。別に、褒めて欲しいわけではないがな……！」", "NORMAL" ]},
