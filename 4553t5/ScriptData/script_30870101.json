		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「ん、ぁ……ああッ、はぁっ、ぁああっ……！？　なぜ顔に、ん……胸、にぃ\n……貴様ァ……っ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "087_0103403" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「貴様の命でパイズリフェラをしてやった私に、んぶっ！？　こら！　文句の\n途中で射精するんじゃないっ……ああああ！」", "NORMAL" ]},
