		{"command":[ "PLAYVOICE", "087_0103217" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「ちゅぷぷぷっ、れろれろれろ……っ、んぁああ……はぁあっ！　んちゅっ、\nぢゅるるっ！　ぐちゅっ！　ぐっちゅっぬちゅっぬぷっ！｝", "NORMAL" ]},
