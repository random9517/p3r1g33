		{"command":[ "PLAYVOICE", "087_0103305" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「で、であれば私も……。ん……んっぐっ……。んく、んく、んく……ど、ど\nう、ら……」", "NORMAL" ]},
