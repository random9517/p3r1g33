		{"command":[ "PLAYVOICE", "087_0103308" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「はぁ……喉に絡みつく……。それに、舌にもまだ、まとわりついているよう\nな感触が残って……」", "NORMAL" ]},
