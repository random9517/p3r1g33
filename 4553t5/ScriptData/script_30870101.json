		{"command":[ "PLAYVOICE", "087_0103309" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「強いオスの味が、する……。もし、こんなものを無理やり膣内に注がれてい\nたら……。はっ！？　な、なんでもないっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "087_0103310" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
