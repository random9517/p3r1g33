{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0027" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「ウタ！　そっちに襲来者（インベーダー）が行ったよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010021530001" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00009601_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「わかってる！　オレに任せとけ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_010021530001" ]},
		{"command":[ "SETCHARA", "0", "char_00009701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「任せとけって……さすがにウタ姉一人でその数を相手にするのは、無理があ\nるんじゃないなぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021530001" ]},
		{"command":[ "SETCHARA", "0", "char_00009801_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「なら、あーしがウタ姉を援護するから、ゲン姉はホク姉を援護してあげて～\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_010021530001" ]},
		{"command":[ "SETCHARA", "0", "char_00009901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「りょーかい！　いざ、カマクラーッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021530002" ]},
		{"command":[ "SETCHARA", "0", "char_00009801_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「ありがとう、ゲン！　右の敵は僕が倒すから、左の方をお願い！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010021530002" ]},
		{"command":[ "SETCHARA", "0", "char_00009601_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ラビットパワー全開でイクぜ！　イェーーーイ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_010021530002" ]},
		{"command":[ "SETCHARA", "0", "char_00009701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「ちょっとウタ姉～。置いていかないで～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_010021530002" ]},
		{"command":[ "SETCHARA", "0", "char_00009901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "bg_0027" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……さっきから結構な数を倒してるはずなのに、どんどん敵が湧\nいて来る……！　いったいどうなってるの……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010021530003" ]},
		{"command":[ "SETCHARA", "0", "char_00009601_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「泣き言なんてホクらしくねぇぞ。でも、これはさすがに異常だな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_010021530003" ]},
		{"command":[ "SETCHARA", "0", "char_00009701_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「このままだと、私たち全員ナムアミオダブツだね……どうする、ホク姉」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021530003" ]},
		{"command":[ "SETCHARA", "0", "char_00009801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「こんなところで死ぬなんて、あーし絶対にゴメンだよぉ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_010021530003" ]},
		{"command":[ "SETCHARA", "0", "char_00009901_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「くっ……！　襲来者（インベーダー）が湧く原因さえわかれば、僕たちのラ\nビットパワーでなんとかできるのに……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010021530004" ]},
		{"command":[ "SETCHARA", "0", "char_00009601_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「先生からの通信だ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010021530005" ]},
		{"command":[ "SETCHARA", "0", "char_00009601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「お前たち！　聞こえるか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010021530001" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「オーケー。問題なく聞こえてるよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021530004" ]},
		{"command":[ "SETCHARA", "0", "char_00009801_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「っても、悠長に話してる暇はないけどな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_010021530004" ]},
		{"command":[ "SETCHARA", "0", "char_00009701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「そうそう。さっきから襲来者（インベーダー）が現れ続けて、とってもピン\nチなんだよね～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_010021530004" ]},
		{"command":[ "SETCHARA", "0", "char_00009901_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「かなり苦戦しているようだな。だが、いい知らせがある」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010021530002" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「いい知らせ？　もしかして、この襲来者（インベーダー）の大群をなんとか\nできる方法とか～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_010021530005" ]},
		{"command":[ "SETCHARA", "0", "char_00009901_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「その通りだ。たった今、襲来者（インベーダー）の本拠地が判明した」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010021530003" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「襲来者（インベーダー）の本拠地！？　それ、本当なの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010021530006" ]},
		{"command":[ "SETCHARA", "0", "char_00009601_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「ああ、間違いない。場所は南にあるリゾート地だ。湧き続けている襲来者（\nインベーダー）も、そこから送り込まれているらしい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010021530004" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「なら、今からその本拠地に殴り込みをかければいいってことだな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_010021530005" ]},
		{"command":[ "SETCHARA", "0", "char_00009701_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「行くのはいいけど、ここに居る襲来者（インベーダー）たちはどうするの？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021530005" ]},
		{"command":[ "SETCHARA", "0", "char_00009801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「安心しろ。私の知り合いに話を通してあるから、そっちは問題ないはずだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010021530005" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「とりあえず、目的地を端末に送っておく。私もすぐに向かうから、お前たち\nも急いで指定した場所に集まってくれ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010021530006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「オーケー！　目的地を確認したよ！　すぐに向かうね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010021530007" ]},
		{"command":[ "SETCHARA", "0", "char_00009601_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「みんな、今の話聞いてたよね。今から敵の本拠地を叩きに行くよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010021530008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「それはいいけど……この目的地、結構遠くない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021530006" ]},
		{"command":[ "SETCHARA", "0", "char_00009801_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「ちょっとした小旅行みたいになりそうだし、ちゃんと準備しておかないと～\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_010021530006" ]},
		{"command":[ "SETCHARA", "0", "char_00009901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「なら各自準備を整えて、現地集合するってのはどうだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_010021530006" ]},
		{"command":[ "SETCHARA", "0", "char_00009701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「それがいいかもね～。おやつも買っておかないと、途中でお腹減っちゃいそ\nうだし～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_010021530007" ]},
		{"command":[ "SETCHARA", "0", "char_00009901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「それじゃあ、ここは先生が呼んでくれた人たちに任せて、僕たちは準備をし\nようか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010021530009" ]},
		{"command":[ "SETCHARA", "0", "char_00009601_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「あっ、おやつは３００ゼニーまでだからね。無駄遣いしないように！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010021530010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「りょーかい！　いざ、シュツジン！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021530007" ]},
		{"command":[ "SETCHARA", "0", "char_00009801_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}