{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015402_02_02" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「はぁ……と、とうとう隊長氏と……こんな関係に……あぁぁ、どうしよう？\n　どうしましょう？　きききき緊張、するでござるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0204101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「は、はいっ……覚悟は出来てるでござる……あ、いえ、その……覚悟できて\nるのかな？　うう、ちょっと自信ないです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0204102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「でも、その……まだ、あまり濡れていないでござるよ……濡れてる方が痛く\nないんでしょう？　だから……その、ちょっと不安でござるよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0204103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「んんんっ……はぁ……お、おっぱい……気持ちいい……あ、ん、はぁ……は\nぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0204104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「おっぱい、モミモミされるの、大好きでござる……んっ、あああぁん……身\n体が、熱くなっちゃう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0204105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「あ、やだ……乳首がビンビンでござる……はぁ……はぁ……ああ、こんなに\n大きくなったの、始めて、かも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0204106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「あっ！　はぁあん……乳首、そんなに摘まれたら……あああん！　い、痛い\n……痛いけど、気持ちいい……はぁぁあん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0204107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「身体が、とろけてしまいそう……え？　もう濡れてる……？　あはは、そ、\nそうみたい、でござる……ビチャビチャです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0204108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「あ、あの……もう大丈夫でござるから……はぁ、はぁ……だから、挿れて、\n下さい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0204109" ]},
		{"command":[ "SETIMAGE", "0", "still_00015402_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「あ……先っちょが……アソコの入り口に……あ、ああ、あったかい……ええ\n、どうぞ。もう心の準備はできてますから――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0204110" ]},
		{"command":[ "SETIMAGE", "0", "still_00015402_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「んはぁぁぁ……はぁ……あぁぁ……入り口が、パックリ開いてるぅ……あ、\nああ……アソコが、伸び切っちゃうぅ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0204111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「あ……あ……どんどん、奥に……う、くぅぅぅぅ……っ！　い、今メリッて\n音が……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0204112" ]},
		{"command":[ "SETIMAGE", "0", "still_00015402_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「あああ……入ってくる……中がこじ開けられて……んん、少し、痛いです…\n…あ、でも全然平気、ですから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0204113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「お、お腹の隙間が……全部、オチンチンになっていくぅ……うぐぅ、あふぅ\n……オチンチンでいっぱいになっちゃうぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0204114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「んっ、あっ、ああぁぁ……ま、待って、下さいっ……はー……はー……少し\n、苦しい、です……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0204115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「ふー……ふー……はふぅ……も、もう大丈夫、です……我慢できます……は\nぁ……はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0204116" ]},
		{"command":[ "SETIMAGE", "0", "still_00015402_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「動いていただいてもオッケー、ですよ……はぁ……はぁ……でも、ゆっくり\nお願いします……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0204117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「んんっ、んはぁぁぁぁ……っ、はぁ……ああ、動いてる……中が、オチンチ\nンに持っていかれちゃうぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0204118" ]},
		{"command":[ "SETIMAGE", "0", "still_00015402_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「ズルズル擦れてる……あ、はぁ……あっ、ひやぁぁぁ……い、今、一番大事\nなところに、先っちょがぶつかってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0204119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「大事なところ、ゴリゴリされてる……赤ちゃんのお部屋が……ノックされて\nる……ん、んんぁ、はぁ……あぁぁあん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0204120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「はー……はー……はぁ……少し、慣れてきました……ふぅ……すみません、\nゴザル口調、忘れていたでござる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0204121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「え？　無理してクノイチにならなくていい？　あ、いえ、無理はしてません\nが……でも、ありがとうございます……ふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0204122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「痛みが、ん、んんん……あまり感じられなくなってきました……はぁ、ふぅ\n……アソコの奥が、ジンジン、します……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0204123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、あぁぁ……はぁ……だんだん、気持ちよくなって、きたような\n……はぁ、はぁ……ううん、まだよくわかりません……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0204124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「でも、はぁ……はぁ……おっぱいを、いじくり回されるのは、すごく好きで\nす……隊長さん、すごくエッチな顔するんですもの……ふふふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0204125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「んっ！　ああぁ……！　はぁ……い、今、少し痛かったん、です……でも、\n痛いの、結構好き、かも……はっ、あはぁ……ひううぅぅん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0204126" ]},
		{"command":[ "SETIMAGE", "0", "still_00015402_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「ああ……今、アソコが、ビクビク、震えています……はぁ……キュッとすぼ\nまった時、オチンチンをいっぱい感じて、気持ちいい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0204127" ]},
		{"command":[ "SETIMAGE", "0", "still_00015402_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「はぁ……ふぅ……隊長さんも、気持ちいいんですか……？　はぁ……はぁ…\n…感じてもらえて、嬉しいですぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0204128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……ああぁ、コツコツぶつかってる……子宮が、赤ちゃんを欲\nしがってる……はぁ、はぁ……はぁぁあん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0204129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「そろそろ、イキそう……ですか？　はぁ……ふぅ、わかり、ました……もう\n痛くありませんから、激しくしてくれてオッケーです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0204130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「ひゃうぅぅぅ！？　あっ、す、すみません……変な声、出しちゃって……は\nー……はー……イキナリ過ぎて、びっくりしちゃいました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0204131" ]},
		{"command":[ "SETIMAGE", "0", "still_00015402_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「んぐぅ、ひうぅぅ……はぁ、はぁ……あああ、すごい……ング、あぅぅ……\n骨盤に響いちゃう……はぁ、うぐぅ……あはぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0204132" ]},
		{"command":[ "SETIMAGE", "0", "still_00015402_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「揺れる……おっぱいがユサユサ揺れてる……はぁ、ふぅ……根本から千切れ\nちゃう、かも……はー……はー……あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0204133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「ん、んん、あ、はぁ……気持ちよくなって、きました……ああ、駄目ぇ……\n駄目駄目駄目ぇぇ……イキっ、そう……ですぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0204134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「た、隊長さんも、一緒に……あっ、あはぁぁ……ひやぁぁぁああん！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0204135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「ひやぁぁぁ！！　あっ、あはぁぁぁ……！　はぁぁぁあん……んっ、キモチ\n、いい……これが……絶頂、なんですねぇ……はへぇぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0204136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015402_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「はー……はー……あ、頭が、ぼーっと、しちゃい、ますぅぅ……はふぅ……\nこれ、過呼吸なん、でしょうかぁ……はー……ふー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0204137" ]},
		{"command":[ "SETIMAGE", "0", "still_00015402_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「すごく……よかったですぅ……はー……ふぅ、わたし、痛いの、好きだった\nん、ですねぇ……はぁ、ふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0204138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「う～ん、時々『あ、わたし、ドＭかも……』とは思うこともあったんですが\n、まさか本当にそうだとは思っていません、でしたね……はぁ、あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0204139" ]},
		{"command":[ "SETIMAGE", "0", "still_00015402_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「え？　このまま、続きを？　はー、ふぅ、わ、わかり、ました……でも少し\n休ませて下さい……頭がぼーっと、して………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0204140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「………………ふ、ふふ、あはははは……悪いな……あたしが相手してやるよ\nぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0204201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「ああ？　棒もないのに、人格が変わっただぁ？　うっせーな、こっちは非常\n事態なんだよ。こまけーこたぁ、気にすんな……ふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0204202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「呼吸もだいぶ整ってきた……よし、来な。ガンガンに来ていいぜ……へへ、\nこちとらドＭだから、遠慮はいらねーぜぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0204203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「んっ……んんぁ、はぁ……あああ……へへ、本当に遠慮しねーのな……いい\nぜ、その調子だ……痛いのも、案外悪くぁねぇぜ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0204204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「あたしが戦闘狂なのも、ん、んん、痛みが欲しいからかも……はぁ……ふぅ\n……あっ、はぁ……はぁあん……い、いい……もっと来いよ、こらぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0204205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「んんっ！　はぁ……マンコの中で、クチュクチュ、音がする……ああ……す\nげぇ、これ、精液なんだな……はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0204206" ]},
		{"command":[ "SETIMAGE", "0", "still_00015402_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「ネットリして、ん、ふぅ……擦れるたびヌメヌメして……ああ、気持ちいい\n……精液、あたしは嫌いじゃないぜぇ……味も匂いもな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0204207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「ん、んぁ、はぁ……はぁ……マンコの中に出されるのも、悪くねぇ……ふふ\n、次の射精が、楽しみだぜぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0204208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「ああぁ……はぁ、んんん……っ、すげぇ……精液が、染み込んで、くる……\n子宮の中に、刷り込まれちまう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0204209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「あ、ああ……へへへ……ヤベェ……自分から、腰を、動かしちまう……あた\nしも、随分淫乱になっちまったもんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0204210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……まだマンコが痛い……でも、痛いと興奮する……はー……は\nー……たまんねぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0204211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「なあ、もっと激しいのくれよ……ああ、あたしならへっちゃらだ……だから\n、もっと――あっ、あっ、んん、うくぅぅぅぅ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0204212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「は～～……ヤベぇ……気持ちいい……奥に、チンポがえぐり込んでくる……\nはぁ……ふぅ……はぁぁぁあん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0204213" ]},
		{"command":[ "SETIMAGE", "0", "still_00015402_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「ふぅ……ふぅ……最高だな、セックスって……戦闘よりも、こっちの方が、\nずーっといいじゃねぇか……へ、へへへ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0204214" ]},
		{"command":[ "SETIMAGE", "0", "still_00015402_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……たまんねぇ……マジでヤベぇ……で、隊長よぉ、これがあ\nんたの限界か？　もっと激しくしていいんだぜ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0204215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「ふぐぅぅ！？　んはぁ！　あっ、あっ、ひやぁぁぁあん……♪　はぁ……は\nぁ……ヤベェ、変な声、出ちまった……あ、はぁ……あはぁぁぁあん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0204216" ]},
		{"command":[ "SETIMAGE", "0", "still_00015402_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「やっ、駄目ぇ……い、いい、もっと……もっと、痛いこと、してぇ……はぁ\n、んっ、おっぱい、もっと、いじめてぇぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0204217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「あ、ああ……痛い……痛くて、気持ちいい……おっぱいも、オマンコも、喜\nんでるぅ……はぁ、はぁ……あはぁあ！　きゃうぅぅん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0204218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「ヤバい……イク…………イキそう……あっ、あっ、ヤベぇよぉ……マジ、イ\nッちまうぅ……はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0204219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「あはぁ……アンタも、イキそうなのか……じゃ、一緒に、イカせてもらうぜ\n……ん、くぅ！　イッ、イク……ッ、あ、あはぁ！　ひやぁぁああん！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0204220" ]},
		{"command":[ "SETIMAGE", "0", "still_00015402_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「あっ、ああぁぁっ……イッてる……今、あたし、いっぱいイッてるぅ……！\n　あ、あああ……駄目ぇ、気持ちいいの、止まらない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0204301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015402_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「子宮が、はぁ……はぁ……深呼吸してる……んん、精液が、中に入ってくる\n……ああ、すごぉい……こんなの、駄目ぇ……おかしく、なっちゃう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0204302" ]},
		{"command":[ "SETIMAGE", "0", "still_00015402_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……駄目ぇ……イッてる……ずーっと、気持ちいい……はぁ、\nはぁ……はぁぁぁあん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0204303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「はぁ……ふぅ……ん、んん……あふぅ……すみません……自分のこと、ばっ\nかりで……はぁ、はぁ……あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0204304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「始めてのこと、ばっかりで……ちょっとテンパってるんだと、思います……\nはぁ……あふぅ……クノイチ設定も忘れちゃってたし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0204305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「え？　ああ、いつの間にか、人格が元に戻っちゃいましたねぇ……えへへ…\n…彼女も、きっと楽しんでたんだと思います……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0204306" ]},
		{"command":[ "SETIMAGE", "0", "still_00015402_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「ふぅ……でも、気持ちよかったぁ…………今も、子宮がヒクンヒクン震えて\nいます……ふふ、心臓が鼓動してるみたい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0204307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「ふぅ……どっちの人格でも、セックスを楽しめてよかったぁ……はぁ……あ\nあ、やだ、まだイッてます……ああ……気持ちいい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0204308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「それで？　隊長さんは満足していただけましたか……？　そうですか……ふ\nぅ……よかったぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0204309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「それじゃあ、今日はこれくらいで失礼いたします……また、わたしとエッチ\nして下さいね…………それでは、しからば御免！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0204310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「ああぁぁぁぁあん……イッてる……あたし、イッてるぅ……！　あっ、ああ\n……はぁ……はへぇぇぇぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0204401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015402_02_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「熱いぃ……肌に、アツアツの精液が、染み込んでくる……はぁ……なんだ、\nこれぇ……ヤベェ……キモチ、いい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0204402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「こんなの、火傷しちまう……ああ、はぁ……まだ精液、いっぱい出てる……\nあぁぁん、シャワー浴びてる、みたい……はぁ、ふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0204403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「あぁ……アソコが、口を開けてる……オチンチンの形に、パックリ開いて、\n奥まで丸見えになっちゃってるよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0204404" ]},
		{"command":[ "SETIMAGE", "0", "still_00015402_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「奥から、精液が溢れてくる…………ああ、すごぉい……ずーっと、気持ちい\nい……ずーっとイッてる……あぁぁあん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0204405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……射精、終わったみたい、ですね……ふぅ……あふぅ……う\nわぁ、こんなにドロドロ……ふふ、いっぱい出しましたね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0204406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「ふぅ……ふふふふ……いつの間にか、普段のわたしに戻っちゃってたみたい\n、です……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0204407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「別人格の彼女には、いつも戦闘ばかり押し付けてますから……少しはセック\nスを楽しんでくれてたら嬉しいなぁ……ふふふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0204408" ]},
		{"command":[ "SETIMAGE", "0", "still_00015402_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「それで？　隊長さんは満足していただけました？　ふぅ……そうですか……\nよかったぁ……」", "NORMAL" ]},
