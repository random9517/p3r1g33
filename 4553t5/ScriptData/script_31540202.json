		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「それじゃ、今日はありがとうございました……あの、もしよかったら、また\n呼んで下さいね……待ってますから――では、しからば御免！」", "NORMAL" ]},
