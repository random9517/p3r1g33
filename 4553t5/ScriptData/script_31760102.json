{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017601_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「さあ盟友よ！　我とともに甘美なる刹那を貪ろうではないか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0104101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「ふふふ。我ももう辛抱できなくなっているのだ。我の芯核が汝の魔槍（おち\nんぽ）から迸るものを欲しておるのだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「遠慮しなくてもよいぞ。もう、我の粘液は何人にも止められないほどに汝を\n求めているのだからな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0104103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「さあ、我と汝を隔てるものは溶かし流してしまうぞ。ふふ、剥き身になった\n魔槍（おちんぽ）を、今こそ我が粘液の中へ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0104104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「んぅっ！　ああっ、熱い魔槍（おちんぽ）……！　わ、我の中に……粘液で\n、包んで……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0104105" ]},
		{"command":[ "SETIMAGE", "0", "still_00017601_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「ど、どうだ盟友……。我の……中……。んふぅ、ねっとりと魔槍（おちんぽ\n）に絡みついて……いるだろう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0104106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「んぅうっ！　本当に、熱くて……ああっ、わ、我の身体が……とろけてしま\nいそうだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0104107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「汝のもつ、爆炎の魔槍（とてもあついおちんぽ）が、我の身体を熱く……沸\nき立たせる……ぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0104108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「んんっ、ああっ、動かすぞ……んくぅっ！　我の粘液……んぁあっ、蠢かせ\nて……魔槍（おちんぽ）をしごいて……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0104109" ]},
		{"command":[ "SETIMAGE", "0", "still_00017601_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「んっ、んっ、んふぅうっ！　はぁあんっ！　汝の、魔槍（おちんぽ）の形…\n…隅々まで、ンッ、感じて……しまう……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0104110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「ああ、汝も感じているか……？　我が体内で……粘液が高ぶって……アンッ\n！　魔槍（おちんぽ）をしごきまくってる……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0104111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「んっ！　んくぅっ！　そんなに中で、魔槍（おちんぽ）を暴れさせるなっ！\n　あっ、あっ、あぁんっ！　あんっ、あはぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0104112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「粘液をぐりぐりとかき回されると、んっ、身体がますます、とろけてしまう\n……はぁ、はぁ……っ！　あっ、あぁあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0104113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「そんなっ、我がこうして覆いかぶさっているのに、汝は……腰を、動かして\n……んっ、んっ、んぅううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0104114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「さ、さすが我が盟友……んんっ！　我が粘液の中で、迷いなき魔槍（おちん\nぽ）さばき……っ！　ああっ、んっ、んぁああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0104115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「わ、我も負けていられないな……っ！　魔槍（おちんぽ）をしっかりと捕ま\nえて……しごいてやらないと……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0104116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「はぁんっ！　ああっ、ああっ、感じてしまう……っ！　んくっ、中を……ぐ\nちゃぐちゃに、かき混ぜられるの……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0104117" ]},
		{"command":[ "SETIMAGE", "0", "still_00017601_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「我が深層（おまんこ）に突き立てられし魔槍（おちんぽ）がっ、ぐりぐりと\n動いて、大きな渦潮を身体の中で作っている……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0104118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「こんなに雄々しき猛りをぶつけられて……んぁっ、それが体内で荒ぶる様を\n見せつけられて……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「ああっ、平静を保っていられるはずがないではないか……っ！　んっ、あっ\n、ああっ、あぁあんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0104120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「汝の魔槍（おちんぽ）も、ああっ、膨らんできて……っ！　んんっ、我が深\n層（おまんこ）をかきわけ、より深くにまで……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0104121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「ああっ、ああっ、汝の槍さばきにっ、我の身体が波打って、んくぅっ、次第\nに芯核が降りてきて、しまう……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁっ、熱いっ、熱いぃっ！　んんっ、粘液が沸騰してしまうぅっ\n！　ああんっ、ああっ、ああぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0104123" ]},
		{"command":[ "SETIMAGE", "0", "still_00017601_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「魔槍（おちんぽ）が暴れまわるぅっ！　んっ、んっ、芯核のそば、そんなに\nぃっ！　ああっ、ああぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0104124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「ぐちゃぐちゃにされるのっ、気持ちよくって、んっ、ああっ、だめっ、だめ\nぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「魔槍（おちんぽ）の切っ先（さきっぽ）が芯核に近づくたびに、んっ、ああ\nっ、身体が、爆ぜそうなほど、感じてしまうぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「ああっ、ああっ、汝も我の深層（おまんこ）を感じてくれているのか……？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0104127" ]},
		{"command":[ "SETIMAGE", "0", "still_00017601_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「んんっ、粘液だが、しっかりと魔槍（おちんぽ）を締め付けて……アンッ、\n離さないように……して……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「ああんっ！　こうすると本当にっ、魔槍（おちんぽ）を感じてっ！　んっ、\nんっ、ああっ、快感が……たまらなく……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「ああ、もっともっと、我が体内を、感じて……いいからぁ……っ！　んぁっ\n、ああっ、熱いので……かき混ぜて……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0104130" ]},
		{"command":[ "SETIMAGE", "0", "still_00017601_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「んんっ、とろける……っ。身体ぁ、とろけてしまう……ぅ……っ！　はぁっ\n、はぁ……はぁ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「んっ、どうした？　こうして粘液に包まれて、もう……汝も限界を迎えそう\nか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「ああっ、ンッ、我も……我ももう……イキそう……っ！　ああっ、ああっ、\n沸き立つ快楽に支配されるぅう……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「汝の子種をっ、アアッ、我が、芯核にぶつけるようにぃっ！　びゅくびゅく\nと、は、放って……っ！　んっ、あっ、ああぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「こ、こいっ、こい……っ！　ああっ、ああ……っ！　あっ、ああぁぁああぁ\nぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0104135" ]},
		{"command":[ "SETIMAGE", "0", "still_00017601_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「なっ、流れ込んでくる……っ！　子種がっ、我が体内にぃっ！　白濁が注ぎ\n込まれてるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0104136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017601_02_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「ああっ、見えるだろう？　我が体内を泳ぐ汝の子種汁ぅ……。はぁ……はぁ\n……熱い……濃くて、ドロドロだぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0104137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「はぁ……。このような濃いのを、芯核に浴びて……。我は……本当に……と\nろけてしまうぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0104138" ]},
		{"command":[ "SETIMAGE", "0", "still_00017601_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「んぅ……。もっと、もっとしてほしい……。ふふ……まだまだ終わらないぞ\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0104139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「せっかくこうして……汝のことを、我が粘液で包み込んでいるのだからな…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「んん……。魔槍（おちんぽ）はまだまだ硬く猛り……汝が我を求めているこ\nとを伝えてくるようだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0104201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「我も……汝ともっと、もっと……ンッ、汝に、気持ちよくなってほしいから\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「んふっ、ほら……ここはどうだ……？　汝の、尻穴を……我が粘液で刺激し\nてやろう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁ……。このような不浄の真円（こうもん）も……んっ、んん…\n…苦くても……いとおしく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0104204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「ん？　味……？　ふふ、そうだぞ……我はスライムだから、どこでも味を感\nじられる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0104205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「だから、ンッ、汝の禁忌の深淵（あなる）に……んぁっ、粘液を入れて、舐\nりながら、魔槍（おちんぽ）を刺激……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0104206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「んぁああっ！　魔槍（おちんぽ）の勢いがっ、増して……っ！　んっ、んっ\n、熱さも、先ほどよりずっと……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0104207" ]},
		{"command":[ "SETIMAGE", "0", "still_00017601_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「このように、アンッ、責められながら……汝も感じているのだな……？　ん\nっ、それは、我も……うれしい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「様々な魅惑の冒険譚（えろほん）から、んぁっ、原住民の悦ばせかたを学ん\nだ甲斐があったというもの……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「んんっ、んぁあっ、それにしても、我も変な気分だ……っ！　深淵（あなる\n）を舐りながらより興奮して……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0104210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「汝の魔槍（おちんぽ）を包む粘液が、んぁっ、勝手に、よりうねりを生んで\nしまう……っ！　んっ、んっ、ああっ、ああぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0104211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「気持ちよくっ、なって……っ！　んっ、んんっ！　我が体内で、ああっ、魔\n槍（おちんぽ）、いっぱいしごくからな……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0104212" ]},
		{"command":[ "SETIMAGE", "0", "still_00017601_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「ああっ、ああっ、身体が熱く……なってきた……っ！　こんなに、体内をめ\nちゃくちゃにされているのに……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0104213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「汝の魔槍（おちんぽ）が気持ちよくって、ああっ、止まらない……止められ\nなく……っ！　んぁあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0104214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「汝も、もう限界か？　深淵（あなる）を舐られるのが効いたみたいだな？　\nんんっ、いいぞ。アアッ、子種、を……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0104215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「また、我の芯核に向かってっ！　思いっきり、白く濁った子種をびゅくびゅ\nくと……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0104216" ]},
		{"command":[ "SETIMAGE", "0", "still_00017601_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「猛り脈打つその魔槍（おちんぽ）からっ！　アアッ、我の身体が白き潮で満\nちるほどに……たくさん……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0104217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「ああっ、ああっ、わかっている……味わうっ、汝の出すものを、みんな味わ\nうから……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0104218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「ああっ、ああっ、芯核も降りてきてっ、汝の子種浴びたがって……！　ああ\nっ、ああっああ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0104219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「き、きて……きて……きて……ぇ……っ！　あっ、あっ、ああ……ああ……\nああぁぁ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0104220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「んぁあああぁぁぁっ！　ああっ、あはぁあああぁぁぁあぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0104301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017601_02_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「精液きてるっ！　いっぱい、濃くてドロドロしたのが注がれちゃってるよぉ\nおおおっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0104302" ]},
		{"command":[ "SETIMAGE", "0", "still_00017601_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「一番感じちゃうコアのところにっ、ぶっかけっ、ぶっかけぇええっ！　んぁ\nっ、ああっ、イクイクイクッ、イッくぅうううぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0104303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「びゅくびゅくってすごいぃいっ！　あぁっ！　あぁっ！　二度目なのにっ、\nこんなにたっくさん射精しちゃうなんて、人間すごいぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0104304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「ああぁっ！　まだっ、まだ射精続いてるっ！　粘液の中でおちんぽ脈打って\n、びゅくんびゅくんって、まだ、射精……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0104305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁっ、濃いので満たされるよぉ……。ドロドロおいしい精液……\nああ……素敵すぎぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0104306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「……はっ！　ど、どうした？　い、いや、別にキャラ崩壊とかしてないぞ？\n　わ、我は、いつも通りだし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0104307" ]},
		{"command":[ "SETIMAGE", "0", "still_00017601_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「そんなことより！　な、汝の子種汁、きちんと味わったぞ。その……美味で\nあった！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0104308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「ジェルスタン王国が再興した暁には、汝の子種汁を国賓たちにふるまいたい\nくらいだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「……ううん、隊長の精液は、私だけのものなんだから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「んぁあああぁぁぁっ！　なっ、なんて勢いで……っ！　んっ、んんぅううう\nぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0104401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017601_02_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「そんなっ、ああっ、我の身体がとろけていたとはいえ、こんなに勢いよく噴\nきあがって……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0104402" ]},
		{"command":[ "SETIMAGE", "0", "still_00017601_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「子種が……ああ……我の身体を、ドロドロに汚してしまうほどに……っ！　\nはぁ……はぁ……すごいな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0104403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「ああ……汝の子種の味を、熱を、匂いを……全身で、感じるぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0104404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「こんなに……凶悪な……しかし蠱惑的な香りを……はぁ……我は、この体の\n中で受け止めていたのか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0104405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「ああ……まだまだ、我の中で、汝の魔槍（おちんぽ）が子種を放ち続けてい\nるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0104406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「ジェルスタン王国の王女を、こんなに汚すなんて……。はぁ……だが、愛し\nい汝の子種なら、いくらでも汚されたい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0104407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「まだまだ、我は汝のことを包み込んでいたいのだ……。とろとろにとろけた\n身体で、汝を覆ってしまいたい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0104408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「ふふ……遠慮はしなくてよいのだぞ？　ジェルスタンではこうして交わり続\nけるのが習わし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0104409" ]},
		{"command":[ "SETIMAGE", "0", "still_00017601_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「だから……今宵はとことん、我の粘液におぼれてもらうからな？」", "NORMAL" ]},
