		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「隊長ちゃんも、イキそうですか？　それなら、隊長ちゃんも一緒に、好きな\nようにイキましょうね♪」", "NORMAL" ]},
