		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「隊長くん、どうしましたか？　今日は私をこの部屋に呼び出して……。ああ\n、なるほど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0204101" ]},
		{"command":[ "SETCHARA", "0", "char_00026202_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「隊長くん、もしかして私に甘えたいんですね。ふふっ、いいですよ。いっぱ\nい甘えさせてあげます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0204102" ]},
		{"command":[ "SETCHARA", "0", "char_00026202_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「でも……そうですね。いつも通りだと隊長くんも刺激が足りないでしょうし\n、こういうのはどうでしょう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0204103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「ふふっ、隊長くんのことを魔法で小さくしちゃいました。ああ、ちっちゃい\n隊長くん本当にかわいいです♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0204104" ]},
		{"command":[ "SETCHARA", "0", "char_00026202_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「かわいすぎて、『隊長くん』というより『隊長ちゃん』という感じですね。\nああ、もうたまりませんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0204105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「隊長ちゃん……♪　こぉ～こ、マキママのオマンコ見えまちゅか～♪　ふふ\nっ、そうそう、よ～く見てくださいね～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0204106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00026202_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「ここが、これから隊長ちゃんのオチンチンが入っちゃう穴でちゅよ～♪　ン\nッ、そうそう、濡れちゃってます♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0204107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「隊長ちゃんのオチンチンが欲しくなると、マキママのオマンコはおもらしし\nたみたいに濡れちゃうの♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0204108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「でも、これは隊長ちゃんに甘えて欲しい女の人ならみ～んなこうなる、普通\nのことなんでちゅよ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0204109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「それで、隊長ちゃんのオチンチンは、どうなってるかな～？　マキママに見\nせてくださ～い♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0204110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「うふふっ♪　ちっちゃくてもしっかり勃起して、かっこいいオチンチンにな\nってまちゅね～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0204111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「それじゃあそのオチンチンを、マキママのオマンコ穴に挿れてみましょうね\n～♪　ちゃぁんとマキママが、挿れるところ教えてあげまちゅよ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0204112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「ん……んんぅ……♪　そ、そう……そこぉ……♪　ああ、ちっちゃくてもア\nツアツのオチンチン……んっ、んふぅ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0204113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「オマンコの入り口……もうちょっと、下よ……ンッ♪　そのまま、マキママ\nに抱きつくみたいに腰を動かして……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0204114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「んっ、あはぁんっ♪　はいりまちたよ～♪　隊長ちゃんのミニミニオチンチ\nン、マキママの……オマンコにぃ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0204115" ]},
		{"command":[ "SETIMAGE", "0", "still_00026202_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「んふふぅ～♪　マキママの中、どうでちゅか～♪　隊長ちゃん、とっても可\n愛い顔してます～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0204116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「オチンチンが中でピクピク震えちゃって……♪　ンッ、隊長ちゃん、この後\nどうするのかわかるかな～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0204117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「ふふっ、次はオチンチンを出したり入れたりするんですよ～♪　そうすると\n、オチンチンがもっと気持ちよくなりますよ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0204118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「ああんっ♪　そう、そうやって……んっ、腰……動かして……♪　はぁ、は\nぁ……んっ、そうそう、上手ぅ……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0204119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「オチンチン、マキママが気持ちよくなっちゃうところに、ちゃぁんと当たっ\nて……あはんっ、すっごく……いいのぉ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0204120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「はぁっ、あっ、んん……っ♪　隊長ちゃんの腰遣いっ、いいっ、すっごく感\nじちゃう……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0204121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「んふふぅっ、必死な顔で、腰をふっちゃって……♪　ああっ、一生懸命なと\nころがとくにかわいいっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0204122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「あんっ、どんどんヌルヌルになっちゃう♪　オマンコが、いやらしいお汁で\nいっぱいになっちゃってる♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0204123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「隊長ちゃん……ああっ、連続で弱いところ、ずんずんってされたら……っ♪\n　あっ、ああ……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0204124" ]},
		{"command":[ "SETIMAGE", "0", "still_00026202_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「で、でちゃうっ♪　マキママのおっぱいから、ミルク……でちゃいます……\nっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0204125" ]},
		{"command":[ "SETIMAGE", "0", "still_00026202_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁっ、隊長ちゃんが上手だから、母乳出ちゃった……♪　んふっ\n、もっと突いてくれたら、ミルク、もっと出ちゃいますよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0204126" ]},
		{"command":[ "SETIMAGE", "0", "still_00026202_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「あはんっ、隊長ちゃんったら、そんなに張り切って腰振ってぇっ♪　んっ、\nああっ、あはぁんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0204127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「いいっ、いいっ、オマンコいっぱい感じてっ、母乳っ、母乳止まらないっ♪\n　はぁっ、はぁっ、ああっ、ああ……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0204128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「マキママのオマンコ、いっぱいオチンチンをぎゅ～ってしちゃってるっ♪　\nんっ、隊長ちゃん、とっても上手だから……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0204129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「オマンコの中っ、うねうねってして、ンッ、隊長ちゃんのオチンチンに、気\n持ちよくしてくれてるお返しをしているんでちゅよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0204130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「マキママの、オマンコでのお返し、気持ちいいでちゅか？　んふ……っ、あ\nあっ、隊長ちゃんからも、いっぱいお返し……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0204131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「元気いっぱいのピストンで、マキママのオマンコいっぱいかき混ぜられちゃ\nって……んっ、あっ、ああぁっ、あはぁ……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0204132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「どんどん、母乳も出ちゃいますっ♪　んぁっ、おっぱいぎゅってしながら…\n…ぁあっ、されたら、ますます出ちゃうぅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0204133" ]},
		{"command":[ "SETIMAGE", "0", "still_00026202_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「隊長ちゃん、んふっ、どうしたの？　なにか、オチンチンから出そうになっ\nてるのかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0204134" ]},
		{"command":[ "SETIMAGE", "0", "still_00026202_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「隊長ちゃんからも、ミルクがでちゃうのね♪　ふふっ、オシッコじゃないの\n、精液っていう、男の子のミルクがでるんですよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0204135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「マキママのオマンコは、隊長ちゃんの男の子ミルクをいれるところなの、だ\nから、このままお漏らししちゃってもいいんでちゅよ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0204136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「ああっ、だから……だから……っ♪　あっ、ああ……っ！　あああぁぁぁあ\nあああ～～～～んっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0204137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00026202_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「いいっ、いっぱい……オマンコに注がれてるぅっ♪　隊長ちゃんの、男の子\nミルクがいっぱい……♪　ああ……すごいぃ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0204138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「ふふ……隊長ちゃん、いっぱいだしましたね……♪　これが、射精ですよ～\n♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0204139" ]},
		{"command":[ "SETIMAGE", "0", "still_00026202_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「隊長ちゃんが、マキママのオマンコでいっぱい気持ちよくなってくれたのが\nわかって、とってもうれしいです～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0204140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「ふふ……♪　それで、隊長ちゃんのオチンチンはまだまだ元気みたいでちゅ\nね～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0204201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「もっともっと、マキママに甘えたがってるみたいです♪　隊長ちゃん、まだ\nまだマキママのこと気持ちよくしてくれまちゅか～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0204202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「んんっ♪　そう、またいっぱい腰を振ってくださいね♪　隊長ちゃんっ、あ\nあっ、んっ、そう……そうやって……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0204203" ]},
		{"command":[ "SETIMAGE", "0", "still_00026202_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「マキママのオマンコをいっぱい、じゅぽじゅぽってかき混ぜてくだちゃいね\nっ♪　んんっ、上手、上手です……あはぁんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0204204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「ああ、さっき、マキママもイッたから……♪　んっ、隊長ちゃんにいっぱい\n気持ちよくしてもらったからぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0204205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「すぐ、また……。ああんっ、オマンコが、気持ちよくなって……イキそうに\n、なって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0204206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「んっ、イクッていうのは、女の人が男の人にいっぱい気持ちよくなったよっ\nて教える合図なんですよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0204207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「あんっ、そう、イかせてくれるんですね？　隊長ちゃん、マキママのこと、\nイかせてくれるんですね……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0204208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「ああっ、そう……そうです……いっぱいオマンコすると、マキママ、イッち\nゃうから……あはぁんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0204209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「隊長ちゃんの男の子ミルクと、マキママのお汁でぐちょぐちょのオマンコ、\nオチンチンでいっぱいかき混ぜてくださいぃっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0204210" ]},
		{"command":[ "SETIMAGE", "0", "still_00026202_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「あはぁっ、あっ、ああ……んっ、んぁっ、ああ……んくぅ……っ♪　そう、\nそう……そうやって……あはぁんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0204211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「上手っ、上手……ぅ……っ♪　んいっ、いいっ、いいですよっ、隊長ちゃん\n、あはんっ、マキママ……イキそうですよ……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0204212" ]},
		{"command":[ "SETIMAGE", "0", "still_00026202_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「んんっ、ああっ、マキママのオマンコが、ぐねぐねってしてるの、わかりま\nちゅか～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0204213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
