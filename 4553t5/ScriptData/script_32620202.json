		{"command":[ "PLAYVOICE", "v2_262_0204215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「ああっ、ああ……っ♪　隊長ちゃんっ、隊長ちゃん……っ♪　んっ、ああっ\n、もう……マキママ……もうぅ……っ♪」", "NORMAL" ]},
