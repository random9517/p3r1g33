		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あああぁぁぁああぁぁあぁ～～～～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3103301" ]},
		{"command":[ "SETIMAGE", "0", "still_00000131_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「んはぁっ、ああっ、あはぁ……っ！　ち、乳首……乳首で、イッたぁ……。\nまた、あなたに……乳首……んふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3103302" ]},
		{"command":[ "SETIMAGE", "0", "still_00000131_01_14" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「そして、あなたも……私の手の中に、また……。こんなにたくさんの精液を\n、だしてくれたのだな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3103303" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ああ……すごい……。手袋が、真っ白になるほど……。まだこんなに、濃厚\nな精液をだせるだなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3103304" ]},
		{"command":[ "SETIMAGE", "0", "still_00000131_01_13" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ふふ……さすがは私の王子様だ……。本当に、いやらしい……。そして、た\nくましく、男らしい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3103305" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「もしもこれが、手ではなくオマンコだったら……。私は間違いなく、あなた\nの子供を孕んでいたかもしれないな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3103306" ]},
		{"command":[ "SETIMAGE", "0", "still_00000131_01_15" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ふふ……。今からそれを想像したら、身体が疼いてしまう……。胸ではなく\n、子宮のところが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3103307" ]},
		{"command":[ "SETIMAGE", "0", "still_00000131_01_13" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「なあ……このまま続きをしてもらっても、大丈夫だろうか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3103308" ]},
		{"command":[ "SETIMAGE", "0", "still_00000131_01_12" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「さ、察してくれ。あなたの精液を、オマンコにも注いで欲しいのだ。できれ\nば、いますぐに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3103309" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ああ、少し休憩したらでもかまわない。この続きをしよう。王子様、待って\nいるぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3103310" ]},
		{"command":[ "SETIMAGE", "0", "still_00000131_01_13" ]},
		{"command":[ "WAITINPUT" ]},
