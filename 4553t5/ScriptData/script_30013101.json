{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「急に呼び出してすまない。用事というのは、あなたに、姫としてのつとめを\nしなければと思ってな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3103101" ]},
		{"command":[ "SETCHARA", "0", "char_00000131_01", "2", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「私がこの姿に至ったのは、運命の王子様であるあなたのおかげだ。だから…\n…今日はあなたに、奉仕をさせてほしい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3103102" ]},
		{"command":[ "SETCHARA", "0", "char_00000131_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「まあ、この姿でなくとも、口でしたり胸でしたりと、あなたには何度か奉仕\nをしたことはあるが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3103103" ]},
		{"command":[ "SETCHARA", "0", "char_00000131_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「とにかく、なにかリクエストはあるか？　……え？　授乳手コキ？　わかっ\nた。その授乳手コキというのをしてやろう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3103104" ]},
		{"command":[ "SETCHARA", "0", "char_00000131_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「……っと、こうだろうか。なんだか不思議な気分だな。母乳もでないのに、\n授乳だなんて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3103105" ]},
		{"command":[ "SETIMAGE", "0", "still_00000131_01_01" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ♪　さっそく、乳首に吸いついて……。はぅ……あなたの口の中で、乳\n首が、舌で弄ばれている……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3103106" ]},
		{"command":[ "SETIMAGE", "0", "still_00000131_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「吸うだけでは、ないのだな……。舌を、乳首にじゃれつかせるように動かし\nて……ンッ、い、いやらしい動きだぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3103107" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「こ、困った王子様だ……。はぁ、はぁ。私の乳首に、そんなに甘えてくるな\nんて……ンッ、ああ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3103108" ]},
		{"command":[ "SETIMAGE", "0", "still_00000131_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「でも、いいんだ。今日は私にとことん甘えてくれ。もっと、頭を抱えるよう\nにしたほうがいいか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3103109" ]},
		{"command":[ "SETIMAGE", "0", "still_00000131_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あなたが、もっと私の乳首を吸いやすくなるように……。あんっ♪　そうや\nって吸われると、胸の奥が疼いてきてしまう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3103110" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「さて……このまま手コキもすればいいのだな？　ふふっ、あなたのオチンポ\nが、雄々しくそそり勃っている……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3103111" ]},
		{"command":[ "SETIMAGE", "0", "still_00000131_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「パンパンに膨らんで、ヒクヒクと震えて……。こちらも、かまって欲しそう\nにしているな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3103112" ]},
		{"command":[ "SETIMAGE", "0", "still_00000131_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「わかっている。あなたのオチンポも、しっかり気持ちよくしてやるから……\n。ンッ、すごい熱さだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3103113" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「こうやって、上下に手を……。ふふ、あなたの気持ちよくなるリズムで、力\n加減で、オチンポをしごくから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3103114" ]},
		{"command":[ "SETIMAGE", "0", "still_00000131_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「しこしこしこ……しこしこしこ……っと、腰がもぞもぞと動いているな。ふ\nふふ、感じてくれているようだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3103115" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「手袋の感触が気持ちいい？　たしかに、素手のときよりオチンポが悦んでい\nるような気もするな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3103116" ]},
		{"command":[ "SETIMAGE", "0", "still_00000131_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「もっともっと、私の手コキを感じてくれ。それと、おっぱいも。母乳は、ま\nだでないだろうがな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3103117" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁっ、だがそんなことお構いなしに、あなたは……ち、乳首に吸いついて\n、くる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3103118" ]},
		{"command":[ "SETIMAGE", "0", "still_00000131_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ちゅぱちゅぱと、音をたてながら……。あんっ、乳首が、勃起してきている\n……のか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3103119" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「それは、そうだろう……。だって、あなたが一生懸命に甘えてくるのだから\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3103120" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「求めてくれるのが嬉しくて、私も……身体を、疼かせてしまっている……。\n乳首だって、勃起してしまうぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3103121" ]},
		{"command":[ "SETIMAGE", "0", "still_00000131_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ああっ、そうやって吸いやすくなった乳首……んっ、ああっ、伸びちゃうく\nらい吸って……んくぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3103122" ]},
		{"command":[ "SETIMAGE", "0", "still_00000131_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「こ、このままでは、私ばかりが感じさせられてしまうな……。はぁ、はぁ、\n私だって……あなたに、手コキを……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3103123" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「この張りつめたオチンポを、ンッ、いっぱい、しごいて……。んぁっ、どん\nどん膨らんで、熱くなっていく……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3103124" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ああ、そうだ。私の手で、気持ちよくなってくれ。あなたがたくさん射精で\nきるように、奉仕するから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3103125" ]},
		{"command":[ "SETIMAGE", "0", "still_00000131_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「しこしこ、しこしこ……。先走りが、溢れてきている……。私の手袋に、染\nみこんで……ヌルヌルになっていく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3103126" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「オチンポが悦んでいるのが手に伝わってくる……。んっ、こんなにビクビク\nさせて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3103127" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ああっ、乳首への吸い付きが、は、激しく……っ！　も、もしかして、イキ\nそうになっているのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3103128" ]},
		{"command":[ "SETIMAGE", "0", "still_00000131_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「それなら、このまま。私の手に射精してくれてかまわないから。遠慮なく、\n射精してしまっていいから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3103129" ]},
		{"command":[ "SETIMAGE", "0", "still_00000131_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あなたがだしてくれるものを受け止める準備は、いつでもできているぞ。ふ\nふっ、このまま激しくしごけばいいだろうか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3103130" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁんっ、手コキ、激しくしたら……あなたも、強く、吸い付いてきて……\n！　んっ、んくっ、このままでは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3103131" ]},
		{"command":[ "SETIMAGE", "0", "still_00000131_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「私もあなたに……授乳しながら、イッてしまう……！　あっ、ああっ、それ\nでいいのか？　私も……あなたと、一緒に……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3103132" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ああっ、ああ……っ、私も限界だ……一緒に……！　乳首……っ！　乳首で\n、イ……ッ、イク……ッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3103133" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あはぁあああぁぁぁああぁぁあぁ～～～～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3103134" ]},
		{"command":[ "SETIMAGE", "0", "still_00000131_01_05" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁ……っ。さっそく、すごい勢いで……あなたの精液が、手の中\nに……射精されて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3103135" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「アツアツで、ドロドロだ……。それに、あなたの匂いが、ここまで漂ってく\nる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3103136" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「おまけに、あなたに乳首を吸われながら、イッてしまった……。ああ……胸\nがジンジンと疼いている……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3103137" ]},
		{"command":[ "SETIMAGE", "0", "still_00000131_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ふふ……どうだ、私の奉仕は、王子様に満足していただけるものだっただろ\nうか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3103138" ]},
		{"command":[ "SETIMAGE", "0", "still_00000131_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「オチンポを見てみろ？　……まだ、硬いままだな。だが、想定内だぞ。これ\nくらいで満足するはずがないことは承知している」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3103139" ]},
		{"command":[ "SETIMAGE", "0", "still_00000131_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あなたを満足させられるよう、奉仕を続けよう。ふふっ、また私の手コキと\n、乳首を味わってくれ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3103140" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ああっ、ンッ、そうやってまた、乳首に……あぁ、んふぅ……っ。一度、イ\nかされたから……感じやすくなっている……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3103201" ]},
		{"command":[ "SETIMAGE", "0", "still_00000131_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あなたの口の中で、舌が、乳首を弾いて……あんっ♪　た、たまらず声が、\nでてしまう……ンッ、くぅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3103202" ]},
		{"command":[ "SETIMAGE", "0", "still_00000131_01_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「だが、このように乳首を求められるのは、悪くない気分だ……。ふふ、まだ\n子を成していない今、この乳首は王子専用だからな♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3103203" ]},
		{"command":[ "SETIMAGE", "0", "still_00000131_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「オチンポも気持ちよくしないとな。ああ、さっきの精液で、手袋がますます\nヌルヌルになってしまった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3103204" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「まだまだガチガチの勃起オチンポを、精液まみれの手袋で、たっぷりあやし\nてやるから……な……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3103205" ]},
		{"command":[ "SETIMAGE", "0", "still_00000131_01_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ああ……すごい……。さっき射精した精液が、こうやってオチンポをしごく\nたびにぐちゅぐちゅといやらしい音を立てている……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3103206" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「もう少し、強く握って、しごいても大丈夫そうだな……。ふふっ、その方が\nあなたも、気持ちよくなってくれるだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3103207" ]},
		{"command":[ "SETIMAGE", "0", "still_00000131_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ああ、またオチンポが、手の中でビクビクと暴れている……。イッたあとで\n敏感になったのは、あなたも同じか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3103208" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「んんっ、乳首への責め……っ。あっ、ああっ、また激しく吸って……あはぁ\nんっ！　き、気持ちいい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3103209" ]},
		{"command":[ "SETIMAGE", "0", "still_00000131_01_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ああっ、ああっ、そんなに熱心に吸われたら、本当に母乳がでてしまいそう\nだ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3103210" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「私も、手コキを……んっ、もっと激しく、あなたのオチンポに気持ちよくな\nってもらえるように……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3103211" ]},
		{"command":[ "SETIMAGE", "0", "still_00000131_01_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「にゅるにゅるのオチンポを……しごいて……。はぁっ、はぁ……っ。指で、\nカリやエラのところ、擦るように……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3103212" ]},
		{"command":[ "SETIMAGE", "0", "still_00000131_01_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「感じて、くれているんだな。嬉しいぞ。私の奉仕で、いっぱい気持ちよくな\nってくれ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3103213" ]},
		{"command":[ "SETIMAGE", "0", "still_00000131_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「そして、またたくさん射精して欲しい……あなたに、真っ白い精液を、たっ\nぷり放ってもらいたい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3103214" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あんっ、私のことも、またイかせようとしているのか……。ち、乳首……激\nしく吸って……んぁっ、の、のびてしまいそうなくらいに……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3103215" ]},
		{"command":[ "SETIMAGE", "0", "still_00000131_01_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ああっ、そんなにっ、んくぅ……っ！　わ、私も気持ちよくなる。乳首で感\nじまくる……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3103216" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「い……イキそうだ……。あなたに奉仕しながら、あなたに、乳首を責められ\nながら……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3103217" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「い、イク……イッてしまう……！　はぁ、はぁ……あなたも……あなたも、\n射精……して……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3103218" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「いっぱい、しごくから……たくさん、だして……！　私に向かって、好きな\nように射精していいから……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3103219" ]},
		{"command":[ "SETIMAGE", "0", "still_00000131_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ああ……っ！　も、もう、我慢が……私も、い、イク……乳首……授乳で、\nイク、イク、イク……ッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3103220" ]},
		{"command":[ "SETIMAGE", "0", "still_00000131_01_09" ]},
		{"command":[ "WAITINPUT" ]},
		
