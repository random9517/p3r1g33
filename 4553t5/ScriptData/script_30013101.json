		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ああぁっ！　ああっ、精液……噴き出て……っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3103401" ]},
		{"command":[ "SETIMAGE", "0", "still_00000131_01_17" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ま、まだまだこんなに……ドロドロの、精液が……っ！　あなたの匂いがす\nる濃い精液が、身体に……たっぷり……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3103402" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁ……っ。べっとり、ネバネバのザーメンシャワー……。ああ…\n…イク……乳首だけじゃなく、ぶっかけられた全身で……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3103403" ]},
		{"command":[ "SETIMAGE", "0", "still_00000131_01_16" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「んんぅ～～っ！！　身体が、悦んでしまう……。あなたに汚されて、反応し\nて……震えて、しまう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3103404" ]},
		{"command":[ "SETIMAGE", "0", "still_00000131_01_20" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……。あなたも、こんなに射精してしまうほど、気持ちよくな\nってくれたのだな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3103405" ]},
		{"command":[ "SETIMAGE", "0", "still_00000131_01_19" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「とても、嬉しい……。ああ……それにしても、すごい匂いだ……。とても、\n愛おしい匂い……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3103406" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「これを嗅いでいると、子宮が、疼いてしまう……。ふふ、王子様……このあと\nはもちろん、本番、だよな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3103407" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「この、全身を犯すドロドロの精液を、オマンコに注がれたくてたまらない気\n分なんだ……」", "NORMAL" ]},
