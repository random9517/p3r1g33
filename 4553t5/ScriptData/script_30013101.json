		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「なあ、上手に奉仕ができた姫に、ご褒美を与えてもいいんじゃないか？」", "NORMAL" ]},
