{
		"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0117" ]},
		{"command":[ "DISPIMAGE","0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「カツマ、大丈夫！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010021150001" ]},
	{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
	{"command":[ "DISPTEXT", "TRUE" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「カグヤも来たのか～。今日は千客万来だなぁ～」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「か、カグヤさん！　どうしてここに！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010021150013" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「まりあ殿だけでは手に負えない可能性があると思い、先ほどワタクシがお声\nがけをさせていただいたのです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021150028" ]},
	{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「これは……！　ジュンジローから聞いてた以上に堕落しきってる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010021150002" ]},
	{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふふ♪　また新しい子が来ましたよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010021150030" ]},
	{"command":[ "SETCHARA", "0", "char_00015701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「誰が来ても無駄だよ……ご主人様は絶対に渡さない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010021150027" ]},
	{"command":[ "SETCHARA", "0", "char_00015801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ＭＯＥ" ]},
		{"command":[ "SETTEXT", "「ふふっ。いざとなったら、私たちで愛の逃避行をするのもいいかも知れない\nわね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010021150022" ]},
	{"command":[ "SETCHARA", "0", "char_00011101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「愛の逃避行だなんてさせない！　これ以上カツマを誘惑しないで！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010021150003" ]},
	{"command":[ "SETCHARA", "0", "char_00000201_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「それにカツマもカツマよ！　こんな風になるなんて、どうかしてる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010021150004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「な、なんだよぉ！　俺がこんな風になったのは、お前らにも原因があるんだ\nぞ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「俺にばっかり仕事を振るし、責任を負わせるし……！　アレをやれ、コレを\nやれって言ってきて……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「それなのに給料は一切上がらない上に、褒められることもない……！　それ\nどころか、罵倒されるばかりの日々……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「でもロッテやクララ、ＭＯＥは違う！　俺のやることを褒めてくれるし、あ\nりとあらゆるお世話をしてくれる！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「仕事を手伝わせても、文句の一つも言わないし……！　お前たちは最高のメ\nイドロボとメイドカーだ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ＭＯＥ" ]},
		{"command":[ "SETTEXT", "「メイドカーだなんて……！　私としては、生涯の伴侶カーの方が嬉しいんだ\nけどなぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010021150023" ]},
	{"command":[ "SETCHARA", "0", "char_00011101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「そんなに褒められると、嬉しくて思考回路がショートしちゃいます♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010021150031" ]},
	{"command":[ "SETCHARA", "0", "char_00015701_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ご、ご主人様……私たちのこと、本当に大切にしてくれてるんだね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010021150028" ]},
	{"command":[ "SETCHARA", "0", "char_00015801_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お前たちの居ない生活なんて、もう考えられない！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「仕事をしてるのは、主にクララ殿なんですけどねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021150029" ]},
	{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「これは完全に依存の状態になってますね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010021150014" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「こ、こんなのカツマじゃない！　お願いだから正気に戻って！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010021150005" ]},
	{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ロッテぇ～、クララぁ～、ＭＯＥぇ～！　俺は悪くないのに、正気に戻れと\nか言われるよぉ～！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「よしよし。ご主人様、大丈夫ですよ～。ご主人様はずっとこのままでいてく\nれていいんですよ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010021150032" ]},
	{"command":[ "SETCHARA", "0", "char_00015701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「私たちはちゃんとご主人様のこと理解してる……大変なことは全部任せて…\n…！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010021150029" ]},
	{"command":[ "SETCHARA", "0", "char_00015801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ＭＯＥ" ]},
		{"command":[ "SETTEXT", "「カツマちゃんはなにも悪くないわ。悪いのは、カツマちゃんを悪く言う人た\nちよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010021150024" ]},
	{"command":[ "SETCHARA", "0", "char_00011101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「な、なんですかアレは！　カツマさんのことを肯定するだけじゃなくて、私\nたちが悪者にされてますよ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010021150015" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「あの様子では、ご主人が自立する確率はゼロといってもいいでしょうな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021150030" ]},
	{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「そんなのダメ！　どんなにダメでも立ち向かうのがカツマなんだから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010021150006" ]},
	{"command":[ "SETCHARA", "0", "char_00000201_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「そ、そうですね！　こうなったら、無理矢理にでもあのロボットたちからカ\nツマさんを引き剥がしましょう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010021150016" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「やっ、やめろぉ！　幸せな時間の邪魔をするな！　俺の側に近寄るなああー\nーーーーーーーーーッ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ご主人様に手出しはさせません！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010021150033" ]},
	{"command":[ "SETCHARA", "0", "char_00015701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ご主人様の嫌がることをするなら、容赦しないよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010021150030" ]},
	{"command":[ "SETCHARA", "0", "char_00015801_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「くうぅっ！　な、なんてパワーなの……！　まりあ、サポートをお願い！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010021150007" ]},
	{"command":[ "SETCHARA", "0", "char_00000201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「わかりました！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010021150017" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ＭＯＥ" ]},
		{"command":[ "SETTEXT", "「カツマちゃんの仲間に怪我はさせたくはないけど、私たちの時間を奪うなら\n容赦しないわ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010021150025" ]},
	{"command":[ "SETCHARA", "0", "char_00011101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「スクラップになっても恨まないことね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010021150008" ]},
	{"command":[ "SETCHARA", "0", "char_00000201_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
	{"command":[ "EXIT" ]}
	]
}