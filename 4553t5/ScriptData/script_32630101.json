{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「あ、隊長。お疲れさまでーす……えへへ、今日はですね。毎日頑張る隊長を\n、私が癒やしてさしあげようかと思ったのです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0103101" ]},
		{"command":[ "SETCHARA", "0", "char_00026301_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「ほらほら、こちらに来て欲しいのです。そう、お風呂場です。この憩いの場\nでたっぷりと隊長を癒やしてさしあげますです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0103102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「見ててください……これ。そう、ローションです。私は水神ですから、こう\nいうのも作れちゃうのです。褒めてくれていいんですよ、えへ、えへへへへ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0103103" ]},
		{"command":[ "SETCHARA", "0", "char_00026301_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「お風呂とローション……男の人が大好きな癒しなのです。ネットで読んだか\nら、知っているのですよ……ふふふ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0103104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「え、ここに寝転んで欲しい？　今日は私が癒やしてあげようっと思ってるの\nですけれど……でも、強引な隊長も好きかも……です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0103105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「あっ、そんな迫ってきて、もしかしてこのままローションで入れちゃうので\nす？　隊長なら、私はいつでもオッケーなのです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0103106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「んんっ。あ、え？　隊長、そこはお腹……んっ、ああっ、ふうっ、んっ、こ\nんなの、酷い、入れてくれるって思ったのです……あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0103107" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00026301_01_02" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「あっ、んんっ、もどかしい……隊長のおちんちんがお腹こすってきて……気\n持ちいいけどもどかしいのです……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「ひゃうっ！！　いきなり胸を……あんっ、乳首つまんだらだめなのです！！\n　あんっ、あっ、これが好きだろって……そうですけれど、やんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「好きなのは、隊長にしてもらうことなのです……あうっ、んっ、くりくりし\nちゃだめ……だめなのです……ふあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「ああんっ、んっ、ふうっ、なにか、変なのです……入れられてないのに、お\n腹こすられてるだけなのに、身体が熱く……あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0103111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「え、私のお腹のお肉が気持ちいいって……それ、褒め言葉じゃないのです。\n人が気にしてることを……ひああっ、乳首、つまんだら……あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「もう、それさえしておけば私が喜ぶと思っているのです？　ふあっ、ああっ\n、あんっ、んっ、気持ちいい、ですけれど、やんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「んうっ、なんだか、お腹も……よくなってきたのです。隊長のおちんちんの\nカリ首がお腹をこすって……感触が……あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「あっ、ああっ、だめっ、おちんちんと乳首、同時にするのはだめなのです、\nふあっ、ああっ、やあっ、身体が、溶けちゃうのです……ふああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0103115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「んんっ、ふっ、あっ、んっ、隊長、私、そろそろ、イっちゃうのです、あっ\n、ああっ、そのまま、ごしごしって、お腹と乳首を……んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「あっ！？　なんで、止めちゃうのです……んっ、あっ、ひどい、抑えつけら\nれて、動けなくされたら……んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0103117" ]},
		{"command":[ "SETIMAGE", "0", "still_00026301_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「こんなの生殺しなのです……おちんちん入れてくれないし、イかせてくれな\nいし……隊長はひどい人なのです……ぐすっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「ひああっ、あっ、私が文句を言ったら気持ちよくしたらいいと思ってるので\nす、んっ、気持ちいい、気持ちいいのですけれど、やあっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0103119" ]},
		{"command":[ "SETIMAGE", "0", "still_00026301_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「お腹もごしごしされて、乳首もこりこりって、ふあっ、ああっ、隊長のおち\nんちんが入ってないのに、お腹の奥がきゅうってなるのです……んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「んっ……乳首だけじゃなくてお腹も……やあっ、お腹だけじゃなくて乳首も\n……両方、両方してくださいですっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0103121" ]},
		{"command":[ "SETIMAGE", "0", "still_00026301_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「あっ、ふっ、もう、隊長、ずるくてひどい人なのです……でも、そんなとこ\nろも好きなのです……あんっ、あっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「んんっ、隊長、隊長は気持ちいいですか？　んうっ、あっ、最高だなんて…\n…うふふ、照れるのです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0103123" ]},
		{"command":[ "SETIMAGE", "0", "still_00026301_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「あんっ、本当だ……隊長のおちんちん、ローションだけじゃないネバネバが\n出てきてるのです……んっ、ふっ……カリ首も竿も熱くなってるのです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「あうっ、ふっ、隊長の顔も、真剣になってきた……本当に、気持ちいいんで\nすね。私のお腹、好きなのですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「当たり前って……やっぱり、隊長は口がうまくてずるいのです……そんなこ\nと言われたら、私だって……です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「んっ、んっ、ふっ、お腹こすられてるだけなのに、その奥がきゅんきゅんっ\nて啼いてるのです……あっ、んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0103127" ]},
		{"command":[ "SETIMAGE", "0", "still_00026301_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「あっ、乳首もそんな優しくいじられたら……んっ、ああっ、あんっ、あっ、\nもどかしいのです……あっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「あんっ、いじわる、やっぱり隊長はいじわるなのです……んっ、私がもっと\n欲しがってるのを分かってて、こんな風に焦らしてるのです……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0103129" ]},
		{"command":[ "SETIMAGE", "0", "still_00026301_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「ね、ね、隊長、もうちょっと強く……あっ、んっ、もう、本当にいじわるな\nのです。ずっと同じ力と動きで……んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「ふうっ、ううううっ、生殺しなのに、なんだかお腹が……ぐずぐずに溶けて\n、あっ、ああっ、あっ、頭の中も溶けて……ふうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「あう、ふっ、隊長のおちんちんも私のお腹に沈んで……あっ、そこで動かさ\nれたら、お腹越しに子宮が突かれてるのです、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「あっ、ああっ、凄い、お腹におちんちん入れられて……中に入ってないのに\n、もどかしいのに、私の中が……あうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「ああっ、だめっ、今乳首こりこりされたらっ、ふあああっ、オマンコの奥が\n……あっ、お腹越しに突かないで、あんっ、いじわるなのですっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「欲しいのに、中に欲しいのに、お腹と乳首だけでイっちゃう、イっちゃうの\nです！！　隊長、隊長、もっと強くしてなのですっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0103135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「ふあああっ、隊長のおちんちんもがちがちになって、私に出したがってるの\nです！！　んんっ、いいですよ、お腹にいっぱい出してっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0103136" ]},
		{"command":[ "SETIMAGE", "0", "still_00026301_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「あっ、ああああああっ、イっくううううううっ！！　んんっ、隊長の精液お\n腹に出されて、イっくううう！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0103137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00026301_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「んんんっ、お腹がどろどろに……隊長の精液でべとべとになっちゃってるの\nです……ふううっ、あっ、お腹越しに妊娠しそうなのです……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「ローションと精液でどろどろです……ふふ、気持ちよかったですか、隊長？\n　よかったなら、嬉しいです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0103139" ]},
		{"command":[ "SETIMAGE", "0", "still_00026301_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「いつも忙しい隊長を少しでも癒やせたら、よかったです。私もいっぱい気持\nちよくなっちゃったですけれど……えへへ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「えう……？　え、まだ足りない……もう一回って、そんなすぐに……ふああ\nあっ、おちんちんがもう復活してるのですっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0103201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「ああっ、んっ、ローションに精液のぬるぬるが追加されて、カリ首がお腹を\n滑っていくのが分かるのですっ、ふあああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0103202" ]},
		{"command":[ "SETIMAGE", "0", "still_00026301_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「ふあああっ、さっきよりも強く乳首をつままれて、んんっ、さっき言ったと\nきはしてくれなかったのに、いじわる、いじわるなのですっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0103203" ]},
		{"command":[ "SETIMAGE", "0", "still_00026301_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「あっあっあっ、お腹と乳首で、頭の中まで蕩けて……んんっ、隊長のことし\nか、隊長が気持ちよくしてくれることしか考えられなくなってるのです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0103204" ]},
		{"command":[ "SETIMAGE", "0", "still_00026301_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「ふあああっ、入れられてないのに、なんでこんな気持ちいいのです。んんっ\n、あっ、ああっ、おちんちんも指も気持ちいいっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「ああっ、好き、この動きも、指も、隊長も全部……あんっ、あっ、すごい、\n隊長の動きも速くなってるのです、ひああああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「んっんっんっ、そんな乳首の先っぽだけくりくりされたら、頭おかしくなっ\nちゃうのです……ふううっ、あっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「んひいっ！！　乳首に合わせておちんちん動かさないで、んっ、お腹の中に\nずぷずぷって沈んでくるっ！！　ひうううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「お腹も胸も隊長に好きに弄られて……頭の中もどろどろになって……もう、\nなにも考えられないのです、ふああああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「隊長、隊長……あっ、私を見てる顔も素敵……入れられてないのに、おちん\nちんが中にあるみたいです……んうううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0103210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「あっ、お腹の中でおちんちんが膨らんで……隊長もまた出したいんですね。\nいいのですよ、私のお腹にまたいっぱいかけて……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「私のお腹がふかふかで気持ちいい……？　複雑な気持ちですけど、隊長が気\n持ちいいなら許すのです。んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0103212" ]},
		{"command":[ "SETIMAGE", "0", "still_00026301_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「私の身体を好きにできるのは、隊長だけなのですから。胸も、お腹も、どこ\nだって好きに使っていいのですよ。あんっ、ふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「ふふっ、ねちょねちょ、どろどろと音がしてますね。ローションと精液の混\nぜ物で凄い匂いと音がしてるのです。んんっ、うっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0103214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「ふあっ、あああっ、隊長の顔、またさっきと同じ顔に……そろそろイきそう\nなのです？　私も、隊長の手とおちんちんで……んっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0103215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「一緒に、一緒にイくのですっ！！　ふううっ、隊長と私、一緒にイきたいの\nですっ！！　あんっ、ああああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0103216" ]},
		{"command":[ "SETIMAGE", "0", "still_00026301_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「ああっ、最後の最後にそんな強くつままれたら、頭の中、なにも考えられな\nく……あうううっ、んっ、おちんちんがずっぷり……ふあああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「あっ、あんっ、あっ、おちんちんが、隊長のおちんちんが私のお腹で暴れて\nるのが分かるのです、形も、熱さも、大きさも……んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0103218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「ふううっ、うっ、隊長、んっ、ふあああっ、両手と、おちんちんでそんなに\n責められたら、またイっちゃう、イっちゃう、イっちゃうのです、ひあああっ\n！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「あっ、うっ、隊長も、隊長もイってください！！　私の身体に、好きにかけ\nてっ！！　隊長の精液を、くださいですっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「ひあああああああっ！！　お腹の上に、またどぷどぷって……精液で池がで\nきちゃう……ふあああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0103301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00026301_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「んんっ、こんなの、こんなに一杯出されたら、ここで妊娠しちゃいそう……\n隊長の精液、強そうですし……んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「ふうっ、胸もじんじんしてるし、まさかこんな風にイかされるなんて……こ\nんなやり方があるなんて、知らなかったのです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0103303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「熱さも匂いも凄くて……隊長に出されたって分かるのです……ふふっ、お腹\nに塗りこめたくなっちゃうのです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0103304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「え？　私のお腹が魅力的だからこんな風にした？　も、もう。仕方ない人で\nすね隊長は。えへ、えへへへへへへへへ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0103305" ]},
		{"command":[ "SETIMAGE", "0", "still_00026301_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「そんな風に熱烈に語られたら、悪い気はしないですね……うふふふ。まあ、\n私も気持ちよかったのです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0103306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「お腹をこすられているときの感触とか、隊長のかっこいい顔とか、ちょっ\nとくせになりそうなのです。水神冥利に尽きるのです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0103307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「疲れた隊長もたっぷりと癒やせたみたいなのです。隊長、すっきりした顔し\nてるのです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0103308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「でも……今日のも素敵だったけど、やっぱりこの太くて硬いおちんちん、私\nの中に入れて欲しかったのです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「今度はこの量を全部、私の中で出してくださいね。約束なのです、隊長」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「あっ！？　え、おちんちんがお腹から……ふあっ、そんな、今顔に向けられ\nたら……っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0103401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00026301_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「ひあああああっ！！　私の顔に、隊長の精液が……んんんっ、んっ、顔中に\nかかってるのです、ふああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「ねばねばして……匂いと、味も……んんっ、隊長の精液が顔と口に……髪の\n毛も、全部ぶちまけられてるのです……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0103403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「あ……すごい。これ、好きかも……エナジードリンクよりおいしいのです…\n…隊長の精液、んくっ、んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0103404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「ふう……お腹に出されたのもよかったけど、顔もいいかも……ふふ、もしか\nしたら美容にもいいかもです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0103405" ]},
		{"command":[ "SETIMAGE", "0", "still_00026301_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「んっ、最後の一滴がまた……ふふ、どろりと濃くて、ねばねばしてます……\n隊長が気持ちよかった証拠なのです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0103406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「顔もお腹も真っ白です……私の全身、隊長の匂いでいっぱいなのです。こん\nなにかけられたら、もう隊長のものだっていわれてるようなものです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0103407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「隊長、私はちゃんと癒やせましたか？　えへ、それならよかったです。隊長\nが望むなら、またいつでもやってあげるのです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0103408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「でも今度は、さっきお腹にしたみたいに、私の中をごしごしして欲しいので\nす。やっぱり、隊長と繋がりたいのです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0103409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「顔もいいけど、次は中にいっぱいお願いなのです、隊長」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_0103410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}