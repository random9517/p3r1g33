{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「あ……こ、このまま……するの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1203101" ]},
	{"command":[ "SETCHARA", "0", "char_00000112_01", "2", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPTEXT", "TRUE" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「確かに……今日は特別な夜だし……この格好で、どんなご奉仕でもしてあげ\nるって言ったわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1203102" ]},
	{"command":[ "SETCHARA", "0", "char_00000112_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「でも……やっぱり、その……立ったままなんて恥ずかしいと言うか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1203103" ]},
	{"command":[ "SETCHARA", "0", "char_00000112_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「それに、慣れないし……ちゃんと、オチンポ……してあげられるかどうか、\n心配で……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1203104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「だ、大丈夫……？　もう……分かったわよ。レディに二言はないわ……ちゃ\nんと、太ももで……オチンポを扱いてあげるから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1203105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「ええ、いいわ。おっぱいも……あなたの好きなようになさい……ひぁっ……\nんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1203106" ]},
	{"command":[ "SETCHARA", "0", "char_00000112_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「ちょっ、ちょっと……んっ、好きにしていいとは言ったけど、ちゃんと……\n優しく触りなさいっ……そ、そう……んっふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1203107" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00000112_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「それ位の感じならいいわ……あっ、手のひらいっぱいに……握り締められて\n……ゆっくり、ぎゅうって……んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1203108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「ち、乳首が……勃ってるとか……そんなことっ……いちいち言わなくても分\nかるでしょうっ。デリカシーに欠けるんだからっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1203109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「んっ、はっ、んふっ……分かってるわ……私も、ちゃんとすればいいんでし\nょう……？　太もも……動かすわよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1203110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「あっ、んっ……どう、かしら……こんな感じで大丈夫……？　んっ、んくっ\n、はっ、んふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1203111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「あぁ……当たってる……オチンポ……すごく太くなっちゃってるじゃない…\n…すごく熱くなって……はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1203112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「それだけ楽しみにしてたってこと……？　もう、確かにこの衣装にしてから\n、ずっとあなたの視線は気になってたわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1203113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「まさか……気づかれてないとか思ってないでしょうね？　あんな、いやらし\nい視線……バレバレですからね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1203114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「んっふ……まぁ、私も……その……ちょっと期待しては……いたけれど……\nあっ、そ、そこっ……んっ、つまんでぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1203115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「あぁ……指で転がすの上手ぅ……んくぅ……あっ、あぁっ……また、ど\nんどんしこって来ちゃうの……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1203116" ]},
		{"command":[ "SETIMAGE", "0", "still_00000112_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「ええ……感じる、わ……乳首……コリコリされるの、気持ち、いいの……あ\nふっ、あぁ……でも、ひ、引っ張るのはダメェ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1203117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「わ、分かってるわよ……ちゃんとサボらないで……足……動かせばいいんで\nしょう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1203118" ]},
		{"command":[ "SETIMAGE", "0", "still_00000112_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「んっ、ほら……んっ、しょっ……はぁ……んっ、あっ、オチンポ当たるぅ…\n…太いのの感触……ドキドキするぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1203119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「んぅっ……や、やだ……オマンコ……すぐ近くにあるから……はぁ……入っ\nてないのに、意識しちゃう……あ、あぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1203120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「ぬ、濡れてるとかっ……だから、言わないでっ……あぁんっ、またおっぱい\nっ……あひんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1203121" ]},
		{"command":[ "SETIMAGE", "0", "still_00000112_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「あぁ……さ、触られながらご奉仕するの、難しい……おっぱいの揉み方が…\n…いやらしすぎて……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1203122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「右と左でどっちが感じるかなんて……わ、分かるわけ……あっ、ないでしょ\nっ……ひぁっ、んぅんっ、今、触ってる方よっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1203123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「んぁっ、だ、だからって……左右……両方ともなんてぇっ、はひぁっ、そん\nなのっ、ずるっ、あっ、あひっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1203124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「も、もう……調子に乗ってっ、私だって……んっ、ふっ、こうよっ……はっ\n、んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1203125" ]},
		{"command":[ "SETIMAGE", "0", "still_00000112_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「ほら……どうなの……？　これ、結構いいんじゃない？　オチンポがちょっ\nと震えてるわよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1203126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「やっぱり気持ちいいのね、ふふっ……調子に乗っていても、やっぱり単純な\nんだから……ほら、ほら……んっ、えいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1203127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「んんっ！　ダメよ……乳首を弄った位で、もう……簡単には止まらないわ…\n…むしろ、激しくする、んっ、だけよっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1203128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「はっ、あっ、んんっ、あぁ……で、でも……こんな所……絶対に他の人に見\nせられないわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1203129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「この私が……あっ、サンタの衣装もこんなにはだけてっ……はしたなく腰を\n振って、太ももでオチンポ扱いているなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1203130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「あぁ……しかも両手をこんなに上げて……腋もおっぱいも丸出しにして……\n指で、いいように弄り回されて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1203131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「はぁっ、あぁんっ、やだ……そんなこと考えてたら、また乳首……ムズムズ\nしちゃう……あぁ……オチンポももっと元気になってるじゃない……変態……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1203132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「んんっ、でも……太ももで擦るの……私も……あっ、いい……感じ……うん\nっ、はぁ……ぬるってしちゃう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1203133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「わ、私の汗だけじゃないわよね……？　これ……そろそろ、オチンポが射精\nしたがっているサインでしょ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1203134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「んんっ、はぁっ、するわっ……もっと、感じてっ……はぁっ、んっく、ほら\nっ、出したくなったら……このまま出してしまいなさいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1203135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「でもっ、衣装は汚さないように気をつけなさいよっ？　太ももは……濡らし\nてもいいからっ……だからっ、早くっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1203136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「ひぁぅんっ！　あぁっ……出てるっ、熱いのっ……いっぱい射精してるぅっ\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1203137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000112_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「んっ……はぁぁ……あぁ……本当に遠慮なく出してくれるわね……太ももが\nドロドロだわ……んっ……すごい匂い……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1203138" ]},
		{"command":[ "SETIMAGE", "0", "still_00000112_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「でも……それだけ、私の太ももが気持ちよかったってことよね？　そうなん\nでしょう、そうって言いなさいよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1203139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「そうそう素直でよろしい。気が向いたら、またしてあげてもいいわよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1203140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「って……な、何普通にまた腰を振り始めているのよっ！？　き、気が向いた\nからって……それは私の気がって意味で……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1203201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「んぁんっ……あっ、はぁっ……も、もう……仕方ないわね……そんな悲しそ\nうな顔されたら、私が悪いみたいじゃない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1203202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「いいわ……続けてするから……オチンポ、扱いてあげるから……んんっ……\nふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1203203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「あぁ……精液でヌルヌルになっちゃってる……やだ……この感じ……滑るの\nよ……んっ、しょっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1203204" ]},
		{"command":[ "SETIMAGE", "0", "still_00000112_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「はっ、ふっ……んんっ……あんっ、はっ、あんっ……んっ、ダメ……太もも\nに精液塗り拡げられちゃってる……こんな……あっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1203205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「やっ……おっぱいも、また……んんっ、は、うんっ……指ぃ……さ、さっき\nより強くなってる……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1203206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「だ、大丈夫……んっ、今は……少し乱暴な位でも……何だか火照って、いい\n……みたい……あっ、あぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1203207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「だからって、すぐっ……遠慮なしになるんだからぁっ……あっ、んっ、あぁ\nんっ、私だって……んんっ、くっ、んぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1203208" ]},
		{"command":[ "SETIMAGE", "0", "still_00000112_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「どう……？　精液のお陰で……さっきより、もっと……にゅるって……滑る\nでしょ……？　んんっ、はぁっ、あっ、はんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1203209" ]},
		{"command":[ "SETIMAGE", "0", "still_00000112_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「これ……私も、あっ……感じ……ちゃうのっ……んんっ、太ももが……敏感\n過ぎて、オマンコみたいになっちゃってるの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1203210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「あっ、あぁっ、腰が動いてるっ……オチンポずりゅずりゅって……私の太も\nもマンコっ……犯されちゃってるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1203211" ]},
		{"command":[ "SETIMAGE", "0", "still_00000112_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「はぁんっ、あぁっ……いいのっ、オチンポ責めっ……あひぁんっ、してっ…\n…おっぱいも……ぎゅってしてっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1203212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「あぁっ……あっ、あぁぁっ……私がご奉仕してる筈なのに……これじゃ、逆\nみたいに……んんっ、なってるぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1203213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「でも……んんっ、サンタなんだから……私も、ちゃんと……プレゼントして\nあげるんだから……んっ、んふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1203214" ]},
		{"command":[ "SETIMAGE", "0", "still_00000112_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「ふっ、んふんっ……ほら……ここっ、気持ちいいとこでしょっ、分かってる\nんだからぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1203215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「うんっ、はぁんっ……あぁっ、また腰をカクカクさせてっ……また、出した\nくなって来てるのねっ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1203216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「ちゃんと……分かるわ。だって、こんなに……オチンポが出したいって太も\nもにくっついて来てるからっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1203217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「いいわっ、我慢なんかしないで……気持ちよくぴゅっぴゅって出しなさいっ\n……太ももマンコに中出しでも……違うところでもっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1203218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「もう……衣装が汚れてもいいからっ……だってっ、私もこんなに気持ちいい\nのっ……我慢……あっ、できなくなっちゃうからっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1203219" ]},
		{"command":[ "SETIMAGE", "0", "still_00000112_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「はぁっ、んんっ……あぁ……おっぱいつままれてっ、イキそうになってるっ\n……あひんっ、も、もうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1203220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「またっ……太ももがいいのっ？　いいわっ……太ももマンコに中出ししてっ\n、してぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1203301" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「んぁぁぁぁぁっ！　また出てるっ、あっ……ひっ……さっきより……もっと\nいっぱい……出てるの……あぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1203302" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000112_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「あぁ……すごい……噴水みたいに……気持ちいいからって……んっ、出しす\nぎぃ……はぁ……あふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1203303" ]},
		{"command":[ "SETIMAGE", "0", "still_00000112_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「んっ……終わった……？　後もうちょっとね……？　ま、まだ乳首触るの…\n…？　も、もう……本当にあなたは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1203304" ]},
		{"command":[ "SETIMAGE", "0", "still_00000112_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「あっ……出て来た……これで最後……はぁ……あ……ふっ……呆れる位……\n射精したわね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1203305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「でも……私も気持ちよくなりすぎちゃった……おっぱいがまだジンジンして\n……軽くイッちゃったみたい……あふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1203306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「あーあ……やっぱり衣装は汚れちゃったわ……もう、これだけ出したら、そ\nれも仕方ないわよね……クリーニングに出しておかなきゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1203307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「まぁ……それだけ元気が有り余ってたってことだろうし……でも、こんなク\nリスマスプレゼントで……本当によかったのかしら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1203308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「え……？　さ、最高だった……？　あ……そ、そう……喜んでくれたのなら\n……まあ、いいわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1203309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「そうね……どうしてもって言うのなら、また来年のクリスマス……して、あ\nげなくも……ないわ。一年ちゃんと待てるなら……ね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1203310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「えっ……な、なにっ？　今度は……身体に掛けたいのっ？　あぁっ、もうっ\n、何でもいいわっ、いいから、射精しちゃいなさいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1203401" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「ひぁんっ！　あっ……また、ビュクって……こんな、お腹にも……おっぱい\nにもっ……元気よすぎぃっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1203402" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000112_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「んふぁっ……まだ腰振ってる……もう、そのまま全部出しきっちゃいなさい\n……はぁ……んっ……あぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1203403" ]},
		{"command":[ "SETIMAGE", "0", "still_00000112_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「あっ、出てる……やだ……こんな挟んだ状態だと……何だか私が射精したみ\nたいに見えちゃうじゃない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1203404" ]},
		{"command":[ "SETIMAGE", "0", "still_00000112_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「た、確かに……私も……イッちゃったから……気分的には似たようなものだ\nけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1203405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「んっ、これで終わり……？　はぁ……すごい量だったわ……粘り気も強くて\n……こんなの、直接受けたら絶対妊娠しちゃうじゃない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1203406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「べ、別に……そうしたかったって訳じゃないのよ？　今日は、ここまでって\n最初から決めてたんだし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1203407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「まぁ……一応、私なりに精一杯のクリスマスプレゼントだったけど……本当\nにこれでよかったのかしら……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1203408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「え……？　さ、最高だった……？　あ……そ、そう……喜んでくれたのなら\n……まあ、いいわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1203409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「そうね……どうしてもって言うのなら、また来年のクリスマス……して、あ\nげなくも……ないわ。一年ちゃんと待てるなら……ね」", "NORMAL" ]},
