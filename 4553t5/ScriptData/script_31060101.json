{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「なーに？　こんな時間に呼び出して……今忙しいんだけど？　ほら、アニメ\nを見て、ニホンゴの練習しなきゃいけないしさ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0103101" ]},
		{"command":[ "SETCHARA", "0", "char_00010601_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「はぁ……？　トレーニング？　普段からクンフーを積んでるから、あなたに\nとやかく言われる憶えはないんだけど？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0103102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「って、何？　特別な訓練……？　一体何をさせるつもり？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0103103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「はぁぁ……？　エエエ、エッチな奉仕でトレーニング？　な～～に言ってん\nの！　バッカじゃない！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0103104" ]},
		{"command":[ "SETCHARA", "0", "char_00010601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「へ？　恥ずかしいことをあえて行うことで、精神を鍛錬……？　そんなこと\nで強くなれるわけないでしょ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0103105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「……出来なきゃセップクする軍規だって？　そんなワケないでしょ！　バカ\nにしないでちょうだい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0103106" ]},
		{"command":[ "SETCHARA", "0", "char_00010601_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「…………だ、誰が怖がってるのよ！　冗談じゃないっての。いいじゃない、\nやってやろーじゃないの！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0103107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「ひうぅ……こ、これが、おちんちん……。変な形……うう、なんだか、先っ\nちょがペタペタしてて、気持ち悪い……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0103108" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00010601_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「それに、変な匂いがするんだけど？　仮設トイレみたいな匂い……くんくん\n……くんくんくん……うえぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「ほ、ほんとに、これ、必要なことなんでしょうねぇ？　もしいい加減なこと\n言ってたら、あとでセップクだからね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「そ、それで……？　どうしたらいいの……？　ふえぇ……挟み込んだまま、\nおっぱいを動かせ……ですって？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0103111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「こ、こんな感じ……？　ん、んん、はぁ……ふぅ……あうぅぅ……谷間の中\nで、ヒクヒク動いてる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「はぁ……ふぅ……結構な、重労働じゃない……クンフーが積めそう……で、\nこれであってるの？　早く、終わらせてよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0103113" ]},
		{"command":[ "SETIMAGE", "0", "still_00010601_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「はぁ？　こんなことで音を上げるわけないでしょ！　早くアニメを見なきゃ\nいけないって、だ、け……はぁ、はぁ……ふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0103114" ]},
		{"command":[ "SETIMAGE", "0", "still_00010601_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「……うう、呼吸をすると、おちんちんの匂いが、鼻に染み付いてくる……は\nぁ、ふぅ……あうぅ、変な匂いぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0103115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「ん、んんぁ、はぁ……先っちょが、プクプク膨らんでる……グロい……うう\n、ここだけ、どうしてこんなに生々しいのよぉ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「うう、谷間から顔出してる……川底に住む魚類みたい……ひうぅ、ほんと気\n味悪い……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0103117" ]},
		{"command":[ "SETIMAGE", "0", "still_00010601_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「はぁ、んふぅ……谷間の中で擦れてる……ああうぅ、変な感触……。皮膚の\n下で、ゴリゴリしてる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「おちんちんって、こんなに硬いの？　ふぅ……アニメで、ここをぶつけたり\nしたとき、金属音がするけど……あれ、本当だったのね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「え？　ちょ、何を笑ってるのよっ、もう……なんだかムカつく……はぁ、は\nぁ……ん、んん……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0103120" ]},
		{"command":[ "SETIMAGE", "0", "still_00010601_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「何よ……顔が赤いって？　仕方ないでしょ？　今クンフーを積んでる真っ最\n中、なん、だか、ら……はぁ、ふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「はぁ……ふぅ、こんなことさせて、強くなれなかったら……あなた、セップ\nクしてもらうからね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「子曰く『嘘つきはニンジャの始まり』よ。え？　知らない？　まあ、今思い\nついたから当然ね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「はぁ……ふぅ、とにかく……ん、んん……はぁ、あたしは、ニンジャと嘘つ\nいてエッチなことさせる卑怯者が嫌いなのっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「あたしは、武侠……はぁ、はぁ……ニンジャと、非道は許さない……ん、ふ\nぅ……はぁ……あああ、空気がオチンチン臭いよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0103125" ]},
		{"command":[ "SETIMAGE", "0", "still_00010601_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……あうう、おちんちんが苦しそう……おっぱいの中で、ヒク\nヒク痙攣してる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「おっぱいの間が、ヌルヌルしてる……汗？　え？　我慢汁……？　何それ、\nあたしの国の言葉でなんて言うの？　はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「ふえぇ？　気持ちよくなると、ヌルヌルが出るの？　アニメで見た精液と違\nう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「はぁ？　精液じゃない？　気持ちよくなると出るんじゃないの？　うう……\nあたし、ニホンゴ、ヘタになっちゃった……？　意味わかんない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0103129" ]},
		{"command":[ "SETIMAGE", "0", "still_00010601_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「え？　もうすぐ精液が出る……？　なんだか、わかんないけど……はぁ、は\nぁ……もっと激しく……？　しょうがないなぁ……よいしょっと──」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0103130" ]},
		{"command":[ "SETIMAGE", "0", "still_00010601_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「んっ、んっ、んん……っ、はぁ……はぁ……ほら、これで、どう？　気持ち\n、いい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「くぅ……ふぅ、これは確かに、鍛錬に、なる、かも……はぁ、はぁ……んっ\n、んん～～～……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「え？　気持ちいい……はぁ、はぁ……もう出そう？　い、いいよ……出して\n……はぁ、ふぅ……このまま全部……ん、んくぅぅぅぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「ひやぁぁぁぁ！！？　やっ、な、何これ！？　きゃうぅぅぅ……っ、なんか\n、出てる……いっぱい熱いの飛び散ってる！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0103134" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010601_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「ひうぅぅ……こ、これが、精液ぃ！？　うう……すごい……うわ、うわわ、\nこんなにいっぱい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0103135" ]},
		{"command":[ "SETIMAGE", "0", "still_00010601_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「はー……はー……アニメで見たとおりね……ふぅ、ビックリしたぁ……はふ\nぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0103136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「もう、お仕舞い？　ふぅ……そう、よかったぁ……え？　普段からエッチな\nアニメを見てるのか、だって？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0103137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「こっちに来てからよ。あたしの国は、エッチはご法度だもん。はぁ……ふぅ\n……ニホンはいろんなアニメがあっていいよね～……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「とにかく……これで終わりなんだよね……はぁ、疲れたぁ……でも、強くな\nった気がしないんだけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0103139" ]},
		{"command":[ "SETIMAGE", "0", "still_00010601_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「ふぅ……本物の精液って、すごいのね……うわぁ、まだビュルビュル溢れて\nる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「……え？　何？　このまま鍛錬の続きを……ですって？　ちょっと！　射精\nしたら終わりじゃないの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0103201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「一度で終わりだなんて言ってない……だって？　くぅ……ニンジャのように\n、人を騙すのね、あなたって……はぁ、ふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「侠者の風上にもおけない、クソニンジャヤロウね……後で憶えてなさいよ…\n…で？　さっきみたいにすればいいの？　オッケー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0103203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「ん、んん、はぁ……あぁ、精液で、ヌルンヌルンする……はぁ、ふぅ……あ\nあ、ニチャニチャ音がするよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0103204" ]},
		{"command":[ "SETIMAGE", "0", "still_00010601_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「変な匂い……ん、はぁ……谷間に匂いが染み付いちゃうぅ……匂いが取れな\nくなったら、あなたがなんとかしなさいよ？　わかった？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……んぅ、あぁあ……すごぉい……さっきより大きくなってる\n……谷間の中でドクンドクンと脈打ってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「はー……ふう……ああ、精液の匂いで、息が……できない……失神しちゃい\nそう……頭が、ぼーっと、してきちゃった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「ん、んん、はぁ、あふぅ……おっぱいが、ジンジンする……あうぅ、乳首が\nビンビン……だんだん恥ずかしく、なってきちゃった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「え？　この恥ずかしさに耐えることが、鍛錬の目的……だって？　くぅ……\nいい加減なこと言わないでよねぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0103209" ]},
		{"command":[ "SETIMAGE", "0", "still_00010601_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「どうしてこれに耐えたら、パワーアップできるのよ！　ん、んん、仕組みが\n全然わかんないってーの……もう、バカ、アホ、クソニンジャめ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0103210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「あ、ああ……やだ、ビクビクしてる……また、さっきみたいに、気持ちよく\nなってる……ん、ふぅ、はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0103211" ]},
		{"command":[ "SETIMAGE", "0", "still_00010601_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「こんなことで、気持ちよくなるだなんて……はぁ、ふぅ……おちんちんって\n、変なの……んん、あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「でも、なんだか……可愛く思えてきちゃった……はぁ、あはは……もっとイ\nジメてあげたく、なっちゃう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「え？　嬉しそう……？　バカ……イヤイヤやってるんだからね、ん、ふぅ…\n…勘違いしないで……はぁ、はぁ……あはぁあ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0103214" ]},
		{"command":[ "SETIMAGE", "0", "still_00010601_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「あああ、まだ震えてる……あはぁ、あなたも、変な声あげてる……それ、気\n持ちいい声なの？　ちょっと、不気味……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0103215" ]},
		{"command":[ "SETIMAGE", "0", "still_00010601_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「それで？　はぁ……もうすぐ、イキそう、なの……？　はぁ、はぁ……もっ\nと激しくすればいいのね……？　任せて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0103216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……あああ……精液が、泡立ってる……谷間とおちんちんに、\nもてあそばれて、生クリームみたいになってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「やだ……何、これ……はー、ふぅ……おっぱいが、熱い……溶けちゃいそう\n……ん、んん、あはぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0103218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「え？　もうすぐ、イキそう……？　うん、いいよ……とっとと出しちゃって\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「ふえ？　顔と胸、どっちがいいか……ですって？　そ、そんなこと決められ\nないっての！　好きに……して、ちょうだい……ん、んんん～～～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「あはぁぁぁぁぁ……！　出てる！　またいっぱい、溢れてる……んっ、んん\n、ひゃうぅ……んんんぅん！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0103301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010601_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「ちょっ、何よ、これ！！　うぶっ、げほっ……口に入っちゃったじゃないっ\n……ううぇぇ……変な味ぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「ん、んんぐぅ……ゴクン……おえぇ、喉越し最悪ぅ……はぁ……はぁ……ん\nん、ングゥ……はひぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0103303" ]},
		{"command":[ "SETIMAGE", "0", "still_00010601_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「喉に張り付いてる……ううぅ、味がいつまでも残ってる……はぁ、はぁ……\nあうう、ん、はぁ……匂いもすごぉい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0103304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「くんくん……くんくん……はぁ、ふぅ……さっきの分と合わせて、胸元が真\nっ白になっちゃった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0103305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「……うう、ビチャビチャが凄い……おっぱいが妊娠しちゃいそう……はぁ…\n…はぁ……あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0103306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「はぁ……ふぅ……もう、結局二度もバカなことにつきあわされちゃった……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0103307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「で？　あたし、強くなった？　どうなの？　ふぅ……ま、いっか……なんだ\nかんだで結構楽しかったし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0103308" ]},
		{"command":[ "SETIMAGE", "0", "still_00010601_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「なぁに？　またこんなことしたい……って？　さーて、どうしよっかなー…\n…？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「まあ、暇だったらいいよ。強くなって、ニンジャを一匹でも狩らなきゃなら\nないもんね～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「んぶぅ！？　んっ、んんんぅ！　ひゃうぅぅぅ！！？　ちょっ、あ、あなた\n、正気ぃ……っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0103401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010601_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「きゃうぅ……んんぅ！　顔が……ああん、目の前が真っ白になっちゃうぅ…\n…っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「んぐぅ……げほっ、ごほっ……鼻に、入ってくる……口の中にも……ん、ん\nん、はぁ……んんぅっ、ごくん……はへぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0103403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「変な味ぃ……何、これぇ……こんなもの顔にぶっかけるだなんて……本当に\n酷いんだから……はぁ、ふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0103404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「うわぁ……まだ出てる……ああ、谷間の中で、ビクンビクンしてる……はぁ\n、はぁ……白いので、谷間が埋まっちゃった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0103405" ]},
		{"command":[ "SETIMAGE", "0", "still_00010601_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「ああ……ドロドロで、おっぱいが重たくなっちゃった……くんくん……はへ\nぇ……匂いで、鼻が麻痺しちゃいそう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0103406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「ふぅ……ふう……こ、これで、もう終わり？　はぁ……ふぅ……結局、二度\nも付き合わされちゃった……あたし、バカみたい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0103407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「まあいいわ……結構楽しかったし……。でも、こんなことで、本当に強くな\nれるの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0103408" ]},
		{"command":[ "SETIMAGE", "0", "still_00010601_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「……成果のほどは、次の戦闘で確認させてもらうから。もし強くなってなか\nったら……その時はセップクよ。わかった？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0103409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「ふぅ……それじゃあ、またね。また時間があったら、このバカみたいなトレ\nーニング、付き合ってあげてもいいよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0103410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
