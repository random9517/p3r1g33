		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「改まって……向かい合うと……少し緊張してしまうな……いや、もちろん心\nの準備は済ませている」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0803101" ]},
		{"command":[ "SETCHARA", "0", "char_00004908_01", "2", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「ただ、まずは私の気持ちを……ご奉仕という形で味わってもらいたい……あ\nっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0803102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「ふふ……そんなに待ちきれなかったのか。少しがっつき過ぎじゃないか？　\nそう慌てなくても、私はちゃんとするつもりだぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0803103" ]},
		{"command":[ "SETCHARA", "0", "char_00004908_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「そんなにじっと……胸……お、おっぱいを見て……あぁ……オチンポがみる\nみる大きくなっていく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0803104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……あぁ……それだけ期待していたんだな。嬉しい……あぁ、私\nもどんどん発情してしまってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0803105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「あぁ、任せて欲しい。これも夫婦としての共同作業だ……このオチンポをパ\nイズリしていくからな……挟むぞ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0803106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「んんっ……！　あぁ……大きいな……それに、ビクビク脈打って……なんて\n逞しいんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0803107" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00004908_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「大きいのはお互い様……？　ふふっ、そうだな……私のおっぱいも、こうし\nてオチンポを包み込めるだけの大きさがあって良かったな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0803108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「その、ところで……もう、この場では上司と部下という関係というよりは、\n夫婦になったのだから……そ、その……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0803109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「私のことは……名前で……み、美鈴と呼んでくれないか？　そうされること\nが……私の夢の一つだったんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0803110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「あぁ……はいっ、あなた……。ふふっ……あなたなんて……初めて言ったか\nも知れない。ずっと……言ってみたかったんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0803111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「分かっている。あなたのオチンポを……私のおっぱいでたっぷり扱いて……\n気持ちよくなってもらうから……どうか楽にしていて欲しい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0803112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ、はっ、んんっ、あっ、んくっ、はぁっ、んっ……やり方は……\n何となく分かっている……おかしくは、ないよな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0803113" ]},
		{"command":[ "SETIMAGE", "0", "still_00004908_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「んんっ、気持ちいいか？　んっ、あぁ……もっともっとオチンポに押し付け\nて……私の火照りを感じて欲しい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0803114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「はっ、ふっ、んくっ、あっ……んんっ……どうかな……して欲しいやり方が\nあったら、何なりと言って欲しい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0803115" ]},
		{"command":[ "SETIMAGE", "0", "still_00004908_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「至らない所もあるだろうが、精一杯に頑張って……オチンポに喜んでもらう\nから……んっ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0803116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「おっぱいの形が……大きく崩れるくらいに……んっ、こういう……感じ、だ\nな……？　はっ、ふっ……んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0803117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「あぁ……じっと乳首を見られている……触られていないのに勃起しているの\nが……全部知られてしまう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0803118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「こうして……オチンポに擦り合わせているだけで……どんどん身体が発情し\nて……先端が硬くなってしまうんだ……あひっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0803119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「あぁっ……指で悪戯なんて……あっ、も、もちろん触っていい……だが、ん\nっ、う、上手くご奉仕できないから……程々に頼むっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0803120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「あはっ、あぁっ、んっ……あぁっ、乳首……気持ちいいっ……そ、そうか…\n…一緒に気持ちよくなるのがいいんだな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0803121" ]},
		{"command":[ "SETIMAGE", "0", "still_00004908_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「だが、もっとおっぱいを使いたいからな……んっ、縦に……ズリズリと……\nあふっ、この皮の付け根の場所……敏感だろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0803122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「ギュッと寄せて……また離して……んふっ、自分でも……こんなにいやらし\nく形が変わるんだって……驚いている……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0803123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「あぁ……このドスケベおっぱいは……あなたのモノだ。旦那様のオチンポに\nご奉仕するために、こんなにいやらしく育ったのかも知れない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0803124" ]},
		{"command":[ "SETIMAGE", "0", "still_00004908_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「だから、もっともっと感じて欲しい……今度は横にぎゅうっと……圧力を掛\nけていくからっ……はぁっ、くふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0803125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「あっ、んふっ……あぁっ……幸せだ……こうやってオチンポがすぐ近くにあ\nって……その感触を直接味わえることが嬉しい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0803126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「あなたも、遠慮しないで……もっとおっぱいを触って……腰も振ってオチン\nポを動かして欲しい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0803127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「あっ、んっ、あぁっ、そうだ……私も気持ちいいんだ……あなたのオチンポ\nにくっつけているおっぱいが気持ちいい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0803128" ]},
		{"command":[ "SETIMAGE", "0", "still_00004908_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「ぎゅっと握り締めて……何度も動かしていく間……ずっと、気持ちいい感覚\nに包まれたままで……あふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0803129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「んっ、あなたの気持ちよさそうな表情を見ていると……もう、それだけでも\n……嬉しくて仕方ないんだ……あんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0803130" ]},
		{"command":[ "SETIMAGE", "0", "still_00004908_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「はぁっ、んっ、同じ気持ち……？　あぁっ、私の感じている顔を……好きで\nいてくれる……んぁっ、そんなことを言われたら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0803131" ]},
		{"command":[ "SETIMAGE", "0", "still_00004908_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「あひっ、はぁんっ、嬉しすぎて……あぁっ、どうにかなってしまいそうだっ\n……んんっ、もっとおっぱい扱いていくからっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0803132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「はっ、ふっ、んんっ……あぁ……カウパーが出てる……オチンポもビクビク\n震えて……精液……出したがってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0803133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「いいぞ……もっとズリズリ……おっぱいするから……出したい時に出して欲\nしい……あぁ、できれば……このままおっぱいの中に……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0803134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「分かった……一気にするぞっ、はっ、ふっ、んぁっ、はふっ……根元から押\nし出すようにっ……オチンポ擦ってっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0803135" ]},
		{"command":[ "SETIMAGE", "0", "still_00004908_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「出してっ……あなたの濃いザーメンミルクっ！　私のおっぱいにぶち撒けて\nくれぇっ、あっ、んっ、くぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0803136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「はぁぁんっ！　あっ……あぁっ……熱い……！　濃いのが……中にっ、おっ\nぱいに出てるっ……んくぅうんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0803137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004908_01_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「んふっ、いっぱい出てる……ふふっ……そんなに気持ちよかったのか？　そ\nうか……うん、頑張ったのが報われた気分だ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0803138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「あっ……おっぱいの隙間から精液が垂れて来る……んっ……どうしても漏れ\nてしまうな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0803139" ]},
		{"command":[ "SETIMAGE", "0", "still_00004908_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「はぁ……それでも、中がヌルヌルだ……こんなに出してくれたんだな……本\n当に嬉しい……幸せだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0803140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「あふ……まだオチンポが熱くて硬い……まだ、ご奉仕を続けても大丈夫だろ\nうか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0803201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「ふふっ、もちろんだ……愛する旦那様のオチンポ……もっともっと気持ちよ\nくしてあげたいからな……んっ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0803202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「出してもらった精液のおかげで、滑りやすくなって……んんっ、大きく動く\nことができそうだ……はぁっ、んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0803203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「あふっ、ほら……こういう風に……んっ、うくんっ……オチンポがおっぱい\nの中で踊っているような感じで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0803204" ]},
		{"command":[ "SETIMAGE", "0", "still_00004908_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「ふふ……こういうのが好きなんだな？　あぁ、嬉しい……愛する夫が喜んで\nくれるんだ……嬉しいに決まっている……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0803205" ]},
		{"command":[ "SETIMAGE", "0", "still_00004908_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「そ、その……あなたはどうなんだ……？　この思いは私の一方通行では……\nない、よな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0803206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「そこは……頷くだけじゃなく……こ、言葉にして貰わないと困る……もう、\nシンプルでいい……あ、あるだろう、そういうのが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0803207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「あっ……あぁっ、うんっ……！　私も……愛してるっ！　はぁっ、あなたの\nこともっ……このオチンポもっ、愛しているっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0803208" ]},
		{"command":[ "SETIMAGE", "0", "still_00004908_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ、あふっ……こうして、ずっと肌を重ね合わせていたい……オチ\nンポを包み込むことができる……私だけの特権だ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0803209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「この気持ちよさ……あぁ、止まらない……手がずっとおっぱいを動かし続け\nてしまう……んっ、あぁっ、乳首……くっつけるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0803210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「ふぁっ……！　あぁっ、乳首とオチンポのキスっ……好きだ……くぅんっ、\n先端が熱く痺れて……すればするほど火照りが増して……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0803211" ]},
		{"command":[ "SETIMAGE", "0", "still_00004908_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「この熱を共有したい……はぁんっ、あぁ……もっとおっぱいを強く握り締め\nてっ……くぅんっ、あぁっ、乳首……ジンジンするぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0803212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「ふんっ、うくんっ、はっ、んっ、あぁ……オチンポ……根元の方もしていこ\nう……そうだ……このキンタマの所も弱いだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0803213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「ふふっ、腰の震え方が一段と大きくなったな。これは、もっと集中的に責め\nてやらないとだな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0803214" ]},
		{"command":[ "SETIMAGE", "0", "still_00004908_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「んんっ、ふっ、んくっ……はぅんっ……この柔らかくて、ぷるぷるしている\nのを、もっと押し込んで……くぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0803215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「はふっ……あっ、またオチンポがビクビクしている……んっ、これは……余\n裕がなくなっている証拠だな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0803216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「また、出したい時に出してくれていいからな……あぁ……あなたの出したい\nところに、思いっきり出して欲しい……はっ、んんっ、ふっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0803217" ]},
		{"command":[ "SETIMAGE", "0", "still_00004908_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「私も……あぁっ、あともう少しで……イ、イキそうだ……！　あなたと一緒\nに……その瞬間を迎えたい……だからっ、はっ、くぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0803218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「その瞬間になったら、教えて欲しいっ……！　本気のパイズリで……高みに\n上り詰めてっ……もうっ、本当にすぐっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0803219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「はぁんっ、出してっ……！　射精してっ……！　あなたの濃厚なオチンポザ\nーメンっ、またいっぱいドピュドピュっ、出してぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0803220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「はぁぁぁぁぁぁぁぁぁぅっ！　あぁっ……また、おっぱいの中っ……出され\nてるぅぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0803301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004908_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「あぁ……二発目もすごい量だ……ドクドク出て……止まらない……はふっ、\nあなたのザーメン臭が……いっぱいに広がるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0803302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……あぁ……おっぱいの中で震えるオチンポ可愛い……一生懸命\n射精している所を間近で見られるのがたまらない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0803303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「まぁ、可愛いと言うには、いささか立派過ぎる大きさだが……それでも愛し\nくて仕方ないことに違いはない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0803304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「全部出し切るまで、もう少し強く押し付けるからな……んんっ……ふっ、こ\nれで……搾り出せるかな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0803305" ]},
		{"command":[ "SETIMAGE", "0", "still_00004908_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「あふっ……最後のが出てきた……はふ……んっ、あぁ……これで出し切った\nということでいいだろうか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0803306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「あぁ……ど、どうだったかな……恐らく拙いところも多々あったと思うから\n、感想を聞くのもおこがましい気はするのだが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0803307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「お世辞抜きで最高……ほ、本当に……？　あなたの言葉……そのまま受け取\nっていいのだな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0803308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「ふふ……嬉しい……本当に一生懸命にしたから、それを認めてもらえるだけ\nで、私は本当に幸せだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0803309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「後は……もう少しだけ一休みしたら、今度は直接……ふふっ、最高の一夜に\nなりそうだな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0803310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「あくぅぅぅんっ！　んぁっ、か、顔にっ……ドピュって……あっ、出されて\nるぅぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0803401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004908_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「はぁん……あふっ、二発目は顔面シャワー……んふぅ……あぁ、あなたのザ\nーメン……顔に染み込んでいくぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0803402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「あんむっ……ちゅぷっ、んふぁ……も、もう少し近づけないか……？　直接\n舌で味わいたい……れろ、んちゅ、ぴちゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0803403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「んんっ、濃い……はふ……こんなにも生命力に満ち溢れて……顔にいっぱい\nマーキングされていく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0803404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「後もうちょっと出せそうか……？　あぁ……残さず掛けてくれ……んふ、直\n接オチンポで私の頬に塗り込んでくれ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0803405" ]},
		{"command":[ "SETIMAGE", "0", "still_00004908_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「んんっ……！　今度こそ出し切ったか？　あふ……あぁ……お疲れ様だった\nな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0803406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「それで……だ、大丈夫だったろうか……私のご奉仕は……正直、自信はそこ\nまでないのだが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0803407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「極上……い、いや、そんな見え透いたお世辞はいい。ほ、本当に……？　そ\nうか……いや、とても……嬉しいな、それは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0803408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「だが、気持ちを込めた……それは間違いないのだ。だから、あなたにそう言\nってもらえれば、こんなに嬉しいことはない。ふふ、私は幸せ者だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0803409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「後は……もう少しだけ一休みしたら、今度は直接……ふふっ、最高の一夜に\nなりそうだな……」", "NORMAL" ]},
