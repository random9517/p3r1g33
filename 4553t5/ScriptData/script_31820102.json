	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「うふふ……本当に部屋に呼んでもらえるなんて、嬉しいです。今夜は……も\nちろん、素敵な夜にしてくれますよね？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00018201_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "PLAYVOICE", "v2_182_0104101" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「そうでした、オシオキでした。そのオシオキ……しないんですか……？　楽\nしそうだなって……そりゃそうですよー」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00018201_01", "8", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_182_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「欲求不満の人妻を夜中に呼び出しておいて、今さら野暮ですよ。わたし、も\nうその気になってますから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0104103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「夫に相手してもらえなくて飢えてるのに……あんな若くてたくましいチンポ\nを見せつけられて……お預けなんて、イヤですよ？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00018201_01", "2", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_182_0104104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「うふふ……そうこなくっちゃ……わたし、ここに来るまでにアソコはもうビ\nチョビチョなんです……確かめてみますか？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00018201_01", "8", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_182_0104105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「ほら、あなたも早く脱いで……おっきなチンポを見せてください……うふふ\nっ、ほら、やっぱりもう大きくなってる……」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00018201_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0104106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「このチンポでわたしのぐちょ濡れオマンコの具合を確かめてみてくださいね\n……んっ、あっ……ああっ！　んっあぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018201_02_02" ]},
		{"command":[ "PLAYVOICE", "v2_182_0104107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「か、硬ぁい……熱く、て……夫の中折れチンポと全然違う……わかってたけ\nど、実際に挿入れてみたら……ホントすごぃいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0104108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「あぁあっ！　若いイケメンのチンポ最高ぉ……このエロチンポで、欲求不満\nの人妻マンコをしつけてくださいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0104109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「はっ、あぁんっ……！　あんっ！　ほらぁ、あなたも……腰振って……ガン\nガン奥を突き上げてぇ……んぅ、ふぅうっ……あはぁっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018201_02_03" ]},
		{"command":[ "PLAYVOICE", "v2_182_0104110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「そう、その感じっ……あっああっ……もう角度が違うの……カリが、今まで\n当たったことない所を、ゴリゴリ擦ってるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0104111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「若いオスチンポぉ……ギンギンに反り返った、デカチンっ……好きっ……こ\nれ好きぃ……もう、すごいのぉ……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018201_02_02" ]},
		{"command":[ "PLAYVOICE", "v2_182_0104112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「はあっ、あぁん！　ほ、ら……おっぱいも……おっぱいも、揉んでぇ……好\nきでしょ？　わたしのおっぱい……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0104113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「んっあっ……あん、あはぁぁあぁっ！　い、いぃいっ！　いんっ……気持ち\nいいっ……あぁあっ……奥、まで……きてるぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0104114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「はぁあっ、あぁっ……どう、ですか？　わたしのおまんこ……処女じゃない\nけど、締まりは、結構いいと思うんですけど……んっ、あっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0104115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「まあまあ？　厳しいですね……意地悪……ふふっ……じゃあ、こんなのはど\nうですか……もっと激しく腰振りますね……んふぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0104116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「はっはっ……！　はっ、んっあぁっ！　チンポぉ……わたしのぐちょ濡れま\nんこで、デカチンを……んっふぅ……！　ハメまくってぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0104117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「あんっ、はっ、あぁぁっ……！　こんなこと、小娘にはできないでしょう…\n…あっあっあぁ……あんっ！　はっ、はあぁっ！　ああっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018201_02_03" ]},
		{"command":[ "PLAYVOICE", "v2_182_0104118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「わ、わかってます……オシオキだって……でも気持ちいいんですもの、あな\nたのチンポが……こんな、あぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「夫のことは言わないで……せっかく楽しんでるのに、あの人のことなんか思\nい出したくないっ……んんぅっ……んふぅうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0104120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「わ、悪いとは思ってますけどぉ……あの人だって悪いんですよ、わたしを満\n足させてくれないからぁ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018201_02_02" ]},
		{"command":[ "PLAYVOICE", "v2_182_0104121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「だから、こうしてぇ……若くてイケメンがいるとこに働きに、きてるのぉ…\n…夫がたくましいオスじゃなかったからぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「簡単に若いチンポ咥え込んじゃったのぉ……だから、わたしは、悪くないん\nですっ……あっ、あぁっ……あんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0104123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「はぁあっ、あぁあっ！　と、当然、あなたですっ……比べ物になりません…\n…あなたとのセックスが、気持ちいいに決まってますぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0104124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「ひっ、ひぃあっ、あぁっ……あなたも、わたしのオマンコでぇ……気持ちよ\nくなってぇ……はっ、はひぃぃぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「……んっ、んんっ！　あなたのイケメンチンポで、浮気妻のおまんこにオシ\nオキしてくださいっ……あっんっ、んぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018201_02_03" ]},
		{"command":[ "PLAYVOICE", "v2_182_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「はあっ……あひぃんっ！　す、すご、いぃぃっ……ぶっといオチンポが、奥\nっ……ガンガン突いてくるぅ……！　ひっ、いぃんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0104127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「オマンコおかしくなっちゃう！　は、は、はひいぃ……激しくされるの好き\nですぅ……若いチンポ、大好きですぅ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018201_02_03" ]},
		{"command":[ "PLAYVOICE", "v2_182_0104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「くひぃいっ！　ひっ、はひぃんっ！　イ、イキそうっ……あぁ、激しいぃっ\n……もうイッちゃうぅぅぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「な、中ですっ……！　もちろん中に欲しい、ですっ……！　ドロドロで、熱\n々のザーメンっ……オマンコに欲しぃぃっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018201_02_02" ]},
		{"command":[ "PLAYVOICE", "v2_182_0104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「あんっ、あぁあんっ！　出して、このまま出してぇ……！　浮気マンコに、\nイケメンチンポで種付けしてください、あっあっ……あぁあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「お、おっぱいも……んんっ！　だらしなく揺れまくる、わたしのデカパイ揉\nみながら、中出しぃ……中出ししてくださいっ……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018201_02_04" ]},
		{"command":[ "PLAYVOICE", "v2_182_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「あぁんっ、ワガママでごめんなさい……で、でも、もう我慢できないんです\nっ！　お、夫……？　夫のことなんかどうでもいいです……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「ひぃっ、ひっひぃぃっ！　はぁあッ、イキたいっ……このチンポで、思いっ\nきりアクメしたいっ……お願いですからぁ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018201_02_05" ]},
		{"command":[ "PLAYVOICE", "v2_182_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、あっ！　ああっ！　も、もうっ、ダメっ！　イクっ……イクイ\nクっ、イッくうぅぅぅぅぅ～～～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0104135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「んひぃいぃいぃぃぃっ！　で、出てるっ……オマンコの奥で、若くてピチピ\nチのザーメンが出てるぅぅぅっ！　んっ、んんっ、ふぅぅ！」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018201_02_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0104136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「あぁあっ、はぁあっ……あふっ、うぅんっ……！　すごいっ……熱くって、\n堪らないっ……んっンンっ、あっあぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0104137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「ひぃ、はっ、はぁ……はああっ……あぁ、まだ出てるぅ……やっぱり、若い\nオスは違いますね……ふふっ、お腹がパンパンですぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「んぅうっ……はぁはぁ……お、終わりましたか……？　ふぅ、いっぱい出ま\nしたね……でも、チンポ、硬くなったままですよ……？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018201_02_08" ]},
		{"command":[ "PLAYVOICE", "v2_182_0104139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「あぁんっ……わかってますって……あなたが一回射精したくらいで、満足す\nるはずありませんもんね……続き、しましょう……うふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「はぁ、んっ……このまま二回戦だなんて……夫じゃ、絶対に無理なのに……\nあぁんっ……若いって、いいですね……最高ぉ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018201_02_06" ]},
		{"command":[ "PLAYVOICE", "v2_182_0104201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「今、射精したばっかりなのに、ガチガチで……んんっ、奥まで、届いて……\nあぁ、もう、戻れない……んっ、んっ、んふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「このチンポ、知ったら……もう、夫なんかと……夫婦生活なんか、できない\n……あぁんっ、ず、ずっと……これ欲しい……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018201_02_08" ]},
		{"command":[ "PLAYVOICE", "v2_182_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「わたしのおまんこ、これからも……オシオキしてくださいっ……浮気セック\nスにハマってる、この淫乱人妻を……このチンポでぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0104204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「ひぃあっ！　あっ、あぁぁっ……んんっ！　ま、また中で、大きくなったぁ\n……んふぅっ……カ、カリが……ゴツゴツ擦れてますぅ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018201_02_07" ]},
		{"command":[ "PLAYVOICE", "v2_182_0104205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「あんっ、はぁんっ！　う、嬉しい……あなたにも、気持ちいいって……言っ\nてもらえて、幸せぇ……んんぅぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0104206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「あっ、あんぅっ、はっはひぃ……！　んぅっ……チンポで、奥ゴリゴリされ\nて……子宮押しつぶされるの好きぃ……はぁあっ……あはぁぁぁんっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018201_02_08" ]},
		{"command":[ "PLAYVOICE", "v2_182_0104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「ンンっ、だってぇ……あぁっ、恥ずかしい……おまんこグチョグチョになっ\nてぇ……イヤらしい音が……しちゃうっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「あっあんっ！　あなたのチンポがいけないんですよ……こんなエロチンポぉ\n……欲求不満の人妻に見せたら、夢中になるに決まってますぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「あっ、ああっ……オチンポ、いいっ！　イケメンのエロチンポぉ……若くて\n大きくて、ガチガチでぇ……堪んないっ、んんぅっ、ふぅううっ……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018201_02_06" ]},
		{"command":[ "PLAYVOICE", "v2_182_0104210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「か、感じるっ、ふっといチンポがオマンコの中で、動いてるのが……んふぅ\nっ……も、もう、ダメぇ……感じすぎてぇ……はひぃいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0104211" ]},
