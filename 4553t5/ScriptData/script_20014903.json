{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0031" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "コンテストの開催まで時間がある。俺たちはもう少し会場を散策していた。", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「いやぁ……壮観ですなぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023270001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "2", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うわっ、ジュンジロー。お前はバズーカ隊と会場警備じゃなかったか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「少々時間ができましたので、ご主人と同じく、会場を見て回っていたのです\nぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023270002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……サボりか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「失敬な。ご主人じゃあるまいし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023270003" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「そんなことよりあちらを」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023270004" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ジュンジローに言われた方向に目をやる。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ムチムチスケベなメガネエルフでごさいます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023270005" ]},
		{"command":[ "SETCHARA", "0", "char_00017201_01", "0", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "1", "char_00017301_01", "0", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああ……すげぇな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "なんて高い再現度だ。ふともものムチムチ感なんかいまにも破裂しそうじゃな\nいか。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "まさしくドスケベ爆弾。爆発物処理班を呼ばなければ。いや、俺がその爆発物\nを処理してやろうか？", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「さらにあちらを」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023270006" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ん……？　おぉ……っ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ロリ巨乳のメスガキ海賊団ですなぁ。あわせでしょうか、構成員がそろい踏\nみですぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023270007" ]},
		{"command":[ "SETCHARA", "0", "char_00020701_01", "0", "CENTER", "0" ]},
		{"command":[ "SETCHARA", "1", "char_00020801_01", "6", "CENTER", "600" ]},
		{"command":[ "SETCHARA", "2", "char_00020901_01", "1", "CENTER", "-600" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "DISPCHARA", "2", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「すげぇな……。みてるとわからせたくなってくる……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人、ノータッチですぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023270008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「わかってるよ。それにしても、こっちもすげぇ再現度だな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「もしかしたら『本物』も紛れ込んでいるかもしれませんな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023270009" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "DISPCHARA", "2", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いやいや、いくらなんでも……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ありえない、とは断言できなかった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "なにせ、マルチバース・コスプレ・サミットだ。別次元からやってきた本人が\n参加している可能性も否めない。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "……と、ここで気づく。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "どうやら俺たちは、いつの間にか過激なコスプレが集まるエリアに足を踏み入\nれていたようだ。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「はわわわわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_010023270001" ]},
		{"command":[ "SETCHARA", "0", "char_00022102_01", "5", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "アンが顔を真っ赤にしている。やばい、これは刺激が強すぎたか……！", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「おや、あそこもなにやら盛り上がっていますな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023270010" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「こ、今度はなんだ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ひときわ衆目を浴びている一団に目をやると、そこにいたのは見覚えのある黒\nいオボロだった。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お前っ、ビキニアーマーの神殿で見かけた黒いオボロ！？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「むっ、見つかってしまいましたか。まさかあなた達まで参加しているとは…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090023270001" ]},
		{"command":[ "SETCHARA", "0", "char_00000520_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まさかお前までコスプレを……って、なんだ、ただのビキニじゃないか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「ふんっ。あなたの目は節穴ですか？　頭のコレをみてください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090023270002" ]},
		{"command":[ "SETCHARA", "0", "char_00000520_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「頭……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "黒いオボロが指さすところに、ちょこんとヘッドドレスが装着されていた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「ただのビキニと思わないことですね。ビキニメイドです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090023270003" ]},
		{"command":[ "SETCHARA", "0", "char_00000520_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ビキニメイドだって……！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "言われてみれば、身につけているビキニもモノトーンで、メイドを意識したよ\nうなフリルで飾られている。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「驚いて声も出ないようですね。グランプリとスタークリスタルは今日イチセ\nクシーなウチがいただきましたよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090023270004" ]},
		{"command":[ "SETCHARA", "0", "char_00000520_01", "2", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「せ……セクシー……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "オボロに似ている黒いオボロは、体型までオボロにそっくりで……つまり……\nセクシーと言うには……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「言いたいことはわかりますぞ、ご主人。ですが、一部の層には需要が見込め\nますぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023270011" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「周りにいる人たちも、大盛り上がりみたいね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010023270001" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「当然です。女幹部という高嶺の花が、メイドとなってご奉仕するんですよ？\nブルーオーシャンもいいとこです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090023270005" ]},
		{"command":[ "SETCHARA", "0", "char_00000520_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "黒いオボロはドヤ顔になり胸を張る。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうなのか……？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「ええ、ウチが独自に調査しました。間違いありません。ウチの周りの盛り上\nがりこそ、その証拠です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090023270006" ]},
		{"command":[ "SETCHARA", "0", "char_00000520_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "囲い" ]},
		{"command":[ "SETTEXT", "「ビキニッ！　メイドッ！　ぺったんこ！　ビキニッ！　メイドッ！　ぺった\nんこ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_010023270001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "囲いたちは声を揃えて大合唱だが……こいつら、女幹部でもメイドでもなく、\nこの貧乳に釣られたのでは……？", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「ウチのことを大いに称賛するがいいです。でも、ぺったんこは余計です！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090023270007" ]},
		{"command":[ "SETCHARA", "0", "char_00000520_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ぴしっ、と囲いたちを威嚇するように攻撃を繰りだす黒いオボロ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おいおい、メイドがそんなことしていいのかよ……」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「ふんっ。ウチは情けない主人が相手なら、鞭をふるって逆に躾けてしまいま\nすよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090023270008" ]},
		{"command":[ "SETCHARA", "0", "char_00000520_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "囲い" ]},
		{"command":[ "SETTEXT", "「ビキニッ！　ドＳ！　メイドッ！　ぺったんこぉおっ！　うぉおおおぉぉぉ\nっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_010023270002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "歓声をあげて盛り上がる囲いたち。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「だから、ぺったんこは余計なのです！　どうやらお仕置きされたいようです\nね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090023270009" ]},
		{"command":[ "SETCHARA", "0", "char_00000520_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "黒いオボロが手を振り上げた瞬間、そいつと囲いとの間の地面にクナイが突き\n刺さった。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "？？？？" ]},
		{"command":[ "SETTEXT", "「ビキニメイドはお前だけじゃないのです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110023270001" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "現れたのは、黒いオボロと同じような格好をしたハルノブだ。", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000519_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「グランプリを狙って参加したら、ウチとネタが被っているではないですか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110023270002" ]},
		{"command":[ "SETCHARA", "0", "char_00000519_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「ネタを被せてきたのはそちらでしょう。こっちが先にビキニメイドをしてい\nたんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090023270010" ]},
		{"command":[ "SETCHARA", "0", "char_00000520_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "同じような格好をしたふたりがにらみ合っている。一触即発の雰囲気だが、囲\nいたちはビキニメイドがふえたことでより盛り上がっている様子だった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「真のビキニメイドはウチです。さあ、どうです？　どんな奉仕を望みですか\n、ご主人さま？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110023270003" ]},
		{"command":[ "SETCHARA", "0", "char_00000519_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「ね、ネタ被りのくせに、ウチより目立とうとするんじゃねーですよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090023270011" ]},
		{"command":[ "SETCHARA", "0", "char_00000520_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「二番煎じはさっさと去るです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110023270004" ]},
		{"command":[ "SETCHARA", "0", "char_00000519_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「二番煎じはそちらでしょうが！　ええい、ウチより目立つんじゃねーです！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090023270012" ]},
		{"command":[ "SETCHARA", "0", "char_00000520_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ハルノブを押しのけ黒いオボロが前にでる。と思えば、黒いオボロを押しのけ\nてハルノブが前にでる。", "NORMAL" ]},
		{"command":[ "SETCHARA", "1", "char_00000519_01", "7", "CENTER", "400" ]},
		{"command":[ "SETCHARA", "0", "char_00000520_01", "7", "CENTER", "-400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「ぐぬぬ……。このままでは、埒があきませんね……。だったら……こうです\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090023270013" ]},
		{"command":[ "SETCHARA", "0", "char_00000520_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「……んくっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110023270005" ]},
		{"command":[ "SETCHARA", "0", "char_00000519_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "突然ハルノブの腰が震えた。見ると、黒いオボロの術式がハルノブのパンツを\n引っ張り上げている。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んはぁっ、あっ、なにを……！　んくっ、食い込んで……へ、変なところに\nぃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110023270006" ]},
		{"command":[ "SETCHARA", "0", "char_00000519_01", "5", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「お望み通り、目立ちたいのなら目立たせて差し上げますよ。ただし、恥ずか\nしい格好で……んひゃぁっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090023270014" ]},
		{"command":[ "SETCHARA", "0", "char_00000520_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "今度はハルノブがクナイについている紐で黒いオボロを縛り上げていた。ビキ\nニの上から、凹凸の少ない身体を亀甲縛りにしている。", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000520_01", "5", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「油断しましたね？　あなたも目立ちたいようですから、同じように……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110023270007" ]},
		{"command":[ "SETCHARA", "0", "char_00000519_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「ひぃいっ！　紐が、あ、アソコに……んくっ、ふぅっ、あぁ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090023270015" ]},
		{"command":[ "SETCHARA", "0", "char_00000520_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「なんて声ですか。Ｓかのようにふるまっておいて、本当はとんだドＭメイド\nだったようですね……あひゃぁっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110023270008" ]},
		{"command":[ "SETCHARA", "0", "char_00000519_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「そ、そちらこそ……んくっ、こうやってパンツを引っ張られて、感じている\nんじゃないですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090023270016" ]},
		{"command":[ "SETCHARA", "0", "char_00000520_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んっ、くふぅっ！　この、変態……ぃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110023270009" ]},
		{"command":[ "SETCHARA", "0", "char_00000519_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「こっちの台詞……ひゃぁっ！　で、です……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090023270017" ]},
		{"command":[ "SETCHARA", "0", "char_00000520_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "にらみ合うハルノブと黒いオボロだったが、下半身へ目をやると、ふたりそろ\nってふとももを小刻みに震わせていた。", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000520_01", "5", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "1", "char_00000519_01", "5", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "紐やビキニをワレメにしっかり食い込ませ、腰をピクピクさせている。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "互いのことを責めるうちに、その様子を囲いたちに見せつけるかのような体\n勢になっていた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「んくっ、いい加減に……あっ、負けを、認めて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090023270018" ]},
		{"command":[ "SETCHARA", "0", "char_00000520_01", "2", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「負けを認めるのは、そちら、です……んっ、あぁっ！　こいつらの前で、無\n様な……顔を、晒しぃ……あひゃぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110023270010" ]},
		{"command":[ "SETCHARA", "0", "char_00000519_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「ぶ、無様にアヘるのは、そっち、です……！　くひゅぅっ！　あっ、ああ…\n…っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090023270019" ]},
		{"command":[ "SETCHARA", "0", "char_00000520_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "囲い" ]},
		{"command":[ "SETTEXT", "「ぷにまん！　ぺったんこ！　うぉおおおぉぉぉっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_010023270003" ]},
		{"command":[ "SETCHARA", "0", "char_00000520_01", "5", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "1", "char_00000519_01", "5", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "いつしか、ふたりの小競り合いは相手のパンツを喰い込ませてのイかせあいに\n発展していた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「だ、旦那さま～？　なにが起きてますの～？　な、なにも見えませんの～っ\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_010023270002" ]},
		{"command":[ "SETCHARA", "0", "char_00022102_01", "9", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "さすがに、こんな光景をアンには見せられない。目隠ししながらその場を離れ\nた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「どうする……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010023270001" ]},
		{"command":[ "SETCHARA", "0", "char_00001804_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「どうって……強力なライバルには間違いないわよね。なにせ、時間帝国だし\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010023270002" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「でも……あのようすだと失格で出禁だと思うな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010023270002" ]},
		{"command":[ "SETCHARA", "0", "char_00001804_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まあ……そうだろうな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "まさかスタークリスタルを時間帝国まで狙っているだなんて。その力は、本物\nということなのだろう。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「こうなったら、絶対に優勝しないといけないわね。がんばりましょう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010023270003" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「はい！　絶対にスタークリスタルを手にいれましょう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_010023270003" ]},
		{"command":[ "SETCHARA", "0", "char_00022102_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「そうだね。ダイヤナさん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010023270003" ]},
		{"command":[ "SETCHARA", "0", "char_00001804_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "三人はコンテストに向けて士気を高めあっていた。すると、ダイヤナがなにか\n思いついたような顔をする。", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「……ねえ、グリムロックちゃん。あたしのことちゃんづけで呼んでもいいの\nよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010023270004" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「ええっ、そんないきなり……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010023270004" ]},
		{"command":[ "SETCHARA", "0", "char_00001804_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ダイヤナの提案に、グリムロックは驚いていた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「いきなりじゃないわよ。あたしたち、一緒にお仕事するようになってからそ\nれなりに経つじゃない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010023270005" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あたしとしては、もっとグリムロックちゃんと仲良くなりたいかなって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010023270006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「あ……その……。ちょっと……考えておきます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010023270005" ]},
		{"command":[ "SETCHARA", "0", "char_00001804_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「アンちゃんもね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010023270007" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「は、はい！？　えと……ダイヤナ……ちゃん……。うぅ、なんだか恥ずかし\nいのでこれまで通りで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_010023270004" ]},
		{"command":[ "SETCHARA", "0", "char_00022102_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「んもぅ、かわいいんだから♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010023270008" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "アンは少し照れながらダイヤナを呼ぶ。しかし、いきなりちゃんづけというの\nはハードルが高かったらしい。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETCHARA", "0", "char_00022102_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「歳の近いグリムロックならまだしも、アンにまでちゃんで呼ばせるか……？\n」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「別にいいじゃないよぉ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010023270009" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "即席チームだが、三人はどんどん打ち解けてきているようだった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「いやぁ、いいチームになりましたなぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023270012" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なに古参ぶってんだよ。というか、いつまでも休憩していていいのか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「おっと。それではわたくしはこれにて、持ち場に戻らせていただきますぞ～\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023270013" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}