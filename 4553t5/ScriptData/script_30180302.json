		{"command":[ "PLAYVOICE", "v2_018_0304120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「ああ……おマンコがぐちょぐちょになるぅ……。んぁっ、ああっ、腰が……\n止まらないよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0304121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「君のおチンポを使って……オナニーしちゃう……。おチンポに……おマンコ\n、こすりつけ、オナニー……」", "NORMAL" ]},
