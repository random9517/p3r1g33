		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「だって近頃の君は私のことを見ていてくれないから……。君は不運にも、こ\nんな嫉妬深い魔女に目を付けられちゃったんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0304102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「というわけでね……んふっ、おチンポにしっかり、私のことを覚えこませる\nから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0304103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「こうやって、君のおチンポに、私のおマンコをおしつけて……んっ、ほら、\nおチンポとおマンコ、擦りあわせて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0304104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「んっ、んふぅ……んっ、んっ、ああ……ン……。ほら……しっかり覚えるん\nだよ……私の、おマンコ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0304105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「ああ、すごい……。もう君のおチンポ、ガチガチになってきてる……。私の\nおマンコを感じて……勃起しちゃってるね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0304106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
