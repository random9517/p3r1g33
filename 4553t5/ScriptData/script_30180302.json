		{"command":[ "PLAYVOICE", "v2_018_0304108" ]},
		{"command":[ "SETIMAGE", "0", "still_00001803_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「ヒヒ……私も、興奮しちゃっているよ……。おマンコで、君のおチンポと触\nれ合っているんだもん……はぁ……ああ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0304109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「ずっと、想像していた君のおチンポ……。やっとこうして……ヌルヌルって\n、触れ合ってると思うと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0304110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「ああ……すごく胸が高鳴っちゃう……。もっと……私のおマンコ、擦りつけ\nちゃうね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0304111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「どんどん溢れてくる、愛液をたっぷりと塗りたくって……フェラチオのたび\nに、私の愛液の味がしちゃうくらいに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0304112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「はぁ……おチンポ……んぅ、膨らんで……あんっ、おマンコを押し返すみた\nいに、ビクビク、してる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0304113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「どうしたの？　入れたいの？　私のヌルヌルおマンコに、このおチンポを入\nれちゃいたい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0304114" ]},
		{"command":[ "SETIMAGE", "0", "still_00001803_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「ヒヒ……そうだよね……。でも、不運にもこれは、オシオキだから……。入\nれたくても、ダメ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0304115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「本当は、私もおチンポを入れたいけど……でも、こうして腰を動かしている\nだけでも、気持ちいいから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0304116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「君の切なそうな顔を見ながら……濡れたおマンコをおチンポにすりすりって\nしているだけで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0304117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「ガチガチに……勃起したおチンポ、感じて……んっ、ああ……だめ……気持\nちよく、なり過ぎちゃう……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0304118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「わかる……？　感じる……？　私のおマンコ……クリトリスまでいやらしく\n勃起させて、硬くなって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0304119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
