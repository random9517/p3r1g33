{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0187" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「いよいよ、この瞬間がやってきましたね……何というか……少し感慨深いも\nのがありますね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1803101" ]},
		{"command":[ "SETCHARA", "0", "char_00000518_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「緊張はまぁ少しだけ……ですが、楽しみの方が大きいですから。今日は、普\n段と違うデレたウチを見せてあげるです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1803102" ]},
		{"command":[ "SETCHARA", "0", "char_00000518_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ですから、普段あまりできないことでもしてあげますよ。リクエストがあり\nますか？　大抵のことはお応えしますです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1803103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「パ、パイズリ……？　あの……お、おっぱいでするという……アレ……です\nか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1803104" ]},
		{"command":[ "SETCHARA", "0", "char_00000518_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ウチのサイズを知っていて……それでもなおご所望ということですね？　面\n白いです……その挑戦、受けてやるですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1803105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……なんだかんだで……オチンチンは、しっかり大きくなってる\nじゃないですか。ウチにされることを期待してたんですね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1803106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00000518_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「それで……要するに、おっぱいでこれを包み込んで、擦ってやりながら気持\nちよくさせていけばいいんですよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1803107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「そんなに慣れてはいませんが……ウチを誰だと思ってますか。こんなパイズ\nリくらい……ちょちょいのちょいですっ……んっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1803108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「こうして……んっ、ぎゅっと……寄せ、寄せて……よ、寄らない……んっ、\nもっと……前に出れば……んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1803109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ほ、ほらっ、挟まりましたっ！　ですよね？　挟まってますよね？　これっ\n、オチンチンにおっぱいっ、ちゃんとくっついてますね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1803110" ]},
		{"command":[ "SETIMAGE", "0", "still_00000518_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ふふん、当然です。確かに薄めかも知れませんが、ウチにもちゃんとおっぱ\nいは備わっているんですからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1803111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「こういうものは、量より質です。ウチのテクニックで、オチンチンを極上の\n世界に導いてあげるですから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1803112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ、あっふ……んくぅ……オチンチン……すごく熱くなっています\n……ウチのおっぱいで、ドキドキしたんでしょう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1803113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「そうでしょう、そうでしょう……何と言っても新婚初夜なんです……妻のパ\nイズリで興奮しない夫なんて論外ですからね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1803114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「その点、あなたはそこは大安心のスケベさがありますから。はい、もちろん\n褒めていますよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1803115" ]},
		{"command":[ "SETIMAGE", "0", "still_00000518_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「とにかく、エッチな旦那様を満足させるには、ここからが重要です……まず\n、たっぷりと唾液を垂らして……谷間に……谷間です！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1803116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ほら、これでかなりぬるりと滑るようになります。そうしたら……身体を大\nきくっ……上下に動いていきますっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1803117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「はっ、んふっ、こうしてっ……ずりっ、あっ、んっ、ずりっ……んっ、おち\nんちんが……揺れるのをしっかり捕まえてっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1803118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ヌルヌルを広げていくように……していきますから……んっ、ふっ……どう\nですか？　おちんちん……ちゃんと気持ちいいですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1803119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「すごくいい……本当ですか？　夫婦の間で、変な社交辞令はなしですよ？　\nいいところがあれば伸ばして、悪いところは直しますっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1803120" ]},
		{"command":[ "SETIMAGE", "0", "still_00000518_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「このやり方で……んっ、本当に……ちゃんと上手くいってるんですか？　え\nっ、柔らかい肌と……肋骨の感じがいい……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1803121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「肋骨は……どうなんでしょう……んっ、ま、まぁ……確かに、豊満な人では\nなかなか味わえないものかも知れません……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1803122" ]},
		{"command":[ "SETIMAGE", "0", "still_00000518_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「と、とにかくっ……んっ、このサイズでも……ちゃんと喜んじゃう変態なオ\nチンチンなんですね？　ふふっ、それなら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1803123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んっ、はっ、んふっ、あっ……んくっ、気持ちよくなっちゃいましょう……\n乳首……ぎゅってっ……当てちゃいますよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1803124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あぅんっ……！　いかがですか……？　乳首のコリコリした感触は……巨乳\nの人にも簡単には負けないと思いますよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1803125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「こうして、オチンチンの……鈴口のところをツンツンして……んっ、ふっ…\n…ピクってしたところで……おっぱいを……んっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1803126" ]},
		{"command":[ "SETIMAGE", "0", "still_00000518_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「はっ、ふっ、こうしてっ……ズリズリ……させてあげたら……いい、感じに\nぃ……あっ、なりますよね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1803127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んんっ、鼻息が荒くなって来ましたね……その調子です……もっと、いやら\nしい気分になってくださいね……は、んぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1803128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「はっ、ふっ、えいっ……んんっ……！　ほら、ここですよね？　肋骨のとこ\nろ……こんな場所がいいなんて……本当にド変態ですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1803129" ]},
		{"command":[ "SETIMAGE", "0", "still_00000518_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「まぁ……そんな変態と結婚してしまったウチも、同じくらい変態かも知れま\nせんが……はっ、んんっ、お似合いかも知れません……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1803130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「これで……んっ、あふっ……もっとオチンチン……やる気が出るようにして\nあげますから……んっ、くっ、はっ、んふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1803131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ずりずりっ……しこしこっ……包み込むのは難しくても……こうして、オチ\nンチンと触れ合うのは、いっぱいできますっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1803132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「はい、ウチも……おっぱい気持ちよくなってます……あっ、オチンチンも…\n…お汁出てます……もう少しですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1803133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「出すなら……このまま、おっぱいの中に出して欲しいですっ……んっ、あな\nたの精液……直接おっぱいで受け止めたいですからっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1803134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「後もう少し……本気で……こすこすしますっ、うんっ、はっ、ふっ、あぁ…\n…オチンチンまた、ビクって……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1803135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「出してっ、掛けてくださいっ……熱いのっ……おっぱいにっ、びゅくびゅく\nっ、してっ……あぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1803136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「はぁぁぅんっ！　あぁっ……射精っ……始まってますっ……あぁっ、おっぱ\nいの中にっ……いっぱい精液……出てますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1803137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000518_01_04" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んっ、ふぁ……あったかいの……どぷんって……すごい……おっぱいの中…\n…いっぱいですぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1803138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ふぁぁ……ウチのパイズリ……喜んでもらえたんですね……ちっぱいでもイ\nケる、無節操なオチンチンでよかったです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1803139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んふふ……もちろん褒め言葉ですよ？　それでこそ、ウチの愛すべき旦那様\nなのです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1803140" ]},
		{"command":[ "SETIMAGE", "0", "still_00000518_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「はぁ、ふ……いっぱい出してくれました……でも、これで終わるようなオチ\nンチンではありませんよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1803201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「せっかく、こんなにぬめりを足してくれたんですから、ここからが本番と言\nっても過言ではありません……んっ、しょっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1803202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あふっ……！　さっきより、もっとオチンチン滑って……はぁっ、これは…\n…気持ちいいご奉仕ができそうです……は、ふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1803203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「はぁぁ……それにしても、この精液のにおい……いつ嗅いでも堪りませんね\n……ウチの気持ちが何倍にも高まってしまいます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1803204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「はい、最初はこんな強烈な臭気……絶対無理って思いましたけど……今は、\nもうこのにおいじゃないとダメになってしまいました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1803205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「まあ、しっかりと責任を取ってもらった訳ですから……結果オーライですけ\nどね……ふっ、はっ、んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1803206" ]},
		{"command":[ "SETIMAGE", "0", "still_00000518_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「こうして、んっ、オチンチンのところに、いっぱい馴染ませていくと……よ\nりにおいが熟成されて……ウチの好みになっていきます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1803207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「はぁ、んむっ、ちょっとだけ味見を……ちゅぱっ、はぁぁ……ダメです……\n舌が止まらなくなっちゃいますから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1803208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「今日はあくまでも、パイズリがお望みなんですから……んっ、うんっ、主役\nはおっぱいじゃなくてはいけません……んふっ、はっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1803209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あぁ……んっ、でも……おっぱいの方も……かなりコツは掴んできました…\n…んっ、垂直に近くても……密着させて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1803210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「こうやって、上下に動けば……はぁっ、んっ、おっぱいとオチンチン……か\nなり密着して……激しくなります……はっ、ぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1803211" ]},
		{"command":[ "SETIMAGE", "0", "still_00000518_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あぁ……素敵です……おっぱい……ムズムズして……んふぅ……ウチも、す\nごく……気持ちよくなっちゃってます……あふぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1803212" ]},
		{"command":[ "SETIMAGE", "0", "still_00000518_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んんっ、くぅぅ……もっと……あっ、いっぱい擦って……ずりゅずりゅって\n……一つになって……旦那様に満足してもらうです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1803213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「いい感じですか？　んふっ……当然です……ウチが本気でパイズリしてるん\nですから……サイズのハンデはないようなものですっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1803214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ちっぱいでもっ……ちゃんと、喜んでもらえることをっ……こうして……証\n明させるですっ、あっ、あぁっ……乳首っ、よじれますぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1803215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「はぁっ、んんっ……また、オチンチンっ……イキそうですかっ？　もう一回\n……射精っ、できそうなんですねっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1803216" ]},
		{"command":[ "SETIMAGE", "0", "still_00000518_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「はぁっ、んふっ……分かりましたっ……本気を出しますっ……ウチのラスト\nスパートっ……オチンチンでっ、感じてくださいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1803217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んんっ、くぅんっ、はぁぁんっ……おっぱいの中でもっ……顔でもっ、お好\nきなところにっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1803218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「いっぱい、いっぱい出してくださいっ！　せーえきっ、ドピュドピュっ……\n新妻にっ、出しまくってっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1803219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「はぁんっ、ウチも……イキそうですっ、はぁんっ、あぁっ……お願いっ……\nしますぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1803220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ひゃうっ！　あっ……また、精液っ……おっぱいに……出されてっ、ますぅ\nっ……ふぁぁぁぁんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1803301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000518_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んふぁぁ……濃いのが……ウチのおっぱいを浸していきます……んんっ、あ\nったかい……旦那様にマーキングされてますぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1803302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「はぁっ、オチンチンから出るところ……すごい迫力です……はふぁ……広が\nるにおいも……もっと濃くなってますぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1803303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んちゅぷっ……味見です……あぁ……んっ、美味しい……やっぱり夫の精液\nは栄養価も高いですからね……しっかり味わいませんと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1803304" ]},
		{"command":[ "SETIMAGE", "0", "still_00000518_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あぁ……オチンチン終わっちゃいました……でも、思っていた以上にいっぱ\nい精液……出していただけました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1803305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「おっぱいの中が精液まみれです……ふふん……それだけウチの魅力に参って\nしまったということですね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1803306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「その通りって……な、何を真顔で頷いてますかっ！　ちょっとからかったつ\nもりなのに……ウチの方がからかわれた気分です……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1803307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ま、まぁ……夫婦なのですから、それくらい正直である方がいいのかも知れ\nませんね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1803308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「サイズのハンデはありますが、それを感じさせないように、これからも技を\n磨かなくてはなりませんね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1803309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ふふ……そして、ウチのパイズリじゃないとイケないぐらいに……虜にして\nやりますよ……覚悟しておくです♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1803310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ぷぁっ！　んふぁっ……顔にっ……あっ、んぷっ……精液っ……出されてっ\n、ますぅぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1803401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000518_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「はふぁ……んちゅぷっ、すごい量です……んんっ、一回目よりもっと出てい\nるような……んちゅぷっ、元気過ぎます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1803402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あぁ……オチンチン震えて……びゅくびゅくって……んっちゅ、はぁ、この\n生臭さ……癖のある味わいが格別です……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1803403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「臭いはずなのに……どうして、ウチは虜になってしまったんでしょう……も\nうこのにおいじゃないと物足りなくなってしまいました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1803404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んふぅ……あぁ……射精……終わりました……オチンチンの先端……まだ、\n精液がドロっと残ってますね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1803405" ]},
		{"command":[ "SETIMAGE", "0", "still_00000518_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んちゅっ、ちゅぱっ、ここはちゃんとお掃除してあげないとですね。えろ…\n…れろ、ぴちゃ……んちゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1803406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ふふ……いかがでしたか？　ウチのパイズリ……巨乳の人には及ばないかも\n知れませんが、それなりには満足できたのでは？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1803407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「比べ物にならないくらい最高だった……な、何をっ、そんな……見え透いた\nお世辞は別にいらないですからっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1803408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ほ、本当に……？　ウチがするから問答無用で最高……？　う、うぅぅー、\nそんな真顔で言われたら……こっちの顔が熱くなります……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1803409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「でも、悪い気はしませんね……ふふっ、なら、もっともっと技を磨いて……\n身も心もウチの虜にさせてもらいます……覚悟してくださいね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1803410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
