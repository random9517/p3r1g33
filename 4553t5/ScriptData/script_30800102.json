		{"command":[ "PLAYVOICE", "080_0104122" ]},		{"command":[ "SETNAME", "ヴィシュヌ" ]},		{"command":[ "SETTEXT", "「一点のくすみもなく、美しい色をして……あぁんっ！　欠点がなく締まりが\nいいっ……その上……んっ、ちょうど良い強さで絡みついてきて……っ」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "080_0104123" ]},		{"command":[ "SETNAME", "ヴィシュヌ" ]},		{"command":[ "SETTEXT", "「男性器を天界にすらいざなうというそうです……！　んん、はぁう……あん\nっ！　あんっ、あぁんっ……！　あんっ、あんっ！」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "080_0104124" ]},		{"command":[ "SETNAME", "ヴィシュヌ" ]},		{"command":[ "SETTEXT", "「返事も出来ぬほどですか……っ。あら……どうしたのですか？　切羽詰まっ\nた苦しそうなお顔をなさって……まさか、まさかですけれど……っ」", "NORMAL" ]},
