		{"command":[ "PLAYVOICE", "080_0104125" ]},		{"command":[ "SETNAME", "ヴィシュヌ" ]},		{"command":[ "SETTEXT", "「数度、中をかき混ぜただけで出してしまいそうなのですか！？　ふふふ、ふ\nふふっ……そんなことは許しませんよ……ほら。ほらほらっ……！」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
