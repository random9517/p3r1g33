		{"command":[ "PLAYVOICE", "080_0104135" ]},		{"command":[ "SETNAME", "ヴィシュヌ" ]},		{"command":[ "SETTEXT", "「神の子宮に射精したいのですよねぇ♪　でしたらもっと頑張ってくださいっ\n♪　がーんばれっ……♪　がーんばれ……♪　あっ♪」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "080_0104136" ]},		{"command":[ "SETNAME", "ヴィシュヌ" ]},		{"command":[ "SETTEXT", "「その調子ですよ……あんっ♪　子宮口を激しく突き上げて……あぁんっ♪　\nあんっあんっあんっ♪　そうそうそうそう♪　そう、です……ぅっ♪」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "080_0104137" ]},		{"command":[ "SETNAME", "ヴィシュヌ" ]},		{"command":[ "SETTEXT", "「あらっ♪　あらあらあら♪　すごいですねっ……私の責めに耐えながらも、\n健気におちんちんを膨張させ、て……あああっ♪」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "080_0104138" ]},		{"command":[ "SETNAME", "ヴィシュヌ" ]},		{"command":[ "SETTEXT", "「ごう、いんに……ぃいいい♪　強引に射精だなんてぇえええ……♪　あはぁ\n……ッ！　さすがですっ、さすがです隊長さま……っ♪」", "NORMAL" ]},
