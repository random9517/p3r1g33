		{"command":[ "PLAYVOICE", "080_0104106" ]},		{"command":[ "SETNAME", "ヴィシュヌ" ]},		{"command":[ "SETTEXT", "「くす……。いつ見ても、高慢で信仰心の薄いバキバキのおちんちんですね…\n…。なんて立派な……。指でなぞるだけで、気分が高揚してしまいます」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "080_0104107" ]},		{"command":[ "SETNAME", "ヴィシュヌ" ]},		{"command":[ "SETTEXT", "「んっ……。触り方がいやらしい……？　それは隊長さまも同じでしょう……\n？　あ、あぁ……はぁっ、私の身体を淫靡にまさぐって……♪」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00008001_02_02" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "080_0104108" ]},		{"command":[ "SETNAME", "ヴィシュヌ" ]},		{"command":[ "SETTEXT", "「肉欲丸出しの、下賤なその手つき……嫌いではありません♪　もっと、もっ\nと欲望のままに……あっ♪　そうです、そうして……ああ♪」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "080_0104109" ]},		{"command":[ "SETNAME", "ヴィシュヌ" ]},		{"command":[ "SETTEXT", "「私を撫でまわすと、勃起もどんどん強くなって……。なんと逞しく、雄々し\nいのでしょう……♪　見ているだけで濡れてしまいますね……♪」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "080_0104110" ]},		{"command":[ "SETNAME", "ヴィシュヌ" ]},		{"command":[ "SETTEXT", "「んっ、んっ、ん、はぁ、はぁ……。ねえ、隊長さま……？　じっくり愛撫に\n集中してくださるのも嬉しいのですけれど……どうでしょう？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00008001_02_01" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "080_0104111" ]},		{"command":[ "SETNAME", "ヴィシュヌ" ]},		{"command":[ "SETTEXT", "「まずは、この強直を私の膣内にねじ入れて……ふふっ。下から突きながら、\n愛撫も同時進行してみるという案は……？」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "080_0104112" ]},		{"command":[ "SETNAME", "ヴィシュヌ" ]},		{"command":[ "SETTEXT", "「あっ♪　いいのですか♪　嬉しい……。んんっ♪　亀頭をあてがうとわかる\nでしょう……？　もうトロトロに蜜が溢れているのです……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "080_0104113" ]},		{"command":[ "SETNAME", "ヴィシュヌ" ]},		{"command":[ "SETTEXT", "「そこを掻き分けて、存在を主張するように……ええ、そのまま……そのまま\n……！　あッ♪　あっあああああっ……♪」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "080_0104114" ]},		{"command":[ "SETNAME", "ヴィシュヌ" ]},		{"command":[ "SETTEXT", "「来ましたっ♪　きま……した、ぁ、あ、あ、あ、ああああ……♪　ふぁああ\nあっ……♪　ど、どうしましょう隊長さま、今私……っ♪」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00008001_02_06" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "080_0104115" ]},		{"command":[ "SETNAME", "ヴィシュヌ" ]},		{"command":[ "SETTEXT", "「入れられただけで一度イッてしまいました♪　きっと相性が良いのでしょう\nね……んんんっ♪　はぁ、はぁ、待ち遠しい……！」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "080_0104116" ]},		{"command":[ "SETNAME", "ヴィシュヌ" ]},		{"command":[ "SETTEXT", "「貴方の全力を、あっ♪　私の粘膜に……神の秘裂に突き入れるのですっ……\n！　あぁッ！？　はぁあっ、そう、そう、上手、です……ああっ！」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "080_0104117" ]},		{"command":[ "SETNAME", "ヴィシュヌ" ]},		{"command":[ "SETTEXT", "「上手ぅ……上手っ、じょ、ぉ、ず……っ♪　あぁああ……♪　隊長さま……\n隊長さま……おててが留守ですよっ、止めないでくださいませ……っ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00008001_02_05" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "080_0104118" ]},		{"command":[ "SETNAME", "ヴィシュヌ" ]},		{"command":[ "SETTEXT", "「男らしいその手のひらで……あぁあんっ、あぁんっ！　私の乳房を、胸を揉\nみしだきながら……股間を打ち付け、て……神を抱くのですっ！」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "080_0104119" ]},		{"command":[ "SETNAME", "ヴィシュヌ" ]},		{"command":[ "SETTEXT", "「あっ！　あっあっ！　そう、そうっ……！　獣のように……ぃぃいっ♪　私\nを喜ばせるために腰を振る、のです……あっ♪　あっあっ♪」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "080_0104120" ]},		{"command":[ "SETNAME", "ヴィシュヌ" ]},		{"command":[ "SETTEXT", "「ふふ……どうですか？　女神の女陰……ッ、あぁ……っ！　本来ならば、人\nの手の届かぬ奇跡……っ。まるで熱い湯の中のようでしょう……っ？」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
