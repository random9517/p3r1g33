		{"command":[ "PLAYVOICE", "080_0104102" ]},		{"command":[ "SETNAME", "ヴィシュヌ" ]},		{"command":[ "SETTEXT", "「私、仲間の……人の子に、貴方の好みの衣装を聞き出しました……。そして\n、買ってみたのがこの下着……なのです……♪」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "080_0104103" ]},		{"command":[ "SETNAME", "ヴィシュヌ" ]},		{"command":[ "SETTEXT", "「ふふ、どうやらお気に召したようで結構なことです……。ふふ……いつだっ\nて、隊長さまのお身体は本当に素直で、敏感……♪」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
