		{"command":[ "PLAYBGM", "BGM_015" ]},		{"command":[ "PLAYVOICE", "080_0104101" ]},		{"command":[ "SETNAME", "ヴィシュヌ" ]},		{"command":[ "SETTEXT", "「隊長さま……？　どうか、どうか目をこらしてよーくご覧くださいませ……\n♪」", "NORMAL" ]},
