		{"command":[ "PLAYVOICE", "080_0104139" ]},		{"command":[ "SETNAME", "ヴィシュヌ" ]},		{"command":[ "SETTEXT", "「ああ……ドクドクと膣で脈打って……子宮に精を送っているのですね……♪\n　私を自分のものになさるために……なんと素敵な……♪　あああっ♪」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
