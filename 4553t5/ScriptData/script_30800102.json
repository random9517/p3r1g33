		{"command":[ "PLAYVOICE", "080_0104128" ]},		{"command":[ "SETNAME", "ヴィシュヌ" ]},		{"command":[ "SETTEXT", "「その表情が見たかったのです……♪　私が腰をくねらせる、だけで……ぇえ\nえ♪　苦悶に歪むその顔が……私の大好物なんです……ふふふふ♪」", "NORMAL" ]},
