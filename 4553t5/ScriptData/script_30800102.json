		{"command":[ "PLAYVOICE", "080_0104207" ]},		{"command":[ "SETNAME", "ヴィシュヌ" ]},		{"command":[ "SETTEXT", "「私の……はぁああっ♪　維持神ヴィシュヌの選んだ、たった一人の肉バイブ\nとして……精根尽き果てるまで、狂ったように腰を振るんです♪」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
