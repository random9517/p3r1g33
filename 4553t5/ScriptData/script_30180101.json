		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「あっ、熱いっ……！　ザーメン熱いぃ……！　私の肌……もっと白くなっち\nゃう……！　ザーメンで真っ白にされちゃうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「フフフ……！　道具みたいに扱われて……容赦なくザーメンを浴びせられる\n……！　あああぁ……！　いいっ……！　実に不幸だね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0103403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「不幸すぎて……イッちゃう……！　ねえ……君も感じてる……！？　私の不\n幸せ……感じてくれてる……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0103404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「感じてるなら……もっと出して……！　私の不幸を包み込むぐらい、ザーメ\nン吐き出して……！　あっ、あっ……ああああぁ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0103405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「フフフ……君のザーメンで全身ベトベトだよ……本当に酷い扱いをされちゃ\nったね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0103406" ]},
		{"command":[ "SETIMAGE", "0", "still_00001801_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「でも、イヤじゃないよ……君にメチャクチャにされると、おマンコ感じて…\n…気持ちよくなっちゃうよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0103407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「ねえ……もっと私の身体、メチャクチャにして……？　ザーメンのニオイが\n染み付いて取れなくなるぐらい、いっぱい射精して……？」", "NORMAL" ]},
