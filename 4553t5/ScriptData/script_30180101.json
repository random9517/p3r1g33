		{"command":[ "PLAYVOICE", "v2_018_0103303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「くううぅ……！　んふっ、あっ、ひぐうぅ……！　はぁ、あああぁ……！　\nシゴけばシゴくほど、ザーメンが吹き出してくるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0103304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「ザーメンの熱とニオイ……無理やり感じさせられて……！　ああっ、不幸す\nぎてまたイクッ……！　あっ、あっ……！　イクッ……イクぅ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0103305" ]},
		{"command":[ "SETIMAGE", "0", "still_00001801_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「くっ、あっ……んふうぅ……すごい……ザーメンって、こんなに出るものな\nんだね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0103306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「中途半端に射精させたのもあるんだろうけど……それにしても、出しすぎだ\nよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0103307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「な、なんだい……？　こんなモノじゃ終わらないから、もっとおっぱいでお\nチンポをシゴけ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0103308" ]},
		{"command":[ "SETIMAGE", "0", "still_00001801_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「ちょ、ちょっと待って……！　今、イッたばかりだから……少しだけ休ませ\nて……！　ああっ！　また、勝手におチンポ動かすなんて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「フフ……フフフ……！　フフフフフ……！　この無理やりな感じ……すごく\n不幸せだね……！　私、またイッちゃいそうだよ……！！」", "NORMAL" ]},
