		{"command":[ "SETIMAGE", "0", "still_00001801_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「手を抜くわけじゃないし、一生懸命やるけど……あんまり気持ちよくなかっ\nたら……ごめんね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0103115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「はあぁん……あっ、あうっ……んっ、んんっ……！　おチンポ……すごく熱\nくて、カタいね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0103116" ]},
		{"command":[ "SETIMAGE", "0", "still_00001801_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「おっぱいで擦ってると……あふっ、んふっ……！　肌が焼けちゃいそうだよ\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「私の白い肌が……おチンポで焼けたりしたら……ああっ……！　想像するだ\nけで不幸せを感じるよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「フフフ……もっと君のおチンポを感じさせてもらうね……！　こうやって…\n…思い切り左右から挟んで……持ち上げて……んああぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「おチンポから、エッチなお汁が出てきたね……傘みたいなところが特に感じ\nるの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0103120" ]},
		{"command":[ "SETIMAGE", "0", "still_00001801_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「じゃあ、ここを重点的にシゴいてあげる……こうやって……エッチなお汁を\nおっぱいに絡ませて……はぁ、あっ、あはぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0103121" ]},
		{"command":[ "SETIMAGE", "0", "still_00001801_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「ヌルヌルのぐちゃぐちゃで……おっぱいがローション塗れになっているみた\nいだよ……ベトベトして、変な感じがする……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「でも、そのおかげで……楽におチンポがスリスリできるよ……んっ、んっ…\n…！　あっ、うぐっ……くっ、んふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「はぁ、はああぁ……！　エッチな音が……おっぱいから響いてくるよ……！\n　私たち、すごくいやらしいことをしてるんだね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「んぐっ、あっ、あふぅ……！　おチンポのビクビクが止まらないね……！　\nさっきから、エッチなお汁が何回も吹き出てるよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「それに……すん……すんすん……！　はああぁ……おチンポから……濃くて\n、むせるようなニオイがしてる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0103126" ]},
		{"command":[ "SETIMAGE", "0", "still_00001801_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「女を……私を発情させる、エッチなニオイ……ああっ……もっと、もっと感\nじたい……！　君のおチンポ……すごく素敵だよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「たくましくて、男らしいよ……おっぱいでシコシコしてるだけなのに……お\nマンコが疼いてくる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0103128" ]},
		{"command":[ "SETIMAGE", "0", "still_00001801_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「あっ、んぅ……！　くっ、んひぃ……！　ダメっ……私、すごく発情してる\nっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「おマンコが切なくて、苦しいのに……！　おっぱいでシゴいてるだけなんて\n……こんなの、不幸せすぎるよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「ああっ……！　あっ、ふあああぁ……！　不幸せだって思うほど……気持ち\nよくなってくるっ……！　もっと、もっと頂戴……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「私のおマンコ……切なくして……！　いっぱい、不幸を感じさせてっ……！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「フフフ……！　私がこんなに不幸せなのに……君はおチンポをビクビクさせ\nて、幸せそうな顔をしてるね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「イキそうなんだね……！　いいよ……イカせてあげる……！　私のおっぱい\nを、ザーメンで汚して……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0103134" ]},
		{"command":[ "SETIMAGE", "0", "still_00001801_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「ほら……イッていいよ……！　たくさん出していいから……！　出せるもの\nなら、ね……！　フフ、フフフフフ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0103135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「はあぁん、あっ、ひぎゅっ、んんんっ……！　熱いザーメンが、出てっ……\n！　はあぁ、ああぁん……！　私の肌、本当に焼けちゃうぅ……！」", "NORMAL" ]},
