		{"command":[ "SETIMAGE", "0", "still_00001801_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「魔術や魔導具の材料として、男性の精液は必要不可欠だから……君から提供\nしてくれるのは、すごく嬉しいよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「それに……君の精液を浴びれば、私の魔力も高まるし……君は私のおっぱい\nを堪能できる……お互い、いいことだらけでしょ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0103111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「んんっ……はぁ、あふっ……！　軽く挟んでいるだけなのに……もう我慢で\nきないといった感じだね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「もっと焦らして、君を不幸せにしてあげたいけど……それはフェアじゃない\nよね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「それじゃあ、動かすけど……こういうことをするのは……はじめてなんだ…\n…」", "NORMAL" ]},
