		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001801_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「フフフ……！　思ってたよりもザーメンが出ないの……？　そんなの、当た\nり前だよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0103137" ]},
		{"command":[ "SETIMAGE", "0", "still_00001801_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「だって、私が思い切り君のおチンポをおっぱいで挟んで……締め上げてるか\nら……！　フフフフフ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「ザーメンをたくさん出したら……君、すごく幸せを感じちゃうでしょ……？\nそんなの、許さないから……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「私のイキたくてもイケない気持ち……いっぱい感じて……！　私と一緒に…\n…不幸せになって……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「ああっ……んっ、あふっ……フフフ……不完全燃焼って感じだね……おチン\nポ、カタいままだよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0103201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「おっぱいの中でビクビク暴れて……私のこと、孕ませたいって言いたそうに\nしてるね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「あああぁ……！　君の不幸せな感じ……おチンポから伝わってくるっ……！\n　いいよ……すごくいい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0103203" ]},
		{"command":[ "SETIMAGE", "0", "still_00001801_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「もっと不幸になろ……？　一緒に、堕ちるとこまで堕ちよ……？　そうすれ\nば、もっと気持ちよくなれるから……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0103204" ]},
		{"command":[ "SETIMAGE", "0", "still_00001801_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「えっ……あっ、ちょ……！？　な、なんで……おチンポが動いて……！？　\nあっ、あああぁん……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「やっ……！　ま、待って……！　勝手に腰を動かさないで……！　そんなこ\nとされたら、おっぱい感じちゃう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「もしかして、怒ってる……！？　気持ちよく射精させてあげなかったから…\n…おチンポ、イライラしてるの……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「んんっ、あっ、んひいぃ……！　それ、ダメっ……！　ザーメン軽く吹き出\nしながら……シコシコしないでっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「あっ、あっ！　うぐっ、んくうぅ……！　わ、わかった……！　ちゃんとす\nるから……！　今度は気持ちよく射精させてあげるから……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「ふぇ……？　君の動きに合わせて思い切りおっぱいを挟んで、いっぱいシゴ\nけ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0103210" ]},
		{"command":[ "SETIMAGE", "0", "still_00001801_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「そんな……私のこと、道具みたいに扱うなんて……！　ああぁっ！　やっ、\nあっ！　やめっ……！　無理やりされると、感じる……んんんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「わかったよ……！　君の道具になるから……！　おっぱいでおチンポをシゴ\nく、エッチな道具になるから……！　も、もうやめてっ……ああぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「ふきゅ、んっ、ひぎっ……！　傘の部分を刺激しながら……シゴけばいいん\nだね……！　んっ、あんっ……！　はぁ、ううっ、くううぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「やあっ、あっ、んむうぅ……！　なんでっ……道具扱いされてるのに……さ\nっきより感じるっ……！　おマンコ、気持ちよくなってるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0103214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「不幸せな気持ちも、どんどん強くなって……！　ああっ、これ……！　すご\nくいいっ……！　自分でするより、感じるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0103215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「心と身体が……気持ちいいのと、不幸せに包まれて……あっ、あっ！　私…\n…こ、壊れちゃうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0103216" ]},
		{"command":[ "SETIMAGE", "0", "still_00001801_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「アンハッピーすぎて……イッ、イッちゃうっ……！　全身で不幸を感じて…\n…イッ、イクぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
