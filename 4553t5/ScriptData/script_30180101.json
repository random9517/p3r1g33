		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「イッてないで、ちゃんとおチンポシゴけって……！　だ、だって……君、今\nイッてるし……あああっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0103302" ]},
