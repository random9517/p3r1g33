		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「きゃああぁ……！？　む、胸だけじゃなくて……顔にもザーメンがっ……！\n　うぶっ、んむっ……！　はぁ、あああっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0103401" ]},
