{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0128" ]},
		{"command":[ "DISPIMAGE","0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "環" ]},
		{"command":[ "SETTEXT", "「ちょ、ちょっとタイム！　さすがに三人がかりは卑怯じゃない！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_010021090007" ]},
	{"command":[ "SETCHARA", "0", "char_00014001_01", "3", "CENTER", "0" ]},
	{"command":[ "DISPTEXT", "TRUE" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サキ" ]},
		{"command":[ "SETTEXT", "「最初に喧嘩を売ってきたのはそっちよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_010021090022" ]},
	{"command":[ "SETCHARA", "0", "char_00013901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まあまあ……とりあえず、事情を聴こうじゃないか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "環" ]},
		{"command":[ "SETTEXT", "「確かに、ガラス割ったのは悪いなーって思ってるけどさ……復讐のために、\nどうしても力が必要なんだよね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_010021090008" ]},
	{"command":[ "SETCHARA", "0", "char_00014001_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お前も復讐か……一応聞くけど、どんな理由だ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "環" ]},
		{"command":[ "SETTEXT", "「うちのパパ、剣術の師範だったんだけど……道場破りみたいなことにハマっ\nてさ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_010021090009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "環" ]},
		{"command":[ "SETTEXT", "「それから毎日のように、パパは道場破りに行っては負けて、行っては負けて\nを繰り返して……そんで、そのまま……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_010021090010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「えーっと、死んだとかそういう話……じゃないよな？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "環" ]},
		{"command":[ "SETTEXT", "「当たり前じゃん！　パパ生きてるし！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_010021090011" ]},
	{"command":[ "SETCHARA", "0", "char_00014001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「だよな……ちなみに、その道場破りみたいなことってのはなんだ？　道場破\nりじゃないのか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "環" ]},
		{"command":[ "SETTEXT", "「うちバカだからよくわかんないんだけど、なんかめっちゃ綺麗な女の人が居\nる……きゃばくら？　っていう道場に通っててさー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_010021090012" ]},
	{"command":[ "SETCHARA", "0", "char_00014001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "環" ]},
		{"command":[ "SETTEXT", "「パパがそこの師範代みたいな人に勝負を挑んでたんだけど、なんか気づいた\nらすんごい借金してるわけ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_010021090013" ]},
	{"command":[ "SETCHARA", "0", "char_00014001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "環" ]},
		{"command":[ "SETTEXT", "「これは道場破りと称した詐欺かなんかだと思って、師範代の女に一発かまそ\nうと思ったんだけどー、なんかその人、道場辞めたっぽくてさー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_010021090014" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "環" ]},
		{"command":[ "SETTEXT", "「どうしよっかなーって思ってたら、うちの門下生の子から、この学園の秘密\nの力の噂を聞いて、これだ！　って思ったわけ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_010021090015" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「それは詐欺じゃなくて、単に女遊びにハマって、借金しただけじゃねぇか…\n…」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まあいいや……お前の事情はわかった。でも、こっちの二人も理由があって\n力を求めてるみたいでな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "泉" ]},
		{"command":[ "SETTEXT", "「本当にそんな力があるかわかんねぇけど、よかったらお前も一緒に探そうぜ\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_010021090037" ]},
	{"command":[ "SETCHARA", "0", "char_00013801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "環" ]},
		{"command":[ "SETTEXT", "「マジでー！　ちょー助かるー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_010021090016" ]},
	{"command":[ "SETCHARA", "0", "char_00014001_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「とはいえ、相変わらず手がかりすら掴めてないけどな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "環" ]},
		{"command":[ "SETTEXT", "「うちも噂を聞いて来ただけだから、よくわかんないんだよねー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_010021090017" ]},
	{"command":[ "SETCHARA", "0", "char_00014001_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "環" ]},
		{"command":[ "SETTEXT", "「あっ！　そういえば、ここに来る前に、あっちの窓から変な光みたいなのが\n見えたんだけどー……あれなんだったんだろ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_010021090018" ]},
	{"command":[ "SETCHARA", "0", "char_00014001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あっちって……あの校舎には、学園長の部屋があるぐらいだぞ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "泉" ]},
		{"command":[ "SETTEXT", "「他に手がかりもねぇし、とりあえず環の見た光ってのを見にいかねぇか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_010021090038" ]},
	{"command":[ "SETCHARA", "0", "char_00013801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サキ" ]},
		{"command":[ "SETTEXT", "「闇雲に探してもしょうがないし、そうしましょうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_010021090023" ]},
	{"command":[ "SETCHARA", "0", "char_00013901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "環" ]},
		{"command":[ "SETTEXT", "「よーし！　いっくぞー！　あっ、うち道わかんないから、案内よろしく！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_010021090019" ]},
	{"command":[ "SETCHARA", "0", "char_00014001_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「っていうか、なんでお前らは喧嘩した後なのに、そんなに元気なんだ……？\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0128" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "DISPIMAGE","0", "true" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ここが学園長の部屋だ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サキ" ]},
		{"command":[ "SETTEXT", "「部屋の中から、かすかに声が聞こえるわ。誰か居るのかしら？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_010021090024" ]},
	{"command":[ "SETCHARA", "0", "char_00013901_01", "0", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "環" ]},
		{"command":[ "SETTEXT", "「もしかして、ここに秘密の力があったりしちゃう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_010021090020" ]},
	{"command":[ "SETCHARA", "0", "char_00014001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "泉" ]},
		{"command":[ "SETTEXT", "「そんなの、入ってみればわかるだろ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_010021090039" ]},
	{"command":[ "SETCHARA", "0", "char_00013801_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0129" ]},
		{"command":[ "DISPIMAGE","0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "DISPIMAGE","0", "true" ]},
		{"command":[ "SETTEXT", "俺たちが学園長の部屋の扉を開けると、そこには怪しげな魔術を使っている、\n学園長……風祭マユミの姿があった。", "NORMAL" ]},
	{"command":[ "SETCHARA", "0", "char_00015902_01", "0", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「なっ！？　あ、あなたたち、どうしてここに！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_020021090006" ]},
	{"command":[ "SETCHARA", "0", "char_00015902_01", "3", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「これには少しばかりワケがありまして……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "環" ]},
		{"command":[ "SETTEXT", "「この光、さっきうちが見た奴だし！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_010021090021" ]},
	{"command":[ "SETCHARA", "0", "char_00014001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サキ" ]},
		{"command":[ "SETTEXT", "「……ということは、この部屋に力があるということかしら？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_010021090025" ]},
	{"command":[ "SETCHARA", "0", "char_00013901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "泉" ]},
		{"command":[ "SETTEXT", "「それは学園長に聞けばわかるだろ。えーっと、学園長。秘密の力って知って\nるか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_010021090040" ]},
	{"command":[ "SETCHARA", "0", "char_00013801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「あなたたち、何処でその話を聞いたの！？　まさか、私が力を使って世界征\n服をしようとしているのがバレてしまったの……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_020021090007" ]},
	{"command":[ "SETCHARA", "0", "char_00015902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「素直すぎる反応だな……こっちとしては、事情を話してくれた方がありがた\nいんだけどさ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「私の目的を知られた以上、生きて返すわけにはいかないわね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_020021090008" ]},
	{"command":[ "SETCHARA", "0", "char_00015902_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、お前が勝手に喋ったんだろ……まあいいや。とにかく、戦うしかない\nみたいだな！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
	{"command":[ "EXIT" ]}
	]
}