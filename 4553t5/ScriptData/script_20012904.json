{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0045" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "……そして、翌日。", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "稲穂姫の社にやってきた俺は、集めたそうそうたるメンバーを前に大満足の表\n情になった。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「牛神様、イグニス。そしてほむら……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00003002_01", "6", "CENTER", "600" ]},
		{"command":[ "SETCHARA", "1", "char_00016701_01", "6", "CENTER", "-600" ]},
		{"command":[ "SETCHARA", "2", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "DISPCHARA", "2", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「約束通り、社に来てくれてありがとう。そして……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「は、はい……。いいんですよね？　私も……ここに来て……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020022170001" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "DISPCHARA", "2", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああ！　もちろんだ！　夜日楽……！　これだけのメンツがそろえば、寂れ\nた社に必ず活気を取り戻すことが出来るだろう！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「……おなごばかりたくさん集めて、一体何をするつもりじゃ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_010022170001" ]},
		{"command":[ "SETCHARA", "0", "char_00024101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ふっふっふっ……。そのおなごってのに、アンタも入っているんだぜ？　\n稲穂姫」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_010022170002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「かなり自信のある案が出来たようですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_020022170001" ]},
		{"command":[ "SETCHARA", "0", "char_00003002_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「カツマさん。あなたが思いついた名案について説明願えますか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_020022170002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "困惑している皆に、俺は待ってましたとばかりにアイディアを伝えることにし\nた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「エロい巫女だ」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「え……えろい巫女……とは？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_020022170003" ]},
		{"command":[ "SETCHARA", "0", "char_00003002_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「どれだけ社がショボ……、い、いや、寂れていようとエロい巫女とタダ酒が\n出れば人は来る！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「とにかく人を集めたいってんなら、人が来たくなるような魅力的なモノを準\n備すればいいって話だと思うんだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「エロい巫女とタダ酒とな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_010022170003" ]},
		{"command":[ "SETCHARA", "0", "char_00024101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「酒についてはウチが提供させてもらうぜ。そのへんは、もうコイツと話はつ\nいてんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020022170001" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「そこまでお話は進んでいたんですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020022170002" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「それで、私達は何をすれば……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_020022170004" ]},
		{"command":[ "SETCHARA", "0", "char_00003002_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「牛神様には、神通力で……巫女の衣装をお願いします。そうですね、衣装は\nこんな感じで……ひそひそひそ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「なるほど。承知しました。では、早速……。えーい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_020022170005" ]},
		{"command":[ "SETCHARA", "0", "char_00003002_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0045" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "ぼわん、ぼわわん！", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "牛神様が力を使うと、またたくまにイグニス達の衣装が変わっていく。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「わ……。これが、こちらの世界の巫女の衣装なのか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010022170001" ]},
		{"command":[ "SETCHARA", "0", "char_00016702_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「とってもお似合いですよ。やはり、凛々しい女性に巫女服は鉄板の美しさで\nすね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_020022170006" ]},
		{"command":[ "SETCHARA", "0", "char_00003003_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「……綺麗……そ、そうか。力を使っていただき、ありがとうございます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010022170002" ]},
		{"command":[ "SETCHARA", "0", "char_00016702_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「いえいえ。お礼を言うならカツマさんにですよ。これは彼のアイデアなんで\nすから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_020022170007" ]},
		{"command":[ "SETCHARA", "0", "char_00003003_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「そ……そうだったな。……ありがとう、カツマ殿」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010022170003" ]},
		{"command":[ "SETCHARA", "0", "char_00016702_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「こんな機会でもなければ、私はきっと永遠に巫女服なんて着られなかったか\nら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010022170004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うんうんうん、気にするな。すごく似合ってるぞ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「に、似合って……。そ……そうか。嬉しいものだな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010022170005" ]},
		{"command":[ "SETCHARA", "0", "char_00016702_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「やっぱりお正月は巫女服ですよねぇ～……って、わ、わ、わ、私の服は巫女\nじゃないですよねぇ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010022170001" ]},
		{"command":[ "SETCHARA", "0", "char_00001704_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「素晴らしいノリツッコミですな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022170001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「ど、ど、どうして私だけこんな格好なんですか？　恥ずかしいです、それに\n寒いです～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010022170002" ]},
		{"command":[ "SETCHARA", "0", "char_00001704_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「なんで一人だけ虎縞パンツにぃ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010022170003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「寅年で、鬼族といえばこの服装にきまっているんだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「ええええっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010022170004" ]},
		{"command":[ "SETCHARA", "0", "char_00001704_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「巫女だけじゃ、どうにもパンチが足りないなと思ってさ。そこに鬼娘がいた\nら最高の正月だと閃いたんだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「確かに、お正月らしいといえばお正月らしい気もします……けど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010022170005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「鬼らしい鬼がいいのなら……。お姉ちゃんのほうが適任じゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010022170006" ]},
		{"command":[ "SETCHARA", "0", "char_00001704_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "もじもじして落ち着かない様子の夜叉を後押ししたのは、なんと、俺ではなく\n他の女達だった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「でも、とっても可愛いですよ？　やっぱり鬼っ娘といえば、虎縞ビキニです\nよね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_020022170008" ]},
		{"command":[ "SETCHARA", "0", "char_00003003_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「かわっ……。か、可愛いだなんて……そんな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010022170007" ]},
		{"command":[ "SETCHARA", "0", "char_00001704_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「夜叉は鬼族なのか？　ならばその衣装はバッチリだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010022170006" ]},
		{"command":[ "SETCHARA", "0", "char_00016702_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「ばっちり……でしょうか？　鬼らしいと言われると……。そ、そうかもしれ\nませんね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010022170008" ]},
		{"command":[ "SETCHARA", "0", "char_00001704_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「だいぶ、満更でもない感じだな。じゃあ、夜叉はそれに決定で」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「……わ……わかりました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010022170009" ]},
		{"command":[ "SETCHARA", "0", "char_00001704_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "鬼族として、という部分がとくに夜叉に刺さったようだ。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「よしよし。うまくいったみたいだな。えーと、それでこれから……」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「……良いのう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_010022170004" ]},
		{"command":[ "SETCHARA", "0", "char_00024101_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「んっ？　どうした、稲穂姫」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「装いが変わるだけで、こんなにも美しくなれるとは……！　妾もその巫\n女とやらになってみたい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_010022170005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「巫女は数が多い方が良いじゃろう？　のう……妾も巫女にしておくれ！\n　おぬしの策に混ぜておくれぇ～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_010022170006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あらあらあら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_020022170009" ]},
		{"command":[ "SETCHARA", "0", "char_00003003_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「それは当然俺も考えた。でも……獣人ってのは、普通の人達にとっちゃ珍し\nすぎるかなと思ってさ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「稲穂姫は裏で見ててもらおうと思ったんだが……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「そんな……なんとかならぬのか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_010022170007" ]},
		{"command":[ "SETCHARA", "0", "char_00024101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うーん……。そもそも神様を人前に出すってのもどうかなって……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「……そうじゃ！　これならどうじゃ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_010022170008" ]},
		{"command":[ "SETCHARA", "0", "char_00024101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "得意げな顔をして、稲穂姫がくるりとその場で回ってみせる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0045" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "すると……ポン！　と可愛い音がして、稲穂姫の姿がまるで人間のように変身\nした！", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00024102_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「す、すげえ！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「であろうであろう！？　これならば、妾も巫女としておぬしの案に参加\n出来るはずじゃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_010022170009" ]},
		{"command":[ "SETCHARA", "0", "char_00024102_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……しっぽは隠せてないが、コスプレってことにすればなんとかいけそうか\n……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「よし、じゃあこれでいこう！　作戦開始だ！　みんな、俺のスマホの前に集\nまってくれ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「すまほ……？　ああ、この板か。これの前に立てば良いのじゃな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_010022170010" ]},
