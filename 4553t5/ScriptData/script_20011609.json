{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0081" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「傷、あんまり深くなくてよかったね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010021530054" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00009602_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「傷跡も残らないみたいだし、一安心だよ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_010021530041" ]},
		{"command":[ "SETCHARA", "0", "char_00009902_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「ふふっ。水着のおかげでいつも以上に身体が軽く、動きやすかったおかげか\nも知れないな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010021530054" ]},
		{"command":[ "SETCHARA", "0", "char_00010002_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「それ、やっぱり水着だったんだね。カンゲイコ（寒稽古）のブトウ衣装とか\n言ってたのに」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021530035" ]},
		{"command":[ "SETCHARA", "0", "char_00009802_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「やっぱ先生も、このリゾートで遊びたかったのか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_010021530041" ]},
		{"command":[ "SETCHARA", "0", "char_00009702_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「んんっ！　そ、そんなことはないぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010021530055" ]},
		{"command":[ "SETCHARA", "0", "char_00010002_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「えぇ～、ほんとに～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_010021530042" ]},
		{"command":[ "SETCHARA", "0", "char_00009902_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「私の恰好よりも、まずは現状の把握だ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010021530056" ]},
		{"command":[ "SETCHARA", "0", "char_00010002_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「とりあえず、襲来者（インベーダー）のアジトの位置はつかめたね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021530036" ]},
		{"command":[ "SETCHARA", "0", "char_00009802_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「っても、今のオレたちじゃあ、アイツらには歯がたたねぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_010021530042" ]},
		{"command":[ "SETCHARA", "0", "char_00009702_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「だったら、あの人らをヘルプに呼ぶしかなくな～い？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_010021530043" ]},
		{"command":[ "SETCHARA", "0", "char_00009902_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「そうだね！　先生、あの人たちに助けを求めても良いですか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010021530055" ]},
		{"command":[ "SETCHARA", "0", "char_00009602_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「あの人……？　ああ、独立超常部隊（インクレディブル・スクワッド）のこ\nとか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010021530057" ]},
		{"command":[ "SETCHARA", "0", "char_00010002_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「目的の達成の為に有効な手段は活用すべきである。早速ヤツらと連絡を取る\nとしよう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010021530058" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「とはいえ、ここは南の地……あの街から助けに来てもらうにしても、時間が\nかかってしまうな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010021530059" ]},
		{"command":[ "SETCHARA", "0", "char_00010002_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「それに先生の傷も治ってないし、あんまり無茶なことはできないかな～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_010021530044" ]},
		{"command":[ "SETCHARA", "0", "char_00009902_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「そうだね……うーん。攻めるにしても、ちょっと間が空いちゃうね。どうし\nようか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010021530056" ]},
		{"command":[ "SETCHARA", "0", "char_00009602_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「どうするもなにも、まずは隊長に連絡するところからじゃない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021530037" ]},
		{"command":[ "SETCHARA", "0", "char_00009802_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「そうだな。それじゃ、早速連絡するとするか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_010021530043" ]},
		{"command":[ "SETCHARA", "0", "char_00009702_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「オーケー！　えっと、隊長さんの連絡先は……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010021530057" ]},
		{"command":[ "SETCHARA", "0", "char_00009602_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そこに居るのはホクサイたちじゃねぇか。どうしたんだ、こんなところで」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「ワァッツ！？　どうして隊長さんがここに居るの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010021530058" ]},
		{"command":[ "SETCHARA", "0", "char_00009602_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}