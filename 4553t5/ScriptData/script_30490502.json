		{"command":[ "SETIMAGE", "0", "still_00004905_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「もう膣内が満ち満ちて……、ぁっ……！　溢れた分が逆流してきているから\n……もう、十分だ……っ♪　っくぅ……っ♪　くふぅうう……っ」　", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0504307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「はぁ……♪　はぁ、はぁ、ふぅぅうう……。腹の中が熱いままで……こんな\n幸福感の中、リモート会議を続けるなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0504308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ちょ……長官というものは、どこまでイッても仕事からは逃れられないのだ\nな……♪　はぁっ……♪　受精の瞬間まで働きづめだ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0504309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「だが……そんな私を、私はどうしても嫌いになれない……。ふふふ、これか\nらも君と、仕事と……両方充実させてもらうぞ……♪」", "NORMAL" ]},
