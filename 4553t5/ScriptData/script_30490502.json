		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「は、ぁ……っ♪　あっ……あぁ……あ……。……あッ♪　き……君も随分私\nのオマンコを楽しみにしてくれているようじゃないか……っ？」", "NORMAL" ]},
