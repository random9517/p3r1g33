		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「あっ……♪　こ、こういう風に……たっぷりオマンコを濡らすんだ。性感を\n高めて、高めて、一番昂ったところでご馳走になるとしよう……っ」", "NORMAL" ]},
