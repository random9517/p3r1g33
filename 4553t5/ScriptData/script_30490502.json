		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「私の尻の上で……どんどんペニスが凝り固まって……。あっ……♪　これは\nいけないな……♪　これ以上硬く、太くされると……困る……。あっ」", "NORMAL" ]},
