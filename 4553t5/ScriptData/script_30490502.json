		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「もう何度も身体を重ねているの、だから……。はぁっ、マ、マンネリ防止に\nも……なるだろう……。んっ……ンッ……♪　んっ……んん……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0504111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「……ん？　挿入せずに、尻でペニスをしごいているのが不満、か……？　焦\nらしているわけじゃない……。少し、こちらの準備をしているん、だよ」", "NORMAL" ]},
