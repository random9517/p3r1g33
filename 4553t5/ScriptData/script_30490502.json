		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「んぐぅうううっ……！？　んんんぅ……！　んぐぅううううう～～～～っ！\n　だ……駄目だ、いくら我慢しても声が漏れ……、あぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0504302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「あっ……あっ、い……いや……！　あっ♪　だ、だいじょうぶ、だ……！　\nあっ！　し、しんぱい、しんぱいひゅるな……あっ、うぁあっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0504303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「い、椅子っ……椅子に足をぶつけた、だけ……だ……！　ッふ……！　と、\n特に……オマンコにザーメンがドクドク入ってなど……。ぅあああ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0504304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「なっ……なんでもない！　そ、そちらの案をもっと聞きたくて出せ、と……\nさっきの話を了承するつもりでイキで、と、いっ……言っただけだ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0504305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「そう……そうだ、そのまま続けてくれ……っ。え？　か、会議をに決まって\nいるだろうっ♪　射精、射精はもう十分……っ♪」", "NORMAL" ]},
