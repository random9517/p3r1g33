		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「さ、もうそろそろいいだろう……。もう、中がぐちょぐちょで……これ以上\n蜜を溜めたら溢れ出してしまう。……ん？　ほら、早く挿入してくれ……」", "NORMAL" ]},
