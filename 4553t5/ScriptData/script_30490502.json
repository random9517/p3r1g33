		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ち……違うからな。決して私は生ハメ交尾で、尻にザーメンをぶっかけられ\nたりしていない……♪　仕事中だぞ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0504408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、はぁ……♪　大変気持ち良くて有意義な会議、だったので……\n今日はこれで終了とするぅ……♪　出席ありがとう……」", "NORMAL" ]},
