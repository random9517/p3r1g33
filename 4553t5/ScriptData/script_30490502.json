		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「く……ぅ、うぅう……っ♪　んふ……っ。ん……んっ、た……隊長……あま\nり激しくすると、水音が……あぁ……！　卑猥な音が引いて……あぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0504211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「くぅうう……！　あっ！？　あっ……ぁっ……！　はぁっ……ぁっ、あぁ…\n…！　耐えれば耐えるほど、感度が増して……全身が甘く痺れる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0504212" ]},
		{"command":[ "SETIMAGE", "0", "still_00004905_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「私は……私は長官……長官なのに……。あふっ……！　こ、これ以上はまず\nい……！　声が抑えきれない……あっ！　あっ、いやっ……あぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0504213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「私の感じるところばかり太いチンポでえぐり倒すとは……！　あぁああっ…\n…君は、君は性に関しては本当に天才だな……！　あっぁっあぁんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0504214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「んぁああ……！　だ、大丈夫だ……聞こえている。電波が……あふっ！　で\n、電波の調子が悪くてオマンコが疼くだけだ……あぁあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0504215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「そ……すおだな、その案は……その案はイキで……。あああっ！　な、なん\nでも……ない、そのまま……オチンポそのままぁっ、イッ……イッくぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0504216" ]},
		{"command":[ "SETIMAGE", "0", "still_00004905_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「んんっ、ち、違うんだ、その案でイッ……てくれと……あっぁっあっ。そ、\nそう、だ……そうだ、思いっきりイッ、てくれ……イキまくってくれ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0504217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「中にぃ……この長官のトロトロマンコに最高の案を出してくれっ、ザーメン\n……ザーメンを許可するぅ……！　承認、承認する……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0504218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「平気……平気だ、今画像が乱れたのは……地震で机がガタガタ揺れたからだ\n……！　あっ、やめるな……止めるな、このまま……このままっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0504219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「イッて……イッてくれ！　絶対に出せ、オマンコの一番奥に注げ……ふぁあ\nああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0504220" ]},
