		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ち、ちが……う、違う、これ、は……！　あっ……！　す、すまない……脚\nが痺れて……！　少し待ってくれ……あぁっ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0504403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「あ、ああ……。私は大丈夫、だ……。あっ……♪　尻がザーメンでドロドロ\nになんてなっていな……。あっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0504404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ば、馬鹿者が！　私がリモートワーク中にザーメンなどという卑猥な単語を\n口にするわけがないだろうっ……お……おかしなことを言うんじゃない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0504405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ラーメンっ……ラーメンだ、この会議が終わったらラーメンを食べに行こう\nと思っていただけで……！　あっ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0504406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「あ、足と腰にも垂れてきたぁあ……♪　はぁああ……♪　あつぅい……♪　\n……」", "NORMAL" ]},
