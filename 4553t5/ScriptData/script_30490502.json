		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「あっ♪　きたっ……きたきたぁ……ッ♪　い、一番奥、に……あぁああああ\nっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0504301" ]},
