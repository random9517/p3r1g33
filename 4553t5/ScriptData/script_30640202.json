{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「せっかくのビーチなのに、天気が悪いなんてついていませんねー。こうして\n水着まで用意したっていうのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0204101" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00006402_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「ん？　どうして水着のままここにいるか、ですか？　そんなの、隊長とエッ\nチするために決まってるじゃないですかー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0204102" ]},
		{"command":[ "SETCHARA", "0", "char_00006402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「本当は青空の下、開放的なエッチをしたかったのですが、仕方ありません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0204103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「それに、隊長のおちんぽはもう準備できているみたい……。んふふ、この水\n着で興奮してくれたんですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0204104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「私も……もう、隊長とする準備できてますよ……。この部屋に入る前から、\nビキニの下を濡らしちゃってます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0204105" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00006402_02_02" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「あんっ、このまま、エッチしちゃいましょう……っ！　んっ、ん……ぅ……\nああ……っ！　隊長の硬いの……ぉ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0204106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「水着をずらして、アンッ！　すごい、熱いの当たって……ワレメに……入っ\nてくる……っ！　ん～～～～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0204107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「ああっ、ああ～～っ！　入っちゃいました……！　隊長の、ぶっといおちん\nぽが、ンッ！　おまんこ……いっぱい、いっぱいにぃ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0204108" ]},
		{"command":[ "SETIMAGE", "0", "still_00006402_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……。隊長……。んぁっ！？　ちょっと隊長！？　このまま、\nわ、私のこと……どうするつもりで……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0204109" ]},
		{"command":[ "SETIMAGE", "0", "still_00006402_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「た、立ったまま、抱えて……！？　んんぅっ！　ちょ、ちょっと待ってくだ\nさい隊長！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0204110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「こ、これ……っ！　お、おお……おちんぽが……！　すっごく、ふ、深いと\nころまで、刺さっちゃってます……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0204111" ]},
		{"command":[ "SETIMAGE", "0", "still_00006402_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「お、落ちちゃわないように、隊長にしっかりつかまって……っ！　んんっ！\n　すっごく……隊長を近くに感じるぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0204112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁっ、はぁ……っ！　ンンッ！！　そんな、このままゆさゆさっ\nて……ああっ、ああ……ああ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0204113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「いっちばん、深いところに刺さってる、おちんぽ……ぉ……おお……っ！　\nひゃふぅっ！？　ああっ、ああ……んひゅぅ～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0204114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「おっ、おっ、おちんぽ……ぉ……っ！　だめ、だめです……！　奥をぐりぐ\nりぃ……って、何度も、何度もぉ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0204115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「んぉっ、おおっ！　深いところばかり責められたら、意識が……頭が、真っ\n白になっちゃいそう……です……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0204116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「んぁっ！　ああっ、んっ、んっ、んくぅ……んふぅ……っ！　ひゃはっ！？\n　んっ、んふぅ……あっ、ああ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0204117" ]},
		{"command":[ "SETIMAGE", "0", "still_00006402_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「抱きついてる私を、おお、オナホールみたいに上下させて……！　んひいっ\n！　おちんぽ、出し入れ……んっ、んん……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0204118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「どんどん、おまんこがぬるぬるに、濡れちゃってます……ああっ、いやらし\nいまんこ汁……だらだら垂れちゃってますー……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0204119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「ひゃああっ、だって、隊長のおちんぽが気持ちいいからー……っ！　あっ、\nあっ、んっ、んっ、んふぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0204120" ]},
		{"command":[ "SETIMAGE", "0", "still_00006402_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「私のおまんこだって、隊長のおちんぽ、いっぱい気持ちよくしてあげたいん\nですー……っ！　んひぃっ、んっ、んん～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0204121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「どうですか、隊長？　１／１、褐色ビキニ、エロエロ隊員まんこオナホの具\n合は？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0204122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「勃起ちんぽに熱心に絡みついて、うねうねって蠢いて、天然ローションもた\nっぷりなんですよー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0204123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「んぁあっ！　すごい、隊長のおちんぽ、出たり、入ったり……ぃ……っ！　\nんっ、んっ、あひぃっ！　はあっ、はぁ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0204124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「たっくさん、ずぼずぼって、私のスケベまんこかき回しちゃってますーっ！\n　あっ、いいですっ、いい……気持ちいい……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0204125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「ああっ、隊長のぶっといので、おまんこが隊長の形にされちゃっていくの…\n…っ！　隊長のおちんぽ専用になっちゃいますーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0204126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「ああっ、隊長としてると、どんどん身体が熱くなって……。汗も、いっぱい\nかいちゃう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0204127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「んんっ、隊長、そんな……匂いかぐみたいに、鼻を近づけないでくださいよ\n……っ！　んっ、んん……ひゃふっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0204128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「ああんっ、私のスケベなところ、全部味わうつもりですね。ぜーんぶ堪能し\nちゃうつもりなんですね！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0204129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「そんなの、もちろんいいにきまってます。私は、隊長のものなんですから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0204130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「んんっ、だから、好きなだけ……アンッ！　このいやらしいおまんこを、ぐ\nっちょぐちょにして、ください……ね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0204131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「ああっ、ンッ！　ひゃあっ！　またぁっ！　激しくおちんぽが動いて、ンン\nッ！　おまんこのなか……ああっ、ああ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0204132" ]},
		{"command":[ "SETIMAGE", "0", "still_00006402_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「じゅぼじゅぼってまん汁かきだしながら、おまんこの中、浅いところから深\nいところまで一気にこすりあげてくるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0204133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「んひぃっ！　ひぃいっ！　パンパンに膨れ上がってる先っぽが、一番奥に何\n度も当たってますーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0204134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「どっちゅんどっちゅんきてるーっ！　こんなの繰り返されたら、私……すぐ\nにイかされちゃいますー……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0204135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「た、隊長も……っ！　あっ、ああ……だしちゃって……っ！　私の、おまん\nこに、精液びゅーってしてーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0204136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「んぁあああっ！　ああっ、あああぁぁぁ～～～っ！　きたきたっ、きた……\nきてる……きちゃってるぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0204137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00006402_02_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「すっごく熱い、隊長の精液ぃ……。はぁ……はぁ……一番奥に、ねばっこい\nのがいっぱい、撃ちこまれちゃってます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0204138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……すごい……。水着のせいか……燃え上がっちゃいましたね\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0204139" ]},
		{"command":[ "SETIMAGE", "0", "still_00006402_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「二人っきりでよかったですよ。こんな姿、ビーチではさらせませんからねー\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0204140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「んふふ。じゃあ、もっとしましょうかー。隊長……。おまんこの中で、まだ\nまだ硬いままですからねー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0204201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「んんっ！　また、また……ああ……っ！　私のことを上下させながら、おち\nんぽ、ずんずんってしてー……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0204202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「ひゃはんっ！　さっき中出しした精液が、かきだされちゃいます……っ！　\nせ、せっかく中出ししてもらえたのに……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0204203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「はい、もちろんおまんこ締めますよ。んふぅっ！　隊長の精液、こぼしたく\nありませんからねー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0204204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「んぁっ、ああっ、んくぅっ！　隊長のおちんぽ、ますます感じるぅ……っ！\n　んひぃっ、あっ、ああ……んんぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0204205" ]},
		{"command":[ "SETIMAGE", "0", "still_00006402_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「中で、おちんぽがビクビクして……んんぅっ！　隊長、ああっ、私のおまん\nこで……また、気持ちよくなってくださいねー……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0204206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「んっ、んんつ！　あんっ、あんっ、あんっ！　んふぅっ！　じゅぼじゅぼ、\nまた……ああっ、そこぉ……いいぃ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0204207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「ひゃはっ、んっ、んっ、んんっ！　私のおまんこ、隊長にいっぱい串刺しに\nされて、すごく……悦んじゃってます……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0204208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「はぁっ、ああっ、ああっ、だめ……っ！　力が、抜けちゃいそうなくらい気\n持ちいい……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0204209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「んんっ、んくぅ……っ！　しっかり、隊長にしがみつかないと……っ！　は\nぁ、はぁ……ああっ、ああ……んっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0204210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、んひ……っ！　おちんぽ、おちんぽ……ぉ……おお……っ！　\nじゅぼじゅぼってぇ……っ！　あっ、ああ～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0204211" ]},
		{"command":[ "SETIMAGE", "0", "still_00006402_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「さっきより……ますます硬くなって……っ！　んぁあっ！　おまんこかきわ\nけて、ごりごり抉ってきてますー……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0204212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「んひぃいっ！　た、隊長、隊長……っ！　いいっ、いいですっ！　おちんぽ\n、すっごく気持ちいい……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0204213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「おちんぽで一番奥を突かれると、気持ちいいのが、頭の天辺にまで響くみた\nいで……っ！　ああっ、本当に……気持ちいい……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0204214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「んひっ、んひぃっ！　おちんぽ、ビクビク……っ！　暴れてますっ、おまん\nこの、な、中で……ああっ、ああ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0204215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「ぐちょ濡れまんこ、いっぱい、感じて……気持ちよくなってくれているみた\nいで……嬉しい……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0204216" ]},
		{"command":[ "SETIMAGE", "0", "still_00006402_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「このまま、隊長……？　射精、しちゃってください。ンッ、はぁ……。隊長\nの精液、また、私にだしてください……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0204217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「隊長のすごいおちんぽから放たれる精液、もっと、もっと味わいたいんです\n……食らいたいんです……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0204218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「隊長のでイきたい……。隊長の精液で、隊長と一緒にアクメしたいんです…\n…っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0204219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「だから、きてっ、きてっ！　びゅっびゅしてっ！　また、たっくさん、隊長\nの精液を私にだしてぇえええぇぇぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0204220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「ああっ、あああぁぁぁ～～～～っ！！　精液ぃっ！　おちんぽ脈打たせなが\nら勢いよくでてきてるうう～～～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0204301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00006402_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「びゅっくんびゅっくんって、ああっ、ああっ、入ってきてます！　私の子宮\nの中に、隊長の精液届いてる……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0204302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「ああっ、隊長っ、隊長っ！　もっとおちんぽ、ぐりぐり奥に押しつけて……\nっ！　んっ、んん……んぁあああ～～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0204303" ]},
		{"command":[ "SETIMAGE", "0", "still_00006402_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「子宮口に、隊長の精液をぬりたくって……っ！　んっ、んっ、んんぅううっ\n！　おまんこ、みんな隊長のものにして……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0204304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、ああ……っ！　おまんこが勝手に動いちゃってます……おちん\nぽから、精液、ぜーんぶ絞ろうってしてますよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0204305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「んふー……っ。隊長……すっごいいっぱい射精しましたね……。ビキニの私\n、そんなに興奮しちゃいました？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0204306" ]},
		{"command":[ "SETIMAGE", "0", "still_00006402_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「精液も濃くて、重たーい……。お腹がいっぱいになっちゃってるみたいです\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0204307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「……え？　いつまでしがみついてるつもりかって？　いいじゃないですかー\n。もうちょっと、このままでいさせてくださいよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0204308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「こうやっていないと、隊長の精液が垂れてきちゃいそうなんですから。栓を\nしておかないと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0204309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「それに、隊長のおちんぽは、私のお気に入りなんですから。……ずっとおま\nんこにしまっておきたいです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0204310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「んひぃいっ！　いきなり、おちんぽ引っこ抜かないでくださいーっ！　あっ\n、ああっ、そんな……いっぱい……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0204401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00006402_02_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「すごい勢いで、精液、びゅーっ、びゅーってでちゃってるじゃないですかー\nっ！　んっ、ああっ、あうぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0204402" ]},
		{"command":[ "SETIMAGE", "0", "still_00006402_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「火傷しそうなほどに熱い精液が……。ああ、おまんこじゃなくて、あちこち\nにぃ……。もったいないぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0204403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「でも……こんなにぬるぬる……ねっとり……。はぁ、はぁ……隊長の匂いに\n包まれるのも……ヤじゃないです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0204404" ]},
		{"command":[ "SETIMAGE", "0", "still_00006402_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「んぅ……隊長……もっと、抱きついちゃいます……。この匂いを、もっとも\nっと堪能したいぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0204405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……。まだまだ隊長のおちんぽ、射精してますね……。びゅくび\nゅくって、とまらなくなってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0204406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「ああ、それを全部……私が受け止めます……。ああ、すごくやーらしい匂い\n……。これ……おかしくなっちゃいますよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0204407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「んんっ、ほらぁ……。こんなにぷるっぷるですよー……。肌にくっついて、\n全然垂れそうにありません……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0204408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「んふふ、隊長、もちろんこれくらいじゃ終わりませんよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0204409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「二人っきりの時間はまだまだ長いんですから。もっと、しーましょっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0204410" ]},
		{"command":[ "WAITINPUT" ]},
