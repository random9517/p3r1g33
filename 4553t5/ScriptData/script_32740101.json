{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0046" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「あら……？　こんな森の奥で何をしているのですか？……伝説の花の蜜を探 \nしている？　それなら、ちょうど良かった。どうぞこちらに来てください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0103101" ]},
		{"command":[ "SETCHARA", "0", "char_00027401_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「ふふふふ……♪　蜜はこっちにありますよ。ただし、見つけるには条件があ \nるんです。１つ、服を脱ぐこと。次に、この場所で横になること。そして」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0103102" ]},
		{"command":[ "SETCHARA", "0", "char_00027401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「目を閉じて、私のすることにその身を任せてくれますか？　……ああそう、 \nそうです。そのままじっとして……。いきますよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0103103" ]},
		{"command":[ "SETCHARA", "0", "char_00027401_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「んっ♪　もう目を開けてもいいですよ。あは……♪　驚かれましたか？　突 \n然私がおっぱいを露わにして、貴方の口にあてがったこと……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0103104" ]},
		{"command":[ "SETIMAGE", "0", "still_00027401_01_01" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「でも、これが正しい蜜の採取の方法なんですよ。そう、伝説の花の蜜は…… \n実は私のおっぱいから出るんです。ふふふ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0103105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「どうぞ、乳首を吸ってみてください。……んッ……。ぁ、そ、そうです、も \nっと強く吸ってください……。ん、ん……んんっ、んぅ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0103106" ]},
		{"command":[ "SETIMAGE", "0", "still_00027401_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「舌で乳首を舐めて刺激して……。あっ……♪　んんんぅっ、ど、どうですか \n？　甘く濃厚な母乳が口の中に流れこんできているでしょう……っ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0103107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「そうです、それが……は、ぁっ♪　伝説の花の蜜……。とっても美味しいで \nしょう？　滋養強壮にとても良く効く、栄養満点の蜜なんですよ……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0103108" ]},
		{"command":[ "SETIMAGE", "0", "still_00027401_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「んっ……んっ、は、はい……。いくらでも飲んでいただいて結構です。です \nが……♪　そんなに懸命に蜜をすすっていただけているのですから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「蜜の力で大きく、逞しく勃起してしまったチンポは私が責任をもってなんと \nかしてさしあげましょう。……ここにも白い蜜が詰まっているんでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「……ほぉら♪　私が手で、その蜜を絞り出してあげます。……ふふふふ♪　 \nどうしたんですか？　戸惑うことなんてないでしょう。等価交換ですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0103111" ]},
		{"command":[ "SETIMAGE", "0", "still_00027401_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「私は母乳を、貴方は精液を互いに分け合う……それだけじゃないですか。は \nい、遠慮しないで楽しんでいってください。はじめますよ……ふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「……あぁ……♪　なんて素敵なチンポなんでしょう。見てください。私が手 \nのひら全部で包みこんでも、まだ余るくらいに太いじゃないですか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0103113" ]},
		{"command":[ "SETIMAGE", "0", "still_00027401_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「それに、すごく熱い……♪　指が火傷してしまいそう。うふふふ、こんな危 \n険な凶器を股間にぶらさげて、いつも生活しているんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0103114" ]},
		{"command":[ "SETIMAGE", "0", "still_00027401_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「大変ですね♪　……え？　今は興奮しているからこうなっているだけ？　そ \nうかもしれませんけど、興奮するたびにこんなに長く大きくなるなんて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0103115" ]},
		{"command":[ "SETIMAGE", "0", "still_00027401_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「凶器以外の何物でもないでしょう。ん……っ、力をこめてシゴかないと、快 \n感がチンポの芯に届きそうもありませんね。私も気合を入れませんと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、シコ、シコ♪　シコ、シコ、シコ……♪　あぁ～、硬いぃ。貴 \n方のチンポ、鉄のように硬くしっかりとそびえ立っていますよ。んんんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「……あんっ！？　うふふっ、私に一方的に攻められるのがお嫌なのですか？ \n　必死に乳首を強く吸ってくるなんて……これは競争ではないんですよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0103118" ]},
		{"command":[ "SETIMAGE", "0", "still_00027401_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「でも……あんっ、やる気を出してくださっているのは嬉しいです。はぁっ、 \nはぁっ、ええ、吸ってください、乳首を甘噛みして、伸ばして……吸って」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「……んんんんっ♪　あらいやだ♪　貴方の吸い方があまりにお上手でしたか \nら……吸われていない方の乳首からも、ドロドロの蜜が溢れてしまいました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0103120" ]},
		{"command":[ "SETIMAGE", "0", "still_00027401_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「あ、はい。もちろんそちらも飲んでくださってかまいませんよ……。でも、 \n……あんっ、ますますチンポが元気になってしまうかも……。んっぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、ですが私も……、っんっ♪　蜜を……母乳を貴方がちゅうちゅ \nうと飲んでいる姿を見ると、身体が熱く燃え上がります。……っんんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0103122" ]},
		{"command":[ "SETIMAGE", "0", "still_00027401_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「新しい蜜が、母乳がどんどんおっぱいに溜まってくるのを感じる……♪　で \nすから、どんどん飲み干していってください。ええ、もっと、もっと吸って」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「そのかわりに私も、情熱的に貴方のチンポをシゴかせていただきますから… \n…。んっ、あぁっ……はぁっ、はぁ、はぁあ……いいですね……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0103124" ]},
		{"command":[ "SETIMAGE", "0", "still_00027401_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「こんなに大きなチンポは見たことがありません。シゴきがいがありますよ。 \n……あぁっ、まだですよ、まだイかないで。イッてはいけません……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「貴方は我慢して、我慢して、我慢し続けて一番濃い精液を溜めて……私に捧 \nげるんです♪　んっ、そうですよ。良い子ですからこらえてください♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0103126" ]},
		{"command":[ "SETIMAGE", "0", "still_00027401_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「はい、シコ、シコ、シコ、シコシコっ♪　シコ、シコシコ、シコシコ……♪ \n　あああぁ♪　透明な先走りがにじみ出してきました。えっちですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「こんなにいやらしいチンポを見せつけられたら……あっ、あぁ、私も素早く \nシゴかざるを得ません……！　あっ、ピクピクしてます、すごい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「……あぁんっ♪　私の胸の蜜……伝説の花の蜜の味が濃くなった？　うふふ \nふっ、そうですよ、私を感じさせれば感じさせるほど、蜜は濃くなります」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0103129" ]},
		{"command":[ "SETIMAGE", "0", "still_00027401_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「ですから２人で……あっ、一緒に気持ち良くなればなるほど、私のおっぱい \nも、貴方のチンポも幸せになるということです……。んっ、あぁんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0103130" ]},
		{"command":[ "SETIMAGE", "0", "still_00027401_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「あっ……♪　勢い良く吸って、飲んで、堪能してくださいっ……。せっかく \nの伝説の花の蜜……あっぁっ、無駄にしてはいけませんよねっ……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「あぁ……♪　チンポがパンパンに膨らんできましたよ。私の手に刺激されて \n、こーんなにガチガチにしてしまって……♪　あぁ、すごく可愛いです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0103132" ]},
		{"command":[ "SETIMAGE", "0", "still_00027401_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「出したいんですか？　精子……ぴゅっぴゅってしたいんですよね？　はぁ、 \nはぁ、私も……乳首だけでイキそうです。だから、射精と同時にぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0103133" ]},
		{"command":[ "SETIMAGE", "0", "still_00027401_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「私の乳首、強く吸ってもらえませんか？　あっ♪　そうです、母乳を……蜜 \nを思いっきり吸い上げる感じにっ……。はぁっ、あっ、ぁ、もうすぐですっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0103134" ]},
		{"command":[ "SETIMAGE", "0", "still_00027401_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「私もチンポを、あっ♪　あっ、全力で絞り上げますよっ……！　あっ！　イ \nキますっ……イクッ、出して！　貴方の白い蜜をくださいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0103135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「んぁああぁっ……♪　あっ！？　あぁっ……ふぁあああっ♪　す、すごいっ \n……！　真上にびゅるびゅるって貴方の精液……蜜が舞って……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0103136" ]},
		{"command":[ "SETIMAGE", "0", "still_00027401_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「それに……んんんんんぅっ！　私も乳首からっ、乳首からたくさんの蜜が… \n…！　母乳が噴き出して……！　あああああっ、だめっ、イキますぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0103137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「ひぁああんっ♪　出ちゃうっ、濃い蜜出ちゃうぅううっ……！　あ～～～～ \nっ♪　あぁああんっ！　母乳っ、溢れた母乳飲んでくださぁいっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0103138" ]},
		{"command":[ "SETIMAGE", "0", "still_00027401_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「あっあっ、伝説の花の蜜ぅ……！　びゅくびゅく乳首から噴き出してきます \nよね！　あっ！　貴方のチンポと同じですっ、すごい量が出てるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「んっ、んんんっ……！　ふふふっ、私たち、すごくイキ方が似てますね…… \nっ。あっ♪　相性がいいのかも……！　んん、全部出してください……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0103140" ]},
		{"command":[ "SETIMAGE", "0", "still_00027401_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「ふ、ぁ……♪　たくさん精液を出してくれてありがとうございます……♪　 \nでも、まだまだチンポはお元気そうですね。……ええ、私もです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0103201" ]},
		{"command":[ "SETIMAGE", "0", "still_00027401_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「このままじゃ全然イキたりませんし、花の蜜も枯れてくれません。……どう \nですか？　このまま、もう一度、私と蜜の交換を続けるというのは……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「ふふふ……あら？　あらあらあら……まあまあ♪　貴方のお口よりも、チン \nポの方が先にお返事してくれましたね。そうですか、もっとしたいですか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0103203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「ええ、嬉しいですよ……♪　私も、もう乳首がジンジン疼いて仕方ないんで \nす……。さあ、舐めて、吸ってください……さっきより激しく……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0103204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「あっ……！　んっんっんっ……！　い、いいですよ！　時には軽く歯を立て \nて……あんっ、乳首を甘噛み、して……中の蜜を吸い取るんですっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0103205" ]},
		{"command":[ "SETIMAGE", "0", "still_00027401_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「じゅるじゅる、じゅるじゅるって……！　あっ♪　あっぁっ……上手ですね \n、そのままっ……そのまま吸っていてください……あっ♪　あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「うふふふっ……！　すごくおっぱいが気持ちいい……っ！　あんっ、花の蜜 \nを作りながら……、私もチンポをこすっていきますね……。ん、ん、んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0103207" ]},
		{"command":[ "SETIMAGE", "0", "still_00027401_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「あは……♪　精液、全部飛んでいったかと思いましたけど……チンポのまわ \nりにもついたままだったんですね。これを指に絡めてぇ……んんっ、んぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「先走りと精液でヌルヌルぬとぬとのチンポを、あっつあつになるまでシゴき \nたおしてあげますよ……♪　ぐにぐにぐに……ぐっちゅっぐっちゅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「ああ～……♪　２回目は、卑猥な水音が鳴って、チンポがとっても気持ち良 \nさそう……！　あっ♪　あっ、シゴいている私の手も気持ちいいですよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0103210" ]},
		{"command":[ "SETIMAGE", "0", "still_00027401_01_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「はぁっ……んんっ、ぬっちゃぬっちゃって指から音が聞こえます……♪　貴 \n方のチンポはいくら握っていても飽きませんね……硬くて大きくて……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「理想的なチンポですよ……っ。あっ♪　私のおっぱいはどうですか？　んっ \n、貴方の理想に近いでしょうか？　はぁっ、嬉しそうに吸ってくれますね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0103212" ]},
		{"command":[ "SETIMAGE", "0", "still_00027401_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「……え？　味がどんどん美味しくなってきている？　んふっ……♪　それは \n、貴方が貴方の蜜を捧げてくれたから、私を興奮させたからですよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「貴方のチンポをいじりながら♪　あんっ、貴方の舌で乳首を舐め回されて、 \n吸われて、蜜を奪われて……それが最高に気持ちいいんですっ……はぁんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0103214" ]},
		{"command":[ "SETIMAGE", "0", "still_00027401_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「ええ、たくさん……たくさん美味しい蜜を出しますから……あっ、あっ、や \nめないでくださいねっ、おっぱいを……母乳を吸うの……あっあっあっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0103215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「私の蜜、全て貴方にあげますから……！　あっぁっ、貴方の蜜も、また私に \n……！　っん……！　そ、そうです……私、乳首が一番感じるんですっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0103216" ]},
		{"command":[ "SETIMAGE", "0", "still_00027401_01_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「吸って……吸ってください……！　はぁあああああ……っ♪　脳がトロトロ \nになってきました……♪　蜜を吸われるの、すごくイイ……あっあぁんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「だ、め……♪　チンポをシコシコする手が止まっちゃうぅ……♪　あっ…… \n♪　だ、大丈夫です……！　私も貴方のこと、気持ち良くしたいからっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0103218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「チンポ、どうですか？　精液溜まってきましたか？　気持ち……いいですか \n？　あっ♪　あぁんっ♪　私は気持ち良すぎてもうイキそうですっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0103219" ]},
		{"command":[ "SETIMAGE", "0", "still_00027401_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「あっ♪　あっ、一緒に！　一緒にイッてくださぁいいっ……！　ふぁああっ \n♪　やぁんんっ、乳首からっ、母乳っ、花の蜜出ちゃうぅうっ！　あぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「んふぅうっ♪　あぁんんっ！　出ました、出てますぅううっ♪　私のおっぱ \nいからっ、蜜！　貴方のチンポから、精子……！　おそろいですねっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0103301" ]},
		{"command":[ "SETIMAGE", "0", "still_00027401_01_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「んぁあああっ♪　こんなにも高く打ち上がる精液なんて初めて見ました…… \n！　よっぽど我慢していたんですね、この勢い、嫌いではありません♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「はい、いいんですよっ……！　出したいだけ出してください、あっ……！　 \n私も母乳っ……花の蜜を出るだけ全て出しきってしまいますから……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0103303" ]},
		{"command":[ "SETIMAGE", "0", "still_00027401_01_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「はぁっ、あったかい……♪　それにこの、健康な精液の臭い……♪　びゅる \nっ、びゅるっと宙を舞う白い蜜……これが貴方の本気の射精ですか……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0103304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「あんっ……、一滴も残さずに出してくださいね……！　私の蜜も、どんどん \n飲んでください……！　溢れてこぼれて止まらないんです……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0103305" ]},
		{"command":[ "SETIMAGE", "0", "still_00027401_01_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「あぁっ……！　あっぁっあっ……！　ネバネバした貴方の白い蜜……！　こ \nの蜜を知ってしまったら、もう他の蜜なんて必要なくなってしまいます！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0103306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「……ふふふふふっ。精液を放出しすぎて、少し疲れてしまいましたか……？ \n　ええ。今、少しだけ……目を閉じて気を失っていましたよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0103307" ]},
		{"command":[ "SETIMAGE", "0", "still_00027401_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「あ、慌てて起きたりしないでください。ゆっくり休んでくださっていいんで \nす。……なんて、健気なことを言いましたが私も母乳を出しすぎて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0103308" ]},
		{"command":[ "SETIMAGE", "0", "still_00027401_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「おっぱいを使い過ぎて、体力を使い果たして動けなくなってしまったんです \n。だから……回復するまでは、二人でこうして休みませんか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「そうです。伝説の花の蜜のありかはもう知っているんですから。貴方はいつ \nでも、それを吸いに来ていいですからね。好きな時にいらしてください♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0103310" ]},
		{"command":[ "SETIMAGE", "0", "still_00027401_01_11" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「あぁっ♪　出ます、出ます出ちゃいますぅううっ……！　んぅっ！？　ひぅ \nうっ！？　あっ、貴方の白い蜜……精液が私の顔に……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0103401" ]},
		{"command":[ "SETIMAGE", "0", "still_00027401_01_17" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「はぁっ、あぁああ……♪　熱い……♪　貴方の蜜はこんなにも熱いんですね \nっ……♪　でも、私の母乳も……！　花の蜜もかなり熱いでしょうっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「それは貴方が、私の身体の内側から激しく熱してくれたおかげです……！　 \nふふふっ、貴方の精液が私の顔に、私の母乳が貴方の顔に……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0103403" ]},
		{"command":[ "SETIMAGE", "0", "still_00027401_01_16" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「こんなに幸せなことって他にありません……！　ああああっ♪　私が一番花 \nの蜜を……っ、母乳を飲んで欲しかった貴方に飲んでもらえて！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0103404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「その上で貴方の蜜までいただけてっ……この上なく幸せです！　あぁ……す \nごく臭い、それに……んっ、口の中に入った蜜はとても苦くて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0103405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「それなのにもっと欲しくてたまらないっ！　あぁっ、もっと顔にかけてくだ \nさい！　私も母乳をあなたの口に、顔にかけます……あっぁっあぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0103406" ]},
		{"command":[ "SETIMAGE", "0", "still_00027401_01_17" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「……はぁっ、はぁああ……♪　ご、ごめんなさい……。我を忘れて喜んでし \nまって……。でも、本当に嬉しかったんです。はぁ、はぁ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0103407" ]},
		{"command":[ "SETIMAGE", "0", "still_00027401_01_18" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「互いの蜜を分け合うということは、木の精霊にとっては……。ふふふ、植物 \nにとってはその……とってもロマンチックなことなんですよ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0103408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「私の花の蜜が、どうして伝説になったのかはわかりませんが……。貴方が望 \nむのなら、これからはこれは貴方だけに与えることにします……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0103409" ]},
		{"command":[ "SETIMAGE", "0", "still_00027401_01_19" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「だから貴方も……定期的に、私に蜜を与えてくださいね♪　お互い、すぐに \n溜まってしまうんですから……。待ってますよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0103410" ]},
		{"command":[ "SETIMAGE", "0", "still_00027401_01_18" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}