{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
        {"command":[ "SETIMAGE", "0", "bg_0101" ]},
        {"command":[ "DISPIMAGE", "0", "true" ] },
        {"command":[ "FADEOUT", "NORMAL" ]},
        {"command":[ "PLAYBGM", "BGM_005" ]},
        {"command":[ "WAITMOVE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
        {"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はあ……はあ……だから、こんなとこで無駄に戦ってどうするつもりなんだ　\nよ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「うるせえ……！　先に始めたのはあっちのほうだ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "034_020101090001" ]},
        {"command":[ "SETCHARA", "0", "char_00003401_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
        {"command":[ "SPOTCHARA", "0" ] },
        {"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "Ｍ・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「そもそも、この場にいるべきでない人間が、大きな顔をしているのが問題な　\nのです……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "050_010101090001" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「うるせえ！　またやるかコラ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "034_020101090002" ]},
		{"command":[ "SETCHARA", "0", "char_00003401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "サイボーグ型の怪人" ]},
		{"command":[ "SETTEXT", "「そうだ！　やっちまえ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "Ｍ・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「いいでしょう！　いくらでもお相手して差し上げます！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "050_010101090002" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「だから！　やめろっつーの！　ふぅ……！　まったくきりがないな！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「本当に……姫様、いったいどうしたらこの騒ぎが収まるのでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "002_010101090001" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「私に聞かないでくれ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010101090001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "俺たちがいいかげん困り果てていたその時。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「諸君！　静まりたまえ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "049_010101090001" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ん？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ああ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "034_020101090003" ]},
		{"command":[ "SETCHARA", "0", "char_00003401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「この世界の終わりまで争い続けるつもりかっ！？　正義だの悪だのと言って　\nいる場合ではない！！　即刻、争いをやめるのだ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "049_010101090002" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "壇上に現れた一人の女。そいつの声には、あまりに迫力と説得力があった。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「な、なんだよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "034_020101090004" ]},
		{"command":[ "SETCHARA", "0", "char_00003401_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "Ｍ・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「あの人は……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "050_010101090003" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "争っていた連中も、なんとなく気勢をそがれておとなしくなっていく。ざわめ　\nいていた会議室が、次第に平穏を取り戻す。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「諸君、ご協力感謝する」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "049_010101090003" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「私の名は冴島美鈴、このＥＤＯの日本支部長を務めさせてもらっている　\n者だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "049_010101090004" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「この度、この世界に異次元からの襲来者（インベーダー）が現れ各所で　\n多大な被害が出てしまったのは諸君も知っての通り」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "049_010101090005" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「彼らの力は強大で、個々の組織の戦闘力では到底太刀打ち出来ないレベルで　\nある」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "049_010101090006" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "特殊部隊風の男" ]},
		{"command":[ "SETTEXT", "「おいおい、はっきり言っちゃったよ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "鎧の女" ]},
		{"command":[ "SETTEXT", "「じゃあ、どうしたらいいわけ……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「それを重くみた我々ＥＤＯは、長年敵対してきた悪の組織の総本山・九姉妹　\nと協議し、この外敵を駆逐するまで一時的な協力体制を取ることに相成った」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "049_010101090007" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "将軍風の男" ]},
		{"command":[ "SETTEXT", "「なんだと！？　どういうことだ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ゴーグルの男" ]},
		{"command":[ "SETTEXT", "「そんな、まさか！　ありえない！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "赤い装甲強化服の男" ]},
		{"command":[ "SETTEXT", "「おいおい、嘘だろ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「九姉妹……？　ってなんだ、ジュンジロー」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「おやおや、ご主人。とんだ不勉強ですな。もう少し悪の幹部として自覚を持　\nち、世の中の動きに目を向けるべきですぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "009_010101090001" ]},
		{"command":[ "SETCHARA", "0", "char_00000901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「偉そうなこと言いやがって。じゃ、てめぇは知ってんのか駄犬のくせに」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「もちろん存じておりますぞ。存じておりますが、詳しいことは姫様から解説　\nをお願いいたします」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "009_010101090002" ]},
		{"command":[ "SETCHARA", "0", "char_00000901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「なに？　私か？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010101090002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「人任せにしてんじゃねえ！　どうせお前も知らねえんだろアホ犬！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「……ジュンジローのことはいい。お前はどうなんだ下僕。知っているのか知　\nらんのか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010101090003" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あ……す、すみません、知りません。教えてください……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「まったく貴様は……いいか？　『九姉妹』というのは、悪の組織同士の互助　\n組合のようなものだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010101090004" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「へ？　互助組合？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "悪の組織にそんなものがあったのか。なんか妙に健全だな。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「うむ。それぞれの組織が、てんでバラバラに活動していては効率の悪いこと　\nもあるからな。このような枠組みも必要となる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010101090005" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「敵となる正義の味方の情報交換、作戦区域と実行日の調整、年に２度の親睦　\n会、活動内容はいろいろです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "005_010101090001" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「参加しているのは、ウチらグレート・ルナリアムのほか、ブラックメルヘン　\n、グローバル指定暴力団・極道會などなど――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "005_010101090002" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ま、いろいろあるけど主要な組織は全部で９つ。だから『九姉妹』って呼ば　\nれるわけさね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "003_010101090001" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「もっとも、９組織のほかに各々の下部組織も加入してるから、参加組織は全　\n部で１０８あるけどね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "003_010101090002" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「へえー……知らなかった。世の中、いろんな組織があるもんだなぁ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「静粛に！　静粛に！　いいかね、諸君！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "049_010101090008" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "おっと、話の続きが始まるみたいだ。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「信じられないという気持ちは理解できるが、これはまぎれもない事実なのだ　\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "049_010101090009" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「……長官さん、そこから先は私が説明しましょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "033_010101090001" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "お？　なんだ？　またなんか偉そうな美女が出てきた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あれは！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "005_010101090003" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「なんだ？　知っているのか？　オボロ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "004_010101090001" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あれは血桜お七……！　グローバル指定暴力団・極道會の直系組織、　\nΩ組の組長ですよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "005_010101090004" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「Ω組の血桜お七っていやあ、九姉妹でも相当な顔役だねえ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "003_010101090003" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「なんでも、普段は獄門七重と名乗って株式会社雄雌牙建設の社長業　\nを務めており――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "005_010101090005" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「九姉妹の集まり以外にはめったに姿を現さないと聞いていましたが、こん　\nなところに現れるとは！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "005_010101090006" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「へ、へえ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "なんか話がどんどん大きくなってくるなあ……。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "そんな俺のビビリとは関係なく、壇上の血桜お七は聴衆に向けて語りかけ　\nる。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「確かに今回の話は、簡単に飲める話じゃぁございません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "033_010101090002" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「しかし……彼女の話を聞いてもらってから、お集まりの皆さんに決断しても　\nらった方が良いんじゃぁないかと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "033_010101090003" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「さぁ、こちらへ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "033_010101090004" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "お七にうながされ、壇上に登ってきたのは――", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "黒いルナテミス" ]},
		{"command":[ "SETTEXT", "「…………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_090101090001" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あいつ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「もう一人の私か！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010101090006" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "突然現れた黒いルナテミスを、室内の全員が固唾をのんで見守る。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "黒いルナテミス" ]},
		{"command":[ "SETTEXT", "「…………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_090101090002" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "黒いルナテミスはその様子をざっと見渡し、突然口を開いた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "黒いルナテミス" ]},
		{"command":[ "SETTEXT", "「私の名はルナテミス！　この世界は狙われている！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_090101090003" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "白衣姿の男" ]},
		{"command":[ "SETTEXT", "「なんだって！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "妖艶なドレスの女" ]},
		{"command":[ "SETTEXT", "「なによ！？　狙われてるって誰に！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ル、ルナテミスは私だっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010101090007" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「姫様……落ち着いて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "002_010101090002" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "ふたたびざわめく場内。黒いルナテミスはその中から、こちらのルナテミスに　\n目を止め、言葉を続ける。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "黒いルナテミス" ]},
		{"command":[ "SETTEXT", "「ああ、そうだった……この世界には、こちらの私がいるのだったな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_090101090004" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「では便宜上、私のことは異世界から来たもう一人のルナテミス、『Ａルナテ　\nミス』と呼称してもらおう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_090101090005" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「私はこの場を借りて、自分の世界の遺志を継ぐもの――おそらくは、唯一生　\nき残った者として語りたい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_090101090006" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「私のいた世界は、先日この世界を襲った『襲来者（インベーダー）』たちに　\nよって、完全に崩壊した」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_090101090007" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "スーツ姿の男" ]},
		{"command":[ "SETTEXT", "「崩壊！？　あいつらには、そんな力が……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「襲来者たちは、時空連続体のゆがみにより別の多元宇宙（マルチバース）　\nから現れ――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_090101090008" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「こちらの多元宇宙内の世界を、次々に破壊し続けている。今度は、この世界　\nが狙われているのだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_090101090009" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「もはや一刻の猶予もならない！　同じ世界の住民同士で争っている時ではな　\nい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_090101090010" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「力を合わせ、襲来者に対抗するのだ！　我々の悲劇を繰り返さないために　\nも！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_090101090011" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "Ａルナテミスの言葉に、ざわめいていた会議室がしん、と静まり返る。誰もか　\nれもが、じっと彼女のいったことをかみしめている。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人、思っていたより事態は深刻そうですぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "009_010101090003" ]},
		{"command":[ "SETCHARA", "0", "char_00000901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「…………そうみたいだな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}