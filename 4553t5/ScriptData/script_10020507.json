		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「それからも練習は続いたッ！　しかし、ルルーナだけがうまくタイミングを\n合わせられないッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_999_010113480007" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……。もう一度……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113480009" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「ルルーナさん、あなたはなんというか、台本をただ読んでいるだけのように\n感じます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020113480015" ]},
		{"command":[ "SETCHARA", "0", "char_00002602_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「すみません……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113480010" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「あなたはまだ役になりきれていないようですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020113480016" ]},
		{"command":[ "SETCHARA", "0", "char_00002602_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「令嬢という立場が自分と近いからと甘く考えていませんか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020113480017" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「そ、そんなことは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113480011" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「令嬢は花です。ですがルルーナさんの令嬢はつぼみ、いいえ、草です。雑草\nです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020113480018" ]},
		{"command":[ "SETCHARA", "0", "char_00002602_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「雑草がほかの花と一緒にステージに立てると思っていますか？　そんなわけ\nありませんよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020113480019" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「……っ！　そこまで言わなくてもいいじゃないですか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113480012" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「ああっ、ルルーナちゃん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010113480007" ]},
		{"command":[ "SETCHARA", "0", "char_00001205_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「が、学園長。いくらなんでも言い過ぎじゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020113480008" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「……たとえ雑草でも、花を咲かせます。その時こそ彼女は令嬢の役を掴むで\nしょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020113480020" ]},
		{"command":[ "SETCHARA", "0", "char_00002602_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「さあ、一人いなくなりましたが練習を再開しますよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020113480021" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}