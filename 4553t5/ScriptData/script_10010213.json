{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0116" ]},
        {"command":[ "DISPIMAGE", "0", "true" ] },
        {"command":[ "FADEOUT", "NORMAL" ]},
        {"command":[ "PLAYBGM", "BGM_019" ]},
        {"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ったくよぉ～！　あいつら、できるんなら最初からやれ、っつーのよ！　ぐ\nちゃぐちゃゴネてないでさぁ～！　聞いてる！？」", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "PLAYVOICE", "049_010102200001" ]},
        {"command":[ "SETCHARA", "0", "char_00004902_01", "4", "CENTER", "0" ]},
        {"command":[ "DISPCHARA", "0", "TRUE" ]},
        {"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「お客さん、そろそろ閉店なんすけどね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "034_020102200001" ]},
		{"command":[ "SETCHARA", "0", "char_00003403_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「いいじゃ～ん！　ちょっとだけ聞いてよ、ほむらたぁ～ん！　あいつらさあ\n、全然やる気ないのよぉ～！　おまけに協調性ゼロだしさぁ～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "049_010102200002" ]},
		{"command":[ "SETCHARA", "0", "char_00004902_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「お客さん、飲み過ぎじゃねえすか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "034_020102200002" ]},
		{"command":[ "SETCHARA", "0", "char_00003403_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「飲まなきゃやってらんないっつーのよ！　ほんとにあいつら、普段はやる気\nのカケラもないくせに、目の前にごほうびがぶらさがると――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "049_010102200003" ]},
		{"command":[ "SETCHARA", "0", "char_00004902_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「打って変わってやる気出しちゃってさあ！　なによ！？　なんなのよ、アレ\n！？　ほむらたん、お銚子もう１本！　冷やでいいから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "049_010102200004" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「もう閉店だっていったろ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "034_020102200003" ]},
		{"command":[ "SETCHARA", "0", "char_00003403_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「冷たいこと言わないでさぁ～？　もう１本！　もう１本だけ飲んだら帰るか\nらさぁ～。頼むよ、ほむらたぁ～ん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "049_010102200005" ]},
		{"command":[ "SETCHARA", "0", "char_00004902_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ったく……しょうがねえなあ。これで最後だぞ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "034_020102200004" ]},
		{"command":[ "SETCHARA", "0", "char_00003403_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「はいはい、ありがとありがとね～。に、してもさぁ～？　私もそろそろヤキ\nが回ったかなぁ～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "049_010102200006" ]},
		{"command":[ "SETCHARA", "0", "char_00004902_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「あいつら、もうちょっとデキるヤツらかと思ったけど、いざ部隊編成してみ\nたらあの始末だもんなぁ～！　人選ミスかもなぁ～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "049_010102200007" ]},
		{"command":[ "SETCHARA", "0", "char_00004902_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "034_020102200005" ]},
		{"command":[ "SETCHARA", "0", "char_00003403_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「思えば私さ。人を見る目ないんだわ、若いころから。だから私生活は顧みず\n仕事一辺倒……いや、そのことは後悔してないんよ？　マジで」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "049_010102200008" ]},
		{"command":[ "SETCHARA", "0", "char_00004902_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「でもねえ……そうやって頑張ってきた結果がこれかよ、ってねぇ！？　ほん\nとにこれで地球守れんのかよ！　ってさぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "049_010102200009" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "034_020102200006" ]},
		{"command":[ "SETCHARA", "0", "char_00003403_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「はぁ～……ダメだ、私。長官失格だ。もう、仕事やめよかな。転職しよかな\n。あ、でも、何やったらいいんだろ、今さら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "049_010102200010" ]},
		{"command":[ "SETCHARA", "0", "char_00004902_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「……お客さん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "034_020102200007" ]},
		{"command":[ "SETCHARA", "0", "char_00003403_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「あ、大丈夫！　これだけ飲んだら帰るから！　迷惑かけないから！　とっく\nにかけてっけど！　でも、あとちょっとだけ――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "049_010102200011" ]},
		{"command":[ "SETCHARA", "0", "char_00004902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「これ、あたしのおごりだよ。売れ残りだけどさ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "034_020102200008" ]},
		{"command":[ "SETCHARA", "0", "char_00003403_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ほむら……たん？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "049_010102200012" ]},
		{"command":[ "SETCHARA", "0", "char_00004902_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「それ食って元気出しな。明日も仕事だろ？　長官さんよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "034_020102200009" ]},
		{"command":[ "SETCHARA", "0", "char_00003403_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ほむらたん……！　うっ……うううううっ……！　ありがと……ありがどぉ\nおおおおおお～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "049_010102200013" ]},
		{"command":[ "SETCHARA", "0", "char_00004902_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「うわああっ！？　なんだなんだ！？　いきなり手ぇ握るんじゃねえ！　わわ\nっ！　鼻水！　鼻水垂れてる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "034_020102200010" ]},
		{"command":[ "SETCHARA", "0", "char_00003403_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ありがどぉおお～！　ほむらたん！　愛じでるよぉおおおお～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "049_010102200014" ]},
		{"command":[ "SETCHARA", "0", "char_00004902_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「愛さんでいい！　いいからもうそれ食って帰れ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "034_020102200011" ]},
		{"command":[ "SETCHARA", "0", "char_00003403_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「帰るぅうううう～！　ほむらたん持っておうち帰るぅうううう～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "049_010102200015" ]},
		{"command":[ "SETCHARA", "0", "char_00004902_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「なに言ってやがる！　その手ぇ放せ！　あ、こら！　抱き着くんじゃねえ！\n　あああああああ！　もう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "034_020102200012" ]},
		{"command":[ "SETCHARA", "0", "char_00003403_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「いいかげんにしろぉおおおおお～～～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "034_020102200013" ]},
		{"command":[ "SETCHARA", "0", "char_00003403_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}