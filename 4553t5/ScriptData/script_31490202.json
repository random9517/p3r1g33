		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「はー……あはぁぁ……射精が、止まったみたい、でござるわねぇ……ふぅ、\nあふぅ……気持ち、よかった、ですわぁ……あふぅ……」", "NORMAL" ]},
