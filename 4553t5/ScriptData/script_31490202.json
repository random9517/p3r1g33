		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「あぁぁ……すごぉい……はー……んふぅ……イクのが、止まりませんでござ\nる……はぁ……はぁ……はへぇぇ……」", "NORMAL" ]},
