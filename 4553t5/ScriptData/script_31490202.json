		{"command":[ "SETIMAGE", "0", "still_00014902_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「このまま続きをいたしましょう……ふぅ、ふふ、拙者の方は、全然オッケー\nでござるですよぉ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0204202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「あっ、ん、はぁ……はぁぁ……っ、う、動いてる……ん、あぁん、マンコが\n、チンポを搾りたがってるでござるぅ……」", "NORMAL" ]},
