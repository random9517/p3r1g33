		{"command":[ "SETIMAGE", "0", "still_00014902_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「お腹の中に、子宮がめり込んじゃう……ああ、駄目ぇ……苦しい……潰れち\nゃうぅ……はぁ、はぁ……あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0204122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「マンコが……あ、ああ、おちんぽでいっぱいに、なってる……はぁ、はぁ…\n…マンコが、ちんぽの形になっちゃってるで、ござる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0204123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「んんっ！　くぅ！　はっ、あっ、ああああん……こ、腰使いが、大きくなっ\nて……あ、駄目、駄目駄目……はぁ、ああぁあん！　気持ち、いい……」", "NORMAL" ]},
