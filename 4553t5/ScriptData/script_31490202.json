		{"command":[ "SETIMAGE", "0", "still_00014902_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「んっ、んんぁ、あはぁぁあぁん……こ、こんなはしたない声を上げてしまう\nとは……恥ずかしいでござるですわぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0204107" ]},
		{"command":[ "SETIMAGE", "0", "still_00014902_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「こんな姿……隊長氏にしか見せたこと、ありませんでござるの……ふふ、こ\nの顔、この姿は、隊長氏だけのものですのよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0204108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「んっ、んはぁぁっ、はぁ……い、入り口が、目一杯引き伸ばされているでご\nざるですわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0204109" ]},
		{"command":[ "SETIMAGE", "0", "still_00014902_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「開ききった入り口の形がそのまま、膣奥まで続いてる感じでござるですわぁ\n……はぁ、はぁ……ああ、すごぉい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0204110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「ん、はぁ……はぁぁ……先っちょが、奥に届いてしまったでござるわぁ……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0204111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「あはぁぁ……お腹の奥で、感じちゃう……子宮が喜んでるでござる……はぁ\n、んふぅ……」", "NORMAL" ]},
