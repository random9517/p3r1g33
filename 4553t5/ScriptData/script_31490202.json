		{"command":[ "SETIMAGE", "0", "still_00014902_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「そ、そのままで、お願いいたしますわぁ……あぁ、これいい……すごくいい\nでござるですぅ……ん、あぁ、はぁああん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0204125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……ふふ、よく締まるでしょう？　当然、でござるわ……日々\n、鍛えておりますから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0204126" ]},
		{"command":[ "SETIMAGE", "0", "still_00014902_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「関節技や、寝技の基本は、体幹の力……はぁ、はぁ……知らずしらずのうち\n、膣圧も鍛えられておりましたのでしょう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0204127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「ふふふ……おかげで、隊長氏から絞め技で一本取れそう、ですわね……はぁ\n、はぁ……んふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0204128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「あ、ああ、はぁ……閉めれば締めるほど……チンポを感じるでござる……あ\nあ、マンコの中で、大きくなってるように感じちゃうぅ……」", "NORMAL" ]},
