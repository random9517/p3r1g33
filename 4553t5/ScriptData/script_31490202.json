		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「ひやあ！　あぁあん……精液が、中でぐにゅぐにゅ動いてる……あはぁぁ…\n…精液、気持ちいいよぉ……はぁ、はぁ、はへぇ……」", "NORMAL" ]},
