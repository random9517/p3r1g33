		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「下忍として仕えておりましたが……胸のうちでは、ただの主従に終わりたく\nない……そう思っていたのでござるの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0204102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「はぁ……それにしても、ん、ふぅ……立派なおちんぽでござる……見ている\nだけで、ため息が出てしまいますわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0204103" ]},
		{"command":[ "SETIMAGE", "0", "still_00014902_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「これが、体内に入ってくるかと思うと……もう、ドキドキが止まりませんで\nござる……あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0204104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「それで……もう挿れてよろしくて？　ええ、承知したでござるですわぁ……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0204105" ]},
		{"command":[ "SETIMAGE", "0", "still_00014902_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「んはぁぁ～～～～……入って、来る……んっ、んぁ、はぁ……あはぁあん…\n…マンコが、喜んでるで、ござるぅ……」", "NORMAL" ]},
