		{"command":[ "SETIMAGE", "0", "still_00014902_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「子宮が……あ、ああ……嬉しい悲鳴を、上げている……あ、ああ、精液、欲\nしがってる……熱いドロドロ、恋しがってるぅ……」", "NORMAL" ]},
