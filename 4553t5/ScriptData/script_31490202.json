		{"command":[ "SETIMAGE", "0", "still_00014902_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「あ、はぁ……硬ぁい……カチカチチンポが、マンコ、ぐっちゃぐちゃにして\nるよぉ……あっ、ああ、わたくし、もう……駄目ぇ……」", "NORMAL" ]},
