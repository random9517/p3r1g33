		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「あぁあん、ありがとうでござるですぅ……ん、はぁ……はああ、ああああ、\n中で、いっぱい、動いて……る……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0204119" ]},
		{"command":[ "SETIMAGE", "0", "still_00014902_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「硬ぁい……チンポ硬くて、ぐぅ、んひぃ……マンコが、裂けちゃいそうでご\nざるぅ……あ、はぁ、はへぇぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0204120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「んっ、あっ、あぐぅぅ……さ、先っちょが、子宮を持ち上げてるでござる…\n…」", "NORMAL" ]},
