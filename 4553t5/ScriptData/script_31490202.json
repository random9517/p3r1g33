		{"command":[ "SETIMAGE", "0", "still_00014902_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「ん、んんぁ……はぁ……はぁぁん……中で、ずるずる、動いてる……あはぁ\n、精液がヌルヌルして、気持ち、いい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0204204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「あぁぁ、はぁ……はぁぁあん……勝手に、マンコが、締付けちゃうぅ……あ\n、ああ……チンポの形が、クッキリとわかるで、ござる……」", "NORMAL" ]},
