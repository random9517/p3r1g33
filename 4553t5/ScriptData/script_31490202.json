		{"command":[ "PLAYVOICE", "v2_149_0204210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「はー……はぁぁん……も、もっとしてぇ……はぁ、はぁ……いっぱいイカせ\nてぇ……んっ、くぅ……はぁ、きゃうぅぅん……っ」", "NORMAL" ]},
