		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「……隊長氏と、よもやこのような関係になってしまおうとは……夜闇を忍ん\nでまいった甲斐があるというものでござるですわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0204101" ]},
