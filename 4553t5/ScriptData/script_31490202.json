		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「あ、ああ……硬い……ゴリゴリ、擦れてる……んくぅ、あはぁぁ……硬くて\n、気持ちいいでござるですわぁ～～……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0204113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「ふぅ……んはぁ……子宮が、ヒクヒクしてる……はぁ、はぁ……こうして深\nく深く繋がっていると、幸せを感じてしまうでござるの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0204114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……子宮が、精液を欲しがっているでござる……はぁ……はぁ\n……隊長氏ぃ……もっと、動いていただけてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0204115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「んはぁ……あはぁ……先っちょが、もっといっぱい擦れてる……ん、んんは\nぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0204116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「あぁぁ、気持ちいいでござるわぁ……はぁ、はぁ……あぁぁああん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0204117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「でも、もっと欲しいですわぁ……もう少し、大胆に動いて、いただけてぇ…\n…？」", "NORMAL" ]},
