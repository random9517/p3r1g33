		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「え？　気持ちいい……？　はぁ、ふぅ……よろしくてでござるよ……このま\nま、出していただいても……はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0204131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「あっ！　あぁっ、す、ごぉい……はぁ、んん、そんなに激しく、されたら…\n…あ、ああ……はぁ、あぁあん……」", "NORMAL" ]},
