		{"command":[ "SETIMAGE", "0", "still_00014902_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「あ、ぐぅ……ふぅ、んはぁぁ……子宮に、ずんずん、ぶつかってくるぅ……\nはぁ、ああぁあん……子宮が、精液を吸って、膨らんでるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0204207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「ひやぁぁあっ！　んひぃぃぃ……！　はっ、あっ、ああああ……チンポが、\nマンコ、えぐってる……あはぁ……マンコが、捩れ、ちゃうぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0204208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「ふぐぅ、ひうぅぅぅ……精液が掻き混ぜられて……あ、ああ、泡立ってる…\n…中で、しゅわしゅわしてる……っ！」", "NORMAL" ]},
