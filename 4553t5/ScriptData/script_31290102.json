		{"command":[ "PLAYVOICE", "129_0104101" ]},
		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「やれやれ、アタシはとんでもない野郎にとっつかまっちまったみたいだねえ\n……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "129_0104102" ]},
		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「このアタシに股を開いて子作りをしろだなんて……ふふふ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "129_0104103" ]},
		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「言っとくけど、アタシの裸を見たヤツなんて、今まで誰もいないんだよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "129_0104104" ]},
		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「両親かい？　顔を見たことないからねえ、そんなことはどうだっていいさ。\n女にも見られたことないってのに……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "129_0104105" ]},
		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「せ、セックスなんてね……まあいいさ、アンタとなら……悪くない」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "129_0104106" ]},
		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「な……何だって？　怖いんだろってかい？　バカを言うんじゃないよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "129_0104107" ]},
		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「震えてる？　うぅぅ……くっ！　ああぁ～！　仕方ない、白状するよ。確か\nに緊張してる……初めてだからね」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "129_0104108" ]},
		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「それだけのことだよ。アンタは気を遣うんじゃない。好きなように抱きゃあ\nいいのさ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "129_0104109" ]},
		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「そ、そう……その大きなオチンポでアタシのオマンコに入れれば……はぁ、\nはあぁっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "129_0104110" ]},
		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「あっ、あぁ……オマンコにくっつくと、熱くて硬くて……アンタのやっぱり\nすごいよ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "129_0104111" ]},
		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「はっ……はぅぅ！？　んっ、あ……あぁ～！！　は、入ってくる……よ！　\nはぅぅ、んっ、んん！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012901_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "129_0104112" ]},
		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「はぁぁ！　はぅぅん、ど、どうってことないね、セックスなんて……気合い\nだよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "129_0104113" ]},
		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「あっ、あぁ……ちょっと、いきなり激しく動きすぎ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "129_0104114" ]},
		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「べっ別に何でもないよ、好きにヤリな、はぅん！　はっ……はぁぁ、あっ、\nんあぁぁん」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012901_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "129_0104115" ]},
		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「あっあぁ！？　ちょっと……おっぱいを、んんぅ！？　両方、いやらしく揉\nむんじゃないよ……くぅぅっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "129_0104116" ]},
		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「乳首ぃ、こねくり回してどうする……くっ、くひぃぃ！？　んあぁ～！！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012901_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "129_0104117" ]},
		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「そこ弱いって言ってるじゃないか、だ、だからぁ……え？　もっと激しく動\nく、だって？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "129_0104118" ]},
		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「んっ、くぅぅ！　あっ……何？　やあぁっ！？　くぅぅん！　奥ぅ、んあぁ\n！　オマンコの奥っ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "129_0104119" ]},
		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「オチンポが届いちゃってるよ、ふあぁっ……あぁ！？　ああああぁ～～！？\n」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012901_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "129_0104120" ]},
		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「な、何だって？　アタシがイッちまった？　くぅぅ……そう、だよ。奥に、\n届いただけで……あぁん」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012901_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "129_0104121" ]},
		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「軽くイッたんだよ、アンタのオチンポは宇宙にあるどんな兵器よりも凶暴で\n……くっ、くひぃぃ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "129_0104122" ]},
		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「頭の奥ぅ……パチ、パチって火花が散って、んあぁ！　はあぁ！　はひっ、\nひぃぃん……！！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012901_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "129_0104123" ]},
		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「アタシが、イカされてるっ……くぅぅん！　こ、このアタシが……あああぁ\n！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "129_0104124" ]},
		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「男に抱かれたぐらいで、一匹のメスに成り下がって……はひっ、ひんっ！　\nひあぁ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "129_0104125" ]},
		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「おっぱいも同時にするの反則だろぉ……き、気持ち良すぎるんだってば、や\nあぁん、あぁ……やめろぉ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "129_0104126" ]},
		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「これ、気持ち良すぎるんだ、おかしくなってしまうっ……！　やああぁぁ～\n～～っ！！？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012901_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "129_0104127" ]},
		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「子宮も下がってぇ……アンタの子を孕みたがってるんだよ、んあぁっ！　ひ\nあぁん！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "129_0104128" ]},
		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「はひっ……ひあぁん！　も、もうダメだよ、身体の奥、からぁ……何か来る\nんだ、来るんだよ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "129_0104129" ]},
		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「頭が真っ白になって……くぅぅ！？　こ、こんな気持ち良さ知ったら……あ\n、アタシだって……あうぅ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012901_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "129_0104130" ]},
		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「も、もう……ダメだよ、限界ぃっ……子宮ぅ、がつ、がつって揺らされてイ\nク……イッちゃうよぉ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "129_0104131" ]},
		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「んあぁ、アンタも出るのかい？　い、一緒……一緒にぃ、イク……イク、イ\nクッ、イクぅ……んああぁ！？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012901_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "129_0104132" ]},
		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「あっ、あああ……あああぁぁ～～～～っ！！　あああぁっ、も、もうイクぅ\nぅ～～！！！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "129_0104133" ]},
		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「はひっ！　ひぃぃん！　子宮に、あ……アンタの熱い子種汁ぅ注がれて……\nく、くひぃっ、ひあぁん！」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012901_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "129_0104134" ]},
		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「気持ち良すぎて、頭の奥ぅ灼けちゃってるぅ……んあぁぁん！　あぁ、はあ\nぁ……あうぅっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "129_0104135" ]},
		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「ま、まだオチンポ入ってるのに、スペルマが逆流して……ああぁぁっ。こ、\nこんなに出されたら、絶対に孕んじゃうよ……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "129_0104136" ]},
		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「あ、アンタ……分かってるのかい。なっ、せ……責任は取る、だって？　い\n、いいんだよ……気を遣わなくたってさ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012901_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "129_0104137" ]},
		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「ばばば、バカを言うんじゃないよ、アタシがアンタの嫁……！？　やめなっ\nて、ガラじゃないよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "129_0104138" ]},
		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「なっ、何！？　慌てた顔が可愛い？　くっ、ううう……いつもならビンタし\nてるところだけど……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "129_0104139" ]},
		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「惚れた弱みだねえ、アンタにゃ参ったよ。ねえ、まだ出したりないんだろ？\n　だったらさ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "129_0104140" ]},
		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「アンタの精液、全部搾り取ってあげるよ……さあ、アタシのカラダ……アン\nタの好きにしな」", "NORMAL" ]},
