{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「あ、先輩……呼び出しちゃってごめんなさい。どうしても聞いて欲しい大事\nな話があって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0204101" ]},
		{"command":[ "SETCHARA", "0", "char_00026102_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「私……皆より力がなくて、いつも迷惑ばかりかけてて……いつも一人でピン\nチになってお姉ちゃんにも助けてもらってて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0204102" ]},
		{"command":[ "SETCHARA", "0", "char_00026102_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「そ、それでも、そんな私をカツマ先輩はずっと見捨てずにいてくれて……励\nましてくれたり、特訓をしてくれたり……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0204103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「ち、ちょっとえっちだけど、それでも先輩は私の側にいてくれて……私、少\nしはマスク・ザ・ホワイトとしても、春風うららとしても成長できました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0204104" ]},
		{"command":[ "SETCHARA", "0", "char_00026102_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「本当にありがとうございます……！そ、それが一つです。……それで、それ\nでですね……先輩にそれを伝えようって、最近ずっと考えてたら、その……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0204105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「か、身体が……熱くなってきちゃって、おっぱいとおまんこが、きゅんきゅ\nんしちゃって……先輩が欲しいって、先輩と一緒になりたいって……えへへ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0204106" ]},
		{"command":[ "SETCHARA", "0", "char_00026102_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「こ、こうやって話している今も、もうお腹の奥がきゅうきゅう言ってて……\nあ、あの！……先輩、私のこの気持ち、受け取ってくださいっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0204107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「えへへ、前は先輩に上に乗られたから、今日は私が上になりますね……ふふ\nっ、こうして先輩を見下ろすの、ちょっと気持ちいいかも……です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0204108" ]},
		{"command":[ "SETIMAGE", "0", "still_00026102_02_01" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「んっ、やあっ、あんっ、おっぱい吸ったら、さ……先っぽが出てきちゃいま\nす……んんんっ、先輩、赤ちゃんみたい……あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0204109" ]},
		{"command":[ "SETIMAGE", "0", "still_00026102_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「んんっ、ダメですってば、もう……まだミルクは出ませんよ？　でも……先\n輩との赤ちゃんができたら……出ちゃうかもですが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0204110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「だから……このまま、入れていいですか？　先輩のおちんちん、私のおまん\nこの中で……きゅっきゅって、ごしごしって、していいですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0204111" ]},
		{"command":[ "SETIMAGE", "0", "still_00026102_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「あんっ、先輩、腰が動いてますよ……んっ、ふうっ、ふふっ……それじゃあ\n、私のおっぱい、ミルクが出るようにしてください……、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0204112" ]},
		{"command":[ "SETIMAGE", "0", "still_00026102_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「んうううっ、入って、来た……んっ、先輩のおちんちん、私の中に……ふう\nっ、うっ、この中を埋めてくる感覚……好き、あくうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0204113" ]},
		{"command":[ "SETIMAGE", "0", "still_00026102_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「んんっ、一番奥まで……来た……ふふっ、先輩が全部、入ってきました……\nんふっ、うっ、これ、幸せ……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0204114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「あんっ、あっ、くうっ、奥、こつこつってされるたびに、先輩のことがもっ\nともっと愛おしくなって……んっ、もっと、もっとしてくださいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0204115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「私も、こうして腰を動かして……んっ、あっ、んふうっ、この、二人で動き\nを合わせるの、愛しあってるみたいで、いいっ、んっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0204116" ]},
		{"command":[ "SETIMAGE", "0", "still_00026102_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「あんっ、先輩、おっぱい吸ったら、……んんっ！……胸の奥がきゅんきゅん\nしてもっと腰が動いちゃいます、んっ、あんっ、ああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0204117" ]},
		{"command":[ "SETIMAGE", "0", "still_00026102_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「んくうっ、おっぱいも、おまんこも気持ちよくなっちゃって、んっ、ふうっ\n、ああっ、あんっ！！　身体中、じんじんしてきた、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0204118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「ふうっ、うっ、繋がるって、男の人と、先輩と繋がるってこういうことです\nよね、んっ、んうっ、お腹の奥、こつこつって、ふううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0204119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「先輩のおちんちんが奥に届いて、ぐりぐりってされると、お腹の中から幸せ\nが……んふうっ、うっ、あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0204120" ]},
		{"command":[ "SETIMAGE", "0", "still_00026102_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「先輩、先輩も気持ちいいですか？　私のおっぱいとおまんこ、気持ちいいで\nすか？　あんっ、あっ、またおっぱい、んんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0204121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「んんっ、吸って、もっといっぱい、……強く吸ってください、私も、先輩の\nおちんちん、きゅって抱きしめるから、あんっ、ふうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0204122" ]},
		{"command":[ "SETIMAGE", "0", "still_00026102_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「ふあああっ、上も、下も、気持ちよくて、溶けちゃいそう、あんっ、先輩の\nお口とおちんちんで、私の身体溶けちゃいそう、んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0204123" ]},
		{"command":[ "SETIMAGE", "0", "still_00026102_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「あんっ、あんっ、あっ、ふうっ、んっ、私の中、ぐちゅぐちゅってなってる\nの、分かりますか？　んっ、……先輩のこと、好き、好きって、んっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0204124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「せ、先輩、……好き、好きっ！！　大好きっ！！　愛してるっ！！　んんっ\n、おっぱいも、おまんこも、先輩の好きにしてくださいっ、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0204125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「あっ、凄いっ、先輩のおちんちんも、私のこと好きって言ってくれてる！！\n　んっ、ふうっ、がっ…がっちがちのおちんちんが、私の中でびくびくって！\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0204126" ]},
		{"command":[ "SETIMAGE", "0", "still_00026102_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「んふうううっ、きゅきゅって力を入れたら、おちんちんも返事してくれて、\n私の中で抱き締めあってるのが分かって……ふあああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0204127" ]},
		{"command":[ "SETIMAGE", "0", "still_00026102_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「動くたびに、先輩のことが好きって、……離したくないって、私のおまんこ\n、告白しつづけちゃってます、あんっ、ああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0204128" ]},
		{"command":[ "SETIMAGE", "0", "still_00026102_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「んんんんっ、おっぱい、……乳首、ずっと吸われて、じんじんしてきた、ん\nっ、ふうっ、ミルク、ミルク出るように、先輩の精液、くださいっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0204129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「先輩との子供、できたら、いっぱいいっぱいミルク飲ませてあげられますか\nら、だからっ、膣内に一杯出して……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0204130" ]},
		{"command":[ "SETIMAGE", "0", "still_00026102_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「先輩のこの素敵な、逞しいおちんちんから、子供のもとを一杯出してっ！！\n　全部、全部受け止めますからっ！！　あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0204131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「んふうっ、腰……、こうやって動かしたら、ほら、おちんちんの先っぽ、一\n番奥で吸いついてるの、分かりますか？　ここで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0204132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「ここで……たっぷりと出してくれたら、絶対赤ちゃんできます……そしたら\n、先輩の好きな、お、おっぱいミルク、いっぱい出るようになります……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0204133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「んうううっ、あっ、今の言葉で、おちんちんがさらに膨らんで、イくんです\nね、くっ……ください、私の中に、先輩の精液、くださいっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0204134" ]},
		{"command":[ "SETIMAGE", "0", "still_00026102_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「私、もっ、んんっ、先輩のお口と……おちんちんで、もう、イきそう、んっ\n、おっぱい……吸われて、お、おまんこかき混ぜられて、んんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0204135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「あっ、イっく、先輩と一緒に、イく、んっ、あっ、おちんちん、奥に吸いつ\nいて、イっく、イくうううううううううううううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0204136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「ふああああああっ！！　精液、来たあっ！！　どろどろの、熱いの、注がれ\nてますっ、んんんっ！！　あくうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0204137" ]},
		{"command":[ "SETIMAGE", "0", "still_00026102_02_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「おっぱいも、おまんこも、どっちもどろどろになって、精液とお口で溶かさ\nれてっ、あふううううううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0204138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「あっあっあっ、熱すぎて火傷しそう……んふうっ、凄い、お腹、たぷたぷに\nなってる、先輩の精液で満タンになってます……んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0204139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「んふうっ、凄く、幸せです……先輩に愛されたって証だから……んっ、ふう\nっ、身体の中まで、抱きしめられてるみたい……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0204140" ]},
		{"command":[ "SETIMAGE", "0", "still_00026102_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「あっ……んっ、まだ、おちんちん硬いままですね……あんっ、ふっ、私のお\nっぱいも、まだミルク出ないままですし……んうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0204201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「あ、あの……もう一回……しませんか？　もう一回、先輩の精液もらったら\n、絶対私たちの子供できますし……それに……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0204202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「私も……先輩も……一回じゃ足りないって、おちんちんとおまんこ、お互い\nに……ちゅっちゅって吸いつきあってますよ……ね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0204203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「……んっ、あっ、いきなり腰動かしちゃ、ダメですよぉ……、女の子はもっ\nと優しく……ひあああっ、おっぱいも吸って、んんっ、ふあああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0204204" ]},
		{"command":[ "SETIMAGE", "0", "still_00026102_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「もう、……先輩っ、んっ、私も、気持ちよく、させたいです、んっ、ふうう\nうっ、ほら、おまんこきゅって締めたら、先輩の顔、蕩けてます、んっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0204205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「ふああああっ、下から突き上げるの、んっ、ダメっ、あっ、凄い、これ、頭\nの中までごんごんって、おちんちんで叩かれてる、ふあああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0204206" ]},
		{"command":[ "SETIMAGE", "0", "still_00026102_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「あっあっあっ、先輩のおちんちんが、あっ……私の身体全部こすってるみた\nいで、ふうううっ、んっ、あうううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0204207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「あううううっ、ダメぇ、同時におっぱい吸っちゃダメぇ、ふあああっ、んん\nっ、私だけ、私だけ気持ちよくなっちゃうっ、あんっ、あっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0204208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「ふううっ、こうやって腰を動かしたら、あんっ、ああっ、あくうっ、んっ！\n！　先輩のおちんちんも、気持ちよいですかっ？……んっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0204209" ]},
		{"command":[ "SETIMAGE", "0", "still_00026102_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「二人で、先輩、私だけっ、じゃなくて……二人で気持ちよくなりたいんです\n、んうううっ！！　だって、だって、私……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0204210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「先輩のこと、大好きだから……好きだから、好きな人とは一緒に気持ちよく\nなりたいから、ひあああああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0204211" ]},
		{"command":[ "SETIMAGE", "0", "still_00026102_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「また私の言葉で、おちんちんが……んふうっ、これ、先輩も私のことを好き\nって思ってくれてるって、そういうことでいいんですよね、んっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0204212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「あっ、んんっ、そう思っただけで、なんだか、おまんこの中が、きゅうきゅ\nうって、おちんちんを抱きしめてる……んんっ、ふあああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0204213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「あううっ、んっ、ふああっ、凄い、このまま動いたら、にゅるにゅるって、\n中をかき混ぜられて、んっ、ふうううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0204214" ]},
		{"command":[ "SETIMAGE", "0", "still_00026102_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「おっぱいも、おっぱいも吸われて、んっ、さきっぽ、舌でくりくりってされ\nたら……あっ、もう、全部、身体全部、先輩に味わわれて……んっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0204215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「ああっ、んっ、私の全部、もう先輩のものになってる、んっ、ふあああっ！\n！　んんっ、先輩っ、先輩っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0204216" ]},
		{"command":[ "SETIMAGE", "0", "still_00026102_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「ふああああっ、私の全部、先輩にあげますっ！！　身体も、心も、気持ちい\nいのも、全部っ！！　だから、だからっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0204217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「先輩の子供、私にくださいっ！！　先輩の精液で、私と先輩の子供、くださ\nいっ、んんっ、ああああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0204218" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「あっ、イっく、またおっぱいとおまんこ溶かされて、イっく、先輩に溶かさ\nれて、イくぅ、頭の中、どろどろになっちゃいますぅ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0204219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「ふあああああっ、あっ、イくううううううううううううううううううううう\nううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0204220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
