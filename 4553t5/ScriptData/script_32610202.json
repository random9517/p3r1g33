		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「あくうううううっ、来たあっ！！　二回目の中出し精液、来たああああああ\nっ、んんんっ、ふうううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0204301" ]},
		{"command":[ "SETIMAGE", "0", "still_00026102_02_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「あっ、凄い、二回目なのに、また凄い勢いで私の中、いっぱいにしてる……\nんっ、ふうっ、んっ、どろどろの中に、精液混ぜこまれてる、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0204302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「あっあっあっ、出されてるだけで、またイく、イっく、んんんんんっ！！　\nあくうっ、ふっ、あっ、中、熱い……ひうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0204303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「んんんっ、奥、こすりつけながら最後の一滴まで出てる……私の中に、精液\n塗りつけられてる……ふああっ、幸せ……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0204304" ]},
		{"command":[ "SETIMAGE", "0", "still_00026102_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「おまんこで、おちんちんに残ってる精液も絞るから……全部絞るから……ん\nっ、これで、絶対子供ができます……ふうっ、んくうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0204305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「あっ、うっ、んっ……全部、来た……幸せ……目の前、ちかちかして、頭の\n中、蕩けて、身体も……ああっ、あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0204306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「愛されるって、こういうことなんだって、今分かりました……はあっ、ああ\nっ……んっ、カツマ先輩……大好きです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0204307" ]},
		{"command":[ "SETIMAGE", "0", "still_00026102_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「先輩との赤ちゃん……きっとすっごく可愛い子ができますね……ふふっ、こ\nんなに濃いのを出されたら、絶対できちゃってます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0204308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「赤ちゃん、できたらミルク出ますからね……先輩にも、好きなだけ飲んでも\nらいますよ。……えへへ、赤ちゃん二人できるみたい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0204309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「でも、こうして家族が増えていくんですね……愛する人が増えるって、素敵\nなことだと、そう思います。大好きですよ、先輩。いつまでも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0204310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「ふああああっ、なんで、抜いて……やああっ、精液、中じゃなくて身体に、\nあううううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0204401" ]},
		{"command":[ "SETIMAGE", "0", "still_00026102_02_18" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「んっ、んうっ、あんっ！！　こんな、身体にかけても、赤ちゃんはできない\nのに……できないのに、気持ちいいっ、ふあああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0204402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「膣内とは違うけど、これも……愛されてるって分かる……んんっ、ふうっ、\nうっ、こんなに出されてるのが……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0204403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「この量が、先輩の愛情だって分かります……んんんっ、熱いっ！！　匂いも\n凄くて……それだけ気持ちよかったんですね。ふううっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0204404" ]},
		{"command":[ "SETIMAGE", "0", "still_00026102_02_17" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「私の……身体に……べっとり貼りついて、離れたくないって……ふふっ、精\n液もそんな風に言ってるように見えますね……んうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0204405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「最後の一滴まで私にかけて……あ、ありがとうございます。……んん、愛さ\nれるのは嬉しいけど、やっぱり……お、おまんこにも……欲しかったです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0204406" ]},
		{"command":[ "SETIMAGE", "0", "still_00026102_02_16" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「赤ちゃんができないと、先輩が欲しがってるミルクも……おっぱいから出な\nいまま……ですよ？　いくら吸っても、んっ……出ませんよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0204407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「なので……また今度、する時は絶対……お、おまんこに出してください……\n。先輩の愛の証……、全部私の中に……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0204408" ]},
		{"command":[ "SETIMAGE", "0", "still_00026102_02_17" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「赤ちゃんができたら……そのときは先輩の好きなように……身体にかけても\n構いませんから。……その時までは、お腹の中に出してくださいね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0204409" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「ふふっ、今はそんなにおっぱい吸っても、ミルクは出ませんよ……でも、出\nるまではずっと、ずっと……弄ってください……大好きです……先輩♪」", "NORMAL" ]},
