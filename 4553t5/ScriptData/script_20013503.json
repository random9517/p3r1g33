{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0188" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「さあ、覚悟するがいい。愛に満たされた私達の力は、先程までとは全く違う\nぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022520001" ]},
		{"command":[ "SETCHARA", "0", "char_00000118_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「力を合わせた私達に、怖いものは何もないわ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010022520001" ]},
		{"command":[ "SETCHARA", "0", "char_00000211_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「フン、雑魚が少し力をつけてまとまったからといって、随分と粋がっておる\nようじゃのう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100022520001" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「強がりは見苦しいだけだな。多勢に無勢……さっさと降伏したらどうだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090022520001" ]},
		{"command":[ "SETCHARA", "0", "char_00000122_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「たわけ。お主らだけが、全ての力を得たなどと勘違いせぬことだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100022520002" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「それは……どういう意味ですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_020022520001" ]},
		{"command":[ "SETCHARA", "0", "char_00003004_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ザ・ブライドか。その姿に変身できるのは、お主らだけの特権ではないとい\nうことだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100022520003" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「な、何だとっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022520002" ]},
		{"command":[ "SETCHARA", "0", "char_00000118_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「見せてやろう！　わらわのもう一つの姿を、とくと刮目するがいい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100022520004" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0188" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ふふ……どうじゃ？　これがわらわのザ・ブライドじゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100022520005" ]},
		{"command":[ "SETCHARA", "0", "char_00000313_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「黒い……ドレス……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「無垢な白が、何にも勝るなどと勘違いも甚だしい。全てを塗り尽くす漆黒こ\nそが、最強の力よ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100022520006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "黒い輝きを放つ姿は、威容を与えつつも、確かに一つの美しさも備えていた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「どうじゃ、我が君。そなたの何もかもを受け入れる……それが、この漆黒が\n持つ意味じゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100022520007" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「これから二人きり、たっぷりと子作りに励み、永遠に続くわらわ達の国を共\nに造り上げようぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100022520008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「また世迷い言をっ……こんなのがアタシの分身なんて知れたら、陛下にも申\nし訳が立たないよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022520001" ]},
		{"command":[ "SETCHARA", "0", "char_00000309_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ふん、覚えの悪い女だのう。まだ躾が足りないと見える。そうらっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100022520009" ]},
		{"command":[ "SETCHARA", "0", "char_00000313_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ぐぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022520002" ]},
		{"command":[ "SETCHARA", "0", "char_00000309_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "再びアナザーエファナティカの攻撃が、エファナティカを吹き飛ばす。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「くっ……な、なんて力だい……化け物め……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022520003" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「くく……仮にもわらわの写し身にそう言われるのは心外よのう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100022520010" ]},
		{"command":[ "SETCHARA", "0", "char_00000313_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ふんっ、この程度のことで怯む我々ではないぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022520003" ]},
		{"command":[ "SETCHARA", "0", "char_00000118_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「そういうことだ。一人で分が悪くとも、一斉に掛かれば簡単にはいくまい！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090022520002" ]},
		{"command":[ "SETCHARA", "0", "char_00000122_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「分からぬ奴らめ、身の程を知るがよい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100022520011" ]},
		{"command":[ "SETCHARA", "0", "char_00000313_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「うわぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022520004" ]},
		{"command":[ "SETCHARA", "0", "char_00000118_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ふんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100022520012" ]},
		{"command":[ "SETCHARA", "0", "char_00000313_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「きゃあっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_020022520002" ]},
		{"command":[ "SETCHARA", "0", "char_00003004_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あぐぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090022520003" ]},
		{"command":[ "SETCHARA", "0", "char_00000122_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「さっきまでの威勢はどうした？　所詮、お前たちの人気（じんき）など、そ\nの程度のものということか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100022520013" ]},
		{"command":[ "SETCHARA", "0", "char_00000313_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「くっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022520005" ]},
		{"command":[ "SETCHARA", "0", "char_00000118_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「人気……？　人気って……なんだ……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「人気は……この時空の外部から送り込まれる、強い力のことさ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022520004" ]},
		{"command":[ "SETCHARA", "0", "char_00000309_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「外部から送り込まれる……力？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「アタシも詳しいことは分からないが、一定の周期でここではない、どこかの\n時空から人気という名の力の波動が流れ込む」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022520005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「そいつをどれだけ受けられるかは個人差がある……だが、その人気が明確な\n力の差となって現れるのさ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022520006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「く……私達にもう少し人気があれば、更に変身をすることが出来るのに……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022520006" ]},
		{"command":[ "SETCHARA", "0", "char_00000118_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「人気の総量には限りがある……悔しいが予算の問題がクリア出来ない以上、\n自ずと限界も生じる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022520007" ]},
		{"command":[ "SETCHARA", "0", "char_00000309_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……今、予算とか言わなかったか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「くくっ、どうやら観念したようじゃな。美しく華もある余が持つ人気の前に\nは、お前たちなど足元にも及ばぬ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100022520014" ]},
		{"command":[ "SETCHARA", "0", "char_00000313_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「人気の強さこそがこの世の理……お主らは余にひれ伏す為に存在するのじゃ\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100022520015" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「……それは、どうかしら？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010022520002" ]},
		{"command":[ "SETCHARA", "0", "char_00000211_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「なに……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100022520016" ]},
		{"command":[ "SETCHARA", "0", "char_00000313_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「貴方は、まだ知らないかもしれないけれど……私にはずっと根強く残り続け\nる人気が宿っているのっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010022520003" ]},
		{"command":[ "SETCHARA", "0", "char_00000211_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ぐっ……！？　この……光は……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100022520017" ]},
		{"command":[ "SETCHARA", "0", "char_00000313_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「旦那様っ……もう一度、指輪を私にかざしてっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010022520004" ]},
		{"command":[ "SETCHARA", "0", "char_00000211_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あ……あぁっ、こうかっ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ありがとうっ！　人気なら負けない！　旦那様をっ、カツマを守るのは私だ\nからっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010022520005" ]},
		{"command":[ "SETCHARA", "0", "char_00000211_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0188" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "PLAYBGM", "BGM_007" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「さあ、どうかしら？　これでも、まだ相手にとって不足はない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010022520006" ]},
		{"command":[ "SETCHARA", "0", "char_00000214_01", "6", "CENTER", "6" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「おのれ……余を差し置いて、その派手な振る舞い……放ってはおけぬ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100022520018" ]},
		{"command":[ "SETCHARA", "0", "char_00000313_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「かかってきなさいっ！　人気の現実を教えてあげるわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010022520007" ]},
		{"command":[ "SETCHARA", "0", "char_00000214_01", "6", "CENTER", "6" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ぬりゃぁぁぁぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100022520019" ]},
		{"command":[ "SETCHARA", "0", "char_00000313_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「当たらないわっ！　月影流っ……疾風（はやて）！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010022520008" ]},
		{"command":[ "SETCHARA", "0", "char_00000214_01", "0", "CENTER", "6" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ちっ、ちょこまかと小賢しいっ！　こいつはどうだいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100022520020" ]},
		{"command":[ "SETCHARA", "0", "char_00000313_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ふんっ……当たらなければどうということはないわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010022520009" ]},
		{"command":[ "SETCHARA", "0", "char_00000214_01", "6", "CENTER", "6" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うぉ……なんか、異次元の戦いをはじめてやがる……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「くっ……やはり、幼馴染、清楚、忍者の３属性持ちは強すぎる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022520007" ]},
		{"command":[ "SETCHARA", "0", "char_00000118_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「いや……忍者の属性ってそんなに強いか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090022520004" ]},
		{"command":[ "SETCHARA", "0", "char_00000122_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「少なくとも眼帯よりは強いんじゃないのかい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022520008" ]},
		{"command":[ "SETCHARA", "0", "char_00000309_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「青肌なんて、ニッチな属性持ちには言われたくないぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090022520005" ]},
