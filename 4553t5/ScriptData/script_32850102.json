{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「えっ……？　私を抱きたい、ですか……？　は、はい……。こんな真夜中に\n、殿方と密室で二人きりになった時点で、うすうす覚悟はしておりましたが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0104101" ]},
		{"command":[ "SETCHARA", "0", "char_00028501_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「本当に……私を求めてくださるのですか？　嬉しい……！　ですが、最終確\n認としてお聞きしてもよろしいですか？　私は前にもお話した通り……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0104102" ]},
		{"command":[ "SETCHARA", "0", "char_00028501_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「男性の……。殿方の名前と顔を忘れてしまう呪いにかかっております。それ\nでも……今夜、私を抱いてもいいと？　本気でおっしゃっているのですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0104103" ]},
		{"command":[ "SETCHARA", "0", "char_00028501_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「あっ……！　忘れられない思い出を作ってくださるのですね……？　こんな\n私を、どこにでもいる普通の女として、抱いてもいいと？　あ、あああぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0104104" ]},
		{"command":[ "SETIMAGE", "0", "still_00028501_02_01" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「そうです……っ。ほ、本当は私……！　あなた様にずっと、こうしていただ\nきたかった……！　強引に押し倒されて、裸に剥かれて……。っはぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0104105" ]},
		{"command":[ "SETIMAGE", "0", "still_00028501_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「もう我慢ができないと……耳元で甘く囁かれながら……。んんっ、唇を激し\nく奪っていただきたかった……。っ……ちゅっ……ちゅっ、ちゅぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0104106" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「ええ。私の初めてを、何度でもあなた様に捧げます。もし今宵のことを私が\n明日、忘れたならば……また改めて、初めてを何度でも奪ってください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0104107" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「やがて、私の身体があなた様だけを受け入れ、欲し、愛するまで……。何度\nでも初夜を重ねてくださいませ。私の全てはもう、あなた様だけのもの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0104108" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「……お願いします……っ。口づけをしてください。……んっ……♪　ちゅっ\n、ちゅぅっ……♪　唇を合わせながら、私の色んなところに触れて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0104109" ]},
		{"command":[ "SETIMAGE", "0", "still_00028501_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「んっ、ぁっ♪　胸も……腰も、背中も……足もぉっ……。はぁっ、あぁっ、\nお尻も、……んんっ、あ、アソコも……。おまんこも全部触って……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0104110" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「んっ、んっ……！　わ、かりますか……？　私の肌が、ぬくもりが、どれだ\nけあなた様を求めているか……。あっ、あなた様の手に触れられるだけで」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0104111" ]},
		{"command":[ "SETIMAGE", "0", "still_00028501_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「どれだけ潤って、濡れてくるか……。っう……♪　あぁ、敏感に反応してし\nまって恥ずかしい……。でも、見てください、あっ、あなた様の愛撫で」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0104112" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「花開いていく私を……！　ッんんっ……♪　……んぁっ♪　あぁ……！　は\n、はい……。大丈夫です、たくさん触っていただきましたから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0104113" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「も、もう、準備は整いました。ただ……や、優しく……してくださいね？　\n男女の交わり……性交渉について何も、何も知らないのです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0104114" ]},
		{"command":[ "SETIMAGE", "0", "still_00028501_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「ですから、どうかがっかりしないでください……。……あぁっ、ど、どうし\nましょう。急に火照ってきてしまいました。緊張と焦りがすごくて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0104115" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「……でも……。私はあなた様と一つになりたい……。その逞しく屹立したお\nチンポを、濡れそぼったここに、おまんこに入れて欲しいです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0104116" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「んっ……！？　んんんっ……！　あっ！　う、嘘っ……！？　おチンポはこ\nんなにも硬いのですか！？　あっ……！　ずぶずぶ中に入ってきます！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0104117" ]},
		{"command":[ "SETIMAGE", "0", "still_00028501_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「こ、怖い……！　あっ……、あっぁっあっ……！　……ん……？　あ、あら\n……？　あまり痛みは感じませんね……？　こんなに深く潜り込んだのに」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0104118" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「ふふふ……♪　あなた様の挿入は、特別にお上手なのでしょう。驚きました\n。は、はい。平気です。これくらいなら問題なく……。って、ええっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0104119" ]},
		{"command":[ "SETIMAGE", "0", "still_00028501_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「まだ全て入れていない！？　これから奥まで貫き通す！？　……ああああっ\n♪　そ、そんな……！　あっ！　おチンポ、とても長くて……はぁんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0104120" ]},
		{"command":[ "SETIMAGE", "0", "still_00028501_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「あぁあああああっ！？　な、なんなのですかこれはっ！？　こ、この感覚は\n……っ！　お、おまんこが、私のおまんこがおチンポに突かれた瞬間っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0104121" ]},
		{"command":[ "SETIMAGE", "0", "still_00028501_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「ビリビリと快感がほとばしって……！　んぁああああっ♪　は、はしたない\n声が出てしまいます、あぅううっ？　き、気持ちいい！　こ、これはぁっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0104122" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「……あっ！　あっぁっ！　こ、これがイクということなのですか？　私……\nっ、挿入されただけで絶頂して……？　そ、それに……なぜでしょうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0104123" ]},
		{"command":[ "SETIMAGE", "0", "still_00028501_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「あぅっ♪　んぅうっ、ふぅっ、ううううっ♪　あ、あなた様が軽く腰を揺さ\nぶるだけで、絶頂が……どんどん大きくなっていきます、あっ、あぁんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0104124" ]},
		{"command":[ "SETIMAGE", "0", "still_00028501_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「すごいっ……！　すごいですわっ！？　んぁあああっ♪　こ、これが交わり\n……！　生殖行為、愛し合う方法……っ？　予想よりずっとすごいですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0104125" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「っあああああっ♪　ああああっ、あああああっ……！　ずっと、気持ちいい\nのが終わりません！　どんどんどんどん増していきます……っ！　あっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0104126" ]},
		{"command":[ "SETIMAGE", "0", "still_00028501_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「と、とても心地よいテンポで中を往復されて……！　あっ♪　あなた様のテ\nクニックで、私のおまんこがトロトロに溶けていく……！　あっあっあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0104127" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「だめですっ、絶頂が止まりません！　あぁああっ、イクっ！　イクっ……！\n　ふぁああっ！　初めてなのにこんなにすぐに気持ち良くなれるなんて！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0104128" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「あなた様はぁっ♪　私の運命の御方……！　あっ！　あっ、私の王子様だっ\nたのですね……！　っあっ、まるで初めからこうなるべきだったみたいに♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0104129" ]},
		{"command":[ "SETIMAGE", "0", "still_00028501_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「私のおまんこが、あなた様のおチンポを柔らかく受け入れています！　あっ\n、喜んで迎え入れています！　っんんっ、もっと！　もっとしてください！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0104130" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「私……！　あなた様とするこの行為が！　交わりが好き……っ！　あぁああ\nっ、ヌルヌルした感触が！　すごく、すごく気持ちいいんですぅうっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0104131" ]},
		{"command":[ "SETIMAGE", "0", "still_00028501_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「あっ、はぁっ♪　はぁっ、あぁ……！　あぁっ、あっ、あっ、あぁ……♪　\n硬くて太い、あなた様の分身……！　おチンポを感じます……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0104132" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「っふぅううっ♪　もっと強く！　深く、激しくぅっ……！　私の中にあなた\n様を刻みつけて……！　っあぁああっ！　記憶を失ってもっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0104133" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「このおチンポを見るだけで、ひとりでにおまんこが疼くくらいっ、欲情して\n発情してしまうくらいっ！　おチンポでおまんこを開発してくださぁいいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0104134" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「あっ！　あぁっ！　気持ちいいっ……気持ちいいいっ♪　また、また果てて\nしまいます！　イクぅっ！　初めてなのにまたイキますぅうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0104135" ]},
		{"command":[ "SETIMAGE", "0", "still_00028501_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「ッはぁあああっ！？　あぁああああっ！　あ～～～～っ！　あぁあああああ\nっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0104136" ]},
		{"command":[ "SETIMAGE", "0", "still_00028501_02_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「何……っ！？　なんなのですか！？　あぅううっ♪　私がイッた途端に、お\nまんこの奥に熱い液体が……！　あっ！　あっ、ゾクゾクします、熱いぃっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0104137" ]},
		{"command":[ "SETIMAGE", "0", "still_00028501_02_13" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「こ、これはもしかしてっ……！　あなた様の精液ですか……っ？　あっ……\nんぁああああっ♪　どんどん、どんどん流れこんでまいりますぅうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0104138" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「す、ごい……ひゅごいぃいいいっ……♪　ドクッ、ドクッと一番奥に……！\n　刻みつけるように精液が撃ちこまれて……！　ッんぁああああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0104139" ]},
		{"command":[ "SETIMAGE", "0", "still_00028501_02_14" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「こんな快感を知ってしまったら！　忘れられるはずがありませんっ……！　\n気持ちいい、今まで感じたどんな快感よりも上回る快楽ですぅううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0104140" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「ッああああああっ♪　ああああああぁ……！　ドク、ドク、ドク……っ♪　\nドクドクドクッ……♪　んぅううううっ、クセになってしまいます！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0104201" ]},
		{"command":[ "SETIMAGE", "0", "still_00028501_02_15" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「……あああああ……！　よ、ようやく全て出たようです、ね……？　んん…\n…っ。経験してみると、いつまでも永遠に快感に浸っていたような……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0104202" ]},
		{"command":[ "SETIMAGE", "0", "still_00028501_02_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「あっというまに終わってしまって、もっと、もっと欲しくなってしまうよう\nな……。とても不思議な経験でした……。はぁ、はぁ、はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0104203" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「……はい。射精していただく前とは、自分の身体がまったく違うものに変わ\nった気がします……。特に精液の味を知ったおまんこは……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0104204" ]},
		{"command":[ "SETIMAGE", "0", "still_00028501_02_12" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「やはりあなた様にお願いして正解でした……。……と、お礼を申し上げてい\nる最中ですが……。あ、あの……。なにやら股間がモゾモゾとして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0104205" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「あっ！？　な、なぜ腰を揺らめかせていらっしゃるのですか？　んふっ！？\n　んぁっ、あぁっ……？　あ、あのっ、射精しきれていませんでしたか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0104206" ]},
		{"command":[ "SETIMAGE", "0", "still_00028501_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「それとも私の身体では……、っあっ、お、おまんこではイキきることができ\nずに……？　っうっ♪　そ、そうではなく？　また興奮して……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0104207" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「しおらしく、感謝を述べている私を……。ああっ♪　は、恥じらう私を見て\n、再びおチンポ様が隆起してしまったと……！　え、ええ、かまいません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0104208" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「そうであるのなら……私はとても嬉しいです。っんっ……♪　は、はい……\n。本当は、少し名残惜しかったのです。ですが、もう一度してほしいなんて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0104209" ]},
		{"command":[ "SETIMAGE", "0", "still_00028501_02_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「口に出したら軽蔑されてしまうと思って……！　でも……ふふふっ。気持ち\nが同じなら……っ、ぜひ続けてしてほしい、です……っ。んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0104210" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「あっ♪　今度は私もっ……あんっ、積極的に動きを合わせて……！　っあっ\nぁっあっ♪　あなた様を気持ち良くします……！　ん、こ、こうですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0104211" ]},
		{"command":[ "SETIMAGE", "0", "still_00028501_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「どういう動きがお好みでしょうかっ……！　んぁああっ♪　こうっ……？　\nこれはいかがですっ……？　あはっ！？　お、おチンポ様強いぃいっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0104212" ]},
		{"command":[ "SETIMAGE", "0", "still_00028501_02_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「ええ、ええっ♪　私は充分すぎるほど……おまんこ気持ち良くなってきてお\nりますっ！　あっ！　あっ、さすがですね、素敵な腰使い……んぁっあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0104213" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「喘ぐ声を止められません……！　はぁっ、ああああっ、だ、だめ……♪　気\n持ち良すぎて動けなく、なってしまいます、っあっ……おチンポがすごいぃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0104214" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「私のとても深いところに、ずぶっ、ずぶっと突き刺さって……んぁああっ♪\n　私の中を掻き回して……！　あっ♪　こ、こんなの初めてですっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0104215" ]},
		{"command":[ "SETIMAGE", "0", "still_00028501_02_11" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「くださいっ……、もっと、もっと奥に……！　極限までっ！　一番奥にあな\nた様のおチンポをねじこんでっ……！　突き上げてくださ……、ああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0104216" ]},
		{"command":[ "SETIMAGE", "0", "still_00028501_02_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「そう、です、私の身体が揺れるくらい……！　あっ！　そこっ……そこをえ\nぐってください、ああっ♪　イキますっ、イキますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0104217" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「あああああああ～っ♪　ッぁ……っ♪　も、申し訳ありません、私ばかりが\n先に果ててしまい……！　あなた様のおチンポも、締めつけます……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0104218" ]},
		{"command":[ "SETIMAGE", "0", "still_00028501_02_11" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「精液を絞り上げて……っ、また私の中に、おまんこに射精していただきたい\nのです！　はしたない女神で申し訳ありません……っ、あぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0104219" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「いやらしい女神だと、思われてもいいから……！　欲しいのです！　くださ\nいっ……！　あっ！　あなた様の精子を私の中にくださいぃっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0104220" ]},
		{"command":[ "WAITINPUT" ]},
				
		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「んぁううううっ♪　はぁああっ♪　あぁんっ、あんっ、あぁあんっ……♪　\nあなた様ぁ……！　あなた様ぁあ、すごいですぅううっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0104301" ]},
		{"command":[ "SETIMAGE", "0", "still_00028501_02_17" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「私の中に……！　あなた様の逞しいおチンポからっ……！　大量の精液がド\nッと流れこんでまいりました……っ♪　あぁっ、んぁああっ、あぁぁんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0104302" ]},
		{"command":[ "SETIMAGE", "0", "still_00028501_02_18" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「熱い……ッ♪　狭いおまんこの中だけではとても受け止めきれない量ですっ\n……！　力強く脈打つおチンポ様から、ビュルビュルと幾度も放たれて♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0104303" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「あっ♪　私の中があなた様の種でいっぱいに……っ♪　あっ♪　もうこれ以\n上入りませんわ♪　それなのに……まだっ、次々に入ってきます、あぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0104304" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「身体の中を満たす、ドロドロの精液……。満ち足りた感覚……っ♪　なんで\nしょう、この心地よさは……うっとりしてしまいますわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0104305" ]},
		{"command":[ "SETIMAGE", "0", "still_00028501_02_17" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「ああっ……！　出来ることならこのまま永遠に……っ、あなた様の精を受け\nて、一つに交わったまま……！　互いの記憶を共有し続けていたいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0104306" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「っぅ……♪　ふふふふ、申し訳ありません……♪　あまりに強烈な射精を二\n度もしていただいたおかげで、少し……クラクラしておりました……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0104307" ]},
		{"command":[ "SETIMAGE", "0", "still_00028501_02_16" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「この、お酒に酔ったかのような酩酊感……。全身がぽかぽかと温まった満足\n感……。殿方に抱かれるとは、このように幸せなことなのですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0104308" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「……ええ。忘れたくないです。今日ほど我が身を蝕む呪いを疎ましく思った\nことはありません。ですが……同時に安心もいたしました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0104309" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「もし、私が記憶を無くしても……あなた様は何度でも、私をこうして抱いて\nくださいますよね？　そのことが、ひたすらに嬉しいのです……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「あ、ああ……！　これは一体どういうことなのでしょうっ……！　おまんこ\nだけではなく私の身体までもが熱を帯びて……！　あっああああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0104401" ]},
		{"command":[ "SETIMAGE", "0", "still_00028501_02_19" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「あ、あらっ……！？　あなた様！　精液が私の身体の上に！？　んっ、おチ\nンポが抜けてしまわれたのですか！？　あっ、あっ、ど、どうしましょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0104402" ]},
		{"command":[ "SETIMAGE", "0", "still_00028501_02_20" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「貴重な子種が……！　あぁんっ！　で、でもこれはこれで……っ！　あなた\n様のぬくもりに包まれて……か、感じてしまいます……！　んんんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0104403" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「もっと……もっとかけてくださいませ！　私の肌を真っ白に染め上げて……\n！　あっあっあっ、鮮烈な記憶を作ってくださいませ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0104404" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「っん……！　精液というものは、こんなにネトネトとしていて……あぁ、卑\n猥な粘り気を帯びているのですね……っ。はぁ、はぁ、あぁ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0104405" ]},
		{"command":[ "SETIMAGE", "0", "still_00028501_02_19" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「はっきりとこの目で見てしまうと、見慣れた自分の裸身ですら……いやらし\nいオブジェに変わってしまったかのように思えます……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0104406" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「っあっ……♪　き、気持ち良く射精できましたでしょうか……？え、ええ。\nおまんこの中に射精されるものと覚悟しておりましたから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0104407" ]},
		{"command":[ "SETIMAGE", "0", "still_00028501_02_21" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「初めは驚きましたけれど……。嫌ではありませんでしたよ。むしろ、こうい\nった方法があったのかと、驚きましたが……こ、興奮いたしました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0104408" ]},
		{"command":[ "SETIMAGE", "0", "still_00028501_02_19" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「……私の記憶が、きちんと残ってくれるのかどうかはまだわかりません。で\nすが、少なくとも過激な経験はできました。ふふふっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0104409" ]},
		{"command":[ "SETIMAGE", "0", "still_00028501_02_21" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「今だけは……呪いのことを忘れて、あなた様の臭いに、ぬくもりに身を委ね\nていたい……。願わくば、こんな時間が永遠に続きますように……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0104410" ]},
		{"command":[ "SETIMAGE", "0", "still_00028501_02_20" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}