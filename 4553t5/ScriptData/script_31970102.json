{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「……ふーん……。今日の逢引はここでするの？　なんだか殺風景な部屋……\n。我はもうちょっと楽しそうなところに行きたいんだけどなー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0104101" ]},
		{"command":[ "SETCHARA", "0", "char_00019701_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「って、やっ！　な、何してんのよっ！　いた……いたぁい！　手首っ……手\n首をひねりあげて、……あっ！？　う、嘘でしょお！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0104102" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00019701_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「っ……自分が何をしてるかわかってるわけ！？　こ、こ、このファンタズマ\nちゃんの手を……腕を拘束するなんて……許せない……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0104103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「ねえっ、なんとか言いなさいよっ！　……ん？　『今日こそお前をわからせ\nてやる』……？　な、なによそれ、わからせるって何……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0104104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「あっ……！　んっ、ぁっ……あっ！　ちょ……ちょっとぉ！　乳首……乳首\nだめ、つねんないでっ！　お股も今、び、敏感だからっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0104105" ]},
		{"command":[ "SETIMAGE", "0", "still_00019701_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「やぁっ……やぁだァ……！　やらしい触り方しないでよ！　わ、我は見下す\n者であって……一方的に嬲られるなんてやだぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0104106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「ンッ……♪　ん、ん、ん、んんん……！　ふぅうっ……ふぅう……んぁっ！\n？　あっ……あっ、あっ、なでなでやめて、やめ……んぁうう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0104107" ]},
		{"command":[ "SETIMAGE", "0", "still_00019701_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「くすぐった……い、イタズラやめてぇ……！　わ、悪かったわよっ！　いつ\nもこき使って、上から目線で苛めて悪かったからっ、反省してるからっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0104108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「だからすべすべしないでぇええ……！　っん……！　んっ……！　あ、あん\nたが我のこと、いつもエロい目で見るから、触るから……！　あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0104109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「は、反応……しちゃうの！　……くぅううっ！　ホントになんなのこの縄ぁ\n……！　我が、我が解けないなんて……。って、やっ、あ、ぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0104110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「おっぱいっ……おっぱいぐにぐにしないでよぉ……！　わ、かってるもん…\n…ッ、小さくてみっともないって……。……んひゃううっ、ひゃあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0104111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「『反応が可愛い』？　ば、ばっか……っ！　そんなこと言ったって騙されな\nいんだから……！　……んんっ、こらぁっ、乳首なぞるなぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0104112" ]},
		{"command":[ "SETIMAGE", "0", "still_00019701_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「そのぽっち、ぽっちをこすられると……、ふぅうっ……♪　勝手にお股が湿\nってきて……。……あっ！　股間を触って欲しいって意味じゃなくって！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0104113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「ん、ふ、ふぅっ、ふぅううっ……！　なんなのよぉ……！　あんたの両手っ\nて……やらしいことするために生えてるの！？　乳首と股間やめてぇえっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0104114" ]},
		{"command":[ "SETIMAGE", "0", "still_00019701_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「……い、いじんないで、よぉ……！　っはぁっ、は、ぁっ、はぁっ……！　\n『縦筋クチュクチュしながらツンツン乳首をもてあそぶの最高』ぉ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0104115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「く、ぅう～～っ……！　い、言わせておけばぁ……っ！　『愛液が垂れてき\nた』？　そ、そうでしょ、手……汚れるからもうやめたらぁ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0104116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「ん……ンッ、ん、ん、ふ……♪　ふぅうっ……うう……！　乳首……乳首、\nジンジンする……っ、ぷっくり勃起して……そこをこねられ、てっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0104117" ]},
		{"command":[ "SETIMAGE", "0", "still_00019701_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「同時にお股を太い指が……、ゆびっ、が、何度も何度もなぞって、めくって\n……！　あぁっ！？　ひ、ぅ、んひぃっ、ひぃっ……ねえ、ねえぇっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0104118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「むずむずするぅ……っ！　胸の先っちょと！　アソコがもどかしくってたま\nんないよぉ……！　あんただってムラムラしてるんでしょ、だったらっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「だったら……し、してよ……。今だったらあんたのエッチい気持ちを解消し\nてあげるっ、我の身体を好きにさせてあげるから、だから……だから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0104120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「い、入れたらいいじゃないっ！　……え？　可愛くおねだり出来たら入れて\nあげる、ですって？　……ち、違う、我がエッチしたいんじゃない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0104121" ]},
		{"command":[ "SETIMAGE", "0", "still_00019701_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「あんたが我慢できなくって襲うのっ！　ファンタズマちゃんを無理やりレイ\nプするのっ！　……『嫌ならしない』？　な、なに言ってんのよぉお！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0104122" ]},
		{"command":[ "SETIMAGE", "0", "still_00019701_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「……嫌だからっ！　おねだりなんてしないしぃ！　……ん……？　あ、ほ、\n本当にやめるつもりぃ？　指の動きが弱く、なって……。あ、ぁ、あ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0104123" ]},
		{"command":[ "SETIMAGE", "0", "still_00019701_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「……く、くぅうう……！　わ、わかったわよ！　わかったわよぉ！　……い\n、入れ、て……もいいよ……。もっと媚び媚びに？　ぁ、あぅう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0104124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「い……入れてくだ、さい……ぃ！　ちょっと両手でぐちょぐちょされただけ\nで、愛液ねちょねちょにしちゃう悪い子の我の、悪いおまんこにっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0104125" ]},
		{"command":[ "SETIMAGE", "0", "still_00019701_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「ち、ちんぽ……隊の長のすっごいの、い、入れてほしい……！　ずぶって、\nぐちゅぅうって全力で容赦なく犯すみたいに乱暴に挿入してくださいぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「ん……ッ、ん、ん、ん、ん、んんん……！　ううう……っ！　あれっ……？\n　や、やだ、あんたのって想像より三倍くらいデカくない！？　わああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0104127" ]},
		{"command":[ "SETIMAGE", "0", "still_00019701_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「そ、そんなの入れたら裂けちゃう！？　……ぁ、わ、我がおねだりしたんだ\nからやめない？　……我も入れてほしいけど、でも……あ、あ、あッ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「ん、ぐぅうううううっ！　やっぱりめちゃめちゃふっといじゃないいぃいっ\n……！　んあああああっ！　広がってるっ、アソコ広がってるぅうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「い、やぁあっ、やあぁあっ……！　硬すぎるぅ、重いぃいっ……！　あ……\nあ、あ……棍棒でもねじこまれたみたいに、あっ、おまんこ貫いて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0104130" ]},
		{"command":[ "SETIMAGE", "0", "still_00019701_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「こ、壊れちゃう、おまんこ柔らかいのに壊されちゃうよぉ！　……あっ！　\nんっ、ぅっ、うっ、くぅうんんっ……優しくぅ、動くなら優しくしてぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「……ぁッ！　……あっ！　あっ、ぁっ、あっ……！　あああ……、ヤバ、い\n……ぃ、ぬごっ、めごっ、ておまんこ全体もってかれて、めくられて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「ゆ、ゆっくりっ、ゆっくりしてるのに身体全体ひっくり返されそう……ぅっ\n！　わ、我の身体、小さいから……全部串刺しになったみたいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「あ、はっ、はぁあっ、はぁああっ……あぁうううっ……！　あっ！　あっ！\n　あっ！　我と隊の長の体格ぅ……全然合ってないし……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「こんなのオトナが子どもを犯してるのといっ、しょ、……んああああっ！　\n大きいぃ！　隊の長のおちんぽ、入る限界のサイズ超えてるよぉおっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0104135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「んぐぅうっ！　あぐぅうっ、うぐぅうっ、あうううっ！　……『びしゃびし\nゃに濡れてるから痛くないだろ』？　うん、うん、痛くはない、けど！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0104136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「大きすぎて……熱すぎて、熱した鉄棒出し入れされてるみたいなのっ……！\n　ん、んぅうう……！　おまんこの形、変わっちゃう……拡がっちゃう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0104137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「ちんぽにガバガバにされちゃう……っ！　……『キツキツで超気持ちいい』\n？　あっ！　それは嬉し……。い、いやっ、なんでもないけどぉっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0104138" ]},
		{"command":[ "SETIMAGE", "0", "still_00019701_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「……ンッ！？　なんで、我が怖がってる顔みて更に勃起強めるのよぉっ！　\nもう無理っ、もう無理、これ以上はおおきいの無理……！　えぇっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0104139" ]},
		{"command":[ "SETIMAGE", "0", "still_00019701_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「怯えてる姿見たら射精しそう！？　悪趣味ぃっ！　あっ！　こらぁっ！　出\nさないでっ、出さないでよぉ、まだ……まだ慣れてないの、に、あぁあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「や、やぁああああっ♪　無許可で中出しとかぁあ♪　やだっ、びゅるっ、び\nゅるって出てるの感じるっ、お腹の感覚でわかるっ、きゅぅっ、ううっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0104201" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019701_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「おちんぽビクビク、ビクビクしてるっ……！　射精……射精ぃ……！　これ\nが種付けぇ……！？　あっ！　人間の種付けぇ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「強いオスがメスを孕ませる、モノにする瞬間……っ！　んくぅっ！　またび\nゅるぅって！　あっついお汁がぴゅーぴゅー入ってくるぅう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「……はぁーっ……♪　はぁー……、はぁー……っ……。う、うぅう……。ひ\n、ひどい目にあわされたぁ……。って、何？　また勝手に動いて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0104204" ]},
		{"command":[ "SETIMAGE", "0", "still_00019701_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「あふっ！？　ふぁあっ！？　ん、ぁっ、あぁっ！　『一発じゃヤリ足りない\n』？　ま、待ってよ、今出したばっかりじゃない、もうするのぉ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0104205" ]},
		{"command":[ "SETIMAGE", "0", "still_00019701_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「化け物みたいな耐久力じゃないっ……！　……やぁああ♪　精液で滑りがよ\nくなって……！　え？　なに？　なに？　あっ、やだ気持ちぃ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0104206" ]},
		{"command":[ "SETIMAGE", "0", "still_00019701_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「ちんぽがおまんこヌポヌポしだして……！　えっ？　急に気持ちくなってき\nたぁ……♪　大きさ、全然変わんないのに……硬いままなのに！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0104207" ]},
		{"command":[ "SETIMAGE", "0", "still_00019701_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「スムーズに入ったり♪　あっ♪　抜かれ、たり……あぁっ♪　出たり入った\nり♪　出たり入ったり♪　お♪　ぉ♪　ばかに、ばかになるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「おまんこ、精子まみれでドロッドロに蕩けてきて……♪　んほっ♪　入口だ\nけじゃなくってぇ……中、ぜんぶ……ううん、奥の奥、までぇ入るぅ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「あっ♪　んゆぅうっ♪　奥っ……奥突かれると……んぐぅっ♪　身体が、身\n体が揺れ、て、気持ちいいところにめりこむぅ、当た、るぅうっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0104210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「あっあぁんっ、んぁっ、あっ、あぁっ、あーっ♪　あーっ♪　ねぇえ♪　あ\nん、まり揺らさないでぇ……色んなところにこすれるからぁあっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0104211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「ガックンガックン揺らされながら……あああっ♪　あんたなんかに好き勝手\nされて……！　ひぁぁあっ♪　なのに、なんで、なんで気持ちいいのよぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0104212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「ッああああ♪　ああっ、あああっ……！　や、だ……ぁあ♪　我の蜜、あん\nたの精液と混じりまくって……太ももにつたいおちて……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0104213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「すっごいすっごいやらしいよぉお……！　おまんこも！　何にもしてないの\nに、どんどんちんぽに絡みついて、まとわりついちゃって……んぐぅ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0104214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「これじゃああんたのこと、す、好き、みたいじゃないぃ♪　勘違いしないで\nよぉっ♪　好き♪　なのは♪　デカチンだけであんた……じゃないぃ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0104215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「違う♪　からぁ……♪　こんなのただぁ、あんたのちんぽが強すぎる♪　か\nらぁ……身体が女にされちゃってるだけ、おまんこ喜んじゃってるだけ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0104216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「……んふぅうう♪　ふぅうっ♪　ふぅううう～～～♪　ずっぽっずっぽって\nちんぽ♪　ちんぽ動かされると……めまいするぅ、腰、ガクガクでぇえ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0104217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「んあああ♪　ふぅうう♪　おちんぽっ、好きになっちゃうぅ♪　あっ♪　あ\nっ♪　深いとこまでぞりぞりえぐられて……やだああ、もうだめええ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0104218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「イ……っちゃうう、イかされるぅっ♪　このファンタズマちゃんがッ……人\n間なんかにイかされちゃううっ……あーーーーーっ♪♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0104219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「ゆるっ、してぇ♪　もぉ許してよぉお！　降参！　降参だからぁ！　我の負\nけぇ♪　あんたのちんぽに負けちゃったぁ！　……んんんッイッくぅう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0104220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「うぁああああああんん♪　あぁっ……二発目ぇ……！　どくどくっ、どくど\nく好きぃ～～～っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0104301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
