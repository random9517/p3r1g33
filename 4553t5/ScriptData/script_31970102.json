		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「あはっ♪　あはっ♪　シャレになんないくらい出て……るぅ♪　一番奥でビ\nュップビュプ出てるぅ……あはははは♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「絶対、絶対妊娠してるぅ～……♪　あっ♪　あっ、あっ……♪　でもいいっ\n、気持ちいいから……いっぱいイッてるからいいのぉっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0104303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「ん～～～～♪　おまんこっ、おまんこ締めて、搾り取れるだけ搾り取ってや\nるぅ～……♪　……うぅっ♪　あああっ、とんでもない量を……ぉ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0104304" ]},
		{"command":[ "SETIMAGE", "0", "still_00019701_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「ファンタズマちゃんのぷにぷにおまんこに注いで、孕ませて……♪　この鬼\n畜ぅう……♪　力強過ぎでしょぉ、まったくぅうう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0104305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「あ、かっ……赤ちゃんっ、赤ちゃん出来るまでぴゅるぴゅるっ、ぴゅるぴゅ\nる……うああああ♪　あっつい精子が溜まって、お腹……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0104306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「おなかいっぱいになっちゃったぁ……！　はぁ、はぁ、はぁああ……♪　見\nてぇ……♪　下腹がぽっこり膨らん、で……わかるでしょぉ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0104307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「これっ……ぜーんぶあんたが入れた精液だから……！　んぁああ♪　たぽた\nぽ……♪　ぷりっぷりの新鮮な精液ぃ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0104308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「あー♪　だめだぁ……！　快感すごすぎて……中出し愛しちゃうぅ♪　中出\nし気持ちいい♪　中出し最高ぉ……はぁっ、はぁっ、はぁああ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「ケダモノみたいに交尾して、人に種付けされるなんて……♪　敗北するのも\n悪くない、けど……してやられちゃって悔しいぃ……♪♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「あひぃいいっ！　あぁあっ……あああっ！　イクイクぅう……♪　脚がプル\nプルして止まんない……んぁっ、あ、あんたねぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0104401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019701_02_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「我がイッてる最中におちんぽ抜くとかありえない……、あっ！？　ふぁああ\nっ！　外出し！？　ファンタズマちゃんの身体に、直撃ぃ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0104402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「やっ……♪　あっ、あっ、あぁっ……！　やぁっ！　も、もったいないぃ…\n…！　ねえ、ねえ、尋常じゃない量出てるよぉ、入れてよぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0104403" ]},
		{"command":[ "SETIMAGE", "0", "still_00019701_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「あぅぁああ……っ♪　身体にかけられる、のも、これはこれで気持ちいい…\n…けど、あったかくって、エッチぃけど……ぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0104404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「この量どぴゅーっ♪　どぴゅーっ♪　っておまんこに注入してもらうはずだ\nったのにって思うと損した気分になるじゃないぃ♪　ばかぁあ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0104405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「『ファンタズマちゃんを征服した証』ぃ？　せ、征服なんてされてない……\nしって、話してる時にまた出して……！　ばかばかばかっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0104406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「ふぁああっ♪　ああっ♪　真っ白で、濃ゆくてさいってーな精子ぃい……♪\n　人の子のくせにナマイキぃ……でも、でもでもでもぉお♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0104407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「あんたの色に染められるのも……、わ、悪くはない、かも……。んっ！？　\nよ、良くはないわよっ、……中に出される方がいいしっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0104408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「くぅううう～！　な、何笑ってるのよぉお！　我は一度くらいの外出しじゃ\n、あんたに屈したりしないんだからねっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0104409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「だから……だから、オトしたいなら、何度も何度もしてくんなきゃ……。…\n…わ、わかったぁ！？　返事は『はい』しか許さないからっ」", "NORMAL" ]},
