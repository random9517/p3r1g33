{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「最近はお互い忙しくて、こうして二人きりになる時間も少なかったわね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0204101" ]},
		{"command":[ "SETCHARA", "0", "char_00015902_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「ちょ、ちょっと……！　いきなり胸を触るだなんて……！　もう少し、ムー\nドというものを大切にして頂戴……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0204102" ]},
		{"command":[ "SETCHARA", "0", "char_00015902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「我慢できないのはわかるけど……！　んんっ……！　だからって、こんな強\n引な感じは……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0204103" ]},
		{"command":[ "SETCHARA", "0", "char_00015902_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「ま、まずはキスぐらいしなさい……！　最低でも、それぐらいの段取りは…\n…んっ、ちゅっ……ちゅ、ちゅぱ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0204104" ]},
		{"command":[ "SETCHARA", "0", "char_00015902_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「きゃあああぁ！？　パンストを破かないで……！　わ、わかったから、少し\n落ち着いて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0204105" ]},
		{"command":[ "SETCHARA", "0", "char_00015902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「まったく、あなたという人は……！　初めてセックスをした時と、なにも変\nわってないわね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0204106" ]},
		{"command":[ "SETCHARA", "0", "char_00015902_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「強引に私を押し倒して、オマンコにオチンチンを挿れてズポズポしてきて…\n…！　酷い初体験だったわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0204107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「今もこうして……んっ、くうぅ……！　ぱ、パンストを破って、無理やり挿\nれようとして……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0204108" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00015902_02_02" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「オマンコが濡れてるって……し、仕方ないでしょう！？　私だって、その…\n…期待してたのだから……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0204109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「んんっ……！　そんなに強くいっぱい揉まないで……！　乳首が立ってるの\n、バレちゃうからぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0204110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「あはぁん……！　オマンコが勃起したオチンチンでぬちゅぬちゅ擦られて…\n…んっ、ふああぁ！　あっ、あひいぃん！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0204111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「クリトリスも激しくズリズリされてるぅ……！　だ、ダメ……！　こんなこ\nとされたら、挿れられる前に、イッちゃうわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0204112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「す、少しぐらいなら乱暴にしていいから……早く、あなたのオチンチンをオ\nマンコに挿れて頂戴……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0204113" ]},
		{"command":[ "SETIMAGE", "0", "still_00015902_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「逞しいオチンチンでいっぱいオマンコをズポズポして、気持ちよくさせて…\n…！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0204114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「んっ、あああっ……！　あっ、ふああぁ……！　は、入ってくるっ……久々\nのオチンチン、オマンコに挿れられて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0204115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「あはあああぁ……！　オマンコのお肉をぬりゅぬりゅって掻き分けて、全部\n入ってきてるわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0204116" ]},
		{"command":[ "SETIMAGE", "0", "still_00015902_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「うっ、くううぅ……！　お、奥に当たって……ひいぃん！？　そこ、グリグ\nリしないで……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0204117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「そんなにされたら、気持ちよくなって子宮が降りてきちゃうわ……！　だか\nら、もうやめ……あひいいぃん！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0204118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「だ、だから……！　オマンコの奥をねちっこく責めないでぇ……！　本当に\n、感じすぎるの……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0204119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……わ、わかってくれたのね……なら、もっとゆっくり……ああ\nぁ！？　あっ、やっ、あはああぁ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0204120" ]},
		{"command":[ "SETIMAGE", "0", "still_00015902_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「急に速く動くのもダメぇ！　Ｇスポットと子宮口が、オチンチンで交互にぐ\nりゅぐりゅされてるからぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0204121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「あああぁ……！　さっきよりも感じるっ！　オチンチンで激しく突かれて、\nオマンコ悦んでるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0204122" ]},
		{"command":[ "SETIMAGE", "0", "still_00015902_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「ガチガチの勃起オチンチンのカリが、オマンコを無理やり引っ掻いて、抉っ\nてくるのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0204123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「ああぁ、あぁん！　くっ、あっ、ふああぁ……！？　久々だから、余計に感\nじてるっ！　気持ちよくなってるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0204124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「ひいいぃん！　オマンコほじほじしながら、乳首クリクリするのダメぇ！　\n敏感になってるのに、そんなことしないでぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0204125" ]},
		{"command":[ "SETIMAGE", "0", "still_00015902_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「あっ、ふああぁ……！　んっ、ぐううぅ……！　き、気持ちいい！　セック\nス気持ちいいわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0204126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「あ、あなたも気持ちいい……！？　私のオマンコ、ちゃんとオチンチンにご\n奉仕できてるかしら……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0204127" ]},
		{"command":[ "SETIMAGE", "0", "still_00015902_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「んくううぅ！？　お、オチンチンで返事しないでぇ！　そんなに膣内で暴れ\nられたら、オマンコ壊れちゃうわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0204128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……うぐっ、あっ、んひいいぃ！？　オチンチンが膨らみながら\n、ビクビクしてるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0204129" ]},
		{"command":[ "SETIMAGE", "0", "still_00015902_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「それ、イク合図でしょう……！？　だ、ダメよ！　ちゃんと避妊しないと…\n…！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0204130" ]},
		{"command":[ "SETIMAGE", "0", "still_00015902_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「膣内で出されたら……子宮にどぴゅどぴゅ精子出されたら、赤ちゃん出来ち\nゃうじゃない……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0204131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「お願いだから、出す時は抜いてぇ！　じゃないと、私の子宮が悦びながら、\nあなたの精子を飲み干しちゃうからぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0204132" ]},
		{"command":[ "SETIMAGE", "0", "still_00015902_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「あああっ！　だ、ダメ……！　私もイク……！　ね、お願い……！　だ、出\nすなら外に……！　外に出してぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0204133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「んひいいいぃ！？　いやあぁ！　おっぱい掴んでホールドして、オチンチン\nで子宮口グリグリしながら、腰を振らないでぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0204134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「あっ、あっあっ！　もうダメぇ！　オマンコの奥ズポズポされながらイっち\nゃうっ！　膣内出しされちゃうううぅ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0204135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「あはあああぁんっ！　お、オマンコの奥に出されてる……！　ドロドロの濃\n厚ザーメン、びゅるびゅる出てるわっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0204136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00015902_02_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「子宮の気持ちいいところに、精子流れ込んできてるのわかるわ……！　こん\nなの、絶対に妊娠しちゃう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0204137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「ああっ、んっ、はひいいぃ……！？　た、種付けされながら、またイッ……\nイクうううぅ～～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0204138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「あ、ああぁ……す、すごいわ……！　こんな絶頂、初めてよ……！　お腹の\n奥から、震えるような気持ちよさが駆け巡ってくるの……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0204139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「はぁはぁ……はああぁ……たくさん、出したわね……精子かき出すから、早\nく抜いて……きゃああぁん！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0204140" ]},
		{"command":[ "SETIMAGE", "0", "still_00015902_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「ちょ、ちょっと……！　まだオチンチン大きくなってるの……！？　そ、そ\nれに、いまビクンって……はひいぃん！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0204201" ]},
		{"command":[ "SETIMAGE", "0", "still_00015902_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「ガチガチのオチンチンが、私を犯し足りないってオマンコの膣内で言ってる\nのわかるわ……！　でも、もう許して……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0204202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「ああぁん！　あっ、あっ！　んひいいぃ！？　わ、わかったわ！　オマンコ\n締めるからっ！　オチンチンシゴいて、気持ちよくするからぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0204203" ]},
		{"command":[ "SETIMAGE", "0", "still_00015902_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「だからもう激しくズポズポしないでぇ！　頭がおかしくなっちゃうわ！　イ\nヤらしいことしか、考えられなくなっちゃうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0204204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「はひいいぃ！？　あぐっ、あっ、あぁん！　ち、乳首とオマンコ、同時にほ\nじほじされてるっ！　気持ちいいとこ、知り尽くされてるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0204205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「さっきから軽くイキっぱなしなのぉ！　敏感になったオマンコが、ずっと痙\n攣してるみたいになってるのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0204206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「そ、それにこの体勢……簡単に亀頭がオマンコの奥を小突いてきて……！　\nあっ、んぐっ、ひぐうううぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0204207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「あああぁん！　イクっ！　イッてるぅ！　気持ちよくて、オマンコが自然と\nぎゅううぅって、オチンチン締め上げてるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0204208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「お、お願い！　イキすぎて怖いのっ！　だからもっと、優しく、ゆっくり…\n…んんん～～～っ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0204209" ]},
		{"command":[ "SETIMAGE", "0", "still_00015902_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「ゆっくり引き抜くのも、すごく感じるぅ！　カリ首がオマンコの段差を、ゆ\nっくりと削って降りてくる感じがするわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0204210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「速くても遅くてもダメだなんて、もうどうすればいいのよぉ！　感じすぎて\n、オマンコがおかしくなっちゃうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0204211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「あひっ、あっ、うぐううぅ！？　でこぼこのオチンチンが、また私のオマン\nコのお肉をぐちゅぐちゅ抉ってるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0204212" ]},
		{"command":[ "SETIMAGE", "0", "still_00015902_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「それにオチンチンがパンパンに膨らんで……！？　ま、また出すのっ！？　\nエッチな子種汁、どぴゅどぴゅしちゃうのぉ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0204213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「もう膣内でも外でもどっちもいいわっ！　あなたの気が済むまで、ザーメン\n出してっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0204214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「ビクビクしてるオチンチンから、濃厚精子を私にびゅるびゅる出してぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0204215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「あっ、あひっ！　んっ、くうぅ！　あっ、あっ、ああああぁん！　ピストン\nもどんどん早くなってるのわかるわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0204216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「私もイクッ！　オマンコイクぅ！　さっきよりも大きい快感が、子宮の奥か\nらこみ上げてきてるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0204217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「あ、あなたももう限界なのね！？　いっ、一緒に！　一緒にイキましょう！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0204218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「ああっ、あっ、あはあぁん！　くるっ！　きちゃうぅ！　オマンコイッちゃ\nううぅ！　オチンチンに絡みついて、ぎゅ～ってしてるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0204219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「イクッ！　イクッ！　イクうううぅ！　あなたのオチンチンとザーメンで、\n私をあなた色に染め上げてえええぇ～～～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0204220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「んほおおおぉ～～～！？　精液出てるっ！　膣内にドクドク出てるぅ！　オ\nマンコイクッ！　イッぐうううぅ～～～～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0204301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015902_02_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「妊娠させる気満々の孕ませ汁、私の子宮に流し込まれてるのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0204302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「ああああぁ～～～っ！　ダメっ、ダメぇ！　赤ちゃん出来ちゃうのに、嬉し\nくてイクッ！　排卵してイッちゃうううぅ～～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0204303" ]},
		{"command":[ "SETIMAGE", "0", "still_00015902_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「あっ、ああぁ……！　うううぅ……！　ま、まだ出てるっ……！　熱いザー\nメンで、オマンコ火傷しそうだわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0204304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……お、オチンチン気持ちよすぎるわ……こんなの知ったら、も\nう戻れないじゃない……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0204305" ]},
		{"command":[ "SETIMAGE", "0", "still_00015902_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「多少強引だったけど……身も心も、完全にあなたのモノになったわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0204306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「これからは……いつでも、どこでも……私のオマンコで、オチンチンをズポ\nズポしていいのよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0204307" ]},
		{"command":[ "SETIMAGE", "0", "still_00015902_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「んんっ……！　またオチンチン跳ねさせて……！　まだオマンコしたいの…\n…？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0204308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「これだけ動いて、出した後なのに……本当に絶倫なのね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0204309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「いいわよ……もうこの際だし、時間も気にせずに朝までたくさんセックスし\nましょう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0204310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「お、オチンチンが抜けてぇ！？　あ、熱いっ！　身体にザーメン降り注いで\nるぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0204401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015902_02_17" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「妊娠しちゃいそうになるぐらい、肌の上に精液降りかかって……！　べった\nりと染み付いてくるわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0204402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「触ってないのに、ヌルヌルしてるのがわかるぐらい濃厚で……！　ニオイも\n濃くて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0204403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「あああぁ……！　こ、これが女を堕とす香りなのね……！　本当に、ニオイ\nだけでイッ、イクうううぅ～～～～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0204404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「はああぁ……あっ、んっ、あはあぁ……！　精液でダメにされちゃったわ…\n…私のオマンコも頭も、あなたのことでいっぱいよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0204405" ]},
		{"command":[ "SETIMAGE", "0", "still_00015902_02_16" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「もうこのニオイと感触から、離れられないわ……ずっと、お腹の中にザーメ\nンをため込んでいたいぐらいだわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0204406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「まだまだ精子を注いでやるですって……？　そんなこと言われたら、嬉しく\nてイッちゃいそうだわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0204407" ]},
		{"command":[ "SETIMAGE", "0", "still_00015902_02_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「でも……いいわよ。もっと、あなたのオチンチンを頂戴……私の身体の好き\nなとこに、精液どぴゅどぴゅして頂戴……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0204408" ]},
		{"command":[ "SETIMAGE", "0", "still_00015902_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「あなたが望むままに、いつでもセックスさせてあげるわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0204409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「んっ、あっ……！　と、とりあえず、この服を脱いでから……ちょ、ちょっ\nと……！　んっ、あっ、ああぁ！　ああああぁん！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0204410" ]},
		{"command":[ "SETIMAGE", "0", "still_00015902_02_16" ]},
		{"command":[ "WAITINPUT" ]},
