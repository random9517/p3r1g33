		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「やぁっほ～☆　隊長っぴ～☆　今日もアゲアゲでガンバっちゃってるぅ～？\n　んでんでー、どしたん？　いきなりお呼び出しとか……ボーナス？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0103101" ]},
		{"command":[ "SETCHARA", "0", "char_00001501_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「あっは☆　アタシと隊長っぴの仲じゃーん☆　そんなに気ィ使ってくれなく\nていーのにぃ……って、ハァ？　違うんかい！　何、パワーアップぅ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0103102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「んなことしなくても、アタシは今のままで最強☆　なんですけど☆　……っ\nてありゃ……結構ガチめに言ってるっぽい？　えー、パワーアップ～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0103103" ]},
		{"command":[ "SETCHARA", "0", "char_00001501_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「そりゃ～出来るんなら無限にしたいけど……。って、んぅ？　フェラチオ…\n…？　幹部は皆やってる？　……マジ！？　皆そんな進んでんだ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0103104" ]},
		{"command":[ "SETCHARA", "0", "char_00001501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「あっそー……。そーなんだ、じゃ、アタシが楽しんじゃってもイイってわけ\nね……☆　いいよっ、じゃ、はじめちゃお……フェラ。脱がしたげるよっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0103105" ]},
		{"command":[ "SETCHARA", "0", "char_00001501_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「あはぁ……、コレコレ……♪　ビンビンにそそり勃ったオチンポ……♪　ス\nゴイ……本物じゃん。なんか、あったかいし……。れろっ、ぴちゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0103106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00001501_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「ン、思ったより変な味じゃない……？　ぴちゃっ、ちゅぷ、くちゅ……ちょ\nっぴショッパいけど、口に入れるのは抵抗ないレベル……はむ、あむ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0103107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「んんん……♪　ヤバ～い☆　アタシ、今、生のチンポ舐めちゃってるよぉ～\n☆　っぁ……あっ、ぁっ……はぁっ、はぁ、興奮でクラクラするぅ☆」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0103108" ]},
		{"command":[ "SETIMAGE", "0", "still_00001501_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「ねー……？　隊長っぴぃ……フェラさえすれば、後はアタシが何してもいー\nよね？　んッ……超しっかり舐め舐めするからさ～……はぁっ、あぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0103109" ]},
		{"command":[ "SETIMAGE", "0", "still_00001501_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「オナニー、させて……♪　ホラ……そっちからも見えるっしょ？　アタシ、も\nー我慢できなくてめっちゃ濡れちゃって……あっ♪　あぁん、あんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「チンポねぶりながら指でオナらないと……床にだらだらシロップこぼしちゃ\nう……♪　だから……ね、イイよね☆　っあっ♪　はぁんん、んん……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0103111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「ぴちゃぴちゃしながらのオナニー……、あっ♪　最高ぉ……♪　アハッ☆　\n隊長っぴにも聞こえるっしょ？　オマンコのクチュクチュいう音～……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「アタシの指、すっごい器用だからさぁ……あっ♪　マジシャンのテクで、毎\n晩オナりまくってんだよね☆　けど……ここってろくなオカズないしぃ☆」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「あっ☆　あっ……☆　隊長っぴのカラダとか……♪　ぶっちゃけチンポとか\n想像しながらシてたから……ホンモノ差し出されてラッキーすぎ……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「隊長っぴも～、アタシのオナニー見ながら、オチンポにゅるにゅる舌でイジ\nメられて気持ちーっしょ？　ウィンウィンだよね、コレって……んふふ☆」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0103115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「あっつい視線で視姦しててヨぉ♪　アタシの下品なフェラ顔とぉ……、クリ\nオナ♪　ちゅむ♪　ちゅぷ、くちゅ……あっ♪　あン♪　ちゅっぱっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「レロ……レロレロ♪　くちゅ……ちゅっぷっ、ちゅぷ、ぷっちゅっ……ぷぁ\n……♪　ん、なんかこの段差のトコ……味濃くておいしー……れろーっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「隊長っぴの汗の味……かな？　ぴちゃ……チュ、ちゅっ、ちゅぷっ、ちゅ…\n…キャハハ☆　チンポにチューするとプルプルする～、カワイ……☆」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「うんうん、愛情いっぱい込めてペロペロするよぉ～……ちゅ♪　ちゅ、んち\nゅ……ちゅ♪　ちゅっぷっ、ちゅぷ、ちゅっぷっ、ちゅっぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「あーんって先っちょ丸ごといただきまぁす～……ぐちゅっ♪　ぐちゅっ、ぐ\nっちゅっぐちゅっ……ンン……ひゅごい、太いぃ、顎外れひょぉ♪♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「ひょれに、なーんかヌルヌルひた液が滲み出ひてきて……ぢゅっ♪　ぐちゅ\n……ぐちゅっ、ぢゅっ♪　飲みながらおひゃぶりひないと息出来なひ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「ぢゅっ、ぢゅるっ、ぢゅるっ……ぢゅる……ぢゅるぢゅるぢゅるぢゅる♪　\nぐちゅっ……ぬっちゅっ、ぬっぽっぬっぽっぬっぽっ……んぁああ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「めっっちゃ興奮する～☆　それに……ハァ、ハァ、ハァ……あぁっ♪　上の\n口も下の口もヌルヌルで、なんか突っ込まれてるみたいで……エロい☆」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「この凶悪チンポ、アタシの中に入ってきたらヤバいよね～……♪　裏筋とか\nエゲつないくらい張ってるし、血管浮きまくりでゴツいし……壊されそ☆」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「けど、ソレを体験してみたくて……んっ、あっ、んっ……♪　アハッ……☆\n　指ふやけそーなくらいぐちゃぐちゃになってきちった……あっ、あっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「アタ、シはクリトリス……あっ♪　クリちゃん、とぉ♪　オマンコの入り口\n……あと、奥の方がスッゴい感じるンだけど～……隊長っぴはどこ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「このデカマラちゃんのぉ～……。どのへんが一番感じるぅ？　ここ？　先っ\nちょぉ？　ぺろっ……それとも一番太い笠んとこ？　ぴちゃっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「もしくは～、長くてギンギンの竿んとこ？　ちゅっ、ちゅっ♪　根元とかぁ\n～……裏筋とか、マニアックなとこ～？　れろっ……どこでもイイよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「隊長っぴの極太チンポの一番イイとこ、アタシのオマンコの一番敏感なとこ\nにズリズリしてさぁ……一緒に気持ち良くなるのって最強、じゃん、あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「妄想だけでイキそ……♪　とかって、アタシばっか感じてゴメン～。んむ…\n…♪　ちゅぷ、ちゅぷっ、ちゅぷ……♪　隊長っぴも良くなって～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「アタシ、舌長くて気持ち～でしょ……？　ベロ分厚めだし、隊長っぴのチン\nポ好きだから……大胆に舐めまわすし……っ。んれろっ、れるっ、れろっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「れろっ、れろ……れろぉ……れろっ♪　はぁっ……くちゅ、ちゅっぷっ、ぷ\nちゅ、ちゅぷ……あぁん♪　れろ……れろ、れろ、れろ……アハ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「切なそうな顔ぉ……アタシと同じらね……♪　イキそうなんれひょ……エヘ\n、アタヒも……♪　オチンポと同じくらい限界ぃ……♪　れろっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「一回ぃ……ビュビュって出しちゃっていーよ……♪　軽くイッてからぁ、も\nーっとディープなヤツしよ……。ね？　スパートかけるよぉ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「あむっ♪　ぢゅっぷっ！　じゅっぷっ、じゅっ……じゅるっ、ぢゅるるっ！\n　レロッ、レロッ、レロッ、レロ……ここぉ？　この先っぽの穴ぁ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0103135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「ここからドクドク精子、せいひ出るんれひょ……？　出ひてぇ……欲ひぃ…\n…♪　欲ひィ……ちゅばっ、ちゅば、ちゅぷ……んんっ、んむぅっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0103136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「急におっきくなっれ……！　あっ♪　んんぁっ、あぁ……！　あぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0103137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「んむっ、んむぅうううーっ！？　んむっ……！　んむぅ☆　んむーっ☆　ん\nっ……！　ごくっ……ごく、ごく……ごくっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0103138" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001501_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「んっぁっあっぁっあっあっ♪　苦いぃ……くひゃい、苦ひゅぎぃ……でも飲\nむのやめらんないぃ☆　ごく……ぢゅる……ぢゅるるるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「んーっ、んっんー……！　ごっくっ……んぷぅう……♪　こんっな濃くて口\nん中絡むんらぁ……♪　それに量スゴっ……とてつもないぃ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「ちゅ、ぽ……！　んぁあっ、あぁ、はぁ……♪　なんかもぉ、精子に酔っち\nゃうよぉ～☆　今まで口にしたことない未知の味なのにさぁ……れろっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0103201" ]},
		{"command":[ "SETIMAGE", "0", "still_00001501_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「なんっかクセになるし……頭の芯がぽぉーってあっつくなって痺れてビック\nリ……☆　中毒性あるよねぇ……れろ、れろ……ちろっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「ン、一回目だったから……ちょっちコボしちゃったりしたけどさぁ……。何\n度かすれば受け止めきれるよーになると思うし……まだまだ練習させて☆」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0103203" ]},
		{"command":[ "SETIMAGE", "0", "still_00001501_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「オチンポの魔力、もっと浴びたいし知りたいし……☆　いいよね？　続けち\nゃう☆　んー……チュッ☆　ちゅっ……ちゅ……れろれろれろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0103204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「ちゅぷっ、ちゅぷっ、くっちゅっ……んぁ……☆　ずちゅっ！　ぐちゅっ、\nぐっちゅっ……んぁああ……☆　しつこい苦味……好きぃ、コレ好きぃ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「カリにこびりついてる精子もぉ……、そこらじゅうに散らばった分もぉ……\nアタシのだもん、アタシに出してくれらんらもん……いただきまぁす……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「ぢゅる……ぢゅるるるっ……ぢゅる……ぢゅるるる……ごくっ♪　ごくっ、\nごく……♪　あー……♪　隊長っぴったらヤラシーんだぁ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「腰が浮いてきちゃってるよ～☆　そんなにアタシのおくひ……たまんないぃ\n？　ま、目の前でオナフェラされたら仕方ないっか～☆　ぴちゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「そんなに興奮ひてくれてるんならぁ～、次はこんなことひちゃおっかな……\n♪　大きくオチンポ咥えてぇ……頭を前後させながらぁ……はむ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「オナニーバキュームフェラ～☆　ぶちゅっ！　ぐちゅっ！　ぷっちゅっぐち\nゅっ！　ぢゅるぢゅるぢゅるぢゅるーっ、ぢゅるるるる～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0103210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
