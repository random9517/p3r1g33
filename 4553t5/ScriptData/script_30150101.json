		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「ん、あっ！　ちょ、ちょっと待ってよぉ……！！　おクチの中から逃げ……\n！　アッ！？　あっ、あんんっ！？　んんうううっ！？」", "NORMAL" ]},
