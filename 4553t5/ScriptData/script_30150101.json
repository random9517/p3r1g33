		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「んんぁ……吸っても吸ってもまだ残ってるぅ……ホント尊敬するぅ……。ん\n、ぺちゃっ、ぴちゃ……ぷちゅっ、ちゅぅ……ちゅぅ、ごくんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0103306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「アハ……☆　口ん中、隊長っぴの味しかしないんですけど☆　アタシの唇も\nぉ、舌も、喉も……胃の中もぜーんぶ征服されちったぁ～☆」", "NORMAL" ]},
