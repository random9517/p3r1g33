		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「あぷっ！？　んぁぷぅっんぷぅぅっ……☆　んぁっ……☆　ちょっ☆　メイ\nクもヘアセットもぐっちゃぐちゃになるまでぶっかけとか～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「あぁ～っ、もったいな～い！！　これ、二度目はちゃーんとアタシが口で受\nけ止めるって約束したじゃぁん！　全部顔に出すとかさぁ～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0103403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「いっくらなんでもここまでネトネトの汁他にないよねー！　ねっとりどっち\nゃりかかっちゃってさぁ……しっかもコレ、重たくってウケるくらい～☆」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0103404" ]},
		{"command":[ "SETIMAGE", "0", "still_00001501_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「クサクサのクサだしぃ～……。隊長っぴ～？　なんで顔と頭に出したん～？\n　口に二度出しを遠慮したとかだったら、いらぬおせっかいなんですけど～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0103405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「……って、ふぇっ！？　アタシのおしゃぶり顔見てたら、どーしっても顔に\nかけたくなった！？　ムフ～☆　それってさぁ、アレじゃ～ん？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0103406" ]},
		{"command":[ "SETIMAGE", "0", "still_00001501_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「好きなコへのマーキングじゃぁん☆　しかも超露骨な～！　キャハハッ、ん\nなこと言われたら、こっちも機嫌直ってデレデレなんですけど～☆☆」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0103407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「……んぅ……☆　めっちゃヌルヌルしてて、ん……♪　強烈なニオイだけプ\nンプンしてるから……もったいなさクライマックスだけどぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0103408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「今回は顔で許したげる！　顔射とかも、興味なくはー……無かったし？　で\nも……コレ、粘着力すさまじすぎてとれる気しないんですけど！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0103409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「むー……まさかソレが目的ぃ？　そんなまだるっこしいことしなくったって\n～☆　アタシはどこにも行かないんですけど！」", "NORMAL" ]},
