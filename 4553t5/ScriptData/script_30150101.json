		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「……待って。ジーッとしてて……二回目はこぼさないようにひゅるって約束\nひたれしょ……。舐め舐めひてキレーにひたげる……んちゅ、ちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0103304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「お掃除フェラ～……☆　ンフフフ、快感ってよりも心地い～ってカンジぃ？\n　いいよいいよ浸ってな～余韻☆　んむ……ピチャ、ぺちゃっ、チュプ」", "NORMAL" ]},
