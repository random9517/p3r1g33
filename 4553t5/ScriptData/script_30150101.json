		{"command":[ "SETIMAGE", "0", "still_00001501_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「んーっ、満足、大満足～……☆　けふっ……☆　でも、さ？　このチンポの\n良さを見せつけられちゃって……アタシ少々マジモードだよ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0103308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「いつか、絶対、コレでアタシん中……。オマンコの中掻きまわしてもらうか\nら☆　そんで、今日くらいたーっぷり中に出してもらっちゃうよぉ☆」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「……アタシのマンコちゃんと子宮の中……。精子でタプタプにするまでぇ、\n諦めてあげないんだからねぇ☆　覚悟して、隊長っぴ～☆」", "NORMAL" ]},
