		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「ンぁ……☆　この、喉にまとわりつく喉ごしぃ……んぷ☆　飲みきれないく\nらいの量……精子だけでお腹パンパンになっちゃうじゃん～☆」", "NORMAL" ]},
