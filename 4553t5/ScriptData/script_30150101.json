		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「ぢゅぅ……♪　ぢゅるるるっ、れろっ、れろぉ……ぢゅるっ、ぢゅる、ぢゅ\nるるる……♪　うぅんん♪　ンッ、んっ、じゅぱっ、じゅぱ、じゅぱっ」", "NORMAL" ]},
