		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「はい、太いです……んくぅ……貴方のオチンチン……オマンコ……いっぱい\nにして……ます……んはぁぁ……」", "NORMAL" ]},
