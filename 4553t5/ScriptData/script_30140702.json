		{"command":[ "PLAYVOICE", "v2_014_0704305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「そうですか……よ、よかった……んっ……はぁ、はふ……はい、少しだけホ\nッとしました……」", "NORMAL" ]},
