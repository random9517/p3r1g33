		{"command":[ "SETIMAGE", "0", "still_00001407_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「あぅんっ！　あっ……あぁっ、奥ぅっ……！　はぁっ、ま、待って下さい…\n…そんなっ、あひっ、ダメです、そんなっ、はひっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0704115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「よ、余計なことを考えないように……んんっ……！　そう言われてもっ……\nあぁっ、集中なんて……できるわけっ、くひっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0704116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「はっ、あっ、あぁっ……オ、オチンチンのことだけ考える……んぁぁっ！　\nそんなっ、ことぉっ、あひっ、んひぃんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0704117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「は、はひぃっ、大きいのがっ……今……私のっ……オマンコの中をっ……出\nたりっ、入ったりして、ますぅっ……！」", "NORMAL" ]},
