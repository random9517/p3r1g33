		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「ひゃんっ、あんっ、はひんっ、おとーさんの本気おちんちんっ……きもひっ\n、いーよぉっ、ひゃうっ、んふんっ！」", "NORMAL" ]},
