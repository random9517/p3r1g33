		{"command":[ "PLAYVOICE", "v2_164_0204112" ]},
		{"command":[ "SETIMAGE", "0", "still_00016402_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「はぁふ……おとーさんのおちんちん……イルルのおまんこで食べちゃった…\n…くふふぅ……おちんちん……おっきいのぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0204113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「んんっ、おまんこ……ぐにゅーって広がっちゃう……ね、ね、おとーさん…\n…にゅるんってしてるね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0204114" ]},
		{"command":[ "SETIMAGE", "0", "still_00016402_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「じゃあ、動かすね？　おとーさんは、じっとしてること。イルルがぜーんぶ\nしてあげるからっ……はっ、あっ、んふぅぅぅ……んっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0204115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「はんっ、あっ、うんっ……んくっ、あんっ、はっ、あぁっ……んんんっ、あ\nんっ、はんっ、あっ、あぁんっ、あんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0204116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「あふぁ……イルルのおまんこ……ぐちゅぐちゅってっ、音っ……してるっ…\n…あんっ、はぁんっ、これっ、気持ち……いーねっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0204117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「えっと……んっ、ぐるぐるって……お尻……回してあげるの……いいんだよ\nね……？　んぁっ、ふっ……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0204118" ]},
		{"command":[ "SETIMAGE", "0", "still_00016402_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「ね、おとーさん……して欲しいとこ……ある？　今日は、おとーさんはおき\nゃくさん、だからぁ……イルルがいっぱいおもてなし、します」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0204119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「おとーさんのおちんちん、いっぱい、ごほーしするから……んっ、どんどん\n、言ってね？　うんっ、ふっ、はんっ、あっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0204120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「イルルにおまかせする？　うんっ、分かったっ……イルル……んっ、頑張る\nぅ……もっと、おまんこ……きゅんって……するぅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0204121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「あんっ、はんっ、あはんっ……おまたの中で……おとーさんの、おちんちん\nっ……ビクってするねっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0204122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「おとーさんのおかお……お鼻がぷくってして、んっ、ふっ……かわいーのね\nっ……んっ、あんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0204123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「ねっ、見ててね……おとーさん。今から……イルル、ほんき出して……ゆさ\nゆさっておちんちん……するからっ、んっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0204124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「えいっ、えいっ……あっ、はんっ、あんっ、ほらっ、ゆさゆさってっ……い\nっぱいっ……ゆれるよっ……ねっ、んっ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0204125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「どぉっ？　イルルのおっぱいっ……ゆさゆさっ、してるっ？　してない？　\nんっ、おかしいなぁ……もっとなの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0204126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「もっと……がんばってっ……おっぱいっ、ぷるぷるっ……んふんっ、するぅ\nっ……はっ、んぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0204127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「あっ……おとーさん……どーしたの？　おてて……ぎゅっとして……もっと\nゆっくりでいいの？　どうして？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0204128" ]},
		{"command":[ "SETIMAGE", "0", "still_00016402_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「あ……おちんちん……がまん、できなくなって来たから？　そっかぁ……お\nとーさん、しゃせーしそう、なのね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0204129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「うん、分かった。それじゃあ……んっ、えいっ……んふぅー、んっ……んふ\nーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0204130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「んくっ、ふふっ……イルルのおまんこ……きゅんってなったでしょ？　いー\nのよ、おとーさん、がまんしないで……このままイルルにぴゅっぴゅするの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0204131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「んふっ……もぉ、おちんちん……離れないからぁ……んふふっ、ほら……お\nとーさん……イルルのおまんこに出すの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0204132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「きもちーいーよぉ？　びゅびゅって……出ちゃうの……したいよね……？　\nイルルといっしょに、イッちゃお？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0204133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「ほら、ほらぁ……んふっ、はんっ、あはんっ……ほぉらぁっ……イルルのぉ\n……いっぱい、よくなってぇっ……はひぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0204134" ]},
		{"command":[ "SETIMAGE", "0", "still_00016402_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「んふぁっ！　あっ……おとーさんのっ、おちんちんっ……びゅびゅって……\nしたぁっ！　あっ……なかっ、あついのっ……出てりゅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0204135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016402_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「ふぁぁ……ちっちゃいおまんこっ……ぶっといおちんちんで広がってぇ……\nしきゅう……たねつけされてるぅぅ……はぁぁぁん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0204136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「んぁふ……おとーさん……むすめの、とろとろおまんこに中出しする気分は\nどう……？　気持ちいいー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0204137" ]},
		{"command":[ "SETIMAGE", "0", "still_00016402_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「んとね、そういうと、おとーさんがよろこぶって……あっ……ないしょだっ\nたっけ……えっと、今のは……何でもないの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0204138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「あふんっ！　あっ……また出たっ……ね、ね……おとーさん……今、またせ\nーえき……出したよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0204139" ]},
		{"command":[ "SETIMAGE", "0", "still_00016402_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「ふふぅー、おとーさん、おちんちん気持ちよかったんだ……えへへぇ……よ\nかったぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0204140" ]},
		{"command":[ "SETIMAGE", "0", "still_00016402_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「おとーさん……まだおちんちん、元気いっぱいね？　イルルのおまんこの中\n……いっぱいのままだもん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0204201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「もっとしたいの……？　しょーがないなぁ……おとーさんはぁ……んふふぅ\n……このまま、続きしちゃうねぇ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0204202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「んんっ、あっ……はぁっ……んふんっ……はぁぁ……さっきよりぃ……んっ\n、おまんこ……じゅくじゅくして……すごい音……するぅ……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0204203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「はんっ、あんっ、はぁんっ……イルルのおまんこも……じゅるじゅるって…\n…よだれ出しちゃってるから……おとーさんといっしょ、ね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0204204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「ふんっ、うんっ、んくんっ……イルルね……おとーさん大好きなの……だか\nらぁ、今ね……すっごくうれしいの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0204205" ]},
		{"command":[ "SETIMAGE", "0", "still_00016402_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「だってね、んとね、おとーさんのおちんちんの形……よーく分かるからぁ…\n…おまんこがね、うれしーって思ってるの。それでね、えっとね……あれ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0204206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「えへへ……よく分かんなくなっちゃった。でもね、おまんこがいっぱい気持\nちいーから……もっとしてもいい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0204207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「うんっ、んふぁっ……あんっ、はぁんっ……あふぁっ、ダメじゃないよね？\n　もうイルル……ふつーにしちゃうからぁ……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0204208" ]},
		{"command":[ "SETIMAGE", "0", "still_00016402_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「うぁっ、うんっ……あふんっ、ね、おとーさんっ……ぬとぬとしてるっ……\nおとーさんの白いのっ……おまんこから出てきたよっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0204209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「また……中に戻しちゃうからねぇっ……それでぇ……こしを回してぇ……ぐ\nるぐるぅーって……あふっ、んぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0204210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「はぁぁん……イルル……おっぱいがきゅんきゅんしてる……先っぽこりこり\nで……ずーっとドキドキしてるよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0204211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「おとーさんも、動きたいの？　もぉ、しょーがないなぁ、おとーさんは。そ\nれじゃ、いいよ……おちんちん、動かして」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0204212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「ふひゃぁっ！　あっ、はぁんっ、おとーさんのっ……おちんちんっ……下か\nらっ、ずんずんっ、動いてくりゅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0204213" ]},
		{"command":[ "SETIMAGE", "0", "still_00016402_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「じゅくじゅくって音してぇっ、かたいのっ……こすこすしてぇっ、いっぱい\nっ……あ、あぁっ、しゅごっ、いのぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0204214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「はぁんっ、あっ、はぁぁんっ、おまんこっ……あついよっ！　おとーさんっ\n、イルルっ……はひぁっ、もっ、もぉっ、くふぅぅぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0204215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「あっ……はぁぁぁぁあ……イルルもっ……ビクってなるぅっ……はひゅうん\nっ、イルルのおまんこっ……びくびくっ、してるぅぅ……」", "NORMAL" ]},
