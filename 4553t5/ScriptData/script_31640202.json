		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「んふふ……おとーさんにぃ、えっちで気持ちいいこと、いっぱい教わったじ\nゃない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0204102" ]},
		{"command":[ "SETIMAGE", "0", "still_00016402_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「イルルね、いろいろ覚えて、もっともっと、もーっとすごいこと……したく\nなっちゃったの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0204103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「だから、おとーさん……ちょっとじっとしててね？　だいじょうぶ、今日は\n……イルルが全部してあげるの。おとーさんは、そのまま……ね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0204104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「んふ……ふしぎね、おとーさん。まだ、何にもしてないのに……おとーさん\nのおちんちん、びんびんね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0204105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「こーして……んふっ、おまたのとこで……すりすりしてあげたら……おとー\nさん、気持ちよさそう……んっ、どぉ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0204106" ]},
		{"command":[ "SETIMAGE", "0", "still_00016402_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「あふ……ね？　イルルのおまた……ねとねとってしてるの分かる？　ここ…\n…入れたら、気持ちいーよね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0204107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「ね、おとーさん……入れたい？　ここ……おまんこ……イルルのおまんこ…\n…入れたい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0204108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「ふふー、こーいう時って、おねだりするんでしょ？　おとーさん、ね、おね\nだりは？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0204109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「おちんちん……入れたいですって……ちゃーんと言うの……おとーさん、出\n来るよ……ね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0204110" ]},
		{"command":[ "SETIMAGE", "0", "still_00016402_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「ふふー、よく出来ましたー。いい子のおとーさんには、ちゃんとごほーびあ\nげないとね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0204111" ]},
		{"command":[ "SETIMAGE", "0", "still_00016402_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
