		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「イルル……イッたの……んはふぅ……おとーさんはどぉ……？　んっ、もう\nすぐ……出そう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0204217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「分かった……んっ、イルルがんばるから、おとーさんのおちんちんも、がん\nばって！　んっ、んふっ、はんっ、あんっ……はぁんっ！」", "NORMAL" ]},
