{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017002_01_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「んっく……本当に……この上でオナニーしたら……姉さんを解放してくれる\nんだよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0203101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「ふ、ふん。バランスボールなんて……普段からしてるから、別にどうってこ\nとないし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0203102" ]},
		{"command":[ "SETIMAGE", "0", "still_00017002_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「えっと……それで、どうすればいいのさ……？　手はこのままじゃなきゃダ\nメって……そんなんでどうやって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0203103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「腰を回して……オ、オマンコを刺激させる……んくっ、そういうの見て楽し\nむタイプなんだ……？　ふん、悪趣味だよね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0203104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「わ、分かってるよ。やればいいんでしょっ……んっ、ふっ、はっ、んっ……\nんくっ、ほ、ほら……こんなんでいいワケ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0203105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「もっと、気分を出して……詳しく説明しながら……っく、調子に乗ってっ…\n…！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0203106" ]},
		{"command":[ "SETIMAGE", "0", "still_00017002_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「んくっ……今は……腰を深く落として……ボールに……オ、オマンコを押し\n付けてる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0203107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「軽く体重を乗せて……弾ませるような動きで……リズムに合わせて腰を……\n振るっ……んっ、はっ、んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0203108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「別に、これくらいの刺激……どうってことないし……気分出せって言ったっ\nて、無理なもんは無理だし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0203109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「んぁっ……なっ、何見せてんのさっ！　そんな、オチンポ……な、何する気\nっ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0203110" ]},
		{"command":[ "SETIMAGE", "0", "still_00017002_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「んぁっ！　あっ……ちょっ、あっ……そんな反り返らせて……あ、あぅんっ\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0203111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「あっ、や、やめっ……そこっ、おっぱいに……オチンポッ……くっつけるな\nぁっ……ひっ、あっ、んくぅっ、あっ、んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0203112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「はっ、んんっ、あっ、ダメ……乳首……いじるのっ……反則っ……んくぅっ\n、あっ、あぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0203113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「こ、この状態で……腰をっ、もっと……？　んくっ……そんなことっ、こ、\nこうっ……？　はっ、んぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0203114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「あっ、ふっ、んんっ、あっ、あぁっ……乳首ぃ……そんな、ピンポイントに\nぃ……あっ、んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0203115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「あっ、せ、説明……だからっ……アンタのオチンポの先で……あたしの乳首\n……んんっ、か、陥没乳首っ……グリグリ、されてるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0203116" ]},
		{"command":[ "SETIMAGE", "0", "still_00017002_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「んくぅ……別に、気持ちいいとかじゃ……あっ、んんっ、ちょっと……ピリ\nッてするくらいで……は……あぁんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0203117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「こ、声は……な、何となく出るだけっ……はっ、あぁんっ……で、でもっ…\n…んひっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0203118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「んんっ……ぬ、濡れてる……？　ビキニが……透けて……あっ、バ、バカ…\n…そんなとこっ、あっ、み、見るなぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0203119" ]},
		{"command":[ "SETIMAGE", "0", "still_00017002_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「だ、だって……これは、んっ、そういう刺激……受けてたらっ、自然に……\nなるやつでっ……あぁんっ、だからっ……そんなにオチンポっ、おっぱいにっ\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0203120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「うくぅっ……熱い先っぽ……んっ、すごくねちっこくてっ……はぁっ、んっ\nく……グリグリ……動いてるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0203121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「はっ、んっ、あぁっ、あぁ……ウソ……んんっ、あっ、あたし……オマンコ\n……溢れてきちゃってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0203122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「バランスボールなんて……んっ、何回も使ってるのに……こ、こんなので気\n持ちよくなっていってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0203123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「んっ、あぁっ……やだ、オマンコ……んっ、こんなの……違うのに……んん\nっ、動いちゃう……はっ、んぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0203124" ]},
		{"command":[ "SETIMAGE", "0", "still_00017002_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「うくっ……ちょっと……あっ、オチンポ……また押し付けて……んんっ、あ\nぁ……そんな、鼻先に……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0203125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「に、においを嗅げって言うの？　どうせ言うことを聞かないと、また脅して\nくるんでしょ……分かってるし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0203126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「んっ、すぅぅぅっ、んっ、はぁぁぁ……あぁ……こんなの臭いだけじゃない\n……オチンポのにおいなんて……キツいだけだし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0203127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、んくぅっ、すぅぅぅっ……んっ、こんなの……はぁ……全然\nっ……んんっ……あふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0203128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「んぅっ……な、なんでまた嗅ぎたくなってるの……んんっ、はぁっ、やだ…\n…んっ、ふぅっ……あんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0203129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「うぁっ……オマンコ……疼いちゃってる……あぁ、腰が……止まらなっ、い\nっぱい……動いちゃってるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0203130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「んぁっ、また……オチンポで……先っぽ擦られてぇっ、はぁっ、あっ、ダメ\nっ……あたし……あっ、気持ちよくなっちゃってるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0203131" ]},
		{"command":[ "SETIMAGE", "0", "still_00017002_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「はんっ、あっ、あぁっ、な、何……チンポ震わせてんのっ！？　あたしに…\n…掛けるのっ、あぁっ、おっぱいに出されるのっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0203132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「んぁっ、オチンポぐりぐりされてっ、おっぱいっ……気持ちよくなってっ、\nあっ、んぁぁぁっ！", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0203133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「ひゃぁぁん！　あっ……ザーメンッ……出てるっ！　おっぱいにっ……びゅ\nくびゅく出されてるぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0203134" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017002_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「んくぅぅ……どんどん出てくる……あぁ、くさいの……ぶっ掛けられてぇ…\n…はぁ、んっ、あぁぁ……あたしまで……イ、イクッ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0203135" ]},
		{"command":[ "SETIMAGE", "0", "still_00017002_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「んぁぷっ……！　はぁ……ま、まだ終わらないの……？　そんな目の前でシ\nコシコ扱いて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0203136" ]},
		{"command":[ "SETIMAGE", "0", "still_00017002_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「あふっ！　やめ……そんなオチンポ押し付けて……おっぱいに精液……塗り\n付けるなぁ……んぁ……あっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0203137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「あぁ……べとべとする……おっぱい……精液漬けにされちゃってるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0203138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「んっ……あぁ……やっと……収まった……？　んっ……こんなに出すなんて\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0203139" ]},
		{"command":[ "SETIMAGE", "0", "still_00017002_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「はぁ……んふっ……身体……変な感じ……あたし……どうなっちゃったのか\nな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0203140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「な……まだオチンポ……こんなにビクビクしてる……これで終わらせる気は\nないってこと……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0203201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「んんっ、あっ……こ、今度は……これを……しゃぶれ？　あたしに……フェ\nラチオさせようっていうの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0203202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「しかも……精液まだついてるオチンポを……んっ、あっ、わ、分かってるっ\n、どうせ逆らえないって言うんでしょっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0203203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「と、とにかく……すればいいんでしょ……あ……はぁんむ……あむ、ちゅぱ\nっ、んちゅぷぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0203204" ]},
		{"command":[ "SETIMAGE", "0", "still_00017002_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「んぁぁ……せぇえきの味……すごい……濃いのがドロって……喉に絡んで…\n…じゅぱっ、ちゅぷ、んちゅぷぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0203205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「んふっ、はっ、んりゅっ……あぁ……何なのこの味ぃ……りゅぱっ、れろっ\n、んっ、じゅぷっ、んちゅぷぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0203206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「お、美味しくなんて……りゅぷっ、これは……アンタが……ちゅぱっ、しろ\nっていうから……んりゅぷっ、仕方なくぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0203207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「じゅぽっ、んじゅぱっ、ちゅぱっ、んりゅぷっ……おぷっ……んむっ、じゅ\nぱっ、んふぅうっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0203208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「夢中になんか……なっへっ、あぷっ、んじゅぷっ、ない……んっ、ぴちゃ…\n…腰が動くのは……命令されてるからぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0203209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「そうだよ……アンタが命令したんでしょっ、オナニーしろって……バランス\nボールに……オマンコくっつけろってぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0203210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「ぴちゃ、だからっ……そうしてるのっ、オチンポじゅぱじゅぱってしゃぶり\nながらっ、はぁんっ、気持ちよくなってくのぉっ、んっ、んぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0203211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「あんっ、はぁんっ、あぁっ……おっぱい……ムズムズしたままぁっ……やら\nしぃにおいでぇ……カラダ……出来上がってぇっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0203212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「うんっ、あっ、あぁっ……腰っ……振っちゃうっ、オマンコ揺すっちゃうっ\n、気持ちよくなっちゃうぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0203213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「はぁっ、あっ、んじゅぷっ、ちゅぱっ、オチンポッ……はぁんむっ、らんで\nっ、舐めひゃうっ、れるっ、んれらぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0203214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「あぁっ……んぁぁっ、あぁっ、おいひいっ……そんらっ、オチンポ……おい\nひくなっひゃうなんてぇっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0203215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「んぁぁっ、乳首も……浮いてきちゃうっ……オマンコも……お汁溢れ過ぎて\nっ……あぁっ、じゅくじゅくになってぇっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0203216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「あぁっ、んむっ……オチンポから……お汁……浮いてっ、じゅぱっ……はぁ\nんっ……射精したがってるのっ、分かるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0203217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「じゅるっ、これっ、またあたしにっ……掛けるのっ……？　それともっ……\n飲ませるのっ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0203218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「じゅぱっ、んちゅぷっ、んぁぁっ、も、もうっ、どっちでもいいっ……いい\nからっ、早くっ……んんっ、出してっ……んふぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0203219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「おっぱいでもっ、口の中でもっ……あぁっ、いっぱいっ……出してぇぇっ！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0203220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「んぶぅぅっ！　んぐっ、あむっ、こくっ、んくっ……んぐっ、んくんっ……\nんっ、あっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0203301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017002_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「こんら……いっぱい、口の中れっ……出されるらんてぇ……はぷっ、これっ\n……飲まなきゃっ……らめっ……らろっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0203302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「こくっ、んぐっ、んくんっ、んっ、ちゅぷっ、こくんっ、んっ、ぷぁっ、は\nぁっ、はぁっ、はぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0203303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「はふぁ……ちゃんと飲んだよ……んっ、ねぇ、も、もう……いいでしょ？　\nやっぱ、こういうのガラじゃないし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0203304" ]},
		{"command":[ "SETIMAGE", "0", "still_00017002_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「捕まってエッチなことするって設定はいいけど……トレーニングと混ぜると\n、なんだかよく分かんない感じになっちゃって、混乱する」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0203305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「け、結構ノリノリだったって……そ、それはっ、別に……まぁ、イヤって訳\nじゃなかったから、ちょっと乗ってあげただけで」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0203306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「ま、まぁ、一応は気持ちよかったし？　アンタも２発も出したんだから、よ\nかったんだとは思うけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0203307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「えっ……あ、き、綺麗に……？　わ、分かったよぉ……んっ、ちゅぱっ、も\nう……やんちゃ過ぎるオチンポめぇ……れろ……んちゅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0203308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「ぴちゃ……ほらっ、れろ……綺麗になったれひょっ。んぱっ……はぁ、んふ\nっ……はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0203309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「こんなので興奮するなんて……ホント、アンタも変態なんだからぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0203310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「んぁぷっ！　はぁぁっ、んっ……出てるっ……また精液っ……はぁんっ、顔\nにシャワーされてるぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0203401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017002_01_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「んふぁっ……熱い……ドロドロで濃いの……遠慮なく出されてぇ……んぁっ\n、あたしもっ……また……んっ、イクぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0203402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「んぁっ、はぷっ……はぁっ、ぴちゃ……れろっ、んんっ……ドロっとしてる\n……めちゃくちゃ濃いの……まだ出るの……んっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0203403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……お、終わった？　んっ、最後に後始末まで……すればいいん\nれひょ……れろ、んちゅぷ……ぴちゃ……れろ……んりゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0203404" ]},
		{"command":[ "SETIMAGE", "0", "still_00017002_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「ちゅぱ……ほら……綺麗になったし……これでいいでしょ……もう、とりあ\nえず終わりっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0203405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「はぁ……なんか色々設定がついててややこしかったけど、ホントにこういう\nのが良かったわけ？　確かに結果として身体はいっぱい動かしたけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0203406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「そ、それはまあ……確かに気持ちはよかったし……？　こんなに射精させた\nんだから、盛り上がったのは……そう、なのかな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0203407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「あふ……あぁ、べとべとする……あんたの精液ってばホントに濃すぎなんだ\nもん……ぴちゃ……んっ、ちゅぱ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0203408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「んっ、れろ……この味がクセに……？　そ、そんなこと……んちゅぷっ……\nれろ……あ、あるかも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0203409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「も、もう……どうすんのさ……それ、ちゃんと責任とってくれるの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0203410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
