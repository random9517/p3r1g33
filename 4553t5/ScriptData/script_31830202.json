{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018302_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「ねえ、いいでしょ？　こんなところまで連れてきて……あなたもヤる気満々\nでしょ？　だったら……焦らさないでよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0204101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「夫には友達と食事に行くって言ってるから、大丈夫よ。だから少しくらい遅\nくなっても……いいの。だから……ほらぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0204102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「あなただって、我慢できないでしょ？　ここ……こんなに膨らませて……あ\nあ、素敵……これよ、これ……このチンポ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0204103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「若くて、活力に満ち溢れてて……私とヤリたくて、勃起してくれてる……そ\nうよね？　いいわよ……これで、私のアソコを可愛がってちょうだい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0204104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「私も、あなたのチンポが欲しくて堪らないの……この大きくて、力強く反り\n返ってて……ゴツい形をしたカリが素敵な、このチンポぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0204105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「そうよ、あなたとふたりで出かけるってなったときから……想像していたわ\n。不倫セックスのことしか頭になかった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0204106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「……ほら、わかるでしょ？　私のアソコ……笑っちゃうくらいびしょ濡れ…\n…お漏らししちゃったみたい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0204107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「いい歳して、夫も娘もいるのに……年下の男に入れ込んで……頭の中ピンク\n色で、アソコ濡らしてる……浅ましい女なの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0204108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「でも、あなたはそういう女が好みでしょう？　ほら……ハメまくって、あな\nた専用に作り替えた人妻マンコ、たっぷり味わって……んっ、んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0204109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「はっ、ああぁ……！　あっ、くっ、はいって……くるぅ……！　ごつごつし\nたデカチンが……中、ゴリゴリ擦りながら……ああっ！　ああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0204110" ]},
		{"command":[ "SETIMAGE", "0", "still_00018302_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「んっんっ……ひぐっ！　こ、これぇ……これが欲しかったのぉ……このチン\nポ欲しくて……んはっ！　あっ、ひっ……このチンポぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0204111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「あっ、あんっ！　あんっ……挿入れただけで、アソコおかしくなっちゃう…\n…はぁあっ！　あぁんっ……！　すごいっ、やっぱりすごぉい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0204112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「んっ、んはぁっ……あはぁっ……も、もう……奥まで届いてる……先っぽ、\n子宮に当たって、てぇ……ひっ、ひぃんっ……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0204113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「はぁはぁ、はっ……はんっ、んっ、だい、じょう……ぶ……すぐ、動くから\n……あなたも、気持ちよくしてあげるわよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0204114" ]},
		{"command":[ "SETIMAGE", "0", "still_00018302_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「んんっ！　あっ、あんっ！　んっあっ……車の中、だから……ちょっと動き\nづらいけど……腰、振りたくって……あげる、から……んふぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0204115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「あ、ああっ！　イヤらしい音……鳴っちゃう……アソコぐしょぐしょだから\n……チンポと擦れて、くちゅくちゅいっちゃうぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0204116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「ひぃんっ！　あぁっ、はぁあっ……はあんっ！　いい、気持ちいいっ……こ\nのチンポ、好きぃ……愛してるぅ……んっ、んんっうううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0204117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「いい、どうでもいい……！　夫のことなんか、今、どうでもいいから……あ\nなたもセックスに集中して……余計なことは忘れて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0204118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「あぁんっ！　あっ、あぁんっ！　あ、あなたも……どう？　気持ちいい？　\n私のオマンコ……感じてくれてる？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0204119" ]},
		{"command":[ "SETIMAGE", "0", "still_00018302_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「んっ、んひぃ！　そ、そうね……これだけギンギンに勃起してる、から……\n言わなくても、わかる……けど……言って欲しいの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0204120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「ちゃんと言って欲しいの……言葉にして、お前のマンコ最高だって、言って\n……！　最高の女だって言ってちょうだい……んんぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0204121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「あっ、あはぁぁっ！　う、嬉しい……あぁ、あんっ……！　あなたのおかげ\nで、自分が女だって……はぁあんっ！　実感できるのぉ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0204122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「あぁっ！　あんっ、んっ、んうっ、チンポぉ……グリグリ奥に当たってるぅ\n……！　んっんふっ……！　ひゃうっ、んはぁっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0204123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「ズポズポって、デカチンが中を……かき回してるぅ……んあっ、ああっ！　\nはっ、んっ……よすぎて、腰、止まんないぃぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0204124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「はっ、はっ……はあっ！　んあっ、あんっ、あんっあんっ！　出っ張ったカ\nリが、擦れてぇ……んひぃっ！　ひいっ、いぃんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0204125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ……あぁっ、も、もうイキそぉ……んひっ、いいっ、だって……\nだってぇ……気持ちよすぎるのっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0204126" ]},
		{"command":[ "SETIMAGE", "0", "still_00018302_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「あなたのチンポが……んっ、んふっ！　あぁあぁ……気持ちよすぎて、イッ\nちゃうっ……浮気アクメしちゃうぅぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0204127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「んうっ、んああっ！　もっと、味わいたいのにぃ……んっ、あ、あっ……あ\nんっ、はっ、くひぃっ！　腰、動いてぇ……あああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0204128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「ひぃうっ！　あぁ、チンポも……中で大きくなってるっ！　あなたも、イキ\nそうなの？　イキそうなのね？　あっ、あぁあんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0204129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「あなたも、一緒に……イッて！　んっ、はぁぁぁっ！　あっ、ああっ！　イ\nクっ……イクイクッ！　あんっ、あぁんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0204130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「出して！　ザーメン出してぇぇっ！　あんっ！　あっひっ！　ひいいっ……\nひっ、ひううっ！　イッ、イクイクぅぅぅぅ～～～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0204131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「ひっ！　ひっ、ひぃいいいいいっ！　んひぃいいい～～～～！　イクっ！　\nイッ、くうううっ……んっ、んはぁっぁぁっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0204132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「あぁっ……あぁんっ！　　ザーメン……熱いのが、奥に……んっ、はぁあっ\n！　ドプドプ流れ込んでっ……きてるぅぅぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0204133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「あっ、あんっ……んひぃいっ！　ひっ、ぐっ……あぁっ……すご、いぃ……\n子宮が、ああ……あんっ……いっぱい、に……なるううっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0204134" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018302_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「よくもまあ、こんなたくさん……出して……くれたわね……これで、もう満\n足したでしょ……はぁっ……はぁ……はひっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0204135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「んっ、あぁ……はっ、はぁ、はぁあっ……気持ちいい……不倫セックスで中\n出しアクメ……これ、味わったら……あぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0204136" ]},
		{"command":[ "SETIMAGE", "0", "still_00018302_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「もう、普通の生活じゃ満足できない……んっ……もっと、欲しい……あなた\nも、まだヤれるでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0204137" ]},
		{"command":[ "SETIMAGE", "0", "still_00018302_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「どうせ、一回射精したくらいじゃ……あなたも満足しない、でしょうし……\n実際、チンポは……ガチガチのまま……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0204138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「あぁんっ……若いって、本当にいいわね……射精しても、ずっと勃起しっぱ\nなしなんだもの……これ、で……私を楽しませて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0204139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「もちろんあなたも、たっぷり気持ちよくしてあげるわよ……今度は、そっち\nも好きに動いていいから……さあ、ハメまくりましょう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0204140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「あっあんっ！　くひぃっ、ひぃいっ！　んっ、あぁっ……ホント、大きくて\n硬くて、最高のチンポよぉ……んっ、んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0204201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「あふぅっ、んぅっ！　あんっ！　あっ、あんっ……！　中出しされたザーメ\nンが……オマンコの中でかきまぜられて……すごい音、鳴ってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0204202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「い、いまイったばかりなのに……そんなに激しくしないでって……ひっ、ひ\nいっ！　あぁっ！　あっ……あぐっ、んっ、いやぁっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0204203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「あ、あぁ……ヤらしい……イヤらしい、わ……こんな姿、絶対に……見せら\nれない……あっ、ああっ……！　ひっ、ううっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0204204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「車の中、だから……見られちゃう、かもしれないけど……今さら、やめられ\nないわよ……こんな気持ちいい、こと……ああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0204205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「ほら、あなたも動いて……私のオマンコを突き上げてぇ……んっ、んひっ！\n　あっあっ、あんっ！　そう、その調子でぇ……はっああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0204206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「んっ！　んほぉ、おっおおっ！　は、激しいっ……乱暴なピストンぅっ……\nさい、こぉ……んっんんっ！　んほぉおっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0204207" ]},
		{"command":[ "SETIMAGE", "0", "still_00018302_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「チンポっ、チンポすごいっ！　デカチンっ……奥まで、ズンズンされるの好\nきぃっ！　大好きなのぉ……！　おっ、おおっ……おほおおっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0204208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「そ、そうっ……そうよっ！　もっときて……！　オナホだと思っていいから\n、強く突いてぇっ！　んっ、んひいいっ！　んっ、んんううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0204209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「は、恥ずかしいわよっ……！　恥ずかしいけど……感じちゃうから、仕方な\nいのっ……あっはっ！　はぁあぁ！　おおっ、おっおほぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0204210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「あっ、ぐううっ！　んぐっ！　げ、下品な声……？　あんっ！　だって、あ\nっ……あああっ！　激しくされたら……出ちゃうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0204211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「聞かれる、のは……嫌だけど……ンンっ！　オマンコ、も……おお、おっ、\nおほぉっ！　ぐちゅぐちゅいっててぇ……どうしようもないのぉ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0204212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「あっ、あひぃ！　ひぃぎいいっ！　おおっ！　イ、イクっ！　力任せの荒々\nしいピストンすごすぎて、もうイッちゃううううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0204213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「んっひぃっ！　む、無理ぃっ……我慢とかできないぃ……！　ンうぅっ！　\nおっ、おっおおっ……またくるっ！　きちゃうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0204214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「浮気マンコが、チンポ堕ちアクメしちゃうっ！　んっ、ンンぅっ！　あっは\nぁぁぁあっ、ああっ！　あっ、ぐっ！　ぐひっ、ひぃいっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0204215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「ああっ！　あっ、おっ、おほっ！　だし、てぇっ……ザーメンっ！　ザーメ\nンミルクぅっ！　熱々ザーメン欲しぃのぉぉぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0204216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
