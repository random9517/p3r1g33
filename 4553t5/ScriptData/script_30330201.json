{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "PLAYVOICE", "033_0203101" ]},
		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「隊長さま？　何やら急用とのことですが……。何か事件でも起こりましたか\n？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00003302_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0203102" ]},
		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「そうではなくて……ＣＥＯの姿の私と触れ合いたくなった……？　あら……\n。そうだったんですか。隊長さまの男が収まらない、と……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0203103" ]},
		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「フフ。仕方がありませんね、多少であればお相手いたしましょう。ですが私\nは生娘のように……って、あっ？　な、何を？　ああっ！？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00003302_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0203104" ]},
		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「台詞の途中で後ろから抱き着くなんて……。お、驚かせないでください。こ\nんなこと、誰にもさせたことがないのに……貴方って人は……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003302_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0203105" ]},
		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「……そ、それで？　ここからどうするんです？　はぁっ……私を興奮させて\nくれるんでしょうね……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0203106" ]},
		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「ッ……あ……む、胸……？　ああ……スーツの中に押し込められていた乳房\nが、気になるんですか……フフ……単純な……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0203107" ]},
		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「熟れた女の……一企業のＣＥＯの、汗くさくて現場あがりのでっかいお乳…\n…。それをこねて、もんで……弄ぶ……。まあいいでしょう」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0203108" ]},
		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「どうぞお好きに……。っ……ん……ン……ん……っ……。嫌だ、そんなにガ\nッついて……。うちの雄雌牙の従業員みたいですよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0203109" ]},
		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「荒々しくて……、ぁ……力任せで……っ。勝手なもんです、自分の性欲をぶ\nつけることしか頭にない……。図星でしょう？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0203110" ]},
		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「あっ……、で、でもどうしてでしょうね……。貴方の手、は……指はあたた\nかくて……あっ、マッサージでもされているみたいです」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003302_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0203111" ]},
		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「大きすぎてどぉおっしても凝ってしまうこの爆乳を……ん、自らほぐしてく\nださるなんて……。ありがたい限り、です……フフフフ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0203112" ]},
		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「んっ？　あっ……ふふふ、乱暴な……。そんなにグニグニされたら潰れちゃ\nいますよ……。んぁっ、あ、は……き、嫌いではありませんが……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0203113" ]},
		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「この程度のテクで雄雌牙建設のＣＥＯが屈するわけ……って、あンっ？　な\n、何？　隊長さまの手が……熱くなって、あっ、胸が疼くっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0203114" ]},
		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「あっ！？　あっ、あっ？　あぁっ！？　なんですこれっ……妙な魔法でも使\nって……アッ！？　む、胸の芯から……奥からメラメラと……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003302_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0203115" ]},
		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「熱くて、熱くて、う、疼いちまいます……！　い、いやっ……こんなの知ら\nない……あっ！　む、胸、胸をぐりぐり回さないでぇ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0203116" ]},
		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「あっ……アッ！　あっ、あっあっ！　ああ……！　い、いやだ、焦らさない\nで……！　乳房ばかりをこねこねと……ああっ、ああああっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0203117" ]},
		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「ね、ねえっ……いつまでも、まだるっこしいやり方してないで……んんっ！\n　肝心のとこを触ってください、乳首……乳首を、はやくぅ……っ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003302_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0203118" ]},
		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「あふっ、ンン、んん……！　隊長さまがなかなか触ってくれないものだから\n……、わ、わかるでしょう？　乳首……むずがゆくて……勃起して……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0203119" ]},
		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「お、お願い、お願いよぉ……。乳首、乳首触ってぇ！　乳首つまんでコリコ\nリしてぇ……！　引っ張って、伸ばして、苛めて、いじめてぇ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0203120" ]},
		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「あひっ！？　ヒッ、ヒィイインッ！？　ああ……！　乳首っ、乳首撫でられ\nると……あああ、さすられると腹に、アソコに響いてくるぅ……っ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003302_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0203121" ]},
		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「女の本能目覚めさせられて、あっ！　ジンジン来るっ、ビリビリ来るぅっ…\n…！　ああ！　もっと！　もっと強くつねって！　ひねってぇ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0203122" ]},
		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「ああああっあっあっあっ！　凄い……なんて器用な指……！　し、ＣＥＯの\n私ですら……丸裸にするテクニック、ぁっ、乱してくるこのアツさ……っ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003302_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0203123" ]},
		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「ああっ、やっぱり隊長さまの指は他の誰とも違う……！　漢気を直接乳首に\n注入してくるぅっ、たまんない、たまらないぃ……おかしくなるぅ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0203124" ]},
		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「あっあひっ！　あひっあひっ！　駄目、せっかく事業が基盤にのってきたの\nにぃ……女に戻っちゃだめっ、し、ＣＥＯしなくちゃだめっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003302_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0203125" ]},
		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「なのにッ……なのに……あひぇええっ！　顔保てないぃッ、ＣＥＯの顔して\nられないぃ……乳首、乳首もっとつねってッ、痛くして激しくぅううっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0203126" ]},
		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「っあーーーーーっ！　やだっ！　乳首、乳首だけでこんなに感じるなんて…\n…っ！　神業すぎるッ、あっあっあっ！　あぁっあっあっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003302_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0203127" ]},
		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「腰が勝手にカクカク、して……乳首の刺激だけでアソコがだだ濡れに……っ\n！　う、嘘……嘘よこんなっ……ああっ！　おかしくなるっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0203128" ]},
		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「アアアッああっ！　あヒッ！　あひっひぃっ！　がに股になってお尻ヘコヘ\nコしちゃうぅ……！　全身がっ、乳首の快感でおかしくなるッ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0203129" ]},
		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「あーっ、こ、このままじゃ……このままじゃ！　あッゥッ！　乳首っ、乳首\nだけでイカされるぅ……イかされるゥウっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0203130" ]},
		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「ＣＥＯの権威なくしちゃうっ、偉そうな顔してたくせに乳首でイカされるっ\n……！　ああーッ！　ああっ、ああっ、悪夢っ、悪夢だわっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0203131" ]},
		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「乳首でイっちゃうＣＥＯなんて……シメシがつかないぃいいっ、でもっ、で\nもでもクリクリされると……ンいいいいいいいッ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0203132" ]},
		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「やっ、そんな強く引っ張らないで！　アッああああっ！　それ気持ちいい…\n…！　気持ち、いい、あっ……アッ、立っていられない……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003302_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0203133" ]},
		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「それ以上引っ張ったら乳首戻らなくなっちゃうぅう！　アーッ！　でもいい\nのっ、いいのっ！　貴方の好きに伸ばしてっ、ダメにしてっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0203134" ]},
		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「ンアアアアアアッ！！　アアッ！　そうっ、そうよひどくして、乳首ひどく\nしてぇええっ！　いいのッ、いいのいいのぉおっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003302_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0203135" ]},
		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「そうよ、ひどくされると感じちゃうのッ……ああっ！　乳首おかしくなるま\nでこねて、潰して、伸ばして……ああそうっ、そうやって……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0203136" ]},
		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「ッいいいいいいいっ！！　イイッ！　いいっ、いいいいっ……！　っあぁ…\n…！　イッちゃった……イッてしまった、胸だけ、で……あああっ！」", "NORMAL" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003302_01_06" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0203137" ]},
		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「エッ？　ま、まだ続けるなんて、そんな……！　あっあっあっあっ、ダメッ\n、今度は耐えきれないっ……ああっ！　駄目よっ、だめぇ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003302_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0203138" ]},
		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「ンッああああああっ！！　ああーっ！　ああっ！　またイクぅ、イクぅ達す\nるぅううっ！　あーっ！　あっアアアアッ、いやっ、いやぁああっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003302_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0203139" ]},
		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「っ……はぁっ、はぁあああああ……ああ……。た、隊長さまのせいで乳首が\n大きくなって……。いやらしい形になってしまいました……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003302_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0203140" ]},
		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「こんなに、こんなに充血して……。腫れて……。で、でも、どうしてでしょ\nう……。それがこんなにも、気持ちがいいんです……っ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}