		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "大会委員長" ]},
		{"command":[ "SETTEXT", "「――と、いうわけで、無事、襲来者（インベーダー）は撃退されたわけであ\nりますが、会場周辺の混乱はいまだ収まらず――」", "NORMAL" ]},
	{"command":[ "DISPTEXT", "TRUE" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
	{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "大会委員長" ]},
		{"command":[ "SETTEXT", "「非常に残念ではありますが、本大会はこれをもって中断！　試合結果はすべ\nて無効といたします！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「結局、ノーコンテストですか。仕方ないとはいえ、残念ですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_040104120001" ]},
	{"command":[ "SETCHARA", "0", "char_00013101_01", "1", "CENTER", "0" ]}, 
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「みんな、がんばったのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_010104120001" ]},
	{"command":[ "SETCHARA", "0", "char_00013001_01", "4", "CENTER", "0" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "大会委員長" ]},
		{"command":[ "SETTEXT", "「次の大会は、１０００年後の開催予定となります！　皆さん、また次回、こ\nの会場でお会いしましょう！」", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「無茶を言うな無茶を！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090104120001" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]}, 
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「はぁ～……やれやれ……なんや消化不良な終わり方やなぁ……ケッタクソ悪\nい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_128_010104120001" ]},
	{"command":[ "SETCHARA", "0", "char_00012801_01", "4", "CENTER", "0" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「まったくだ。マグナシア、今からでも決着をつけるか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010104120001" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "6", "CENTER", "0" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「ん？　せやなあ。アンタとやるのも悪ないけどな。それより先に、タコ殴り\nにしたい奴らがおんねん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_128_010104120002" ]},
	{"command":[ "SETCHARA", "0", "char_00012801_01", "6", "CENTER", "0" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「ちょっと隊長！　ウチのケータイ番号教えとくわ！　襲来者（インベーダー\n）どもをぶちのめすのに助けがいるときは、電話してや！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_128_010104120003" ]},
	{"command":[ "SETCHARA", "0", "char_00012801_01", "8", "CENTER", "0" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ケータイ！？　つながるのか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「おう、ウチ、ふだんはアンタらの地球で修行しとるからな！　いつでも駆け\nつけたるでぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_128_010104120004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「そういうことでしたら、私も。お呼びいただければ、ワームホールからいつ\nでも参上します」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_040104120002" ]},
	{"command":[ "SETCHARA", "0", "char_00013101_01", "8", "CENTER", "0" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「私もいくよーっ！　みんなを困らせる、悪い奴らは許せない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_010104120002" ]},
	{"command":[ "SETCHARA", "0", "char_00013001_01", "8", "CENTER", "0" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ふふふっ、どうやら心強い仲間ができたようだな、ルナテミス？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090104120002" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "6", "CENTER", "0" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そうだな。これで少しは、襲来者（インベーダー）との戦いも楽になるかも\nしれん。優勝を逃したのは残念だが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010104120002" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "6", "CENTER", "0" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうですね。これで姫様たちが優勝しててくれれば……くれれば？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「どないしたん？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_128_010104120005" ]},
	{"command":[ "SETCHARA", "0", "char_00012801_01", "6", "CENTER", "0" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああああああっ！　そうだ！　賞金！　優勝できなかったんだから、賞金も\n入らねえんじゃねえか！　冗談じゃねえ！　賞金山分けの夢が！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「あ、ああ……そうなん？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_128_010104120006" ]},
	{"command":[ "SETCHARA", "0", "char_00012801_01", "3", "CENTER", "0" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「結局俺たち、タダ働きじゃねえかーっ！　なんてこったぁ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「えと…………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_128_010104120007" ]},
	{"command":[ "SETCHARA", "0", "char_00012801_01", "1", "CENTER", "0" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おーい！　委員長！　賞金だけくれ！　賞金ーっ！　せめて出張手当ーっ！\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「な、なあ……今さら不安になっても遅いかもしれへんけど……ほんとにアン\nタんとこの隊長、大丈夫なん……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_128_010104120008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「それを言ってくれるな。なんとも答えようがない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010104120003" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "1", "CENTER", "0" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うぁあああああ～～～っ！　賞金～～～～～っ！」", "NORMAL" ]},
