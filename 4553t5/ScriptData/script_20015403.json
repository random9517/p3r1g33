{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0033" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_005" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "カツマたちがサンタガールと行動を開始した、ちょうどその頃……。", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "刻の女王に、カツマ一行の邪魔をするようお願いされたアトロポスとジェスタ\nは……速やかな作戦実行のために、助っ人を呼んでいた。", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00019603_01", "0", "CENTER", "-300" ]},
		{"command":[ "SETCHARA", "1", "char_00023103_01", "0", "CENTER", "300" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SPOTCHARA", "0"]},
		{"command":[ "SETTEXT", "「で、ここが助っ人ちゃんとの待ち合わせ場所？　暗くて寒くてテンション下\nがっちゃう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_010023540001" ]},
		{"command":[ "SETCHARA", "0", "char_00019603_01", "1", "CENTER", "-300" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SPOTCHARA", "1"]},
		{"command":[ "SETTEXT", "「気持ちはわかるけど、クリスマスに暑くて明るかったらそれはそれで困るん\nじゃない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010023540001" ]},
		{"command":[ "SETCHARA", "1", "char_00023103_01", "0", "CENTER", "300" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SPOTCHARA", "0"]},
		{"command":[ "SETTEXT", "「うーん、それはそう～。はぁ～……でもさぁ？　かなり珍しい組み合わせよ\nね。アーちゃんとジェスタなんて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_010023540002" ]},
		{"command":[ "SETCHARA", "0", "char_00019603_01", "1", "CENTER", "-300" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「これまで、おねーさまたちがいる時くらいしか会わなかったから、ジェスタ\nと１対１って逆に新鮮かも」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_010023540003" ]},
		{"command":[ "SETCHARA", "0", "char_00019603_01", "6", "CENTER", "-300" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SPOTCHARA", "1"]},
		{"command":[ "SETTEXT", "「えぇ？　新鮮？　いいね～。それなら、コレを機にボクと青春作っちゃう？\n……って」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010023540002" ]},
		{"command":[ "SETCHARA", "1", "char_00023103_01", "6", "CENTER", "300" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「そこはジェスタ、じゃなくてジェスちゃんって呼んでよ～。ボクもキミのこ\nと、アーちゃんって呼ぶからさ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010023540003" ]},
		{"command":[ "SETCHARA", "1", "char_00023103_01", "8", "CENTER", "300" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SPOTCHARA", "0"]},
		{"command":[ "SETTEXT", "「え～？　どうしよっかな。なんかジェスタって、気が付いたら裏切ってきそ\nうな雰囲気あるんだよね～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_010023540004" ]},
		{"command":[ "SETCHARA", "0", "char_00019603_01", "1", "CENTER", "-300" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SPOTCHARA", "1"]},
		{"command":[ "SETTEXT", "「え～ん、そんなことしないってば～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010023540004" ]},
		{"command":[ "SETCHARA", "1", "char_00023103_01", "4", "CENTER", "300" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SPOTCHARA", "0"]},
		{"command":[ "SETTEXT", "「そのウソ泣きが怪しいの！　って、そんなことはどうでもいいんだってば」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_010023540005" ]},
		{"command":[ "SETCHARA", "0", "char_00019603_01", "3", "CENTER", "-300" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「ね～。ジェスタは今回の命令のこと、どう思う？　カツマおにーさんのクリ\nスマスを邪魔するのが目的とかイミフじゃな～い？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_010023540006" ]},
		{"command":[ "SETCHARA", "0", "char_00019603_01", "0", "CENTER", "-300" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SPOTCHARA", "1"]},
		{"command":[ "SETTEXT", "「んふふふっ。それでも、命令には逆らえないのがツラいとこだよね～」　　", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010023540005" ]},
		{"command":[ "SETCHARA", "1", "char_00023103_01", "6", "CENTER", "300" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "SETTEXT", "「あ、あの～……。もしかして、怪人の派遣を依頼してくださったジェスタさ\nんたちですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_010023540001" ]},
		{"command":[ "SETCHARA", "0", "char_00018403_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「そうだけど。って、あ～！　あんたたちがアーちゃんの待ってた助っ人って\nこと！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_010023540007" ]},
		{"command":[ "SETCHARA", "0", "char_00019603_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「たぶんね。お待たせしちゃってごめんなさい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_010023540001" ]},
		{"command":[ "SETCHARA", "0", "char_00018303_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「お役に立てるといいのですが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_010023540002" ]},
		{"command":[ "SETCHARA", "0", "char_00018403_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「なーんかこの助っ人さんたちさぁ、怪人～っていうより普通の主婦～って感\nじなんですけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_010023540008" ]},
		{"command":[ "SETCHARA", "0", "char_00019603_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「なんでわざわざ主婦を呼んだの～？　カツマのおにーさんってそんなにバブ\nバブに弱かったっけ？　バブみ趣味あり？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_010023540009" ]},
		{"command":[ "SETCHARA", "0", "char_00019603_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んー。呼ぶのは誰でも良かったんだけど。今回は不穏な感じがしてね～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010023540006" ]},
		{"command":[ "SETCHARA", "0", "char_00023103_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「作戦を遂行するのは時間帝国だけじゃないほうがいいんじゃないか～、な～\nんて思ったんだよね～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010023540007" ]},
		{"command":[ "SETCHARA", "0", "char_00023103_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「ほーん、そうなんだ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_010023540010" ]},
		{"command":[ "SETCHARA", "0", "char_00019603_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「それでターゲットの方はどこにいるのかしら？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_010023540002" ]},
		{"command":[ "SETCHARA", "0", "char_00018303_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「あ、それは気にしなくていーよ。ジェスタがワープホール？　ってので一気\nに連れてってくれるから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_010023540011" ]},
		{"command":[ "SETCHARA", "0", "char_00019603_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「その点、お手をわずらわせたりはしませんよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010023540008" ]},
		{"command":[ "SETCHARA", "0", "char_00023103_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「そ、それは助かります……。交通費もバカになりませんので……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_010023540003" ]},
		{"command":[ "SETCHARA", "0", "char_00018403_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「じゃじゃじゃーん！　ジェスタひみつ道具～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010023540009" ]},
		{"command":[ "SETCHARA", "0", "char_00023103_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "謎の効果音を口走りながら、ジェスタは自分のパンツの中に手を突っ込んだ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "そしてそこからズボッ、とあやしい機械を取り出してみせる。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「カツマ君レーダー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010023540010" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「ええええええっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_010023540004" ]},
		{"command":[ "SETCHARA", "0", "char_00018403_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「これね、超ヤバイんだよ？　名前の通り、ガチでカツマおにーさんの居場所\nがわかっちゃうとんでもないマシーンなの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_010023540012" ]},
		{"command":[ "SETCHARA", "0", "char_00019603_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「そのレーダーで目標の所在を把握し、ワープで接近するというわけね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_010023540003" ]},
		{"command":[ "SETCHARA", "0", "char_00018303_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「その通～り！　それでは、さっそくカツマ君を襲いにレッツゴー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010023540011" ]},
		{"command":[ "SETCHARA", "0", "char_00023103_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "ぽちっとな、と言いながらレーダーのスイッチを押したジェスタは、機械を見\nてしばらくぶつぶつ言った後……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「わかった！　そこだね～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010023540012" ]},
		{"command":[ "SETCHARA", "0", "char_00023103_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "とホールを出現させ、カツマ一行の元へ飛んだのだった。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}