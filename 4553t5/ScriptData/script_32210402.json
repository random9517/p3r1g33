{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022104_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ん～っ……♪　旦那さまにたくさんせいえきをもらったから……お礼をした\nいです♪　サキュバスのお礼と言ったらこれですよね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0404101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ふふ……。今度は旦那さまがイタズラ、しますの？　もちろん、わたくしは\nそれでかまいません♪　はぁ、はぁ……むしろ待ちきれない想いです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0404102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「見てください……♪　旦那さまがたくさん可愛がってくださったから、わた\nくしの身体のいたるところがもうベトベトです……♪　それに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0404103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ここからのことを想像して、期待して……おまたがヌルヌルしちゃっていま\nす……。はしたないですよね、でも……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0404104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「今日のわたくしは……ハロウィンのサキュバスさんですから。旦那さまのせ\nいえきを無限に搾り取る、わるーいわるいサキュバスなのですから……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0404105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁ……旦那さまも、もう待ちきれないみたいですね。でも待って\nください。きちんとおねだりします。えっちを……お願いいたします」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0404106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「わたくしの、ちっちゃいおまんこを、よーくご覧になってください……。ん\nんっ……指をあてがうだけで、くちゅ、ぬちゅってえっちな音がしています」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0404107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「これは……赤ちゃんを作る準備ができたということです……。旦那さまのお\nちんちんさんを、ここに……この穴に入れていただきたいという意味です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0404108" ]},
		{"command":[ "SETIMAGE", "0", "still_00022104_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「旦那さまぁ……♪　どうか悪い子のわたくしに、えっちなイタズラをしてく\nださい……♪　お仕置きと、ご褒美をかねた激しいイタズラ希望です……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0404109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「っんっ……♪　そう、です……その太くてかたーいおちんちんさんを……わ\nたくしのここに……あっ♪　お、お尻や脚をなでなでするのはだめですっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0404110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「そ、それだけですごく感じてしまって……！　ふぁああ……♪　おまたのヌ\nルヌルがどんどん増えて……シーツがいっぱいシミになっちゃいます！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0404111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あっ！　お胸やお尻をさわったり、なさらず……っ！　おちんちんさん、お\nちんちん様をはやく入れてくださ……いっ。ふぁっ……あああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0404112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「色々なでなでしちゃだめですぅう……！　あぅうっ……！　せ、せつなくて\n、もう我慢できません……ください、おちんちんください……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0404113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ッあ……っ♪　んふっ……あっ♪　んぁあああ……♪　入り、ましたのぉ…\n…！　旦那さまのおちんちん……わたくしの奥まで届いていますっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0404114" ]},
		{"command":[ "SETIMAGE", "0", "still_00022104_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「んんッ、ふ……♪　ふぅうう……っ♪　こ、呼吸をするのも困難なくらい…\n…いっぱい入ってます、……はぁあっ♪　身じろぎもできません……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0404115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「やっぱり旦那さまはスゴいです……！　っン……♪　んんんん……！　あう\n……っ、ふぅっ、ふぅうう……！　あっ♪　動いちゃうのですか♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0404116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「っああああっ♪　くふぅぅっ♪　やっ……んやぁっ♪　ひゅ、ひゅごい……\n！　しゅごいです！　あっ！？　あっ、腰が浮いちゃい、ます！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0404117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「はぁああっ！？　んぁっ……！　深いです……っ！　あっ……♪　あっ……\n、で、でも……旦那さまのぬくもりがつたわってきて……しあわせ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0404118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あっ……！　え、えんりょしないで思いっきりしてくださいませ……っ！　\nわたくしの、ここ……おまたの穴、今日はすごく濡れていて……それで！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0404119" ]},
		{"command":[ "SETIMAGE", "0", "still_00022104_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「はぁっ♪　ぐちゅぐちゅぅうって♪　どちゅって奥まで一度に突かれても…\n…痛くないし、怖くないんです。むしろ……あっ、ビリビリして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0404120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あっ♪　ぁっ……♪　頭がぼーっとして、気持ちいいんですの……！　あぁ\n……！　お、大人の男の方の本気……わたくしに見せてくださいませ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0404121" ]},
		{"command":[ "SETIMAGE", "0", "still_00022104_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「殿方の……！　旦那さまの全力で、わたくしをだっこして、いっぱいちゅっ\nちゅしながらぐちゅぐちゅしてほしいです……お願いします……ぅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0404122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あっ、んぁあああ……！　ひゃんっ♪　んんっ、んぁんんっ♪　んん……！\n　あっ……♪　んぅうう～……♪　ンン……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0404123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「んにゃぁあっ♪　ひぁっ……やぁあん♪　あっ……わたくし、サキュバスさ\nんになってよかったです……！　こんなに激しくしてもらえるなんて♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0404124" ]},
		{"command":[ "SETIMAGE", "0", "still_00022104_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「わたくしも、旦那さまの大きな愛にお応えしたい……♪　んっ♪　ど、どう\nですか……力を入れて、入口をきゅうって締めてみま、した……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0404125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「えっ……？　最初からキツいから苦しいくらい？　あっ？　あっ、ではどう\nすれば……！　力を抜いてただ旦那さまを感じていればいい……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0404126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「そ、そうだったのですね。わかりました……！　であればお好きにお使いく\nださいっ。あっ♪　そうです♪　強く強く突いて、突き上げてください！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0404127" ]},
		{"command":[ "SETIMAGE", "0", "still_00022104_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ん～～～っ♪　んぁっ♪　はぁああ……っ♪　ふぁあああっ、あぁああ……\n♪　旦那さまっ……旦那さま……！　おっきいです、太い、ですのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0404128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「んぁっあっぁっああああ……！　わたくしの赤ちゃんのお部屋が♪　子宮が\n突かれてよろこんでますっ……旦那さまのおちんちんとキスしたくって♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0404129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「くちゅっ♪　チュッ、て奥にキスしてください♪　わたくしの赤ちゃんを作\nる場所……旦那さまの赤ちゃんを孕む場所にたくさんのキスを……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0404130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ふぁっ……！！　あああああっ♪　そこですっ、そこ……！　あっぁっあっ\nぁっ……！　無理です、もうイッちゃいます……んぁああああ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0404131" ]},
		{"command":[ "SETIMAGE", "0", "still_00022104_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ごめ、んなひゃいぃ♪　勝手に締めつけちゃいますっ！　おちんちんぎゅう\nぎゅうって咥えこんで……締めつけて、一人で許可もなく絶頂して……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0404132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「わるいおよめさまでごめんなさぃい♪　ッあ……♪　でも！　でも、今日は\nわたくし、サキュバスですから……ちびっこ悪魔ですからぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0404133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「せいえき欲しがってもゆるされますよねっ♪　んふぁっ♪　イ、っちゃう…\n…！　あっあっ、せいえき♪　せいえきくだひゃい♪　おしおきしてっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0404134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「えっちなわたくしの中に……旦那さまの一番すごいの、くだひゃい……っ♪\n　ふぁああ……！　このウズウズしているところにどうか……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0404135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「んぁああああぁ～っ♪　あッあっぁっあああ……！　旦那ひゃま……♪　旦\n那しゃまぁああ♪　わたくしの中に、いちばん、奥に……きてますぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0404136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022104_02_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「旦那ひゃまのビュルビュルせいえき……！　あっ、おいしいっ……すごくお\nいしいです！　これっ、好きなんです！　出してもらうの好きでっ……あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0404137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「もっと……ください！　もっとです！　欲しいです……赤ちゃんの種っ……\n！　せいえきミルクびゅるびゅるされるとすごく気持ちがいいのです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0404138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「っあ～～～～～……♪　ふぁああああ……♪　熱い液体が、旦那さまのおち\nんちんミルクがびゅーっ、びゅーって……あったかい……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0404139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「んっ♪　んっ♪　奥にかかってるの、わかり……ます！　感じます、あっ…\n…気持ちいい……！　イッちゃいます、イ……きます、んんん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0404140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「しゃせいしていただいて、こんなに幸せで……ゾクゾクするのは、わたくし\nが今、サキュバスさんだからでしょうか？　あっ！　あっ、まだ出てます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0404201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「まだ……まだきてる、注がれてますぅう……！　あぁ……っ！　ドクドクっ\nて、旦那さまの体温を感じて……あはぁああ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0404202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あ、ありっ、ありがとうございま、した……♪　おいしいせいえき、ドロド\nロミルク……たくさん下のお口で食べさせてもらっちゃいまし、た……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0404203" ]},
		{"command":[ "SETIMAGE", "0", "still_00022104_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「旦那さまは本当にすごいですね……♪　男らしくて……何度出しても、こん\nなにたっぷりせいえきをわたくしにプレゼントしてくれて……んんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0404204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ご主人さまって呼んじゃいそうになりました……。だって、かっこよくて…\n…わたくしのぜんぶを捧げたいと思ったんです。すごく好きです……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0404205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「はぁっ……。お腹がたぷたぷになっても、ずーっと出ていて……大満足です\n。……え？　まだ、全部出しきっていない？　それはどういう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0404206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「……んっ！　お、お腹の中でおちんちんさんがずーっと硬いままです……！\n　いいえ、さっきよりもっと硬く、おっきくなっているような……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0404207" ]},
		{"command":[ "SETIMAGE", "0", "still_00022104_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「……ふふふっ♪　わたくしも……旦那さまと同じ気持ちです。はい♪　この\nまま……せいえきまみれのまま、もう一度えっちしたいです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0404208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「いいですか……？　んっ……してくれますか？　……あ♪　今、おちんちん\nさんがお返事しました♪　うれしい……わたくしも精一杯がんばります！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0404209" ]},
		{"command":[ "SETIMAGE", "0", "still_00022104_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あっ……♪　お尻を振ってゆーわくします……♪　旦那さまのおちんちんが\n大きすぎて……あまり上手に動けません、が……がんばります……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0404210" ]},
		{"command":[ "SETIMAGE", "0", "still_00022104_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「んっ……！　あっ♪　あっぁっ……！　えへへへっ……♪　どんな魔法でし\nょう……？　せいえきをあれだけ出して、まだ硬いなんて……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0404211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「きっと、身体の相性がすごくいいんですね。それに……んぁっ♪　あ、愛が\n……♪　愛があるから、ですね♪　らぶらぶ、だから……！　っあ、あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0404212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「らぶらぶだから……あっ♪　気持ちいい、んですね……！　ああああっ♪　\nずぶぅっ、ズプププッて出たり入ったりしてます、ぅ……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0404213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「もっと、もっと突いてください♪　おちんちんしてください♪　あ～～っ♪\n　あっあっあっ♪　奥まできてます……んぁああっ、ひゅごいでひゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0404214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「わたくしのお腹の、中……！　おまんこさんの中……！　旦那さまのおちん\nちんの形に開いて、ます……！　形覚えちゃっています……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0404215" ]},
		{"command":[ "SETIMAGE", "0", "still_00022104_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「んんっ、ふぅうう……っ♪　前は……奥まで来ると苦しかった、のに……今\n日は……あああっ！　まったく辛くありません、気持ちいい……です！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0404216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「大人の男の人のっ……本気のえっちで感じてしまうなんて……！　あっあっ\n、えっちなサキュバスっ子でごめんなさい……やめないでくださ、い！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0404217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「……ふぁああ♪　心配しないでください、わたくしは立派なサキュバスです\nから♪　旦那さまの本気を受け止められますっ……ですから最後まで！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0404218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「最後まで本気で突いて、貫いて……そのままわたくしにご褒美のせいしを注\nいでください！　っあああ……！　えっち気持ちいい……えっち好きです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0404219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「旦那さま……♪　尊いせいえきをわたくしに注いでください……！　んっぁ\nっぁっ……うぅ♪　イッちゃいます……一緒にイッてくださいぃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0404220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「っふぅううう……っ♪　ふぅううう～～～っ♪　イッてます……！　あなた\n様のアンはっ……びゅるびゅるされてイッてますのぉ……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0404301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022104_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「……ぁっ……♪　い、今、気持ち良すぎて一瞬気を失ってしまっていました\n……。って、やんっ♪　まだどぴゅどぴゅしてます、出てます、出てますっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0404302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あっ、ああああ……！　だめですっ、あふれちゃいますのっ……！　せっか\nく旦那さまに入れていただいたせいし、逆流してあふれちゃいます……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0404303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あッ……！　ああああああっ……！　ドロドロのおもらし気持ちいい……っ\n！　脚に、お尻に……ベッドにごぽっ、ごぷって広がって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0404304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「たらたらぁって垂れていくのが……すごく気持ち良くて……ふぁっ♪　イッ\n……ちゃいます、イキます……！　あぁあああ……♪　んぁあああ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0404305" ]},
		{"command":[ "SETIMAGE", "0", "still_00022104_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「せいえきっ……！　入ってきて、出ていって……もう全部が、ぐちゃぐちゃ\nで……ネトネトで、こんな……♪　新感覚です……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0404306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「……はぁああ……♪　ハロウィンって、過激でえっちなお祭りなんですね…\n…。こんなに乱れてしまったのははじめてです……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0404307" ]},
		{"command":[ "SETIMAGE", "0", "still_00022104_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「わたくし……ちゃんと、旦那さまのためのサキュバスさんになれていました\nか？　いっぱいせいえきをいただいて……はい♪　お腹いっぱいです……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0404308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あの……♪　また、来年のハロウィンも……わたくしとこのように、交わっ\nていただけますか？　……一年後でいいのか、ですか？　うう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0404309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「だ、だめです……。えっと……明日もまた、このお洋服で……旦那さまをゆ\nうわくしにきてもいいですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0404310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「んぁあっ！　イキます……！　旦那さまっ……イキますぅ……！　あぁ……\nっ♪　あぁ……！　ビクビクが止まりませんん……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0404401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022104_02_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あっ……！？　ヌルヌルが……！　せいえきが身体にかかってます……っ。\nんっ、ぁっ……熱いですのっ……！　ひゃうっ……真っ白に……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0404402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「旦那さま……わたくしの中でたくさん気持ち良くなってくださったんですね\n……っ！　ふぁっ♪　びゅるびゅるの勢いがすっごいです……はぅう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0404403" ]},
		{"command":[ "SETIMAGE", "0", "still_00022104_02_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「肌に降りかかる、純白のせいえき……♪　はぁああ♪　サキュバスさんの衣\n装にかかると、とってもえっちで、可愛くて……んっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0404404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「だいすきな旦那さまのにおいに包みこまれるみたいです……♪　あぁ♪　む\nわむわぁってただよってきます、せーしのキケンな香り……あっあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0404405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あのまま中に……奥にびゅるびゅるしていただいて、ハロウィン赤ちゃんを\nおつくりするのもよいかと思ったのですが……かけてもらうのもいいですっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0404406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「わたくしが旦那さまのものである証……♪　えへへへっ、サキュバスさんに\nなっても、それはかわりません。愛しい愛しい旦那さまのせいえき……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0404407" ]},
		{"command":[ "SETIMAGE", "0", "still_00022104_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ぜんぶぜんぶ、たいせつにしますね……♪　え？　しなくていい？　すぐ洗\nえって……そ、そんなのもったいないです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0404408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「っ……ぁ……♪　み、見てください……。さっきお腹の中に出していただい\nたせいしが溢れて出てきちゃいました……。んん、はずかしいですの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0404409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「これくらいでもじもじしてしまうわたくしには、まだ……サキュバスさんは\n早かったかもしれません。でも、本当に楽しかったです……♪」", "NORMAL" ]},
