		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「じゅぶっ、じゅぶぶっ！　んふぅうっ！　んっ……んぐっ！　んっ、んんっ\n……んふっ、んっ、ふうっ……じゅ、んぶぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0203301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024102_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「はあ、あふっ……んぐっ……んっんんっ……んっくっ……ぷはぁ……はぁ、\nはぁ……ごくんっ……ま、また……すごい量じゃな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0203302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「ほれ……全部、飲んでやったぞ……おぬしも妾の蜜を堪能したか……？　\nたっぷり楽しんだようじゃな……はふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0203303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「ふふっ、妾の尺八もすごかったじゃろう？　たっぷり出しておったしのう…\n…今までで、一番じゃろう？　そうに決まっておるわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0203304" ]},
		{"command":[ "SETIMAGE", "0", "still_00024102_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「ふふ、人の子には負けぬわ。ほれ、ちんぽに残った子種も吸い出してやろう\n……んっ、じゅるるっ……ずずっ、じゅうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0203305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「……ぷはっ！　んっくっ……はぁ、喉に絡みつくのう……濃くて、匂いが\n鼻までのぼってくるわ……腹の中から、んぷっ……匂ってくる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0203306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「ひゃ、あっ……こ、これ……んんっ、おぬしも舐めて……綺麗にしてくれる\nのか？　それはよいが……優しくせよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0203307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「達したばかりは、敏感になっておることくらいわかるじゃろう？　んっ……\nほれ、妾も……ちんぽについた子種汁を舐め取ってやろう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0203308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「はむ……れろ、ちゅ……ぺろ、ぺろ……うむ、そうじゃな……なかなか美味\nいちんぽじゃった……珍味じゃ……ふふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0203309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「ああ、気に入ったぞ。毎日でも味わいたいものじゃ……よいのか？　言った\nな？　では遠慮なく、馳走になるとするかのう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0203310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「はあぁあっ……んっ！　ぷはぁあっ！！　ひゃっ……！　あっ、あぁああっ\n……！　出てっ……んんっ！　ひぃいっ！　ひぃいんっ！！」", "NORMAL" ]},
