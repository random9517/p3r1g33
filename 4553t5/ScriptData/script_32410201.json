		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「あぁっ、そ、そこっ……！　くひぃぃ、ひっ……ぐっ！　そこぉ……はぁぁ\nあっ！　ひっあっ……あっあっ、あぁぁぁぁ～～～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0203402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「はふぅ……んっ、んんっ……！　あぁ、吐き出してしもうた……ひゃっ……\n！　あんっ……！　こ、これ……出しすぎじゃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0203403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「顔にまで……かかっておるわ……あんっ……あぁっ、くふぅっ……あ、ぁあ\n……おまんこ、とろけてしまいそうで……力が、入らぬ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0203404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「まったく……さっきより、量が多いではないか……おなごの顔を、楽しそう\nに汚しおってぇ……くっ、ひぃい……あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0203405" ]},
		{"command":[ "SETIMAGE", "0", "still_00024102_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「んっ、んはぁ……あぁ、か、顔がぁ……子種汁まみれじゃ……匂い、すごく\nて……んうっ……鼻がおかしくなりそうじゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0203406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「はぁ……は、はぁ……はーっ、はーっ……ん、そうじゃな……たっぷり馳走\nになったな……おぬしも、しっかり味わったか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0203407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「美味かったじゃろう？　また食いたいか？　そうか、そうか……そこまで\n言うなら、また食わせてやるから楽しみにしておれ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0203408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「なに？　い、今か？　そんなに気に入ったのか？　うむ、妾もおぬしのちん\nぽ……気に入ったぞ。毎日でもしゃぶりたいわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0203409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「そうじゃな……では、今日はとことん味わい尽くすとするか……干からびて\nも知らぬぞ？　妾をその気にさせたのじゃから、覚悟せよ」", "NORMAL" ]},
