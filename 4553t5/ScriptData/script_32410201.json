{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0045" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「これ、おぬしよ。とても美味い珍味とはなんじゃ？　早く食いに行こうでは\nないか……！　なに？　持ってきておるのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0203101" ]},
		{"command":[ "SETCHARA", "0", "char_00024102_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「ほう。用意がいいではないか……しかし手ぶらのようじゃが……本当に珍味\nを持ってきたのか？　量が少ないのか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0203102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「……な！？　そういう……まったくおぬしというやつは……それなら妾の\nめこも、おぬしの逸物に負けず美味いぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0203103" ]},
		{"command":[ "SETCHARA", "0", "char_00024102_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「うむ。よかろう……お互いに食うてみるか？　よし……では、おぬしの逸物\nをよこせ……妾のめこを馳走してやるから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0203104" ]},
		{"command":[ "SETCHARA", "0", "char_00024102_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「はあ……相変わらず、大きな逸物じゃ……なに？　この姿なら、もっと人の\n子っぽく話した方がよい？　まあそうかもしれぬが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0203105" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00024102_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「ち、ちんぽ……？　逸物のことは……ちんぽと呼べばいいのか？　では、\n妾のめこはなんと呼ぶ？　おまんこ……ほう、面妖な呼び方じゃな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0203106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「まあ、よい。みながそう言うておるなら……こほん、改めて……おぬしの\nちんぽ、を……いただくとするかのう……んっ、ちゅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0203107" ]},
		{"command":[ "SETIMAGE", "0", "still_00024102_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「おっと、いかん……まずは匂いを……すんすん……まだそこまで匂いはせぬ\nか……よし、舐めてやろうな……んあ、れろっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0203108" ]},
		{"command":[ "SETIMAGE", "0", "still_00024102_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「味もせぬな……れろれろ……これ、珍味ではなかったのか？　しゃぶれば、\nしゃぶるほど味がしてくるとな？　ほう……そうか、そうか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0203109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「妾のめこ……あ、っと……おまん、こ……も同じじゃ……中からつゆが出て\nくるゆえ、しっかり舐めるのじゃ……んんっ！　そ、そう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0203110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「妾も、味わわせてもらうぞ……ちゅ、ちゅく……んぅっ……！　い、いきな\nり……激しいのう……くっ、はぁあ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0203111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「ぶ、無粋なやつじゃ……もっとゆっくり味わって、食わぬか……あっ、あぁ\nぁっ……くっ、ひぃいっ……わ、妾も……れろ、んちゅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0203112" ]},
		{"command":[ "SETIMAGE", "0", "still_00024102_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「ちゅく、ちゅうっ……なんじゃ、もう味がしてきたか？　そ、そうか……\n妾のおまんこは、美味いじゃろう……んっ、くっ、ふぅう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0203113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「あっ、ああっ……ひゃうっ……！　んぅっ……！　お、おくっ……んぅっ…\n…舌が、挿入ってくる……んひっ、ひぃいっ……あふぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0203114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「待っておれ……くうっ、んんっ……おぬしのちんぽ……味わってやるから…\n…んむっ、んっ、んぶっ……ちゅくっ、じゅるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0203115" ]},
		{"command":[ "SETIMAGE", "0", "still_00024102_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「ほれ、じわじわと……苦味が、滲んできたわ……れろっ、んぷっ……ほれ、\nもっと出さぬか……珍味を食わせてくれるのであろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0203116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「わかっておる、もっと強くしゃぶればよいのじゃろう？　んっ、んぶっ……\nじゅ、むっ……んもっ……じゅく、ぢゅうっ……ぢゅぷっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0203117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「くっ、んぅ……また大きくなりおって……おぬしのちんぽは、大きすぎるの\nじゃ……咥えておるだけで、あごが疲れてしまうわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0203118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「はあ……あっ、あんっ……どうじゃ、わらわの……美味いじゃろう？　好き\nなだけ食ろうてよいぞ……あんっ……んっあぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0203119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「やらしい舌使いじゃ……くうっ、んっ……そっくりそのままお返ししてやる\n、からのう……じゅるっ、じゅ、じゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0203120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「ちゅぱ、ちゅうっ……れろぉ、んふぅ……ひぃうっ……！　じゃ、邪魔する\nでない……じゅぷ、じゅぷっ……はあっ……あむぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0203121" ]},
		{"command":[ "SETIMAGE", "0", "still_00024102_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「はぁあっ……あふっ……ほれ、どんどん……んぶっ……先汁が溢れてきて\nおるぞ……ちゅ、ちゅぱっ……じゅぶ、じゅるるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0203122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「あ、あふぅ……おぬしも、遠慮せず……妾のおまんこ……味わって、おれ…\n…くひっ……ちゅぶっ、んぶっ……ちんぽ、んぶぶっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0203123" ]},
		{"command":[ "SETIMAGE", "0", "still_00024102_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「そう、じゃな……美味いぞ……おぬしのちんぽ、なかなかの珍味じゃ……\nしゃぶっておると……れろ、れろっ……味がしみてくるわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0203124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「ほれ……舌で、先っぽをほじってやる……ちゅく、ちゅうっ……んぅ……\n味が濃い……じゅるるっ……ん、ぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0203125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「そろそろ、果てそう……ではないか？　んっ、子種汁を……馳走してくれ…\n…んむっ……ちゅ、ちゅっぷ……じゅぷ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0203126" ]},
		{"command":[ "SETIMAGE", "0", "still_00024102_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「は、んんっ……あぁ、妾も達しそうじゃ……ひぃうっ……ずっと、おぬしに\n舐められて……おまんこ、びしょびしょじゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0203127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「あっあぁ……ああんっ……そ、それ……舌で、奥まで……くっ、ひぃいっ…\n…はぁあ……は、果ててしまう……あっ、あぁぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0203128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「おぬしも、一緒に……いっしょ……ひっ、あっ……じゅぷっ……んぶっ、\nんふっ……じゅぷ、じゅっぷっ……ちゅく、ぢゅるるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0203129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「くうっ……い、いく？　いく、というのか……？　そ、そうじゃな……いき\nそうじゃ……んっ、んんんっ！　んぷぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0203130" ]},
		{"command":[ "SETIMAGE", "0", "still_00024102_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「おぬしも……じゅるっ……んっ、はむっ……は、早う……出すのじゃ……\nんんっ、んっぷ……むふぅっ……んむむっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0203131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「はぁ、はっ……あふっ……ちんぽ……んむっ……お、大きい……んふぅっ…\n…はぁぁ、んちゅっ……味、が……濃くなっておるわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0203132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「んぶっ……ちゅ、ちゅうっ……おぬしも、いき、そう……なんじゃろう？　\nわかるぞ……ちんぽが悦んでおる……んむっ……んぶぶ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0203133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「ひくひく、震えて……ちゅぶっ……苦い汁が、止め処なく溢れてきておる…\n…んっ……くちゅ、ちゅっ、んふぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0203134" ]},
		{"command":[ "SETIMAGE", "0", "still_00024102_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「は、あっ……妾も、んんっ……！　も、もう……あんっ……んむっ……れろ\nれろっ……ぢゅぶっ、んっ……ちゅうぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0203135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「くっ、ふうっ……んぶっ！　あくっ……いくっ……んっぶっ、むぶっ……\nじゅぽ、んぶぶっ……んっ、んんんっ、んんん～～～～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0203136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024102_01_05" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「んくっ……！　んっ！　んうっ……！　んくんくっ……ぷはぁぁ……あっ、\nあぁあっ……果て、ておるのに……そこぉ……ひぃいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0203137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「くううっ……ぜんぶ、飲んでやるわ……んぐっ……ぢゅっ……ぢゅぷっ……\nじゅるるっ、ちゅ、ちゅぶっ……んふぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0203138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……な、なかなか美味かったぞ……おぬしのちんぽも……んふぅ\n……妾の、おまんこも美味かったじゃろう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0203139" ]},
		{"command":[ "SETIMAGE", "0", "still_00024102_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「なに？　おかわりじゃと……？　も、もちろんじゃ……妾も、まだ足りぬ。\nもっと……このちんぽを食わせてもらうぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0203140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「はぁ、はむっ……むむっ……んぷっ……相変わらず、達したばかりなのに…\n…大きいままで、生意気なちんぽじゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0203201" ]},
		{"command":[ "SETIMAGE", "0", "still_00024102_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「ちゅぷっ……ちゅうっ、んぷっ……ほれ、おぬしもしっかり妾のおまんこを\n舐めぬか……蜜を馳走してやらぬぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0203202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「いいもなにも、おぬしの好きにすればよかろう……なっ……！　そんなすぐ\nに達するわけなかろうが……妾をあなどるでない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0203203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「本当じゃ、確かに果てたばかりで敏感になっておるかもしれぬが……おぬし\nの舌くらいで、簡単に何度も達するわけなかろうて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0203204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「ひゃうんっ！　ち、ちがっ、今のは驚いただけじゃ……！　不意打ちなど、\nしょうもない策を弄するな。まったく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0203205" ]},
		{"command":[ "SETIMAGE", "0", "still_00024102_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「そ、そうじゃ……おなごは優しく扱わねば、嫌われるぞ……んっ、あっあっ\n……くっ、ひんっ……だ、大丈夫じゃ……続けよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0203206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「んんっ……くふぅ、ううっ……わ、わかっておる……妾だって、すぐ舐めて\n、ひんっ！　舐めてやるわ……んっちゅ、ちゅぷ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0203207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「おぬしこそ……果ててしまいそうなら、我慢するでないぞ？　すぐ……出し\nてよい、からな……んぶっ……ちゅ、ちゅっぷ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0203208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「んっぷ……んむっ、じゅぶっ……れろっ……はぁあ……ちんぽ……硬くて、\n熱くなっておるぞ……それにひくひく震えておる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0203209" ]},
		{"command":[ "SETIMAGE", "0", "still_00024102_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「妾の舌使いが堪らぬのであろう？　くあっ……あっ、あふっ、んんっ……\nひゃうっ……つ、強がってなどおらぬ……んぅうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0203210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「はあっ……！　あっ、ひうっ……んっ、んぶっ……あぁっ……そ、そこ弱い\nのじゃ……わ、妾だけでなく、おなごは皆弱いのじゃ……あぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0203211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「はっ、ああっ、あんっ……！　くり、くり……舌で、弄びおってぇ……ひぃ\nいっ、あぁぁ！　あっ、あふっ……はぁ、あぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0203212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「味わって、など……よく言えたものよ……くうっ、邪魔ばかりしておるくせ\nにぃ……ひぃんっ……ひぃい、い、いいっ……あぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0203213" ]},
		{"command":[ "SETIMAGE", "0", "still_00024102_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「んっ、んぶっ！　んぷぅっ……！　しゃぶって、やるから……おぬしも、\nさっさと……果ててしまえ……じゅっ、じゅるるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0203214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「ほれ、苦いつゆが……溢れてきておるぞ……んんっ、じゅぷ……余裕ぶって\nおるが、おぬしも……もうすぐ、なのじゃな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0203215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「はぁあ、はっ、はむっ、んむっ……そ、そうじゃ……妾も、い、いき……そ\nうじゃ……んんっ！　蜜も濃くなっておるか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0203216" ]},
		{"command":[ "SETIMAGE", "0", "still_00024102_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「くっ、くうっ……舌で、お、おくまで……んひぃっ！　ああっ……だ、だめ\nじゃ……もう、我慢が……んんっ、んっ、んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0203217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「頼むから、おぬしも……一緒に……んっ、おぬしの好きな、先っぽを……\nじゅぷ、じゅぷっ……しゃぶってやるから……んぢゅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0203218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「んっんっ！　んぶっ！　ほ、ほへ……おぬひも……じゅぶぶっ……んぅっ！\n　いっひょ、ひ……ぢゅく、ぢゅっ、ずちゅっ……ずずぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0203219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「んっんぶっ！　い、いくっ……んっ、んーっ！　んふぅっ！　はぁあ、らめ\nっ……じゃ……ひっ、んんぶっ！　んんんん～～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0203220" ]},
		{"command":[ "WAITINPUT" ]},

