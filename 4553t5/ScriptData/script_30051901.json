{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「お疲れ様です。今日は、どういった件でお呼びでしょうか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1903101" ]},
		{"command":[ "SETCHARA", "0", "char_00000519_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「いつも完璧な仕事で感謝する……それはどうも。ですが、それがウチの役目\nですから。改まって感謝されるようなことではありません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1903102" ]},
		{"command":[ "SETCHARA", "0", "char_00000519_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ん……？　なんですか……全て万能という訳ではない……ご奉仕の腕前はそ\nこまで完璧ではないと……？　フン……随分と安い挑発をされますね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1903103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「いいでしょう、そう仰るならば、夜のご奉仕においてもウチのパーフェクト\nなメイド術を見せてやるです。さあ、さっさとズボンを脱ぎやがるです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1903104" ]},
		{"command":[ "SETCHARA", "0", "char_00000519_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んっ……なんですか、このオチンポは……何もしてないのに、こんなに勃起\nさせて……最初からその気だったんですね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1903105" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000519_01_02" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「しかも……このにおい……くんくんっ……んんっ、鼻を近づけるまでもなく\n……濃厚なにおいが広がっています……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1903106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はぁっ、くんくんっ、すぅぅぅっ……はっ……ち、違いますよ……？　ウチ\nは、ただ、どの程度のにおいかを確かめようとしているだけで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1903107" ]},
		{"command":[ "SETIMAGE", "0", "still_00000519_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「それによって、どの程度綺麗にするかを考える必要が……んんっ、はぁぁっ\n……あぁ……こんな、強烈なのぉ……もう、選択の余地はないですぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1903108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「れろ、ちゅぷっ、んちゅっ……分かりました……ウチの全力をもって……こ\nのオチンポにご奉仕します……りゅぱっ、じゅぷっ、んちゅぷぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1903109" ]},
		{"command":[ "SETIMAGE", "0", "still_00000519_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「あぁ……んりゅぷっ、れろ……はふぁ……においに負けず……味もすごいで\nす……じゅぱっ……ずっと舌に残る味ぃ……れろ、りゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1903110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んんっ……こんなの、我慢できるハズありません……貴方のオチンポのにおい\nのせいですよ……？　ウチの指が、勝手に動くのはぁ……はっ、ふっ…！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1903111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はっ、んんっ……股間が疼いてしまうんです……このにおいを嗅いでると…\n…自然にオマンコが濡れてきてぇ……は……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1903112" ]},
		{"command":[ "SETIMAGE", "0", "still_00000519_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「あぁ……んんっ、オナニーしながら……ちゅぱっ、んふっ、ご奉仕フェラチ\nオ……しちゃってます……ちゅぱっ、んふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1903113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「最初は亀頭と……割れたところからぁ……ぴちゃ、んりゅっ、れろ、えろ…\n…れろぉ……れる……んりゅっ、える……れろぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1903114" ]},
		{"command":[ "SETIMAGE", "0", "still_00000519_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「たっぷり唾液をまぶしたら……んんっ、ぴちゃ……続けて裏筋……ちゅぷう\nっ……カリ高のところもぉ……えろ……れろぉ……しまひゅう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1903115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んふぅ……ウチの唾液で……でろでろです……はぁ、んっ、勃起が……ビク\nビクして……いやらしく蠢いています……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1903116" ]},
		{"command":[ "SETIMAGE", "0", "still_00000519_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ちゅぷっ、んちゅっ、ちゅぅぅぅっ……いっぱいキスを重ねてぇ……手で…\n…根元を軽く……シコシコして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1903117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「あふっ、どうですか？　ペロペロされながら……皮を扱かれるの……気持ち\nいいんじゃないれふか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1903118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ふふ……とぼけても無駄ですよ？　このオチンポの震え方が全部教えてくれ\nますから……んりゅっ、ちゅぽっ、くぷぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1903119" ]},
		{"command":[ "SETIMAGE", "0", "still_00000519_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「りゅぱっ、大分……オチンポのにおいも……綺麗になってきましたか……？\nんんっ、ウチのにおいと混ざり合って……やっぱりいやらしい感じです…… 」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1903120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んふっ、じゅるっ……少しお汁が滲んで来ましたね……んちゅっ、はふっ、\nんっ……ウチの股間も……似たようなものですが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1903121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はぁ、んっ、あぁ、オマンコの中……ヌルヌルになっちゃってます…こんな\n、れろっ、エッチな気分にさせられたら…我慢出来るわけないですから…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1903122" ]},
		{"command":[ "SETIMAGE", "0", "still_00000519_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んふっ、でも……今日は……ご奉仕の時間です……オナニーに夢中になるば\nかりではダメなことは分かってます……は、んふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1903123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「一番にするべきは……このオチンポにご奉仕をして……いっぱい気持ちよく\nなっていただいて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1903124" ]},
		{"command":[ "SETIMAGE", "0", "still_00000519_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「最後は……ウチの口で……全部受け止める……りゅぷっ、その為の……お時\n間ですからぁ……りゅぱっ、じゅぱっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1903125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んくぷっ、もっと深く咥えまふね……くぽぉっ、あぁ……んむっ、太い……\nお口に全部入らない位……立派すぎるオチンポれふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1903126" ]},
		{"command":[ "SETIMAGE", "0", "still_00000519_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「むぐっ、んふぅぅっ、りゅぷっ……はぁんっ、ふぉら……唇の感触……ぴち\nゃっ、んちゅっ、よく分かるれひょうっ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1903127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「出したくなったら……いつ出しても……いいれふからね……んっ、じゅるっ\n、ちゅぷっ、んちゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1903128" ]},
		{"command":[ "SETIMAGE", "0", "still_00000519_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「まだまだ我慢する……？　んふっ、全く……欲張りなオチンポですね……少\nしでも長く私のご奉仕フェラを楽しみたいと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1903129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はぁ……んむっ、ですが……そう長くは続けさせませんよ……本気でイカせ\nてあげますからね……くぽっ、じゅぷっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1903130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「じゅぷっ、んじゅぅぅっ……オチンポ、強く吸い上げながらっ……んふっ、\n根元をシコシコっ……皮をめくってっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1903131" ]},
		{"command":[ "SETIMAGE", "0", "still_00000519_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ちゅうぅぅっ……滲んできた、カウパー……全部、吸い上げまひゅっ……ん\nちゅるっ……はぁっ、指も……止まりまひぇんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1903132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「じゅぱっ……んはっ、あぁ……オチンポ……ビクビクしてっ、出したくなっ\nてまふねっ？　んっ、もう我慢しないで下さい……りゅぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1903133" ]},
		{"command":[ "SETIMAGE", "0", "still_00000519_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ウチの……口の中にっ……れんぶっ、らひてっ……じゅぽっ、熱いの……ド\nピュッとしてっ……ウチにゴックン……させてくらひゃいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1903134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「じゅぽっ、じゅるっ、んじゅっ、んじゅぅぅぅぅぅぅぅぅぅぅーーーーーっ\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1903135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000519_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んんっ！　んっふっ……あぷっ、れてまひゅぅ……こくっ、んくっ、んくん\nっ、こくっ、んんっ、はっ、ふぁっ……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1903136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ふごい量っ……一気に、れてまふ……んんっ、こぼれちゃう……くらいっ…\n…んぐっ、んちゅぷっ、ぷぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1903137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はぁっ、あふっ……どうですか……すごい勢いでしたが、ちゃんと全部飲み\nきりまひたぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1903138" ]},
		{"command":[ "SETIMAGE", "0", "still_00000519_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ……相変わらず濃厚すぎる精液です……いっぱい喉に絡みついて…\n…飲み込むのも一苦労でしたよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1903139" ]},
		{"command":[ "SETIMAGE", "0", "still_00000519_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「えっ……オナニーでイッたのかって……そ、それは……ノーコメントですっ\n。大体、察しやがれ……ですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1903140" ]},
		{"command":[ "SETIMAGE", "0", "still_00000519_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んぷぁ……さて……十分に予測出来たことですが、やはりオチンポは勃起し\nたままのようですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1903201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「分かっています。パーフェクトメイドのご奉仕はこれからが本番です。ふふ\n……貴方はそのままじっとしていて下さいね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1903202" ]},
		{"command":[ "SETIMAGE", "0", "still_00000519_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「れは……改めて……ちゅるっ、んちゅぷっ、んちゅうぅぅぅっ……まずは、\n一回で出しきれなかった分のお掃除から……ちゅるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1903203" ]},
		{"command":[ "SETIMAGE", "0", "still_00000519_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んふっ、これだけでも、結構な量がありますからね……ちゅるっ……残さず\n舐め取らなければパーフェクトではありません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1903204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「続けて、射精したばかりの敏感なオチンポを優しくケアするように、じんわ\nりと舐めてあげますね……ぺろ、ぴちゃ、れろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1903205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んふふっ……腰が引けちゃいますよね？　多少は仕方ないですが、痛くはし\nませんから、どうぞ楽にして受け入れて下さいね……ちゅぷぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1903206" ]},
		{"command":[ "SETIMAGE", "0", "still_00000519_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「れろ、んっ……他にして欲しいことはありますか？　可能な限りはご要望に\nお応えしたいと思っていますが……んちゅっ、ちゅぷぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1903207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「先端にキスをいっぱいして欲しい……ふふっ、なるほど……オチンポの先を\nツンツンされるキスがお気に召したみたいですね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1903208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ええ、お安い御用です……んちゅっ、ちゅっ、ちゅぱっ、ぴちゃっ、んちゅ\nっ……こんな感じで……いかがですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1903209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ふふっ、唇を軽く押し当てるだけなのに、オチンポが何度も震えて……この\nオチンポキスは……服従の証としてさせる人も多いと聞きます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1903210" ]},
		{"command":[ "SETIMAGE", "0", "still_00000519_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「貴方はウチのことを支配したいと……そういう風に思っている証拠ですか…\n…？　誤解？　まぁ、そういうことにしておきましょうか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1903211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ちゅっ、んちゅっ…んふっ、でも…ウチとしても、こうして、オチンポに\nキスの雨を降らせていると…また、身体の内側がムズムズしてしまいます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1903212" ]},
		{"command":[ "SETIMAGE", "0", "still_00000519_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、あぁ……また、指がオマンコに……んんっ、さっきは、イキ\nかけで……不完全燃焼だったのが効いてます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1903213" ]},
		{"command":[ "SETIMAGE", "0", "still_00000519_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「あっ、んふっ、けど……ウチのことよりも、大事なのは……貴方のオチンポ\nですから……んっ、メイドのおつとめは……ここからが本番です……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1903214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ちゅぷっ、ぴちゃっ……また、オチンポ……おしゃぶりしてもよろしいです\nか？　はい……もっと深く咥えこんで……味わわせて下さい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1903215" ]},
		{"command":[ "SETIMAGE", "0", "still_00000519_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ありがとうございまふ……れは……んふっ、ちゅぽっ、じゅぱっ、くぷっ、\nんりゅぷっ、くぷぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1903216" ]},
		{"command":[ "SETIMAGE", "0", "still_00000519_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んふ……さっきよりも、もっと舌をねっとり絡ませてぇ……りゅぱっ、オチ\nンポ全体に吸い付いて……じゅるっ、んちゅぷぅぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1903217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「腰が前にせり上がって来ましたね……ふふっ、また射精したくなって……我\n慢できなくなってるの……分かりまふよ……じゅぽっ、りゅぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1903218" ]},
		{"command":[ "SETIMAGE", "0", "still_00000519_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んぱっ、くちゅっ……んりゅぷっ……さあ、どうしたいれふか……？　貴方\nのお望み通りになさって下さい……じゅるっ、んちゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1903219" ]},
		{"command":[ "SETIMAGE", "0", "still_00000519_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「また口の中れも……んんっ、顔にぶっ掛けても……お好きになさってっ、ま\nた濃いの……いっぱい射精なさって下さいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1903220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んんっ、口にっ……らふんれふねっ……？　ふぁいっ、むぐっ……ろうろっ\n、らひてっ……んんんんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1903301" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「むぐぅっ……んっ、ふぶっ……！　あっ、ぷっ……また……ふごい……量っ\n……こんなにぃっ……んぐっ、こくっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1903302" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000519_01_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},	
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んはぁっ、あぁっ……らめれふ……この味ぃ……指が止まらなくてぇ……あ\nっ、んんっ、今度こそ……あっ、イクっ、は、うぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1903303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んちゅぷっ、ぷはぁっ……はぁっ、はぁっ、はぁっ……あぁ……んふっ、い\nっぱい出ましたね……はふぁ……大体は飲めました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1903304" ]},
		{"command":[ "SETIMAGE", "0", "still_00000519_01_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「れろ……んちゅぷっ、溢れた分は、今……綺麗にしてしまいまふね……ちゅ\nるっ……零してしまった分……もったいないれふから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1903305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ちゅぱ、ぴちゃっ……んっ、口元のも舐めて……後はオチンポの先端につい\nてる精液も……ちゅるっ、んっ……ごちそうさまです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1903306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「いかがでしたか？　ウチのご奉仕は……パーフェクトメイドとしては、まぁ\nまぁの働きだったのではないかと思いますが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1903307" ]},
		{"command":[ "SETIMAGE", "0", "still_00000519_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「えっ……？　今度はちゃんとイッたのか……？　そ、そこは重要ではないで\nしょうっ！　ま、まぁ……ウチもイキましたけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1903308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「そ、それでパーフェクト……むぅっ、何だか少し釈然としませんが……とに\nかく、満足されたのなら何よりです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1903309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「また次も……？　そうですね……日々のお仕事をしっかりとこなされた後の\nご褒美でよろしければ……喜んでご奉仕いたします」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1903310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「顔にっ……はんっ、掛けたいんれふねっ？　はいっ、じゅぱっ、最後にっ…\n…口を離しますからっ……そこで、ろうぞっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1903401" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ぷぁっ！　はぁっ、んんっ……あふっ……！　あぁっ、出てますっ……顔に\n……いっぱい掛かってますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1903402" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000519_01_16" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はぁぁ……このにおい……あぁ……もう、これを嗅いでるだけでぇ……指が\n止まらなくてぇ……ウチもっ、あっ、イ、イキますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1903403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んんっ、あぁ……ドロドロです……たっぷりの顔面シャワー……はぁ、お肌\nにザーメンが染み込んでいきますぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1903404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はぁ、んちゅぷっ……あぁ、指で掬って……れろっ、ぴちゃっ……んっ、こ\nの味……全然濃さが変わっていません……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1903405" ]},
		{"command":[ "SETIMAGE", "0", "still_00000519_01_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「れろ、ぴちゃ……待って下さいね……オチンポについてる分も舐めてしまい\nますから……ぴちゃ、ちゅぱ、んちゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1903406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はい、これで後始末もできました。オチンポ……お疲れ様でした……その、\nご満足いただけましたか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1903407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「パーフェクトですか。ふふん、まぁ、当然です。ウチはパーフェクトメイド\nですからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1903408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「一緒にオナニーでイッたところが良かった……そ、それはおまけの部分です\nっ！　もっとご奉仕のことを気にして下さいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1903409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ま、まぁ……満足されたのなら何よりです。また、ムラムラしたら……その\n時は、お申し付け下さいね……」", "NORMAL" ]},
