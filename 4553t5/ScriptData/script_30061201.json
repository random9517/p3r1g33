		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「ふぅ、今日の任務もお疲れ様。……どうしましたか？　わたしがこうして戦\nっているのはおかしいですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1203101" ]},
		{"command":[ "SETCHARA", "0", "char_00000612_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「ふふっ、あなたと出会っていなかったら、前線で戦えるほど強くなろうだな\nんて考えなかったでしょうね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1203102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「でも、いまは……って、そうじゃないんですか？　んぅっ、ちょ、ちょっと\nまって……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1203103" ]},
		{"command":[ "SETCHARA", "0", "char_00000612_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「こんなところで押し倒すなんて……。アンッ、そこっ、乳首を……んぅっ、\nはうぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1203104" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00000612_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「わたしの乳首になにを……んふっ！　あぁんっ！　それだめよっ、乳首……\nいじるの……！　あぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1203105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「任務中、ずっと気になっていたんですか？　わたしの乳首……んくっ、スー\nツ越しに、勃起してたから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1203106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「だって……このスーツは身体を締めつけてきて……。だから、胸も刺激され\nちゃって……んぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1203107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「開発されたおっぱい……どうしても感じちゃうんです……。アンッ、恥ずか\nしいスケベ乳だから仕方がないの……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1203108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「んっ、あなたが興奮しているのはわかりましたから、ここでするのはやめま\nしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1203109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「ほかの子が、任務の報告にやってきちゃうかもしれませんから。だから……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1203110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「あはぁあんっ！　スーツの上から、乳首が……ああっ、そんなっ、強くつま\nんじゃだめ……んっ、ああっ、ああ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1203111" ]},
		{"command":[ "SETIMAGE", "0", "still_00000612_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「あなたに、そんなふうに刺激されたら……どんどん勃起しちゃいます……乳\n首が……硬くなってしまいますから……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1203112" ]},
		{"command":[ "SETIMAGE", "0", "still_00000612_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「ああっ、スーツ越しにはっきりと形がわかるくらい、乳首が……勃ってしま\nって……恥ずかしいです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1203113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「んはぁっ！　ああっ、ああ……まって……！　そんなに、乳首を……んっ、\nんふぅ……はぁ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1203114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「指で、んくぅっ！　つまんで、ひっぱって……あひっ、ひぃいんっ！　そん\nなに乱暴に……あっ、ああぁああんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1203115" ]},
		{"command":[ "SETIMAGE", "0", "still_00000612_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「乳首をいじられるとっ、んくっ、感じてしまうから……ひぃっ、ひぃ……っ\n！　んはぁああぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1203116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「ドスケベ乳首感じちゃうぅっ！　ああっ、あなたの指で……乳首をオチンチ\nンみたいにしごかれて感じるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1203117" ]},
		{"command":[ "SETIMAGE", "0", "still_00000612_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「はっ、はいぃっ、エロ乳首で気持ちよくなっています……！　乳首シコシコ\nされて、い……イキそうです……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1203118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「あああ……っ！　イクッ、イクッ、もう我慢できません……！　乳首アクメ\n、キちゃう……！　ひぃっ、ひぃ……イク……ッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1203119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「あっはぁあああぁぁぁああぁぁあぁ～～～～んっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1203120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「んひぃ……ひぃ……イッたぁ……。乳首だけで……ああ……あなたにイかさ\nれちゃいました……ふぅ……はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1203121" ]},
		{"command":[ "SETIMAGE", "0", "still_00000612_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「ああ……言わないで……。ドスケベ乳首で……簡単にアクメしちゃうエロス\nーツ局長だなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1203122" ]},
		{"command":[ "SETIMAGE", "0", "still_00000612_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「こ……このスーツは、そんな……いやらしいことをする目的のものでは、な\nいんですから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1203123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「んくぅっ！　急に、なんですか……オチンチン……！　おっぱいに挟んで…\n…あっ、熱い……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1203124" ]},
		{"command":[ "SETIMAGE", "0", "still_00000612_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「勃起乳首丸わかりのエロスーツのせいで、ずっとこんな……オチンチンを硬\nくしていたんですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1203125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「んぁっ、だから処理させろって……そんな……今じゃなくても……あふっ、\nうぅんっ！　ああ、逞しいの……擦りつけられてる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1203126" ]},
		{"command":[ "SETIMAGE", "0", "still_00000612_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「オチンチンを、そんな……あっ、あぁっ、動かして……！　んぅっ、すごい\n……濃い匂い……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1203127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「んひぃっ！　乳首をつまんでっ、動かさないで……。ああっ、おっぱいが…\n…オチンチンをしごくのに使われてる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1203128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁっ、おっぱいでオチンチン感じるぅ……。わたしのおっぱいで\n……気持ちよくなってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1203129" ]},
		{"command":[ "SETIMAGE", "0", "still_00000612_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「ああ……あなたのオチンチンを見ていると……わたしまで興奮して……だめ\nなのにぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1203130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「こんなところで……オチンチンに夢中になっちゃいけないのに……。スーツ\nおっぱいをズリマンコに使われて……感じるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1203131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「あはぁんっ！　そ、そうです……感じてるのはおっぱいだけじゃなく……乳\n首も……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1203132" ]},
		{"command":[ "SETIMAGE", "0", "still_00000612_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「乳首っ、つままれてっ、動かされて……っ！　あひぃっ！　オチンチンをし\nごくのに使われて感じてますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1203133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「んひぃっ！　ま、またイク……また、イッちゃいそうです……！　ああっ、\nあなたも……ですか……？　あなたもイクの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1203134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「わたしのおっぱいでオチンチンしごいて……ああっ、イッてしまうの……っ\n！　んっ、ああっ、あはぁああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1203135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「ああっ！　あああぁぁぁんっ！　でてるっ、でてる……！　おっぱいに……\n熱いっ、精液……ああぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1203136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000612_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「そんなっ、精液びゅるってするたびに、乳首を強く……つまんだら……っ！\n　ああっ、ああ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1203137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「イクッ！　イクッ！　おっぱいで精液浴びながらっ、また乳首でイッくぅう\nううぅぅぅっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1203138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「ひぃい……ひぃい……勃起乳首いじめられながらイク……イキまくるぅ……\n。ふぅ……ふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1203139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「ああ……も、もういいですよね……？　さすがに、これ以上は……誰かがき\nちゃうかも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1203140" ]},
		{"command":[ "SETIMAGE", "0", "still_00000612_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「あひぃいいいぃぃぃんっ！！　ま、また乳首……そんなにぎゅうっとつねっ\nちゃ……だめぇえええぇぇぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1203201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「イッたばかりなのに、また乳首をごしごししごかれたら……っ！　アアッ、\n感じちゃいます……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1203202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「そ……そんな……。局長なのに、乳首イキしたからお仕置きだなんて……ん\nぁあ……あはぁ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1203203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「また乳首ぃっ！　ぎゅうってしながらおっぱいを乱暴に動かすなんてぇっ、\nああっ、んっ、んひぃいいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1203204" ]},
		{"command":[ "SETIMAGE", "0", "still_00000612_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「精液の匂いが……ただよってきます……。おっぱいにだされた……ドロドロ\nの……いやらしい精液の匂いぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1203205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「ああ……これ以上興奮したら、ますます乳首が勃起しちゃうのにぃ……。は\nぁ……だめ……だめなのぉ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1203206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「あひぃっ！　そんな、腰を動かしたら、ああっ、わたしのおっぱいマンコが\n、好き放題に犯されちゃって……あっ、ああ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1203207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「お仕置きされているのに、興奮しちゃう……！　おっぱいが疼いて、乳首が\nどんどん勃起するぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1203208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「エロ乳首……勃起デカ乳首になるぅ……。んひぃいっ！　そんなに乳首ひっ\nぱったら、伸びちゃうのぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1203209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「ひぃ……ひぃ……イクッ、イクッ、イク……ッ！　スーツ越し乳首っ、いじ\nりまくられてまたイクの……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1203210" ]},
		{"command":[ "SETIMAGE", "0", "still_00000612_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「くひぃいいっ！　ご、ごめんなさい……勝手に乳首アクメしてごめんなさい\nぃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1203211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「でも……あなたの指が気持ちよすぎるから……。ガチガチの勃起オチンチン\nでおっぱいを犯されるのも、興奮しちゃうの……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1203212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「くひぃっ！　はぁっ、はひぃいっ！　お仕置きしてくださいっ、もっと、わ\nたしのドスケベおっぱいにお仕置きしてぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1203213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「ドスケベスーツのおっぱいマンコ、あなたのオチンチンでいっぱい犯してく\nださいぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1203214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「んひぃっ！　はっ、はっ、んひゅぅううんっ！　オチンチン激しいぃっ！　\n熱いのが、おっぱいにこすれるぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1203215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「反省しますぅ……！　淫乱乳首を……スーツの中でビンビンに勃起させてご\nめんなさいぃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1203216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「お……お詫びに……。わたしのおっぱいマンコで……オチンチンすっきりさ\nせてください……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1203217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「ああ……はい……っ！　おっぱいに、お仕置き精液を浴びせてください……\n！　精液ぶっかけられて反省しますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1203218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「はっ、はぁっ、ああ……っ！　イク……ッ！　乳首つままれて、強制パイズ\nリでイッちゃいます……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1203219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「ああ、だしてっ！　だしてっ、だして……っ！　おっぱいに精液……いっぱ\nいだしてぇえええぇぇぇっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1203220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「あはぁあああぁぁぁ～～～～んっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1203301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000612_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「でてるっ！　でてますぅうううぅぅぅっ！　おっぱいにまた、ドロドロの精\n液……ああっ、ああぁ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1203302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「ひぃっ、ひぃっ、またイッてる！　おっぱいマンコ、またイッてます……イ\nッくぅうううぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1203303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「おお……オチンチン、ビクビクしながら……射精……し続けて……。んはぁ\n……ああ……おっぱいがドロドロ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1203304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「精液まみれ……淫乱おっぱいマンコが……あなたの精液でヌルヌルにぃ……\nはぁ……んふぅ……はふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1203305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「あんっ！　スーツの中に、精液を……んっくぅっ、注ぐなんて……ああ、そ\nんなぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1203306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「ああ……スーツと肌の間が、ヌルヌルにぃ……。んふぅ……こんな……気持\nち悪いのに……興奮して……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1203307" ]},
		{"command":[ "SETIMAGE", "0", "still_00000612_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……なんですか……？　このまま、スーツの上にいつもの服を\n着ろ……ですって……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1203308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「夜までそのまま……精液漬けになりながら、仕事をしろだなんて……そんな\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1203309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「わ……わかりました……。あなたの精液に包まれながら……ドスケベ局長、\n夜まで反省しますぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1203310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「んふぅうううぅぅぅっ！　はぁっ、ああっ、でて……るぅうううぅぅぅっ！\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1203401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000612_01_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「あっ、ああっ、凄い勢いで精液がっ、ンッ、飛び散って……あっ、ああっ！\n　顔にまで……きて……るぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1203402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「んひぃいいいぃぃぃっ！！　イクッ、イクッ、ぶっかけでイクぅっ！　ああ\nっ、ああ……っ！　イッちゃうぅうううぅぅぅっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1203403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「イッてる最中なのに、乳首しごかないでぇっ！　はぁっ、はぁっ、覚えるっ\n！　ぶっかけ乳首イキ覚えちゃいますからぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1203404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「んはっ、ひっ、ひぃっ、イクぅっ！！　ヌルヌル乳首しごかれてイクッ、イ\nクッ！！　またイク……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1203405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「反省してますっ！　本当に反省してますからぁっ！　乳首でイキまくりなが\nら、きちんと反省しますうぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1203406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「んぉっ、おおぉぉぉっ！　イクイクッ！　乳首イキまくるっ！　ひぃんっ、\nひぃんっ、とまらないぃいいぃぃっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1203407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「ごめんなさいっ、ごめんなさいぃっ！　ドスケベ乳首ぃっ、はしたなくアク\nメしまくってごめんなさいぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1203408" ]},
		{"command":[ "SETIMAGE", "0", "still_00000612_01_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「ああっ、もっとお仕置きぃ……乳首にお仕置きですか……このあとも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1203409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「はぁ……はいぃ……。お仕置き、お願いします……。淫乱勃起乳首……あな\nたの手で、懲らしめてくださいぃ……」", "NORMAL" ]},
