{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
        {"command":[ "DISPIMAGE", "0", "true" ] },
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},		{"command":[ "PLAYVOICE", "094_0103101" ]},		{"command":[ "SETNAME", "スティグマ" ]},		{"command":[ "SETTEXT", "「隊長さん、ごきげんよう。わたくしを呼び出したのは……つまり、そういう\nことなのでしょう？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00009401_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
        {"command":[ "SPOTCHARA", "0" ] },		{"command":[ "DISPNAME", "TRUE" ]},		{"command":[ "DISPTEXT", "TRUE" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "094_0103102" ]},		{"command":[ "SETNAME", "スティグマ" ]},		{"command":[ "SETTEXT", "「……わたくしをパワーアップさせる、そういう名目で辱めようというおつも\nりなのでしょう？　ふふふ、言わずともわかっていますよ」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00009401_01", "2", "CENTER", "0" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "094_0103103" ]},		{"command":[ "SETNAME", "スティグマ" ]},		{"command":[ "SETTEXT", "「わたくしはサイキック。あなたの思考は簡単に読むことができます。それで\n、何をさせるおつもりなのですか？」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "094_0103104" ]},		{"command":[ "SETNAME", "スティグマ" ]},		{"command":[ "SETTEXT", "「……え？　なるほど。口による、男性器の愛撫……フェラチオですね。存じ\nております……といっても、知っているだけで経験はありませんが」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00009401_01", "8", "CENTER", "0" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "094_0103105" ]},		{"command":[ "SETNAME", "スティグマ" ]},		{"command":[ "SETTEXT", "「ふふふ、不潔なものを口で奉仕させる……恥辱の極みですが、たしかにわた\nくしのパワーアップにつながる可能性もないわけではありませんね」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00009401_01", "2", "CENTER", "0" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "094_0103106" ]},		{"command":[ "SETNAME", "スティグマ" ]},		{"command":[ "SETTEXT", "「……くんくん。匂いますね。これがペニス……なんとも異様な形ですね。で\nすが膣に挿入し、射精することを考えれば、この形は必然なのでしょう」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "094_0103107" ]},		{"command":[ "SETNAME", "スティグマ" ]},		{"command":[ "SETTEXT", "「それにしても……勇気がいる行動ですね。汚物を口に含むも同然ですし……\nえ？　シャワーを浴びて、この匂いなのですか？　そうですか……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00009401_01", "3", "CENTER", "0" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "094_0103108" ]},		{"command":[ "SETNAME", "スティグマ" ]},		{"command":[ "SETTEXT", "「このまま見つめていても仕方ありませんね。あなたを最終的に気持ちよくす\nる必要があるのでしょう？　そろそろ心の準備を決めねばなりませんね」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00009401_01", "2", "CENTER", "0" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "094_0103109" ]},		{"command":[ "SETNAME", "スティグマ" ]},		{"command":[ "SETTEXT", "「ふぅ、では、始めま──ああ、もう、動かさないで下さい。すみません、こ\nんな身体ですので、ご不便をおかけいたします……ん、はあぁむ──」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009401_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "094_0103110" ]},		{"command":[ "SETNAME", "スティグマ" ]},		{"command":[ "SETTEXT", "「あむっ、むぐ……んちゅ……むぐむぐ、んんん、思ったよりも味がありませ\nんね……少ししょっぱいような……んぐ、んんんん……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "094_0103111" ]},		{"command":[ "SETNAME", "スティグマ" ]},		{"command":[ "SETTEXT", "「ん、んん……はむ、むぐむぐ……しゃぶるだけでいいのですか？　え？　あ\nあ、舌を動かすのですね……承知いたいました……れろ、れろれろ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009401_01_04" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "094_0103112" ]},		{"command":[ "SETNAME", "スティグマ" ]},		{"command":[ "SETTEXT", "「妙な味です……ぴちゃ、ねろ……はぁ、空気と味が一体化して、不思議な味\nわいになっています……ねる、れろ、れろぬる……はぁ、ふぅ……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "094_0103113" ]},		{"command":[ "SETNAME", "スティグマ" ]},		{"command":[ "SETTEXT", "「んれろ、ねろれろ、にゅる、んちゅぅ……え？　意外に上手？　ふふ、舌は\n比較的に自由になる部分ですからね……人より器用かもしれません」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "094_0103114" ]},		{"command":[ "SETNAME", "スティグマ" ]},		{"command":[ "SETTEXT", "「んぁむ、れろ、むぐ、んちゅ……ちゅぬる……んん、動かないで下さい。れ\nろ、れろれろ……ああ、じれったいですね……失礼します──」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009401_01_05" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "094_0103115" ]},		{"command":[ "SETNAME", "スティグマ" ]},		{"command":[ "SETTEXT", "「むぐむぐ、もご……んちゅ、れろれろ……動けない？　そうでしょう……サ\nイコキネシスで身体を拘束させていただきました……んちゅ、ぴちゃ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009401_01_06" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "094_0103116" ]},		{"command":[ "SETNAME", "スティグマ" ]},		{"command":[ "SETTEXT", "「ねる、れろれろ……この能力は、突然目覚めたものです……んちゅ、れるん\n、便利ですが、大きな代償を求められました……ちゅぬ、れろれろ……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "094_0103117" ]},		{"command":[ "SETNAME", "スティグマ" ]},		{"command":[ "SETTEXT", "「ねろれろ、ちゅぬぅ……ねろん……ふふ、サイキックの代償として、自身の\n身体を捧げなければなりませんでしたから……ぬるる、んちゅぅ……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "094_0103118" ]},		{"command":[ "SETNAME", "スティグマ" ]},		{"command":[ "SETTEXT", "「といっても、あなたを縛ったり、空中に持ち上げる程度でしたら問題ありま\nせん……ねろ、れろれろ、んちゅぅ……ふふ、ほら、この通りです」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "094_0103119" ]},		{"command":[ "SETNAME", "スティグマ" ]},		{"command":[ "SETTEXT", "「はむ、れろれろ、んちゅ……ぴちゃぁ……ふふ、空中で固定していた方が楽\nですね……ぬるる、れろれろ、ぴちゃ、んちゅ、ねろれろ……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "094_0103120" ]},		{"command":[ "SETNAME", "スティグマ" ]},		{"command":[ "SETTEXT", "「んはぁむ、ねるん……くちゅ、ちゅるれろ、ぴちゃぁ……はぁ、ふぅ……だ\nんだん慣れてきたように思います……ねる、ねろれろ、ちゅるれろん」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "094_0103121" ]},		{"command":[ "SETNAME", "スティグマ" ]},		{"command":[ "SETTEXT", "「ん、んん……動けなくて、もどかしい？　ええ、わたくしが普段から感じて\nいる感覚です……慣れると、それが逆に快感になりますよ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009401_01_04" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "094_0103122" ]},		{"command":[ "SETNAME", "スティグマ" ]},		{"command":[ "SETTEXT", "「んぁむ、むぐむぐ、もご、ぬちゅぅ……んん、ふぅ……それでも、舌だけで\nはなかなかままならないようですね……あむ、むぐむぐ、ねりゅん……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "094_0103123" ]},		{"command":[ "SETNAME", "スティグマ" ]},		{"command":[ "SETTEXT", "「んふふ、モゾモゾしていますね……ちゅぬ、れろれろ、肌をくすぐられてい\nるように感じているはずです……はむはむ、れろ、にゅるぅ……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "094_0103124" ]},		{"command":[ "SETNAME", "スティグマ" ]},		{"command":[ "SETTEXT", "「サイコキネシスで、あなたの身体を愛撫しています……もぐもぐ、ぬるる、\nれろぬりゅ、ぴちゃ……どうですか？　気持ちいいでしょう？」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "094_0103125" ]},		{"command":[ "SETNAME", "スティグマ" ]},		{"command":[ "SETTEXT", "「え？　くすぐったいだけ？　なかなかツボを探り当てられないようですね…\n…あむ、むぐむ、れろ、んちゅぅ……はぁ、ふぅ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009401_01_05" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "094_0103126" ]},		{"command":[ "SETNAME", "スティグマ" ]},		{"command":[ "SETTEXT", "「ん、んん……では、これでいかがでしょう？　んちゅ、ちゅむ、れろろ、に\nゅるぅ……ふふふ、身体が震えていますよ……ぴちゃ、ぬちゅぅ……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "094_0103127" ]},		{"command":[ "SETNAME", "スティグマ" ]},		{"command":[ "SETTEXT", "「ふふ、れろ、れろれろ……感度を上昇させました……ぬるる、ちゅぬ、ぴち\nゃぁ……震えていますね……気持ちいいでしょう？　ねろ、れるれる……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "094_0103128" ]},		{"command":[ "SETNAME", "スティグマ" ]},		{"command":[ "SETTEXT", "「ビクビクしてる……んちゅ、ねるねる、そろそろ、イキそうなのですか？　\nちゅぬる、れろれろ、構いません……イッて下さい……くちゅ、ちゅるる」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "094_0103129" ]},		{"command":[ "SETNAME", "スティグマ" ]},		{"command":[ "SETTEXT", "「……はぁ、ふぅ……精液を出すのですよね？　え？　飲め、ですって？　わ\n、わかりました……んちゅ、ちゅるる、れろれろ、ずるちゅずずるるぅ……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "094_0103130" ]},		{"command":[ "SETNAME", "スティグマ" ]},		{"command":[ "SETTEXT", "「ふぶぅぅぅ！？　んぶっ、んっ、んんんっ、んはぁ……はぁ……んむぅ！？\n　ごほっ、げほっ……はぁ、ふぅ……んぐぅ、ごくん……」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009401_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "094_0103131" ]},		{"command":[ "SETNAME", "スティグマ" ]},		{"command":[ "SETTEXT", "「はぁ、ふぅ……お、驚きました……こんなにいっぱい発射するとは……んぐ\nぅ、ごく、ごくごく……はぁあふぅ……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "094_0103132" ]},		{"command":[ "SETNAME", "スティグマ" ]},		{"command":[ "SETTEXT", "「酷い……匂い……です……ごく、んぐぅ、げほっ……それに、この味ぃ……\nああ、酷い……どんな薬よりも飲みづらい……はぁ、ふぅ……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "094_0103133" ]},		{"command":[ "SETNAME", "スティグマ" ]},		{"command":[ "SETTEXT", "「んんん、喉に張り付いてくる……ゴク……ゴクン……はぁ、はぁ、んちゅち\nゅ、ちゅるるる……ゴクン……はぁ、あふぅ……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "094_0103134" ]},		{"command":[ "SETNAME", "スティグマ" ]},		{"command":[ "SETTEXT", "「ふぅ……身体が衰えているので、飲み込む力も低下しているんです……ふう\n、でも、不思議ですね……なんだか、興奮してしまいます……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009401_01_10" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "094_0103135" ]},		{"command":[ "SETNAME", "スティグマ" ]},		{"command":[ "SETTEXT", "「ふふ、本来飲用すべきものではありませんからね、こんなものを飲ませるだ\nなんて……いけない人ですね……あなたって……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "094_0103136" ]},		{"command":[ "SETNAME", "スティグマ" ]},		{"command":[ "SETTEXT", "「ふふ、やあ、見ないで下さい……恥ずかしい……え？　恥ずかしい目に合わ\nせるために呼んだんだ……ですって？　確かにそうでしたね……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "094_0103137" ]},		{"command":[ "SETNAME", "スティグマ" ]},		{"command":[ "SETTEXT", "「はぁ……はぁ……ああ、頭がぼーっとします。少し無理をしすぎたかも……\n体力と精神に消耗はサイキックの代償ですから……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009401_01_11" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "094_0103138" ]},		{"command":[ "SETNAME", "スティグマ" ]},		{"command":[ "SETTEXT", "「けど、精液を摂取すれば……結果的にプラスになるかもしれません……わた\nくし、精液のことが好きになりそうです……ふふふふ……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "094_0103139" ]},		{"command":[ "SETNAME", "スティグマ" ]},		{"command":[ "SETTEXT", "「まぁ……まだこんなに硬いままだなんて。わたくしの知識では、射精をすれ\nば勃起が治まるはずだったのですが……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "094_0103140" ]},		{"command":[ "SETNAME", "スティグマ" ]},		{"command":[ "SETTEXT", "「これは……続きをした方がよさそうですね。わたくしも精液と、この行為自\n体が好きになったような気がします」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "094_0103201" ]},		{"command":[ "SETNAME", "スティグマ" ]},		{"command":[ "SETTEXT", "「確認のために、引き続きもう一度、射精をしていただこうと思います。隊長\nさん……構いませんか？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009401_01_10" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "094_0103202" ]},		{"command":[ "SETNAME", "スティグマ" ]},		{"command":[ "SETTEXT", "「え？　空中固定を解除して欲しい……？　いいえ、それは駄目です……ふふ\n、動くに動けない苦労、たっぷり味わって下さいね……んん、はぁぁむ──」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009401_01_09" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "094_0103203" ]},		{"command":[ "SETNAME", "スティグマ" ]},		{"command":[ "SETTEXT", "「あむ、むぐ、んちゅ、れろれろ、ねろん……ちゅちゅぅ……んん、ふぅ、オ\nチンチンから少しだけ精液の味がします……ねろんちゅ、ぴちゃぁ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009401_01_08" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "094_0103204" ]},		{"command":[ "SETNAME", "スティグマ" ]},		{"command":[ "SETTEXT", "「ねろ、れるる、ちゅぬ、んちゅぅ……ん、んん、はぁ……ねろれろ、ぬちゅ\nぅ……あぁ、かすかにオチンチン臭い……れろ、れろん……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "094_0103205" ]},		{"command":[ "SETNAME", "スティグマ" ]},		{"command":[ "SETTEXT", "「あむ、れろれろ、ねろん……んちゅぅ……そのような目で見られると、余計\nにドキドキしてしまいます……ちゅるる、ぴちゃ、ぬるれろ、ちゅぽん」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009401_01_07" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "094_0103206" ]},		{"command":[ "SETNAME", "スティグマ" ]},		{"command":[ "SETTEXT", "「ちゅぶ、ぬるぬる、れろん、ちゅちゅぅう……ふふふ、身体をくすぐるのを\n止めて欲しい？　駄目です……だって、楽しいんですもの」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "094_0103207" ]},		{"command":[ "SETNAME", "スティグマ" ]},		{"command":[ "SETTEXT", "「動けない中、相手に好き放題にされる恐怖感……ああ、ドキドキしてしまい\nます……ねろぬるる、ちゅぬ、ちゅるじゅるるぅ……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "094_0103208" ]},		{"command":[ "SETNAME", "スティグマ" ]},		{"command":[ "SETTEXT", "「え？　どんどん舌使いが上手になっている……ですって？　れろれろ、ぬる\nれろ……ありがとう、ございます……ぬるれろ、くちゅぅ……ふふふ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009401_01_05" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "094_0103209" ]},		{"command":[ "SETNAME", "スティグマ" ]},		{"command":[ "SETTEXT", "「恥ずかしいですけど、少し、楽しい……ぬるる、れろれろ、ずるちゅむ、く\nちゅちゅるぅ……はぁ、ふぅ……ああん、ドキドキが止まらない……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009401_01_06" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "094_0103210" ]},		{"command":[ "SETNAME", "スティグマ" ]},		{"command":[ "SETTEXT", "「ん、んんぅ、んぐ、ちゅぼ……ちゅるちゅる、ぐぶぅ……んん、げほっ、ご\nほっ……はぁ、あふぅ……奥まで押し込みすぎました……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009401_01_08" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "094_0103211" ]},		{"command":[ "SETNAME", "スティグマ" ]},		{"command":[ "SETTEXT", "「こういうことをしながらサイキックを扱うことに慣れてませんから……れろ\nれろ、ねろるる、ちゅぷ、ちゅるれろん……あふぅ……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "094_0103212" ]},		{"command":[ "SETNAME", "スティグマ" ]},		{"command":[ "SETTEXT", "「れろねる、ぬるる、ちゅぽん……はぁ、あふぅ、あなたと一緒に時間を過ご\nせば、こういうことになりますでしょうか……にゅる、ちゅりゅぅ……」", "NORMAL" ]},
