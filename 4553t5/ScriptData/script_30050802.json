		{"command":[ "PLAYVOICE", "v2_005_0804305" ]},
		{"command":[ "SETIMAGE", "0", "still_00000508_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
