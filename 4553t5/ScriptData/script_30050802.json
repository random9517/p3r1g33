		{"command":[ "PLAYVOICE", "v2_005_0804306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……あぁ……終わった……す、すみません……支えてもらって…\n…も、もう少しこのままで……いいですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0804307" ]},
		{"command":[ "SETIMAGE", "0", "still_00000508_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
