{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000508_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「ひゃっ！　ちょ……ちょっと……急になんですかっ……んっ、そんなもう待\nちきれないって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0804101" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「ここまで来たら……もうっ、後ちょっとだけ待てば……いいのにっ、こ、こ\nらっ、器用に脱がすなですっ、んぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0804102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「あ……こ、こんな時ばっかりめちゃくちゃ手際よく脱がしてぇ……何なんで\nすか、その妙な特技はっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0804103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「んくっ……だ、ダメです……そこ、触っちゃ……あっ、んふんっ……あ……\nあぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0804104" ]},
		{"command":[ "SETIMAGE", "0", "still_00000508_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「な、何ですか……ニヤニヤして。そうですよ、濡れてたら……何だって言う\nんですか……こ、こら……指……ダメです……あ、あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0804105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「そうですよ……ウチだって、期待してましたよ……それが何か？　こんなホ\nテルに来る時点で……そういうことだって分かってるじゃないですか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0804106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「んっ、あぁ……おちんちん……擦りつけないで下さい……ムズムズしちゃう\nじゃないですか……んっ、あ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0804107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「そんな、入り口ばっかりずっと……しつこいです……あぁ、何で……途中ま\nで抜群の手際で……今度は急に焦らすんですか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0804108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「も、もう……ベッドまで待てなかったんでしょう……それなら、さっさとし\nたら……いいじゃないですか……んっ、ふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0804109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「なっ……ウ、ウチがっ、言わなきゃ……入れない……何ですか、ここまでし\nておいてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0804110" ]},
		{"command":[ "SETIMAGE", "0", "still_00000508_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「あぁぅ……分かりましたからっ……あぁ……ちゃんと言います……ずっと我\n慢出来なかったです……からぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0804111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「お願いします……あなたのおちんちん……ウチの、あそこに……入れて下さ\nい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0804112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「あぅぅ、だからっ……お、おまんこっ……ウチのおまんこですっ、もうおち\nんちん欲しくて待ちきれなくなってるおまんこぉっ、は、早くぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0804113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「んんんんんんんんっ！　んふぁぁぁ……あっ、はぁぁぁぁんっ……あぁ……\nき、来たぁ……んっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0804114" ]},
		{"command":[ "SETIMAGE", "0", "still_00000508_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「あっくぅぅ……あっという間に……奥に、届いちゃいました……はぁぁ……\nおちんちん……すごく熱い……んくぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0804115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「んぅぅ……ずっと待ってたなんて、ウチは、あぁ……うんっ、くふっ……だ\nって、あなたが色々するから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0804116" ]},
		{"command":[ "SETIMAGE", "0", "still_00000508_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「気がついたら……その気にさせられたんです。ウチのせいじゃなくて……あ\nなたのせいですっ、んぁっ！　あっ、おちんちんっ……んくぅぅん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0804117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「あ、あぅ……今のだけで、ちょっとイ、イキそうでした……も、もうちょっ\nとだけ手加減して下さい……このままじゃ、ウチ……も、もう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0804118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「んはぁぁぁっ……あっ、これっ、そこっ、おちんちんが……ごりごりって、\n当たるとっ……はっ、んぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0804119" ]},
		{"command":[ "SETIMAGE", "0", "still_00000508_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「ダメです……想定していたより、ずっと刺激が強くて……んっく、た、立っ\nてられません……やっぱりベッドで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0804120" ]},
		{"command":[ "SETIMAGE", "0", "still_00000508_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「あっ、あぁっ！　身体……支えて……そんな所ばっかり逞しいの……何なん\nですかっ、はぁんっ、あっ、あぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0804121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「わ、分かりました……このままでいいですから……んっ、もうちょっとだけ\n……手加減して下さい……これ、感じすぎます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0804122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ、はい……それ位で……はっ、ふっ、んっ、あぁ……おちんちん\nの動きが分かる位が……ちょうど、いいです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0804123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「全くもう……サンタがスイッチなんですか？　ミニスカですか？　まさか、\nここまで猿みたいに盛るなんて思いも寄らないじゃないですか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0804124" ]},
		{"command":[ "SETIMAGE", "0", "still_00000508_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「あ……はぁぁぁ……んっ、ウチも……同じ……？　そ、それは……ウチも、\nいやらしい気持ち……なくはないですけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0804125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「し、締め付けてくるって……それは、んっ……あなたのおちんちんの動きに\n合わせて……し、自然になるからで……あっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0804126" ]},
		{"command":[ "SETIMAGE", "0", "still_00000508_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「そんな、元からスケベとか……そう、言われるのは……心外で……あっ、あ\nぁっ、そ、そこぉ……くひぃっ……あっ、いいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0804127" ]},
		{"command":[ "SETIMAGE", "0", "still_00000508_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「あっ……い、今のは……だって！　ず、ずるいです……ウチの弱いとこ、こ\nこぞとばかりに……責めるなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0804128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「あひっ、あっ……、あぁっ！　意地悪ばっかりぃっ、あっ、ダメですっ……\nおちんちんっ、あひぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0804129" ]},
		{"command":[ "SETIMAGE", "0", "still_00000508_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「んはぁっ……あふっ、ちょっとイッた……うぅー、結局イッちゃったじゃな\nいですか……おまんこ……こつんってされるの……すごすぎます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0804130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「あぁ……やだ、お汁が……垂れて来ちゃいます……やっぱり、ちょっと刺激\nが強すぎです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0804131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「どさくさ紛れに胸まで触って……んっ、く……あふっ……ウチのこと、どれ\nだけメロメロにさせるつもりですかっ……あっ、ぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0804132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「い、イヤって訳じゃないです。ずっとペースが乱されるのは不本意ですけど\n……でも、あなたがして、くれるのは……イヤじゃ、ないです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0804133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「んぁっ！　あっ、またっ、おちんちんっ……そんな……元気にっ、はぁんっ\n、あぁっ、いいっ……ですっ、あっ、中で震えてるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0804134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「射精っ……したいんですかっ？　ならっ、中ですっ……ウチの中にっ……子\n宮に精液出して下さいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0804135" ]},
		{"command":[ "SETIMAGE", "0", "still_00000508_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「おまんこの中……びゅくって……元気な精液でっ、いっぱいにっ……んぁっ\n、してっ……してぇぇぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0804136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「んぁぁぁぁっ……出て……ますっ、中……出てますっ……はっ、あぁぁぁぁ\nんっ、イクぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0804137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000508_02_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「はぁ、んふぁ……またイッた……あぁ……腰がまだプルプルしてます……ん\nふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0804138" ]},
		{"command":[ "SETIMAGE", "0", "still_00000508_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「いつもと違う格好だから、こんなに頑張ったんですか？　それとも、いつで\nもこんな感じなんですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0804139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「ま、まぁ……これだけ射精してくれたなら、この恥ずかしい格好もムダでは\nなかったです。それだけでも、ホッとしたです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0804140" ]},
		{"command":[ "SETIMAGE", "0", "still_00000508_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「でも……ま、まだです……これだけウチの身体に火を着けておいて、もう終\nわりとかダメですよ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0804201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「おちんちん、このまま……続きしますから。んっ、ウチも……その気になる\nように、んっ、こうして……んっ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0804202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「どうですか……？　こうして、くいって……お尻を振って、ウサギサンタの\n……えっちなダンス……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0804203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「もっと、おちんちん……して欲しいって……あっ、んっ、おねだり……しま\nすっ……ひゃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0804204" ]},
		{"command":[ "SETIMAGE", "0", "still_00000508_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「あっ、あぁぁっ！　またっ……スイッチ入りましたかっ？　はんっ、よ、よ\nかった……今の……めちゃくちゃ恥ずかしいんですからっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0804205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「ちゃんとっ、んっ……おちんちんっ……頑張ってくれないとっ……ダメなや\nつなんですからぁっ、はんっ、あっ、あひんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0804206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「んっ、さっきの……おまんこのとこ……こつんってするの、またして下さい\n。あれ……好きです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0804207" ]},
		{"command":[ "SETIMAGE", "0", "still_00000508_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「あんっ！　あっ、そ、それです……んんっ、ウチのおまんこの弱い場所……\n優しくつつかれるの……んっ、好きぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0804208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「はふっ、んぁっ、それで……ゆっくり掻き回すように、腰を使って……それ\nで……はひっ、そうです……ぴたってくっついて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0804209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……んっ、ウチも……頑張ります……この格好だと、ぎゅって…\n…おまんこに力を入れる位しか出来ませんけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0804210" ]},
		{"command":[ "SETIMAGE", "0", "still_00000508_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「んっ……いい、ですか？　んふぅ……なら、もっと強く、しても……いいで\nすよ。いえ……して、欲しいです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0804211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「あっ！　はぁぁんっ！　さっきよりガツガツ来てますっ、はぁんっ、ウチの\nおまんこっ……おちんちんに食べられてるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0804212" ]},
		{"command":[ "SETIMAGE", "0", "still_00000508_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「ひゃっ、ふっ、んふっ……ぐちゅって漏れるっ……愛液……どんどん出てっ\n、止まらないれふっ、恥ずかしい音っ……鳴ってるぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0804213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「んぁぁっ、ひぃんっ……！　食べてっ、いっぱい味わって下さいっ……！　\nエッチなサンタのっ……発情おまんこっ……あんっ、はぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0804214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「あっ、はぁんっ、すごすぎっ……おちんちんっ……強くてっ、また……ウチ\nっ……イッ……イクっ、あ、んぁぁぁぁぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0804215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「あぁ……イ、イッちゃいましたぁ……で、でも……大丈夫ですから……続け\nて、下さい……おちんちん、イクまで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0804216" ]},
		{"command":[ "SETIMAGE", "0", "still_00000508_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「んっ……鼻息が荒いです……あなたも、もう一回……おちんちん、イキそう\nですよね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0804217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「ちゃんと、分かります……この出る前の……感じ……はんっ、おまんこの中\nでビクビクって……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0804218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「くぅんっ、ふっ……あぁっ、またっ……強くっ、はっ、んっ、これっ、出る\nまで……一気にっ……はひっ、あぁっ、くぅんっ！」", "NORMAL" ]},
