		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「いいです……よっ……また、中に……下さいっ……ウチのおまんこ……待っ\nてますからっ……あ……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0804301" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「ひぁぁぁぁっ！　出てまひゅっ……熱いっ……せーえきっ……中出しっ……\nおまんこ……奥にっ……びゅくびゅく来まひゅうっ！」", "NORMAL" ]},
