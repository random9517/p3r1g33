{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016101_02_02" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「ふふ……さあ、また楽しい時間が始まるぜぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0104101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「しょうがねぇよなぁ、アタシをさんざんその気にさせて……何も済まない訳な\nいなんて、分かってるもんなぁ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「ま……そっちも、当然そのつもりだったんだろ？　ああ、別に返事はお前に\n聞いてねぇよ、こっちだ……こっちに聞いてる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0104103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「そうだよ……このおっ立ててる、ギンギンチンポ。正直だよなぁ……これ…\n…どういうつもりなんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0104104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「だよな、これだけオッパイガン見してるもんな。結構な巨乳好きってのがバ\nレちまってる訳だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0104105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「ほれ……入り口のトコ……こうして……んっ、ふっ、分かるか？　アタシも\nトロトロになってる……準備オッケーって訳だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0104106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「で、そっちもオッケー……さて、後はどうすれば始まるか……分かってるよ\nな？　ほら、このチンポはどうしたい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0104107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「ふふ……聞こえねぇぞ？　アタシのマンコを使いたいなら、チンポをハメさ\nせて下さい、どうかお願いします……だろ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0104108" ]},
		{"command":[ "SETIMAGE", "0", "still_00016101_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「ほら、ほら……それとも素股で満足しとくか？　マンコの入り口だけで、ド\nピュッと出して、それで終わりにしちまうかー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0104109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「くくっ、そうかそうか、そんなにチンポが疼いて仕方ねぇか。ずぶっとマン\nコに行きてぇんだな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0104110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「そこまで言うなら仕方ねぇな……へへ、すぐに漏らすなよ？　しっかりアタ\nシを楽しませるんだ……ほら……入るぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0104111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「んんんんっ……ふぅぅ……んくぅっ……あぁ……ズブっと来たぜ……あくう\nぅ……チンポハマるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0104112" ]},
		{"command":[ "SETIMAGE", "0", "still_00016101_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……あぁ、届いちまったなぁ……マン肉、押し広げて……しっか\nりチンポが吸い付いて来てる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0104113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「くぅ……んむっ……へへ、流石に粗チンって感じじゃなさそうだ……どうだ\n、アタシのマンコ……どんな感じだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0104114" ]},
		{"command":[ "SETIMAGE", "0", "still_00016101_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「熱くて柔らかくて……トロトロか……へへ、当たり前のことしか言わねぇな\n。もっと気の利いた感想はねーのかよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0104115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……もっと味わってから？　言うねぇ……それなら、お望み通り\nに……んっ、してやるよ……はっ、んふっ、くっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0104116" ]},
		{"command":[ "SETIMAGE", "0", "still_00016101_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「うんっ、はっ、どうだ？　アタシ自ら腰を振ってやってるんだ……ふっ、ん\nくっ……しっかりマンコの具合……確かめろよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0104117" ]},
		{"command":[ "SETIMAGE", "0", "still_00016101_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「んっく……おっと、まだお前に腰を振るのは許してねぇよ。今のお前のチン\nポは、動くの禁止のオナホールだ……じっとしてろ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0104118" ]},
		{"command":[ "SETIMAGE", "0", "still_00016101_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「何……んっ、ふっ、気が向いたら、それも許してやるよ……今は、大人しく\n……ヌルヌルマンコ……楽しんでろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「んくっ、ふっ、はっ、ふふっ……何だよ、随分と目線が落ち着かねぇな？　\n揺れるオッパイが気になって仕方ないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0104120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「間近で見られるのも役得だよなぁ。何だよ、金魚みてぇに口パクパクさせて\n……もしかして、吸いたいのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0104121" ]},
		{"command":[ "SETIMAGE", "0", "still_00016101_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「ようし……それなら、首持ち上げて吸ってみろよ、乳首で釣りだ……ほぉら\n……よっと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0104122" ]},
		{"command":[ "SETIMAGE", "0", "still_00016101_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「ははっ、もっと速く動かねーと逃げられるだけだぜ？　もう一回やってみろ\nよ、おっとと……こっちこっち……んっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0104123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「んくっ……！　へへ、食いついたな……いいぜ、捕まえたんならお前のモン\nだ……ほら……吸っていいぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0104124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「んっ、あぁっ……そうだ……遠慮なくイけ。はぁ……んっ、舌で転がして…\n…チュウっと吸って……いい感じだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0104125" ]},
		{"command":[ "SETIMAGE", "0", "still_00016101_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「あぁ……ギチギチにシコってやがる。乳首……マジ気持ちいいな……んっく\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「おっと……つい腰が止まっちまった。まだ腰は回しとかねぇとな……うんっ\n、んくっ、んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0104127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「あぁ……マンコジンジンする……こんなに濡れんの初めてだな……ぁふっ…\n…チンポも硬いままで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「っくぅ……もっと奥の方で……コツンって……あぁ……これ、いいわぁ……\nはっ、ふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「はっ、んっ、はぁっ……へへ、気持ちいいみたいだなぁ。どうだ、そろそろ\n出したくなって来てるんじゃねーか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0104130" ]},
		{"command":[ "SETIMAGE", "0", "still_00016101_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「チンポがビクビク震えて……バレてるぜ。まだだ、後もう少しだけ我慢しろ\nよ？　アタシがちゃんとイクまで、射精禁止だからな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「ふんっ、んくっ、はぁっ、あっ、あぉっ……あぁっ、チンポっ、感じるっ…\n…マンコに効くぅっ、くぅっ、たまんねぇっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0104132" ]},
		{"command":[ "SETIMAGE", "0", "still_00016101_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「そこだ……あぁっ、チンポ擦れてっ……くぅっ、続けてしたらっ、あっ、く\nぅっ、やべっ……も、うっ……あっ、くぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「はっ、んぁっ、あぁっ……暴れて来やがるっ……んくぅっ、乳首もっ吸われ\nてっ……よしっ、いいぜっ……射精っ……許してやるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0104134" ]},
		{"command":[ "SETIMAGE", "0", "still_00016101_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「このままっ、はっ、んふっ、中出しだっ……ヘタにこぼしたらっ、タダじゃ\nおかねぇからなっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0104135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「はっ、んふぁっ、さあっ、出せっ……マンコの奥っ……しっかり子宮までっ\n……チンポ汁っ……出せっ！　はっ、んぁっ、くっ……んぁぁぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0104136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「あっ……ひっ！　くぅぅぅぅぅんっ……出たっ……チンポっ……来てるっ、\nおぉっ、マンコイクっ……おひっ、イッ……くぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0104137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016101_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「はぁぁっ……おふっ……ドプッと来てる……くぅぅ……いいぞぉ……はぁぁ\n……やべぇ……たまんねぇ……あひぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「はふぁ……んっ、ふぅぅ……中出ししちまったなぁ……へへ、これでアタシ\n達は文字通りの抜き差しならぬ関係になっちまった訳だ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0104139" ]},
		{"command":[ "SETIMAGE", "0", "still_00016101_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「思った以上に、立派なチンポだったじゃねぇか……これなら……もっともっ\nと楽しめそうだぜ……なぁ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「さて……そんな訳で……気分も乗って来たところで、ノンストップの第二ラ\nウンドだ……んっ、くぅ……はっ、んむっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0104201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「当然まだまだ終わらねぇだろ？　少なくとも、チンポは今もビンビンにおっ\n勃ったままだもんなぁ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「んふっ、くぅぅぅんっ……たっぷりザーメンも出たから……このヌルっとし\nた感じ……前よりもっと気持ちいいぜ……ほら……んっ、はっ、んぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0104203" ]},
		{"command":[ "SETIMAGE", "0", "still_00016101_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「あぁ……マンコの襞が、超敏感になってる……カリと擦れて、っくぅ……あ\nぁ、そこぉ……マンコいい……すげぇ、いい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0104204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「んふっ……そっちはどうだ……？　ちゃんと、チンポ……感じてるか？　こ\nの締め付け……気に入ってるか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0104205" ]},
		{"command":[ "SETIMAGE", "0", "still_00016101_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「ははっ、らしくないか？　そうだな、さっきまでオナホールとしか見てない\nチンポに、妙な気を使っちまってるよな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0104206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「けど……どうせなら、お前のチンポが……アタシのマンコに……心から屈服\nする所も見たいもんな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0104207" ]},
		{"command":[ "SETIMAGE", "0", "still_00016101_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「くくっ……別に、すること自体は変わんねぇよ？　チンポとマンコを、ねっ\nとり絡み合わせて……んっ、汁をじゅくっと交換する……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「二人で……エロい気分になってくのが……いい感じだろ？　ほら……繋がっ\nてるトコ見えるか？　マンコをぱっくり開いて……中にチンポが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「くぅっ……んっくっ、はぁぅ……んっ、はっ、なぁ……また乳首吸ってくれ\nよ……放ったらかされて、ムズムズ来てる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0104210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「んっ！　そうだ……んふっ、ちゃんと舌を使え……何なら少し噛んだって…\n…くんっ！　てめ……言う前にしたな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0104211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「いい度胸だ……んっ、そんな……お前のチンポにはっ……こうっ、してっ…\n…んくぅっ……またマンコ、がっちりロックして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0104212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「ぐりっと回してっ……んっ、ふっ……気持ちいいか？　はっ、んんっ、くぅ\nっ……あぁ、まだだ、ちゃんとアタシも良くしてくれよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0104213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「んんっ、そうだ……乳首をしゃぶって……チンポ、回してみろっ……んっ、\nふっ、アタシのマンコ……もっと感じさせろっ、はっ、んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0104214" ]},
		{"command":[ "SETIMAGE", "0", "still_00016101_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「くぅぅ……全く、きかん坊のチンポだっ、はっ、んんっ、おぉっ、マンコっ\n……弱いトコばっかりっ、突いてくるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0104215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「くそっ……生意気なチンポめ……っくぅ……はんっ、あぁっ、止まらねぇっ\n……腰が、勝手に動いてっ……汁が溢れてっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0104216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「くぅっ、ぐちゅぐちゅっ……エロい音させてぇっ、はぁっ、火照ってるっ…\n…カラダっ……燃えてっ、くぅっ、チンポ効くぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0104217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「はぁっ、んふっ、まだイカねぇぞ……んっ、お前もヤバい筈だっ……このチ\nンポの震え具合……二発目……すぐだな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0104218" ]},
		{"command":[ "SETIMAGE", "0", "still_00016101_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「あぉっ！　くぅっ、ここでっ……ラストスパートだなっ……はぁんっ、いい\nぞっ、突けっ、もっとマンコ突けっ、くっ、あぉぉぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0104219" ]},
		{"command":[ "SETIMAGE", "0", "still_00016101_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「はぁっ、いよいよ……出るのか？　さあ……どうしたいんだ……射精っ、ど\nこがいいんだっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0104220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「んぅっ、くぅんっ、中だなっ……？　いいぞっ、もう一発……中にっ……出\nせっ……マンコに中出しっ……そらっ、出せぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0104301" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「んぁぁぁぁぁっ！　出たっ……あっ、チンポザーメンっ……打ち付けられて\nっ、くぅぅぅんっ！　イッ……くぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0104302" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016101_02_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「あ……ぁぁぁ……イッてるぅ……また、マンコっ……ドロドロにされてっ、\nはへぁっ……これっ……さっきよりっ、やべ……あ、ひぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0104303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「チンポの先が……びゅくびゅくっ……震えてっ、あっ、子宮っ……打ち付け\nてるっ……またっ、気持ちよくっ、あひぁっ、なるぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0104304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「くぅぅぅ……んんっ、あふぁっ……おぉっ……またっ……はぁっ、イクの来\nたっ……続けてっ、イ、イッてるぅぅぅっ……んはぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0104305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「チンポ……まだ出るのか……？　んくぅぅ……全部、出せよ……？　そうだ\n、腰……持ち上げて、奥に……出しきれぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0104306" ]},
		{"command":[ "SETIMAGE", "0", "still_00016101_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「んっ、ふぁ……はぁ……はぁ……終わったな……んっく……めちゃくちゃ出\nして……アタシを孕ませる気満々だったな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0104307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「くくっ、そうなったらどうするかなぁ。当然、きっちり落とし前はつけても\nらうとして……ガキを育てるってのも悪くないかもな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0104308" ]},
		{"command":[ "SETIMAGE", "0", "still_00016101_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「ははっ、めちゃくちゃ真顔になってやがる。大丈夫だよ、今日は多分、な」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「へへ……とりあえず、また次はどんな風に乱れてくれるか……楽しみに見せ\nてもらうさ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「はっ、ふっ、何だ……？　アタシに掛けたい？　へへっ、この期に及んで欲\n望丸出しのおねだり……キライじゃないぜ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0104401" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「ああ、いいぜ……その代わり、しっかり狙えよ？　ほら……お前の大好きな\nオッパイはここだからなっ……ほらっ、んんっ、出せっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0104402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「んふぁぁぁぁぁっ！　あっ、出てるっ……濃いのがっ……びゅくびゅくっ…\n…アタシもっ、んくぅぅっ、イクぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0104403" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016101_02_17" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「んふぁっ……いいぞ……派手に飛ばせ……んっ、べったりへばりつかせて…\n…んくぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0104404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「ああ……そこだ……おっぱいに塗り込めてやれ。んっ、ちゅぷっ……この味\n……申し分なしだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0104405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「はぁぁ……んっ、熱いな……もっと出せるか？　残り……直接チンポ押し付\nけて……腹んトコ……出しちまえ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0104406" ]},
		{"command":[ "SETIMAGE", "0", "still_00016101_02_16" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……ふぅ……これで終わりか……？　後から漏らしても面倒見き\nれねぇからな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0104407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「ふぅ……それにしても、まあたっぷり出したよなぁ……そんなにアタシのマ\nンコは良かったか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0104408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「くくっ、そうか、そうか。ああ、アタシも認めるよ。お前のチンポとの相性\nは抜群だった。間違いないな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0104409" ]},
		{"command":[ "SETIMAGE", "0", "still_00016101_02_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「そんな訳だから……まあ、また次も、楽しませてもらえそうだな。今度はど\nんな風に、襲ってやるか……へへ、よーくチンポを洗って待っとけよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0104410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}