		{"command":[ "SETIMAGE", "0", "still_00022003_02_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「はふぁぁ……あっ、あぁぁ……熱い……全身蕩けさせられちゃう……あふぁ\nぁ……はぁぁぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0304138" ]},
		{"command":[ "SETIMAGE", "0", "still_00022003_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「んっ、あぁ……射精……落ち着きましたか……はぁ……本当に全部中に出さ\nれちゃいました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0304139" ]},
		{"command":[ "SETIMAGE", "0", "still_00022003_02_12" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「今日は大丈夫だったかしら……んぅ……赤ちゃん……本当に出来ちゃったか\nも……はふぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0304140" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……あぁ……また、私……流されて……娘や夫になんて言った\nらいいのか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0304201" ]},
		{"command":[ "SETIMAGE", "0", "still_00022003_02_13" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「きゃっ！？　あっ……あのっ、あっ、んんっ、また、オチンポが膨らんで…\n…あっ、あぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0304202" ]},
		{"command":[ "SETIMAGE", "0", "still_00022003_02_14" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「何も考えずに……身を任せて……そ、それは……あっ、はぁぁんっ……また\nっ、オチンポぉっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0304203" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「あんっ、あっ、はぁっ、は、はい……そこを……ずぶってされるの……あっ\n、好きっ……好きです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0304204" ]},
		{"command":[ "SETIMAGE", "0", "still_00022003_02_11" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「はぁん……あぁ、ダメ……何も考えられない……んくう……太いオチンポ責\nめに逆らえる訳ないの……んぁっ、はぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0304205" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「はい……もっと突いて下さい……！　欲しがりオマンコは、あなたのオチン\nポをもっと頬張りたくて仕方ないんですっ、あっ、あぉんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0304206" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「あぁっ、罰当たりなことをしちゃってますっ……動物みたいにっ、後ろから\nオマンコ突かれてっ……くひっ、んひっ、いひぃんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0304207" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「神様に見せつけるなんて……あぁっ、は、恥ずかしいっ……こんな、お汁を\n溢れさせてるオマンコ見せちゃうなんてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0304208" ]},
		{"command":[ "SETIMAGE", "0", "still_00022003_02_12" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「んひっ！　また奥ぅっ……！　そんな、ズンズンされたらっ、あっ、私っ…\n…またっ、あぁぁっ、イ、イキますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0304209" ]},
		{"command":[ "SETIMAGE", "0", "still_00022003_02_14" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「はっ、はひ……また……イキました……やだ、オマンコ……イキ癖がついち\nゃってます……気持ちいいの……止まらないの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0304210" ]},
		{"command":[ "SETIMAGE", "0", "still_00022003_02_13" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「んっ、んんっ……は、はい……もっとヒクヒクさせます……私ばかりじゃな\nくて……貴方にも、何度もイッて欲しいですぅ……」", "NORMAL" ]},
