		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「んっ……あ、あの……私……えっ、分かってるって……あぁっ、いきなりそ\nんなバックからなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0304104" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、あ、あの……入れ……ないんですか？　えっ……わ、私次第\n……？　そ、それは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0304105" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「い、意地悪ですわ……でも、こんな風に焦らされたら……私……やっぱり…\n…我慢なんかできるわけありませんもの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0304106" ]},
		{"command":[ "SETIMAGE", "0", "still_00022003_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「お願いします……どうか、貴方の太くてたくましいオチンポを……欲しがり\nのふしだらな私のオマンコに……ハ、ハメて下さい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0304107" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「もうそのまま入れられる位に……はしたなく濡らしてしまってるんです……\nお願いします……どうか、オチンポを奥まで……あっ、はぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0304108" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「あっ、あぁぁぁん……！　入って……来ますっ！　オチンポッ……根元まで\nっ……届いちゃいっ、ますぅぅぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0304109" ]},
		{"command":[ "SETIMAGE", "0", "still_00022003_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「くぅぅぅ……んんんっ……！　あっ、はぁぁっ、は、はい……私は……今、\nオチンポを入れられただけでイッてしまいました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0304110" ]},
		{"command":[ "SETIMAGE", "0", "still_00022003_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「か、簡単にイッてしまう……淫らな母でごめんなさい……ど、どうしても我\n慢出来なかったんです……あぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0304111" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「は、はい……まだ大丈夫です……このまま続けて、私のオマンコをもっと味\nわって下さいませ……あっ、あふんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0304112" ]},
		{"command":[ "SETIMAGE", "0", "still_00022003_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「あっ、あんっ、あぁんっ……あぁっ、硬いっ……んくんっ！　はぁっ、奥で\n……ぐりぐり……突き刺して来るのっ……すごっ、いっ、ですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0304113" ]},
		{"command":[ "SETIMAGE", "0", "still_00022003_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「はい……んっ、あぁ……ご奉仕をしていた時から……もう、私……ずっと疼\nいていたんです……この逞しいオチンポで貫かれたらって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0304114" ]},
		{"command":[ "SETIMAGE", "0", "still_00022003_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「はぁっ、んんっ、今……それが叶ってっ……あっ、か、身体を支えるだけで\nもやっとなくらいにっ……すごい、ですっ、んひぃんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0304115" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「はっ、あぁっ……あっ、んっ……やだ……おっぱいも……あっ、敏感なまま\nなんです……そんなに揉みしだかれたら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0304116" ]},
		{"command":[ "SETIMAGE", "0", "still_00022003_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「んふっ……くぅっ……んっ！　あぁっ、オマンコ串刺しにされて……パンパ\nン音をさせて……こんな神社の境内なのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0304117" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「だ、ダメです……見せつけるなんて……こんな所……絶対に見せたらダメで\nす……あぁ、いやらしくよがってるお母さんでごめんなさい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0304118" ]},
		{"command":[ "SETIMAGE", "0", "still_00022003_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「はぁんっ、はい……私は……夫に内緒で、若い男の人のオチンポを自分から\n誘ってオマンコに咥え込む……いやらしい母親です……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0304119" ]},
		{"command":[ "SETIMAGE", "0", "still_00022003_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「あぁ……こんなこと言わせるなんて意地悪……あぁ……でも、んっ、はぁ…\n…オチンポがまた膨らんで……あっ、んぁっ、あひぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0304120" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「いけない人……んっ、私が乱れる姿で興奮してるんですね……？　それなら\n、私も……んっ、ふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0304121" ]},
		{"command":[ "SETIMAGE", "0", "still_00022003_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「んんっ、ほら……こうして締め付けると……んっ、オチンポ……弱いですよ\nね？　もう分かってるんですから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0304122" ]},
		{"command":[ "SETIMAGE", "0", "still_00022003_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「貴方のピストンに合わせて……私も……こうしてっ、はひっ、あふっ、んふ\nんっ、一緒に腰を回したら……あんっ、もっと気持ちよく……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0304123" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「んくっ……あふぅっ、あっ、はぁ……すごい……外で、あっ、こんな……は\nしたない音聞こえてるのに……お汁がどんどん溢れ出してぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0304124" ]},
		{"command":[ "SETIMAGE", "0", "still_00022003_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「あっ、あぉっ……あぁっ、私……いやらしすぎます……淫乱オマンコが……\nオチンポを頬張って……涎、垂らしてしまってぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0304125" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「ダメ……あぁっ、こんな激しいの、またイッちゃいますっ！　あっ、あぁん\nっ、はひっ、イクッ……イキますっ、オ、オマンコ……イクっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0304126" ]},
		{"command":[ "SETIMAGE", "0", "still_00022003_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「んんっ……んふぅぅぅ……あぁぁ……ま、またイカされちゃいました……も\nう腰がガクガクで……あんっ、あぁっ、ま、まだ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0304127" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「た、確かに……まだ、貴方をイカせてあげられてません……んっ、はい……\nも、もっと頑張らないと……んっ、くふぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0304128" ]},
		{"command":[ "SETIMAGE", "0", "still_00022003_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「あっ、あぁっ……またおっぱい搾られながら……オマンコ突きまくられて…\n…声が……出ちゃいますっ……あふっ、くぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0304129" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「あはぁぅっ、気持ちいいっ……オチンポ気持ちいいっ……ふといいオチンポ\nズポズポされるの気持ちいいですっ、もう止まらないっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0304130" ]},
		{"command":[ "SETIMAGE", "0", "still_00022003_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「あんっ、あぁっ、ダメぇ……声も出ちゃうっ……あっ、あぁっ、あんまり大\nきな声出したら……見つかっちゃうかも知れないのにっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0304131" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「こんな所っ、誰かに見られたら絶対言い訳できませんっ……あぁっ、発情し\nてるオマンコ見せつけちゃうなんて……そんなことぉっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0304132" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「はんっ、あふんっ、でもっ……あぁっ、そんなこと……考えたら考えるほど\n……オマンコ……じわってしてっ……あっ、私……またっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0304133" ]},
		{"command":[ "SETIMAGE", "0", "still_00022003_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「あっ、んんっ、でもっ……貴方もっ……もうすぐイキそうなんですねっ？　\nならっ……後少しっ、我慢しますっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0304134" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「はいっ、一緒にイキたいですっ……このまま、中にっ……出してっ……赤ち\nゃんのもとっ……オマンコに……下さいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0304135" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「あぁっ、ダメっ……もうイキますっ！　あひぃんっ、オチンポズボズボされ\nてっ、オマンコ……イクッ……イクぅぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0304136" ]},
		{"command":[ "SETIMAGE", "0", "still_00022003_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETTEXT", "「んぁぁぁぁっ……！　あぁっ……中に……熱いの……入って来てる……くぅ\nぅぅんっ……濃いのがオマンコいっぱいにしてますぅ……」", "NORMAL" ]},
