		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、こんな申し出を……私の方からしてしまうのは、はしたない\nことだと……重々承知はしています……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0304101" ]},
		{"command":[ "SETCHARA", "0", "char_00022003_01", "2", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「ですが、一度こうなってしまうと……私だけではどうにもならなくて……そ\nの、最近は夫もなかなか相手もしてくれず……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0304102" ]},
		{"command":[ "SETCHARA", "0", "char_00022003_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「あっ、す、すみませんっ。別に夫に不満があるとか、そういう話ではなくて\n……ただ、あっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0304103" ]},
		{"command":[ "SETCHARA", "0", "char_00022003_01", "3", "CENTER", "0" ]},
