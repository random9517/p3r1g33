		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「はぁふ……あぁっ……オチンポ抜けてるのに……オマンコ……震えて……は\nっ、んふぅぅぅぅんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0304402" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「やだ、私……お漏らしみたいに……あぁ……し、潮吹きなんて……は、恥ず\nかしすぎます……んぁぁ……止まってぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0304403" ]},
		{"command":[ "SETIMAGE", "0", "still_00022003_02_21" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「あっ、ふっ……この衣装……借り物なのに……精液も……愛液も……全部染\nみこんじゃいます……ふ、はぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0304404" ]},
		{"command":[ "SETIMAGE", "0", "still_00022003_02_22" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……はぁ……あぁ……お射精……終わりましたか……？　はひ…\n…あぁ……すごかったです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0304405" ]},
		{"command":[ "SETIMAGE", "0", "still_00022003_02_24" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「もう……最初はちょっとしたご褒美のつもりだったのに……いつの間にか、\n私の方が完全に夢中にさせられちゃいました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0304406" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「それと言うのも、貴方のオチンポが凄すぎるから……こんなの、逆らえる筈\nないです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0304407" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「でも……貴方のお陰で、ずっと奥に眠っていた燻りは……なんだか溶けてく\nれたような気がします……」", "NORMAL" ]},
