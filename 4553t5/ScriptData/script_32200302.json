		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「んんんんんーーーっ……！　はぁぁ……また、熱いの流れ込んで……オマン\nコ……いっぱいにされて……まひゅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0304301" ]},
		{"command":[ "SETIMAGE", "0", "still_00022003_02_16" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「オチンポが……ビクビク震えて……種付けしてるの分かっちゃう……あぁ…\n…こんなの、絶対妊娠しちゃいます……きもち……いい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0304302" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「んぁふっ……ま、まだ腰を動かして……射精しながら……ずっと私のオマン\nコ……貪られてるぅ……あ、あぁぁ……ん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0304303" ]},
		{"command":[ "SETIMAGE", "0", "still_00022003_02_15" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「はぁ……はふっ、あぁ……ポタポタ溢れて……溢れた分……止まらないれふ\n……私……お行儀悪すぎます……ふぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0304304" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「んっ……射精……終わりましたか……？　あ……ふっ、は、はい……お疲れ\n、さまでした……まだ中でとくんとくんって……動いてます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0304305" ]},
		{"command":[ "SETIMAGE", "0", "still_00022003_02_19" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「結局……いっぱいしちゃいました……私……いけない奥さんですね……貴方\nにも甘えてばかりで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0304306" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「んちゅ……んふ……ダメですよ、そんな優しいキス……んっ……また、私…\n…変な気持ちになっちゃいますから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0304307" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「え……違う？　これは……何も考えなくていい……欲望だけのキス……んっ\n、ちゅぷっ、ふふっ……そんなのってあるんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0304308" ]},
		{"command":[ "SETIMAGE", "0", "still_00022003_02_17" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「んっ、はぁ……ちゅぱっ……でも、不思議です……なんだか、ちょっとだけ\n気持ちが軽くなりました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0304309" ]},
		{"command":[ "SETIMAGE", "0", "still_00022003_02_18" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「はい……これ以上、難しいことは考えないで……今は、この心地いい感覚に\n浸っています……ありがとうございました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0304310" ]},
