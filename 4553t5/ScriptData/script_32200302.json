		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「でも、もっと締め付けないとぉ……ほら……ど、どうですか……？　んっ、\nオチンポ……キュンってしちゃいますから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0304213" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「あふっ……声が変わりましたね……ふふっ、今の……よかったんですね？　\nじゃあ、もっとこうして……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0304214" ]},
		{"command":[ "SETIMAGE", "0", "still_00022003_02_13" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「ほら、気持ちいいですよね？　んふっ……射精したばかりの敏感オチンポ…\n…また、次の精液……出したくなってないですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0304215" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「んぁひっ！？　あっ、あぁっ……！　ず、ずるいですっ……私に反撃された\nくないからって……また、乳首しながら……オチンポ突くのはっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0304216" ]},
		{"command":[ "SETIMAGE", "0", "still_00022003_02_11" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「んぁぁっ、先っぽ引っ張られてっ……こんなっ、でも、わ、私だって……ん\nっ、負けません……からっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0304217" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「はっ、あぁっ、オチンポまたビクビクって……！　いいんですよっ？　今度\nは先にイッてしまってもっ……くっ、んひぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0304218" ]},
		{"command":[ "SETIMAGE", "0", "still_00022003_02_13" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「あっ、ふっ……なんてっ……強がっちゃいましたけどっ……あっ、もう、私\nも無理っ……♪　オマンコよすぎてっ、無理ですっ、あっ、またっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0304219" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「イクっ……続けてイキますっ！　オマンコッ……イキますからぁっ……！　\nまたっ、イキっ……ますぅぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0304220" ]},
		{"command":[ "SETIMAGE", "0", "still_00022003_02_11" ]},
