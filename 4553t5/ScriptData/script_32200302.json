		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「ふっ、んぁっ、はぁっ、あぁっ……ジンジンします……襞がよじれて……腰\nの真ん中がムズムズしてぇ……」", "NORMAL" ]},
