{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0180" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_005" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「はぁっ……。はぁ、はぁ、はぁ……。つ、疲れた……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_010022390001" ]},
		{"command":[ "SETCHARA", "0", "char_00019601_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ぐだぐだになってしまった自己紹介を終えて、アトロポスが大きくため息をつ\nく。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「アトロポス。ご苦労であった。これで三人全員の自己紹介を無事終えられた\nな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_010022390001" ]},
		{"command":[ "SETCHARA", "0", "char_00019401_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「……簡素にではあったが、女王の気にかけていた男を直接見る事が出来て良\nかった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_010022390002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「召喚に応じてくれてありがとう、カツマ。また、機会があれば再会するとし\nよう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_010022390003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まあ……喜んでもらえたんならよかったです」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そろそろ、こっちの眠気もピークに達しそうだ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "刺激的なスケベダークエルフの魅力をもってしても、俺の頭はフラフラしてく\nる。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「真夜中に呼んだから、眠くなっちゃったよね～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_010022390001" ]},
		{"command":[ "SETCHARA", "0", "char_00019501_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「それじゃあ、今日はそろそろお開きにしよーかぁ。それで～、カツマくんは\nこの後わたしとおちあってぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_010022390002" ]},
		{"command":[ "SETCHARA", "0", "char_00019501_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「二人っきりの甘ぁい夜を過ごそうよ……って、ひゃっ！？　なになにぃっ！\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_010022390003" ]},
		{"command":[ "SETCHARA", "0", "char_00019501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ブゥンッ……！", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "つい最近、自分の部屋で聞いたばかりのワームホール出現の音。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "それと共に、城の一部が歪み……再び闇が溢れ出してきた！", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「こ、これ……って今から俺が帰る穴……とか？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「違う！　これは異なる場所からの干渉……どこかから繋がれた穴だ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_010022390004" ]},
		{"command":[ "SETCHARA", "0", "char_00019401_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「えーっと……この穴を作り出したのは……皆さんなんですよね？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「いやいやいや、違う、違うよぉ！？　こんなの聞いてない！　聞いてないっ\nてば！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_010022390002" ]},
		{"command":[ "SETCHARA", "0", "char_00019601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「わたしたちはあなたと仲良くお話してたから……ホールを呼ぶ暇なんてなか\nったよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_010022390004" ]},
		{"command":[ "SETCHARA", "0", "char_00019501_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「確かに……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「ならば、誰がホールを拡張したというのだ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_010022390005" ]},
		{"command":[ "SETCHARA", "0", "char_00019401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ダークエルフ三姉妹の間に緊張が走り、俺とジュンジローも唾を飲む。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「……もし、敵がこの時間城へ侵入しようとしているのだとしたら……倒すし\nかあるまい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_010022390006" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「カツマ。貴方は後ろに下がっていろ。私達三姉妹が、本気を出すとこの一帯\nが危険区域になる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_010022390007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「それに貴方を巻き込むことは出来ない。早く……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_010022390008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「とはいっても……！　戦力は１人でも多い方がいいんじゃ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「あ、そういえばカツマさんって……お仕事が中間管理職っていうか……どこ\nかの隊長さんなんだよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_010022390005" ]},
		{"command":[ "SETCHARA", "0", "char_00019501_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「それなら、わたしたちをうまーく使ってくれれば……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_010022390006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「ならぬ。もし、彼に傷一つつけてみろ。女王が悲しむ顔は見たくない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_010022390009" ]},
		{"command":[ "SETCHARA", "0", "char_00019401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「でもー、後ろから少しでも助言してくれれば勝率があがるかもしんないじゃ\nん！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_010022390003" ]},
		{"command":[ "SETCHARA", "0", "char_00019601_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「そ、それは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_010022390010" ]},
		{"command":[ "SETCHARA", "0", "char_00019401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「わ……わかった。やれるだけやってみる。指示を出すぞ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "三人" ]},
		{"command":[ "SETTEXT", "「了解！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_010022390011" ]},
		{"command":[ "PLAYVOICE", "v2_195_010022390007" ]},
		{"command":[ "PLAYVOICE", "v2_196_010022390004" ]},
		{"command":[ "SETCHARA", "0", "char_00019401_01", "6", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "1", "char_00019501_01", "6", "CENTER", "0" ]},
		{"command":[ "SETCHARA", "2", "char_00019601_01", "6", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "DISPCHARA", "2", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……いくぞ！　クロートー！　ラケシス！　アトロポス！　カツマ！　謎の\nワームホールにゼットストレートアタックをかけるぞ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「うん！　ってじゃああんたは誰なのよ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_010022390005" ]},
		{"command":[ "SETCHARA", "2", "char_00019601_01", "3", "CENTER", "400" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや……黒い三人組を見ると、つい……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「はぁあ～！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_010022390006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「……来るぞ！　穴が開く！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_010022390012" ]},
		{"command":[ "SETCHARA", "0", "char_00019401_01", "3", "CENTER", "-400" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "DISPCHARA", "2", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0180" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_001" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「んふふふふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_010022390001" ]},
		{"command":[ "SETCHARA", "0", "char_00017801_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "構えを取った俺達の前に現れたのは、妖しげな、触手の生えた美女……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「二周年おめでとう……。祝宴にかけつけさせてもらったわ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_010022390002" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "彼女はワームホールから現れた直後に、俺の顔に着地して……そのまま思いっ\nきり飛び上がった。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「んぐぁあああ！！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご、ご主人を踏み台にしたぁ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022390001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "顔面を強打されて、俺が床に崩れ落ちる頃。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "正体不明の女は、クロートー達三姉妹の前に優雅に降り立っていた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「……ふう。遅くなってしまってごめんなさい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_010022390003" ]},
		{"command":[ "SETCHARA", "0", "char_00017801_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「あ、貴方は一体……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_010022390013" ]},
		{"command":[ "SETCHARA", "0", "char_00019401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「私は天野川ホールディングスの経営者。またの名は、実力と容姿を兼ね備え\nた人気歌手……天野川・織姫・あゆむ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_010022390004" ]},
		{"command":[ "SETCHARA", "0", "char_00017801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「主に触手の素晴らしさを世界に広めるために、この手による洗脳を繰り返し\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_010022390005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「この世に優秀な『悪』を次々と排出させてもらっている者よ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_010022390006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「天野川・織姫・あゆむ……？　あっ、聞いたことがあるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_010022390007" ]},
		{"command":[ "SETCHARA", "0", "char_00019601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「あ～っ。わたしも知ってるかも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_010022390008" ]},
		{"command":[ "SETCHARA", "0", "char_00019501_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「あなたってぇ、何よりも触手を愛する触手姫で……。触手を否定する相手に\nは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_010022390009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「自分触手を刺して強制的に触手大好きにしてしまう魔性の敏腕社長……！　\nあの有名な天野川さんでしょう～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_010022390010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「っていうかアーちゃん、ふっつーにファンなんですけど！　あ、あのっ、サ\nイン！　サインもらえませんか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_010022390008" ]},
		{"command":[ "SETCHARA", "0", "char_00019601_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「もちろん。私の音楽がわかるだなんて、貴方……なかなかよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_010022390007" ]},
		{"command":[ "SETCHARA", "0", "char_00017801_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「うわぁあああ……♪　あ、ありがとうございます！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_010022390009" ]},
		{"command":[ "SETCHARA", "0", "char_00019601_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「ふふふ……可愛い子。触手が生えていたらもっと可愛かったけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_010022390008" ]},
		{"command":[ "SETCHARA", "0", "char_00017801_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「それで……貴殿は何をしにここへ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_010022390014" ]},
		{"command":[ "SETCHARA", "0", "char_00019401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「……確かに、その説明を忘れていたわね……。私は彼に……カツマに会いに\nここまで来たのよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_010022390009" ]},
		{"command":[ "SETCHARA", "0", "char_00017801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「へっ！？　ま、また俺！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「そう。クロートー。貴方が刻の女王の意向で彼に……隊長に興味を示したよ\nうに、私も彼に興味があるの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_010022390010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「いずれ接触しようと思っていたのだけれど……ちょうど二周年でキリが良か\nったし、お祝い事は好きだから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_010022390011" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「この機会を逃してはならないと思って、多少強引な方法を取らせてもらった\nというわけ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_010022390012" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「さ、さっきから言っている二周年ってなんなんだ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「フフ……それを今、貴方が知る必要はないわ。とにかく、私は素晴らしい日\nに素晴らしい事を成しにきた」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_010022390013" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「言える事はそれだけよ。あと、触手属性の優遇を運営に訴えに来たの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_010022390014" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「運営……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "これ以上深く突っ込むのも怖かったので、俺は彼女の言いたいようにさせてや\nることにした。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「よくわからんが、アンタはとにかく有名な歌手で社長で……触手が好きって\nことだよな」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「ええ。その解釈で間違いないわ。で。……貴方、触手は好き？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_010022390015" ]},
		{"command":[ "SETCHARA", "0", "char_00017801_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「触手は目で見て楽しむ派？　女の子に生やす派？　自分に生やす派？　自然\n発生がお好み？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_010022390016" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「触手にはたくさんのタイプがあるでしょう？　どれが好きかしら。粘着力が\nあるもの、ないもの、どちらを選ぶの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_010022390017" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「へぇっ！？　えっ、ぁっ……あっ、うあっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "とてつもなく鋭い眼光で問われ、俺はその場に硬直した。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「す……少し考えさせてください……」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「そうなの？　触手はいいわよ……。これからは、あなたも触手の素晴らしさ\nを知ってちょうだい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_010022390018" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「そして触手を愛さぬ者を、共に滅し……フフ。フフフ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_010022390019" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「と、これ以上は祝いの席にふさわしくない表現がまろび出てしまいそうだか\nらやめておきましょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_010022390020" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「なにそれ、こっわぁ～……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_010022390010" ]},
		{"command":[ "SETCHARA", "0", "char_00019601_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「……ああ、いけない。楽しすぎてつい口が滑ってしまったわね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_010022390021" ]},
		{"command":[ "SETCHARA", "0", "char_00017801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「私はこれから刻の女王との打ち合わせがあるから……そろそろいかなくちゃ\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_010022390022" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「あっ。女王様のお客様だったんですねぇ～。じゃ、わたしがご案内しま～す\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_010022390011" ]},
		{"command":[ "SETCHARA", "0", "char_00019501_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「よろしくお願いするわ。本当に、二周年おめでとう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_010022390023" ]},
		{"command":[ "SETCHARA", "0", "char_00017801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「だから、二周年ってなんなんだよ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「天野川さま～。あたしも案内します～☆　きゃははは！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_010022390011" ]},
		{"command":[ "SETCHARA", "0", "char_00019601_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「…………」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「…………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_010022390015" ]},
		{"command":[ "SETCHARA", "0", "char_00019401_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "立ち去ってしまった次女と三女、そして触手姫を見送って……俺とクロートー\nは二人でひたすら絶句していた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「この後どうしろってんだ……。ぐだぐだにも限度があるだろ……」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「こ……こうなったら仕方ない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_010022390016" ]},
		{"command":[ "SETCHARA", "0", "char_00019401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「な、何かいい案でもあるのか！？　クロートー！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「だ、第３部でお会いしよう！　本日はここでお別れだ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_010022390017" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おいおいおいおいっ！　ぶん投げもいいところじゃないか！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「わ……私が終焉と言ったら終焉なのだ！　そらっ、元の世界に帰るが良い！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_010022390018" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "sbg_0000" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
		{"command":[ "SETTEXT", "ぶぉん！", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "……俺とジュンジローは、真っ暗なワームホールに飲み込まれ……。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0149" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "元いた自室に放り出された。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うぉぁあ！？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ら、乱暴にもほどがありますぞぉーっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022390002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「どいつもこいつも滅茶苦茶だ……。酷い目にあったぞ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「しかし……とびきりキャラの濃い４人でしたな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022390003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「これは……次のシーズンも見逃せませんぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022390004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「次のシーズンってなんだよ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「って、やっべぇええ……。かなり時間を食っちまったじゃねーか！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "慌てて確認すると、真っ暗な部屋の時計は午前４時を指し示していた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うああああっ、明日俺５時起きなんだぞ！！　どうしてくれるんだよ！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「寝るぞ、寝るぞジュンジロー！　もう一刻の猶予もない！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「はいですぞ、ご主人！　……あっ、きちんと毛布は掛けてくだされ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022390005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「わーってるっつうの！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "sbg_0000" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "……こうして、俺は一旦、刻の女王とその配下のダークエルフ三姉妹……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "モイライシスターズについて考える余裕を無くした……。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}