{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0147" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "特訓を終えて、俺たちは学園に戻ってきた。", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ひ……ひどい目に……あった……」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「でも、おかげで新しい力を手に入れることができたよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020115900001" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「そのおかげで、金棒が何本かダメになっちゃったんですけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020115900001" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「わたしのパワーについていけなくなっちゃったのかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020115900002" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「俺に一撃を当てようとするたびに金棒がひん曲がってたよな。針金みたいに\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「そんなに！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020115900003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「そうでしたよ。鬼の金棒を地面に叩きつけて曲げちゃうなんて、人間とは思\nえないパワーでした！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020115900002" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「そっか……。ふふっ、ならやれるね。みんなを助けられる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020115900004" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "桃花は特訓で新たな力に確かな手ごたえを感じているようだが……。大丈夫か\n？　洗脳された連中を気絶させる程度で済むのか？", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「夜日楽、次にみんなと戦うときは、お願いね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020115900005" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「金棒ですか？　い、いいですけど……大事に扱ってくださいね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020115900003" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「一晩で金棒を十本以上ダメにしたって、お姉ちゃんが知ったらなんて言われ\nるか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020115900004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「わかってるって。何回も特訓して、金棒を壊さないくらいの加減はわかった\nからさ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020115900006" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「特訓のとき、そう言いながら何本も曲げてましたよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020115900005" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「そ、そうだった……？　あははは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020115900007" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「ところで珠魚先生は？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020115900006" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「珠魚先生は、途中で帰ったみたい。なんだかわたしを見ていろいろ研究意欲\nがわいたとか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020115900008" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「へぇ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そのとき、俺は意識もおぼろげだったからはっきり覚えてない。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「というか、お前のケガは大丈夫なのかよ」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「うん、なんか武器を２つ持つことにしたあたりから、急に身体の調子もよく\nなった気がするのよね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020115900009" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「レベルアップしたってことかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020115900010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「たぶん、そうだと思います？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020115900007" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "はたして、それはいいことなのだろうか。夜日楽の反応もはっきりしない。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "俺から見れば、明らかにいままでよりヤバいもんに成長してるような気もする\nが……。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「見つけた……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115900001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「覚悟しなさい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_010115900001" ]},
		{"command":[ "SETCHARA", "0", "char_00002401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なっ、ルナテミス！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「バッケンハンターに、ガン・シスターも……。塾の生徒たちもいる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020115900011" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「こんな朝早くにやってくるなんて！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020115900008" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「ヒヒヒ……不運にも作戦がバレちゃったからには、計画を隠してもムダだよ\nね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_030115900001" ]},
		{"command":[ "SETCHARA", "0", "char_00001803_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「とっととあさイチで攻撃を仕掛けるのが一番である」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_050115900001" ]},
		{"command":[ "SETCHARA", "0", "char_00002005_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「さあ、塾生たち！　キミたちの不運の元凶を破壊しつくすのだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_030115900001" ]},
		{"command":[ "SETCHARA", "0", "char_00002203_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "洗脳された生徒たちと一緒に、アナザー３人組まで現れやがった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "いま、学園にいるのは俺たちだけ。そして、戦えるのは……。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「ど、どうしましょう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020115900009" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「戦うしかないよ、３人で」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020115900012" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "おいまて桃花。おまえとの特訓でボロボロになってる俺を頭数にいれるんじゃ\nぁない！", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「そうですね。応援がくるまで、３人でここを守り切りましょう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020115900010" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "夜日楽まで！？　鬼か！？　……いやおまえは鬼だったな。そうじゃなくて！", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "……ああもう、こうなったらやるしかねぇ！", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}