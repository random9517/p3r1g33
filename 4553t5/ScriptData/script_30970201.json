{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「どうした、隊長。なんか悩み事か？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0203101" ]},
		{"command":[ "SETCHARA", "0", "char_00009702_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「日焼け止めを塗りたいけど、自分じゃ全部塗れない？　なら、オレが塗って\nやろうか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0203102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「へへっ。遠慮すんなって。オレと隊長の仲じゃねぇか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0203103" ]},
		{"command":[ "SETCHARA", "0", "char_00009702_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「それじゃ……こうして胸にたくさん日焼け止めを塗って、っと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0203104" ]},
		{"command":[ "SETCHARA", "0", "char_00009702_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「準備完了だ。まず前から塗ってやるから、その履いてるズボンを脱いでもら\nおうか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0203105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「なに驚いてやがる。まさかオレがこんなことすると思ってなかったのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0203106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00009702_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「普通に背中にだけ塗って欲しいって？　それじゃあ面白くないだろ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0203107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「それに……こんなにガチガチにしてたら、説得力がねぇぞ？　ほら……こう\nして挟むだけでも、気持ちいいだろ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0203108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「谷間を圧迫するだけで、ビクビク震えてるぜ。そんなにオレのおっぱいが気\nに入ったのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0203109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「なんでこんなことするのかって……べ、別に他意はねぇよ。ただ、隊長はホ\nクシィよりオレを選んでくれたから……その……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0203110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「あー、もう！　なんでもねぇ！　ちょっとした恩返しとでも思ってろ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0203111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「それに、こんなことするのは今回限りだ！　メモリーズ・オブ・サマーって\nヤツだよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0203112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「いいから、オレに任せとけ……！　んっ、くうぅ……確かこうして、ヌルヌ\nルのおっぱいで全体を擦るようにして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0203113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ひゃうぅ！？　なんかメチャクチャ跳ねたぞ！？　もしかして、痛かったの\nか……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0203114" ]},
		{"command":[ "SETIMAGE", "0", "still_00009702_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「オレのおっぱいが気持ちいいから、思わず反応した……？　そ、そうか。気\nに入ってくれたんだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0203115" ]},
		{"command":[ "SETIMAGE", "0", "still_00009702_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「へへっ。隊長に気に入ってもらえて、オレも嬉しい……じゃなくて！　オレ\nのおっぱいなんだから、当たり前だろうが！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0203116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「そもそも、ホクシィたちはこんなことしてくれないだろ。オレだからして貰\nえるんだぜ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0203117" ]},
		{"command":[ "SETIMAGE", "0", "still_00009702_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「そこらへんをちゃんと理解して、感謝の気持ちを忘れず、常にオレの側に居\nりゃいいんだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0203118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「そうすりゃ……こうしておっぱいを上下に擦ったりして、いっぱい気持ちよ\nくしてやるから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0203119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「オォウ！　隊長のから透明な汁が出てきてる……相当感じてるみたいだな。\nオーケー、いま楽にしてやるよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0203120" ]},
		{"command":[ "SETIMAGE", "0", "still_00009702_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「んっ、はっ、はあぁ……あっ、あはあぁ……！　傘みたいなとこが、谷間で\n擦れて……あぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0203121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「おっぱいをずりゅずりゅ擦るたびに、先端から我慢汁がドクドク出てきてる\nぜ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0203122" ]},
		{"command":[ "SETIMAGE", "0", "still_00009702_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「擦れば擦るだけ出て来やがる……まるで噴水みたいだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0203123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ただ、ニオイはちょっとキツイっていうか……んっ！　なんか、クセになる\n感じが……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0203124" ]},
		{"command":[ "SETIMAGE", "0", "still_00009702_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「これが隊長の……オスのニオイ……はあぁ、あっ！　オレまで興奮してきち\nまったじゃねぇか……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0203125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「くっ、はあぁ……んぐっ、ふああぁ……！　どんどん熱く、硬くなってきて\nやがる……こいつは想像以上だな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0203126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「中途半端にシコシコしてるだけじゃ、オレの方がイッちまう……！　しょう\nがねぇ、ラビットパワー全開で行くぜ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0203127" ]},
		{"command":[ "SETIMAGE", "0", "still_00009702_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「んっ、はぁ、あっ、くううぅ……ど、どうだ……！　全体を包み込みながら\n、ズプズプ擦られる感覚は……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0203128" ]},
		{"command":[ "SETIMAGE", "0", "still_00009702_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「へへっ。気持ちいいみたいだな……アソコの震えが、さっきよりも激しくな\nってきてるぜ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0203129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「なら……こういうのはどうだ？　円を描くようにおっぱいをぐにぐに動かし\nて、撫でるように責め立てて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0203130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「傘の部分だけじゃなくて、根本までおっぱいの感触が響いて気持ちいいだろ\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0203131" ]},
		{"command":[ "SETIMAGE", "0", "still_00009702_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「言葉では否定しても、身体は正直みたいだぜ……何度も小刻みにアソコが動\nいて、イキたいって主張してきてやがる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0203132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「出すなら好きなだけ出していいぞ……！　さっきも言っただろ。ちょっとし\nた恩返しだって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0203133" ]},
		{"command":[ "SETIMAGE", "0", "still_00009702_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「だからオレのことは気にしないで、おっぱいの感触をしっかり味わいな……\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0203134" ]},
		{"command":[ "SETIMAGE", "0", "still_00009702_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ほらっ、イケッ！　イケッ！　好きなだけおっぱいに精液をブチまけろっ！\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0203135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「んぐううぅっ！　あっ、熱っ……！　隊長の子種が、勢いよく飛び出て……\nはああぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0203136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009702_01_05" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「胸の中で暴れながら、次から次にクサイ汁をまき散らしてやがる……あっ、\nああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0203137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「えっと……確か射精中に擦れば、さらに気持ちいいってウキヨエに書いてあ\nったな……！　だったら、こうして……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0203138" ]},
		{"command":[ "SETIMAGE", "0", "still_00009702_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「くううぅ……！　さっきよりも勢いが増して……あっ、ああっ！　どぴゅど\nぴゅが止まらねぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0203139" ]},
		{"command":[ "SETIMAGE", "0", "still_00009702_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「こんなに出るなんて知らなっ……んんっ！　あっ、くっ、あんっ、ふあああ\nぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0203140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「派手にブチ撒けたじゃねぇか……オレのおっぱい、そんなに気持ちよかった\nのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0203201" ]},
		{"command":[ "SETIMAGE", "0", "still_00009702_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「素直に頷かれると、こっぱずかしいな……でもまあ、頑張ってウキヨエで勉\n強した甲斐があるってもんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0203202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ちっ、違っ！　別に隊長のために勉強したんじゃなくて……！　そういった\n面でも、ホクシィに負けないようにだな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0203203" ]},
		{"command":[ "SETIMAGE", "0", "still_00009702_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「って……なんで出したばっかりなのに、また硬くなってんだよ！？　こうい\nうのって、一回出したら終わりなんじゃ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0203204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「オレが可愛いくて大きくなったから、もう一回して欲しい……？　んなっ、\nオマエ……！　ちっ……わかったよ。あと一回だけな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0203205" ]},
		{"command":[ "SETIMAGE", "0", "still_00009702_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「相手がオレだから、こうして付き合ってやってるんだぞ……？　これがもし\n、ホクシィなら……んっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0203206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「オレが話してるのに、勝手に腰を振るんじゃねぇ……！　えっ……今はオレ\nだけを見て居たいから、ホクシィの話をして欲しくない……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0203207" ]},
		{"command":[ "SETIMAGE", "0", "still_00009702_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ばっ、バカ野郎！　なに言って……！　ううぅ……！　隊長の言葉がすげぇ\n嬉しくて、アソコの奥がきゅんきゅんする……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0203208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「クソっ！　いいからさっさとするぞ！　二回目だからって、容赦しないから\nな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0203209" ]},
		{"command":[ "SETIMAGE", "0", "still_00009702_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「アソコが濡れてるのがバレる前にイかせないと……！　さっきみたいに、全\n体を撫でまわすようにしながらシコシコして……んっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0203210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「はぁあぁ……谷間からぬちゅぬちゅって変な音が……！　それに蒸れた精液\nのニオイが、鼻の奥に届いて……はぁっ、あっ、ああっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0203211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ヤバい……！　おっぱいでヌプヌプしてるだけなのに、感じすぎちまう……\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0203212" ]},
		{"command":[ "SETIMAGE", "0", "still_00009702_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「はぁ、はあぁ……擦れば擦るほど、ニオイが濃くなっていくぅ……！　それ\nに、谷間もどんどん熱くなっていって……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0203213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「いろんな汁が混ざって、汚くてクサイのに……隊長のをシコシコしてるって\n思うと、全然イヤじゃなくなっていく……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0203214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ああっ、隊長……！　オレ、なんかどんどん変になってる……！　身体中が\n火照って、隊長のを求めてるんだ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0203215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「隊長のをいっぱいシコシコして、気持ちよくしてやりたいって……んんっ！\n　はぁ、はぁ……た、隊長……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0203216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「んくうぅ！　そんな……急に激しく腰を振られたら、おっぱいが気持ちよく\nなる……！　オレまでイッちまうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0203217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ！　んっ、ふあっ、あああぁん！　隊長のがビクビクして……ま\nたイクんだな！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0203218" ]},
		{"command":[ "SETIMAGE", "0", "still_00009702_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「オレもイキそうだから……！　もっと強く腰を振ってくれ……！　おっぱい\n、いっぱいシコシコするから……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0203219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「あっあっ！　んっ、あっ！　好きな時に出してくれ！　いっぱい、隊長のを\n感じさせて……！　あぐっ、ふっ、ふあああぁ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0203220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「んぐううぅ！　隊長の熱い精子、またオレの胸の中に……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0203301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009702_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「肌にネバネバが張り付いてる……！　ビキニのせいか、余計に隊長の精液を\n感じるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0203302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「そうだ……射精中もいっぱいシコシコして、尿道の奥に残ってる分も出した\n方がいいんだったな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0203303" ]},
		{"command":[ "SETIMAGE", "0", "still_00009702_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「んっ、くううっ……！　あっ、はあぁっ……擦るたびにどぴゅどぴゅが強く\nなって……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0203304" ]},
		{"command":[ "SETIMAGE", "0", "still_00009702_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「あっ、ぐうぅ……ダメだ……！　精液の出る感触だけでイッ……イクぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0203305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……はぁ、ああっ……どうやら、全部出し切ったようだな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0203306" ]},
		{"command":[ "SETIMAGE", "0", "still_00009702_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「オレの胸はどうだ？　ホクシィなんかより、よっぽど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0203307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「まだオレだけを見て居たいから、ホクシィの話はするなって……？　ったく\n、しょうがねぇな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0203308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「隊長がそんなにオレにメロメロだとは思ってもみなかったぜ。意外と独占欲\nが強いんだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0203309" ]},
		{"command":[ "SETIMAGE", "0", "still_00009702_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「まぁ……ウサギは寂しいと死ぬって言われてるぐらいだから、オレも独占欲\nが強い方なんだろうな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0203310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ノォオオオォ！？　どうして急に腰を引いて……あぶっ！？　隊長の精子が\n顔にかかってっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0203401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009702_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「あっ、んぐっ！　はぁ、あああぁん！　これ、日差しよりも熱いっ！　焼け\nるような子種が、たくさん飛び出て……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0203402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「やっ、あんんっ！　まだ出るのかっ！？　二回目なのに、どれだけ出すんだ\nよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0203403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ひゃううぅ！　鼻のすぐ側に精子がかかって、キツいニオイが……ダメだ、\nニオイだけでイッちまう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0203404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「あっ、はあああっ！　イクっ！　アソコの奥から熱いのこみ上げてきて……\n！　あっ、あっ！　イクっ！　イクぅ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0203405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「はぁー……はぁー……ったく、なんてことしやがるっ！　火傷しそうだった\nじゃねぇか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0203406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ったく……精子がかかったのが顔だったからいいものを……耳にかかってた\nら、大変なことになってたんだからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0203407" ]},
		{"command":[ "SETIMAGE", "0", "still_00009702_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ウサギってのは耳で体温調節をしたり、感情を表現したりするんだ。だから\n耳は特に大切に扱わなきゃいけないんだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0203408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「いま耳がピンと持ち上がってるけど、どんな気持ちなのかって……？　これ\nは、その……嬉しいときの反応で……って、そんなこと聞くんじゃねぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0203409" ]},
		{"command":[ "SETIMAGE", "0", "still_00009702_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ガッデム！　いいか、この耳の形は怒ってるときの合図だ！　よーく覚えと\nけ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0203410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}