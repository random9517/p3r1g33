		{"command":[ "SETIMAGE", "0", "still_00016705_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「一回イッて……敏感になっているが、まだ、オマンコは……動かせるからな \n……はっ、あぁっ、んふっ、くぅぅっ……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0504202" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
