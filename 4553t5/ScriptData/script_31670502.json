		{"command":[ "SETCHARA", "0", "char_00016705_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「この辺は確かに人気がないが……あ、主殿……急にどうしたんだっ……その \n、オ、オチンポを出して……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0504104" ]},
		{"command":[ "SETCHARA", "0", "char_00016705_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「こ、この上で、スクワットをする……それは……つまり、その……そういう \n、ことか……主殿の命令とあらば……」", "NORMAL" ]},
