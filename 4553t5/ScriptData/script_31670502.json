		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「さて……まだ時間はあるし、せっかくのビーチだ。もう少し身体を動かした \nいところだな。どうだ主殿、ビーチバレーでも……」", "NORMAL" ]},
