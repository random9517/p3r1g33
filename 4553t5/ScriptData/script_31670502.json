		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……両手を頭に置いて……最初は……普通にスクワットから…… \n分かった……んっ、ふっ、んんっ……うんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0504106" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「なるほど……これだけ足を広げて大きく腰を落とせば、確かにかなりの運動 \nにはなりそうだ……だが、ビキニをずらさなくても……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0504107" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「乳首が……揺れないように無駄のない動きをする為……そ、そういうことな \nらば……んっ、ふっ、んくっ、んふんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0504108" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「どうだろうか……んっ、まずまずの動きが出来ていると思うが……この調子 \nで……わ、分かった……んっ、ふっ……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0504109" ]},
		{"command":[ "SETIMAGE", "0", "still_00016705_02_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「ふっ、んっ、たしかに……これは……しっかりと足に効く……訓練には最適 \nかもしれないが……んっ、ふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0504110" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「目が自然に向いてしまう……し、仕方ないだろう……こんな……勃起オチン \nポを前にして……んっふ……お預けをされるようなものだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0504111" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「一歩前に出ていい……あぁ……それは、要するに……挿入しろという……こ \nとでいいのだな……？　わ、分かった……行くぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0504112" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はぁっ、うっ、んんんっ……！　あぁっ、は、入るぅっ……オチンポっ…… \nあぁ、オマンコの中に……入っていくぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0504113" ]},
		{"command":[ "SETIMAGE", "0", "still_00016705_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あ、あくまでも……運動が本来の目的……わ、分かっている……このまま上 \n下にスクワットをすれば……いいんだな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0504114" ]},
		{"command":[ "SETIMAGE", "0", "still_00016705_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「ふっ、はっ、んくっ……はうっ、んんっ、あっ、あぁっ、はぁぁんっ……あ \nぁっ、太いっ……くぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0504115" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んんっ……ふっ……ここから、身体を……上下、させるっ……大きく、動か \nして……はっ、んんっ、いちっ、にっ、いちっ、にっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0504116" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あくぅぅぅぅ……あっ、おおぉっ、思った以上に……これは、んっ、下半身 \nに……効きそうだ……ふ、んくっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0504117" ]},
		{"command":[ "SETIMAGE", "0", "still_00016705_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「しっかりと、踏ん張りを効かせて……また、身体を持ち上げるっ……あぁっ \n、オチンポっ……ずるって抜けそうに……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0504118" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「ここで、また……深く……腰を落とすっ……はぁぅんっ！　あぁっ、太い… \n…オチンポが……めり込むぅぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0504119" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はっ、んんっ、これを、ゆっくりと……繰り返していく……腕の位置も…… \nこのままなのは、なかなか……きついな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0504120" ]},
		{"command":[ "SETIMAGE", "0", "still_00016705_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「だが、はぁっ、んっ……それだけいい運動になるということだ……あふっ、 \n何より……オ、オマンコが……気持ちいい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0504121" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んんんっ……だが、それに溺れてはダメだ……これは鍛錬がメインなんだか \nらな……身体を支えて、垂直に動かしていく……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0504122" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はぁっ、うんっ、んんっ……あぁっ、腰を浮かせる瞬間……オチンポが、気 \n持ちいいところを擦りまくっている……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0504123" ]},
		{"command":[ "SETIMAGE", "0", "still_00016705_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はぁっ、あふっ……それに、この熱……んんっ！　オチンポの熱を直接味わ \nって……身体をくねらせると……汗が滲んで止まらない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0504124" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「大丈夫だ……まだ、この程度で音を上げたりするものか……これでも、日々 \nの鍛錬で鍛えているんだからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0504125" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「もっと、オチンポを軸にして……んっ、スクワットを繰り返すっ。いちっ、 \nにっ、いちっ、あぉっ、おっ、おほっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0504126" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はぁっ、あっ、あひぁっ、カウント……できないっ……あっ、自然にいやら \nしい声が……漏れてしまうっ、は、ひっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0504127" ]},
		{"command":[ "SETIMAGE", "0", "still_00016705_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「けどっ……し、仕方ない……んっ、オマンコが……良すぎるからっ……太く \nて硬いのがっ、堪らないからぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0504128" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んっく、ダメだ……バランスを崩す訳にはいかない……しっかり前を向いて \n……んっ、スクワットするんだ……はぁっ、あぉっ、くぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0504129" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んんっ！　くぅ……集中しないと……あっ、ふっ……すぐ、イッてしまう… \n…んんっ、主殿のオチンポ……良すぎるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0504130" ]},
		{"command":[ "SETIMAGE", "0", "still_00016705_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はぁっ、あぁっ……乳首……凝ってる……？　そ、それはぁ……こんなに、 \nドキドキさせられたらぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0504131" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あっ、はひぁっ……乳首……おっぱいだって……興奮するに決まってる…… \n！　はぁぉっ……ズリズリ……来るぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0504132" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ、あぁっ……こ、ここでもっとペースアップ？　そんなことをし \nたら……んんっ、いや、分かった……泣き言は言わぬっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0504133" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はっ、はぁっ、んんっ、本気の……オマンコスクワットっ……！　あぁっ、 \n全力で……オチンポを扱き上げるっ！」", "NORMAL" ]},
