		{"command":[ "FADEOUT", "NORMAL" ]},		
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はぁぁぁぁっ、熱いの……子宮に流し込まれてぇ……ふぁぁ……ダメだ、こ \nれぇ……感じ……すぎるぅぅぅ……」", "NORMAL" ]},
