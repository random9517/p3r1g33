		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はぁっ、んんっ、だ、だが……こんなにもっ、あぁっ……オチンポとの相性 \nがいいと……んんぅっ、あっ、ぉぉっ！」", "NORMAL" ]},
