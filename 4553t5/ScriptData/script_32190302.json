		{"command":[ "SETIMAGE", "0", "still_00021903_02_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「はあぁぁぁ……お仕置きザーメン……あぁぁ、でも、これ……ご褒美ぃ…… \nあぁ……どぷって、あ、溢れてるぅ……受精しちゃう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0304302" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「はふぁぁ……あぁ……いっぱいになって……オマンコの隙間から垂れて来ち \nゃう……んくぅ……お汁……漏れてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0304303" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「んぁふっ……あぁ……チンポ……止まった……やっと、射精……落ち着いた \n……？　はふぁ……おっぱいの方も止まった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0304304" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「うん……んふ……はぁ、はぁ……お仕置き……ありがとう……ございました \nぁ……あぁ……すご……かったぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0304305" ]},
		{"command":[ "SETIMAGE", "0", "still_00021903_02_14" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「おっぱいが、ずっと刺激されたままで……あぁ、どうしよ……これ、外れた \n後も……ずっと敏感なままかも知れない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0304306" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「もしかしたらブラ越しでも感じちゃったりして……あぁ……おっぱい、こん \nなに気持ちよくなっちゃうなんて……淫乱過ぎるよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0304307" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「本当に……？　ちゃんと、おっぱいの面倒……見てくれるの……？　途中で \n飽きたりしちゃわない……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0304308" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「う……うん……じゃあ、また疼いちゃったら……お願いするから……気持ち \nよくしてね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0304309" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「今度はお仕置きじゃなくて……普通に……たくさんおっぱい……可愛がって \nもらうんだからね……」", "NORMAL" ]},
