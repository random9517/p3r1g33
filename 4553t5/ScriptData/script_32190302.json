		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「うぅ……分かったよ。お仕置きを受ければいいんでしょ……で、どうする気 \nなの？　えっ……あっ、ちょ、ちょっと！」", "NORMAL" ]},
