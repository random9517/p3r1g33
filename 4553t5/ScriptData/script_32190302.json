		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「んふぁぁ……掛けてぇ……中だけじゃなくて……外からも……熱いの、ドロ \nドロで……", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0304402" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「あぁ……ねとねとになってる……全部……からだ……ザーメンまみれで…… \nむわっとしてる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0304403" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……あ……振動……止まった……んっ、はぁ……これで、お仕置 \nき……済んだってこと……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0304404" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「んん……はひ……ありがとうございました……はふぁ……どうしよ……ずっ \nと気持ちいいままだったぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0304405" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「ていうか、おっぱい……振動止まってるよね？　まだ、何だか……変な感じ \n……残ってる気がする……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0304406" ]},
		{"command":[ "SETIMAGE", "0", "still_00021903_02_16" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「これ……収まるのかな……服……着ててもまだ、感じたりしたら……どうな \nっちゃうんだろ……私……やらしすぎる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0304407" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「オマンコの方も……ムズムズして……あぁぅ……私ってば、つくづくキミに \n開発されちゃったんだなって実感するよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0304408" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「ちゃんと責任取る……？　また疼いたら良くしてくれるってこと……？　う \nぅん、まぁ、それは……」", "NORMAL" ]},
