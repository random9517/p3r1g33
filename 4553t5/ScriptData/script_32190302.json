		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「あふっ、んぁっ、あぁぁっ……ひゃひっ、見てますっ……チンポがっ、わら \nひのオマンコっ……突きまくってるとこぉっ……」", "NORMAL" ]},
