		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「割れ目がぐぽぐぽ言いながらっ、やらしいよだれ出してるとこもっ、あぁ… \n…全部見せちゃってまひゅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0304214" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「はぁぁ……はひっ、これからもっ、このやらしいオマンコでチンポのお世話 \nをしまひゅっ、からぁっ……あっ、んぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0304215" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「何回でもっ、イカせてっ……！　あぁっ、チンポもイッて下さいっ！　また \n、ズボズボってしてっ、熱いせーえきっ、どぷってぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0304216" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「あぁぁっ……もうすぐ、次のっ……出ちゃうっ？　はぁぅんっ、わ、わらひ \nもっ……またすぐっ、次のイクのっ、来てるからっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0304217" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「んふぅぅっ……！　いっぱいオマンコ締め付けてっ……悦んで出してもらえ \nるようにするからぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0304218" ]},
		{"command":[ "SETIMAGE", "0", "still_00021903_02_13" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「あひっ、あぁっ、おっぱいまた来るっ！　オマンコも来てるっ！　ひぃぁっ \n、またイクっ、オマンコ続けてイクからぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0304219" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「んぁぁぁっ、出してっ……！　キミのせーえきっ、またっ、びゅくびゅくっ \n……熱いのっ、全部っ……出してぇぇぇぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0304220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},
		
		{"command":[ "LABEL", "LABEL1" ]},	
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「くぅぅぅぅんっ……！　あぁぁぁ……出て、るぅぅぅっ！　新しい精液っ、 \n中出しっ……されてるぅぅぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0304301" ]},
