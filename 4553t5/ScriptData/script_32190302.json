		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「んっ、こ、これがお仕置き……んくぅっ、あっ、や、やだ……振動が……あ \nっ、ふっ、んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0304105" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「わ、分かってるくせに……おっぱい……特に、乳首……敏感なの知ってるん \nでしょ……は、んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0304106" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「くっ、んんぅっ！　あぁっ、こんなっ……あっ、プルプルって……はぁっ、 \nうんっ、あっ、ひぁっ、あぁんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0304107" ]},
		{"command":[ "SETIMAGE", "0", "still_00021903_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「やだ……もう、乳首っ、コチコチなのにっ……こんな責め続けられたらっ… \n…普通に服が着られなくなっちゃう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0304108" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「はぁんっ、やめっ、あぁっ、反省しましたからっ……あんっ、おっぱい、許 \nして……はっ、ひっ、あぁぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0304109" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「お、おねだり……？　任務失敗の謝罪と……チ、チンポおねだり……んんっ \n、うんっ、わ、分かったからっ……するっ、するからっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0304110" ]},
		{"command":[ "SETIMAGE", "0", "still_00021903_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「わ、私は……大事な任務に失敗して……皆様に迷惑を……あっ、お掛けして \nしまいました……は、んっ、あふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0304111" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「これから……わ、私のオマンコでお詫びを致しますから……どうか、おっぱ \nいの……ドームを外して、チンポを……中に、入れて、下さい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0304112" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「はぁぁぅんっ！　あっ、あぁぁぁんっ……チンポっ……ずぶって……一気に \nっ、来るぅぅぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0304113" ]},
		{"command":[ "SETIMAGE", "0", "still_00021903_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「はひぁっ、あぁっ、熱くて太いのっ……奥まで届いてるぅ……はっ、ひぁっ \n、あぁっ……すごっ、いっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0304114" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「んんっ！　う、動かすって……あっ、待って……先にっ、おっぱいっ、あっ \n、乳首っ……止めてっ、ひゃひっ、あっ、あひっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0304115" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「ま、まだっ……？　お仕置きっ、まだっ？　それっ、はっ、ひゃひいっ、あ \nっ、あぁっ、チ、チンポがっ、ずりゅってぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0304116" ]},
		{"command":[ "SETIMAGE", "0", "still_00021903_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「はぅっ、くぅんっ、や、やだっ、あぁっ、振動に……合わせてっ、チンポが \nっ……あっ、オマンコっ……グリグリっ、してくるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0304117" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「あっ、あひんっ、はっ、ひぃんっ！　やっ、足……そんな、開いちゃっ…… \nは、恥ずかしいっ……ああぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0304118" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「あっ、よく見ろなんて……ダメ……オマンコ……ぱっくり開いてる所……全 \n部……見えちゃってる……くぅっ、んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0304119" ]},
		{"command":[ "SETIMAGE", "0", "still_00021903_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「あふっ、あぉっ……やだっ、おっぱいが……またプルプルしてっ、そんなっ \n、同時になんてっ、はぁんっ、ダメっ……ダメェっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0304120" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「気持ちっ……んぅんっ、いいっ……違うのっ、あぁっ、気持ちよすぎてっ… \n…あっ、もっとされたらっ、変になっちゃうからぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0304121" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「も、もう少しゆっくりっ……あひんっ！　あぁっ、チンポっ……あぁっ、優 \nしくかき回してっ、はひっ、それっ、いいっ、いいんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0304122" ]},
		{"command":[ "SETIMAGE", "0", "still_00021903_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「はひっ、あぁっ、あぁんっ……くぅっ……なんで……こんなの……上手すぎ \nるしっ……あふっ、おっぱいっ……またプルプルしてるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0304123" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「あっ、あぁっ、なんでっ……また、あっ、乳首っ……止めてくれないのっ、 \nこんなのっ、あっ、強くてっ……ひっ、あぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0304124" ]},
		{"command":[ "SETIMAGE", "0", "still_00021903_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「ダメっ……あっ、そんな、されたらっ、すぐイクっ、イッちゃうからっ、あ \nひぁっ、あぁぁんっ、イ、イクぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0304125" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「ふひぁ……あぁ……イ、イッた……あふぅ……イキまひたっ……はぁぁ…… \nチンポ……激しすぎて……あっという間に……イカされましたぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0304126" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「あっ……んぅぅっ！？　ま、まだっ……続けてっ、あぁっ、オマンコっ…… \nそんなっ、はうっ、んくぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0304127" ]},
		{"command":[ "SETIMAGE", "0", "still_00021903_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、キミがイクまでっ……あっ、まだ……それはっ、あっ、あん \nっ、お仕置き……続くのっ、はっ、ひぃぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0304128" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「するっ……するからっ……！　あんっ、オマンコっ……キュンってしてっ、 \nキミのっ、太いチンポっ、締め付けるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0304129" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「はぁんっ、あぁっ、ダメっ……おっぱいもずっと気持ちいいっ！　もうっ、 \n私っ……いやらしすぎるっ、淫乱になっちゃったっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0304130" ]},
		{"command":[ "SETIMAGE", "0", "still_00021903_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「あぁっ、いいのっ……んっ、チンポいいっ！　あぁっ、もっと……んっ、チ \nンポもっとしてっ、オマンコしてぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0304131" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「あふっ、くぅぅんっ！　すごいっ、奥……コンコンされてっ、中……ぐちゅ \nぐちゅっ、されるのっ、たまんないっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0304132" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「はぁっ、あぁっ、もっと……ピストン速くなってくっ！　はっ、ふっ、今度 \nはっ……キミもっ、あっ、イクのっ……近いのっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0304133" ]},
		{"command":[ "SETIMAGE", "0", "still_00021903_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「うんっ、あぁっ、来てっ！　してっ、あぁっ、中出しでいいっ、ううんっ、 \n中出しがいいのっ、精液っ……オマンコに欲しいからぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0304134" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「出してっ……あぁっ、奥っ……深いとこにっ、キミの……濃いのっ、いっぱ \nいっ、出してぇぇぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0304135" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「んんんんんんんーーーっ！　またイっ……中っ……出されてるっ……はっ、 \nふっ、ひぃぃっ……イっ……くっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0304136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021903_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「はぁぁぁ……どぷって……あぁ……おっぱいも……キュンってされたままぁ \n……あぁ……続けてイクの……くふぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0304137" ]},
		{"command":[ "SETIMAGE", "0", "still_00021903_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「はっ、ふっ……あぁ……チンポ……止まった……？　あ……ふっ、射精…… \n落ち着いたの……？　今……ホント……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0304138" ]},
		{"command":[ "SETIMAGE", "0", "still_00021903_02_12" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「んんっ……はぁ、はぁ……はへぁ……あぁ……すご……すぎたぁ……硬いチ \nンポ……まだ中で……おっきいままぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0304139" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「お仕置き……んっ、ありがとう……ございましたぁ……ふぁぁ……あっ、ふ \nっ……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0304140" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「あ……ふっ……んんっ、どうしよ……すごく激しくされて、乱れたトコ…… \n見せちゃったのに、まだ……オマンコウズウズしてるの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0304201" ]},
		{"command":[ "SETIMAGE", "0", "still_00021903_02_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「こんな……淫乱女に……もっといっぱいお仕置きして……おっぱい振動させ \nたまま……もっとオマンコ……して下さいっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0304202" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「はぁっ、うんっ、あっ、あひぁっ！　それぇっ、あっ、また……グリグリっ \n……チンポっ、されてっ、るぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0304203" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「んぁぁっ、ズボズボって……あっ、ひぃっ、出した精液っ……かき回される \nっ……はぁっ、あぁあんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0304204" ]},
		{"command":[ "SETIMAGE", "0", "still_00021903_02_11" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「はふっ、すごい……あぁっ、ぞわぞわするっ……チンポが……奥にめり込む \n度に……からだっ、ビクってさせられてっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0304205" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「んんんっ……！　いいタイミングで……おっぱいにも振動が……来てっ…… \nくぅっ、はふっ、こんなのぉっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0304206" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「んぁぁ……蕩ける……オマンコ……トロトロに蕩けちゃうよぉ……あぁぁ… \n…チンポ止まらないっ、何度もっ、何度もぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0304207" ]},
		{"command":[ "SETIMAGE", "0", "still_00021903_02_13" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「はふぁっ、いいトコにしか……当たらないっ……！　はひっ、ダメっ、私… \n…またイクっ！　続けてイッちゃうぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0304208" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「んんんんんーっ……！　あぁぁ……やら……何回もイッてるのに……気持ち \nいいのっ、全然おさまんないっ……く、ひぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0304209" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「内側からっ、ズボズボされてっ……あくぅんっ、あぁっ、もっと……もっと \nお仕置きしてぇっ、オマンコずぶってぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0304210" ]},
		{"command":[ "SETIMAGE", "0", "still_00021903_02_12" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「はひぃんっ！　してますっ、任務っ……失敗してごめんなさいっ、オマンコ \n喜んじゃってごめんなさいっ、反省してますからぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0304211" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「あぁっ……乳首もっ、プルプルさせてぇっ……！　はひんっ、あぁっ、振動 \nが気持ちいいっ、はぁぁんっ、ビクビク……するぅっ！」", "NORMAL" ]},
