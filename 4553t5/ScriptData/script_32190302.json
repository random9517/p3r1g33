		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「ひゃあぁぅ……！　あぁっ、掛かってるっ……追加の精液っ……びゅくって \n……からだにぃっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0304401" ]},
