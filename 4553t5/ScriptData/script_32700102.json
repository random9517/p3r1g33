{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「あ……隊長さん、お時間を取っていただき、ありがとうございます。相談っ \nていうのはその……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0104101" ]},
		{"command":[ "SETCHARA", "0", "char_00027001_01", "2", "CENTER", "0" ]},
		{"command":[ "DISPCHARA","0", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「私、今まで男の人はほとんどパイズリだけでイかせてて……たまに二回目も \nできるって人がいても、すぐに終わっちゃってたんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「それでその……私、サキュバスなのに本番の経験が少なくて……気持ちよく \nなったこともなくて……でも隊長さんなら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0104103" ]},
		{"command":[ "SETCHARA", "0", "char_00027001_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「隊長さんのチンポなら、セックスで感じられそうなんです。隊長さん、私と \nエッチしてくれませんか……え、そんな即答で、ふふ、嬉しいです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0104104" ]},
		{"command":[ "SETCHARA", "0", "char_00027001_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「それじゃあ失礼して……私が上になりますね。あんっ、隊長さんのチンポ、 \nもう準備万端じゃないですか。期待してくれてたんですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0104105" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00027001_02_01" ]},
		{"command":[ "DISPCHARA","0", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「んっ……はっ、あっ、入ってきた、あんっ、うっ、やっぱり、いつもと違う \n……んんっ、あっ、あんっ、あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0104106" ]},
		{"command":[ "SETIMAGE", "0", "still_00027001_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「んふうっ、んっ、ああっ、んっ、あんっ、あっ、隊長さん、おっぱい吸っち \nゃだめ、あんっ、あっ、赤ちゃんみたい……んんっ、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0104107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「赤ちゃんはこんな風に腰を動かさないって……んっ、ふうっ、そう、そうで \nす、ね、あんっ！！　奥、奥にごつごつって、あっ、んっ、んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0104108" ]},
		{"command":[ "SETIMAGE", "0", "still_00027001_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「んうううっ、奥つつきながらおっぱい吸われたら、先端をくりくりって舐め \nられたら、あんっ、ふうっ、んんんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0104109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「あんっ、気持ちいいっ、んんっ、オマンコ気持ちいい、んっ、これが、本当 \nのセックス……あんっ、あっ、あくうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0104110" ]},
		{"command":[ "SETIMAGE", "0", "still_00027001_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「んんっ、私だってサキュバスだから、隊長さんを気持ちよく……ふうっ、あ \nっ、この動きはどうです、んっ、あっ、ひあっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0104111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「あんっ、あっ、そんな、合わせて下から動くなんて、ふああっ、あっ、おっ \nぱいも吸われたら、ひうううっ、私、私だけ気持ちよくなっちゃう、あんっ！ \n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0104112" ]},
		{"command":[ "SETIMAGE", "0", "still_00027001_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「えっ……隊長さんも気持ちいいって……私のオマンコで気持ちよくなってる \nって、んっ、ふうっ、なら、嬉しい、あんっ、あっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0104113" ]},
		{"command":[ "SETIMAGE", "0", "still_00027001_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「おっぱいも、おっぱいも気持ちいいって、あんっ、そんな吸われたら、私も \n気持ちよくなっちゃう、んっ、ああっ、ああああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0104114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「ね、ね、隊長さん、もっと、もっと言って。気持ちいいって、もっと言って \nください！！　あっ、ふっ、んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0104115" ]},
		{"command":[ "SETIMAGE", "0", "still_00027001_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「私のオマンコ、気持ちいいって、んんっ、あっ、おっぱい吸いながら言った \nらだめっ、吐息と歯が当たって、あんっ、あっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0104116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「あっ、あっあっ、でも、嬉しいっ！！　こんな風に、お互い気持ちいいって \n思うセックスがあるなんて、あんっ、ああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0104117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「隊長さんのチンポのおかげ……オマンコの中でも分かる、カリ首の高さと、 \n大きさと、太さと……立派なチンポ、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0104118" ]},
		{"command":[ "SETIMAGE", "0", "still_00027001_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「んんっ、私のオマンコも気持ちいいって、そんなこと、そんなこと言われた \nら……あんっ、んっ、んんっ、んふうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「好きに、好きになっちゃう！！　隊長さんのこと、好きになっちゃう……好 \nき、好きぃっ！！　隊長さん、好きぃっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0104120" ]},
		{"command":[ "SETIMAGE", "0", "still_00027001_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「隊長さんのチンポも、動きも、隊長さん自身も……全部、全部好きっ！！　 \nおっぱいを吸う口も……んんっ、好きっ、好きっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0104121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「大好きっ！！　隊長さん、あんっ、ああっ、あくうっ！！　好きって言った \nら、チンポがまた……んっ、私のオマンコも締めつけてる……？　だったら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「好き、好きです、隊長さんのこと、好き……んっ、そんな、おっぱい吸って \n応えないで、んんっ、でも、そんなところも好き、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0104123" ]},
		{"command":[ "SETIMAGE", "0", "still_00027001_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「ふううっ、こんな、気持ちだけでこんなに変わるなんて、あんっ、あっ、そ \nうやって、子供みたいにおっぱい吸ってくるのも愛おしい……んっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0104124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「んっんっんっ、好きって思うだけで、隊長さんのチンポ、オマンコできゅっ \nて締めつけたくなる……んっ、ふっ、ふうっ、はあっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「私の中のチンポ、形も、太さも分かって……んんっ、これが今私の中に入っ \nてるって思うと……それも好きっ、んっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「あんっ、あっ、くうっ！！　こんなに、腰を動かすだけで気持ちいいセック \nスなんて初めて、んっ、ああああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0104127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「ほら、私の中がぐじゅぐじゅに蕩けて、チンポに絡みついてるの、分かりま \nす？　こんなのも初めてで……んんっ、でも、好き、あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0104128" ]},
		{"command":[ "SETIMAGE", "0", "still_00027001_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「隊長さんと繋がってると、頭の中が好きだけになっちゃう……んっ、ふうっ \n、気持ちいいだけじゃなくて、幸せも……んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「好きな人とのセックスって、こんなに素敵なんですね……んんっ、あっ、お \nっぱい甘噛みしちゃだめ……あんっ、ふっ、ああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0104130" ]},
		{"command":[ "SETIMAGE", "0", "still_00027001_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「噛みながら動かれたら、あんっ、ふうっ、イっちゃう、イっちゃうからあっ \n、あんっ、ふううっ、だめですったら、隊長さん、んっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0104131" ]},
		{"command":[ "SETIMAGE", "0", "still_00027001_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「イくのは、イくときは一緒に、ね？　二人のセックスで、二人一緒に……ん \nんっ、本当にイくのって、そういうことでしょう？　あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「んんっ、んっ、中、中でチンポが膨らんで、今の言葉でそんなに興奮してく \nれたのね……ふふっ、嬉しい、そういう所も好きっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「好きっ！！　隊長さん、今だけでいいから、私と恋人になって、んんっ、恋 \n人セックスしてっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0104134" ]},
		{"command":[ "SETIMAGE", "0", "still_00027001_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「もうすでにそのつもりだって……んっ、嬉しいっ、ふうっ、ああっ、あっ、 \nじゃあ、一緒にイって、チンポからザーメンいっぱい出して……んっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0104135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「隊長さんのことを好き好き大好きなオマンコに、チンポからザーメンいっぱ \nい出して、んんっ、そこ、奥ぐりぐりってされたら、イっく、んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0104136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「イく、イく、イっくううううううううう！！　ああああんっ！！　ザーメン \nもきたああああっ、ふああああああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0104137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00027001_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「出てる、いっぱい出てる！！　お腹の中、たっぷたぷにされてる、濃厚ザー \nメンで満たされてるうっ、ああああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「お腹の中、きゅんきゅんしてる！！　ザーメンも好きって子宮が言ってるう \nううっ！！　ふあああああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0104139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「ああっ、幸せ……好きな人と繋がって、ザーメン注がれて、それがこんなに \n幸せなんて……素敵……隊長さん……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「ふふ、まだ硬いままですね。ね、もう一回しましょう？　ラブラブセックス \n、一回だけじゃ物足りないです……ダメ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0104201" ]},
		{"command":[ "SETIMAGE", "0", "still_00027001_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「あんっ！！　オマンコとおっぱい、また……んんっ、ふうっ、あっ、もう、 \n身体が隊長さん専用に変わっちゃいそう……あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0104202" ]},
		{"command":[ "SETIMAGE", "0", "still_00027001_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「サキュバスにそう思わせるなんて、んっ、あなたがそこまで魅力的な人って \nことですよ、隊長さん。ですから、んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0104203" ]},
		{"command":[ "SETIMAGE", "0", "still_00027001_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「おっぱいもオマンコも、どっちももう好き放題してくれていいんですよ？　 \n私の身体、全部好きにしちゃってください。私も、ふっ、うっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0104204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「私も隊長さんの身体、チンポ、全部好きにしますからあっ！！　あんっ、あ \nあっ、聞こえますか、オマンコからぐじゅぐじゅって音がしてるのっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0104205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「私のオマンコも、隊長さんに好き好きって言ってるんです、ザーメン注がれ \nて大好きって、あんっ、ああっ、チンポがまたっ、奥にっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0104206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「ふあああ、濃厚ザーメン、オマンコの中でかき混ぜられて、んんっ、ヌルヌ \nルチンポが中をこすって、ふあああああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0104207" ]},
		{"command":[ "SETIMAGE", "0", "still_00027001_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「お腹の奥、じんじん痺れて、ふああっ、おっぱい、おっぱいもそんなに吸わ \nれたら溶けちゃう！！　隊長さんの口の中で溶けちゃう！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「んんんっ、私だって、オマンコの中でチンポ溶かしてあげる……んうっ、あ \nっ、あふうっ、あっあっあっ！！　ふあああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0104209" ]},
		{"command":[ "SETIMAGE", "0", "still_00027001_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「あうっ、あっ、んんっ！！　凄い、繋がってるところからっ、んんっ、お互 \nい溶けあって……私の中でひとつになってるみたい……あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0104210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「んんんっ、締めつけながら動いたら……んっ、ふっ、ああっ、また違う感触 \nが……ふっ、うっ、チンポの形が……あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0104211" ]},
		{"command":[ "SETIMAGE", "0", "still_00027001_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「どろどろオマンコでもチンポの形が分かって、んんっ、これ、この動きも好 \nきっ！！　んっ、隊長さんも私のおっぱいが好き……あふうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0104212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「もう、私のおっぱいはまだミルク出ませんよ、んんっ、でも、隊長さんさえ \nその気なら、そのうち……ね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0104213" ]},
		{"command":[ "SETIMAGE", "0", "still_00027001_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「だからもう一回、いっぱい私の中に出して、おっぱいミルクのために、ザー \nメンミルクいっぱい出してっ！！　あうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0104214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「ああんっ、腰を動かしながらおっぱい噛まれたら、また、またイっちゃう、 \nんんんっ、隊長さんにイかされちゃうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0104215" ]},
		{"command":[ "SETIMAGE", "0", "still_00027001_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「隊長さんも、隊長さんもイってえ！！　ラブラブ大好きセックスで、一緒に \nイって！！　私のオマンコに、濃厚ザーメンまた出してっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0104216" ]},
		{"command":[ "SETIMAGE", "0", "still_00027001_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「ああっ、んっ、チンポが膨らんでる、オマンコの中で膨らんで跳ねてるっ！ \n！　またザーメン出したがってる、ふあああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0104217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「いいですよ、隊長さん、イって、また私のお腹にザーメンごくごく飲ませて \nっ！！　私の中を隊長さんの好きで満たしてっ！！　あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0104218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「あっあっあっ、私も、私もイっちゃう、隊長さんにおっぱい噛まれて、チン \nポでかき回されて、イく、イっく、イくうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0104219" ]},
		{"command":[ "SETIMAGE", "0", "still_00027001_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「ふあああああっ！！　隊長さん、好きっ、イくっ、好きっ、イくっ、好きイ \nくううううううううううううううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0104220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「あくうううっ！！　きた、ザーメンのおかわりきたあっ！！　私のオマンコ \nに濃厚こってりザーメンのおかわりきたああああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0104301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00027001_02_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「ふうっ、ふっ、あっ、もう、入り口から一番奥まで、ザーメンでいっぱいに \nなって、満たされてる……んんっ、んっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「まだ、まだ出てる……熱い……こんなの、こんなの注がれたら、もう隊長さ \nんの子供できちゃう……あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0104303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「ふふ、そうしたらおっぱいミルク出るようになりますね……赤ちゃんの前に \n、隊長さんにミルクいっぱい飲ませてあげますから……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0104304" ]},
		{"command":[ "SETIMAGE", "0", "still_00027001_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「そのためにきゅっきゅって、チンポ締めつけて、最後の一滴まで搾り取って \n……んんっ、ふっ、オマンコどろどろに染め上げて……んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0104305" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「ふうっ、うっ、ああ……腰が溶けちゃいそう……私、今、凄く満たされてま \nす……お腹の中だけじゃなくて、心も……あふうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0104306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「隊長さんに、身も心も全部満たしてもらいました……好きな人とのセックス \n、教えてもらって……んっ、好き、本当に好きっ……あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0104307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「だから……また、抱いてくれますか？　サキュバスと男じゃなくて、好きな \n人同士のセックス、してくれますか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0104308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「ふふ、喜んで、なんて。ありがとうございます。隊長さん、優しいんですね \n。だからこそ、好きって思えるようになったのかも」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「セックスだけじゃなく、隊長さんの全部、本当に好きですよ。だからまた、 \nいっぱいいっぱい気持ちよくなりましょうね、あなた」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「ああんっ、あっ、チンポ、抜けちゃう、ああっ、それ、私の身体にぶっかけ \n、ひああああああああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0104401" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「こってりザーメンが身体に……んっ、んんっ、中じゃないけど、これはこれ \nで、ふあああっ、凄く、気持ちいい、あんっ、ああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0104402" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00027001_02_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「私、隊長さんにマーキングされてるっ！！　自分のものだって、ザーメンで \nマーキングされてるっ！！　あふうっ、あっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0104403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「こんなにべっとりつけられたら、歩いてるだけで隊長さんのものだって分か \nっちゃう……んんっ、んっ、素敵……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0104404" ]},
		{"command":[ "SETIMAGE", "0", "still_00027001_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「量も、濃さも、匂いも、どれも最高で……サキュバスじゃなくても、こんな \nのをかけられたら……もう……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0104405" ]},
		{"command":[ "SETIMAGE", "0", "still_00027001_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「隊長さんのザーメンを覚えたら、もう他の男の精気なんていらなくなっちゃ \nう……んんっ、罪な男の人……ふうっ、うっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0104406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「んっ、中も外も、隊長さんのザーメンで塗り上げられちゃった……ふふ、で \nも、それも好きだからこそしてくれるんですよね……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0104407" ]},
		{"command":[ "SETIMAGE", "0", "still_00027001_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「濃厚ザーメンシャワー、素敵でした……もう、私の全部が隊長さんで満たさ \nれてます……幸せ……好き……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0104408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「セックスして、こんなに幸せになったのははじめて……隊長さんが初めてで \n、隊長さんだけだわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0104409" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「だから……また抱いてください。中でも外でも、好きな所に出していいです \nから。隊長さんの好きに……それが私の好きになるから、ね？」", "NORMAL" ]},
