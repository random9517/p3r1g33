{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0045" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_023" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ヤムがどこにもいない……。どうやって探せばいいんだ」", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "一通り、今まで来た道を探してみたもののヤムの姿はどこにもない。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「早く探してやらなくては……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023660001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "焦る姫様と俺、そしてイルル、ジュンジローの元に迷子アナウンスが聞こえて\nきた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アナウンス" ]},
		{"command":[ "SETTEXT", "「神社へお越しのカツマ様、ルナテミス様、イルル様。ヤム様がお探しです。\n至急、本堂隣、社務所までお越しください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_010023660001" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「おとーさん、しゃむしょ、ってなあに？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010023660001" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いわゆる事務所みたいなとこだな。そこでヤムを預かってくれているらしい\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「そうなの……！？　じゃあ、早くいこっ。きっと寂しい想いをしてるから…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010023660002" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ああ、そうしよう。社務所の場所はわかっている。行くぞ、私についてこい\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023660002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_013" ]},
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「……ということで、迷子アナウンスを流してもらいましたから、もうすぐパ\nパさんがここに来てくれますからね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_010023660001" ]},
		{"command":[ "SETCHARA", "0", "char_00022003_01", "8", "CENTER", "0" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「だから、泣かないで。怖いことなんて、な～んにもありませんよ～。よしよ\nしよし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_010023660002" ]},
		{"command":[ "SETCHARA", "0", "char_00022003_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「うん……、うん、わ、わかってる……。わかってるけど……ぐすっ、ぐすん\nっ、ひっく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010023660001" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「あらららら、もっと泣いちゃいましたね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_010023660003" ]},
		{"command":[ "SETCHARA", "0", "char_00022003_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "？？？？" ]},
		{"command":[ "SETTEXT", "「頭で理解していても、心が寂しくて泣いておるのよな。可哀想にのぉ。よし\nよしよし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_010023660001" ]},
		{"command":[ "SETCHARA", "0", "char_00027601_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "？？？？" ]},
		{"command":[ "SETTEXT", "「婆で代わりになれるかはわからぬが……共におるから、少しは気持ちを楽に\nしておくれ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_010023660002" ]},
		{"command":[ "SETCHARA", "0", "char_00027601_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「うん……。ありがとぉ……。ぐすっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010023660002" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……いたぞ！　ヤム！　ここにいたんだな！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「パパぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010023660003" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「あっ！　ヤムちゃんのお父さんですね！　娘さんはここです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_010023660004" ]},
		{"command":[ "SETCHARA", "0", "char_00022003_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あ、あぁ、えっと。俺は別に実の父親ってわけじゃ……あはは」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「って……！　いつぞや助けて頂いたバニーママ！？　これも怪人派遣なのか\n？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「はい。ヤムちゃんから名前を聞いて、おそらく……とは思っていましたが、\nお久しぶりです～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_010023660005" ]},
		{"command":[ "SETCHARA", "0", "char_00022003_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「その節はお世話になりました。今回は神社でアルバイトを……という話は置\nいておいて、まずはヤムちゃんを」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_010023660006" ]},
		{"command":[ "SETCHARA", "0", "char_00022003_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああ、そうだったそうだった。ヤム、迎えにきたぞ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「パパぁ、パパぁ！　会いたかった！　さみしかったよぉおおおお！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010023660004" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "？？？？" ]},
		{"command":[ "SETTEXT", "「もうはぐれてはいけないよ。大事な縁はぎゅっと掴んでおくものだからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_010023660003" ]},
		{"command":[ "SETCHARA", "0", "char_00027601_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「うん！　ありがとう、バニーママさん！　クラミツハさん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010023660005" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「いえいえ。いつでも頼ってくださいね。ふふふっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_010023660007" ]},
		{"command":[ "SETCHARA", "0", "char_00022003_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「良かったな、すぐに合流できて……って、ん？　……んんっ？　ど、どなた\nだ？　その……隣にいるのは」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023660003" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「隣？　隣ってヤムの隣か？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「え？　この人……？　知らない人だよ。でもヤムが泣いてたら、頭を撫でて\n慰めてくれたの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010023660006" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「へえ……。いい人なんだな。あの、ありがとうございました」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「ほっほっほっ。礼を言われるほどのことは何もしておらんよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_010023660004" ]},
		{"command":[ "SETCHARA", "0", "char_00027601_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「…………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023660004" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「姫様、どうしてそんなに汗をかいているんですか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そ、そ、そ、その御方は、その御方は……ガクガクガクガク」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023660005" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「どこにでもいる、面倒見のいいお子様じゃないですか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「お子様だなんてそんな！　あわわわわわ、ハワワワワ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023660006" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「……おねーさん、一体どうしちゃったわけ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010023660007" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「ものすごく青ざめてる……。怖いものとか、見ちゃったのかな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010023660003" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あ、あの！　こ、このたびは大変お世話になりました！　そ、その、私たち\nのような若輩者が多大なご迷惑をおかけいたしまして……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023660007" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「これこれ。婆はそんなに大層なものではないからの、そのように頭を下げた\nりして……あまり困らせんでおくれ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_010023660005" ]},
		{"command":[ "SETCHARA", "0", "char_00027601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「は、はいぃいいっ！　かしこまりました！　あ、あぁあ……それでも、お手\nをわずらわせてしまって……申し訳ありません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023660008" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「なあに、気にするでない。いつでも婆に頼っておくれ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_010023660006" ]},
		{"command":[ "SETCHARA", "0", "char_00027601_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「め、めめ、滅相もございません！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023660009" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……恐縮しまくってるな。あんな姿、ルナルバース様の前でしか見たことな\nいぞ……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「この子って何者なんだろう？　稲穂姫辺りに聞けば分かるかな……？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00027601_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "そこまで考えて、俺はハッ！　と気が付いた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「というかそもそも、アナザー・稲穂姫が大暴れしてるってのにオリジナルの\n稲穂姫はどこに行ったんだよ！？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}