		{"command":[ "PLAYVOICE", "001_0104310" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「つ、次もまあ……何かあったら、お仕置きをしてくれ……。頼んだぞ！　隊 \n長の任務を果たせ！　いいな！」", "NORMAL" ]},
