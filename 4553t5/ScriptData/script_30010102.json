		{"command":[ "PLAYVOICE", "001_0104303" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あ、あ、奥の方にも……いっぱい……っ！　あ、あ、ああああ……あっ…… \n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0104304" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……はぁああ……だ、出されて……しまった……。また、こん \nなにたくさん……私の中に……ふあぁああ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000101_02_22" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0104305" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そ、それにしても……さっき出したばかりなのに、どうしてまだこんなに出 \nるのだ……。一回目より多いのではないか……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0104306" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「え……？　わ、私の中が、そんなに気持ちよかったのか？　そうか！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0104307" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「な、何をいう！　喜んでなどいないぞ！　別に、そんな風に言われても…… \nほめられたとは受け取れん！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000101_02_23" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0104308" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「だ、だが……そんなに気持ちよかったのか？　そうか……私もまあ……その \n……気持ちよ――」", "NORMAL" ]},
