		{"command":[ "SETTEXT", "「ああああああ……っ！　この、キツい臭い……！　いつもの、下僕の臭いだ \n……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0104404" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ふぁああああ……どろどろした下僕の分身が……下僕の臭いが……私の身体 \nに……はぁああ……ああ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0104405" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「って！　どうしてくれるのだ！　全身、お前の臭いものでドロドロになって \nしまったではないか……。これでは、これでは……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000101_02_11" ]},
