		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あ、んあっ！　はああああああっ！　あああああーっ！　下僕っ！　下僕ぅ \nっ！　ふぁあああああーっ！」", "NORMAL" ]},
