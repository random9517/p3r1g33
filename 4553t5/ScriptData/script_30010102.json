		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あ。あ、あああああああああーっ！　中に……中にっ！　あああ……熱い… \n…っ！　んんんっ！　はぁあああ……っ！」", "NORMAL" ]},
