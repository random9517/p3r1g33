		{"command":[ "PLAYVOICE", "001_0104309" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「き、気持ちよく反省ができたぞ！　う、うん！　次回につながる、いいお仕 \n置きだった！　お前もどうやら、隊長としての自覚が出てきたようだな！」", "NORMAL" ]},
