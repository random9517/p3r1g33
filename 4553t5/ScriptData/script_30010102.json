{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000101_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "PLAYVOICE", "001_0104101" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「くううっ……うっ……いいかげんに……しろっ。いつまで私をこんな風に… \n…くうっ……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0104102" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「おい、下僕！　聞こえているんだろう！？　どこかで私を見ているはずだぞ \n！　早くここから解放し――」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0104103" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んあああっ！　あ、あ、ああああああっ！　ひぃいっ！　や、やめろぉ！　 \nスイッチを入れるな――はぁああああんっ！　あ、あああっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000101_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0104104" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁあああああんっ！　ああああっ！　くうぅううっ……体の……体の芯が \nビリビリ震えて――はぁあああん！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0104105" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ああああっ！　はぁあああああ……ああん！　あっ！　ああああ……はぁあ \nああん！　あああっ！　あっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0104106" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁあああ……あっ！　あああん！　あんっ！　んんんんん……やめろぉ！ \n　ビリビリしすぎて、感覚がおかしくなるぅ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0104107" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あ、あ、あああああっ！　くうぅうううっ！　んんあああああああ――あっ \n！　あ……あぁ……あ……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0104108" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……もう、終わりか……なんだ。お仕置きとやらも、たいした \nことは――」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000101_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0104109" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「うぁあああああっ！？　またぁっ！　んんんんっ！　くはぁっ！　さ、さっ \nきより……強いぃいいっ！？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000101_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0104110" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あ、あ、あ、ああああああっ！　はぁああああん！　くうううっ……ひぃい \nいいいっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0104111" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「や、やめ……やめろぉおおぉ！　あああああん！　あぅうううううっ！　キ \n、キツいっ……！　振動が……頭のてっぺんまで……はぁあああん！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0104112" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んあああっ！　あっ！　あっ！　あっ！　ひゃうううううんっ！　あ、あ、 \nあああああん！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0104113" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ふぁああああ……げ、下僕！　下僕ぅっ！　聞いてるなら返事――ひゃぁあ \nああん！　やめろぉ！　振動を強くするな……あああああああん！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000101_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0104114" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「や、やめろ……この振動を止め――あああああん！　あっ！　あああああん \n！　はぁっ！　ああああん！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0104115" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「や、やめろ……スイッチを切れ――あああああん！　あっ！　あああああん \n！　はぁっ！　ああああん！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0104116" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んんんんっ！　あっ！　ああっ！　はぁあああ！　あ、あ、ああ……も、も \nう、やめ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0104117" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「下僕っ！　おいっ！　下僕ぅ！　んんんんっ！　どこに……んぁっ！　どこ \nにいる……はぁああん！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000101_02_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0104118" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「おい、下僕ぅ！　聞いているんだろ！　ここに……あああああっ！　ここに \n来いっ！　来てくれ……っ！　下僕！　下僕ぅ！　あああん！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0104119" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「なぜだ……！　なぜ来ない……どうして私を……んんんっ！　一人にするん \nだ……！　早く来い……来てくれ、下僕ぅ！　んんああああっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0104120" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んああっ！　あっ……ああああっ！　ああっ！　下僕っ！　やっと来たのか \n、下僕っ！　今までどこに――」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0104121" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ち、違うっ！　別に、お前に会いたかったなどと、そんなことは全くないぞ \nっ！　私はただ、早くこのお仕置きを終わらせろと――」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000101_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0104122" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んあぁああああっ！　だからぁ！　ブルブルさせるのはもうやめろぉ！　こ \n、このような屈辱、いつまでも……ひゃぁああん！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000101_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0104123" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「違うぅ！　感じてなどいない！　濡れてない！　屈辱のあまり、下半身が泣 \nいているだけだぁ！　ひゃぁああんっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0104124" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「だから！　違うと言っているだろう！　パーフェクト・メイデンたる私がそ \nんな、だらしなく股間を濡らすなど――あ、あ！　ああああん！　あ――」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0104125" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「――んんっ！？　ど、どうしてバイブを外す！？　お仕置きはもう――んあ \nああああっ！？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000101_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0104126" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んんんっ……！　ど、どうして……？　どうしていきなりお前のチンポが入 \nってくるのだ……！？　ふああああ……！　太い……っ！」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000101_02_13" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0104127" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ、あっ、あああっ……！　はっ！　げ、下僕ぅ……っ！　こ、これは、 \nどういう……んっ、んんっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0104128" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あっ、はっ、はぁああ……っ！　固いのが……中でこすれ――んんんっ！　 \nああん！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000101_02_15" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0104129" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「感じていない！　感じてなど……ああああん！　どうして私が、お前の汚い \nモノなどで……んんんんっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0104130" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「お、おいっ！　下僕っ！　これは……これはお仕置きなのか！？　お仕置き \nなんだなっ！？　そうなんだなっ！？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000101_02_14" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0104131" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そ、そうか……！　お仕置きか……！　ならば仕方ないな……！　もっと… \n…もっと突いてくるがいいっ！　んああああっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000101_02_13" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0104132" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「違うっ！　違うぞっ！　お前のが、気持ちいいからじゃないっ！　感じてな \nどいない！　これは……お仕置きだからなっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0104133" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「こ、この屈辱を次回の糧として、次こそは勝利をつかむためだっ！　そのた \nめなんだからなっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0104134" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「決して、お前に抱かれて嬉しいだなんて、そんなこと、あるはずが……ふぁ \nああん！　あんっ！　ふあああん！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0104135" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あ、あああああっ！　もっとだ！　もっとぉ！　もっと教訓を与えてくれ… \n…んんんっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000101_02_15" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0104136" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あ、ああ、あああああっ！　だ、ダメだ……！　教訓が身に沁みすぎて…… \nはぁあああっ！　あんっ！　あっ！　あああああん！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0104137" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「イ、イクのか！？　お前もか！？　い、いいだろう！　中に好きなだけ出す \nがいいっ！　たとえ孕まされても、それもまた教訓――」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000101_02_14" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0104138" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ふあ、あ、あああああああああ～っ！　んんあああっ！　で、出てる……っ \n！　私の中に……あああああああ～っ！」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000101_02_21" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0104139" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ああああっ……あっ……あっ……はぁああ……。こ、これでいい……これを \n次回の糧とする……。ああ……私の腹の中が、次回の糧でいっぱいだ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0104140" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「こら……どこへ行く。もう少し私といろ。私が、きちんと反省したとわかる \nまで……私をしっかりと捕まえておけ。……隊長の義務だぞ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000101_02_20" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0104201" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「……おい、下僕。これはどういうことだ？　今イッたばかりなのに、どうし \nてまた私の中でチンポを大きくしている？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000101_02_19" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0104202" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「なに？　私のこの格好が……妙にいやらしくて興奮しただと！？　な、何を \n言い出すのだ、この変態！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0104203" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「何ぃ！？　そんな口答えをするとは、お仕置きが足りない、だと！？　勝手 \nなことを言いだすんじゃ――ふあぁああん！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0104204" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ん、んんっ！　あっ！　あああっ！　つ、つまり、これもお仕置きなのか… \n…！？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000101_02_20" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0104205" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「くぅうつ……お仕置きか……っ！　ずいぶん、キツいお仕置きだ……っ！　 \n二回目なのに、さっきより硬くて……んんんっ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0104206" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「なに？　キツいのは私のせいだというのか！？　それは……くっ……！　な \nぜ……っ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000101_02_19" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0104207" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「わ、私のが、キツくお前のを締め上げているだと……！？　バ、バカなっ！ \n　そんなこと……んんんんっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0104208" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「だから！　お前にこんな風に犯してほしいなどとは思っていな――んぁああ \nっ！　ないいぃっ！　ふあああん！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0104209" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あ、あ、ああああっ！　だから。お仕置きだろっ！？　お仕置きなんだな！ \n？　だったら……あ、あ、ああああん！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000101_02_20" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0104210" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「バ、バカモノぉ！　わ、私をかわいいなどと……んぁあ！　キ、キスなんか \nするなぁ！　そんなこと……ふぁああああああ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0104211" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「お仕置きだ、お仕置きだ！　これはお仕置きだろ！　だから……精一杯お前 \nのものを感じて……反省……んぁああん！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0104212" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「明日のために！　明日のために！　明日のためにこうして――ふぁああん！ \n　気持ちよく……んんんんっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0104213" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あ、あ。あ、ああああっ！　もっと……もっと奥までお仕置きしろっ！　私 \nを……もっと、もっと反省させろっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000101_02_21" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0104214" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ああああああ……！　下僕なんかにこんな風に、気持ちよくさせられるとは \n……！　これは厳しい……！　厳しいお仕置き――あああん！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0104215" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あ、あ、厳しい！　厳しいぞ下僕っ！　もっとビシビシと突き上げてくれっ \n！　んんんんっ！　そうだ！　もっと、もっと！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0104216" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んあああああっ！　いい、いい感じだ！　ふぁあん！　身動きの取れないも \nどかしさが、反省を掻き立てて……わ、私は……もう、もうっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0104217" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あ、あ、ああああん！　も、もうダメだっ……！　もう、頭の芯がぼぉっと \nして……どこかへ……飛んで行ってしまいそうだっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000101_02_19" ]},
		{"command":[ "WAITINPUT" ]},
