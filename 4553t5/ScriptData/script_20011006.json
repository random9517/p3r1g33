		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021310001" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「うわわっと！　何なの、もー、けっこーめんどくさいことしてくれるじゃん\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_010021310002" ]},
		{"command":[ "SETCHARA", "0", "char_00016601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「ここまでだアルマ。無駄な抵抗はやめて、大人しく観念しろ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021310002" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「調子に乗んないでよね……私だってもう力は手に入れたんだから。それなら\n、ちょーっと本気……見せちゃおうかなー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_010021310003" ]},
		{"command":[ "SETCHARA", "0", "char_00016601_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「はぁぁぁぁぁぁぁぁぁーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_010021310004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「何だ……？　身体が光って来て……！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「ふぅー」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "true" ]},
		{"command":[ "PLAYVOICE", "v2_166_010021310005" ]},
		{"command":[ "SETCHARA", "0", "char_00016602_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「せ、成長した！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「魔法少女が育つのはマニア向けで、賛否両論ですぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021310001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お前、何言ってんの？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「原理主義者の方には寛大になって欲しいという心の叫びですぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021310002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「だからお前、何言ってんの？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「んーっ、この姿に戻るのも久しぶり。わぉ……やっぱり、力がビンビンにな\nってるねぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_010021310006" ]},
		{"command":[ "SETCHARA", "0", "char_00016602_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「く……アルマ、貴様……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021310003" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「イグニスは知ってるよねー、私の今の状態。それでも、まだやり合おうとか\n思っちゃう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_010021310007" ]},
		{"command":[ "SETCHARA", "0", "char_00016602_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「…………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021310004" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「なーに、さっきの姿よりは、よっぽど遠慮なく殴れるようになったってもん\nだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020021310002" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「ほむら殿っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021310005" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「へぇ……私の力を感じても、まだそんな強がりを言っちゃうなんて……よっ\nぽど怖いもの知らずのおバカちゃんなのかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_010021310008" ]},
		{"command":[ "SETCHARA", "0", "char_00016602_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「はん、これから戦おうかって相手に、最初から気合い負けしてる奴が勝てる\nかってんだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020021310003" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「確かに……そうだ。私とて、条件は同じ……簡単に屈するつもりなどない！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021310006" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「おう、そういうことだ。とびっきりの根性見せてやっから、テメーこそビビ\nってんじゃねーぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020021310004" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「いいね、いいね、その強がり♪　どこまで続くか見せてもらおっかなー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_010021310009" ]},
		{"command":[ "SETCHARA", "0", "char_00016602_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うぉっ……！　さ、さっきより力が……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「上等だオラァ！　行くぞぉぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020021310005" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
