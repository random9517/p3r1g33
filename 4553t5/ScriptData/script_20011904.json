{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0027" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「なるほど、ではフランカとデビルトンファーは、この男を断罪するために動\nいていたと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021590001" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「そういうことだ。理解して貰えて助かる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_010021590001" ]},
		{"command":[ "SETCHARA", "0", "char_00016001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「ライオットの邪魔さえなけりゃ、こんなことにはならなかったんだよなー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_010021590001" ]},
		{"command":[ "SETCHARA", "0", "char_00020601_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「はぁ？　敵に掴まって、フランカに撃たれそうになってたヤツがよく言うぜ\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_010021590001" ]},
		{"command":[ "SETCHARA", "0", "char_00016101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「あ、アレはちょっと油断してただけだ！　それにアンタの助けがなくても、\nあんなヤツすぐにボコボコにしてやったさ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_010021590002" ]},
		{"command":[ "SETCHARA", "0", "char_00020601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「負け惜しみか？　やっぱテメェは口だけの三下だな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_010021590002" ]},
		{"command":[ "SETCHARA", "0", "char_00016101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「なんだとぉ！？　やるかぁ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_010021590003" ]},
		{"command":[ "SETCHARA", "0", "char_00020601_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「いいぜ！　かかって来いよっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_010021590003" ]},
		{"command":[ "SETCHARA", "0", "char_00016101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「いい加減にしろ、二人とも」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_010021590002" ]},
		{"command":[ "SETCHARA", "0", "char_00016001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「ふふっ。お前たちは仲がいいんだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021590002" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「ところでフランカ。色々と思うところはあるとは思うが、この男の処分は、\n大いなる秘法（アルス・マグナ）に任せて貰えないだろうか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021590003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「はぁ！？　せっかくアタシと姉御が悪事を突き止めて成敗したのに、手柄だ\nけ持ってくのかよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_010021590004" ]},
		{"command":[ "SETCHARA", "0", "char_00020601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「そういうワケではない。ただ、この男を調べることで、もっと多くの組織を\n壊滅させることができるからだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021590004" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「正義を執行したいという気持ちも理解できる。だが私たちには、この街を守\nる使命があるからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021590005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「あんなこと言ってるけど……どうする、姉御？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_010021590005" ]},
		{"command":[ "SETCHARA", "0", "char_00020601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「それがさらなる悪を裁くことになるなら、別にいいさ。私たちは、また違う\n悪を裁きに行けばいい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_010021590003" ]},
		{"command":[ "SETCHARA", "0", "char_00016001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「姉御がそういうなら、アタシもいいけどさ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_010021590006" ]},
		{"command":[ "SETCHARA", "0", "char_00020601_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「すまない。では、この男はこちらで処理させてもらうとしよう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021590006" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「ああ、それと……礼を言うのが遅くなってしまったな。先ほどは助かった。\nありがとう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021590007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「別に感謝されるようなことじゃねぇよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_010021590004" ]},
		{"command":[ "SETCHARA", "0", "char_00016101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「そうそう。悪を倒すのは、アタシたちヒーローの役目だし！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_010021590007" ]},
		{"command":[ "SETCHARA", "0", "char_00020601_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「あのまま爆弾が爆発していたら、市街地にも大きな被害が出ていただろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_010021590004" ]},
		{"command":[ "SETCHARA", "0", "char_00016001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「市民に被害を出してしまうようでは、正義を語る資格などないからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_010021590005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「ふふっ。そうだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021590008" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「あー、それにしても、暴れたら腹減ってきたな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_010021590005" ]},
		{"command":[ "SETCHARA", "0", "char_00016101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「ライオットに同意するのは尺だけど、アタシもお腹が減ってきたかなー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_010021590008" ]},
		{"command":[ "SETCHARA", "0", "char_00020601_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「それなら、ここから少し歩いたところに、正義（まさよし）という居酒屋が\nある」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021590009" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「この男を本部に引き渡したら、みんなで食事をしたいのだが……どうだろう\nか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021590010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「勿論、助けてもらったことと、この男の処分を譲ってもらったお礼……と言\nってはなんだが、飲食代は私が出させてもらおう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021590011" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「太っ腹だな！　タダ飯が食えるなら、アタシはどこにだって付き合うぜ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_010021590006" ]},
		{"command":[ "SETCHARA", "0", "char_00016101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「正義（まさよし）ならアタシも知ってる！　あの店、『正義』って名前だか\nら、気に入ってるんだよな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_010021590009" ]},
		{"command":[ "SETCHARA", "0", "char_00020601_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「マサヨシ？　セイギ？　……どういうことだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_010021590006" ]},
		{"command":[ "SETCHARA", "0", "char_00016001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「その店、漢字で正義って書く……って、なんか言葉だと伝えにくいな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_010021590010" ]},
		{"command":[ "SETCHARA", "0", "char_00020601_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「まさよしは、正義……つまり、正しい道理という意味の漢字を書く。英語で\n言うと『Ｊｕｓｔｉｃｅ（ジャスティス）』だな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021590012" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「そうそう、ジャスティス！　ジャスティスな店って聞くと、ヒーローのアタ\nシたちにはピッタリな感じがするだろ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_010021590011" ]},
		{"command":[ "SETCHARA", "0", "char_00020601_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「ジャスティスか……ふふっ。そう言われると、興味をそそられるな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_010021590007" ]},
		{"command":[ "SETCHARA", "0", "char_00016001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「しかし、代金を出してもらえるとのことだが、本当にいいのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_010021590008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「気にしないでくれ。思想は違えど、ともに正義を愛する者として、是非とも\n交流を深めておきたいからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021590013" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「そうか。では、お言葉に甘えさせてもらうとしよう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_010021590009" ]},
		{"command":[ "SETCHARA", "0", "char_00016001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「それでは、まずはこの男を本部に連れていくとするか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021590014" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「いぇーい！　なに食べよっかなー！　やっぱ唐揚げかなー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_010021590012" ]},
		{"command":[ "SETCHARA", "0", "char_00020601_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "それから一同は悪者を連行した後、居酒屋正義（まさよし）へと足を運ぶのだ\nった。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}