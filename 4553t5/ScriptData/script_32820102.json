		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「あぁぁぁんっ！？　オチンポ……抜けてっ、そんな……あぁっ……子種が、 \nこぼれてしまいますっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0104401" ]},
		{"command":[ "SETIMAGE", "0", "still_00028201_02_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「これで……いいっ？　んっ、あぁっ……最初から……私を精液まみれにする \nことが目的……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0104402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「そんな風に仰られたら……も、もう何も言うことは……あぁっ、オチンポ… \n…お腹に擦れてっ、あひっ、私も……母乳が……出ますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0104403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「あぁっ、ザーメンを塗りつけられて……母乳と混ざり合って……全身が熱く \nて……はひぁ……おかしくなってしまいそうです……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0104404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「あふ……はい……もっと染み込ませて下さい……外側からでも孕んでしまう \nくらいにたっぷりと……お願いします……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0104405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「んんっ……あぁ……落ち着きましたか……あふ……本当にザーメンまみれに \nしていただきました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0104406" ]},
		{"command":[ "SETIMAGE", "0", "still_00028201_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「確かに……もう十分オマンコには頂いていましたから、こうして身体にも浴 \nびせて頂くのは、私としても嬉しいことでした……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0104407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「あぁ……ご主人様のにおいに包まれて……私の身体はまだ高揚したままです \n……ずっと、この余韻に浸っていたいですわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0104408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「最初は少し驚きました。ですが、この荒々しい動き……私にとっては最高の \nご褒美だったかも知れません……」", "NORMAL" ]},
