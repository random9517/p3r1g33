		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「んっ……急にムラムラして……あぁっ、私のオマンコをお求めに……？　ん \nっ、そんな……大変光栄なことですが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「こんな風にいきなり押し倒さなくても、私はいつでもご主人様のモノですわ \n……ちゃんと、お相手致しますから……あっ、はぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0104103" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「あぁっ……は、入って……来ます……あくぅっ……オチンポが、どんどん… \n…中にぃ……は、うぅぅぅんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0104104" ]},
		{"command":[ "SETIMAGE", "0", "still_00028201_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「そこまで我慢できなかったのですか……？　あぁ……勃起が膨らんで……中 \nで広がっていく……んくぅぅ……あっ、んぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0104105" ]},
		{"command":[ "SETIMAGE", "0", "still_00028201_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「こ、こんな風に……乱暴にされてしまうのも……いい、かも知れません…… \nあぁ……オマンコがあっという間にいっぱいに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0104106" ]},
		{"command":[ "SETIMAGE", "0", "still_00028201_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「ヌルヌルって……んんう……あぁ、仰る通りです……私も……きっとオマン \nコを犯して頂けるのだと期待しておりました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0104107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「最初から、前戯もいらずに……ぐしょぐしょにしていたのは、私の淫乱オマ \nンコが欲しがっていたからですわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0104108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「ですから、どうか……もっと私のオマンコをご遠慮なく突き回して……奥を \n……ズンズンさせて下さいませ……あっ、あぉっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0104109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「はっ、あぁっ、あぉっ……！　太いのがいいですっ！　あぁっ、オチンポっ \n、そこっ、あぉっ、はぁぉぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0104110" ]},
		{"command":[ "SETIMAGE", "0", "still_00028201_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「はぁぁっ……めり込むぅ……この角度……いつもより、ずっと深いところま \nでオチンポが届いて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0104111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「んんんっ！　あぁっ、ぐっと……押し込まれると……はぁぁっ、気持ち良す \nぎて……あひっ、ミルクが……あっ、出ますっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0104112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「あぁ……恥ずかしいですわ……気持ちいい場所を全部知られてしまっていま \nすから……オチンポされる度に母乳が漏れてしまいますの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0104113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「もっと出せば……あぁっ、はいっ、ズリズリして下さいっ……ご主人様のオ \nチンポでオマンコを犯されて、私は気持ちよくなっております！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0104114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「あっ、んぁぁっ、はぁぁんっ、身体がビクッと……してしまいますっ……く \nぅぅ……オチンポとオマンコがいっぱい擦れてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0104115" ]},
		{"command":[ "SETIMAGE", "0", "still_00028201_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「あぉぅっ！　オチンポっ！　あぁっ……太いですっ……はぁっ、出し入れさ \nれる度に……目の前に火花が散って……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0104116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「くぅっ……んふっ……はしたないと分かっていても……浅ましい声が……あ \nぉっ、漏れてっ、しまいますのっ、はひぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0104117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「はいっ、あぁっ、ご主人様が望まれるのでしたらっ、もう我慢は致しません \nわ……メスのよがりをあげさせて……いただきますっ、あぁぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0104118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「あぉっ、おぉぉんっ！　硬いオチンポ様、いいですっ……！　はぁっ、一番 \n弱いところにっ……亀頭が……ぐりって押し込まれて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0104119" ]},
		{"command":[ "SETIMAGE", "0", "still_00028201_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「あっ、あぁぁっ、ごりゅごりゅっ……チン先ですり潰されるとっ……はぁぁ \nっ、内側から……マン汁っ、溢れ出して……きますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0104120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「はぁっ、あぁぉっ……これが……ご主人様のケダモノセックスぅ……あぁっ \n……何も考えられませんっ、はっ、んくっ、おふぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0104121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「は、はい……申し訳ありません……私ばかりよがって……一方的に快楽を享 \n受するばかりで……んんっ、ふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0104122" ]},
		{"command":[ "SETIMAGE", "0", "still_00028201_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「せめて……もう少しオマンコを締め付けて……オチンポに楽しんで頂けるよ \nうにいたしますわ……んっ、んむぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0104123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「あふっ……いやらしい腰使いだなんて……そんな……あぁ……ご主人様に求 \nめられて……必死なだけですわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0104124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「ですが……お褒めいただくのは嬉しいです……私のオマンコは、オチンポ様 \nに悦んで頂くためにあるのですから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「もっともっと求めていただけるように……いやらしいオマンコであり続けま \nすわ……んんっ、んくぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「はぁっ、あっ、んぁっ、あひぁっ……あぁっ、ご主人様に……躾けられてお \nります……んふぅっ、はしたないオマンコぉっ、はひぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0104127" ]},
		{"command":[ "SETIMAGE", "0", "still_00028201_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「あぁっ、子宮に届いてしまいそうです……んんっ、こんな奥までオチンポが \nめり込んでぇ……先端にキスされてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「はぁん……ダメ、もっと締め付けて……気持ちよくなっていただかないと… \n…あっ、はひっ、あひぃっ、んひぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「はふぁ……あぁ……緩んだ顔をご覧にならないで下さい……はぁん、口が自 \n然に開いて……舌が出てしまいます……ぁふっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「あぁ……そうですわ……こんな絶対に見られたくない表情……ご主人様の前 \nでしか……決して晒すことはありませんっ……んふぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「それでもっ、やっぱり……お見せするのは恥ずかしいですっ……オチンポで \n蕩けてしまっている……淫らな顔は……あっ、んぁぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「また……ご主人様のオチンポが、激しくっ……あっ、ふぁっ、あぁっ、この \nまま、出すまでっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0104133" ]},
		{"command":[ "SETIMAGE", "0", "still_00028201_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「あぁっ、はいっ、もう……オマンコもっ、子宮も……ご主人様のザーメンを \n受け止める準備はできておりますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「どうかっ、このまま激しくオチンポ突き回してっ……中に出してっ……私を \n孕ませて下さいませぇっ……はぁぁぁんっ、んあぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0104135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「あひぃっ！　あぁっ……中に来てますっ！　熱いの……どぷって流し込まれ \nてますぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0104136" ]},
		{"command":[ "SETIMAGE", "0", "still_00028201_02_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「んぁぁぁ……イ、イクッ……！　オマンコイキながらっ……中出し受精して \nいますっ、ご主人様のザーメン気持ちいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0104137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「はふぁぁ……あぁ……種付けありがとうございます……んふぅ……まだ奥に \n出てる……オマンコがずっと悦んでおります……んくぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「はぁ……あぁ……射精……収まってきました……隙間から……精液……こぼ \nれてしまう位……いっぱい出していただきました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0104139" ]},
		{"command":[ "SETIMAGE", "0", "still_00028201_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「あふ……あぁ……母乳もこんなに漏れてしまいました……乱れきった姿をお \n見せし続けて……恥ずかしいです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「でも、こんなに沢山の子種……こぼさず、お腹の中で大切にしますわ……本 \n当にありが……あっ、んぁっ……ご主人様っ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0104201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「あひっ、あぁっ……つ、続けてっ……も、もう……オチンポが元気に戻った \nんですかっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0104202" ]},
		{"command":[ "SETIMAGE", "0", "still_00028201_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「あっ、あぉっ、あぁっ……！　いけません……子種が……せっかく頂いた赤 \nちゃんのもとが溢れてしまいますっ、じゅぷって……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「イ、イッたばかりのオマンコ……力が……入らなくてっ……あっ、隙間から \n……お汁が……か、掻き出されてしまって……あ、んぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0104204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「えっ……？　何も気にすることはない……ですか……？　それは……その、 \nどういう……はっ、うんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0104205" ]},
		{"command":[ "SETIMAGE", "0", "still_00028201_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「もっと……いっぱい……出して下さる……あぁ……濃いのを……孕むまで… \n…は、はいっ……あぁっ、嬉しい……ですわっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0104206" ]},
		{"command":[ "SETIMAGE", "0", "still_00028201_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「そういうことでしたら……何も憚ることはありません……どうか、発情しき \nった欲しがりのオマンコをもっと躾けて下さいませ……んぁぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「くぅっ……んんんっ！　あぁっ、二回目の方が……オチンポっ……もっと… \n…熱くて硬くなっていますわ……んんっ、ふぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「もう……オマンコいっぱいになっているのに……もっと内側から広げられて \nいく感じがして……く……んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「中の襞が……オチンポにこねられて……キュンって……震えて……あぁっ、 \n好きですっ……こんな風にオチンポされるのっ……大好きですぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0104210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「ダメ……あぁっ、気持ちよすぎて……ま、また……母乳が出てしまいます… \n…あ、あひっ、出る……んんんんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0104211" ]},
		{"command":[ "SETIMAGE", "0", "still_00028201_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「あぁぁ……い、いえ……まだ、イッてはいません……が……射精したみたい \nに……母乳が漏れてしまってます……恥ずかしい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0104212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「あっ、あぉっ、ご、ご主人様っ……？　あぁっ、は、恥ずかしがる顔を見た \nいなんて……そんな、意地悪なこと……あ、ぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0104213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「あっ、あひっ、あぉぉっ、これ以上……気持ちよくされたらっ、ま、また… \n…オマンコ……すぐイッてしまいますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0104214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「もうっ、あっ、くぅんっ……オチンポ、すごすぎてっ……何とか耐えて…… \nいる状況でっ……あっ、あぁっ、またグリグリっ、そこぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0104215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「イ、イッていい……？　は、はひっ、ありがとう……ございます……でも、 \n私は……ご主人様と……一緒に絶頂したいのですっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0104216" ]},
		{"command":[ "SETIMAGE", "0", "still_00028201_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「ですから……んんっ、も、もう少しだけ頑張りますっ……ぎゅっと、オマン \nコっ、オチンポに吸い付けますからっ、あっ、あぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0104217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「はひっ、分かりますっ……オチンポがビクビク震えてっ、後……少しっ…… \nまた……いっぱい出して下さいませっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0104218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「奥の奥にいっぱい出してっ……孕ませて下さいっ！　ご主人様の子種をっ、 \nもう一度っ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0104219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「んぁぁっ、激しいっ！　ダメっ……イキますっ！　浅ましいオマンコアクメ \n致しますっ、あぉぉぉっ、オマンコイキ……ますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0104220" ]},
		{"command":[ "SETIMAGE", "0", "still_00028201_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「んぁぁぁぁっ……！　また……濃いのが……流れて来ますっ……ニ回目種付 \nけぇっ、始まって……おりますっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0104301" ]},
		{"command":[ "SETIMAGE", "0", "still_00028201_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「あっ、あぁぁ……はぁぁん……さっきよりも勢いが強くて……んんっ……し \nっかり受精させられている感じがします……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「はぁぁ……あっ、射精と一緒に……母乳もびゅびゅって溢れて……シーツに \nじっとり染み込んでしまいます……あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0104303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「しかも……あぁぉっ……オチンポ、まだ動き続けて……射精したまま犯され \nて……くぅぅん……気持ち……よすぎます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0104304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「あっ、ふっ……！　止まりました……種付け……しきってくれましたか…… \n？　はひ……ありがとうございます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0104305" ]},
		{"command":[ "SETIMAGE", "0", "still_00028201_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「んふ……隅々まで身体を貪り尽くされたような……そんな気分です……たっ \nぷりとオマンコを満たして頂いて……とても満たされておりますわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0104306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「あふっ……まだオチンポ……そのままにしておいて下さいますか？　ご主人 \n様と繋がったまま……しばしの余韻に浸りたく思います……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0104307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「あぁ……やっぱり大きい……この太い感触をずっと感じていられるのは…… \n本当に幸せなことだと改めて痛感致しますわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0104308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「はい、これからもご主人様のご気分のままに……ムラムラなさったら、私を \nご利用下さいませ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「私は、ご主人様のオチンポに尽くすメスですから……ふふ……また、いつで \nも躾けていただくこと……心待ちにしておりますわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0104310" ]},
		{"command":[ "WAITINPUT" ]},
