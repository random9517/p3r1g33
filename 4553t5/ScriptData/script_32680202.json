{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「こんなところに呼び出して……もう騙されないわよ。またパワーアップと称\nして、エッチな事を企んでいるんでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0204101" ]},
		{"command":[ "SETCHARA", "0", "char_00026802_01", "2", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「えっ……騙していたのは照れ隠しで、私のことが好きだから、エッチして欲\nしいって……きゅ、急にそんなこと言われても！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0204102" ]},
		{"command":[ "SETCHARA", "0", "char_00026802_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「いや、別にイヤとかそういうことは……私も隊長のこと、好ましいと思って\nいるけど……あっ、ちょ、ちょっと！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0204103" ]},
		{"command":[ "SETCHARA", "0", "char_00026802_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「きゃあぁっ！？　いきなり押し倒すだなんて！　それに、服がはだけて……\nあっ、やぁっ……は、恥ずかしい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0204104" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00026802_02_01" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「今までしてきた、エッチなトレーニングは恥ずかしくなかったのかって……\nあ、あれは、そういうものだと思っていたから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0204105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「やっ、あっ……オチンポがオマンコにあたってっ……んんっ！　私の膣内に\n入りたいって、ウズウズしてるみたい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0204106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「はぁ、あっ、んくぅ！　クリトリスにも、カタいのが擦れてっ……はぁ、く\nっ！　んふっ！　はぁ、あっ……オマンコ、疼いちゃうっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0204107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「本当に好きだから、セックスしたいだなんてぇ……押し倒しながら告白する\nなんて卑怯よ……こんなの、その気になっちゃうじゃない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0204108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「うっ、んっ！　はぁ、あくぅっ……わ、分かった……挿れていいから……そ\nの代わり、優しくしてね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0204109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「もし痛くしたら、絶対に許さないから……んっ、あっ……あふっ……オマン\nコに、熱いのが入ってくるっ……あっ、あっ！　あはぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0204110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「あっ、くっ……うぐぐっ……オマンコが、オチンポで拡げられてるっ……お\n、奥まで入ってくるの、分かるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0204111" ]},
		{"command":[ "SETIMAGE", "0", "still_00026802_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「はっ、はふっ……あっ、んはぁ……このズブズブ突き挿れられる感じ、すご\nく好きかも……はぐっ、あっ、あっ！　はふぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0204112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「ゆっくりされるの、好きっ……隊長のこと、いっぱい感じられて……頭の中\nが、ヘンになりそう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0204113" ]},
		{"command":[ "SETIMAGE", "0", "still_00026802_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「もっと深くまで、突き挿れてちょうだい……隊長のオチンポ、オマンコでい\nっぱい感じたいからっ……ひっ、あひっ！　はひっ、んっくぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0204114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「んふっ、はひゅうぅ……赤ちゃんを作るところに、カタいのが当たってる…\n…私たち、一つになって……あぁっ、すごく嬉しいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0204115" ]},
		{"command":[ "SETIMAGE", "0", "still_00026802_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「やっ、あっ！？　んひっ、ひくっ！　んっ、ふっ、あっ、あっ！　い、いき\nなり動くなんて……んひっ、はひぃんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0204116" ]},
		{"command":[ "SETIMAGE", "0", "still_00026802_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「オチンポがオマンコをズリズリ擦ってくるぅ！　デコボコしたところが、私\nの膣内を出たり、入ったりしてるのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0204117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「これ、すごく気持ちいい！　オマンコが拡がってて、少し苦しいのに……動\nかれると、感じちゃうのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0204118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「あっ、あっ！　ひっ、あぁぁんっ！　もっとズリズリしてっ！　オマンコの\n入口から奥まで、いっぱい擦ってぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0204119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「んひっ、あっ、ひゃふっ！　くっ、あっ！　あひっ、んっひぃ！　あ、浅い\nところもいい！　そこを刺激されると、おしっこの穴が疼いてくるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0204120" ]},
		{"command":[ "SETIMAGE", "0", "still_00026802_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「ど、どこが感じるかって……あっ、ぐうぅぅ！　そ、そこっ！　今、ちょう\nどカタいのが当たってるとこ……はひっ！　ふんぐぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0204121" ]},
		{"command":[ "SETIMAGE", "0", "still_00026802_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「これ、Ｇスポットって言うの？　え、えっと、Ｇスポットがいいの！　その\nザラザラしてるところをトントンされると、オマンコが震えてくるの！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0204122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「出し入れされてるところが、ヒクヒクしてっ……あひっ！　んひぃ！　オマ\nンコ、勝手に締まっちゃうっ！　んぐっ、ふっ、んっふぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0204123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「あっあっ！　やっ、あぁぁっ！　本当に、気持ちよすぎるからっ！　Ｇスポ\nットズリズリされると、お漏らししちゃうからぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0204124" ]},
		{"command":[ "SETIMAGE", "0", "still_00026802_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「隊長の前で、おしっこなんてしたくない！　お、お願いだから、もうそれ以\n上、Ｇスポットを擦らないでっ！　感じすぎて……ひぐっ！　ひゅぐぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0204125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「あっ！　あっ！？　オチンポが勢いよく奥にっ……はっひぃぃぃんっ！？　\nやっ、あぐっ！　も、もうそれ以上、奥に入らないからぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0204126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「ヘソの下あたりに、カタいのが届いて……こ、これ、赤ちゃんの部屋に、オ\nチンポが当たってるってことでしょう！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0204127" ]},
		{"command":[ "SETIMAGE", "0", "still_00026802_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「ぐっ、うぐぐっ！　くっ、あぁぁっ！　私の一番大事なところ、トントンさ\nれてっ……あっ、あっあっ！　これ、すごく好きぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0204128" ]},
		{"command":[ "SETIMAGE", "0", "still_00026802_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「オチンポが当たってるところ……し、子宮口って言うのね！　あぁっ、すご\nい！　子宮口の周りを突かれると、意識が飛びそうになるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0204129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「気持ちいいのが、オマンコから全身に伝わってきて……腰が勝手に浮いちゃ\nうっ……ふっ、んふっ！　はっ、あぅ！　んっ、んっふぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0204130" ]},
		{"command":[ "SETIMAGE", "0", "still_00026802_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「オマンコの震えが止まらないわっ！　子宮口の奥から、気持ちいいのが込み\n上がってきて……あっ、はひっ！　あっ、んっ、あはぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0204131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「な、何か来ちゃうっ！　オマンコの深いところ……今、隊長がトントンして\nるところから、ヘンなのが溢れてくるのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0204132" ]},
		{"command":[ "SETIMAGE", "0", "still_00026802_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「はひっ、んひっ！　んっひぃっ！？　隊長のオチンポも、ビクビクして……\nな、なにこれ！？　いったい、なにがどうなってるの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0204133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「もうイキそうって……こ、これが、イクッてことなの！？　私も、イキそう\nってことなの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0204134" ]},
		{"command":[ "SETIMAGE", "0", "still_00026802_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「んっ、はふっ！　あっ、あっ！　あぁぁっ！　よく分からないけど、気持ち\nいいの出るぅ！　イクッ！　イッちゃうのぉぉぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0204135" ]},
		{"command":[ "SETIMAGE", "0", "still_00026802_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「あっはぁぁぁぁっ！　熱いのがオマンコに出てるぅ！？　オチンポが跳ねな\nがら、ドロドロしたの吐き出してるのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0204136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00026802_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「これが精液で、今しているのが射精なの！？　そんなの、急に言われても…\n…はひっ！　ひっ、はひぃぃんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0204137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「あぁぁっ！　精液感じるっ！　オマンコの奥のところに、びゅるびゅる出て\nるからぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0204138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「擦られてるときも気持ちよかったけど、こうして熱いのを注がれるのも、す\nっごく気持ちいいのぉ！　ふっ、はふっ！　ぐっ、うぐぐっ！　んぐぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0204139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「ひぐっ、んぐぅ！　またくるっ！　気持ちいいの、奥からくるぅ！　イクッ\n！　イッちゃうぅぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0204140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「ふぅ……んっ、はふっ……あはぁ……す、すごかったわ……これが、イクっ\nてことなのね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0204201" ]},
		{"command":[ "SETIMAGE", "0", "still_00026802_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「それに射精……精液を注がれるのも、たまらないわ……今まで感じた中で、\n一番気持ちよかったかも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0204202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「なるほど……これがセックス……赤ちゃんを作る行為なのね……愛し合う二\n人がする、男女の営み……あぁっ、すごく嬉しいわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0204203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「その……もし、まだセックスできるなら、もっとして欲しいのだけど……こ\nのまま、いっぱいオマンコを突いてちょうだい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0204204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「さっきよりも激しくしていいから……隊長のオチンポ、もっと感じたいの…\n…もっともっと、セックスしたいの！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0204205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「あっはぁぁっ！　あっ、ひっ、んぐっ！　おっ、おぉぉっ！？　いきなり、\nオチンポをガンガン突いてくるなんてぇっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0204206" ]},
		{"command":[ "SETIMAGE", "0", "still_00026802_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「た、確かに、激しくしていいとは言ったけど……こんな急に……おっ！？　\nほっ！？　んおっ、おっ、おっ、あひぃぃぃんっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0204207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「お、奥のところ、ものすごい勢いでズンズンされてるぅ！　赤ちゃんの部屋\nに、オチンポが入っていくみたいな感じがするぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0204208" ]},
		{"command":[ "SETIMAGE", "0", "still_00026802_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「おごっ、んごほぉっ！　おっ、おぉぉっ～！？　感じすぎて、頭おかしくな\nるっ！　オチンポのことしか、考えられなくなっちゃうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0204209" ]},
		{"command":[ "SETIMAGE", "0", "still_00026802_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「このオチンポに夢中になっちゃう！　隊長だけじゃなくて、オチンポも好き\nになるぅ！　はひっ、おぐっ、んおっ！　おごほぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0204210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「あっ、あっ！　あぁっ！　オマンコに出された精液が、子宮口を通じてヘソ\nの下に届いてくる！　私の大事なところに、押し込まれてるのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0204211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「んっ、んんっ！　この精液が流れ込んでくる感覚、すごく気持ちいい！　も\nっと注いでっ！　オマンコの精液、ぜんぶ奥にちょうだい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0204212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「おほっ、んおっ！　おっ、おっ、おひぃ！？　あぁっ、あはぁぁぁっ！　好\nき！　大好きぃ！　隊長も、このオチンポも、どっちも好きぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0204213" ]},
		{"command":[ "SETIMAGE", "0", "still_00026802_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「ひぐっ、んっふぅ！　はぁ、あぐっ、おっ、おほぉっ！　また、浅いところ\n……Ｇスポットもズリズリされてるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0204214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「んっひぃぃっ！？　こ、今度は子宮口に、オチンポがきてぇっ！？　私の感\nじるところを、交互に突くなんてぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0204215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「あひっ、おっ、おごぉっ！？　んおっ、おっ！　おぉ～！？　気持ちいいの\n、止まらないわ！　オチンポでズポズポされるの、感じすぎるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0204216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「そんなに激しく突かれたら、またきちゃう！　オマンコの奥から、気持ちい\nいの溢れてくるのぉ！」」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0204217" ]},
		{"command":[ "SETIMAGE", "0", "still_00026802_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「あっ、あっ！　んひっ、おっ、んほぉっ！　隊長のオチンポも、オマンコの\n膣内でビクビク跳ねまわってるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0204218" ]},
		{"command":[ "SETIMAGE", "0", "still_00026802_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「また、イクのねっ！？　ドロドロの精液、びゅーってするのねっ！？　いい\nわ、出して！　またいっぱい、どぴゅどぴゅしてぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0204219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「隊長の精液を感じながら、イキたいのぉ！　あっ、あっ！　くるっ！　オマ\nンコ、イクッ！　ひっ、んひっ！　あっおっあっ、んほぉぉぉっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0204220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「ほひぃぃぃっ！？　熱い精液、またオマンコの奥に出されてるぅぅぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0204301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00026802_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「今度は、赤ちゃんの部屋に直接流し込まれて……はひっ！　し、子宮口にオ\nチンポがぴったり当たってるのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0204302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「さっきと感じ方が全然違うわ！　こっちの方が、赤ちゃんの部屋に精液注が\nれてるって感じがするぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0204303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「あぁぁっ！　あっ、あはぁぁっ！　気持ちいい！　しゃせー、気持ちいいぃ\n！　もっと出して！　びゅーってしてぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0204304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「君の射精を感じながら、イキたいからっ……おひっ！　ひっ、あっ！？　ん\nあっ、はっ、ふひっ！　あっはぁぁぁぁっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0204305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、おっ、おふっ……すごかったわ……こんなに、いっぱい出し\nてもらえるなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0204306" ]},
		{"command":[ "SETIMAGE", "0", "still_00026802_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「それだけ、私のオマンコが気持ちよかったってことよね？　ふふっ……すご\nく嬉しいわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0204307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「それにしても、告白してすぐセックスだなんて……隊長らしいというか、何\nというか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0204308" ]},
		{"command":[ "SETIMAGE", "0", "still_00026802_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「え？　もし赤ちゃんが出来ても、ちゃんと責任を取る？　そんなの、当たり\n前でしょう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0204309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「私をこんな気持ちにさせたんだもの……ちゃんとしないと、許さないから…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0204310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「あひっ、あっ！？　あはぁぁぁっ！？　オチンポがオマンコから抜けて……\nんひっ！　あっ、熱いぃ！　ヘンな汁が、身体にかかってるぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0204401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00026802_02_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「この熱さとドロドロした感じ、まさか精液なのっ！？　な、なんで身体にか\nけてっ……ひゃ、あっ！？　ま、まだ出てるっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0204402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「やっ、んんっ！　すごく気持ち悪いのに、感じちゃう！　精液かけられなが\nら、またイクのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0204403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「あっ、あっ！　くるっ！　気持ちいいの、きてるっ！　イクッ！　イクイク\nッ！　ふっ、あっ、あっ……あひぃぃぃんっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0204404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「あっ……はふっ……くっ、んふぅ……すごいにおい……これが、私のオマン\nコに注がれていたのね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0204405" ]},
		{"command":[ "SETIMAGE", "0", "still_00026802_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「というか……どうしてオマンコに出さなかったの？　隊長の精液なら、赤ち\nゃんの部屋でぜんぶ受け止めてあげたのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0204406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「膣内も膣外も、精液で真っ白に染め上げたかった？　なによそれ……そんな\nの、まるで私が隊長のモノみたいじゃない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0204407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「イヤとか、そういうことじゃなくて……むしろ、嬉しいというか……隊長の\nモノになれたって思うと、オマンコが疼いてきちゃうわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0204408" ]},
		{"command":[ "SETIMAGE", "0", "still_00026802_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「んっ……んくっ……どうして……いま、イッたばかりなのに、またシたくな\nってきちゃう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0204409" ]},
		{"command":[ "SETIMAGE", "0", "still_00026802_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「ねぇ……私のことが好きなら、もっとシて……隊長のオチンポ、もっともっ\nと、感じさせてちょうだい……」", "NORMAL" ]},
