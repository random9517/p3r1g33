{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「……はぁっ、はぁ、はぁ、はぁ……っ♪　あ、あなた……！　わたくしにこ\nこに呼び出された理由……よぉ～っくわかっていますわよね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0104101" ]},
		{"command":[ "SETCHARA", "0", "char_00020701_01", "5", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「毎日毎日、わたくしのことをいじくりまわして開発して……！　わ、わ、わ\nたくし……すっかりエッチなメスガキになってしまったのですわ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「責任をとりなさい……。ええ、そうよ？　これだけ焦らしに焦らしたのです\n、今日こそ本番のエッチをしてもらいます。そうでなくっちゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0104103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「もう、身体がどうにかなってしまいそうなんですものっ……ううううっ。早\nく、はやく……わたくしをオトナの女にしてくださいませぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0104104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「ふーっ♪　ふーっ、ふぅうーっ……♪　ど……どうです？　こんなポーズま\nでしているのです……。おちんぽ硬く、太くなってきますわよね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0104105" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00020701_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「よーくその目でご覧になって……。この小さなカラダを、日々もてあそんだ\n悪い男……あなたのせいで、わたくしはもうダメダメなのですっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0104106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「お……おまんこはずぅっとピクピクしていますし、愛液、がショーツにいつ\nもシミを作って……。で、でも一人でするなんてやり方もわかりませんし！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0104107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「こわい……ですから、ずっと放置して……。そうしたらもう、入口がジンジ\nンしてつらくなって！　うぅ、おっぱいだってずっと張っているんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0104108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「乳首も勃起したまま戻らないし……お洋服を着るとこすれて、モジモジして\nしまって……。なのに、あなたは最後の一線は越えようとしない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0104109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「そんなのっ、そんなの蛇の生殺し！　人道にもとる最悪な所業ですわぁっ！\n　トドメもささずになぶって遊んだだけなんて……！　ですからっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0104110" ]},
		{"command":[ "SETIMAGE", "0", "still_00020701_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「きょ……今日こそはしてもらいます、おまんこ……わたくしのおまんこに、\nそのおちんぽをい、入れて、ズプズプ犯してもらいます、いいですわね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0104111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「……あっ♪　あなたもおちんぽ、大きくしているではありませんか……。な\nら早く、はやくきてくださいまし……。って、あら？　なんですのそれは？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0104112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「いやっ！？　つ、つめたい！？　えっ！？　な、なんでお尻の穴に！？　あ\n、あのっ、そこはおまんこではありませんわよ！　お尻、お尻の穴ですっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0104113" ]},
		{"command":[ "SETIMAGE", "0", "still_00020701_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「なぜわたくしのお尻の穴に謎の液体を！？　あっ……？　お、おやめなさい\nっ、何をしているんです！　ちょっと！　ニュルニュル入ってきてますの！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0104114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「っぅううううう！？　あああああ！　ローション……潤滑油ぅ！？　潤滑油\nをお尻、おしりの穴の奥にまで挿入して……ど、どういうつもりですか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0104115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「わたくしはおまんこにおちんぽを入れろと命令して……！　……ふぇっ？　\nまさか……ま、まさかですわよね。そのおちんぽを……まさか……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0104116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「おぉおっ！？　ふ……ッ！？　やっ……！　う、うそっ……！　んおおおお\nっ……！？　ま、待ちなさい、お尻におちんぽを……？　んふっ、おぅっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0104117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「は、いりません……入るわけがないでしょうっ！　そ、そこは出すところで\n入れるところではございません！　あっ……？　あっ、無理です、無理ぃっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0104118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「お尻の穴はローションを塗っても、おちんぽが入る大きさじゃ……って、う\nぐぅううう！　おぉっふっ！？　んぉっ！　は、入っちゃった……ぁあ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0104119" ]},
		{"command":[ "SETIMAGE", "0", "still_00020701_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「あ……ッ、あ、ぅ……あ……？　あっ……あ……。はぁーっ、はーっ、はー\n……っ！　なぜ……なぜお尻に入れたんですか、……うぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0104120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「重いです……！　それに、お尻の中、ミチミチに拡げられて……く、くるひ\nい……っ。あ、あなた、何をしているかわかっているのですか……あぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0104121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「ケツハメ……っ！　下品にも程がありますわ！　あっ……あっ、わたくしの\n狭くて無垢なお尻にそんな、無骨で凶悪なちんぽをねじこんで……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「あくま……、悪魔ですっ！　んぉっ……、屈辱、です……！　はぁ、はぁ…\n…一刻も早く抜きなさい。でないと怒りますわよ……って」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0104123" ]},
		{"command":[ "SETIMAGE", "0", "still_00020701_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「あうっ！？　あうっ、あぁううっ！　動かさないでぇ！　あっ！　あっ！　\nあふぅっ！？　おっ！？　おぉっ、うっ、んぉおっ！　おふぅっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0104124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「お、しり……ぃっ、わたくしのお尻でおちんぽ動かさないでください、ませ\nぇえええ……！　壊れちゃいます、お尻壊れちゃうぅう！　あふぅうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「わ……わ、かりました……！　もうわかりましたぁあ！　わたくしが生意気\nでした、悪いガキでした、あなたを挑発して貶めて最低でしたからぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「謝りますからやめてくだ、ひゃ……。んぁああああああ！　なんでぇ！？　\nなんで激しく動かすのぉ！？　やぁああ……だめ、だめ、やぁあああ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0104127" ]},
		{"command":[ "SETIMAGE", "0", "still_00020701_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「んぁっ！　あやまっ……！　謝っているのにぃ！　ごめんなさいしたのにお\n尻っ……お尻ほじほじされてる、熱い……お尻が熱い、怖いよぉお……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「あーっ！　あっあっあぁっ！　あぅうううっあっあっあぁ！　あーーーっ…\n…！　おっ……おぉっ！　や、めてぇ……ほじほじしちゃらめぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「ずぬっ、ずぶっ、ずぷって出たり入ったりして……ます、……ああっ！　信\nじられない……っ、お尻をおまんこにされてます、わたくし、わたくしぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「おしりっ、おしりを犯されてるぅうっ！　あふッ！？　ずっぽっずっぽっず\nっぽって……あああっ！　おちんぽ焼けるように熱くって、あっあっあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0104131" ]},
		{"command":[ "SETIMAGE", "0", "still_00020701_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「腸内おかしくなってしまいます、お尻の穴っ……性器になってしまいますっ\n！　あっ……あっ！　おまんこ、おまんこでもエッチまだなのにっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「お尻の処女を奪われて……犯されて、ぶっといおちんぽハメハメされて……\nおケツ使われちゃってますのっ……！　あっあぁあっ、悪夢、悪夢ですぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「……んっ！？　な、なんでお腹の中でおちんぽが大きくなってきているので\nす！？　えっ！？　このまま中出しするつもりですか！？　えっえっえっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「お、お尻はおまんこではありませんのよ！？　ここに出しても無駄撃ちで、\n赤ちゃん出来ませんし、……ああっ！　良くありません！　やめっ、うう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0104135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「んぉほおおおっ！？　んほっ！？　んおっ、おおっ、おぉおッ！？　や、や\nってくださいましたわねぇっ！？　お尻に中出しっ……中出しぃい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0104136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00020701_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「おなかっ、ゆ、ユルくなっちゃいますのっ……いやっ、いやぁっ、だめ……\nだめぇえっ！　ちょっとぉ！　ドクドク注がないで……んあああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0104137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「おまんこ処女のまま、おケツに精液ドピュドピュですわぁあ……ッ！　あ～\n～～～っ！　熱いっ、熱いんです、精液あつい……熱いぃいい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「あっ……ま、まだ出すのですか……っ。わ、わたくしのお尻は具合が良くて\n……ちょうどイイ感じにおちんぽにフィットする？　そ、そんな……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0104139" ]},
		{"command":[ "SETIMAGE", "0", "still_00020701_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「お尻でエッチをする才能がある？　う、嬉しくありませんっ……！　あっ…\n…♪　あぁ、い、いつまで出しているんですぅ！　も、もういいです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「……ふーっ……♪　ふぅっ、ふぅ……っ。よ、ようやく全部出しきったので\nすか……。あああ、お尻をお便所にされてしまいました……くやしい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0104201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「せっかく……せっかく今日は、おまんこであなたと結ばれると思っていたの\nに……記念すべき日になるハズだったのに、おしり……なんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「もうプンプンです！　フンッ、これだけ好き勝手したならスッキリしたでし\nょう！？　さっさと離れてくださ……。やっ！？　えっ、何！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「あぅううう！？　えええっ！？　こらぁっ、どうしてまたおちんぽが復活し\nて……！？　それに、も、もう一度動かしていいなんて言っていませんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0104204" ]},
		{"command":[ "SETIMAGE", "0", "still_00020701_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「精子っ……精子でタップタプのお腹……突かないで、えぐらないでください\nぃい！　やぁあっ♪　おまんこじゃないんですから、そこはお尻ですぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0104205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「んああああっ！　あっ、あっ、んふぅっ！？　ああ……！　ぐ、ぐっちょぐ\nっちょ音がしてます、お尻っ……お尻掻き回されて……あっあっあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0104206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「おちんぽ一回も抜かないで、二回目っ……お尻で二回目のエッチをするなん\nて……野蛮、野蛮ですわ……！　ああっ！　くるしっ……やぁっ、ああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「精子がヌルヌルしているせい、でっ……さっきより奥までハマっちゃってま\nすぅう！　いやぁっ……お尻の中、行き止まりをゴツゴツノックされてっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「あううっ！　こんなのありえませんん……！　完全にお尻をおまんこがわり\nにされて、ますわ、あふぁあっ！　変態です、これはヘンタイのHですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「んッ……おぉっ！？　おほぉおっ！　おぁっ、あふぅっ！？　おああっ！　\nか、可愛い声で喘ぎたかったのに……こんな、こんな切羽詰まった声でぇっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0104210" ]},
		{"command":[ "SETIMAGE", "0", "still_00020701_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「おケツでオホオホ言わされて……恥ずかしい、恥ずかしいぃいい……！　お\nほっ！？　んっ……ほぉっ！？　あぅっ……あうぅううっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0104211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「んぁあああ……っ！　お、おちんぽの力が強すぎてぇ……わたくしの腰が、\nお尻が、脚が勝手に揺れて、しまって……あっあっあっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0104212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「ピストンに合わせて大きく上下しちゃってますわぁあ……！　ひんんっ！　\nぶちゅぅうっ、ぐちゅううっていやらしい下品な音まで聞こえてきますっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0104213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「あっああああ……！　こんな姿、仲間にも、部下にも絶対見せられないぃ…\n…！　あっ、あぐぅっ！　て、手加減無しでお尻を犯すだなんてぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0104214" ]},
		{"command":[ "SETIMAGE", "0", "still_00020701_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「わ、わたくしがおかしな趣味に目覚めっ、たらっ、どう責任をとるつもりで\nすかぁあっ……！　っぁっ……既にちょっと気持ち良くなってきたぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0104215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「あっ……うっ、な、なんで……？　お尻で感じるなんて、ヘンっ……変、な\nのに……！　うぁっ！　硬いおちんぽでズコズコされると……んああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0104216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「まるでお尻はおまんこだったみたいに身体がっ……あうっ！　心が誤解して\n……！　あっあっ、それ以上は……だめ、危険すぎるぅ！　あっあっあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0104217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「んっぉっ……！？　やだぁ、今の一撃……響いちゃった、……あっ！　お尻\nでイかされるなんていけないこと、禁断の快楽です！　でも……でもっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0104218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「あふぅううっ！　わたくしの気持ちなんておかまいなしにっ……おちんぽが\n、おちんぽがわたくしをイかせようと……！　ああ～っ、うああああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0104219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「もう限界っ、限界ですぅううっ……！　イくぅっ、イグッ……♪　ケツ穴ハ\nメハメで下品アクメキメちゃいますぅっ！　やだっ、見ないでぇえっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0104220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「んぉおおおっ……！？　おおおおっ！　精子っ……精子が注入されて……お\nぁああああっ♪　強制絶頂させられちゃいますっ、ああああっ、イクぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0104301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00020701_02_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「二回もぉっ……二回もお腹にっ……！　お尻に精液ビュッビュされてっ……\n種付けされちゃいましたぁああ……お尻、わたくしのお尻がぁあ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「お尻がおまんこにされちゃいましたわ……ぁっ！　ああっ！　そんなにっ、\nそんなにしつこく射精されたら……お尻が勘違いします、あっううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0104303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「イ……くぅっ、イキますぅうっ……！　イッちゃってますのぉお……っ！　\nあふっ、ま、まだ出すのですか……もうお尻に入りきりませんん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0104304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「あふぁあっ！？　っくぅううう……！　あっ……あっぁッ……♪　お尻でイ\nクなんて、イケるなんて……知りませんでした、恥ずかしい……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0104305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「はぁー……っ♪　はぁっ、はぁあ……♪　にくらしい……♪　スッキリした\n顔をして……。あっ♪　わたくしは……ま、まだ余韻が長引いているのに」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0104306" ]},
		{"command":[ "SETIMAGE", "0", "still_00020701_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「ああ……。二回もお腹に、お尻に種付けされてしまいました……。なんでこ\nんなことにぃ……。はぁ、はぁ、はぁ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0104307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「んっ♪　だめ……♪　中からドロっと精液が溢れ出しそうに……♪　そうな\nんですね、お腹にぎゅーっと力をいれておかないと……漏れちゃうのですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0104308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「……あなた、自分は関係ないという顔をしていますけれど……、わたくしを\nこんな蛇の道に……ヘンタイの道に誘ったのですから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「これからも、わたくしの近くにいて、……た、たまーに気持ちいいことをし\nてくれなきゃいやですわよ……？　むぅ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「イグぅっ、イック……って、あっ！　いやぁっ！？　ヌルンってお尻からお\nちんぽが抜けて……あっあああっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0104401" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「んふっ！？　あうっ……あふっ、んん……！？　ドロドロが、ネチョネチョ\nが雨みたいに降り注いでくるぅ……あっ、あっ、精液……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0104402" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00020701_02_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「だめぇ……！　ベトベトがくっついて、とれなくなっちゃいます……っ！　\nあっ、ぁっ、かけないで……ぶっかけちゃだめぇ……っ！　やぁあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0104403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「だ、め……♪　ダメなのに、気持ちいい……っ♪　精液の雨、ヌルヌルの精\n液まみれになって……。やだやだぁ、くさいですっ……くさぁい……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0104404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「あッ……♪　あっ、あぁああ……！　な、なんで二回目の射精でこんな量を\n吐き出せるんですっ……溺れそう……。んっ、んぷ……うう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0104405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「っはぁあああ……♪　きゅ、急にお尻からおちんぽを抜いたりするから……\n一度目の精液がお尻から垂れてしまっているじゃありませんかぁああ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0104406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「もう、わたくしの下半身はドロッドロのドロですわ……っ。ヌチョヌチョで\n、……あっ♪　少し動くだけで精子の匂いに満たされて……あぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0104407" ]},
		{"command":[ "SETIMAGE", "0", "still_00020701_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「すっごくいやらしい気持ちになって……。どうしたらいいの、こんな感情は\nじめてで……うう……。なのに、いやじゃない。むしろ幸せかもしれない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0104408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「あ、あなたの精液だから……なのでしょうか……？　それとも、ただ……わ\nたくしがお尻でのエッチの素質があっただけ？　わかりませんん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0104409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、混乱させないでくださいませ……っ。今日のこと、わたくし絶\n対に絶対に！　忘れてなんかさしあげませんから……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0104410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
