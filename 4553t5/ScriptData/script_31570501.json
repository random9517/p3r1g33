{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015705_01_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「もー、何ですかーさっきから、私の身体をジロジロと見て……気持ち悪い下\n僕ですね～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0503101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「私の格好がそんなに気になりますか？　――うわぁ、何ですかその顔、本当\nに気持ち悪い……死ねばいいのに」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0503102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「ですが……いいですよ、そんなに私に興味津々というのなら、可愛がってあ\nげちゃいましょうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0503103" ]},
		{"command":[ "SETIMAGE", "0", "still_00015705_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「嬲って、虐めて、泣かせて……下僕はいったいどんなみっともない姿を見せ\nてくれるのかしら、にゃふふふ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0503104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「あらあら、今更慌てたところで逃がしませんよ、っと！　はい、つーかまー\nえた♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0503105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「無駄な抵抗はやめて、みっともない姿を見せてくださいな♪　そうですねぇ\n……足で――いえ、太ももで虐めてあげるなんてのは、どうでしょうか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0503106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「あら？　あらあら？　逃げようとした癖に、どうしておちんちんがこんなに\nも気持ち悪く勃起しているんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0503107" ]},
		{"command":[ "SETIMAGE", "0", "still_00015705_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「私に虐められるの、期待しちゃいました？　もしかして、下僕はマゾとか呼\nばれる人種だったりします？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0503108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「――違う？　本当に？　でもほら、太ももで乱暴に圧迫するだけでおちんち\nん馬鹿みたいにびくびくしてますよー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0503109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「そういえばですけど、人間のおちんちんって、どれぐらい力を込めれば潰れ\nちゃうんでしょうね～♪　……試して、みます？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0503110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「にゃは、にゃはは♪　冗談ですよ、冗談！　そんな簡単に壊してしまうと、\n虐め甲斐がないじゃないですか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0503111" ]},
		{"command":[ "SETIMAGE", "0", "still_00015705_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「――でも……変に抵抗したり、私の機嫌を損ねるようなことをすれば……ね\nぇ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0503112" ]},
		{"command":[ "SETIMAGE", "0", "still_00015705_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「あぁ……その怯えたような表情、とっても素敵……ずっとその態度でいるな\nら、壊さない程度に、可愛く苛め抜いてあげちゃいますよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0503113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「みっともない雑魚おちんちんを、太ももでぎゅ～って挟んで……んっ……す\nりすり、すりすり……にゃふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0503114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「私の表面装甲、中々の弾力でしょう？　ゆっくりと、ずりずりって皮を巻き\n込んでおちんちん扱いて……左右に振り回して……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0503115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「――あ、気が付きました？　内部機構の温度を少し高めに設定しました。私\nの太ももの間、人肌のような心地よさがあるでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0503116" ]},
		{"command":[ "SETIMAGE", "0", "still_00015705_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「太ももの間で、すりすりって摩擦して……おちんちんを圧迫して、緩めて、\n圧迫して、緩めて……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0503117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「にゃは、また馬鹿みたいにびくんって跳ねましたね～♪　分かってます？　\nおまんこでも何でもない、ただ太ももに挟んでるだけですよ～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0503118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「男として……いえ、人間として恥ずかしくないんですか？　好き勝手におち\nんちんを太ももで遊ばれて、いいように弄ばれて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0503119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「――は？　気持ちいいからこれはこれでよし、ですか……？　ちっ、面白くな\nい開き直り方をしますね、気持ち悪い……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0503120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「ほら、根元からきつく圧迫してもまだそんな余裕でいられますか？　血管を\n押しつぶして、捩じるようにぐりぐり、ぐりぐり……んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0503121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「にゃは♪　そう、聞きたいのはその苦し気な声ですよ！　あなたは下僕なん\nですから私の玩具になっていてくださいよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0503122" ]},
		{"command":[ "SETIMAGE", "0", "still_00015705_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「根元をぎゅっぎゅっ、血流を止めるような強さでぎゅ～～！　苦しいでしょ\n？　緩めてほしいでしょ？　でもダメです、まだまだ虐めるんですから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0503123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「しこしこ、ぎゅっぎゅっ、しこしこ、ぎゅっぎゅ♪　にゃは、おちんちん真\nっ赤になってきた♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0503124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「こんなのが気持ちいいとか、本気ですか～？　ああ、やっぱり下僕はマゾな\nんだ。この変態のどマゾ野郎め……にゃふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0503125" ]},
		{"command":[ "SETIMAGE", "0", "still_00015705_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「先っぽから気持ちの悪い液体も垂れてきましたね～……ほーら、私の自慢の\n爪でカリカリって塗り広げてあげっちゃいますよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0503126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「段差のところをカリカリ、先端に爪を差し込んでぐりぐり……痛い？　刺激\nが強すぎる？　私の知ったこっちゃないですね～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0503127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふふ、勝手に感じられるのは不愉快ですが、ここまで分かりやすく反応\nを見せられるのは、それはそれで悪くないですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0503128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「――分かってますよ、もう出したい、ですよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0503129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「雑魚おちんちんをこんなにヒクつかせて、腰をみっともなくびくびくさせて\n……いえ、馬鹿みたいなおねだりも、懇願も必要ありません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0503130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「ただ私はこの雑魚おちんちんを虐めるだけです。下僕の興奮なんてしりませ\nん。私の都合で、私が弄んで、玩具のようにイかせるんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0503131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「ほーら、またおちんちんの根元をぎゅ～～！　太ももをこすり合わせて、す\nりすりって擦ってもあげちゃいます♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0503132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「んんっ、んふっ……！　ふふ、苦しそうな声……みっともない喘ぎ顔……そ\nのまま果ててしまってください！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0503133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「――圧迫が強すぎて苦しい？　もっと緩めてくれないと出せない？　はっ、\n知ったことではありませんね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0503134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「最悪下僕のおちんちんが壊れてしまってもいいんです！　そうなりたくなけ\nれば、ほら！　射精するんです！　私の太ももに虐められて出しなさい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0503135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「んんんんっ♪　にゃふふ、まさか本当にこの圧迫の中で出すなんて！　ああ\n、気持ち悪いドロドロがどんどん出てくる……にゃふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0503136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015705_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「すんすん……うわぁ……なんて臭い精液を出すんですか。気持ち悪い、あぁ\n、気持ちわる～い♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0503137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「人の太ももをこんなにも汚してくれちゃって……これは躾の意味も込めて、\nまだまだ虐めてあげる必要がありますね～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0503138" ]},
		{"command":[ "SETIMAGE", "0", "still_00015705_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「――ほら、とっとともう一度雑魚おちんちんを固くしてください。逆らうよ\nうなら……このままブチっと潰しちゃいますよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0503139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「にゃは、おちんちんビクンってした♪　その調子ですよ♪　なーんだ、やっ\nぱり下僕ももっと私に虐めてほしいんじゃないですか♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0503140" ]},
		{"command":[ "SETIMAGE", "0", "still_00015705_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「さっきの精液を太ももに塗り込んで……んんっ、んふっ……滑りのよくなっ\nた太ももで、さっきより激しく虐めてあげちゃいますからね～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0503201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「ほ～ら、赤くパンパンに腫れた、敏感おちんちんを太ももで、ぐちゅぐちゅ\n、すりすり……にゃは、いいですよぉ、その情けない喘ぎ声♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0503202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「また爪でもおちんちんをひっかいて上げちゃいます。括れの部分をカリカリ\n、爪を立ててツーーっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0503203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「このまま私が少しでも力加減を間違うと、おちんちんが爪でズタズタになっ\nちゃいますね～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0503204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「――痛いですか？　苦しいですか？　でも、おちんちんは気持ちいいんでし\nょ？　にゃは♪　気色悪いですねぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0503205" ]},
		{"command":[ "SETIMAGE", "0", "still_00015705_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「おちんちんの先端をカリカリ、指先ではじいてピーンっ！　んふっ……もう\nちょっと力を入れて虐めても壊れなさそうですね～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0503206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「太ももの方もまた強く圧迫して上げちゃいます。根元から締め付けて、潰す\nような勢いでぎゅ～～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0503207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「んふっ、んんっ……！　なんでしょうね、この気持ちは……下僕のことが憎\nくて仕方ないはずなのに、情けなく身悶える姿をみせられると……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0503208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「んぁんっ……！　少し、可愛いと思ってしまいます……んんんっ……！　私\nの玩具……私だけの玩具……にゃふ、にゃふふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0503209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「このままもっと虐めて、壊して……たっぷり感じさせてあげちゃいますから\nね～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0503210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「更に爪を深く差して……カリカリ、カリカリ……にゃは♪　おちんちんに赤\nい線が入っちゃいましたね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0503211" ]},
		{"command":[ "SETIMAGE", "0", "still_00015705_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「ジンジン痺れて、熱を持ったように痛くて……でも、気持ちいいでしょう？\n　カリカリひっかかれるのが、いいんですよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0503212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「あぁ、憎くてたまらない顔をしてますけど、その痛みに眉をしかめる表情は\n悪くありません♪　にゃふふ、情けなくて、みっともなくて、可愛い……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0503213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「太ももの動きも、もっと大きく、早く……！　んふっ、んんっ……！　おち\nんちんをすり潰してあげちゃいます！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0503214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「いいですよ、その切羽詰まった悲鳴にも似た喘ぎ声！　ほら、太もものしこ\nしこに合わせてあんあんって喘いでくださいよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0503215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「しこしこ、ぎゅっぎゅ、しこしこ、ぎゅっぎゅ♪　血管を圧迫して、皮を巻\nき込んで、しこしこ、ぎゅっぎゅ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0503216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「にゃは♪　先っぽがみっともなくヒクつき始めた♪　おちんちんいいように\n虐められてまた出すんですね！　ドマゾ射精しちゃうんですよね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0503217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「ほら、射精の瞬間はまた苦しいほどに圧迫してあげちゃいます！　おちんち\nんをぶっ壊す勢いで精液をぶちまけてくださいな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0503218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「んふっ、んんっ、んんんっ……！　おちんちんの中、ドクドクって精液がさ\nかのぼっていって、んふぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0503219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「出しちゃうんですね　おちんちんいじめられてドマゾ射精しちゃうんですね\n！　いいですよ……　ほらイって！みっともなくイっちゃってください～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0503220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「あっ、んふぅぅんんっ！　すごい精液の勢いっ！　にゃふ、身体にまで飛ん\nで、んんんんっ～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0503301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015705_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「まったく、自慢のパーツが下僕のくっさい精液で汚れちゃったじゃないです\nか、んんっ、んにゃんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0503302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「この生意気おちんちん、どうしてやりましょうかね……？　にゃふふ、この\nまま爪で本当にズタズタにしちゃいます？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0503303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「にゃは♪　さすがに慌てるんですね～♪　ほーら、射精したばかりのおちん\nちんを爪でカリカリ、カリカリ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0503304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふふ♪　いいですよ、その馬鹿みたいな喘ぎ声♪　ま、それに免じてず\nたずたは許してあげましょうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0503305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「どうですか、下僕、身の程をわきまえましたか？　自分は虐められるのが大\n好きなド変態って、認めますか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0503306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「――え？　この程度普通のプレイのうち？　気持ちよくしてくれてありがと\nう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0503307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「こ、この下僕は……気に入りません、そーゆーところ、心底気に入りません\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0503308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「ですが……にゃふ♪　まぁ、いいです。そっちがその気なら、私だって本気\nであなたのことを苛め抜いて上げます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0503309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「その生意気な態度がいつまでもつか、楽しみにさせてもらいますよ。ね、私\nだけの玩具♪　にゃふ、にゃふふふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0503310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「あっ、んふぅぅんんっ！　また太ももにくっさい精液ぶちまけてっ、にゃふ\n、んぁぁぁんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0503401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015705_01_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「まったく、どれだけ私の太ももが気に入っちゃったんですか、んんんっ……\n！　まだまだ射精が止まりそうになくて、んふんんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0503402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふふ、気持ち悪い、本当に気持ち悪い下僕ですね～♪　私に無理やり虐\nめられただけなのに、こんなに激しくイっちゃうだなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0503403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「やっぱり変態ドマゾなことは確定ですね～……んんっ、んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0503404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「まぁ、楽しませてくれたサービスです。最後の一滴まで、下僕の大好きな私\nの太ももで搾り取ってあげちゃいます。んん、んふぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0503405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふ♪　これでおしまい、ですかね？　ほんと、子孫を残せるわけでもな\nい無駄ウチ射精、ご苦労様ですね～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0503406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「どうです、私に虐められた感想は？　――え？　普通に気持ちよくて最高だ\nった？　ありがとう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0503407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「こ、この下僕は……気に入りません、そーゆーところ、心底気に入りません\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0503408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「ですが……にゃふ♪　まぁ、いいです。そっちがその気なら、私だって本気\nであなたのことを苛め抜いて上げます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0503409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「その生意気な態度がいつまでもつか、楽しみにさせてもらいますよ。ね、私\nだけの玩具♪　にゃふ、にゃふふふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0503410" ]},
