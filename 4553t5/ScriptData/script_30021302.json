{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「……え？　ま、またあの術をしてほしい……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1304101" ]},
		{"command":[ "SETCHARA", "0", "char_00000213_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「そのために、ここに呼び出したの？　そうだったんだ……。普通にデートし\nてくれたのかと思って勘違いしてた。ラ、ラブホテル……だもんね」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000213_01", "5", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_002_1304102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ケーキを食べながら、二人で映画でも見るのかと……。散多の術……あれは\n身体に結構負担がかかるんだけど……気に入ってくれたってこと、だよね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1304103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ううん……どうしようかな。本当に……見たい？　うん……。わ、わかるけ\nど……。うん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1304104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「どうしても……今日したいの？　誰も邪魔の入らない場所。どれだけ大声を\nあげても気取られない部屋……確かにそうだけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1304105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「……わかった。あなたがそこまで言うなら……使う。恥ずかしいから、少し\n目をつぶっていて……。月影流忍術奥義・散多の術……！！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000213_01", "0", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_002_1304106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「成功……。あっ、ほ、本当に……感覚が繋がってる……。わか、る……。あ\nなたの口の湿った感触と、硬いオチンチンの熱気が同時に……わかる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1304107" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000213_02_01" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あなたにも伝わってる？　私達の２つのぬくもり。え？　２人とも、もう身\n体が火照ってるって？　はぁ、はぁ、すごく濡れちゃってる？　そんな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1304108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「せっかく分身したんだから、２倍触って楽しみたい？　……ぁ。……胸も、\nお尻も……アソコも？　２倍、２倍触るの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1304109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「……きゃっ！　ま、まずは私から？　……蜜が溢れ出してトロトロ滴ってる\nなんて、そんなのはっきり言わないで……。あっ、やっ、やっ、やぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1304110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「アソコが赤く充血してて美味しそう……？　あっ、舐めたり吸ったりされた\nら……。あっ！　気持ちいいけど、けど……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1304111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「舌は尖らせてチロチロしたり……あんっ、んん……んんっ！　大きく動かし\nて愛液ごとおしゃぶりしたり……。あぁ、そんなに夢中でしちゃだめ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1304112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「胸も握って揉むの……？　んんっ……。大きい手のひら……。私の乳首、ピ\nンって勃起してて目立ってる？　もう、あまり見ないで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1304113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「コリコリに硬くなってるとこを、つまむの……？　あっ！　や、やだ……声\nが出ちゃう。クリクリって転がして……？　き……気持ちいい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1304114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ツンツンって舌に当たるクリトリスを……。あっ、舌で剥いて甘噛みして…\n…。っんんんぅっ……ゾクゾクする、ビリビリ来る……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1304115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁ、はぁ、はぁ……！　あっ……んんっ、ンッ、んん……！　舌\nで割れ目、舐められると……全身で感じちゃう、あっあっあっあぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1304116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「じゅるじゅる音をたてて吸ったりしたら……！　ッうぅ……んふぅっ……っ\n。ああっ……ああ、恥ずかしい……恥ずかしい……んーっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1304117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「……そろそろ、私にも触って……。一人だけを触り続けると……えっと、変\nな感覚がこっちにも来ちゃうから……分散した方が」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1304118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「さ……さっきから、あなたの口が這ってる感覚がこっちにも伝わってきてて\n……。ムズムズして止まらなくなってきて。アソコが疼いて落ち着かない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1304119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「うん、自分では止められないの。栓をしてほしい……！　んふっ……わ、わ\nかるでしょ？　入り口がビクビク痙攣してる……怖い」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1304120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「……え、もう入れたい？　……あ……。う、うん。あなたもこんなに大きく\nしてくれてるし。……いいよ。来て……あぁあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1304121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あ……あ、太いのが入ってきた……！　んふっ……！　これ、これすごい…\n…すごく太い、中がゴリュゴリュって突かれて、広げられて、く……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1304122" ]},
		{"command":[ "SETIMAGE", "0", "still_00000213_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「今日……角度が鋭い気がする。興奮してるんだね。そういうのわかるよ……\n。ん、んんぅ……一番奥にコツコツ先がぶつかってくる……はぁ、はぁあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1304123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「……んん！？　んう！？　わ、私にも伝わってくる……！　あっ！？　こ、\nこんな風にはっきりわかるんだ、挿入の感覚……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1304124" ]},
		{"command":[ "SETIMAGE", "0", "still_00000213_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「へ……変な感じ……！　あなたの舌の濡れた感覚と、オチンチンの熱くて硬\nい、ゴツゴツした感触……！　同時に粘膜に襲いかかってくる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1304125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「なんて不思議な快楽……！　ふ、ぅ……ううう……。狂っちゃいそう……っ\n、だめぇ、こんな気持ちいいことしてる人なんか他にいない……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1304126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あっ、ぁっ、あっ、ぺちゃぺちゃ恥ずかしい音が聞こえて……あああっ。そ\nれなのにスケベなオチンチンがオマンコを満たしてて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1304127" ]},
		{"command":[ "SETIMAGE", "0", "still_00000213_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「こ、このままオチンチン動かして……！　っん～～～～～！　すごい……す\nごいっ……オマンコ、オマンコ全部気持ちいい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1304128" ]},
		{"command":[ "SETIMAGE", "0", "still_00000213_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「クリも、表面も……中も、奥っ……奥もぉおお……一度に全部気持ち良くて\n、……いやぁっ、いやっ。子宮口コツコツノックされてるのに……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1304129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ピストンされてる時にはクリトリスッ……クリを舐め転がされてて、……ふ\nぅううっ……。どんどん快楽に押し流されちゃう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1304130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あ……今、今オッパイもぐにぐにされたら、オマンコ、クリ、オッパイ三点\n攻め……！　いや……いや、全身がオマンコになったみたい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1304131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「うん、うんっ！　全身がオマンコ……！　どうしよう、体中全部、全部オマ\nンコで……そこをオチンポされてる、あはぁっ……あぁんっ、あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1304132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「全部があなたでいっぱいぃ……！　くふぅうう……！　汗がダラダラ流れる\n、愛液であなたがびちゃびちゃになっていく……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1304133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「イ……くぅ、イクぅ……ああああっ！　もうイッてるのに次々イッちゃう…\n…！　えっ？　あ、あなたも出そう？　精液出ちゃいそう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1304134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ま……待って！　今射精されたら、私達も激しく達しちゃう……っ！　あ…\n…だめ、今、中が、粘膜が熱くなってるから……今はダメ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1304135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んっう！？　んんっ……んんー……っ！　胸とあそこが気持ち良くて、あそ\nこは舌とオチンチン両方で攻められてて……ひぁああああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1304136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000213_02_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「こんなの、こんなの耐えられる人いない……！　忍者でも、忍でも忍べない\nっ……げ、限度がある……！　やっぁっあっ、果てる、果てる……ぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1304137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んーーーーーーーっ！！　んんーーーーっ、んんっ！　ひゅ、ひゅごいぃ…\n…！　赤ちゃんのお部屋にミルクが注ぎ込まれてくる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1304138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んんんん……！　違う、この術にハマったりはしてない……！　あっ、あな\nたに喜んでほしいからしただけ、イッてない、イッてなんか……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1304139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「っううううう……っ。あああああ……！　も、もう一人の私もイッてるの…\n…？　い、いやぁ……見ちゃだめ、見ちゃだめだから……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1304140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あぁああ……っ！　ふひゅううっ、ひゅううっ……ひゅー……ひゅー、ひゅ\nー……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1304201" ]},
		{"command":[ "SETIMAGE", "0", "still_00000213_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「呼吸、するの忘れるくらい気持ち良かった……。でも、快楽に流されすぎて\n……溺れちゃって、頭が真っ白になって……よくわからなかったから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1304202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「このまま、オチンチンを抜かないでもう一度しよう？　ね……？　もう一人\nの私だって、きっとそれを望んでる。そうだよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1304203" ]},
		{"command":[ "SETIMAGE", "0", "still_00000213_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「うん……。さっきのもう一回してほしい。私の全部、あなたのオチンチンで\nこすられて……天国に連れていかれたみたいだった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1304204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「いつものエッチより、夢中になっちゃってたから……。もう一回してくれる\nなら、今度はちゃんと記憶する。しよ……。してもいい……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1304205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「私達もオチンチンに尽くすから……３人でもみくちゃになって、全員で高め\n合いたい……。あなたも期待してるよね、まだまだ全然硬いまま」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1304206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「３人で精進してエッチに前向きに……。　はぁ、はぁ、またイヤらしいお汁\nがオマンコから溢れ出してきちゃった……ごめんね、あぁ、あぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1304207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あっ……！　お口で舐められてると、オチンチンも欲しくなる……。私も腰\nを揺らして上下させるね……あっ、こ、こうやって……あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1304208" ]},
		{"command":[ "SETIMAGE", "0", "still_00000213_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ホテルの外にまで聞こえちゃうくらい激しい水音がたってる……っ。あっ、\n交わって……赤ちゃん作ってる、本能が抑えきれない……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1304209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「赤ちゃん、赤ちゃん作るのが正しいってオマンコが言ってる……オチンチン\nも出来ちゃってもいいって言ってくれてる！　あぁっ、あっあっあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1304210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「クリスマスは、両想いの男女がラブホテルで赤ちゃん作る場所だよね……っ\n。だったら、だったら問題ない？　もっとして、もっと……もっと！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1304211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ん、くぅううっ……私の赤ちゃんのお部屋が震えてる……っ。パパとママは\nここって教えてくれてる……！　ああっ！　気持ちいい、気持ちいい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1304212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「股間っ……！　あなたのお顔に押し付けて、私……浅ましくてごめんなさい\nっ！　でも、いいの、あなたのお口気持ちいい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1304213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あなたのクンニがうますぎて……、あっ、あっ、ずちゅずちゅピストンされ\nるのも気持ちいい……身体がどんどん熱くなってく……ぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1304214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「うぁああっ……グチュグチュ、ぐちゅぐちゅ続けてぇ……。そのまま、その\nままがいい……！　いいの、良すぎるの、感じすぎて……あああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1304215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「オチンチンのことしか考えられなくなる……！　あんっ、あんっ、あんんっ\n……！　オチンチン、オチンチンすごい……おかしくなっちゃいそう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1304216" ]},
		{"command":[ "SETIMAGE", "0", "still_00000213_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「私も……っ、私もやめてほしくない！　オチンチンに突き上げられて、子宮\nが喜んでる……あっ、あぁ、感度が上がり続けて！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1304217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「すっごく大きな絶頂がそこまで来てるのがわかる！　これ……これ、逃した\nくない！　あと少し、もう少しだけ精液出さずに突いて……ああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1304218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「イっ……く……♪　あああ、イッちゃった……！　イクところ、見られちゃ\nった……だらしない顔見られたくないのに……はぁはぁはぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1304219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「もっとしたいのに、勝手にオマンコが締まっちゃう、キツくなっちゃう……\n！　あなたのオチンチン搾り取っちゃう、んふ、うう……うううっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1304220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「もう……もうだめ、だめええええっ……。イクっ……！　オマンコビクビク\n震えて……！　あああああああ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1304301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000213_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「うん、うん、そこ……そのまま……！　そこで出し続けてくれたら……子宮\nにドプドプ精液が入ってきて……あぁ、さっきよりもたくさん来てる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1304302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あ……あ、あ……！　あなたのマーキング、情熱的すぎて……オマンコが戸\n惑ってる、受け止めきれないくらいの量……。こんな量全部飲み干せない……\n」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000213_02_10" ]},
		{"command":[ "PLAYVOICE", "v2_002_1304303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あなたのいやらしいお汁が子宮に広がって……オマンコがいやらしい臭いに\n変わってく……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1304304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「っああああ……！　こっちはヘンな気分……オマンコは空なのに、精子が入\nってくる熱さまで伝わってきて……ク、クセになっちゃいそうで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1304305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「私のオマンコの中……また、あなたのでいっぱいにされちゃった……。こん\nなの、絶対妊娠してる……。ふふふ、嬉しい……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1304306" ]},
		{"command":[ "SETIMAGE", "0", "still_00000213_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あなたのものにされるのって、何よりも気持ち良くて……幸せ……。あぁ…\n…。で、でも……えへへ、どうなるんだろうね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1304307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「分身して、２人同時に絶頂して、イキながら受精しちゃったら……。元に戻\nった時、受精卵……双子になっちゃうかも。２人産まれちゃう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1304308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「私は……それでいいよ？　双子、産む……。あなたが出してくれた精液、少\nしも無駄にしないで一人でも多く産みたいから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1304309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ふふっ……これからも、こうして散多の術を使ったら……たくさん子どもが\n出来ちゃうのかな……？　それが、私からのプレゼントになるといいな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1304310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あ！　あっ、あ、ああああ……！　私達、胸も身体も……あなたの色に染ま\nっていく……。真っ白なお汁にまみれにされて、イッちゃう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1304401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000213_02_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「熱い……！　ベタベタ肌にくっついてくる……っ。あっ……ま、まだ出るの\n……？　二度目の射精なのに凄すぎる……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1304402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「なんて、なんて強い臭い……！　こんなの、皆にすぐわかっちゃう、私があ\nなたの女にされたこと……。今日はずっとシてたこと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1304403" ]},
		{"command":[ "SETIMAGE", "0", "still_00000213_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「嫉妬、されてヤキモチやかれちゃうかもしれない。はぁっ……。だってわか\nるもの、ザーメンミルクが凄すぎて……ニオイが絶対消えないと思う……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1304404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「２人分の精液の感覚……。肌に焼き付くみたいに精液の感触がはりついて、\n染みこんでくるみたい……。こんなの初めて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1304405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「で、でも……。こんなに盛り上がった後で言うのもなんだけど……。本当は\n中に出してほしかったかも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1304406" ]},
		{"command":[ "SETIMAGE", "0", "still_00000213_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「2人で感覚を共有してたから、降り注いでくる精液の量が2倍に感じられて\n……。酔ってうっとりして、そのまま受け入れちゃった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1304407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「肌に感じたあの熱さ、あの粘り気……。一番敏感な部分に欲しいって思うの\nは女の本能かも……。でも……かけられるのもいいし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1304408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「迷っちゃう……。あ。今度はあなたを２人に増やして、中と外に一度にかけ\nてもらうっていうのはどうかな？　そしたら……絶対に凄いはず」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1304409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「３人でも、４人でもいいよ……。あなた以外は絶対嫌だけど、あなただった\nら……どんな風になっても、受け止める……。ふふ、楽しみにしてるね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1304410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}