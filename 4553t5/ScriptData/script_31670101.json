{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016701_01_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「……主殿、こ、これで……んっ、いいのだろうか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0103101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「その……奉仕ということは聞いていたが、何分、どうしていいかよく分から\nなくて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0103102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「胸で……し、して欲しいということだったから……その、こんな形で……大\n丈夫なのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0103103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「気持ちいい……？　そ、そうか……オ、オチンポが埋もれると……気持ち、\nいいのだな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0103104" ]},
		{"command":[ "SETIMAGE", "0", "still_00016701_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「とにかく……んっ、してみよう。もし、至らない所があれば、何でも言って\nくれ……その、努力は……する……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0103105" ]},
		{"command":[ "SETIMAGE", "0", "still_00016701_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……こんな感じで……上下に動かすと……いいのだな？　確か、\nパイズリと……言うんだったな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0103106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んんっ、動かして行くぞ……はっ、ふっ、んくっ……あぁっ、な、中で跳ね\nて来るっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0103107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「待ってくれ、主殿……あまりオチンポを跳ねさせては……上手く出来なくな\nってしまう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「しっかり……包み込むようにすればいい、のか。わ、分かった。とにかく、\nなるべくじっとしていてくれ……んふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はぁっ、んっ、あっ……はっ、あぁ……何だか凄いな……胸で……私のおっ\nぱいの中で……ピクピクしている……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0103110" ]},
		{"command":[ "SETIMAGE", "0", "still_00016701_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「それに、すごく熱い……んっ、主殿の熱が……あぁ、全身に広がっていくよ\nうな感じだ……んふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0103111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「どうだろうか……んっ、もっと肌をくっつけて……擦ると、いいんだな……\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0103112" ]},
		{"command":[ "SETIMAGE", "0", "still_00016701_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「もちろんだ……それが命令ならば……私は言う通りにしてみせるぞ……んっ\n、はっ、んふっ、くっ……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はぁっ、んっ、あっ、はぁっ……あぁ……おっぱいが、熱い……んっ、オチ\nンポの熱で……どうにかなってしまいそうだ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「それに……んっ、この匂い……んんっ、オスの……逞しい匂いが……はぁぁ\n……広がってる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0103115" ]},
		{"command":[ "SETIMAGE", "0", "still_00016701_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あぁ……すんっ、すんっ……この匂いを嗅いでいるだけで……何だか心臓が\nドキドキして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あっ……！　オチンポがピクって……んっ、は、鼻息が掛かったのか？　済\nまない……その、私も興奮してしまってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「し、仕方ないんだ……その、こんなことは慣れてなくて……おっぱいの先も\n……んっ、ピンと立って……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0103118" ]},
		{"command":[ "SETIMAGE", "0", "still_00016701_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「分かってる。ちゃんと……するぞ……もっとしっかり、おっぱいを……オチ\nンポに……押し付ける……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はぁっ、んっ、はっ、あぁっ……凄い……こんな風に、皮がめくれるんだな\n……んっ、もう少し……滑りやすくさせると、いい……のか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「つまり……もう少し、湿り気を……分かった、では……ちょっとだけ失礼す\nる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んっ、れろ……れる、れりゅ……んんっ、れろっ、えろっ……れろっ、れろ\nぉぉぉぉぉっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0103122" ]},
		{"command":[ "SETIMAGE", "0", "still_00016701_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あぁぁ……な、舐めてしまった……！　主殿の……オチンポを、し、舌で…\n…舐めて……何というはしたないことを……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「な、何……？　それが、とても……いい……そ、そうなのか。私の舌で……\n主殿が、気持ちよくなってくれているのか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0103124" ]},
		{"command":[ "SETIMAGE", "0", "still_00016701_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「舐めながら……一緒にパイズリをしたら、もっと……感じる……なるほど…\n…うむ、やってみよう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「ぴちゃ……んちゅ、んっ、ふっ、んんっ……んりゅ……んっ、はっ、んふっ\n……んっ、んぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0103126" ]},
		{"command":[ "SETIMAGE", "0", "still_00016701_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「ど、どうだ？　オチンポの先をペロペロして……真ん中は、おっぱいで包ん\nで、ズリズリして……気持ちいいのか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んっ、はぁっ、あっ、またオチンポがビクって！　そうか……んっ、ふっ…\n…今のが気持ちいい証なのだな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「分かった、もっと私のおっぱいを感じてくれ……もっとしていくから……ん\nっ、ふっ、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0103129" ]},
		{"command":[ "SETIMAGE", "0", "still_00016701_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「大きくて……柔らかくて……さ、最高……なのか。んっ、このように……大\nきいだけのモノ……邪魔で仕方ないと思っていたが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「もし、主殿に喜んで貰えるのなら、巨乳というのも悪くないのかも知れない\nな……あっ、あぁっ……んっ、また跳ねて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「これは、もしかして……で、出そうなのか？　私にも分かるぞ……射精した\nいんだな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0103132" ]},
		{"command":[ "SETIMAGE", "0", "still_00016701_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「いいぞ……主殿……どうか、私のいやらしいメスおっぱいのパイズリで……\nたっぷり射精してくれっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あぁ……このまま、私のおっぱいの中に……濃い……子種を思いっきり出し\nてっ……んっ、はっ、はぁっ、あぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あぁっ、ひくひくしてるっ……オチンポが出たがってるっ、早くっ……あっ\n、あぁぁーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0103135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んんっ！　あぁっ、出たっ……精液っ……射精してるっ、私の……おっぱい\nの中にっ……熱いのが出てるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0103136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016701_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あぁ……凄い、ドロッとしたのがこんなに……あったかい……んっ、主殿の\n匂いが広がっていく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0103137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……んっ、ふっ……よかった……私のおっぱいが射精の役に立て\nたんだな……あぁ、ちゅぷ……んっ、濃いな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あぁ……やっと、止まった。おっぱいの中が……ヌルヌルして……はぁ……\n凄いことになっている……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0103139" ]},
		{"command":[ "SETIMAGE", "0", "still_00016701_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んふ……気持ちよかったのか……あぁ……私もだ……何だか、まだ身体が少\nしふわふわしたような……不思議な気持ちになっている……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あ……？　ど、どうした……のだ？　また、オチンポが……あっ、中で……\n膨らんで……んっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0103201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「も、もしかして……これは、一度では満足しきれていないと、そういうこと\n……なのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「誤魔化すことはない。そうなんだな、主殿……分かった、私が責任を持って\n、出し切れていない精液も射精させよう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0103203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「多少だが、パイズリの心得も出来てきた……もっと、私のはしたないおっぱ\nいを感じて欲しい……んっ、ふっ、はぁっ、んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0103204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あぁ……んくっ、さっきの精液が滑って……あっ、ヌルヌルする……何だこ\nれは……前と、違う……んぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はぁっ、んっ、あぁっ、おっぱいの中で……オチンポが擦れてぇっ、あぁっ\n、感じてっ……しまうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0103206" ]},
		{"command":[ "SETIMAGE", "0", "still_00016701_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はっ、んんっ、それにっ……ぐじゅぐじゅってっ……い、いやらしい音ぉっ\n……してぇっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「おっ、おっぱいマンコ……？　あぁっ、わ、私の……おっぱいが……オ、オ\nマンコにさせられてしまったのか……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あっ、はっ、んんっ！　主殿っ、あっ、そんなにオチンポを激しくされたら\nっ、はっ、ひっ、あっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あぁっ、き、気持ちいいっ！　あぁっ、オチンポに犯されてっ、私のおっぱ\nいマンコが感じるっ、気持ちよくなってるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0103210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はぁっ、んっ、ダメだっ……されるばかりではっ、私もっ、あっ、ちゃんと\n……オチンポにご奉仕をしないとっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「また……先端を舐めてっ、んんっ、えろっ、れるっ、れろっ、れりゅっ、ん\nれるっ、れろっ、んれろぉぉおっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0103212" ]},
		{"command":[ "SETIMAGE", "0", "still_00016701_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あぁ……ちゅぷっ、精液の味がする……はぁっ、もっと……いやらしい気持\nちになってしまうっ……パイズリ……んっ、止まらないっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「ふっ、はっ、うんっ……んんっ、どうだ？　あぁっ、ちゃんと私のパイズリ\n……出来ているだろうかっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0103214" ]},
		{"command":[ "SETIMAGE", "0", "still_00016701_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はぁっ、んんっ、あぁっ、あぁっ……私も気持ちいいっ……あぁっ、おっぱ\nいマンコ……気持ちいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0103215" ]},
		{"command":[ "SETIMAGE", "0", "still_00016701_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「ちゅぷっ、んちゅっ、れろっ……あっ、はぁっ、先走りの味がするっ……は\nぁっ、我慢できなくなってるの……分かるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0103216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はぁっ、んんっ、主殿のオチンポっ、あぁっ、またおっぱいの中でビクビク\nして、膨らんでっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「分かるぞっ……んっ、これ……また、射精しそうになっているの……オチン\nポの先が、膨らんでるっ……また射精したがってるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0103218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「大丈夫だっ……私の方は……んんっ、いつでもっ、いいからっ、主殿っ……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「……出してくれっ、りゅぷっ、んんっ！　はぁっ、好きなようにっ……溜ま\nった精液っ、びゅくびゅくっ、射精してくれぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んぁぁぁっ！　またっ……あぁっ……おっぱいマンコに……中出しぃ……！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0103301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016701_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あぁぁ……熱い……んっ、二回目なのに……こんなに出るのか……あぁ……\n溢れて……止まらない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んんっ、主殿の匂いだ……んんんっ、すぅぅ……んふっ……まだ、出る……\nあぁ……止まらない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0103303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……はぁ……んっ、はぁ……はぁ……やっと……落ち着いた…\n…のか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0103304" ]},
		{"command":[ "SETIMAGE", "0", "still_00016701_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んふぅ……ど、どうだっただろうか……？　私のおっぱい……満足して、貰\nえただろうか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0103305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「そ、そうか！　ちゃんと……気持ちよくなってくれたか……そ、それならよ\nかった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0103306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「その、もし……よければ……いつでも、私のおっぱいを使ってくれて……い\nいからな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0103307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「私も、その……き、気持ちよかったし……精液の風味も……思ったより中々\n……あ、いやっ、な、何を言ってるんだ私は……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0103308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「と、とにかく……！　もし、その……またパイズリを求めるならば……いつ\nでも言ってくれ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0103309" ]},
		{"command":[ "SETIMAGE", "0", "still_00016701_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「今度はもっと上手く出来るように、私も鍛錬しておく……え？　ど、どんな\n鍛錬かはいいだろうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んぁぷっ！　あぁっ……顔に……熱いのがっ……はぁっ、んんんんっ……！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0103401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016701_01_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あぁ……ちゅぷ、んっ、れる……れろ……主殿の精液……チンポミルク……\nザーメン……ドロっとした、濃い味だ……ちゅぷぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はぁぁ……それに、この濃密な匂い……んっ、私の中の女が……メスが屈服\nしてしまう……オチンポの匂いに逆らえなくなってしまう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0103403" ]},
		{"command":[ "SETIMAGE", "0", "still_00016701_01_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「ああ……だけど、これが……奉仕の幸せ……主殿に喜んで貰えて……私も気\n持ちよくなって……はふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0103404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁっ……んっ、もう少しで落ち着くのか？　んっ、私は構わない…\n…最後の一滴まで……顔にぶっ掛けて欲しい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0103405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……これで、最後……か？　んふぅ……あぁ……いっぱい出した\nな、主殿……はぁ……顔が精液まみれだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0103406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んふ……まだオチンポの先が少し震えている……あぁ……確か、こういう時\nは後始末をするのだったな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0103407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「ぴちゃ、れろ……んっ、ちゅぷ……んっ、これで、どうだろうか……綺麗に\nなったぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0103408" ]},
		{"command":[ "SETIMAGE", "0", "still_00016701_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はぁ……んふぅ……んふ……気持ちよかったのなら何よりだ……私のふしだ\nらな巨乳でも、ちゃんと主殿の役に立てるのだな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0103409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「それにしても、この感じ……癖になってしまいそうな……い、いや、何でも\nない！　気にしないでくれっ、主殿」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0103410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
