{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024501_01_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「……んん……だめ、眠たくなってきた……。やっとこれから……おにいちゃ\nんに……隊長さんに会えるのに……寝ちゃいそう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0103101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「来てくれるまで、すこしだけ……ほんの少しだけ、目をつぶっててもいいか\nな……？　お布団で寝てたら、気付いてくれるよね。……ん～……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0103102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「むにゃ……むにゃ……。エスティマおねえ、ちゃん……隊長おにいちゃん…\n…。ふたりとも、だーいすき……むにゅむにゅむにゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0103103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「はやく……きて、おにい、ちゃん……。じゃないとルナ……。わたし、ほん\nとに熟睡しちゃうよー……。すぅ……。すぅ、すう……すぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0103104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「ふぁ……。ン……。ん……んん……。なんか……へんなにおいがする……？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0103105" ]},
		{"command":[ "SETIMAGE", "0", "still_00024501_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「あ、む……んん……？　んむぅ……むぅ……。やぁ……この匂い……。んー\n……じゃま……。どけて……。んん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0103106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「……すぅ……。くぅ……、ふぅ……ふぅ、ふぅ……。くぅう……。んー……\n、んん……んぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0103107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「ふ、む？　おくちに何か……ぴとぴと、ぴたぴたくっついてくる……。ちょ\nっと湿った、ぷにっとした……。なに……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「わたし、ねむいの……。あったかいのなすりつけてこないでぇ……。ぴたぴ\nた……ぷにゅぷにゅされると困るぅ……。ひっこめてぇ……んー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「……もしかして……キャン、デー？　あったかい……飴みたいな……ソフト\nクリームみたいな……？　そっか、これ……夢のお菓子なんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「だったら……食べてもいいかなぁ。舐めてもいいんだよ、ね……？　ん、れ\nろ……れろ、れろ……。あれ、舌が届かない……待て待てぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0103111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「ちゅぱ、ぺろ……ぺろ、ぺろ……。ンン……。……れろ……。なぁに、これ\n……なんか、お口がもぐもぐする……もごもごして……。待って」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0103112" ]},
		{"command":[ "SETIMAGE", "0", "still_00024501_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「にげないで……。上手に食べられないでしょお……。……っれるっ……ぴち\nゃ……ぺろっ、ちゅく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「あむっ……はむ……ちゅる、ちゅるる……。くぷ……くちゅ、ちゅぅ……ち\nゅ……。んん～……？　ヌルヌルしたお汁が出てきたぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「飴ちゃん、溶けてきた……？　ちゅぱ……ちゅぱ……。あふ……。ねっとり\nしたお汁で、おくちのまわりがベトベト……。ぅ……ちゅぷ、ぷっちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0103115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「なぁんだろ……？　これ……なあに……？　あったかくて、ちょっと硬い…\n…。プルプルしてて……なんか、太い……舐めにくい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0103116" ]},
		{"command":[ "SETIMAGE", "0", "still_00024501_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「これ……おいしいのかなぁ？　キャンディ……。もっと舐めないと、甘くな\nらないのかなぁ……？　れろ……れろ、んん……ぴちゃ、ぴちゃぴちゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「ちろ……ちろ、ちゅく……。くちゅ、ちゅ、ちゅ……。おっきすぎて、息…\n…しにくい……。こんなサイズの飴……初めて……ぴちゃ、ぴちゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「まだるっこしい……。一気に、舐めないと……。んむー……。　……ん！？\n　んぷぇ……！　すっごく長くて……喉の奥に突き刺さって……あぷ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「なに……？　にゃに？　くるひぃ……くるひぃ……！　あぷ……うぷ、くち\nゅ……無理……こんなサイズ舐められにゃい、大きすぎりゅ……。んぷ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0103120" ]},
		{"command":[ "SETIMAGE", "0", "still_00024501_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「なんでこんなにキャンディ……くるしいの……。ん……っ、くちゅ……ちゅ\n、あ……れ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「隊長おにいちゃんのにおいがする……？　んぅ……？　なんで……？　おに\nいちゃんの匂い……。もしかして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「……んむ……？　おにいひゃん……？　おにいひゃん、来てくれたんだ。今\nね、わたひ……すごく長いキャンディぺろぺろしてて……。」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「……んむ！？　ちゅぽっ……！　あ、れ……？　キャンディまた逃げた……。\nこれ、隊長お兄ちゃんの……あなたのキャンディだったの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0103124" ]},
		{"command":[ "SETIMAGE", "0", "still_00024501_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「だって、お兄ちゃんの匂いするし……？　うん？　深く考えなくていいから\nもっと舐めてって？　いいよ。元々そのつもりだよ……いただきます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「ぱく。……んッ……あれ？　またおっきくなっれる……。くちゅ、くちゅ…\n…それに、ビーンって上をむいてて……舐め、にくい、よ……ちゅっ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024501_01_04" ]},
		{"command":[ "PLAYVOICE", "v2_245_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「もっと、わたひのお口の中にちゃんと入れれぇ……？　……んぷ……。んく\n、くちゅ……くちゅっ、ちゅ……。ん、それくらいの角度でいい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「ちゅぷ……ちゅぷ、くちゅっ。くちゅ……くちゅ、あぷ……。れろ……れろ\n、れろ……。んぅ……。今、ビクッてなったみたい……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0103128" ]},
		{"command":[ "SETIMAGE", "0", "still_00024501_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「もっと、首をかしげたり……角度を変えて舐めるの？　わかった……。そう\nだよね、色んな部分を舐めないと……お汁が垂れちゃう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「ぴちゃ……。もっと舌を動かしれ……。れろれろして……。れる、れる、れ\nる……にちゅっ！　くちゅっ、ちゅぷっ……はむ……。っんん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「おにいひゃん……？　この飴ぜんぜんなくならないし、ちっちゃくなんなひ\nぃ……。れろぉ……れろ、顎がちゅかれてきたぁ……れろっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「ちゅっぷっ、ちゅっぷっくちゅっ……ちゅっ、ちゅ……。はむ、あむ、むぅ\n、むん……！　ぴちゃっ、ぴちゃ、ちゅぱっ、ちゅぷ、くっちゅっにゅる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「はぁっ……んん……。んむ！　あんまりぐいぐい突っ込まないれぇ……息で\nきないよぉ……。っちゅぷ……ちゅぷ、くぷっ、くぷ……くぷぷぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「は、ぁ……っ。あむ……んむ……っ。ぴちゃ……ぴちゃ、ちゅぷ……くちゅ\n、ちゅぅ……ちゅ……。はぁ、はぁ、はぁ……。んちゅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「顎がちゅかれる……ぅ、れも……。あなたが喜んでくれるなら……。れろ…\n…れろ、ちゅ……っ。ぺろ……ぺろ、くちゅ……ちゅ、ちゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0103135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「んぷ……！　あっ……んぁ……！　だからお口に深く入れたらくるひぃよお\n……！　ん！？　んっ……ん、んん！？　んむっ、入ってくるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0103136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「んぁぷぅううっ！？　んぷ！？　んんんん！？　んん！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0103137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024501_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「んーっ！？　んーっ、んーっ……！？　ンン！？　にゃにぃ？　なんか、熱\nいのがビュビュッて飛び出た……！　けほっ、けほ……！　えふっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「喉っ……喉の奥っ……お口にはりついて……！　んっ！　待っれ、まだ出て\nる……！　あれっ……と、止まらにゃい、あっ、出れる……ぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「んーっ！　んーっ、んんんん～～～～！　んぐぅっ！　め、目が覚めひゃ…\n…！　な、なんれ？　なんれわたひ……おちんちんを咥えてりゅの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「けほっ……！　あ……ぁ……。お、おにいひゃん……？　おにいひゃんがわ\nたひの口におちんちん、入れてたの……？　これ……このお汁、なに……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0103201" ]},
		{"command":[ "SETIMAGE", "0", "still_00024501_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「せいし……？　赤ちゃんを作るお汁？　おちんちんから出るお汁？　……ん\nっ。これ、ぺってしちゃダメなんれしょ？　飲む？　飲むの？　う、うん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「飲む……せいし飲む……。あふ……。ごくっ……。ごく……。うまく飲めに\nゃい……。口の中に残っひゃう……ごくっ……。まだある……ごくっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0103203" ]},
		{"command":[ "SETIMAGE", "0", "still_00024501_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「ぷぁ……。の、飲んだよ……。でも、な、なんで起こしてくれなかったの…\n…？　私の寝顔を見てたらムラムラしていたずらしたくなった……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0103204" ]},
		{"command":[ "SETIMAGE", "0", "still_00024501_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「んぅ……。いたずら……してもいいけど、おちんちんを口に入れて、いきな\nり精子を出したりしちゃだめだよぉ。……っぅ、まだお口の中苦いもん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「ぜんぶ飲みきれてなくて……ヌトヌトする……。んっ……。え？　そのまま\nもう一度くわえて？　お……おちんちんを？　んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「ぱく……。こ、こう……？　んぅ……。おちんちんもネトネトしてるよぉ…\n…。そのニュルニュルで、刺激するの？　えっと……えっと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0103207" ]},
		{"command":[ "SETIMAGE", "0", "still_00024501_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「ん……ん、ん、ん……？　こ、こぉ……？　んっ……ん……。目を閉じて集\n中して……くぷぷっ！　ちゅくっ、ちゅぽ……くちゅ、ちゅ、ちゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「あぅう……苦い味がひゅるぅ……。ネトネトしたお汁がたくさん……。ぺち\nゃ……ぺちゃ……んん……んふ……っ。え？　もっと激しく……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「わ、わかったぁ……。んちゅる……ちゅる、ぢゅる……じゅる、じゅるるっ\n……！　くぷ、くぷ、くちゅ……ぐちゅ、ンッ……んんん……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0103210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「はむ……っ。あ、あのね……？　ぺろぺろするのは本当にいいんだよ？　い\nいんだけど……おちんちんがおっきすぎて、難しいの……。くちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0103211" ]},
		{"command":[ "SETIMAGE", "0", "still_00024501_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「あんまりたくさん動かされると……ぬるんって抜けちゃいそうになるから、\nわたしにまかせてくれる……？　んっ、んむ、むぅっ、むうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「少しずつ……少しずつ上手になるから、わたし……あなたがハァハァして、\n興奮するの嬉しいから……。はむ、たくさん吸ってレロレロするからぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「気持ちをこめておしゃぶりするからじっとしてて……。ん、ぺろっ……れろ\n、れろ、れろ……んちゅぅ……ちゅる、ちゅっ、ちゅぅうう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0103214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「くっぷっ、くっちゅっぐっちゅっぐちゅ……。ぺちゃ……ぴちゃ、ちゅぱ…\n……ちゅぷ……っ。おしゃぶりを咥えるみたいに？　わかった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0103215" ]},
		{"command":[ "SETIMAGE", "0", "still_00024501_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「はむぅっ……！　ぐっちゅっ、ぐちゅっぷちゅ……！　はふっ、はふ……っ\n！　ちゅぷっ……ぢゅっぷっぢゅっぷっ、じゅぷ、じゅぷぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0103216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「ベロを絡ませて……れろぉ、れろれろれろ……！　はぁっ……気持ちいい？\n　吸うのがいいの？　……ぴちゃ……ちゅぅ、ちゅぅう……ちゅぅ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「あう……。また、おちんちんから苦いお汁が出そうなの……？　うん……、\n気にしないで出していいよ……。今度はひゃんと起きてるからぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0103218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「お口にびゅーって、びゅーってひて……♪　ここ……ここだよぉ、わたしの\nおくち……。ここにお汁をびゅるびゅるーって出して……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「たくさんお汁が出るように……いっぱい吸い出すね。っちゅっ……ちゅぅう\nうう……♪　ちゅる……！　ちゅぷぷぷ、ちゅぅううう～～～っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「んふぁっ……んぷぅ……！　はぷっ……！　んっ……んんん……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0103301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024501_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「今度はちゃんと飲めるよ……。んく……んく、んく……っ。どんどん飲むか\nら、どれだけ出しても平気だよ……。……こくっ……こく、こくん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「んむ……。お口に残った分は……舌で舐め取って……。っごくっ……！　ね\n？　飲めたでしょ？　えらい？　褒めて褒めて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0103303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「ふふ……ふふふふ♪　ん？　お汁を飲むのはいつも大変だよ？　でも……わ\nたしは、おべんきょうが得意だから……二回目は一回目より上手にできるの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0103304" ]},
		{"command":[ "SETIMAGE", "0", "still_00024501_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「もちろん三回目はもーっと……。そしたらあなたは、もうわたしから離れら\nれないかもね。って……、わ……。まだお口の端についてたみたい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0103305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「ぺろ……ちゅる。ごくっ……ん～……やっぱり、苦くてヌロッとしてる……\n。でも、すぐに慣れると思うから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0103306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「今度からは……わたしが起きてる時に頼んでほしいな。あのね、あなたのだ\nったら……いつでもできるから……。……んっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0103307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「無防備に寝ているわたしだから良かったの？　それって、ちょっとあぶない\n趣味だし……寝る時どきどき、そわそわしちゃうから……　たまーに、にして……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0103308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「ん……たまにだったら、いいから。えっ？　脱がしたり、パンツの中におち\nんちんを入れたりするのはだめだよ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「もぉ……！　放っておいたらどこまでもエスカレートしそう……。そうなら\nないように、今夜からは……一緒に寝て、見張っておかないとだよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「ぷぁ、んっ……うっ！　んんぁっ……！　あっ……！　お汁が……お汁がび\nゅぶびゅぶって……お空を飛んでるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0103401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024501_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「あうっ……んぅ！　お顔……お顔にお汁がかかってる……。これでいいの？\n　あなたはこうしたかったの……っ？　ふぁ……あああ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「熱くてヌルヌルしたのが、こんなに……。んぷ……。やぁ……、お口にも入\nってくる……。んっ、んっ……すごい、シャワーみたい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0103403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「おちんちんが目の前でびっくんびっくんしてて……すごすぎるよぉ……！　\nあっ……こんな、こんなに近くで見せつけられて……。うぅ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0103404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「……あぁ、顔……赤くなってきちゃった……。だって、だって……あなたの\nお汁が、おにいちゃんのお汁がわたしにかかってるなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0103405" ]},
		{"command":[ "SETIMAGE", "0", "still_00024501_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「それって、良く考えたらえっちすぎて……。……ぁ……。なに……？　この\nお汁、少しずつ乾いて……なんかはりついてくる……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0103406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「ん……顔がカピカピしてうまく目が開けられない……。にがにがの精子がこ\nってり頭に……顔に、目にひっかかってて……目が開かないよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0103407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「すごく強いノリみたいにベタベタしてる……。精子って、濃かったりネバネ\nバしてる方が良い精子なの？　うん……そうなんだ。色も大事で……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0103408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「じゃあ、今回はとっても良いのが出たってことだよね。もしそうだったら、\nすごく嬉しい……。わたしのぺろぺろ、上手だった？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0103409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「そしたら……なでなでして、ぎゅーしていっぱい褒めて欲しい！　あっ、お\n顔と髪を洗ってからだよ？　じゃないとベタベタついちゃうからね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0103410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
