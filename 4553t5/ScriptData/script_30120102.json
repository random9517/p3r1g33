{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001201_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "PLAYVOICE", "012_0104101" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「わ、すごぉい、オチンチンもうバキバキに固くなってるよ？　お尻に挟まれ\nるの気持ちいいんだ？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "012_0104102" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「んもー、けーびいんさんはあいからわずＨなんだから……もちろん、わたし\nもＨなことは大好きだけどね♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "012_0104103" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「だって、けーびいんさんにたくさんＨなことされて……イヤらしいことをい\n～っぱい仕込まれちゃったから……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "012_0104104" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「無垢な女の子をこんなにＨにしちゃった責任は、ちゃ～んととってもらうか\nらね？　覚悟をしておくよーに」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "012_0104105" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「そのかわり、わたしがけーびいんさんのオチンチンを気持ちよくしてあげる\nから。ほら、うりうり～！　どう？　わたしのお尻、気持ちいいでしょー？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "012_0104106" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「えー？　もう、デカ尻じゃないよぉ。たくさん運動してるから、ちゃんと引\nき締まってるでしょ？　ほれほれ～！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "012_0104107" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「お尻の間でオチンチンを挟みながら、上下にごしごししたら……ほら、オチ\nンチンビクビクしてる。気持ちいいんでしょ？　素直になりなよ～」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "012_0104108" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「わたしもお尻でオチンチンを擦るとね、んっ、根本のところがオマンコとか\n、敏感な部分を擦るから、んぁっ、気持ちよくなってきちゃうんだぁ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "012_0104109" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「オマンコにオチンチンが擦れる度に、お腹の奥がキュンキュンして、んっ、\nんあっ、オマンコが熱くなって、濡れてきちゃう……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "012_0104110" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「けーびいんさんのオチンチン欲しいよぉ……もう挿れてもいいよね？　ダメ\nって言ってもしちゃうからね。えへへ、ドキドキするなぁ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "012_0104111" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「んあぁっ、あっ、あっ、ビンビンのオチンチンが、わたしのオマンコのナカ\nに、ずぷずぷ……んふぅぅっ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001201_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "012_0104112" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「カチコチに固くなった亀頭がオマンコのお肉をぬぷぬぷかき分けて、んあぁ\nっ、どんどん入ってくるよぉ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "012_0104113" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「あぁっ、オチンチン大っきい……んふぅっ、固くて、熱くて、んぅぅっ、ず\nりずり擦れながら、奥まではいってくるぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "012_0104114" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「あんっ！？　あっあっ、奥にコツンて先っぽが当たって……あぁっ……オチ\nンチン、根本まではいっちゃった……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001201_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "012_0104115" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「んふぅっ、オマンコの中がオチンチンでいっぱいになってるよぉ……熱くて\n、お腹の中がじんじんする……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "012_0104116" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「じゃあ、今度は動くからね……んあぁっ、腰を上げてゆっくりオチンチンを\n引き抜いていくよぉ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "012_0104117" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「あぁっ、あっあっ、抜ける時に、オチンチンの出っ張りがオマンコのナカを\nぷりぷり引っ掻いて、あふぅっ、オチンチン凸凹多すぎるよぉ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001201_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "012_0104118" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「んふぅっ、あぁっ、ヤだぁっ……オチンチンが、わたしのＨなお汁でベタベ\nタになっちゃってるぅ……うぅ、恥ずかしい……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "012_0104119" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「また腰を下ろして、オチンチンをナカに挿れてくよ……んあぁっ、やっぱり\nオチンチン太いっ、おっきな亀頭がオマンコをかき分けて入ってくるぅ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "012_0104120" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「んあぁっ、どんどん動いていくからね……あぁんっ、腰を上下に往復させて\n、んあぁっ、オチンチンをオマンコに出し入れしていくよ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "012_0104121" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「ほかにも、前後に動かしたり……んあぁっ、すごい擦れるっ……ぐりぐりっ\n回すと……あぁんっ、オチンチンがオマンコのナカかき回してるぅ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "012_0104122" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「あぁっ、んあぁっ、オチンチン気持ちいいよぉ、んあぁっ、あっあっ、腰が\nしびれて、うまく動けなくなっちゃう……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "012_0104123" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「あひぃっ！？　下からずんずん突き上げられたらぁっ、んあぁっ、あぁんっ\n！　深すぎるぅっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001201_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "012_0104124" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「オマンコの奥の、子宮のところを、あぁんっ！　あひぃっ！　オチンチンが\nズコズコしてるぅっ！　あひぃんっ！　お腹に響いちゃうぅっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "012_0104125" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「ぐちゅぐちゅイヤらしい音が鳴ってるよぉ、あぁんっ！　エッチな声もいっ\nぱいでちゃうぅっ！　あっあっあっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "012_0104126" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「カチカチのオチンポで中をいっぱいズリズリ擦られて、あぁんっ！　奥もず\nんずんされたら、オマンコ熱いよぉっ、頭が変になっちゃうぅっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "012_0104127" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「んあぁぁっ！　おっきいのキちゃうっ！　あっあっあっ、あひぃっ！　イっ\nちゃうっ、オマンコずぽずぽされて、イっちゃうよぉっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "012_0104128" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「あっあっ、あっ！？　けーびいんさんのオチンポも、おっきくなってきた！　\nぱつんぱつんになって、オマンコいっぱい擦ってるぅっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "012_0104129" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「奥のお部屋、そんなにどちゅどちゅされたらぁっ！　あっあっあひぃんっ！\n　オマンコがキュンキュンしちゃうよぉっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "012_0104130" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「もうダメっ、イッちゃうっ！、オチンポもイって、精液どぴゅどぴゅっ、オ\nマンコに出してぇっ！　あっあっ、イくっ、オマンコ、イくううぅっ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "012_0104131" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「んぁああああっ！　あちゅいっ！　オマンコの奥にびゅっびゅっ！　せーえ\nき出てるっ！　オチンポしゃせーしてるぅっ！」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001201_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "012_0104132" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「子宮の入り口にどぴゅどぴゅ当たってるぅ、あっあっあっ、気持ちいいっ、\n中出し気持ちいいよぉっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "012_0104133" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「オチンポがびくんびくんって跳ねると、あぁんっ、あっつい精液がびゅるび\nゅる飛び出してくるぅっ、あっあっあっ、またイっちゃう、イくぅっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "012_0104134" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「精液いっぱい、どぷどぷオマンコに注ぎ込まれて、んあぁっ……もう入り切\nらないよぉ、入り口からあふれてきちゃうぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "012_0104135" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁっ……Ｈすごいよぉ、気持ちよすぎるぅっ……こんなの、クセに\nなっちゃうぅっ、ハマっちゃいそうだよぉ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "012_0104136" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「オチンチンまだ固い……ねぇ、もう一回しよう？　オマンコぐるぐるかき回\nして、またどぷどぷ中出ししてぇ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001201_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "012_0104137" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「あぁ、わたしもう……けーびいんさんのオチンポなしに、生きられない身体\nにされちゃったぁ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "012_0104138" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「だって、けいびいんさんに身体の隅々までＨな開発をされて……もうすっか\nりＨな女の子になっちゃったんだもん……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "012_0104139" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「それに、こんなにたっぷり中出ししたんだから、きっと妊娠しちゃってるよ\n？　男の子かな、女の子かな？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "012_0104140" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「わたしをこんなふうにした責任は、ちゃ～んととってもらうんだから……覚\n悟してよね、だーりん？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}