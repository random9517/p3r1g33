		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「あらあらー。そういう日もあるわよねー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010115160003" ]},
		{"command":[ "SETCHARA", "0", "char_00021201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ええい、お前の推理に従って一点掛けしたからだろうが！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115160001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「というか、店に入るなり紅茶を淹れさせろと言い出すし、注ぎ方も変だし！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115160002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「高い位置から湯を注いでいるが……なにか意味があるのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090115160001" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「これは、鳳雛のシンキングポーズである。こうすると、なにかを閃くのだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115160002" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「なにかってなんだ！　どうせロクでもないことだろう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115160003" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「落ち着けルナテミス。ところで、Ｍ．Ａ．Ｍ．Ａはなにをしているんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090115160002" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「空の段ボール箱が溜まってきたから、お片付けよー」", "NORMAL" ]},
