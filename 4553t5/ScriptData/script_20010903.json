{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0027" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_007" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "カツマの目の前でトタンとブリキ２との激闘が行われていた。", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「ほらほらほらー！　もっともっと踊ってよ。私を楽しませてよー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_010021180001" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00012101_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「くっ、いなしてもいなしても、すぐに次の攻撃がくる。なんて手数……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_010021180001" ]},
		{"command":[ "SETCHARA", "0", "char_00011701_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なあ、大丈夫なのか？　押されているように見えるが……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ふむ。相性はあまり良くないのかも知れませんな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021180001" ]},
		{"command":[ "SETCHARA", "0", "char_00000901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ブリキ２はカウンターの強烈な一撃をたたき込む型。しかし、その隙がなけ\nればただ受け続けるだけ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021180002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「それと……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「トタン……大丈夫か……。よし、いいぞ。そこだ！　くっ、だめか。いや、\nまだまだ。もう一度だ、よし、よしよし！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_010021180001" ]},
		{"command":[ "SETCHARA", "0", "char_00012001_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あのクラッドってやつ、さっきから一人応援してるだけだが！？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「微笑ましいですなぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021180003" ]},
		{"command":[ "SETCHARA", "0", "char_00000901_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「偉そうにしているけど、やっぱりポンコツなんじゃないか？　うちの誰かさ\nんみたいに」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「ほらっ、隙でーきたっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_010021180002" ]},
		{"command":[ "SETCHARA", "0", "char_00012101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「きゃぁあああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_010021180002" ]},
		{"command":[ "SETCHARA", "0", "char_00011701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ああっ、我々が目を離している隙になんだかとんでもないことに！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021180004" ]},
		{"command":[ "SETCHARA", "0", "char_00000901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「く……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_010021180001" ]},
		{"command":[ "SETCHARA", "0", "char_00011401_01", "1", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "1", "char_00011501_01", "1", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「うう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_010021180001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おいおい、変身が解けてるじゃねーか！　大丈夫かよ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「お待ちください。伝説の戦士はこれくらいでは折れません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021180005" ]},
		{"command":[ "SETCHARA", "0", "char_00000901_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いやお前、あいつらの何を知ってるんだよ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「相変わらず、小細工の通用しない相手だ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_010021180002" ]},
		{"command":[ "SETCHARA", "0", "char_00011401_01", "1", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "1", "char_00011501_01", "1", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「パワー一辺倒の戦い方で、まるで誰かさんのようですわね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_010021180002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「へへ、言ってろ。パワー勝負ってことはアタシの出番だな。いいよな、葉金\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_010021180003" ]},
		{"command":[ "SETCHARA", "0", "char_00011401_01", "6", "CENTER", "-400" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「もちろんです。この身体、鈴にあずけますわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_010021180003" ]},
		{"command":[ "SETCHARA", "1", "char_00011501_01", "6", "CENTER", "400" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんだ？　また変身するのか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「真空蒸着！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_010021180004" ]},
		{"command":[ "SETCHARA", "0", "char_00011401_01", "7", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "1", "char_00011501_01", "7", "CENTER", "400" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「アマルガメーション！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_010021180004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "bg_0027" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "カツマの目の前で、二人がまた変身した。しかし、その姿はブリキ２ではない\n。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETCHARA", "0", "char_00011601_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「電光石火、無双の型！　雷撃のアマルガム、ブリキ１ッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_010021180001" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「赤くなった！？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「技に秀でたブリキ２に対して、力に特化したブリキ１。これならトタンと十\n分に渡り合えますな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021180006" ]},
		{"command":[ "SETCHARA", "0", "char_00000901_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「しらねーよ！　てか、さっきからなんでそんなに詳しいんだよ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ニチアサのチェックは紳士の嗜みにございますよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021180007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「ふふっ。今度はブリキ１が遊んでくれるのね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_010021180003" ]},
		{"command":[ "SETCHARA", "0", "char_00012101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「ああ、かかって来いよ。板金屋から一生出られなくしてやる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_010021180002" ]},
		{"command":[ "SETCHARA", "0", "char_00011601_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "bg_0005" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
		{"command":[ "SETTEXT", "同時刻、大使館前", "NORMAL" ]},
