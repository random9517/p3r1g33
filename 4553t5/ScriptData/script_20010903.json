		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「人の子よ……私を中へ入れてください……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_010021180001" ]},
		{"command":[ "SETCHARA", "0", "char_00011901_01", "1", "CENTER", "0" ]},
