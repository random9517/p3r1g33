		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "警備員" ]},
		{"command":[ "SETTEXT", "「失礼ですが、どこに所属している方ですか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「しょ、所属？　えっと、神様だから所属とかそういうのは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_010021180002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "警備員" ]},
		{"command":[ "SETTEXT", "「申し訳ありません、素性のわからない方を中に入れるわけにはいきません」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「ええっ。か、神様なんですけど。鋳物の仕事をしているんですけど！？」", "NORMAL" ]},
