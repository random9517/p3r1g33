{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003002_01_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「ええと……このような格好でいいの……でしょうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0203101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「私自身の姿勢には特に問題はありません……とにかく、貴方に対してのねぎ\nらいを、どのような形で行えばいいか……それを教えて頂ければ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0203102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「つまり、乳房を露出して……貴方の陰茎を……擦って……射精に導けばいい\n……そういうことですよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0203103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「え……違う？　何か違うことがありましたか……あ……言い方……ですか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0203104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「乳房がおっぱい……陰茎が……オチ○ポ……はい、擦るはシコシコする……\n射精が……ドピュッ……なるほど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0203105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「それで……ご褒美は、ママから与えられるものだと……分かりました。また\n、至らないことがあれば教えて下さい。では、参ります……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0203106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「その、お仕事お疲れ様でした。頑張ったご褒美に、ママが……貴方のオチ○\nポをシコシコして……精液をドピュってさせてあげますね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0203107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あ、いい感じですか？　はい、それでは……早速……んっ、ふっ……んんっ\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0203108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「強さはこれくらいで大丈夫ですか？　はい……それと、身体は……重くあり\nませんか？　邪魔になったりとかは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0203109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はい、大丈夫ならいいんです。オチ○ポ……シコシコしてあげますね……う\nん、んふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0203110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「……皮がめくれる音がよく聞こえます……結構、激しいように思えますけど\n……痛くはありませんか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0203111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「そう……気持ちいいんですね……はい、もっとシコシコ扱いて……オチ○ポ\nからドピュってさせてあげます……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0203112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「え……？　ママのオッパイを吸ってもいいか……？　えぇと……乳首を吸い\nたいという、こと……ですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0203113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はい、それは……そうしたいということでしたら、構いませんが……あんっ\n！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0203114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あっ……んんっ、あぁ……吸ってます……んふっ、乳首……あっ、んくっ、\nは……んっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0203115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「い、いえ……強すぎるという程のことは……大丈夫です……私も、しないと\n……いけませんね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0203116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あふっ、んっ……んぅんっ……今日は、いっぱい頑張りましたね……ママの\nご褒美……受け取って下さいね……あっ、はっ、あんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0203117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んっ……オチ○ポの方は問題ありませんか……あっ、くっ……んっ、ふっ…\n…んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0203118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あ……この声は、その……乳首が刺激されて……ムズムズしてしまって……\nんっ、その、これ以上……されると……あっ……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0203119" ]},
		{"command":[ "SETIMAGE", "0", "still_00003002_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はぁっ……あっ、出て……来ちゃいました……あふっ、はい……その、私…\n…乳首を刺激されると……母乳が出てきてしまう体質で……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0203120" ]},
		{"command":[ "SETIMAGE", "0", "still_00003002_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「先に伝えておけばよかったのですが……申し訳……あっ、あぁんっ……あり\nませんっ……んっ、ふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0203121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「えっ……これ以上ない、ご褒美……？　そ、そうなのですか……？　ええ、\nそれは……勿論……飲んで頂いて構いませんが……あぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0203122" ]},
		{"command":[ "SETIMAGE", "0", "still_00003002_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あっ、はぁっ、あぁっ……乳首がっ、んんっ、チュウって……あっ、す、吸\nわれるっ……んくぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0203123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あぁっ、そんなに一生懸命、母乳を飲まれるなんて……あっ、ふっ……え…\n…？　あ、は、はい……そうでした、オチ○ポもお扱きします……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0203124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んっ、んふっ……あっ、はぁっ……んっ、このような形で、喜んで頂けてる\nのでしょうか……んぁっ、はぁっ、んっ、ぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0203125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「声……は……あっ、どうしてでしょうか……その、我慢しきれないで……自\n然に出て、しまいまして……あひっ、んぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0203126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あぁっ、もっと……聞かせて欲しい……ですかっ、は、はい……意識しなく\nても、あっ、自然に……出て、しまいますので……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0203127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「いけません……んっ、ふっ、もっと集中しないと……オチ○ポ……シコシコ\n、続けます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0203128" ]},
		{"command":[ "SETIMAGE", "0", "still_00003002_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ、先端の所……くちゅくちゅ……してます……根元も、した方が\nいいですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0203129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はい……では、こちらも……指を絡めて、棒の部分を……ぎゅっと握って擦\nって行きます……んっ、んくっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0203130" ]},
		{"command":[ "SETIMAGE", "0", "still_00003002_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あぁ……皮が大きく動きますね……表情を見る限り……とても、感じている\nみたいですね……んふっ、いい子ですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0203131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あっ、ふっ……んっ、あぁ……新しい汁が分泌されて来ました……ねとねと\nして、先端が……光って来ています……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0203132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「これは、もうすぐ射精……ドピュッと出そうになっているということですね\n？　はい……頑張ります……んっ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0203133" ]},
		{"command":[ "SETIMAGE", "0", "still_00003002_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「どうですか……んっ、気持ちいいの……続けたら、いっぱいピュって出せる\nんですよね？　いいですよ……いつでも出して下さいね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0203134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はっ、ぁっ、んっ……乳首も……んっ、いっぱい吸って……感じて、あぁっ\n、はっ、んっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0203135" ]},
		{"command":[ "SETIMAGE", "0", "still_00003002_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「出して……下さいっ、オチ○ポから……精液っ、ドピュドピュっ……出して\nぇっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0203136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あんっ！　はぁっ、すごい……びゅくって……出てます……精液が……いっ\nぱい……噴き出してます……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0203137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003002_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あぁ……んっ、手がヌルヌル……すごい量……こんなに出してくれたのです\nね……ふふ、ママも鼻が高いです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0203138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あ……落ち着いて来ましたね……はぁ……んっ、いかがでしたか。これで、\nご褒美になったのでしょうか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0203139" ]},
		{"command":[ "SETIMAGE", "0", "still_00003002_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「とっても良かった……あぁ、そう言って頂けると安心です。私なりに少しで\nもお役に立てたのなら、何より嬉しいことですから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0203140" ]},
		{"command":[ "SETIMAGE", "0", "still_00003002_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「え……？　でも、まだ物足りなさが残る……ですか？　はぁ……あの、それ\nでは、どうすれば……もうちょっと続けて欲しい……と」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0203201" ]},
		{"command":[ "SETIMAGE", "0", "still_00003002_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はい、私は構いませんが……射精したばかりでお疲れになったりはしていま\nせんか？　あっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0203202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「なるほど……こんなに強く勃起されたまま……確かに、もう少し続けた方が\nよろしいみたいですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0203203" ]},
		{"command":[ "SETIMAGE", "0", "still_00003002_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「では、続けて……オチ○ポ、シコシコしますね。もし、痛かったり、辛かっ\nたりしたら言って下さい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0203204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……んふっ……大丈夫そうですか……よかった。あ……はい、お\nっぱいも吸って構いませんよ……あ、あんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0203205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んんっ、あぁ……チュウチュウ……熱心に吸ってます……んっ、あひっ、あ\nぁっ……はっ、んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0203206" ]},
		{"command":[ "SETIMAGE", "0", "still_00003002_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「ここが……私の、性感帯という……ことなのですか……んっ、それを、お互\nいに……刺激しあうから……こんなに、感じてしまう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0203207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、確かに……こんな感覚を味わうのは……初めてです……あふ\nっ、はぁっ、んっ……気持ち……いいですっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0203208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「ママ……あっ、んっ、そうでした……貴方のママになって、オチ○ポのお世\n話をしなくてはダメですよね……あふっ、はい……シコシコします……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0203209" ]},
		{"command":[ "SETIMAGE", "0", "still_00003002_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「どうですか……ママの手……いっぱい出した精液でヌルヌルになっています\n……お陰で……よく滑るでしょう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0203210" ]},
		{"command":[ "SETIMAGE", "0", "still_00003002_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……これに……あっ、おっぱいから出た……母乳も一緒に絡めて\n……はぁんっ、もっとグチュグチュさせてあげますっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0203211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んくんっ！　あっ、乳首……舌で転がしてる……んふっ、はい……ママも気\n持ちいいですよっ、またお乳……出ますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0203212" ]},
		{"command":[ "SETIMAGE", "0", "still_00003002_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はぁんっ……あぁ、どうしてでしょう……今まで、母乳が出る時にも……こ\nんな風に感じることなんてなかったのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0203213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「このままだと……イ、イクような感じにっ……はぁんっ、あっ、あぁっ、あ\nぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0203214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「えっ……あっ、んっ、次に出す時は……私とい、一緒に……ですか？　んっ\n、それは……あっ、は、はいっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0203215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「分かりました……ママが、このままオチ○ポ、ピュッピュさせてあげますか\nらっ……それと一緒に……おっぱいもっ……イキっ……ますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0203216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「うんっ、はっ、あぁっ……もっとぎゅっと強く握ってっ……こすこすっ……\nシコシコしてっ……あっ、あぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0203217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はぁん！　おっぱい吸われてっ……気持ち……よくてっ、はひっ、あっ、も\n、もうっ……私もぉっ、すぐにぃっ、あっ、イキっ……そっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0203218" ]},
		{"command":[ "SETIMAGE", "0", "still_00003002_01_11" ]},
