		{"command":[ "SETNAME", "アナザー・稲穂姫" ]},
		{"command":[ "SETTEXT", "「妾を愛さず、崇めず、呪いと疫病の神として祀った人間たちに復讐する者じ\nゃ！」", "NORMAL" ]},
