		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おい！　稲穂姫！　話を聞いてくれ、俺たちは……」", "NORMAL" ]},
