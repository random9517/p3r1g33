{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0045" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「やれやれ、ご主人。お待たせしましたぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023650001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "さっきはちょうどトイレでいなかったらしいジュンジローを加えて、俺達は４\n人と１匹で神社にやってきた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お、着いたな。イルル、ヤム。……それにしても、いつにも増して賑わって\nいるな」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「かなり人が集まっているようです。さすがは正月といったところですな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023650002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「実際、今来ないならいつ来るんだよって感じだもんなあ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「すっごい人の波！　これって全員『はつもうで』っていうのに来た人なの？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010023650001" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ああ、そうだ。……おっと、迷子にならないように手をつないでおくか？　\nほら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023650001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「ルナテミスおねーさん、とってもやさしいね。えへへ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010023650001" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ばっ……！　ば、馬鹿、そんなに可愛らしいことを言うんじゃない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023650002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「照れてる照れてる～。んふふふっ、ルナテミスおねえちゃんの手あったか～\nい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010023650002" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「イルルもつなぐ！　あ、でもそうしたら、おとーさんがさみしくなっちゃう\nから……イルルはおとーさんとつなぐね♪　えへへ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010023650002" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「あ、ずるーい！　ヤムもパパと手、つなぐ！　おねーさんとパパと、どっち\nもがいい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010023650003" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うぉっ。両手がふさがってしまった。これじゃ子持ちのおじさんみたいだぞ\n」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "8", "CENTER", "400" ]},
		{"command":[ "SETCHARA", "1", "char_00017502_01", "8", "CENTER", "-400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「たまにはこういう触れ合いもいいだろう。……ん？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023650003" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "ルナテミスがふと、視線を送った先では巫女さんがブツブツと長い祈願をして\nいるようだった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「どうか願いが叶いますように……。どうか願いが叶いますように……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010023650001" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "4", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あれはカグヤ、か？　遠すぎて良くみえないな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023650004" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まさか。こんなとこにいないでしょう。姫様、目が悪くなったんじゃないで\nすか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「な、なんだと！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023650005" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「甘酒～、甘酒はいかがですか～？　トロトロあつあつで、本当にと～っても\n美味しいんですよ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_010023650001" ]},
		{"command":[ "SETCHARA", "0", "char_00022003_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「今なら無料配布しております～。甘酒～、新春の思い出にいかがでしょう～\n♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_010023650002" ]},
		{"command":[ "SETCHARA", "0", "char_00022003_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「……１杯いただいてもいいだろうか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090023650001" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "SETCHARA", "1", "char_00000109_01", "0", "CENTER", "-1500" ]},
		{"command":[ "MOVECHARA", "0", "CENTER", "400", "NORMAL" ] },
		{"command":[ "MOVECHARA", "1", "CENTER", "-400", "NORMAL" ] },
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「あら～っ、どうぞどうぞ！　お熱いので気をつけて……。ゆっくりね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_010023650003" ]},
		{"command":[ "SETCHARA", "0", "char_00022003_01", "8", "CENTER", "400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ……。ごく……ごく……。……ぷぁっ、ほのかに香るいい匂い……。こ\nれが甘酒か」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090023650002" ]},
		{"command":[ "SETCHARA", "1", "char_00000109_01", "2", "CENTER", "-400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「特別な日って感じがして素敵ですよね～。私もすっごく好きなんですよ～♪\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_010023650004" ]},
		{"command":[ "SETCHARA", "0", "char_00022003_01", "6", "CENTER", "400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「も、もう１杯いただこう。おかわり」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090023650003" ]},
		{"command":[ "SETCHARA", "1", "char_00000109_01", "6", "CENTER", "-400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「はいはぁ～い♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_010023650005" ]},
		{"command":[ "SETCHARA", "0", "char_00022003_01", "8", "CENTER", "400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "（なんだか人混みの中に、見たことのある顔ぶれがいたような……。気のせい\nか？）", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "しかし、今はお嬢様３名の護衛として側を離れる事は出来ない。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "それに人が多すぎて、いちいち確認するのも億劫になって……深く追求しない\nことにした。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0000" ]},
		{"command":[ "SETTEXT", "それからは……。", "NORMAL" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "参拝したり……。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0045" ]},
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「手水で手を洗って、神様の前で２礼、２拍手、それから１拝……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010023650004" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んんんっ！　することが多すぎて難しいんだけどーっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010023650005" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「でも、上手にできてたよ？　これから毎年、おとーさんとここに来たいな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010023650003" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ふんっ……。その時はヤムも一緒にね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010023650006" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「うん。来年も、再来年も……ね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010023650004" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0000" ]},
		{"command":[ "SETTEXT", "はたまた、おみくじを引いたりして楽しんだ。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0045" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「……おおっ！？　やったぞ、大吉だ！　今年も良い年になりそうだな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023650006" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「姫様は運がいいな……。さて、俺は……って、げええっ！　大凶だ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「イルルは……えっ、だ、大吉……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010023650005" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ヤムも大吉！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010023650007" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「な、なんで俺だけこんなに運がないんだよおおおおっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「日頃の行いのせい、というやつですな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023650003" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ふむ……なになに。恋愛、相手を甘やかすと良好。な、なるほど……。今年\nはもう少し違った攻め方も……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023650007" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ん？　何か言いました、姫様？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「な……なんでもない。イルルとヤムはどうだった？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023650008" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「イルルはね……。えっと、れんあい、おもいをつたえるとよし。えへへ、イ\nルルいつもやさしいおとーさん、大好き！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010023650006" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あぁ、ありがとうイルル」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んっと、れんあい、せまればせまるほどみのる。……だって……え～っ？　\nどうする～？　パパぁ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010023650008" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ま、待ってくれ！　こんな場所で抱きついたら……変な目で見られるから…\n…！　事案に成りかねないから！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「じゃあ誰もいない場所ならいいの？　それなら２人の時にしたげるっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010023650009" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はははは……。っと、一応、俺も内容を見てみるか。うーん、気になるのは\nやっぱ健康かな」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「健康、近いうちに死ぬ。親しき人にも不幸あり。………………………………\n………………………………………………え」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……とんでもなく恐ろしい事が書かれているんだが。………………見なかっ\nたことにしよう」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「他には……。ん？　待ち人、自らの先生となる者に出会う……ふむふむ……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023650009" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「さすが大吉、皆様の未来は明るいですな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023650004" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「俺は近いうちに死ぬんだが……！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「よっし、大体やるべきことはやったよな。それじゃあ帰るとするか」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「うん！　あ～、楽しかった～！」", "NORMAL" ]},
