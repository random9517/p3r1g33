{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「あ！　きたきたご主人様～！　こっちですよ～、こっちこっち～！　わざわ\nざ部屋まできてもらっちゃって、ありがとうございます♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0603101" ]},
		{"command":[ "SETCHARA", "0", "char_00015706_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「呼び出した理由はもちろんこれです！　YSKモード！　まだまだ十全に扱\nえているとは言えませんから、性能テストに付き合ってほしくて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0603102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「まるで人間の肌のようなスキン。これを使って、メイドとして正しくご主人\n様に癒し効果を与えられるかどうか――もちろん、えっちな意味で！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0603103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「それのテストを行いたいのですが……ご主人様、お付き合いして、頂けます\nか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0603104" ]},
		{"command":[ "SETCHARA", "0", "char_00015706_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「――にゃふふ♪　まったく、テスト内容も聞かずに即答とは、そーゆーとこ\nろですよ、ご主人様？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0603105" ]},
		{"command":[ "SETCHARA", "0", "char_00015706_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「――はい、私の太ももに頭をのせてください！　ご主人様は何も考えなくて\n大丈夫！　貴方のメイドに、ぜーんぶお任せくださいな♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0603106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んっ……こ、これは中々……っ……いえ、ご主人様の髪の毛が、少しくすぐ\nったくて、ですね……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0603107" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00015706_01_02" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「思ったより皮膚パーツの感度が高めに設定されてるみたいです。んっ……少\nし調整した方がいいかな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0603108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ご主人様はどうです、私の膝枕の感触、楽しんで頂けてますか？　にゃふふ\n、実はご主人様好みの柔らかさにカスタマイズしたんですよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0603109" ]},
		{"command":[ "SETIMAGE", "0", "still_00015706_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「――って、聞くまでもないですね～。でれでれしちゃって、ご主人様ってば\n、ほんとーにかわいいんですから～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0603110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「よしよ～し、ご主人様、いい子いい子～。このままもっと甘やかしてあげた\nいですけど……こーゆーのはお嫌いでしょうか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0603111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「――え？　大好物だからもっとくれ？　んにゃん♪　乳首にも吸い付いてき\nちゃって、どうしようもないバブちゃんですねぇ、ご主人様は♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0603112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「あっ、んんぁん！　も、もう、今回のテストは私が癒さなければ意味ないん\nですってば！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0603113" ]},
		{"command":[ "SETIMAGE", "0", "still_00015706_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ほ～ら、ご主人様のおちんちん、にぎにぎしていきますね～。スベスベの肌\nの感触、い～っぱい楽しんでくださいね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0603114" ]},
		{"command":[ "SETIMAGE", "0", "still_00015706_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふふ、相変わらずご主人様のおちんちんは大きくてかっちかちですね～\n。全然手の中に納まりきりませんよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0603115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んっ……根元の辺りをぎゅって握って……ゆっくりしこしこ……大きくしこ\nしこ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0603116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふふ、もうおちんちんの先っぽからお汁が出てきちゃってます。まった\nく、我慢の効かないダメダメご主人様ですねぇ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0603117" ]},
		{"command":[ "SETIMAGE", "0", "still_00015706_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「どうですか、私の手で、しっかり癒されてくれてますか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0603118" ]},
		{"command":[ "SETIMAGE", "0", "still_00015706_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「――気持ちいいけど、もっと速くしごいてくれると更にいい？　ふむ……肌\nの感触が変わっているので、力加減の調整が少しズレてましたか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0603119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「もっと早く……んっ、んんっ……握力の数値も再設定……ん、しょ……おち\nんちんの反応を見て微調整……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0603120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「手首を回して、おちんちんの皮を大きく引き下げる……にゃふ、おちんちん\nがビクンって跳ねた♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0603121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ほ～ら、ご主人様も自分で腰を動かしていいですからね～。私の手コキに合\nわせて、いち、に、いち、に♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0603122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「えっちなお汁をぐちゅぐちゅ、しこしこ。おちんちんもいい子いい子♪　し\nこしこ～、しこしこ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0603123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んあぁんっ！　ご主人様ったら、また乳首に吸い付いてきましたね～？　―\n―にゃふふ、もちろん、怒ってなんていませんよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0603124" ]},
		{"command":[ "SETIMAGE", "0", "still_00015706_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「この新しい肌も、手も、乳首も、全てご主人様を喜ばせるためのモノ……ご\n主人様だけのモノなんですから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0603125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「いくらでも甘えて、おっぱいに吸いついて、私に癒されちゃってくださいね\n、ご主人様？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0603126" ]},
		{"command":[ "SETIMAGE", "0", "still_00015706_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んふっ、あっ、んぁんっ！　にゃふふ、必死におっぱいに吸い付いてくるご\n主人様、やっぱりかわいい……あぁんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0603127" ]},
		{"command":[ "SETIMAGE", "0", "still_00015706_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「おちんちん、もっと激しくしこしこしちゃいますね。えっちなお汁をいっぱ\nい指に絡めて……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0603128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ぐちゅぐちゅ、しこしこ……先っぽの部分をぎゅっと握って、いい子いい子\n……あっ、あんぁんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0603129" ]},
		{"command":[ "SETIMAGE", "0", "still_00015706_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ご主人様ってば、ほんとにおっぱい好きですよね～。んあぁん。そんなに必\n死に唇で挟んで、吸い付いて……あっ、あぁんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0603130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「――にゃふふ、もちろん分かってますとも♪　亀頭をびくびく震わせて、も\nう我慢できないんですよね！　びゅーびゅー射精したいんですよね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0603131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ご主人様のお好きなように、出してくださいな。私のスベスベの手の中で、\nた～っくさん射精しちゃってください♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0603132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「あっ、あぁんっ！　もっと激しく、早く……！　根元から先端まで、しこし\nこ、ぎゅっぎゅ！　しこしこ、ぎゅっぎゅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0603133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ここですよね！　括れの部分を指先でくすぐって、先っぽの割れ目をぐりぐ\nり～。にゃふふ、おちんちん、びくびく大暴れ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0603134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ほら、出してご主人様♪　新しい私のボディを――私の『肌』をご主人様の\n精液でドロドロに汚してください！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0603135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「にゃあぁんっ！　出てる、ご主人様の精液がドクドクって、こんなにいっぱ\nい！　あっ、あぁんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0603136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015706_01_05" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「すごいっ……これが『肌』で感じるご主人様の精液なんだ……熱くて、ドロ\nドロで……ただの『ボディ』で感じるのとは全然違う！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0603137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「私の膝の上でご主人様が感じて、射精して、乳首まで舐められて……んにゃ\nん♪　こんなの、私も癒されちゃいますよぉ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0603138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ほらほら、ご主人様、まだまだ出せますよね？　射精中もしこしこ、ぎゅっ\nぎゅっ♪　乳首もちゅーちゅーしていいですからね～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0603139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んんっ……でも、ほんとに熱い……ただ手に出されただけでこれだもん……\nもしこれが、他の場所に射精されたりしたら……にゃふ、にゃふふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0603140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「――分かってますよ、ご主人様。一回出しただけじゃ、満足なんて、できま\nせんよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0603201" ]},
		{"command":[ "SETIMAGE", "0", "still_00015706_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「私もまだまだ癒し足りません！　心行くまで私に甘えて、いーっぱい気持ち\nよくなっちゃってくださいな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0603202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んっ、んふっ、んんっ……！　やっぱり手コキは二回目からが本番ですよね\n～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0603203" ]},
		{"command":[ "SETIMAGE", "0", "still_00015706_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「いっぱい出た精液をおちんちん全体に広げて、塗り込んで……えっちな音い\nっぱい！　ぐちゅぐちゅ、しこしこ、根元からぎゅっぎゅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0603204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「人の『肌』で精液を掻き回すと、こんな風になるんですね。指の間までぐち\nょぐちょで、滑っていくというより、ねっとり絡みついていく感じ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0603205" ]},
		{"command":[ "SETIMAGE", "0", "still_00015706_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふふ、ご主人様は、どっちの私にご奉仕されるのが好きですか？　いつ\nもの私？　それともYSKモードの私？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0603206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「――え？　どっちもロッテなんだからロッテの全てが好き？　……にゃふ、\nにゃふふ、にゃふふふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0603207" ]},
		{"command":[ "SETIMAGE", "0", "still_00015706_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ご主人様、そーゆーところですよ、そーゆーところ！　私もご主人様の全て\nがだ～い好きです♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0603208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「にゃぁんっ♪　またそんなに甘えちゃって♪　ご主人様、それ、乳首を唇で\n挟んで舌でぺろぺろするの、気持ちよすぎますよ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0603209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「それにさっきから、んぁんっ！　頭もぐりぐりって、太腿に押し付けてきて\nるの、わざとでしょ？　少しくすくったいんですって！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0603210" ]},
		{"command":[ "SETIMAGE", "0", "still_00015706_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「――でも、そっちがその気なら、私だって負けませんよ！　ご主人様の顔が\nトロトロになるまで、癒しまくってあげちゃうんですから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0603211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ほ～ら、ご主人様、いい子いい子♪　今日もいっぱい頑張りましたね～、頭\nもいっぱいなでなでしてあげますよ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0603212" ]},
		{"command":[ "SETIMAGE", "0", "still_00015706_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「頭をなでなで、おちんちんしこしこ♪　このまま私にいーっぱい甘えて、ま\nた精液びゅーびゅーってしちゃいましょうね～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0603213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「あっ、んんっ、んあぁんっ！　ご主人様が可愛すぎて、乳首を吸われてるだ\nけなのに、私もどんどん気持ちよくなってきてっ、んにゃんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0603214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「――にゃふふ、はい、私もイきそうです！　ご主人様にいっぱい甘えられて\n、乳首ちゅーちゅーされて、いっちゃいそうです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0603215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ご主人様のおちんちんも、またドクドク暴れ始めましたね。裏のところ、優\nしくいーっぱいなでなでしてあげますから、一緒にイきましょうね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0603216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「YSKモードの最適な力加減もわかってきました……んんっ！　『肌』が柔\nらかいから、いつもより少し強めに押し込んで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0603217" ]},
		{"command":[ "SETIMAGE", "0", "still_00015706_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「指の関節を、おちんちんのデコボコにひっかける……んぁんっ！　肌を滑ら\nせるように、手のひらでおちんちんをナデナデ、ぎゅっぎゅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0603218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「にゃあんっ！　そんな吸い付かれちゃうと、乳首伸びちゃいますよ～。\nあっ、ふぁっ、んあぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0603219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「いいですよ！　出してくださいご主人様！　私も一緒にイきますから！　好\nきなところにいっぱい精液をぶっかけてくださいな♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0603220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んにゃああぁあんっ♪　また、手にこんなにいっぱい……！　ご主人様の精\n液熱すぎて、指が火傷しちゃいそうです♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0603301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015706_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「あっ、ふあぁんっ！　んにゃぁんっ♪　もう、そんなに私の顔をじっと見て\n乳首を吸っちゃって……かわいすぎますよ～ご主人様～♪　」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0603302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「いい子いい子♪　射精しながら乳首をいっぱい吸えて、偉いですね～ご主人\n様♪　あふっ、んあぁんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0603303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「射精も全然とまりませんねー♪　ビクンビクンっておちんちんが暴れまわっ\nて……んぁんっ！　にゃふふ、こっちもかわいい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0603304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「やっぱり『肌』で感じるご主人様の精液は格別です……これを『中』で感じ\nることが出来たら、私どうなっちゃうんでしょうか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0603305" ]},
		{"command":[ "SETIMAGE", "0", "still_00015706_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ん……どうですか、ご主人様。私の身体で癒されてくれていますか？　私の\nご奉仕、満足してくれていますか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0603306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「――この程度じゃまだまだ足りない？　もっと甘えさせてほしい？　おっぱ\nいに顔をうずめさせろ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0603307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふ、にゃふふふふ♪　まったく、どーしよーもない甘えん坊さんですね\nーご主人様は♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0603308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「もちろん、いいに決まってるじゃないですか！　私のすべてはご主人様のモ\nノ。ご主人様へのご奉仕が、私の幸せなんですから♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0603309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「これからもいっぱい癒されて、私に甘えて……そして、私の事も可愛がって\nくださいね、私だけのご主人様♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0603310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んにゃああぁあんっ♪　ご主人様の精液が、顔にまで飛んできて、あっ、ん\nにゃぁんっ！　す、すごい、これが本当の顔射なんだっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0603401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015706_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「あふっ、あっ、んあぁんっ！　『肌』に熱い精液がべったりくっついて、ど\nろどろが、気持ちいい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0603402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「顔にかけられるだけでこんなに気持ちいいのに、『中』に出されたりしたら\n、私どうなっちゃうんでしょうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0603403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「あっ、んあぁんっ♪　ご主人様のおちんちん、まだまだ跳ね回ってますね♪\n　いい子いい子、いっぱいびゅーびゅーしていいですからねぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0603404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「――にゃふふ♪　どうでしたか、ご主人様？　ＹＳＫモードの私、堪能して\nくださいましたか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0603405" ]},
		{"command":[ "SETIMAGE", "0", "still_00015706_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「って、んにゃん！　そ、その頭ぐりぐりはくすぐったいんですって！　なん\nですか、それ気にいっちゃったんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0603406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「え？　私の反応が可愛すぎるのが悪い？　もっとくすぐったり色々して今ま\nで見れなかった反応を見てみたい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0603407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふ、にゃふふふ♪　もう、どーしよーもないですねー、私のご主人様は\n♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0603408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「肌の感度は少し下げようと思っていましたが……ご主人様がそういうなら、\nこのままにしておいてもいいかなー、なんて♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0603409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「だから……新しい私も、今まで以上にかわいがって、大事にしてくださいね\n、私だけのご主人様♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0603410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}