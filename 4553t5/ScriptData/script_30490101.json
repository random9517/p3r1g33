{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "PLAYVOICE", "049_0103101" ]},
		{"command":[ "SETNAME", "冴島美鈴" ]},
		{"command":[ "SETTEXT", "「冴島美鈴、呼び出しに応じて参上した。……それで？　用事とはなんだ」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "049_0103102" ]},
		{"command":[ "SETNAME", "冴島美鈴" ]},
		{"command":[ "SETTEXT", "「私が多忙だとわかっていながら、緊急招集をかけるとは……。……なんだ？ \nこちらをジロジロと見て……言いたいことがあるなら言いなさい」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "049_0103103" ]},
		{"command":[ "SETNAME", "冴島美鈴" ]},
		{"command":[ "SETTEXT", "「……なるほど。私の無駄に大きな胸で君の生殖器を挟み、慰めて欲しい、と\n。……と……な？　何？　な、なんだと！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "049_0103104" ]},
		{"command":[ "SETNAME", "冴島美鈴" ]},
		{"command":[ "SETTEXT", "「じょ、冗談だろう？　君、言っていい冗談と悪い冗談が……。……ん！？　\n嘘ではない……？　しかもその上舐めろだと！？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "049_0103105" ]},
		{"command":[ "SETNAME", "冴島美鈴" ]},
		{"command":[ "SETTEXT", "「な、舐めっ……胸で挟みながら……？　……私が？　え、ええと……。『経\n験豊富な長官ならば造作もないことだろう』だと……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "049_0103106" ]},
		{"command":[ "SETNAME", "冴島美鈴" ]},
		{"command":[ "SETTEXT", "「け、経験……。経験……。そ、そうだな、私に経験が無いわけがないだろう\n！？　ありすぎて困っているくらいだ、だから……その……なんだ」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "049_0103107" ]},
		{"command":[ "SETNAME", "冴島美鈴" ]},
		{"command":[ "SETTEXT", "「デザート感覚でペニスをしゃぶるのがモテる女の日常的行為だと言うのなら\nば、そうなのだろうな。やらせてもらおう」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "049_0103108" ]},
		{"command":[ "SETNAME", "冴島美鈴" ]},
		{"command":[ "SETTEXT", "「……わ、私の鍛え抜かれた技術であれば、君など手間取らず、すぐに射精に\n導ける……はず、だ。おそらく……ううむ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "049_0103109" ]},
		{"command":[ "SETNAME", "冴島美鈴" ]},
		{"command":[ "SETTEXT", "「だが！　君とは初めての行為になる。まずはペニスを閲覧させてもらおうか\n。……えっ！？　やっ……！　お、大きい……！？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "049_0103110" ]},
		{"command":[ "SETNAME", "冴島美鈴" ]},
		{"command":[ "SETTEXT", "「こんなもの胸で挟めるのか？　……ああ、いや、何でもない。独り言だ。で\n、では……始めるぞ。ん……んん、ん……ん……っ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "049_0103111" ]},
		{"command":[ "SETNAME", "冴島美鈴" ]},
		{"command":[ "SETTEXT", "「あ、熱い……谷間が燃えるようだ……。それに、このゴツゴツとした感触…\n…こんなにも、男のモノというものは……ごくっ……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004901_01_01" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "049_0103112" ]},
		{"command":[ "SETNAME", "冴島美鈴" ]},
		{"command":[ "SETTEXT", "「……あ、あ、そ、そうか。これを舐めるのだったな。胸で刺激しながら……\n。はぁ、はぁ、少し怖いが……何事も試しだ。……っ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "049_0103113" ]},
		{"command":[ "SETNAME", "冴島美鈴" ]},
		{"command":[ "SETTEXT", "「チュ……ちゅ、ちゅ、ちゅ……んんっ！？　先っちょがプルプルしている…\n…！　んん？　棒の部分は硬いのに……不思議なものだ。っちゅっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "049_0103114" ]},
		{"command":[ "SETNAME", "冴島美鈴" ]},
		{"command":[ "SETTEXT", "「ん……うまく胸が動かせないが……、はぁっ……こう、か……？　こうか？\n　んん？　君ぃ……何か言いたまえ……っあっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "049_0103115" ]},
		{"command":[ "SETNAME", "冴島美鈴" ]},
		{"command":[ "SETTEXT", "「ん、ん、ん……！　む、胸を上下左右させていると……その、乳首がこすれ\nて……ンッ……あっ、んん……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "049_0103116" ]},
		{"command":[ "SETNAME", "冴島美鈴" ]},
		{"command":[ "SETTEXT", "「あ、喘ぎ声が可愛い……？　ば、馬鹿者……！　私は喘いでなどいな……ん\nっ！？　あっ、あッ……しまった、こ、声が出てしま……あっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "049_0103117" ]},
		{"command":[ "SETNAME", "冴島美鈴" ]},
		{"command":[ "SETTEXT", "「く、口を塞いでしまわなければ……。っ……そ、そうだ。ペニスを舐めてい\nれば喘ぎは漏れまい……。ぺろ……ぺろ、ぺろ、れろ、れろ、れろ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "049_0103118" ]},
		{"command":[ "SETNAME", "冴島美鈴" ]},
		{"command":[ "SETTEXT", "「れる……れるんっ、ちゅっ、チュ……ちゅっぱっ、ちゅっぱちゅっぱっ……\n！　れる……れる、れる……れるんっ、れるっ、れるん……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "049_0103119" ]},
		{"command":[ "SETNAME", "冴島美鈴" ]},
		{"command":[ "SETTEXT", "「ひゃっ！？　ペニスが太く……！　お、驚かせるな！　……続けるぞ。はぷ\n……ちゅ、ちゅ、チュ、ちゅっ、ちゅ、ちゅむ……ちゅむ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "049_0103120" ]},
		{"command":[ "SETNAME", "冴島美鈴" ]},
		{"command":[ "SETTEXT", "「れろ……れろっ、れろ……れろっ！　ちゅぷっ、ちゅぷっ、ちゅぷぷぷ……\nはぁ、はぁ、どうだ？　良すぎて声も出んか？　……チュッ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "049_0103121" ]},
		{"command":[ "SETNAME", "冴島美鈴" ]},
		{"command":[ "SETTEXT", "「な、に……？　あまりに稚拙で、浅くて、弱くてまったく感じない……？　\n馬鹿な……！　これ以上強くしたらペニスが折れてしまわないか……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "049_0103122" ]},
		{"command":[ "SETNAME", "冴島美鈴" ]},
		{"command":[ "SETTEXT", "「普通はもっと深く咥えて、じゅるじゅるとすするのがマナー？　……そうな\nのか……。あ、いやっ、し、知っていたぞ。当然な！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "049_0103123" ]},
		{"command":[ "SETNAME", "冴島美鈴" ]},
		{"command":[ "SETTEXT", "「では『普通の』しゃぶりをするか……。ん……こ、こんな巨大なものを丸飲\nみにするのか……。ええい、ままよ……！　っぐちゅっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "049_0103124" ]},
		{"command":[ "SETNAME", "冴島美鈴" ]},
		{"command":[ "SETTEXT", "「んぐっ！？　ぷはっ！？　い、息が出来な……！　いや、平気だ！　私は経\n験豊富だからな……見ていろ！　っぐっちゅっ！　ぐっちゅっぐちゅ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004901_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "049_0103125" ]},
		{"command":[ "SETNAME", "冴島美鈴" ]},
		{"command":[ "SETTEXT", "「にゅぷ……にゅぷぷぷっ！　ぢゅぱっ！　じゅぱっ、じゅっぷっ！　んくっ\n……んく、んぐっ……んんんぅ……んーっ！？　ンンッ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "049_0103126" ]},
		{"command":[ "SETNAME", "冴島美鈴" ]},
		{"command":[ "SETTEXT", "「ど、どういうことら……ペニスがどんどん熱くにゃって……んむっ！　顎が\n、顎が壊れ……んんっ！　ぐぷっ！　ぐっぷっぐちゅっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "049_0103127" ]},
		{"command":[ "SETNAME", "冴島美鈴" ]},
		{"command":[ "SETTEXT", "「じゅっぷっ！　じゅっぷっ！　じゅっぷっれろっ……！　レロッ、れろっ、\nれろっ……れろれろ……れるんっ、れろっ、れろん……ぢゅるっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "049_0103128" ]},
		{"command":[ "SETNAME", "冴島美鈴" ]},
		{"command":[ "SETTEXT", "「あ、ああ……乳房に私の唾液が垂れて……あぁ……！　にゅるにゅる、にゅ\nるにゅるして……ぢゅるっ……！　じゅるるっ、じゅるっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "049_0103129" ]},
		{"command":[ "SETNAME", "冴島美鈴" ]},
		{"command":[ "SETTEXT", "「そうか……こうして滑りをつけて、胸と口を動かすのか……！　わかったぞ\n！　にゅるっ……にゅるっ、にゅるっ！　ずるるるっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "049_0103130" ]},
		{"command":[ "SETNAME", "冴島美鈴" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、あっ……これは……！　これは私も気持ち、いい……！　ぢゅ\nるっ、ぢゅるるっ……れるっ、れるっ、れる、れろ……んーっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "049_0103131" ]},
		{"command":[ "SETNAME", "冴島美鈴" ]},
		{"command":[ "SETTEXT", "「ん……？　君のペニスが、脈打ち始めた……？　んぶっ！？　な、なんだこ\nれは？　どうなって……？　れろっ……れろ、れろ……なんだ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "049_0103132" ]},
		{"command":[ "SETNAME", "冴島美鈴" ]},
		{"command":[ "SETTEXT", "「……え？　で、出そう……？　出るって何がだ！？　あっ！？　あッ！？　\nあっ……！　と、止まれ、止まれ……なんだ……っああっ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "049_0103133" ]},
		{"command":[ "SETNAME", "冴島美鈴" ]},
		{"command":[ "SETTEXT", "「んーっ！？　んんんっ！？　ん゛ーっ！？　えっ！？　精液っ？　精液を出\nしているのか？　ま、待て……待てっ、あああっ！」", "NORMAL" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004901_01_06" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "049_0103134" ]},
		{"command":[ "SETNAME", "冴島美鈴" ]},
		{"command":[ "SETTEXT", "「これっ、どうしたら止まる……！？　し、舌で押さえれば……？　ん、んん\nぅ……！　だ、ダメだ、止まらない……あああっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "049_0103135" ]},
		{"command":[ "SETNAME", "冴島美鈴" ]},
		{"command":[ "SETTEXT", "「出てる、出てる、出ているっ……。そ、そうか君は……私の拙い……いや、\n経験豊富なフェラチオとパイズリで射精してしまったのか……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "049_0103136" ]},
		{"command":[ "SETNAME", "冴島美鈴" ]},
		{"command":[ "SETTEXT", "「なんということだ……。何がなにやら、わけがわからないうちに終わってし\nまった……。ん……？　あ、ざ、残念というわけではなくて……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "049_0103137" ]},
		{"command":[ "SETNAME", "冴島美鈴" ]},
		{"command":[ "SETTEXT", "「そ、そうだ！　あまりにあっけなく出すものだから驚いただけだ、別にもっ\nたいないだなんて思ってはいない……いないぞ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004901_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "049_0103138" ]},
		{"command":[ "SETNAME", "冴島美鈴" ]},
		{"command":[ "SETTEXT", "「ま、まあいい……。これくらいのことなら、業務に支障も出まい。また溜ま\nったら私を呼ぶように。そつなくこなしてみせよう」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "049_0103139" ]},
		{"command":[ "SETNAME", "冴島美鈴" ]},
		{"command":[ "SETTEXT", "「……『チンポを咥えられて嬉しかったか』だと？　う、嬉しいものか！　君\n……私をからかうのもたいがいにしたまえ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "049_0103140" ]},
		{"command":[ "SETNAME", "冴島美鈴" ]},
		{"command":[ "SETTEXT", "「わ、私は地球防衛機構の……ＥＤＯの長官だぞ。皆に出来ることは出来る！\n　以上だ！　……あまり私を見くびらぬように！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}