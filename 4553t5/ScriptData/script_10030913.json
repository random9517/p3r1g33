		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「でやぁっ！　はぁっ！　こいつ……なんてスピードなの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_010115930001" ]},
		{"command":[ "SETCHARA", "0", "char_00002804_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「そんな攻撃、へなちょこすぎて当たらないのである」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_050115930001" ]},
		{"command":[ "SETCHARA", "0", "char_00002005_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「ほらほら、その自慢の金棒は飾りかいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_030115930001" ]},
		{"command":[ "SETCHARA", "0", "char_00002203_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「ど、どこからあんなに爆弾を……っ！　弾幕濃すぎて近寄れません！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010115930001" ]},
		{"command":[ "SETCHARA", "0", "char_00001701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "アナザー・ハルカプトラとアナザー・サイレーンは見た目どおりにてごわく、\n夜叉も、ツインソードとなったバッケンローダーも苦戦していた。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そして俺も。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「ヒヒヒ……不運だね……もっと不運にしてあげるからね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_030115930001" ]},
		{"command":[ "SETCHARA", "0", "char_00001803_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "アナザー・グリムロックの攻撃を避けるので精いっぱいだ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "いや、そもそも俺が幹部級の敵に太刀打ちできるわけねーだろーが！　配役が\nおかしい！", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「カツマくん、なに朝から暴れてるの！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010115930001" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「その声は、サイレーンか！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「お？　こっちの世界でのボク？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_030115930002" ]},
		{"command":[ "SETCHARA", "0", "char_00002203_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「出勤してみたら、いったいなんの騒ぎである？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_010115930001" ]},
		{"command":[ "SETCHARA", "0", "char_00002001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「朝から時間帝国の相手？　不幸だね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010115930001" ]},
		{"command":[ "SETCHARA", "0", "char_00001801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「むむっ、こちらの世界の我であるか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_050115930002" ]},
		{"command":[ "SETCHARA", "0", "char_00002005_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「ヒヒヒ……出会っちゃった……。不運だね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_030115930002" ]},
		{"command":[ "SETCHARA", "0", "char_00001803_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ちょうどよかった、苦戦していたところだったんだ！　こいつらの相手をし\nてくれ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「言われなくても！　ボクがアナザーより優れているところ、見せないといけ\nないからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010115930002" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「ふんっ、ボクの方が優れた頭脳を持っているにきまってる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_030115930003" ]},
		{"command":[ "SETCHARA", "0", "char_00002203_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「いや、ボクの方がキミの何倍も優れた思考力をもつからボクの方がすごい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010115930003" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「なにを言ってるのか。ボクの方がキミより優れた技術を持っている。すなわ\nちボクの方がすごい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_030115930004" ]},
		{"command":[ "SETCHARA", "0", "char_00002203_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「いやいやボクが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010115930004" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「いやいやいやボクの方が」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_030115930005" ]},
		{"command":[ "SETCHARA", "0", "char_00002203_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「子供のケンカかぁっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「フフフ……自分のアナザーと戦わなきゃいけないなんて、不幸にもほどがあ\nる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010115930002" ]},
		{"command":[ "SETCHARA", "0", "char_00001801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「ヒヒヒ……作戦を邪魔されて、こっちの世界の自分と戦う……なんて不運…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_030115930003" ]},
		{"command":[ "SETCHARA", "0", "char_00001803_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「フフフ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010115930003" ]},
		{"command":[ "SETCHARA", "0", "char_00001801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「ヒヒヒ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_030115930004" ]},
		{"command":[ "SETCHARA", "0", "char_00001803_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "sbg_0213" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「どちらが優れているのか、こいつで決めようじゃないか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_030115930006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「いけっ！　ハルカプトラ、Verじゅうなな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_030115930007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「Ver『ワン・セブン』である」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_050115930003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「なるほど、キミもマシンファラオのメカニックにかかわっていたんだね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010115930005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「のぞむところだ！　いけ！　ハルカ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010115930006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「『ま゛っし』である」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_010115930002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "アナザー３人組の相手をこっちの世界の３人組にまかせることにして、俺たち\nは生徒たちを安全な場所へ運ぶことにした。", "NORMAL" ]},
