		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ローズ" ]},
		{"command":[ "SETTEXT", "「あっ！　あっ、あっあっあっあぁっ……！　な、ぜ、もっと激しく腰を動か\nす……！？　抜いてくれ……！　尻穴に貴公のチンポは大きすぎ、て！」", "NORMAL" ]},
