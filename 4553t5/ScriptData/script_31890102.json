		{"command":[ "SETIMAGE", "0", "still_00018901_02_07" ]},

		{"command":[ "SETNAME", "ローズ" ]},
		{"command":[ "SETTEXT", "「あッ、かっはっ……！　うぐ……！　腹が重い、ズシンと響く……！　あ、\nあ……でも……。ゾクゾクが、止まらない。背徳感と一緒になって」", "NORMAL" ]},
