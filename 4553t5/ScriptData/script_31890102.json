		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ローズ" ]},
		{"command":[ "SETTEXT", "「あぁっ！　ま、まだ動かなさないでくれ……！　凄まじい圧迫感なんだ……\n！　あっ！　だ、だめだ、動かすな、小さく前後にでもだめだ！」", "NORMAL" ]},
