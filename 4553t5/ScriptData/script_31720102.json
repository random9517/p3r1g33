		{"command":[ "SETIMAGE", "0", "still_00017201_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「はぁあ……ああぁ……っ！　んぁっ、また……ちんぽが動いて……んっくぅ\n……あはぁあんっ！」", "NORMAL" ]},
