		{"command":[ "PLAYVOICE", "v2_172_0104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「んふっ！　どうされたのですか？　このまま、もう一度セックスを？　アン\nッ！　すごい……まだ、ちんぽが硬い……」", "NORMAL" ]},
