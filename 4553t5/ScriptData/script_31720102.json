		{"command":[ "SETIMAGE", "0", "still_00017201_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「勃起ちんぽが、アアッ、まんこをまた、こすって……んっくぅっ！　なんだ\nかさっきよりも、大きな快感が……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0104205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「んぁっ！　ああぁんっ！　身体の感度が、ンッ！　上がっている……はぁっ\n、はぁ……んぁああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0104206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
