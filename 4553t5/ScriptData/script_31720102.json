		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「ああっ、ああっ、ちんぽが激しく……んはぁあっ！　ずぼずぼって、まんこ\n、まんこに……ああっ、なにか……キちゃう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0104137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「ああぁっ！　ああっ、ああぁあああぁあっ！　んはぁああぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0104138" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017201_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「ああ……中に……中に精液……。あなたの……ドロドロした熱い精液が……\n流れ込んできています……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0104139" ]},
		{"command":[ "SETIMAGE", "0", "still_00017201_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……、私も……とても気持ちよかったです……。頭が真っ白に\nなるような感覚……初めてでした……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「え……先ほどの感覚が、イクというものなのですか？　それで……なるほど\n、イクときはそう宣言するものなのですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0104201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
