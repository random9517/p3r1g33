		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「はぁ～……。あ、すみません。どうも最近スランプと言いますか……思うよ\nうに調子が出なくて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0104101" ]},
		{"command":[ "SETCHARA", "0", "char_00017201_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「その……。お恥ずかしい話なのですが、仲間の縦笛を見るとあなたのちんぽ\nを思い出してしまって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「演奏に集中できず……。このようなとき、ニンゲンはどうしているのでしょ\nうか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0104103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「ええっ！？　一発ヤる！？　そ、それはどういう……というかヤるとはなに\nを……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0104104" ]},
		{"command":[ "SETCHARA", "0", "char_00017201_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「セックス……なのですか？　ですがそれは子孫を残すための行為では？　そ\nれはニンゲンも同じでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0104105" ]},
		{"command":[ "SETCHARA", "0", "char_00017201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「ニンゲンはセックスを娯楽にする……？　娯楽……つまり気分転換にセック\nスをするということですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0104106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「体験してみればわかると……そうですね。何事もやってみなければわかりま\nせんね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0104107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「こうして仰向けになるのですね。それでは気分転換のセックスというものを\n、私に教えてくださいませ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0104108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「ん……ああっ、胸を……。んふぅ……っ！　ああっ、そんなに力いっぱい…\n…あんっ、揉むなんて……んくぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0104109" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00017201_02_02" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「んはぁ……はぁ……んん……。なんだか……力が抜けていきます……ふぅ…\n…はふぅ……。身体の奥が熱くなるようで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0104110" ]},
		{"command":[ "SETIMAGE", "0", "still_00017201_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「快感を……得ているのでしょうか……？　んっ、アンッ！　ですがたしかに\n、下半身も……疼いて……んぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0104111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「ああ……あなたの勃起したちんぽが、私の股間を擦って……。んふぅ……そ\nの……挿入するのですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0104112" ]},
		{"command":[ "SETIMAGE", "0", "still_00017201_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「ニンゲンのちんぽを挿入……。はぁ……はぁ……お願いします……。どうぞ\n、私の中へ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0104113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「んぁあっ、はぁああぁぁっ！　きたっ、ンンッ！　ちんぽが……私の中にぃ\n……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0104114" ]},
		{"command":[ "SETIMAGE", "0", "still_00017201_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「はぁ……私はこんなに太いものを、口の中に入れていたのですね……んっく\nぅ……身体が……裂けそう……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0104115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「んぁっ！　あっ、ああぁっ！　腰を動かして……っ！　ちんぽが、んはぁっ\n！　中……擦る……ンッ、はふぅうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0104116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「す、すごいです……こんな感覚……っ！　ああっ、ちんぽに身体を貫かれる\nような……んくっ、はぁっ、ああぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0104117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「頭の中までっ、ンッ、ちんぽが届いているかのような……ああっ、ああっ、\n全身を揺さぶられて……んっふぅうううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0104118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「ニンゲンのセックスは……ああっ、こんなにも激しく、ンッ、腰を振るので\nすね……はぁ、はぁ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「わ……私の中が気持ちいいから、なのですか……？　ンッ、ちんぽを締め付\nける具合が、いいのですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0104120" ]},
		{"command":[ "SETIMAGE", "0", "still_00017201_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「では、私もがんばって、中を締めますから……。ンッ、まんこ？　ここのこ\nとは、まんこと呼ぶのがニンゲン風なのですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0104121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「はい、まんこ締めます。まんこ締めて、ちんぽをぎゅぅっと……！　んっ、\nああっ、すっごく……ちんぽ感じるぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「アツアツで、ぶっといちんぽが、ああっ、私のまんこの中をごしごし擦って\n……っ！　ああっ、あはぁあんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0104123" ]},
		{"command":[ "SETIMAGE", "0", "still_00017201_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「はい……とても……気持ちいいです……！　ちんぽ、ちんぽ気持ちいい……\nっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0104124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「ニンゲンのいう、娯楽セックス気持ちいいです！　ああっ、ちんぽもっと…\n…もっとください……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「あはぁんっ！　また、胸まで……んっ、ああっ！　そちらまで一緒にされた\nら、ああっ、ますます感じてしまって……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0104126" ]},
		{"command":[ "SETIMAGE", "0", "still_00017201_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「ああっ、ああっ、ちんぽが……んっふぅっ！　じゅぼじゅぼと音を立てて、\nまんこを出入り、して……ああぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0104127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「私のまんこ、んんっ、すごいっ、擦れて……ああっ、ああっ！　それに奥ま\nで……ちんぽ、ちんぽきて……んくぅううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「ちんぽいいっ、いい……っ！　ああっ、んはぁっ、はぁあぁっ！　気持ちい\nいです！　とても……とても……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「あなたのちんぽを、まんこで感じて……はぁっ、はぁっ、こんなにも快感を\n……ああっ、得て、しまっているなんて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「そう、ですね……ああっ、小さな悩みなど、この快感の前では吹き飛んでし\nまいそうです……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0104131" ]},
		{"command":[ "SETIMAGE", "0", "still_00017201_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「ですからもっと、私にちんぽの快感を刻んで……んはぁっ！　なっ、まんこ\nの中でちんぽが……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「ちんぽがビクビクと……んっ、ああっ、この感覚……あなたの射精が近いと\n……ちんぽが……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「そ、そんな……中出しは……！　で、ですが……ああ……身体が言うことを\n聞いてくれないのです……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0104134" ]},
		{"command":[ "SETIMAGE", "0", "still_00017201_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「このまま、最後まで……ニンゲンのセックスを、最後まで味わいたい……！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0104135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
