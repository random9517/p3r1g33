		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「それはちんぽが……あなたのちんぽがとても気持ちいいのです……！　ああ\nっ、身体が反応して、しまうんです……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0104211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「ちんぽっ、ちんぽ……ちんぽ……いいんです……っ！　ああっ、ああっ、ま\nんこがジンジンと熱くなるんです……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0104212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「奥にっ、ズンズンと届くちんぽ感じるっ！　アアッ！　全身をちんぽ快感で\n揺さぶられて！　身体が勝手に動いてしまいます！」", "NORMAL" ]},
