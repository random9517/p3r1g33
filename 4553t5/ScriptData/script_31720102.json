		{"command":[ "PLAYVOICE", "v2_172_0104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「い……いい……っ！　ああっ、ちんぽ、ちんぽが……あはぁんっ！　感じま\nす！　さっきよりも……んぉっ、おおぉっ！」", "NORMAL" ]},
