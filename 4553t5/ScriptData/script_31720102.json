		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「ああっ、ああっ！　ますます激しくなった！　ちんぽ、激しくなったぁああ\nんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0104218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「ずぼずぼしてっ！　アアッ、胸も……んはぁああっ！　揉んでっ、ンッ、気\n持ちいいのっ！　全身に感じちゃうぅうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0104219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「イクッ、イクッ！　またこの感じ……！　イキますっ！　ニンゲンのちんぽ\nでイッちゃいますぅうううぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0104220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「イッくぅうううぅぅぅううぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0104301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017201_02_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「ああっ、ああっ！　んっはぁああぁぁぁああぁぁっ！　また中出しぃ……っ\n！　精液……きたぁ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「流れ込んでくる……ああ……ちんぽがビクンビクン、まんこの中で脈打ち…\n…ながらぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0104303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「私の……まんこの奥へ……んはぁ……。注がれてます……ああ……あなたの\n、精液ぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0104304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……。気持ちいい……セックス……気持ちいいです……。まん\nこにちんぽを挿入する行為が、こんなにもいいなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0104305" ]},
		{"command":[ "SETIMAGE", "0", "still_00017201_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「んぅ……。まだまだ、あなたのを挿入していたいです……。抜かないで、も\nうちょっとだけ、このまま……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0104306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「ふぅ……。相談に乗ってくださり、ありがとうございました……。おかげで\n、練習にも集中できそうです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0104307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「ですが……もしもまた、私が集中できなくなってしまったら……そのときは\nもう一度、セックスしてくれますか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0104308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「えっ、いつでもしていい？　ニンゲンとは……そんなに何度もできる生き物\nなのですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「それなら……。このまま、もう一度セックスしてくれませんか？　私……こ\nの行為の虜になってしまいました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「ああっ、んぁああっ！　ちんぽをいきなり抜いて……んっ、はぁああぁああ\nぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0104401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017201_02_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「ああっ、ああ……っ！　メガネに、精液……っ！　んっ、ドロドロに、なっ\nて……んふぅううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0104402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「い……イクッ！　ああっ、顔とメガネ、精液でべっとり汚されながらイクッ\n、んあぁっ、イク……イク……ッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0104403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「ああ……そうでしたね……。ニンゲンの射精は、こんなにも勢いよく……二\n度目でも濃厚で……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0104404" ]},
		{"command":[ "SETIMAGE", "0", "still_00017201_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「ああ……前が……。ドロドロの精液で、視界が塞がれて……んぁ……それに\n……匂いも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0104405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「とても濃いオスの匂いが……はぁ、はぁ……鼻の穴を犯しています……んふ\nぅ……はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0104406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「ああ……これがニンゲンの娯楽セックス……。なんて刺激的な……。そして\n甘美な快感……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0104407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「いけないとはわかっているのですが……。私……もっとあなたのちんぽを味\nわいたいです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0104408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「まんこの疼きも、まだまだ収まらない様子で……ふふっ、どうなされたので\nすか？　こんなにスケベだとは思わなかった？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0104409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「それは……私自身が驚いています。私はこんなにも、快楽に弱いエルフだっ\nたのですね。うふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0104410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
