	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「なに……？　なんなの……？　いったいなんなんです！？　この装備はぁ～\n～～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_010021370001" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00006802_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「ど、どうしてビキニなんですかぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_010021370001" ]},
		{"command":[ "SETCHARA", "0", "char_00006402_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「うううううう……こんな格好、恥ずかしいです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_065_010021370001" ]},
		{"command":[ "SETCHARA", "0", "char_00006502_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「しっかり着替えて武器も装備しておいて、いまさらなにを言ってるんだ。Ｂ\nＢ隊なんだからビキニに決まってるだろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021370001" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「ＢＢ隊だから……ビキニ……？　もしかして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_010021370001" ]},
		{"command":[ "SETCHARA", "0", "char_00005602_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「あの……長官？　まさか『ＢＢ隊』という名前は……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_010021370001" ]},
		{"command":[ "SETCHARA", "0", "char_00006702_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「もちろん、ビキニバズーカ隊……略して『ＢＢ隊』だ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021370002" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「やっぱり……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_010021370002" ]},
		{"command":[ "SETCHARA", "0", "char_00005602_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「なんて安直な……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_010021370001" ]},
		{"command":[ "SETCHARA", "0", "char_00005802_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「てか、なんでビキニなんスか！　なんで戦いに行くのにお肌を露出して、バ\nズーカ一丁で行かなきゃならないんスかぁ～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_010021370001" ]},
		{"command":[ "SETCHARA", "0", "char_00006102_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「私たちがかわいい女の子だから、こんな格好にさせたんでありますか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_010021370001" ]},
		{"command":[ "SETCHARA", "0", "char_00006302_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「いまさらなんだっつーの！　この程度の露出で戦う女幹部は、ウチには\nいくらでもいるだろ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021370003" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「あの人たちと一緒にしないでくださいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_010021370002" ]},
		{"command":[ "SETCHARA", "0", "char_00006302_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「それにだな、今回ビキニ装備を採用したのには、合理的な意味もあるんだぞ\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021370004" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「……聞かせてもらおうじゃないの。その『合理的な意味』とやらを」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_010021370002" ]},
		{"command":[ "SETCHARA", "0", "char_00006702_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「うむ！　実はおまえたちが向かう任務地は、高温多湿の森林地帯だ。ふだん\nの戦闘服では、５分と持たずに熱中症でやられてしまう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021370005" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「そんな森林地帯で、素肌を露出する方が危険だろうが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_010021370002" ]},
		{"command":[ "SETCHARA", "0", "char_00005802_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「それに、どうしてバズーカなんですか。森林地帯なら、もっと取り回しのい\nい武器が向いてるはずでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_010021370002" ]},
		{"command":[ "SETCHARA", "0", "char_00006402_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……なあ。あの映画って、ビキニでバズーカ撃ったりする話だっけ」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ほぼほぼ関係ありませんな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021370001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「じゃ、なんでビキニとバズーカなんだよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「よくわかりませんが、あの後でなにか妙なアニメでもご覧になったのではあ\nりませんかな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021370002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「わかんねえ。まったくわかんねえ……でも、ひとつだけわかることもあるぞ\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「なにかわかったんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_010021370003" ]},
		{"command":[ "SETCHARA", "0", "char_00006402_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああ。長官がこうなったら、もうなにを言っても聞きゃしねえ、ってことが\nな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「それも……そうですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_010021370002" ]},
		{"command":[ "SETCHARA", "0", "char_00006802_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "隊員たち" ]},
		{"command":[ "SETTEXT", "「はぁああ～……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_010021370003" ]},
		{"command":[ "SETCHARA", "0", "char_00005602_01", "1", "CENTER", "-600" ]},
		{"command":[ "SETCHARA", "1", "char_00005802_01", "1", "CENTER", "-200" ]},
		{"command":[ "SETCHARA", "2", "char_00006102_01", "1", "CENTER", "200" ]},
		{"command":[ "SETCHARA", "3", "char_00006402_01", "1", "CENTER", "600" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "DISPCHARA", "2", "TRUE" ]},
		{"command":[ "DISPCHARA", "3", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ビキニはおまえたちの体型を衆人環視の元にさらけ出すが、私は公平だ！　\nおまえたち個人のスリーサイズがどうだろうと見下さない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021370007" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "DISPCHARA", "2", "FALSE" ]},
		{"command":[ "DISPCHARA", "3", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「おまえたちは平等だ！　おまえたちは全員、平等にはしたない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021370008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「はしたない格好をさせてるのは誰よ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_010021370004" ]},
		{"command":[ "SETCHARA", "0", "char_00006702_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「では、さっそく訓練を開始する！　全員このまま外に出ろ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021370009" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「人の話をぜんぜん聞いてない……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_010021370005" ]},
		{"command":[ "SETCHARA", "0", "char_00006702_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「な？　ほら、ああなったらもうダメだって……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
