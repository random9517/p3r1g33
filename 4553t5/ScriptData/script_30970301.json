{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009703_01_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「おっと、今更逃げようたってそうはいかねぇぞ。大人しくしな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0303101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「そう不安そうな顔すんなって。これはおまえへのご褒美なんだ。楽しまない\nと損ってもんだぜ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0303102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ヘヘヘ……！　暴れたりしなきゃ、ヘヴンに連れてってやるからよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0303103" ]},
		{"command":[ "SETIMAGE", "0", "still_00009703_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ほら、おっぱいにおまえの熱いモノが挟まってるぞ。これ、好きだろ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0303104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「はははっ！　ビクビクって跳ねてやがる！　言葉じゃなくて、こいつで返事\nするとか、変態すぎるぜ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0303105" ]},
		{"command":[ "SETIMAGE", "0", "still_00009703_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「まさか気持ちよすぎて、クチもきけなくなったってか？　どんだけおっぱい\nが好きなんだよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0303106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ほらっ、ほらっ……！　こうやって、圧迫されながらスリスリされるのたま\nらねぇだろ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0303107" ]},
		{"command":[ "SETIMAGE", "0", "still_00009703_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「我慢せずに、素直に喘いでみろよ。女みたいに、あんっ、あんっ、って！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0303108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「へぇ……この程度じゃ素直にならないってか？　なら、私もちょっと本気を\n出させてもらうぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0303109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ほら、見えるか。私の唾液まみれのエッチな舌……これでおまえのモンを、\nいっぱいペロペロしてやるからな……んっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0303110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ぷちゅ……ぺろっ、れりゅっ……ぴちゃっ、くちゅ……ぷちゅ、れろれろっ\n……んっ、ちゅるるうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0303111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「んっ、あっ……くちゅるっ……！　ヘヘヘ……！　どうだ？　気持ちいいだ\nろ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0303112" ]},
		{"command":[ "SETIMAGE", "0", "still_00009703_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「おっぱいだけじゃなくて、舌使いにも自信があるんだぜ。私のフェラで、思\nいっきり喘ぎやがれ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0303113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ぴちゅるっ、ちゅるっ……くちゅ、ぺろぺろっ……んじゅ、ずりゅ……！　\nぴちゃぴちゃ……くちゅ、じゅるるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0303114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「んっ、んっ……！　ぐじゅるっ……！　へへっ。いま、我慢できずに喘いだ\nな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0303115" ]},
		{"command":[ "SETIMAGE", "0", "still_00009703_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「別に恥ずかしがることないだろ。これはご褒美なんだし。そもそも、気持ち\nいいことを気持ちいいと言って、なにが悪いんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0303116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ちゅるっ、じゅるるっ……！　ほら……理性トバしてこうぜ？　羞恥心とか\nなくしちまえば、いつも以上に気持ちよくなれるんだぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0303117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「精子びゅるびゅる出すときも、遠慮なんかしなくていいんだぞ。好きなだけ\n、私を穢していいんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0303118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「そう……罪悪感なんて感じなくていい。自分のしたいように、欲望を曝け出\nせばいい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0303119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「そのための後押しをたーっぷりしてやるよ……！　んっ、あむっ……じゅる\nっ、ぴちゃっ……！　ちゅ、ちゅるっ……じゅるるるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0303120" ]},
		{"command":[ "SETIMAGE", "0", "still_00009703_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「んっ、あふっ……！　ぴちゃっ、ぐちゅ、じゅぷっ……！　いい声で鳴くよ\nうになったな。調子出てきたじゃねぇか……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0303121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「エッチでトロトロな汁もたくさん出てきたし……そろそろ、本格的に責めさ\nせてもらうぜ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0303122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「じゅちゅ、ぐちゅ……れろぴちゅ、ちゅぱっ、ぢゅるぅ……！　あふっ、ん\nっ……くちゅ、じゅずっ、じゅろろろっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0303123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「んっ、んんっ……！　こうやって……おっぱいでシコシコされながら、舐め\nられるの……好きだろ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0303124" ]},
		{"command":[ "SETIMAGE", "0", "still_00009703_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「どこを舐めて欲しいか言ってみな……おまえのウィークポイントを、曝け出\nしちまえ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0303125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ヘヘヘ……！　このカリの裏側や裏筋……亀頭のあたりが感じるんだな……\nなら、そこを重点的に……じゅるるっ……！　ちゅ、ちゅちゅうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0303126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ぢゅ、じゅる……！　ぴちゅ、くちゅ……！　れろっ、んろっ……！　ずぽ\nっ、ちゅぴっ……くちゅくちゅ、ずぐちゅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0303127" ]},
		{"command":[ "SETIMAGE", "0", "still_00009703_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「あむっ、ぐちゅるっ……んぷはっ……！　皮の隙間も……ちゃんと舐めてや\nるからな……ぐちゅ、れりゅるるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0303128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「臭くて汚いカスも……ちゅぷっ、じゅるっ……！　全部舐めとって、綺麗に\nしてやる……じゅぞっ、ぷちゅ、れろれろっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0303129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「はあぁ……濃厚な味が舌から伝わってくるぜ……！　グレートな味だ……！\n　すごく私好みだぜ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0303130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「いいモノを味わわせてくれたし、少し過激にサービスしてやる……！　じゅ\nるるっ……！　くりゅ、ずりゅ……れろっ、んちゅぷっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0303131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ずちゅ、れろっ、じゅちゅるぅ……！　こうやって……先端部分をホジホジ\nされるの、たまらねぇだろ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0303132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ハハハっ！　先っぽに舌を捻じ込んで軽く弄っただけなのに、反応しまくり\nじゃねぇか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0303133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「じゅちゅるっ！　ちゅ、れろれろっ、くりゅりゅっ！　ビクビクがどんどん\n強くなってきてるぞっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0303134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ずぱっ、ぐちゅ、にちゅるっ！　ずっ、ぢゅぷうぅ！　我慢できねぇって感\nじだな！　ほらっ！　クチで受け止めてやるから、全部ブチまけろっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0303135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「じゅるるっ！？　んっ、あぶっ……ぐっ、じゅるるっ！　ドロドロの濃厚な\nザーメン、たくさん出てやがる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0303136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009703_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「んぐっ、ぷちゅ……！　じゅずずっ、れろっ、じゅるるるっ……！　ぴちゅ\n、ぴちゃっ！　れろっ、ちゅるるっ……じゅぞぞっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0303137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ぐっ、うぶっ……！　こんなに出すなんて、随分と溜め込んでやがったな…\n…！　ぐちゅ、じゅるっ……ぢゅぷっ、ちゅぱっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0303138" ]},
		{"command":[ "SETIMAGE", "0", "still_00009703_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「それとも……私のパイズリフェラが気持ちよくて、いつもより出してるのか\n……？　じゅちゅ、ちゅ……んっ、ぢゅううぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0303139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「まあ、どっちでもいいけどよ……！　んっ、じゅるっ……！　ほら、最後ま\nでちゃんと出しきれ……！　ちゅぱっ、ぐちゅ、れろっ……にちゅるうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0303140" ]},
		{"command":[ "SETIMAGE", "0", "still_00009703_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「んっ……じゅるっ……んくっ、ごくんっ……！　おまえのザーメン、全部飲\nんでやったぜ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0303201" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009703_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ヘヘヘ……！　本来なら女のアソコに出して、孕ませるためのモンなのに…\n…絶対に孕まない場所に出して、飲み込まれてんだぞ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0303202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「こんなにカタくて、大きくて、たくましいモン持ってんのに、私にいいよう\nにされて……ちゅ、じゅるるっ……！　男として情けないよなぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0303203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「……おいおい。あんだけ出して、しかもバカにされたってのに…まだビクビ\nク動いて、熱くなってきたぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0303204" ]},
		{"command":[ "SETIMAGE", "0", "still_00009703_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「もっとペロペロ舐めて、おっぱいでシコシコして欲しいってか？　いいぜ。\nその情けないモン、もう１回可愛がってやるよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0303205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「んちゅ……んっ、あっ……！　ぶちゅ、ぐりゅるっ……！　ちゅぱっ、れろ\nっ、ぴちゅ……じゅぽっ、れろれろっ、ぷちゅるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0303206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「どうだ……？　さっきより激しく舐められながら、おっぱいで揺さぶられる\n気分は……！　最高だろ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0303207" ]},
		{"command":[ "SETIMAGE", "0", "still_00009703_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「なんだよ、その顔……もっとして欲しいのか？　んっ、じゅちゅ……ちゅぱ\nっ、あぷっ……！　して欲しいなら、しっかり返事しな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0303208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ハハハっ！　またこのカタいモンで返事しやがったな！　気持ちよすぎて、\nクチで返事できないってか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0303209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ったく。返事もできねぇようなヤツには……んっ、じゅるっ……！　こうや\nっておっぱいに圧をかけて……ちゅぱっ、ちゅっ……いっぱい、舐めれば……\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0303210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「じゅるるっ……んっ、れろっれりゅっ……あぷっ……！　動かせねぇだろ…\n…！　ほらっ。どうして欲しいか、ちゃんとクチで言ってみなっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0303211" ]},
		{"command":[ "SETIMAGE", "0", "still_00009703_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「上手におねだりできたら……んっ、あぶっ……れろっ、じゅぱっ……ちゅち\nゅ、ぺろっ……ちゃんと出させてやるぜ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0303212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ほら、言ってみな……ゴッド様、ブッダ様、ウタマロ様……どうかこの情け\nないモノを気持ちよくして、シャセイさせてくださいって……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0303213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「あははははっ！　本当に言いやがった！　ああ、もう！　最高に無様で、可\n愛くて、弄りがいのあるヤツだぜ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0303214" ]},
		{"command":[ "SETIMAGE", "0", "still_00009703_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「約束通り、出させてやるっ！　私のパイズリフェラで、クレイジーになるほ\nど感じやがれっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0303215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ！　んっ、じゅるっ、ぐちゅっ！　ちゅぱっ、れろっ、ぷちゅるっ\n……！　じゅぞっ、ぢゅるるっ！　んぐっ、ぷちゅ、ぴちゅるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0303216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
