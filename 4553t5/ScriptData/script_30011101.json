{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE","0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「……来たぞ。こんなところに呼び出して、一体何の用事だ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1103101" ]},
	{"command":[ "SETCHARA", "0", "char_00000111_01", "0", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPTEXT", "TRUE" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「……いや、皆まで言うな。わかっている……どうせまた、ナニかハレンチな\nことを考えているのだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1103102" ]},
	{"command":[ "SETCHARA", "0", "char_00000111_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「……その顔は、図星だな？　はぁ……まったく、お前というやつは……困っ\nたものだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1103103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「このような水着姿で働かせるだけでは飽き足らず、その上まだ、何かさせよ\nうというのか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1103104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「無論、私はお前を信じている。おバカでドスケベでどうしようもないクズだ\nと言われているお前が、実はヤる時にはヤる男だとも知っている」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1103105" ]},
	{"command":[ "SETCHARA", "0", "char_00000111_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「だが、それでももう少し真面目にやってもらわねば困る。勝てる戦も勝てな\nくなるぞ？　良い機会だから言わせてもらうが、そもそもお前は──」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1103106" ]},
	{"command":[ "SETCHARA", "0", "char_00000111_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「……あ、こら！　どこへ行く！　今日は逃さんぞ！　少しばかり、お前を甘\nやかしすぎたようだ。今日という今日はキチッと話をさせてもらう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1103107" ]},
	{"command":[ "SETCHARA", "0", "char_00000111_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「む……そ、そんな目で見ても、ダメだ！　そうやって、簡単に私が絆される\nと思ったら、大間違いだぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「こ、こら…………だから、ダメだと…………くぅぅっ……わ、わかった。わ\nかったから、そんな情けない顔をするな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1103109" ]},
	{"command":[ "SETCHARA", "0", "char_00000111_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「まったく……少しだけ、だからな？　今日だけ、特別だぞ？　それで……私\nに、ナニをして欲しいんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……これで、いいのか……？　胸で挟んで、気持ちよくして欲し\nいなどと……ハレンチな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1103111" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000111_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「オマケに、コレをもうこんなにも、大きく、固くして……あっ、んっ……！\n　また、ビクってしたぞ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「わ、私の胸が、気持ちいいのか……？　し、しかたのないやつだ！　それで\n……このまま、上下に動かせばいいのか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ、ふぅっ、んふっ……これで、どうだ……？　ふぅ、ふぅ……私の胸の\n間で、お前のが、出たり入ったり……なんて、イヤらしいんだ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1103114" ]},
		{"command":[ "SETIMAGE", "0", "still_00000111_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あっ、んっ、ふぅっ……真面目に働いている者たちもいるというのに……は\nぁ、ふぅ……こんな姿で、こんなハレンチなことをするなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1103115" ]},
		{"command":[ "SETIMAGE", "0", "still_00000111_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ、んっ……こ、こら……あんまり、ジロジロと見るな……お前に、じっ\nと見つめられると……あっ、んふぅっ……少し、恥ずかしい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「な、なっ……！　へ、変なことを言うな！　カ、カワイイとか、キレイなど\nと……！　こ、こんなことをさせておいて、調子のいいやつめ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1103117" ]},
		{"command":[ "SETIMAGE", "0", "still_00000111_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「だ、だいたいだな、今の私に、そんな言葉は似合わないだろう……？　見え\n透いた世辞を言われたところで、う、嬉しくなど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1103118" ]},
		{"command":[ "SETIMAGE", "0", "still_00000111_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「っーーーー！！？　わ、わかったから……もう、やめてくれ……うぅぅっ…\n…顔が、熱い……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1103119" ]},
		{"command":[ "SETIMAGE", "0", "still_00000111_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ、ふぅ、ふぅ……肌が、ざわざわして……あっ、んっ……身体が、落ち\n着かない……うぅぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1103120" ]},
		{"command":[ "SETIMAGE", "0", "still_00000111_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「いいから、お前はコッチに集中しろ……んっ、んっ、ふぅっ……自分が気持\nちよくなることだけを、考えればいい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あっ、んっ、すごい、さっきよりも大きくなって……んふぅっ、先っぽの、\n亀頭のところが……パンパンに、腫れ上がってきた……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁっ、割れ目のところが、パクパクと動いて……あっ、あっ、透明な、先\n走りのお汁が、こぼれてきた……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1103123" ]},
		{"command":[ "SETIMAGE", "0", "still_00000111_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ふぅ、ふぅ……どうだ……？　あんっ、んっ、んっ、私の、おっぱいは……\nあっ、んふぅぅっ……キモチイイか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1103124" ]},
		{"command":[ "SETIMAGE", "0", "still_00000111_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁ、ふぅ、ふぅ……わ、私は、べつに……あんっ、あふぅっ、お前のオチ\nンポを、シゴいて、興奮など……あふぅんっ……していないぞ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、オチンポが、さっきよりおっきくなって……んふぅっ、私の胸\nに挟まれて、ビクビク、震えている……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「もう、イきそうなのか……？　んっ、ふぅ、あふぅっ、いいぞ、イっても…\n…？　ガマンなど、しなくていいんだぞ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「私のおっぱいで、お前のオチンポを、たくさん擦ってやるからな……んっ、\nふぅ、ふぅっ……思う存分、射精してくれ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁっ、そうだ……お前の気持ちよさそうな顔を、見せてくれ……！　んっ\n、ふぅっ、可愛い声を、たくさん……私に、聞かせてくれ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ、んっ、私のおっぱいで、オチンポを挟まれて、シコシコ、擦られて、\nそら、イけ、イってくれ、出して、精液、いっぱい、射精して……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ふあぁああっ！？　あぁっ、すごいっ……！　こんなに、いっぱい……！？\n　お前の精液が、私のおっぱいに……あぅんっ、熱いっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1103131" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000111_01_05" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「おっぱいの間で、お前のオチンポが、ビクビクふるえて……あっ、またっ…\n…！　先っぽから、びゅる、びゅるって、白いのが、出てるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ、んっ……もっと出して、いいんだぞ……？　ほら……んっ、ふぅっ、\nふぅっ、おっぱいで挟んで、絞ってやる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あんっ、またっ……！　射精しながら、オチンポをシゴかれるのは……んっ\n、ふぅっ、気持ちいい、のか……？　ふふっ、いいぞ、いくらでもシてやる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ、ふぅっ、ふぅっ……私のパイズリで、オチンポいっぱい、気持ちよく\nなれ……好きなだけ、射精してくれ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1103135" ]},
		{"command":[ "SETIMAGE", "0", "still_00000111_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……あぁ、すごい……こんなに、出るなんて……。私のおっぱい\nが、お前の精液で……ヌルヌルだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1103136" ]},
		{"command":[ "SETIMAGE", "0", "still_00000111_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ……熱くて、ドロドロで……すぅっ……はあぁぁっ……なんて、イヤら\nしいニオイなんだ……これが、男の……お前の、ニオイなんだな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1103137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「なんだ、だらしない顔をして……んっ、そんなに私のパイズリが、気持ち良\nかったのか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1103138" ]},
		{"command":[ "SETIMAGE", "0", "still_00000111_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「……ふふっ、そうか。んっ、ふっ……まだ、少し、出ているな……んっ、オ\nチンポの先っぽから、とろとろと、精液が……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「私が、絞ってやろう……んっ、んっ……こうして、おっぱいで、ナカに残っ\nている精液も……ふぅっ、んぅっ、んふぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ……これ、は……あんっ、んふぅっ、心なしか、また……オチンポが、\n固くなってきたような……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1103201" ]},
		{"command":[ "SETIMAGE", "0", "still_00000111_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「……もしかして、もっと、シて欲しいのか……？　んっ、ふぅ、ふぅっ、私\nのおっぱいで、もっと……射精、したいのか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1103202" ]},
		{"command":[ "SETIMAGE", "0", "still_00000111_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「そ、そうか……まったく、しかたのないやつだな……あんっ、私のおっぱい\nを、こんなにしておきながら……あんっ、まだ、物足りないなどと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1103203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「だ、だが、こんなに大きくしたままじゃ、外も歩けないからな……そ、それ\nに……ほかの女性たちに、手を出されても、その、困るからな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1103204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「も、もう一回だけ……シてやろう……し、しかたなく、だぞ？　べ、べつに\n、私が好きでやっているわけでは、ないのだからな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ、んふぁっ、あんっ……精液で、ぬるぬるして……んっ、んくぅっ……\nオチンポが、すべる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1103206" ]},
		{"command":[ "SETIMAGE", "0", "still_00000111_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「もっと、強く……んっ、んんっ……おっぱいで、ぎゅっと、包み込んで、ん\nっ、くふぅっ……上下に……んっ、ふっ、くぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あっ、んっ、んうぅぅっ……おっぱいの間を、固くて、大きいのが……あふ\nっ、んくぅぅっ、出たり、入ったり……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「オチンポが、さっきより、擦れてっ……あんっ、んふぁぁっ、イヤらしいカ\nタチが、はっきりと、わかってしまう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「カチカチで、反り返っていて、あっ、あっ、でっぱりの、雁首のところが、\nずりゅずりゅっ、あふぅんっ、おっぱいのナカを、擦っている……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1103210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あんっ、んっ、んふぅっ、私の、おっぱいが、あんっ、お前の、オチンポの\nカタチになる……んふぅぅっ、カタチを、覚えてしまうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、精液が泡立って……んぅぅっ、グチュグチュ、イヤらしい音を\n立ててる……！　んふうぅっ、なんて、ハレンチな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁぁっ……ニオイも、すごい……んふぅぅっ、オチンポの……精\n液の、臭い……んふぅぅっ……！　頭が、クラクラ、する……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
