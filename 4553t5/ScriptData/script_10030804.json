		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「なるほど、そういうことですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_020115680001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "驚く私たちのもとに、唐突に牛神様が現れた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
