		{"command":[ "PLAYVOICE", "v2_016_010115680002" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「さっきの戦闘で、この古時計の力が戻ったのでしょう。みなさんの魔力を吸\nって、再起動したようです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_020115680002" ]},
