		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「次は勝つからな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080115680001" ]},
		{"command":[ "SETCHARA", "0", "char_00000408_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「次に会ったときが、運の尽きです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010115680001" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "戦力が充実していたこともあり、時間帝国には圧勝。彼女らが盗もうとしてい\nた古時計も回収した。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「ふぅ。時計に破損は……なさそうですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020115680001" ]},
		{"command":[ "SETCHARA", "0", "char_00002602_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああ……そうみたいだな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「お前たちのところの学園長、めちゃくちゃな強さだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115680001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「ああ、ゆえに我々の首領なんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010115680001" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「でも、やっぱり普通の古時計だよなー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010115680001" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「かわったところはないわよねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010115680001" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「とりあえず持ち帰ってみればいいじゃないか。……またこれじゃないって言\nわれるのは勘弁だけどさ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010115680001" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「そうですね。それらしいものはこれしかないようですし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010115680001" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "まりあが時計に近づき、触れた瞬間。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「え……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010115680002" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "まりあの足元に、光の渦が出現した。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「きゃぁあああぁぁぁっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010115680003" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まりあ！　……って、うわぁあああぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "渦の中に落ちてしまうまりあ。カツマが助けようと飛びだして、かろうじて手\nを掴んだが、一緒に落ちてしまう。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「お姉ちゃん！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010115680001" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「こ、これはどうなっているのである！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_010115680001" ]},
		{"command":[ "SETCHARA", "0", "char_00002001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「フフフ……やっぱりいわくつきの時計だったんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010115680001" ]},
		{"command":[ "SETCHARA", "0", "char_00001801_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
