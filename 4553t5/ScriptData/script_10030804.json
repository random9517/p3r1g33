		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ええい、とにかくカツマを助けに行くぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115680002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
