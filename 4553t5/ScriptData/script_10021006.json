		{"command":[ "SETNAME", "グリムロックの部下" ]},
		{"command":[ "SETTEXT", "「くううっ！　原住民どもめっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_010114240001" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「すまない！　だが、しばらく体育館に入っていてくれ！　必ず元に戻すから\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090114240001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0150" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「なんてこった！　うちの子たちまでやられたのか！？　ホントにやっかいな\nガスだな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010114240001" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「Ｄｒ.サイレーン！　いいとこに来たぜ！　こいつらを体育館へ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「もちろん連れてくよ！　でもね、もうこれ以上は無理だ！　ガスの被害が広\nがりすぎてる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010114240002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なに！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「体育館は、変身した学生たちでいっぱいなんだよ！　もう入らない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010114240003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんだとぉ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「下校時間はとっくに過ぎてたはずだよ！　どうしてそんなに学生が残ってた\nんだい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010114240001" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「そこ、いま気にするとこぉ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010114240001" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「とにかく、このままじゃダメだ！　他の手を打たないと！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010114240004" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「他の手？　他の手と言われてもな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114240001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ガスだ！　ガスの元を断つんだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090114240002" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「って言われても～？　それ、いったいどこなわけ～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_010114240001" ]},
		{"command":[ "SETCHARA", "0", "char_00001501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうだな……あのガスは、いったいどこから流れて来てるんだ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「そのことなのですが、屋上に行ってみてください。おかしな人たちがいるよ\nうです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_020114240001" ]},
		{"command":[ "SETCHARA", "0", "char_00003002_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「屋上～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_010114240002" ]},
		{"command":[ "SETCHARA", "0", "char_00001501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「たしかに、あのガスは空気より重いはずだ。屋上に陣取るのは理にかなって\nいるな。カツマ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090114240003" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ．サイレーン" ]},
		{"command":[ "SETTEXT", "「体育館はボクらが引き受ける！　屋上は頼んだよ！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おう！　みんな、屋上へ急ぐぞ！　翔生子も来てくれ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「は、はいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010114240001" ]},
