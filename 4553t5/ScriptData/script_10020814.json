		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "塾生三号" ]},
		{"command":[ "SETTEXT", "「古い作品だからレンタルでもなかなか見かけなかったんだけど」", "NORMAL" ]},
