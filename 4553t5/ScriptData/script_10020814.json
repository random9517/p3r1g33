		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "塾生二号" ]},
		{"command":[ "SETTEXT", "「『１万年と２０００年前からのプロポーズ』海外版……！？」", "NORMAL" ]},
