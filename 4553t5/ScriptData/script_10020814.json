		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "塾生二号" ]},
		{"command":[ "SETTEXT", "「体育会系が駄目だったなら、今度は文系で攻めるんです！」", "NORMAL" ]},
