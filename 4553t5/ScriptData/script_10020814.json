		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "塾生三号" ]},
		{"command":[ "SETTEXT", "「とあるショップでワゴンセールに入ってたから、買っちゃいました！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "塾生一号" ]},
