{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「ああ……誤魔化そうとしなくていい。こうして呼ばれて、隊長が何を求めて\nいるのか……もうわかるさ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0104101" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00011001_01", "0", "CENTER", "0" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「おかしなことだ。妹を失い、この世のすべてに絶望し、ただ悪を滅ぼす戦い\nだけにこの身を捧げたはずなのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「隊長。いつの間にか……私の心にはあなたがいた。大勢いる中のひとりでも\n構わない。それでも……あなたと繋がりたい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0104103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「だから、私にも……このひとときだけ、あなたを感じさせてほしいんだ。戦\n士ではなく、ひとりの女として」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0104104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「大丈夫だ。必要な知識は、もうあなたから学ばせてもらったさ。だから、任\nせてほしい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0104105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「いつも教えてもらってばかりの隊長に、初めてを捧げる今日くらいは、私が\n……あなたに奉仕したい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0104106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「んっ、ああ、わかる……くふっ、あぁ、隊長の大きなチンポっ、私のここ…\n…オマンコ……当たるだけで、もうっ、ふぁあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0104107" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00011001_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「はぁはぁ、ああ、こ、これで根を上げるほど軟弱ではない。このまま腰を落\nとして……くっ、あぁっ、あふぁあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0104108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「はうぅっ、いいぃっ、あぁ、は、入った……全部っ、くうぅっ、あぁ、隊長\nのチンポ……全部、私の中に……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0104109" ]},
		{"command":[ "SETIMAGE", "0", "still_00011001_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「ああ、思ったより中が窮屈だが、大丈夫だ。痛み……というより、熱く痺れ\nるような感じが……んぅっ、はぅぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0104110" ]},
		{"command":[ "SETIMAGE", "0", "still_00011001_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「耐えられなくはないし……これが、隊長とひとつになれた証だと思うと、と\nても幸せに思える……ふふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0104111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「ただ繋がっているだけで、ずっと乾き続けていた胸の奥が満たされていくよ\nうな……ふふっ、何なのだろう、この幸せな気持ちは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0104112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「んぅっ、隊長も感じてくれているのか？　私の中で、チンポが元気に震えて\nいる……んぅっ、ますますふくらんできたようだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0104113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「私も……もっと動きたい。お腹の奥が切なくて、ここ……子宮で、隊長を感\nじたくて、我慢できない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0104114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「はぁっ、ひぃっ、んんんっ！　あぁ、腰が勝手に動いてしまう。奥、奥まで\n、チンポ……ほしくてっ、はふううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0104115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「あぁっ、はぁはぁ、お尻を振って、胸……おっぱいをいやらしく揺らしてぇ\nっ、はしたないのに、こんな……くうううっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0104116" ]},
		{"command":[ "SETIMAGE", "0", "still_00011001_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「でも、止められないっ。あふぅっ、あぁ、チンポの先で、子宮、軽く突かれ\nるだけで……もうっ、はひっ、ふぁああんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0104117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「声がっ、恥ずかしい声が止まらない。はひっ、くぅぅっ、んぅっ、隊長……\nはぁっ、隊長っ、くうううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0104118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「中が熱い……濡れているのか、私の中……オマンコ、隊長を求めて、淫らに\n濡れて……蕩けてっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「あんぅっ、あぁ、ふふっ、自分でも驚いている。黒衣の死神と呼ばれた私に\n、まだこんな女としての想いが残っていたなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0104120" ]},
		{"command":[ "SETIMAGE", "0", "still_00011001_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「だが、今はそれが嬉しい。おかげで、こうして隊長に思いをっ、身体を捧げ\nられているのだから……幸せっ、はひぃぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0104121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「はぁっ、もっとっ、んくっ、もっと激しくっ、くううっ、チンポで私の中に\n、隊長の形を刻み込んでくれっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「私があなたのものだとっ、オマンコで感じさせて……ひぃっ、くふぁあっ、\nいぃっ、あんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0104123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「んくぅぅっ、そこっ、あぁ、チンポの出入りする角度が変わって、端っこ…\n…クリトリスにこすれているっ、ひいいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0104124" ]},
		{"command":[ "SETIMAGE", "0", "still_00011001_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「んんぅっ、あぁ、そこっ、ダメだっ。気持ちよすぎて、意識が飛んでしまう\n。ひゃうううっ、ふぁっ、ああああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「いぃっ、中が勝手に締まってっ、んくっ、そこっ、隊長のチンポでゴリゴリ\nいっぱいこすられて、広げられてぇ、ふぁああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「あぁ、一緒にっ、一緒にイキたいっ。隊長の精液っ、熱いモノ、お腹いっぱ\nいに感じてっ、イク……イキたいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0104127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「ああ。もっと早く、腰、動かす……お尻、隊長の腰で弾ませるように振って\n……いやらしくっ、もっと淫らにっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「はぁはぁ、胸も揺れてっ、んぅっ、あぁ、隊長の目線、乳首に感じるっ。淫\nらに尖っているところっ、見られて……くぅぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0104129" ]},
		{"command":[ "SETIMAGE", "0", "still_00011001_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「恥ずかしくて、嬉しくてぇ、もうっ、あぁっ、全身、隊長に愛されているよ\nうで……はひっ、ふぁあああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「きてくれ、隊長っ。一緒に……ふぁああっ、あぁっ、くるっ、きてしまうっ\n、もう少しでっ、ひんっ、あひぃいい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「もっと深くまで……お尻っ、思い切り落としてっ、子宮の中までチンポが届\nくように、くうううっ、イク……くぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「出してくれ、隊長。このままっ、ふぁあああっ、もうっ、イク、私、イク、\n一緒、一緒にっ、イクッ、くううううううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「くふぁあああああっ、イィッ、あぁっ、熱いのっ、きてぇっ、イッ……んく\nううううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「ふぁあああ……あぁ、奥にドクドクと、勢いよく流れ込んできているぅ……\n精液、熱いのぉ……はぁはぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0104135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00011001_02_05" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「お腹の奥が熱い……んぅっ、あぁ……こんなに心地よい温もり、他では決し\nて味わえないだろう……はふぅ……はぁはぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0104136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「ふふっ、まだ私の中で元気に震えて、精を注いでくれようとしている……隊\n長のチンポ……愛おしい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0104137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「はふぅ……はぁはぁ、死神と呼ばれた私が、新たな命を生み出せるのかもし\nれないと思うと……不思議な感覚だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「……まさか、こんな喜びを味わえる日が来るなんて。……だが、一度味わっ\nてしまったら、すっかり癖になってしまったよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0104139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「まだ物足りない。もっと……もっと、私に教えてくれ。ただの女として、あ\nなたに尽くす喜びを。愛している、隊長……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「ん……隊長？　また動き出して……？　もしかしてもう一度、私を愛してく\nれるのか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0104201" ]},
		{"command":[ "SETIMAGE", "0", "still_00011001_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「ああ……嬉しいぞ！　もう一度、あの快楽を味わわせてくれるのか……んん\nんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「ん、ん、んんっ！　隊長の熱く、硬いものが、ゆっくりと動き始めて……ん\n、んっ！　ああっ！　はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「ああ……大丈夫だ、さっきより、だいぶ楽になってきた。楽になって、隊長\nのものをじっくりと味わえるように……ああぁあん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0104204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「あ、ああああっ……体が……体がむずむずする。隊長の熱いものを、もっと\nもっと味わいたくて……んんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0104205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「あ、あ、あ、あ、腰が……！　あああ、腰が止まらないっ！　あああああっ\n……隊長……っ！　チンポ欲しい！　もっとだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0104206" ]},
		{"command":[ "SETIMAGE", "0", "still_00011001_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「んあっ！　あっ！　あっ！　そうだ！　隊長、そうだ！　そうやって、腰を\nぐいぐいと打ち付けて……んあぁあああん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「はぁっ、はっ、はっ、あっ、あっ、あっ！　あああ～っ！　いいっ！　いい\nぞ、隊長！　隊長のゴリゴリしたチンポが、膣内で……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「あああ、こすれるっ！　こすれるっ！　いい……ふぁああん！　一気に奥ま\nでぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「あ、あっ！　あああん！　ふぁああん！　そうだ！　奥のほう！　奥の方を\nえぐってくれ……ぁああん！　あんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0104210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「あ、あ、あ……くぅっ！　ど、どうだ……？　隊長！　私の、腰の振り方は\n……もっとか！？　もっとだな！？　よしわかった！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0104211" ]},
		{"command":[ "SETIMAGE", "0", "still_00011001_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「ああああああっ！　隊長っ！　隊長もだ！　もっと動いてくれっ！　もっと\n私の中をゴリゴリと……はぁああん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0104212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン." ]},
		{"command":[ "SETTEXT", "「ん、ん、ん、んんんんっ！　んっ、はぁああん！　あんっ！　あああああ…\n…はぁああん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0104213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「ああ……知らなかった！　世の中に、こんなに気持ちいいものがあるなんて\n……はぁあっ！　ああああん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0104214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「私はもう、これなしでは！　隊長のチンポなしではいられないっ！　チンポ\n！　チンポ最高だぁあああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0104215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「んっ！　んんんっ！　くぅううっ……！　た、隊長！　チンポがヒクヒクし\n始めたぞ。もう……出るのかっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0104216" ]},
		{"command":[ "SETIMAGE", "0", "still_00011001_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「あ、ああっ！　私もだ！　私も、もう……イクッ！　イクッ！　イッてしま\nうっ……んんんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0104217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「んぁあああっ！？　あっ！　はっ！　そ、そんなに激しくされたら、本当に\nイッてしまうっ！　ああああ、ダメだ！　ダメダメダメダメ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0104218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「あ、あ、あ、あああああああああっ！　ひぃいいいっ！　ああああああああ\n～んっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0104219" ]},
		{"command":[ "SETIMAGE", "0", "still_00011001_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「あ、あ、ああああっ！　隊長もか！？　あああっ！　きてくれっ！　私の中\nに、熱いものを思いっきり……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0104220" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},
		{"command":[ "LABEL", "LABEL1" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「んはぁっ！　あ、あ、ああああああっ！　はぁああああああ～んっ！　隊長\n……出ているっ！　出ているぞぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0104301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00011001_02_08" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「あ、あ、あああっ！　子宮の奥の奥まで……っ！　ふぁああああっ……！　\n隊長の、熱い精液が……！　はぁあああっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「たまらない……っ！　熱い精液が流れ込んでくるこの感覚が……！　一度味\nわうと病みつきに……！　はぁあああああ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0104303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「あっ、あああっ……まだ出ている……！　隊長のチンポが、私の中で大きく\n跳ねながら、精液を……あああああ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0104304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「あ、あ、あっ……はぁ……はぁ……んんっ……お腹の中が……精液でいっぱ\nいだ……暖かい……なんて心地よい暖かさだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0104305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「隊長、これで……私は母親になれるのだろうか、こんな私でも、お前との子\n供を産み、育てることが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0104306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「え！？　それはわからない？　そ、そうなのか？　やはり、死神では子供の\n親になることなど……え？　そうではない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0104307" ]},
		{"command":[ "SETIMAGE", "0", "still_00011001_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「ああ、そうか。一度や二度では、出来ているかどうかわからないということ\nか……理解した。そういうことであれば、隊長」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0104308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「これからも、私の中にどんどん出してくれ。私の中に生命の素をどんどん放\n出してくれ。頼む」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「他者の命を奪うことしか知らなかった私が、愛する人と新しい生命を生み出\nせるのなら、こんなに素晴らしいことはない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},
		{"command":[ "LABEL", "LABEL2" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「ああああああん！　なにをするんだ！　誰がチンポを抜けと……はぁあああ\nあっ！？　精液が！？　飛んでくるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0104401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00011001_02_12" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「あっ！？　あああああっ！　はぁああああ……っ！　あああっ……隊長のチ\nンポから……新鮮な精液が……！　あぁああああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0104402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「オマンコにも……腹にも、胸にも……熱い精液が、どくどくと降り注いで…\n…はぁあああ……ああっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0104403" ]},
		{"command":[ "SETIMAGE", "0", "still_00011001_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「ん、んんんっ……マグマのような精液が、私の肌を染めていく……はぁああ\nあ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0104404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「あ、あああああ……隊長が、私の全身に……ああああああ……もっとだ、も\nっと浴びせてくれ……はぁああ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0104405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「まるで体全体に、隊長を感じるようだ……このドロドロネバネバした感じ、\nまさに隊長だ……ああああ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0104406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「そうか、これが狙いだったのだな、隊長。こうすればオマンコの中だけでは\nなく、外でも隊長とつながっていられる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0104407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「いまや私の中も、外も……すべてが隊長のもの、隊長と一体だ……はぁああ\nあ……っ！　そう考えるとゾクゾクしてくるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0104408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「この匂いも、もはや私の匂い……隊長は私、私は隊長だ……あああああ……\nなんて素晴らしい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0104409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「隊長、もっとかけてくれ。もっともっと、あなたと深くつながりたい……。\n愛しているぞ、隊長……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0104410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
	{"command":[ "EXIT" ]}
