		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「んぁぁぁぁぁーっ！　またっ……熱いの出てりゅっ、また中にっ……出され\nてるっ……どぷって……来てる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0104301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00020601_02_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「あへぁ……イッてるオマンコに中出しぃ……口元……緩んじゃう……ア、ア\nヘ顔見られちゃう……だらしない顔見せちゃうぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「あぁ……でも、もう何でもいい……ずぶって挿し込まれてるオチンポ気持ち\nいいからぁ……ま、まだ射精続いてるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0104303" ]},
		{"command":[ "SETIMAGE", "0", "still_00020601_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「んふぁ、あぁ……すご……ドピュって出しながら……まだオチンポ動かされ\nてる……はひ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0104304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「あ……ふっ、んんっ……！　い、今ので……最後……？　ホントに……ホン\nト……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0104305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「はぁぁ……また……めちゃくちゃにされちゃった……２回も中出しされて…\n…恥ずかしい顔、全部見られて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0104306" ]},
		{"command":[ "SETIMAGE", "0", "still_00020601_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「うぅ……こんなのクセになったらどうしてくれるの……責任取ってくれるの\nぉ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0104307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「あ、だから……つまり、その……確かに、恥ずかしくて……キツかったけど\n……イ、イヤって感じじゃなかったと言うか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0104308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「アタシ……こういう風にされるの、好きなのかな……あぁぁ、正義の味方の\n筈が変態なんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「や、やっぱり責任取ってくれなきゃだよね！　これっきりにしたら許さない\nからっ、ま、また次もっ……ねっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「んぁぁぁぁぁーっ！　あっ、びゅるって出てるっ……お尻っ……熱いのっ、\n掛かってるぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0104401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00020601_02_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「はぁんっ、アタシもまたイクっ……！　はぁぁ……オマンコ……おっぱい…\n…気持ちよくて……ずっとプルプル震えてるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0104402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「あぁ……もう、こうなったら……全部出してぇ……残ってるオチンポミルク\n……精液ぃ……アタシにぶち撒けてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0104403" ]},
		{"command":[ "SETIMAGE", "0", "still_00020601_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「はぁぁ……そ、そんなマジマジと顔見ないでぇ……恥ずかしいイキ顔……も\n、戻せないんだからぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0104404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「んふっ……あぁ……はぁ……も、もう終わり……？　あっ……今……出たの\nで……ちゃんと、最後……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0104405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……はぁ……あ……ふぁ……やだ……腰に力入んない……、こ、\nこんな恥ずかしいカッコのままなんてぇ……」", "NORMAL" ]},
