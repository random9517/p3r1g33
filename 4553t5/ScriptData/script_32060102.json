{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00020601_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「あ、あのっ、ちょっ……ちょっーと待ってっ、ね、ねぇっ、これっ……あの\n、また身動き取れないんだけどっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0104101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「確か、予定では……その、アタシと……色々関係を深めるというか……せ、\nセックスするって感じの話だったよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「ていうか、前も同じようなパターンだった気がするんだけど……な、何で、\nカラダ……拘束されて……足、ひ、広げさせられてるの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0104103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「こ、ここが悪の組織の秘密基地……い、いやでもそれ言ったら、アタシだっ\nて今はその一員でっ、本当は正義の味方だけど、けどっ、うひぁっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0104104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「あっ、まっ、またっ……お、おっぱいっ！　乳首にっ……変なのっ、あ、当\nたってるぅ！　くっ、あぁんっ、あひぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0104105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「まっ……待ってって！　い、一応っ……好きにしていいっていうかっ、普通\nに手で揉んでもいいのにっ、何でっ……マシンなの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0104106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「き、気持ちいいかも知れないけどっ、そこはもっと、乙女心というかっ、色\n々汲んでくれてもいいものがっ、あっ、両方摘むのっ、はへぇっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0104107" ]},
		{"command":[ "SETIMAGE", "0", "still_00020601_02_16" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「あっ、ひゃ……ふっ……何でぇ……あっ、あぁっ……くにくにっ……んっ、\nされて……あっ、弱いのにっ……はひっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0104108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「あ……あぁっ、やだ……この前の時から、んくっ、これ……感じやすくなっ\nてるのに……そ、その気になって来ちゃうっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0104109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「そ、それに……あの、お尻に、何か当たってるんですけど……これ……オ、\nオチンポ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0104110" ]},
		{"command":[ "SETIMAGE", "0", "still_00020601_02_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「ひぁっ……あ……擦って来てる……んくぅ、こんな風にされたら……ま、ま\nた疼いて来ちゃう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0104111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「あ……あぁ……ダメ……待ちきれない……オ、オマンコ……その気になって\nるからぁ……あっ、はぁっ、んぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0104112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「も、もう入る……？　入ってきちゃう……？　あ……あぁっ、ずっと滑らせ\nてるだけなのっ……ず、ずるいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0104113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「はぁんっ、あぁっ……ダメ……乳首でその気にさせといてぇ……焦らすばっ\nかりとかぁ……早くっ……早く入れてってばぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0104114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「だからっ、オチンポっ！　お前のっ……ギンギンになってるオチンポをっ！\n　早くっ……中っ、オマンコっ、オマンコに入れてぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0104115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「んぁぅんっ！　あっ……はっ、あぁぁっ……あっ……んくぁぁぁぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0104116" ]},
		{"command":[ "SETIMAGE", "0", "still_00020601_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「あっ……あぁぁ……全部入っちゃった……そんな、アタシ……そんな、慣れ\nてる訳じゃ……ない、のにっ……くふぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0104117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「あぁぁ……でも、ま、前から知ってるみたいな、この感じ……はぁぁ、オマ\nンコのお肉が……よ、悦んじゃってるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0104118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「はぅっ……んぁっ！　あぁっ、あひっ、あっ、動かしてっ……んくぅっ、ズ\nボズボってっ……オマンコっ、かき混ぜてぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0104119" ]},
		{"command":[ "SETIMAGE", "0", "still_00020601_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「はんっ、あっ、あぁっ……す、すごいっ……音してるっ、あひっ、ぐちゅっ\nて……こ、これ……アタシのオマンコがさせてる音ぉっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0104120" ]},
		{"command":[ "SETIMAGE", "0", "still_00020601_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「はぁっ、んひぁっ、は、恥ずかしいっ……けどっ、んんっ、こ、興奮っ……\nするぅっ、ふぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0104121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「ひぁっ！　あっ……そんな、機械も一緒になんてっ……乳首っ、さっきより\n痺れてるのにっ、あおぉん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「あんっ、はっ、ひあっ、でもっ……これっ、前した時よりいいっ……オチン\nポが本物になってるからっ、ずっと気持ちいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0104123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「はぁんっ、あぁっ、ぱんぱんって……お尻に当たる音ぉっ、こ、こんな激し\nくされてるのにっ、アタシっ……メチャクチャ良くなってるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0104124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「あんっ、ああっ、す、スケベとかっ……そんなっ、そんな言い方ぁっ！　こ\nんなっ、捕まって……好きにされたらっ、誰だってなるからっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「はんっ、アタシだって……スケベになるっ、スケベにさせられるのっ、こん\nなオチンポっ……絶対ダメになるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「あっ、ひぁんっ！　あぁっ、そこっ、またグリグリかき回されたらぁっ！　\nすぐっ、ダメになるっ、ひぁっ、イクっ、イッちゃうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0104127" ]},
		{"command":[ "SETIMAGE", "0", "still_00020601_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「イッ……イクっ！　んぁぁぁんっ！　オチンポでイクっ！　んひぃっ、オッ\nパイもイクっ、どっちもイクぅぅぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「はぁぁ……んぁぁぁ……アタマ、おかしくなる……あぁぁ、全部……れんぶ\n……いいのぉ……はひぁぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「あ……はぁぁ……お汁が漏れちゃう……あへぁ……は、ぁぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「ひゃ……んひっ！　あっ……また、休み……なしっ？　ひっ、あぁっ、イ、\nイッてるオマンコにっ……また熱いオチンポぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「はぁんっ、あっ……ひぁっ、ぐちゅぐちゅっ、い、いやらしい音してぇっ、\nはんっ、あっ、アタシっ……ずっと蕩けてるのっ、んひぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「あぅんっ！　オチンポも……出たがってるのっ？　あぁっ、でもっ、アタシ\nもっ……待ちきれないっ、あへぁっ、あぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「イクっ……またオマンコイクのっ……！　ひぁんっ、ダメっ……あひぃっ、\nイクぅぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「んぁぁぁ……あっ、出されてるっ……直接中に……オマンコ……射精されて\nるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0104135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00020601_02_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「はぁぁ、こ、これって……種付け……？　あぁ……身動きとれないのに……\n全部中出しなんて……んぁ……でも気持ちいい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0104136" ]},
		{"command":[ "SETIMAGE", "0", "still_00020601_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「もう、お嫁に行けない……ずっと、慰みものになっちゃうんだ……あっ、ん\nぁっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0104202" ]},
		{"command":[ "SETIMAGE", "0", "still_00020601_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「ちょっ……ひ、人が感傷に浸ってる時にっ……ナニ、普通に続きしようとし\nてるワケっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0104203" ]},
		{"command":[ "SETIMAGE", "0", "still_00020601_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「ア、アタシの顔見てムラムラ来たってっ……！　もうちょい言い方っ……ひ\nゃひっ！　あっ、またっ……奥ぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0104204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「はんっ、あぅっ、うんっ、あぁっ、さ、さっきよりっ……ガツガツ来てるん\nだけどっ、イッたばっかでっ、ジンジンしてるのにっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0104205" ]},
		{"command":[ "SETIMAGE", "0", "still_00020601_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「あひっ、あぁっ、ずりゅってされてるっ！　中出しされた精液っ……はんっ\n、あっ、かき回されてるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0104206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「ひっ！？　ウ、ウソっ……またっ……マシン動いてきて……あ、ひゃぁっ！\n　またっ……おっぱいもまたぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「あっ……やだっ……何で、今更っ……動きが絶妙になってるのっ？　はぁん\nっ、そ、そんなピンポイントにくすぐっちゃ……ひゃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0104208" ]},
		{"command":[ "SETIMAGE", "0", "still_00020601_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「あっ、ダメっ……今、コリコリになっちゃってるからっ、先っちょっ……摘\nむのっ、はへぁぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「ひゃふっ……ちょっ、そっちまでっ……背中に指っ、つぅって……！　これ\n以上っ、刺激増やしちゃダメっ、あっ、はぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0104210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「背中がダメならお尻とかっ、そういうことじゃないのっ！　あぁんっ、揉み\nたくらないでっ、もっ……何されても気持ちいいからっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0104211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「はんっ、あぁっ、またイクっ……イッちゃうっ！　いひぃんっ、オマンコダ\nメッ、気持ちよすぎてっ、ま、またオマンコイクぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0104212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「はぁぁぁ……あぁ……あぁ、また……イッた……顔……緩んじゃう……また\n、イキ顔……見せちゃってるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0104213" ]},
		{"command":[ "SETIMAGE", "0", "still_00020601_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「あぁぁ……恥ずかしいのに……んぅ、オマンコ……勝手にヒクヒクしちゃう\n……んくぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0104214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「んふぁ……あぁ、中で……オチンポがビクビクしてるの分かるぅ……敏感に\nなり過ぎて……感覚がおかしくなってるの……はぁぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0104215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「はひっ！　あっ、ま、まだするのっ？　も、もぉ……アタシ……腰っ……支\nえてられないのっ……んぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0104216" ]},
		{"command":[ "SETIMAGE", "0", "still_00020601_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「あ……あぁっ、そんな……お尻むぎゅって鷲掴みしてぇっ……確かに固定さ\nれたけどっ、んひぃぃんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0104217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「はぁっ、あぁっ、あっ、オチンポ、また奥までっ……何回もされてぇっ……\n続けてイクっ、オマンコ気持ちよくなりすぎちゃうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0104218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「オ、オチンポの方もっ？　もっ……何でもいいからっ、好きに出していいか\nらっ……また射精してっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0104219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「あぁっ、アタシもイクっ……続けてイクのっ、くひぃっ、オマンコッ……イ\nックぅぅぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0104220" ]},
		{"command":[ "WAITINPUT" ]},

