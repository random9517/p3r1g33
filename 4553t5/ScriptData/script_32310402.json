{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00023104_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「おおぉっ！？　思ったより積極的ぃ♪　そんなにボクのマンコにハメハメし\nたかったぁ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0404101" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んぁっ、ああ……っ。ガッチガチのチンポが、マンコにこすりつけられてる\nぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0404102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……。発情アピールしすぎぃ……。まだ挿れてないのに、ヘコヘ\nコ腰振っちゃってぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0404103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「そんなにハメたかったら……んふっ、いいよぉ、キミのデカチンポ、ボクの\nマンコに挿れちゃって～……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0404104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「あはぁあああぁぁぁっ！　ちょ、ちょっとぉ、いきなり深くチンポ突っ込ま\nなくっても……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0404105" ]},
		{"command":[ "SETIMAGE", "0", "still_00023104_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「マンコがびしょ濡れ過ぎるからだって？　そ、そりゃあボクも濡らしてたけ\nどさぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0404106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「へ？　さっきのでイッただろって？　いやいや、そんなわけないじゃん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0404107" ]},
		{"command":[ "SETIMAGE", "0", "still_00023104_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ボクがキミのデカチンのひと突きでイクような、クソザコマンコの持ち主だ\nと思ったら大間違い……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0404108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「くひんっ！　ちょっ、また奥突いたっ！　おっ、おおっ、ちょっとぉっ！？\n　んぁっ、あっ、ああぁっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0404109" ]},
		{"command":[ "SETIMAGE", "0", "still_00023104_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「カリ高……勃起チンポで……。ゆっくりボクのマン肉ぞりぞりひっかきなが\nら、腰引いて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0404110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ひゃはぁっ！！　一気に奥まで、チンポぶちこんでくるぅっ！　んぁあっ、\nあっ、まってそれ、反則ぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0404111" ]},
		{"command":[ "SETIMAGE", "0", "still_00023104_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んひっ、はぁっ、あひぃっ！　抜ける、チンポと一緒にぃ、ボクのマン汁も\nかきだされちゃうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0404112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「キミのチンポ、エロ汁まみれにしちゃって……んはぁっ、ああっ！　じゅぶ\nっとチンポ突っ込まれると、もっと溢れるぅっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0404113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んふぅっ、んくっ、ひぃっ、ひぃいんっ！　そうやって、ねっとりピストン\nやばいぃ……んぁっ、奥っ、ンッ、いいぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0404114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「その動き、だ、ダメ……ダメだしぃ……。もっと激しく、ボクのマンコをじ\nゅぼじゅぼ犯すのも、ダメなんだからね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0404115" ]},
		{"command":[ "SETIMAGE", "0", "still_00023104_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ひゃぁあっ！？　ちょ、ちょっとぉっ！？　ダメって言ったのに、なに腰の\n動きを激しく……んぉっ、おおぉっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0404116" ]},
		{"command":[ "SETIMAGE", "0", "still_00023104_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「おねだりかと思ったって、ち、違うっ、このエロゲ脳めぇっ！　あっ、あぁ\nっ、んひぃいいいぃぃぃんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0404117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「チンポ激しいっ、んぁっ、ああっ、マンコかき混ぜられてるぅっ！　おっ、\nおおっ、じゅぽじゅぽエロい音しちゃってるよぉっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0404118" ]},
		{"command":[ "SETIMAGE", "0", "still_00023104_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「いっ、いいっ、マンコいっぱい、チンポ感じるぅっ！　あっ、ああっ、ヤバ\nいヤバい、気持ちよくなって、力抜けるぅ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0404119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ひゃはっ、はぁあああ～～～～っ！　で、でちゃってるっ、んぉ、オシッコ\n……ぉっ、おお……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0404120" ]},
		{"command":[ "SETIMAGE", "0", "still_00023104_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「マンコ、ガンガン突かれながら、お漏らしぃっ！　んひぃっ、気持ちよくな\nっちゃって、おっ、おぉおおぉぉ……っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0404121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「も、もっと気持ちよくてやるって？　ちょっと、これ以上ボクのマンコをめ\nちゃくちゃに突きまくるつもり！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0404122" ]},
		{"command":[ "SETIMAGE", "0", "still_00023104_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「あっ、ああっ、そんなボクをガッシリ掴んで、腰打ちつけてぇっ！　くひっ\n、すっごい音、パンパンって激しいぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0404123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「チンポが、ぶっといのがぁっ！　あっ、暴れてるっ！　ボクのマンコのいろ\nんなとこ、ごりごりしてくるよぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0404124" ]},
		{"command":[ "SETIMAGE", "0", "still_00023104_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「おっ、おおっ、いいよぉっ！　チンポ、チンポいいっ、んぁっ、マンコ負け\nてるっ、クソザコマンコ敗北ぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0404125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「腰振りながら、キミのチンポにぎゅうぎゅう媚びちゃうぅっ！　んはぁっ、\n勝手に締まるぅ、チンポ感じちゃうぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0404126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んはっ、キミもどんどん、ピストン激しくなってくぅっ！　んっ、おっ、そ\nんなに気持ちいい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0404127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ボクのマンコに思いっきり腰打ちつけてさっ、ああっ、チンポ子宮までどち\nゅってして、んっ、ひぃいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0404128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「チンポ大きくなって、マンコひろげて、はぁっ、はぁっ、亀頭グリグリって\nやばいよっ、気持ちいいよぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0404129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「イクッ、もう我慢っ、イクの最初から我慢できてないけど、今度は本当に我\n慢できないっ、いっ、イクッ、イク……ッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0404130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「き、キミもイキそう？　ビクビクってチンポ震えてるし、ピストンも余裕な\nさそうだしぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0404131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んぁっ、いいよぉ、イッちゃってよぉ。ボクのマンコに思いっきり中出しし\nちゃってぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0404132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ガン突きされて嬉ションまでしちゃうクソザコマンコにぃ、キミのつよつよ\nザーメン中出しでわからせてぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0404133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んぁあっ、あっ、あっ、ああっ、あはぁあっ！　イクッ、イク……ッ！　あ\nっ、あっ、ああ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0404134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「あはぁあああぁぁぁ～～～～っ！！　ひっ、ひぃっ、でてるぅっ！　どびゅ\nどびゅってきたぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0404135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00023104_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「熱いのっ、マンコに注がれるぅっ！　んっくぅうっ、染みるぅ、キミのザー\nメンが、マンヒダに染みこんでくるよぉ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0404136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「中出しされて、マンコ悦んでるぅ。うねうねして、チンポからザーメン搾ろ\nうとしちゃってるよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0404137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んはぁ……はぁ……。キミも……気持ちよくなってくれたみたいだねぇ……\n。んふぅ……マンコがザーメンでたっぷたぷぅ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0404138" ]},
		{"command":[ "SETIMAGE", "0", "still_00023104_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「え……？　まだまだヤり足りない感じ……？　ちょっとまって、もう少し休\n憩してからで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0404139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んぁあっ、もう、チンポが動き始めちゃってるぅっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0404140" ]},
		{"command":[ "SETIMAGE", "0", "still_00023104_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ちょっと、本当にまって……んぁっ、あっ、んひぃいっ！　チンポ、まだガ\nッチガチだよぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0404201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「あんなに、いっぱい射精したのに、勃起したままボクのマンコを犯しまくっ\nてるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0404202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んひっ、ひいいっ、本当にやばいって。イッたあとだから、敏感に……くひ\nぃっ！　チンポ、感じちゃうんだからぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0404203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「あ、アツアツのチンポに、マンコずぼずぼかき混ぜられてるっ！　んっ、あ\nあっ、あたって、こすれて、気持ちいいぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0404204" ]},
		{"command":[ "SETIMAGE", "0", "still_00023104_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「どんどんマンコから汁あふれちゃうぅ♪　ボクの愛液と、キミのザーメンま\nぜまぜされちゃってるよぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0404205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁっ、そんなに、ああぁんっ！　激しくされたら腰抜けて、立っ\nてられなくなるからさ、んぁあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0404206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「もうちょい優しく……ンッ、支えてやるから大丈夫って、そういう問題じゃ\nないんだけどなぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0404207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んっ、ああぁっ！　無防備マンコにチンポが迫るぅっ！　亀頭に、子宮口、\n突きあげられちゃうぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0404208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んひっ、イッてる、敏感になってるマンコ、キミに動かれるたびにイッてる\nからぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0404209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ずぼずぼ、ごりごり、マンコの中、キミに好き放題されちゃってるのに、す\nっごく気持ちいいのぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0404210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「声もおさえられないよぉっ！　んぁっ、だめ、感じてるエロい声、突かれる\nたびに、ああっ、勝手にでるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0404211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んっ、もっと、もっとぉっ♪　マンコ、チンポでどちゅどちゅしまくって、\n気持ちいいのしてぇっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0404212" ]},
		{"command":[ "SETIMAGE", "0", "still_00023104_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んぁあっ、ああっ、それぇっ♪　いいっ、いいのっ、あはぁあっ！　だめだ\nめイクッ、それ即イキしちゃうピストンぅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0404213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「あっ、ああっ、そんな、感じやすすぎのザコマンコだって。んひっ、そんな\nこと、あはぁっ、否定できないけどぉ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0404214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「キミのチンポが気持ちよすぎるせいなんだからぁ♪　この凶悪つよつよチン\nポのせいで、んっ、あっ、ああっ、またイク……ッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0404215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「キミもまたイキそうなの？　んじゃあまた、思いっきり射精しちゃいなよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0404216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ボクがチンポに敗北したって証、キミのザーメンで刻むように、思いっきり\nさ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0404217" ]},
		{"command":[ "SETIMAGE", "0", "still_00023104_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んぁっ、ああっ、ボクもまた、もう何回目かわっかんないけど、イクからさ\nぁ、あっ、ああ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0404218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「イク、イク、イク……ッ！　んっ、ああっ、キミも、キミも射精しながら、\nね、ボクと一緒にぃ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0404219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「イッて……思いっきり、ザーメンどぴゅりながらイッて、キミのザーメンで\n、ボクをイかせてぇえええぇぇぇっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0404220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「あはぁあああぁぁぁぁ～～～～っ！！　あっ、ああっ、きたぁっ、またきた\nぁあああ～～～～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0404301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00023104_02_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「マンコにぃ、子宮にぃ……っ！　２回目なのに、あっつあつのザーメンが打\nちつけられるぅううう～～～～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0404302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「くひぃいいっ、イクッ、イッてる、マンコイキまくりっ、あああぁぁっ、だ\nめぇ、戻ってこれないぃ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0404303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「腰、ガックンガックン震わせながら、イキまくっちゃうの……。お、おお…\n…だめ……また……キちゃうぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0404304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「あひぃいいいぃぃぃ～～～～……っ！　で……でちゃった……イキながらお\nしっこぉ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0404305" ]},
		{"command":[ "SETIMAGE", "0", "still_00023104_02_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「じょぼじょぼとまんないよぉ……。んひぃ……もう膀胱までキミに屈服しち\nゃってるかもぉ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0404306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……。ちょっと、そんなにじっくり見ないでよぉ……。さすが\nのボクも、おもらしを凝視されるのは恥ずかしい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0404307" ]},
		{"command":[ "SETIMAGE", "0", "still_00023104_02_16" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「……って、マンコの中でまたチンポがかたくなってる！？　ちょっとぉ、キ\nミってばそういうシュミ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0404308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「まったく、女の子のおもらしで興奮するようなチンポはボクが責任をもって\nすっからかんになるまで搾らなくちゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0404309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「もっとヤりたいだけだろうって？　ふふっ、さぁて、どうだろうね？　オシ\nオキして本音を聞きだしてみればいいじゃん、なんてね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0404310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んぁああっ、抜けちゃった、チンポ……んっ、ああぁぁあああ～～～～っ！\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0404401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00023104_02_17" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ひゃっ、ああっ、ぶっかけぇっ！　キミの精液が、いっぱい身体にかかって\n　……んっ、イクッ、ぶっかけでイクのぉおおお～～～～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0404402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「あはぁあああぁぁぁ～～～～っ！！　ぶっかけアクメでイキションしちゃう\nぅううう～～～～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0404403" ]},
		{"command":[ "SETIMAGE", "0", "still_00023104_02_18" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「あ……ああ……っ。ザーメン浴びながら、おしっこ……やば……いっぱいで\nちゃってる……とまんないよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0404404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「いやらしい匂いと、恥ずかしい匂いに包まれて……どうにかなっちゃいそう\n……はぁ……はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0404405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ちょっと、なに、もっとしごいて……。んっ、まだまだボクにぶっかけるつ\nもりぃ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0404406" ]},
		{"command":[ "SETIMAGE", "0", "still_00023104_02_19" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「あぁっ、ボクの身体、真っ白になるぅ……。キミのザーメンで、肌が埋め尽\nくされちゃうよぉ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0404407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「あ……やば……。ザーメンまみれにされて、またイキそ……。んっ、んふぅ\n……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0404408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「こんなにドロドロにされて……また嬉ションしちゃってるよぉ……♪　はぁ\n……はぁ……ボク、おかしくなっちゃってるぅ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0404409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んふふ、キミってばまた興奮しちゃってる？　解放的になってるのはお互い\n様だけどね。じゃあ、もっとヤろうか。だって夏だもんねっ♪」", "NORMAL" ]},
