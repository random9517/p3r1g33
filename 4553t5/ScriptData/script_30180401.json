{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0162" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「……こんばんは。改まって、どうしたの？　私に聞きたいことがあるって…\n…何？　ああ、なるほど。この衣装に変身する方法が気になるの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0403101" ]},
		{"command":[ "SETCHARA", "0", "char_00001804_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「これはね……説明すると長いんだけど。魔法少女状態になるのに、特別な魔\n力が必要になるんだ。その魔力は、魔力ポーションから作られていて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0403102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「少しだけ入手しづらい材料からできているんだけど、今はそのストックは充\n分にあって足りている……って感じかな。……材料の入手方法？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0403103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「それは……ええと。かなり特殊で……。普通なら秘密にしておくんだけど、\n……うん。誰にも言わないのなら教えてあげる。これはね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0403104" ]},
		{"command":[ "SETCHARA", "0", "char_00001804_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「んっ……。私が安定して魔法少女に変身するためには、魔力ポーションが必\n要だって話はしたよね……。それに必要な材料は、精液なんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0403105" ]},
		{"command":[ "SETCHARA", "0", "char_00001804_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「……うん。大丈夫だよ、私のことを信用してくれればいいの。……なんて言\nわれても少し怖いかな？　フフフ、大丈夫だよ……本当に……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0403106" ]},
		{"command":[ "SETCHARA", "0", "char_00001804_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「君は私に精液を採取されるだけ……。つまりは一方的に、快楽を与えられて\nおチンポから白濁とした種汁を吐き出してくれればいいだけだから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0403107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「痛いことも、辛いことも１つもない……。むしろ、気持ち良すぎてハマって\nしまうかもね。それで、性的嗜好が歪むかもしれないのは可哀想だけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0403108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「……どうしても、他の人のじゃなくて。君の精液で変身……したいから、協\n力してほしい。……いい？　じゃあ、いくよ。ゆっくり、ゆっくりね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0403109" ]},
		{"command":[ "SETCHARA", "0", "char_00001804_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「……ぎゅっ……♪　うん、そうだよ。おチンポを手で握って、指でくにくに\n刺激していってる……。最初は優しく、だよね。デリケートな部分だし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0403110" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00001804_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「え？　何をされているか見えなくて、不安でゾワゾワする？　うーん……そ\nれは……少し困る。良質な精液を提供してほしいから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0403111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「できるだけリラックスして、私のすることを信じて身体の力を抜いて……。\n……確かにおチンポは急所だし、敏感で繊細な部分ではあるけれど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0403112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「自分でシコシコしごくのも、私に握られて、手コキをされるのも結果的には\n同じ……だと思う。でも……恐怖が勝るなら、他に気をそらしてあげる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0403113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「……ぴちゃ。くちゅ、ちゅっ、ちゅぷ……ぴちゅ……♪　……ん？　何をし\nてるんだ、って？　感覚的にわかっているはず。……そうだよ、お尻の穴」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0403114" ]},
		{"command":[ "SETIMAGE", "0", "still_00001804_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「君のアナルに私の舌を入れて、腸内を舐めほぐしながら……おチンポを触っ\nたり、いじったり……性感を徐々に高めていってる……。んっ、くちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0403115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「ん、んっ……♪　別に遠慮、しなくていいよ……。ぴちゃっ。私と君の仲だ\nし……。っくちゅっ、ちゅぅっ、何も初めて見る部分じゃ……ないし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0403116" ]},
		{"command":[ "SETIMAGE", "0", "still_00001804_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「君のだったら……ちゅぅっ、汚いとか、思わないし。平気……。だから、接\n待されているとでも思って快感にだけ酔いしれていてくれる？　んちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0403117" ]},
		{"command":[ "SETIMAGE", "0", "still_00001804_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「そうしたら……おチンポも、お尻の穴も……だんだん幸せになっていくはず\n……。そういうことで。……ぴちゃっ、くちゅ、ちゅぷ、ぷっちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0403118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「んっ……♪　ンッ……♪　フフフ、……すごい。予想通り……♪　お尻の穴\n舐められながら手コキされてると、どんどんおチンポが太くなってくる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0403119" ]},
		{"command":[ "SETIMAGE", "0", "still_00001804_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「自分でもわかるよね……。一回手を動かすごとに……ちゅぷっ、硬くなって\n、大きくなって……ちゅっ、ぷちゅっ、伸びて……くるよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0403120" ]},
		{"command":[ "SETIMAGE", "0", "still_00001804_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「私の手、ぐいぐい押してくる……♪　フフフ、力強すぎて……笑みがこぼれ\nる。これはいい精液がとれそう。うん、そのまま……そのままだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0403121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「ジッとしてて……。んれろっ……♪　ねえ、私の舌が……お尻の穴のフチを\nつつつつ～って丁寧になぞっているの、わかる……？　れろ、れろっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0403122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「こうやって焦らしながら、おチンポをしごいて……。油断したところで、…\n…んっ♪　こうやって、穴に舌を入れる……ねじこむぅ……。くちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0403123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「んんっ♪　んぅ♪　ん～～～～～っ……♪　んっ……♪　普段人に触られな\nい場所……。二か所同時に攻められりゅと、不思議な感覚れひょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0403124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「お尻はゾクゾクひて……。ちゅぷ、ぷっちゅっちゅぷっ、おチンポはどんど\nん熱くなるの……。私のひんやりした舌先が腸内を舐め回ひて……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0403125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「くっちゅっちゅっぷっ、んれろっ……れろっ、れろ……♪　んちゅぷっ♪　\nれりゅっ、んちゅっ……♪　ん～♪　腰がビクビクしてりゅ、面白い♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0403126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「ん、わたひ……。こういう、同時に色んな場所を攻めるの……得意かも？　\nぴちゅっ……んちゅっ……♪　んぅ、お尻の中もおチンポも熱い……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0403127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「今、君は私に自分の下半身の主導権を全部……握られてる♪　どんな気分…\n…？　屈辱？　それとも……。くちゅっ、興奮……かな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0403128" ]},
		{"command":[ "SETIMAGE", "0", "still_00001804_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「……いいよ。こんな経験、なかなかないだろうし……。じっくり楽しんで…\n…。んっ、ちゅぷっ、くちゅ、ちゅっ、ちゅ、ぴちゃっぴちゃっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0403129" ]},
		{"command":[ "SETIMAGE", "0", "still_00001804_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「たまにはバキュームですすってみようかな？　っぢゅるっ……じゅるるるっ\n！　その後すぐに、また舌を入れてぇ……んんっ、んんんん～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0403130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「あは……♪　予想以上に翻弄されてくれる……。そんなに良い反応されると\n……ちゅぷっ、こっちも夢中で攻め続けたくなっちゃう……。んちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0403131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「ほら……♪　ほら、精液出したくなってきたよね……♪　イキたい？　女の\n子みたいにぃ……ちゅぷ、下半身もてあそばれて、イクのかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0403132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「大事なところ、前も後ろも私にいじめられて、いじりつくされて射精するの\n……？　……まだだよ、精液がドロドロに白くなるまで溜めて……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0403133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「あ……♪　あはは、つらい……？　それでもまだ……♪　っちゅっ……、く\nちゅ、ぷちゅ……ちゅっ♪　チュッ……ちゅぅっ、ちゅう……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0403134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「手の方でも強く絞っていくからね。それに合わせて出して……。いくよ。そ\nれ♪　それ……っ♪　射精して、精液を私に与えてほしい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0403135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「んんッぅ……♪　そう……！　そのまま、何もかも解放して！　精子をほと\nばしらせてっ……！　あっ♪　あっ、勢いがすごい……びちゃびちゃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0403136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001804_01_03" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「うんっ、上手に射精できてる……っ♪　ありがとう、でももう少し量が欲し\nいから……根元から絞り出すよ。……んんっ♪　……あ、また出た♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0403137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「あああああ……♪　お尻の穴をヒクヒクってひくつかせながら射精してる…\n…。一滴も無駄にしない、全部もらうから……安心して？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0403138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「へえ……。こんな感じでいつも、私の中に精液を放っていたんだ……♪　客\n観的に見ていると、興味深いかも……。すごく跳ねて暴れてる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0403139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「ひゃっ、あっ、腕にも、身体にも飛び散ってきた……♪　フフフフ、そんな\nに撒き散らさないで……。んっ、……全部吐き出せたかな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0403140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「これは……♪　ポーションに使うのに最適な、タンパク質の濃さ……。強烈\nな臭い……。粘度も申し分ない、精子もたっぷり詰まっていて極上……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0403201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「これはとてつもなくいい材料になりそう……。はぁっ♪　味も見てみるね…\n…。……ちゅ……ごくっ……♪　んっ、理想的な苦味。最高だよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0403202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「あぁ……♪　私が精液を欲したら、素直に恵んでくれる……。すごくありが\nたいけど、……君はまだ満足しきっていないみたい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0403203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「……ねえ？　おチンポ、全然萎えないね。これだけ精液を出して硬さも大き\nさも変わらないなんて……続行を望んでいるってこと……なのかな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0403204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「うん。私も、ポーションのストックは無限に欲しいから……。このまま、い\nけそうなら予備の分もちょうだい。……もちろん、お手伝いする」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0403205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「んんん……レロッ、れろぉ……れろっ♪　くちゅ……ぴちゅ、こうやって、\nお尻の穴、好きなだけ舐めてあげるからまた濃い精子を与えて……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0403206" ]},
		{"command":[ "SETIMAGE", "0", "still_00001804_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「くちゅ、ちゅぷ、……あ、手もお留守にしてちゃダメだよね。しっかりシゴ\nかなきゃ……。ん……んっ、ちゅぱ……♪　れろっれろっレロッ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0403207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「んっふふ♪　私に舐められるの……慣れてきた？　お尻の穴、まったく抵抗\nしてこなくなっちゃった。唾液でトロトロ……すごく可愛い」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0403208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「もっと欲望に溺れていいよ……。んれるっ、ぴちゃ、ちゅぷ……くちゅ♪　\n嬉しい？　おチンポも反応してる……。っちゅっ、くちゅっ、ぴちゃっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0403209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「たくさんほぐして、舌をねじ入れて……んちゅっ、キレイにしてあげるね。\n……ちゅぷっ、くちゅ……♪　あ、お尻の穴開いたり閉じたりしてる♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0403210" ]},
		{"command":[ "SETIMAGE", "0", "still_00001804_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「……それに、どう……？　さっき出してくれた精液が、ローションがわりに\nなって……んちゅっ、おチンポをシゴく手がスムーズに、なったでしょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0403211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「ニュルニュルした柔らかい手がおチンポを刺激して、股間に甘い快感がはし\nる……♪　これに耐えられる人なんて、ほとんどいないはず……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0403212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「んれろっ、れるっ、くっちゅっちゅっぷっ……♪　ぴちゃっ、ぴちゃっ♪　\n君のお尻、も……♪　おチンポも独占できて、幸せ……♪　っちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0403213" ]},
		{"command":[ "SETIMAGE", "0", "still_00001804_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「……あっ♪　あっ♪　君の幸せも、硬いおチンポからちゃんと私に伝わって\nきてるよぉ……♪　ぴちゅっ♪　ちゅぷ、ぴちゃっ、ぴちゃ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0403214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「んぁっ……♪　指がすべる……♪　くちゅっ♪　ん？　私の声が艶っぽくな\nってきた……？　それはそう、私も感じてる……んちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0403215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「君の本気で感じているところを見ていたら……っ♪　は、ぁ♪　わかる……\nよね。私の息、熱い？　手だって火照ってきてる。んっ……んんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0403216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「これはもう、君のお尻の穴とおチンポ、私の口と手とのエッチ……だよ♪　\nはぁ、はぁ、一緒にどこまでも高まって……っちゅっ、ちゅぅっちゅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0403217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「ちゅっ……、お願い……もう一回私に精液を与えて……♪　ん、ちゅっ、ち\nゅむっ、むちゅっ……んん～っ、ちゅぱっ、れろッ……れるっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0403218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「大事にするからぁ……♪　君の、んんっ♪　精子♪　私にちょうだい♪　れ\nろっ……♪　れろっ、おチンポからドクドクって解き放って♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0403219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「……睾丸から尿道に精液がこみあがってくる感覚を思い出して……。さあ、\n私に君の生命の力強さを思い知らせて……♪　さあっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0403220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「んぅううっ♪　良いっ……！　回数を重ねるごとに上手に射精できるように\nなってきてる……！　そのまま出し続けていて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0403301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001804_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「あぁっ♪　一度目の射精の時よりも飛距離が伸びているっ……！　これは期\n待ができそう……っ♪　あぁっ、魔力の素がこんなに……♪　あんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0403302" ]},
		{"command":[ "SETIMAGE", "0", "still_00001804_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「色も濃くて……臭いもキツい……♪　私が求めていた精液はこれだったんだ\nって確信した……！　もっと出せる！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0403303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「指の力を強めて……牛の乳しぼりみたいに絞り、抜く……っ♪　わぁあっ♪\n　びゅぶっ、ぶびゅって溢れ出してきた……この方法が正解だったぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0403304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「ンンッ♪　んんんっ……♪　同じ場所に……手に二回射精してもらうことで\n、一度目の射精との比較ができる……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0403305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「ふぁあっ♪　一度目よりも重い……♪　見て、手のひらにべったりはりつい\nて自己主張してる……。新鮮で特別な君の精液……受け取った♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0403306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「フ……フフフ、これだけあれば、当分変身のための魔力ポーションには事欠\nかないはず……♪　想定していたよりも１０倍は精液が手に入った……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0403307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「みんなに幸せを届ける魔法少女のはずなのに、根っこは魔女っぽい……？　\nそこはね、私の根本の性格だから……大きくは変わらないよ。でも」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0403308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「ワガママに付き合ってくれて、これだけ質が良くてタンパクも豊富な精液を\n提供してくれた君には……本当に感謝してる。これからもよろしくね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0403309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「……え？　ストックがなくなったらまた来るよ？　そうしないと、魔法少女\nになれないし……。今からその時が楽しみ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0403310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「あれっ！？　ひゃっ！？　あッ……！　ち、違うっ！　私の手に出して……\nっ！　あっあっ、どうしよう、どんどん飛び散って……うぁああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0403401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001804_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「ま、待って！　射精の勢いが凄すぎて精液っ、私の身体に……！　かかって\nしまっているっ……！　あっ！　て、手で回収するつもりだったのに！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0403402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「あああああっあああ……！？　二回目の射精だと思って甘く見ていた、目測\nを誤ってしまった……！　あぅっ！　だめ、こぼれるっ、あああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0403403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「採取不可能なくらいにぶちまけられて……うううっ♪　すごい臭い……むわ\nぁって精液の青臭い臭いがそこらじゅうに……♪　んぁあっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0403404" ]},
		{"command":[ "SETIMAGE", "0", "still_00001804_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「ストックっ、魔力ポーションのストックを作らなくちゃいけないのに……！\n　少しだけ、かけられて悦んでいる自分がいるぅ……！　あったかい……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0403405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「あああ、採取と欲望と、どっちを優先したらいいのかわからないぃ！　精子\n浴びたいっ……！　だけど、集めないと……ああああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0403406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「……ん、ふ……♪　ふぅううう……♪　二回目はだいぶ精液をこぼしてしま\nって……失敗、ということになると思うけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0403407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「君の精液の素晴らしさを、直接肌で感じられたのは得難い経験……だったの\nかも。ヌメりも、粘りも、自分で体験しないとわからないことはあるし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0403408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「有意義ではあった……けど、もちろんポーションがなくなるタイミングは早\nまってしまったと、思う。だから……次はまた違う方法を試したい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0403409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「もっと精液を大量に集められて、暴発もしない新しい体位を考えないと……\n。その時は絶対に協力してもらうから、それまでしっかり溜めておいてね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0403410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}