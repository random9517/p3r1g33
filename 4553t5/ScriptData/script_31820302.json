		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「ふぁああっ♪　きゃっ♪　あぁ……♪　あぁんっ、んんんッ……♪　作って\nる♪　赤ちゃん作ってるぅ……！　あぁっ、ああああ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0304301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018203_02_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「デキちゃう……！　あっ♪　あっぁっ、こんなにすごい精液流しこまれて、\n妊娠しないなんて無理ですっ……あはっ♪　すごすぎます……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0304302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「ふぁっあっあっあぁっんあっ……！？　二回目なのにこんな量……っ、人妻\nでも受け止めきれるかどうか……！　あっ！　も、漏れちゃうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0304303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「だめぇ……！　せっかくもらった精液なのに……んんっ！　絶対無駄にした\nくない……！　あぁっ、奥ぅ……こぼれないように奥に注いでぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0304304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「あ～～～っ♪　あつぅい……っ♪　いいよぉ、尿道に残った分はわたしがし\nぼり取ってあげるね……んんんん～っ……どうっ？　しぼれてるぅ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0304305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「あぁんっ、限界を超えて子宮に入ってくる精液……♪　若い男の、強い男の\nドロドロザーメン……美味しすぎます……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0304306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「は～～～っ……♪　ふぁああっ……あぁ……も、もうだめぇ……♪　これ以\n上は一滴も入りません……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0304307" ]},
		{"command":[ "SETIMAGE", "0", "still_00018203_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、すぐにでもお仕事に戻らないと……いけないのに、身体がシビ\nれて動けません……♪　頭もぼーっとして……んんんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0304308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「なにもかもがどうでもよくなってしまうくらい、素晴らしいエッチでした…\n…♪　こんなの経験したら、わたし、もう……戻れないかも」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0304309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「今度は隊長さんの、えっちな専属ウェイトレスさんになっちゃおうかな……\n？　お給料は～、１日１回のエッチがいいかもしれません♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0304310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「きてきてぇ……っ！　わたし絶対妊娠するから……。……んっ！？　た、隊\n長さん！？　きゃっ……！　んんっ！？　待って……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0304401" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「あっ……！　か、身体にかけるのぉ……っ？　あっ！？　あっぁっ……すご\nい量……。あっ……！　夫と全然違う、こんなに……くぅんんっ♪」", "NORMAL" ]},
