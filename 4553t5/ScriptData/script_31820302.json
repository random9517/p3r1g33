{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0122" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「あっ……♪　隊長さ～ん、またお店に来てくれたんですね♪　ちょうどいい\nタイミングです。やっぱりわたしたち……相性がすごくイイのかも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0304101" ]},
		{"command":[ "SETCHARA", "0", "char_00018203_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「仕事中も、ず～っと隊長さんのこと……考えてたんですよ？　ここには色ん\nな男の人が来ますけど、その中でわたしを夢中にできるのは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0304102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「あなたなのかな、って。……お客様？　どうぞこちらにいらしてください。\nふふっ、この席なら……あまり人に見られませんから♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0304103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「……じゃぁん♪　あなたが今日来てくれたら、ここでこういうことしようっ\nて……ずっと考えていたんです。待ちきれませんでしたよ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0304104" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00018203_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「あら。あなたもノリ気になってくれているみたいですね。嬉しい……♪　ふ\nふ、店内で卑猥な格好して、お客様のチンポを取り出して……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0304105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「わたしってイケない人妻ウェイトレスですよね……。でも、もう我慢できな\nいんです……。っはぁっ、来る日も来る日もずっと妄想してました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0304106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「誰か来るかもしれない店内で、夫じゃない男の人とエッチなことをする妄想\n……。はぁっ、はぁ、淫らなことを考えてショーツを濡らす日々……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0304107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「はじめは若い男の子なら誰でもいいって思ってました。でも……日に日に、\n想像の相手が、あなたばかりになってきて……それで……んんんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0304108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「次にあなたがこの店にきたら……襲っちゃおうって♪　人妻のフェロモンで\nメロメロにして……ぱく～って食べちゃおうって決めていたんです♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0304109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「……わたしに食べられるの、イヤですか？　なぁんて、お返事はこの、立派\nなオチンポくんがしてくれてますよね。エッチなことしたい、したいって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0304110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「背徳感い～っぱいの、不倫エッチしたい～ってワクワクしてるのが……。あ\nっ♪　わたしのアソコからつたわって、きますよ……んんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0304111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「ねえ……？　お願いですから、このたくましいオチンポでわたしのいやらし\nいところ、こすってください……。あっ♪　遠慮なんてしないで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0304112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「わたしとあなたの仲じゃないですか……。あッ、ん……♪　そうです、割れ\n目にそわせて……はぁんんっ、チンポの形がよくわかるように……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0304113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「おしつけて、わたしのアソコ、気持ち良くしてください……♪　……んッ…\n…♪　あぁ、あぁん……っ♪　こうしてると硬さと大きさが良くわかるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0304114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「隊長さんにも、つたわるでしょう？　わたしのオマンコから、だんだん愛液\nが溢れてくるのが……♪　はぁ、あぁ、そうです、期待してるんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0304115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「このオチンポ♪　浮気チンポにここで……バイト中に犯されるの期待して濡\nらしています……。奥まで一突きにされてめちゃくちゃになって……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0304116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「はしたない声をあげて喘ぐ自分を想像するだけで……あっ♪　たまりません\n♪　あの……胸も揉んでください。乳首が大きくなってますよね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0304117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「わたし、素股だけで感じちゃってます♪　あんっ♪　あん、ん～～っ……ン\nン♪　このもどかしさが、クセに……なっちゃいます、んっ♪　ンンっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0304118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「ふぁああ……♪　んぁっ、あぁ……あっ……♪　隊長さんって前戯もうまい\nんですね。すっかり準備が整っちゃいました。ですから……その……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0304119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「入れて、くれませんか？　このチンポ……どうしても欲しいんです～♪　あ\nっ、こらぁっ……これ以上焦らさないでください、いじわるしないで～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0304120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「わたしとあなたで、昼下がりのあやまちを犯しましょう……♪　っん……♪\n　入れてくれないのなら……わたしが勝手に入れちゃうから……♪　あっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0304121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「んぅううう……！　は、ぁ……ッああああああぁ……っ♪　ほぉら、見えま\nすか？　感じますか？　チンポ、オマンコに入っちゃいましたよぉ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0304122" ]},
		{"command":[ "SETIMAGE", "0", "still_00018203_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「あっ♪　困ったチンポさんですね♪　太すぎて……あっ♪　全然動けません\n……♪　ふふふっ、そんなに待ち遠しかったんですかぁ……？　っあっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0304123" ]},
		{"command":[ "SETIMAGE", "0", "still_00018203_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「チンポが太すぎて♪　挿入しちゃってるの丸わかりですねぇ……？　ふぁっ\n……♪　チラ見されただけで即バレちゃいそうです、んぁああ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0304124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「だからって……じゃあ抜くかっていわれたら絶対にいやですけど♪　っんぅ\n……♪　やめたくないです、続けたいです、エッチ……♪　はやくぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0304125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「クビになっちゃってもいいですっ、みんなに聞こえちゃってもいいから突い\nて……突きまくってイかせてください、イカせまくって……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0304126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「んぁあっ……はぁんんっ♪　んぁあ……ああああ……♪　あっ、ご、ごめん\nなさぁい……夢中になって自分だけ良くなっちゃってましたぁ……♪」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018203_02_05" ]},
		{"command":[ "PLAYVOICE", "v2_182_0304127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「すごい音、してますね……んぁんんっ♪　あなたが動くたび……わたしの身\n体が揺れて、ぐっちゅっ、ずっちゅっていやらしい音が響いてるぅ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0304128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「これ、なんです……っ♪　わたしが欲しかったのはこのチンポちゃんなんで\nすっ……♪　ああああ～……♪　本当にイイっ、これじゃなきゃだめっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0304129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「勝手に腰が揺れちゃう、……はぁっあぁっ、あぁっ……！　オマンコが求め\nちゃう、自然にキツぅく締まってチンポを刺激しちゃう……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0304130" ]},
		{"command":[ "SETIMAGE", "0", "still_00018203_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ♪　あなたのチンポだけがわたしが女だって♪　いやらしい女だ\nって思い出させてくれるのぉ……！　ちょうだい、もっとちょうだいぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0304131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「……あ♪　いいのっ、そこ……そこグリグリしてぇ♪　一番奥っ、子宮っ…\n…突き上げて子作りモードにして……♪　んあぁあんっ、くるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0304132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「赤ちゃん欲しくなってきちゃった……！　ね～え……♪　ねえ隊長さぁん…\n…♪　赤ちゃん♪　赤ちゃん欲しいです、赤ちゃんの種くださぁい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0304133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「いいですよねぇ？　夫にはうまく言いますから……だから無責任中出ししち\nゃってください♪　いいんですぅっ、わたしが欲しいんですからぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0304134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「わかりますよね♪　ここです、こ、こ……♪　わたしの一番奥ぅ……オマン\nコの奥の奥、子宮めがけて精子、精液を恵んでください……ん～～～っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0304135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「んふぅううう～～～♪　入ってきますっ、子宮にドクドク入ってくるぅうう\n～っ♪　やだ♪　本当にわたしっ、中出し不倫しちゃってるぅうっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0304136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018203_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「き、もちいい……♪　中出し気持ちいいですっ、最高のオチンポから最上級\nの赤ちゃんミルク出てるぅ……ぜんぶ、ぜんぶわたしのですぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0304137" ]},
		{"command":[ "SETIMAGE", "0", "still_00018203_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「んぁああああ♪　アルバイト中に赤ちゃんデキちゃいます……♪　ウェイト\nレスなのに♪　お客様のオチンポ貪って妊娠しちゃいます……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0304138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「ああっ、あなたぁ……♪　ごめんなさい、わたし……このチンポには勝てな\nいんですっ、このチンポが一番好きっ……これがいいの……ぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0304139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「あっ！　くぅううんっ♪　頭がクラクラしちゃう……お腹の奥、子宮の中に\nあつ～いミルクが溜まってく……♪　しゅごい、すごいぃい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0304140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「んんっふ……♪　子宮がタプタプいってるぅ……。飲食店で精液つまみ食い\nしちゃうなんて……わたしって本当にイケない奥さんですよねぇ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0304201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「あなたの精液って、ずっしり重くて入ってるってはっきりわかるんです……\n。満足感がすごくって、あぁ、満たされてるぅって幸せで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0304202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「でもぉ……。わかってますよね？　わたし、一度の射精じゃごちそうさまっ\nて言えないんです。むしろ、本格的にお腹が減ってきました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0304203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……♪　完全に淫乱スイッチ入っちゃいました……。いいですよ\nね♪　このまま抜かずに、２回戦突入しちゃうの、アリですよねっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0304204" ]},
		{"command":[ "SETIMAGE", "0", "still_00018203_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「安心してください、わたし……。あっ♪　自分で動きますし♪　すぐにイッ\nちゃいますよ……。あっ♪　あっ、見ててください……あぁっあっあっんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0304205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「んぁああっ！！　今っ……今イッてます！　あんっ♪　あんんんっ……！　\nオマンコぎゅーって締まるからわかりますよねっ、あああイクッ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0304206" ]},
		{"command":[ "SETIMAGE", "0", "still_00018203_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「あなたのオチンチン、チンポ離したくなくて本気でオマンコがうねってるん\nです……っ！　はぁあっ♪　あぁ、ああ……ずっとイカせてぇ……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0304207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「ふふふっ……キツいですか？　オマンコぬりゅぬりゅ動いてますか？　……\n人妻だって、本当に感じればこれくらい締まるんですよぉ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0304208" ]},
		{"command":[ "SETIMAGE", "0", "still_00018203_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「あなた、に♪　もう一度ザーメンどぴゅどぴゅ放ってもらうためにならぁ…\n…恥も外聞も捨てちゃいます、お仕事放棄でマジイキしますっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0304209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「んあああああ……！　イクぅ……！　あうぅんっ！　お尻、お尻揺らすの止\nめられませんん……！　ずっとイキたいの、これやめたくないぃ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0304210" ]},
		{"command":[ "SETIMAGE", "0", "still_00018203_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「あっ♪　あなたも……隊長さんも気持ちイイですかぁ……？　わたしばっか\nりっ……ごめんなさい！　お詫びに、どうぞお好きに……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0304211" ]},
		{"command":[ "SETIMAGE", "0", "still_00018203_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「わたしの人妻オマンコ、好きに使ってください……！　あっ♪　ふふふっ、\nチンポがビクビクって反応しましたね……こういうのがお好きですかぁ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0304212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「あっ♪　淫乱人妻のハルミは、隊長さんのおっきな浮気オチンポが大好物で\nすっ♪　硬くて長いチンポを入れられると発情しちゃうんですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0304213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「ああぁ……ッ♪　むちゃくちゃに突き上げてください♪　人妻オマンコ貸し\n出し中ですからぁっ……今っ、ちょうどイッてますからぁ♪　あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0304214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「一番熟れた状態のオマンコっ……味わってください、あっ♪　あっ♪　ソフ\nァーに、床にわたしのおツユが飛び散ってる……いやらしすぎますっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0304215" ]},
		{"command":[ "SETIMAGE", "0", "still_00018203_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「むせかえるような人妻の……あふっ♪　オンナの匂い……♪　今だけはわた\nしは隊長さんのオンナ、ですから……ぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0304216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「っふふ……♪　あなたのピストンのリズム、オマンコが記憶していきます…\n…♪　あっ♪　これじゃなきゃイケなくなっちゃいそう……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0304217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「っんぅ！？　ど、どうしたんですか？　急にせわしなく腰を使って……。…\n…あ♪　また出しちゃいそうなんですね♪　うふふ、イイですよっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0304218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「わたしにもう一度、不倫中出しキメてください♪　あなたの精液で、わたし\nを自分のモノにして……♪　あぁっ、欲しい、欲しいです……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0304219" ]},
		{"command":[ "SETIMAGE", "0", "still_00018203_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「わたしっ、あなたの精液が欲しいの……！　みんな見ててぇ……！　わたし\nが夫じゃない男の人に、種付けされるところを見ていて……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0304220" ]},
