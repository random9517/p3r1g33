		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「精液のびゅるびゅるが、制服にかかっちゃう……っ。あっ♪　だ、め……♪\n　だめなのに拒めない……っ♪　かけてもらえるの、すごく嬉しい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0304403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「いい、ですよ……♪　隊長さんがそうしたいなら、わたしはそれを受け入れ\nますっ……どうぞ、赤ちゃんのお汁、このまま全部かけてください……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0304404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「あっ♪　あっ、あぁ……はぁあんん……♪　制服に、絶対にとれない濃いニ\nオイが染みこんで……。取り返しのつかないことになってるのにっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0304405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「それで、わたし……感じちゃってますっ……あぁんっ♪　あつぅい……気持\nちいい……っ♪　ヌルヌルが肌にまとわりついて……最高です……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0304406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「あぁ……♪　ここまで精液で濡らされちゃうなんて……驚きです。店長に叱\nられちゃいますよ。クリーニングしてもとれないかも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0304407" ]},
		{"command":[ "SETIMAGE", "0", "still_00018203_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「でも、隊長さんはな～んにも気にしなくっていいですからね？　だってそう\nでしょう、わたしが誘って、わたしがお願いしたんです。ふふふっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0304408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「それでもちょっとだけ気になるのなら～……あっ。そうですね……♪　今度\nはまた、別のバイト先が決まった時でにも、同じように……シてください」", "NORMAL" ]},
