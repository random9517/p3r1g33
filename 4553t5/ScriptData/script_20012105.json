{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0157" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "そうして、俺が水着の品評会に大忙しになっているのと同時刻。", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "美しいスパのロビーには不似合いな、怪しい集団……。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "謎の戦闘服に身を包んだ一団が、ヒソヒソコソコソと集まりつつあった。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハチ乙女" ]},
		{"command":[ "SETTEXT", "「ハーチハチハチハチ！　こーこーが今日の仕事現場だそうですねぇ～……！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_010021700001" ]},
		{"command":[ "SETCHARA", "0", "char_00021901_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ぼよんっ、ぼよよよよん！", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "豊かな二つの膨らみを、存分にユサユサと揺さぶりながら、リーダーらしい少\n女が一歩前に出る。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハチ乙女" ]},
		{"command":[ "SETTEXT", "「いいですか！？　私達の仕事には失敗は許されません！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_010021700002" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハチ乙女" ]},
		{"command":[ "SETTEXT", "「ここでのんきに遊んでいる人々を……一人残らず絶望の淵に叩きこんであげ\nましょうね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_010021700003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「はいっ！　お任せを！　ハチ乙女さま！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_010021700001" ]},
		{"command":[ "SETCHARA", "0", "char_00018201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「や……やれるだけ、やってみますー……。初めてのお仕事で不安ですけど…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_010021700001" ]},
		{"command":[ "SETCHARA", "0", "char_00018301_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「とはいえ、そんなに難しい仕事じゃないって聞きましたよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_010021700001" ]},
		{"command":[ "SETCHARA", "0", "char_00018401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「他の現場に送られるよりはいいじゃないですか。リゾートなんて豪華ですし\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_010021700002" ]},
		{"command":[ "SETCHARA", "0", "char_00018401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「それはそうですね。全力で頑張りましょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_010021700002" ]},
		{"command":[ "SETCHARA", "0", "char_00018301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「常夏のスパリゾートを制圧！　あぁ……戦闘員として、胸がこう、高鳴りま\nすわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_010021700002" ]},
		{"command":[ "SETCHARA", "0", "char_00018201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "一言喋るたびにブルンッ、ブルルンッ、と豊満なオッパイを揺らす戦闘員たち\n。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「……正直、お客さんとして遊びにきたかったとは思いますよね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_010021700003" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「うんうんっ、いいですわよねぇ～。スパリゾート！　家事の疲れも吹き飛び\nそう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_010021700003" ]},
		{"command":[ "SETCHARA", "0", "char_00018301_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「それに、ここ……湿度が高くて。スーツが胸にはりつきます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_010021700003" ]},
		{"command":[ "SETCHARA", "0", "char_00018401_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「あ、わかる。それな～。私達、出るとこ出てるから、スーツがパッツンパッ\nツンで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_010021700004" ]},
		{"command":[ "SETCHARA", "0", "char_00018301_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「そうなの。ちょっと息苦しいよねぇ。もっと、ゆったりしたスーツを支給し\nてくれればいいのにぃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_010021700004" ]},
		{"command":[ "SETCHARA", "0", "char_00018201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「ねえねえ。あっちに美味しそうなパフェが売ってるみたい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_010021700004" ]},
		{"command":[ "SETCHARA", "0", "char_00018401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「ホント～？　ちゃっちゃとお仕事終わらせて、４人で食べにいこうよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_010021700005" ]},
		{"command":[ "SETCHARA", "0", "char_00018201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「賛成～。あっ、期間限定メロンパフェですって。いいもの食べて元気出しま\nせんとね～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_010021700005" ]},
		{"command":[ "SETCHARA", "0", "char_00018301_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「わかる～。わかりみが深いです～。私はイチゴパフェにしようかしら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_010021700006" ]},
		{"command":[ "SETCHARA", "0", "char_00018201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「チョコバナナパフェもいいかもしれませんよ。ああっ、迷っちゃう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_010021700005" ]},
		{"command":[ "SETCHARA", "0", "char_00018401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「それなら……全員で、別々のものを頼んで分け合うのはどうです？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_010021700006" ]},
		{"command":[ "SETCHARA", "0", "char_00018301_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「まあ！　名案だわ。ハチ乙女さまは何パフェにします？　チェリーですか？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_010021700007" ]},
		{"command":[ "SETCHARA", "0", "char_00018201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハチ乙女" ]},
		{"command":[ "SETTEXT", "「……目移りするのはわかるけど、一応ちゃんと働かないとだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_010021700004" ]},
		{"command":[ "SETCHARA", "0", "char_00021901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハチ乙女" ]},
		{"command":[ "SETTEXT", "「ちゃんとやってなかったって報告されたら……。後ですっごく怒られるかも\nしれないし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_010021700005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「ふふふっ、それはさすがに困っちゃいますよねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_010021700007" ]},
		{"command":[ "SETCHARA", "0", "char_00018301_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「でも……今ならパフェにお紅茶かコーヒーがつくようですよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_010021700008" ]},
		{"command":[ "SETCHARA", "0", "char_00018201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハチ乙女" ]},
		{"command":[ "SETTEXT", "「う、それは惹かれますね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_010021700006" ]},
		{"command":[ "SETCHARA", "0", "char_00021901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「オレンジジュースを頼まれるようなら、私、クーポンを持ってきましたので\nさしあげます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_010021700009" ]},
		{"command":[ "SETCHARA", "0", "char_00018201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハチ乙女" ]},
		{"command":[ "SETTEXT", "「いいの！？　……ってそうじゃなーい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_010021700007" ]},
		{"command":[ "SETCHARA", "0", "char_00021901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハチ乙女" ]},
		{"command":[ "SETTEXT", "「私達が来たからには、この地を恐怖のどん底に叩き落してやらなきゃいけな\nいんだよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_010021700008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「う、うん。そうでしたそうでした、すっかり忘れていました！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_010021700008" ]},
		{"command":[ "SETCHARA", "0", "char_00018301_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハチ乙女" ]},
		{"command":[ "SETTEXT", "「んもぉ！　忘れちゃだめだってば～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_010021700009" ]},
		{"command":[ "SETCHARA", "0", "char_00021901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「そんなこと言って～。ハチ乙女さまだってすっかりパフェの気分だったくせ\nに～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_010021700010" ]},
		{"command":[ "SETCHARA", "0", "char_00018201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "どっ、と自分達の台詞に自分達で笑い出す。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "その雰囲気は、なぜかとても主婦の井戸端会議そっくりの空気をかもしだして\nいた……。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}