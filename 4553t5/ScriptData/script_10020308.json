{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0138" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "そして、翌日……。", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「はぁ～……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113340001" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "4", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ルルーナは、プラモを壊されたのがよっぽどショックだったのか、", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "教室でもこの調子だ。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「先生……ルルーナさん、ずっとこうなんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130113340001" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まったくなぁー……あのプラモ、作ったのは俺なのになぁ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "まあ、このまま放っておくわけにもいかない。ちょっと声をかけてみるか。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「姫様？　お嬢様？　……おーい、ルルーナちゃん？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「……ほっといてちょうだい。ううううー……私のＫＶ－２がぁ……せっかく\nの自信作がぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113340002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「作ったのは俺ですけどね……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "それはともかく、こりゃダメっぽいな。しばらく放置するしか……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ねえねえ！　聞いた！？　模型シミュレーションセンターの話！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020113340001" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お、なんだ？　あそこは点検中じゃなかったのか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「それがね？　異常がなかったんで、マシンを再開したんですって。そしたら\n――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020113340002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「もしかして……また出たんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130113340002" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113340003" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「そう！　あの怪獣戦車が現れて、遊んでた子たちのプラモを壊しちゃったん\nですって！　すっごいわよねー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020113340003" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、そこ感心してどうする」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「ふふふふふふふふ……そう。出たの……。また出てきたのね、あのボケナス\nビが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113340004" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「ル、ルルーナさん……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130113340003" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「許さない……絶対に許さないわ、あのボケナスビ……！　私が苦労して作っ\nたＫＶ－２を……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113340005" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「だから苦労して作ったのは……いえ、もういいですけど……とにかくお嬢様\n？　もしかして？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「ええ！　復讐よ！　あのボケナスビを、このままのさばらせてはおけないわ\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113340006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「ルルーナさん……！　わかりました、やりましょう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130113340004" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "動機はどうあれ、ルルーナがなんとか立ち直ったのはいいことだな。問題は…\n…。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「どうやって、あいつをやっつけるかだな……あいつ、文字通りの怪獣戦車だ\nからな……」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「それは、みんなで考えましょ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_020113340001" ]},
		{"command":[ "SETCHARA", "0", "char_00001802_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「グレーテル？　それに夜日楽もか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「私たちだって、みんなで作ったプラモデルを壊されてるんです。このままじ\nゃ、納得できません！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "7", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_017_020113340001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「そうね！　みんなで協力して怪獣退治よ！　今度こそあいつを、ギャフンと\nも言えなくしてやりますわ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113340007" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0149" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
		{"command":[ "SETTEXT", "そして、その夜……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「カツマ！　遅いわ！　なにをやってたのよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113340008" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そう言われましてもね、こっちはＥＤＯの仕事もあるんですよ！　っていう\nか、なんなんですか、表の看板」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「『怪獣戦車対策本部』よ！　決まってるじゃないの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113340009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「……私は、やめてと言ったのに」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_020113340002" ]},
		{"command":[ "SETCHARA", "0", "char_00001802_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「だろうな。そこは同情する」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「それより先生、さっきお願いしたものは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020113340002" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああ、買ってきた。これでいいのか？　１／３５スケールの『Ｍ２４チャー\nフィー』。このプラモを２つだな？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「そうです！　これです！　怪獣と戦うのなら、この戦車以外にありえません\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020113340003" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうなのか？　怪獣相手に強いのか？　この戦車」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「はい、ちゃんと調べました！　数々の名作怪獣映画で、防衛隊の主力として\n活躍した車両です！　間違いありません！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020113340004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「怪獣映画の……防衛隊？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "それ、大丈夫なのか？　ほぼ、やられ役なんじゃないのか？", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「……ご主人。いま考えておられることは、口に出さぬほうが身のためかと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113340001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……わかってる」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「では、カツマはそのプラモを、明日までに作っておくようにね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113340010" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「２チーム分。よろしく」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_020113340003" ]},
		{"command":[ "SETCHARA", "0", "char_00001802_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0022" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ふぁあああああ～……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「ちょっとカツマ！　あくびなんかしてないで、ちゃんと見張りなさい！　怪\n獣戦車が出てきたらどうするの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113340011" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「徹夜でプラモを２つも作らされたこっちの身にもなってくださいよ、まった\nくもう……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "あれから俺は寝ないでプラモを作り、授業を終え、ミス・パープルに頼んでマ\nシンを稼働させてもらい……というわけで、仮想空間内にいる。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いったい怪獣戦車はどこに……」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「音もせず、姿も見えず、ですな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113340002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「来るわ！　怪獣戦車！　気を付けて！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_020113340004" ]},
		{"command":[ "SETCHARA", "0", "char_00001802_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}