{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0144" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「さて皆様、単なるノルマでしかない戦闘、お疲れ様でした」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023100001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「実況がオブラートに包む気がないと、解説としてもツッコミようがありませ\nんね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110023100001" ]},
		{"command":[ "SETCHARA", "0", "char_00000514_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ともあれ、早速最初の対決を始めましょう。　既に、メンバーの選出は決ま\nっているようでありますな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023100002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「最初の対決テーマは何でしょうか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110023100002" ]},
		{"command":[ "SETCHARA", "0", "char_00000514_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「はい、発表いたします。最初のテーマは、題して……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023100003" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「『私がママよ！』母性的な花嫁対決！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023100003" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「…………はぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110023100003" ]},
		{"command":[ "SETCHARA", "0", "char_00000514_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「どうかされましたか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023100004" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「いえ、花嫁対決と言っているのに、ママを出してくるところに、そこはかと\nない気持ち悪さを感じまして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110023100004" ]},
		{"command":[ "SETCHARA", "0", "char_00000514_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「いやいや、結婚した妻の先にあるのは、もちろん母ですから。良妻賢母とい\nう言葉は、良き妻だけでは得られませんぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023100005" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「本当にそういう意味でならいいのですが。競技内容はどうなっていますか？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110023100005" ]},
		{"command":[ "SETCHARA", "0", "char_00000514_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「はい、皆様にはカツマ殿に関する５問の早押しクイズを出題し、最も正解数\nの高い花嫁が優勝となります」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023100006" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「テーマの割に、やることはクイズなんですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110023100006" ]},
		{"command":[ "SETCHARA", "0", "char_00000514_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「既に、壇上には出場者の３人が、一歩も譲らぬと睨み合っております！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023100007" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「どうもカツマの母です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010023100001" ]},
		{"command":[ "SETCHARA", "0", "char_00020103_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「どうもカツマの（育ての）母（ポジション）です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_040023100001" ]},
		{"command":[ "SETCHARA", "0", "char_00000703_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「どうも母（性のある神）です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_020023100001" ]},
		{"command":[ "SETCHARA", "0", "char_00003004_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「随分と貫禄のある３人の対戦だな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「さあ、一体誰が勝利を手にすることができるのか！　まずは最初の第１問！\n　カツマ殿の好きな食べ物は？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023100008" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「無論、私……母の手料理だ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010023100002" ]},
		{"command":[ "SETCHARA", "0", "char_00020103_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……いや、食った記憶がないんですが……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「本部ではカップラーメンを食されていることが多いように感じます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_020023100002" ]},
		{"command":[ "SETCHARA", "0", "char_00003004_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……すみません、他に選択の余地がなくて……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ふむ、この前、部下共にスシを振る舞ったな。スシは好きじゃろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_040023100002" ]},
		{"command":[ "SETCHARA", "0", "char_00000703_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あ……それは、まぁ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「美味かったよなぁ？　スシ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_040023100003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「は、はい」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ということで、カツマ殿が好きな食べ物はスシでした！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023100009" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ちょっと待て、これ、そういうルールなのか！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「はい、気にせず続けて第２問！　カツマ殿が好きな色は？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023100010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「それは、無論、燃え盛る赤に決まっておろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_040023100004" ]},
		{"command":[ "SETCHARA", "0", "char_00000703_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「爽やかな白も、よろしいかと思いますが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_020023100003" ]},
		{"command":[ "SETCHARA", "0", "char_00003004_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「青において他になし。息子よ、今、お前が着ている服は何色だ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010023100003" ]},
		{"command":[ "SETCHARA", "0", "char_00020103_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「それは……青、ですかね……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ふ……今、口にしたようだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010023100004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「あっと、これは刻の女王様の頭脳プレイ！　青とはっきり言わせましたー！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023100011" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「だから、こういうルールでいいのかよ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「実際、何でもいいんじゃないですかね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110023100007" ]},
		{"command":[ "SETCHARA", "0", "char_00000514_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「投げやり！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「では次の問題。カツマ殿が好きなおっぱいのサイズは？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023100012" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010023100005" ]},
		{"command":[ "SETCHARA", "0", "char_00020103_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_040023100005" ]},
		{"command":[ "SETCHARA", "0", "char_00000703_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「大きいの……お好きではありませんか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_020023100004" ]},
		{"command":[ "SETCHARA", "0", "char_00003004_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……え、えぇ……まぁ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ここは、完全に牛神様が黙らせたーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023100013" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「……うぬ、息子のことを知りすぎているが故に……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010023100006" ]},
		{"command":[ "SETCHARA", "0", "char_00020103_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「余も、本来の姿に戻っていれば……！　いや、しかし、あのサイズまでは…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_040023100006" ]},
		{"command":[ "SETCHARA", "0", "char_00000703_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「チッ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110023100008" ]},
		{"command":[ "SETCHARA", "0", "char_00000514_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……今、すげぇ舌打ちが聞こえたな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「さあ、３人が同点に並んだところで、続いての問題！　カツマ殿が今一番欲\nしいものは？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023100014" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「母の愛であろう。私が存分に与えてやろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010023100007" ]},
		{"command":[ "SETCHARA", "0", "char_00020103_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あの……少し恥ずかしいですが……母乳をお飲みいただくというのは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_020023100005" ]},
		{"command":[ "SETCHARA", "0", "char_00003004_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ふふん、そんなものよりもっと切実に欲しいものがあるじゃろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_040023100007" ]},
		{"command":[ "SETCHARA", "0", "char_00000703_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「おっと、これはルナルバース女王が随分と自信ありげですぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023100015" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「……有給……３日分」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_040023100008" ]},
		{"command":[ "SETCHARA", "0", "char_00000703_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ほ、欲しいっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「あーっと、これは見事に決まりました！　女王にもう１点追加だ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023100016" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「目先の欲に釣られましたね……後から後悔するパターンですが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110023100009" ]},
		{"command":[ "SETCHARA", "0", "char_00000514_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……５日って言っとけばよかったか……？　いや、だが……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「随分低レベルなところで悩んでますね」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000514_01", "5", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_005_110023100010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「いかにもご主人と言えるでしょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023100017" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うるせぇよ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「さて、ここまでの得点は、刻の女王と牛神様が１点ずつ、そしてルナルバー\nス女王が一歩リードの２点。しかしまだ分かりません！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023100018" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「いよいよ最後の問題です！　最後の問題はなんと得点が３倍！　全員に逆転\nのチャンスがございます！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023100019" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「はぁぁぁっ！？　なんじゃそれっ！　通るかそんなもんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_040023100009" ]},
		{"command":[ "SETCHARA", "0", "char_00000703_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「そ、そう言われましてもルールですので……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023100020" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「見苦しいぞ、貴様も女王ならもう少し泰然自若としていたらどうだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010023100008" ]},
		{"command":[ "SETCHARA", "0", "char_00020103_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「参加者がルールに従わないのは、問題になるかと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_020023100006" ]},
		{"command":[ "SETCHARA", "0", "char_00003004_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「うぬぅ、負けておるからここぞとばかりに……構わん、余が残りの１問も取\nればいいんじゃろうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_040023100010" ]},
		{"command":[ "SETCHARA", "0", "char_00000703_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「は……承知頂けたようで何よりです。それでは最後の問題！　カツマ殿の母\nといえば誰？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023100021" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……お、おいおい、それはっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「それならば、勿論、私だ。メインストーリーでも重要な役割を果たしていた\nだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010023100009" ]},
		{"command":[ "SETCHARA", "0", "char_00020103_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「言い方がメタい！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「勿論、余じゃよな？　さっきの休暇……取り消されたくないじゃろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_040023100011" ]},
		{"command":[ "SETCHARA", "0", "char_00000703_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「めちゃくちゃパワハラなんですけど！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「……カツマさんは、お二人の時は、いつも私に甘えるように母乳を飲まれま\nすよね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_020023100007" ]},
		{"command":[ "SETCHARA", "0", "char_00003004_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ちょっ！　あっ、いやっ、そのプライベートなことはっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「どさくさ紛れに、ドン引きの性癖が暴露されましたね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110023100011" ]},
		{"command":[ "SETCHARA", "0", "char_00000514_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そこまでのやつじゃねぇだろぉっ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「さあ、母の元へ来るがよい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010023100010" ]},
		{"command":[ "SETCHARA", "0", "char_00020103_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「う、うぉっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「こら！　カツマは余の元におるのじゃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_040023100012" ]},
		{"command":[ "SETCHARA", "0", "char_00000703_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あだっ、あだだだだっ！　ひ、引っ張らないで下さいっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「おっぱい……吸っていいんですよ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_020023100008" ]},
		{"command":[ "SETCHARA", "0", "char_00003004_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おわぷっ！　か、顔が埋もれっ……息がっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「あーっと！　ここで各選手一斉にカツマ殿に群がり、権利を奪いに掛かりま\nした！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023100022" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「そりゃあ、あんなガバガバルールを見せつけられたら手段を選んではいられ\nねーですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110023100012" ]},
		{"command":[ "SETCHARA", "0", "char_00000514_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「男としてはある意味夢のような展開……あ、あぁーっと？　これは……ご主\n人……プレスされて……気絶？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023100023" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「見事に圧死しましたね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110023100013" ]},
		{"command":[ "SETCHARA", "0", "char_00000514_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「これは……え～、答えの鍵となるご主人が気絶してしまった為、正解者はな\nしとなります」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023100024" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「と言うことは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110023100014" ]},
		{"command":[ "SETCHARA", "0", "char_00000514_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ここまでのポイント一歩リードしていた、ルナルバース陛下が勝利となりま\nす！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023100025" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「うぉらっしゃーーーーーいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_040023100013" ]},
		{"command":[ "SETCHARA", "0", "char_00000703_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「うぬっ……そんな馬鹿な……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010023100011" ]},
		{"command":[ "SETCHARA", "0", "char_00020103_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あらあら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_020023100009" ]},
		{"command":[ "SETCHARA", "0", "char_00003004_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「見事、原作部門チームが一歩先行という形になりました！　と……ご主人…\n…カツマ殿は？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023100026" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「まだダウンしたままですね。三方から揉みくちゃにされたから当分起き上が\nれませんよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110023100015" ]},
		{"command":[ "SETCHARA", "0", "char_00000514_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「うむぅ……仕方ありませんな。というわけで、またしばらくバトルでお待ち\n下さい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023100027" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「完全にＣＭモードですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110023100016" ]},
		{"command":[ "SETCHARA", "0", "char_00000514_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}