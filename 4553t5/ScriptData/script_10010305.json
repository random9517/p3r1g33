{
	"scriptCommands" :  [
        {"command":[ "FADEIN", "NORMAL" ]},
        {"command":[ "SETIMAGE", "0", "bg_0101" ]},
        {"command":[ "DISPIMAGE", "0", "true" ] },
        {"command":[ "FADEOUT", "NORMAL" ]},
        {"command":[ "PLAYBGM", "BGM_004" ]},
        {"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「くっ！　まだまだっ！」", "NORMAL" ]},
        {"command":[ "DISPTEXT", "TRUE" ]},
        {"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "PLAYVOICE", "001_010103050001" ]},
        {"command":[ "SETCHARA", "0", "char_00000101_01", "4", "CENTER", "0" ]},
        {"command":[ "DISPCHARA", "0", "TRUE" ]},
        {"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「もういいかげんにしろ。今の貴様では、私には勝てない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_090103050001" ]},
        {"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ふざけるな！　私は――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010103050002" ]},
        {"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「私は貴様だ。貴様の考えることなら、それこそ手に取るようにわかる。なに\nしろ自分のことだからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_090103050002" ]},
        {"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「なにぃ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010103050003" ]},
        {"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「もちろん、貴様が今、冷静さを欠いていることもな。冷静さを欠いたときの\n貴様は――いや私は……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_090103050003" ]},
        {"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「でやぁあああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010103050004" ]},
        {"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「このように見え見えの太刀筋で、力任せに切りかかってくる。わかるんだ、\n自分のことだから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_090103050004" ]},
        {"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「くっ……くううっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010103050005" ]},
        {"command":[ "SETCHARA", "0", "char_00000101_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ルナテミス、いいかげんに意地を張るのはよせ。さあ、こちらへ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_090103050005" ]},
        {"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「そうだよ、ルナテミス。もうやめて、カツマさんを探しに――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "012_010103050001" ]},
        {"command":[ "SETCHARA", "0", "char_00001201_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「う、うるさいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010103050006" ]},
        {"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「あっ！　ルナテミス待って！　もう、しょうがないなあ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "012_010103050002" ]},
        {"command":[ "SETCHARA", "0", "char_00001201_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「やれやれだ……つきあってられないねえ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "003_010103050001" ]},
        {"command":[ "SETCHARA", "0", "char_00000301_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「エファ？　どこ行くんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "004_010103050001" ]},
        {"command":[ "SETCHARA", "0", "char_00000401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「……散歩だよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "003_010103050002" ]},
        {"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "002_010103050001" ]},
        {"command":[ "SETCHARA", "0", "char_00000201_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「はぁ……いったい、どうしろっていうんだ。隊長は逃げ出す、隊はバラバラ\n。この調子で、地球を守れるのか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "049_010103050001" ]},
        {"command":[ "SETCHARA", "0", "char_00004901_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「お困りのようですね？　そんなときこそ我が、クリスタル・コンツェルンの\nサービスを！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "072_010103050001" ]},
        {"command":[ "SETCHARA", "0", "char_00007201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「うわっ！　な、なんだ！？　ミス・パープル！　急に現れないでくれ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "049_010103050002" ]},
        {"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「いえいえ。必要とされるサービスを必要な次元に迅速にお届けする、という\nのが当コンツェルンの理念ですので」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "072_010103050002" ]},
        {"command":[ "SETCHARA", "0", "char_00007201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「それで？　何を売りつけようっていうんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "049_010103050003" ]},
        {"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「本日お勧めするのは、代わりの隊長です！　この事件転移装置にクリスタル\nを投入し、こちらのボタンを押しますと――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "072_010103050003" ]},
        {"command":[ "SETCHARA", "0", "char_00007201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「押しますと？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "049_010103050004" ]},
        {"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「別次元から有能――かもしれない人材が召喚されます！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "072_010103050004" ]},
        {"command":[ "SETCHARA", "0", "char_00007201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「おお！　それは素晴らし――いや、ちょっと待て。有能『かもしれない』と\nいったか？　そうでない可能性もあるのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "049_010103050005" ]},
        {"command":[ "SETCHARA", "0", "char_00004901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「そこは長官の運次第！　大丈夫！　気に入った人材が出るまで、クリスタル\nを投入し続ければいいのです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "072_010103050005" ]},
        {"command":[ "SETCHARA", "0", "char_00007201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ちょっと待て！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "049_010103050006" ]},
        {"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「クリスタルが足りなくなるのがご心配ですか？　大丈夫！　そんなときには\n当コンツェルンのクリスタルローンを――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "072_010103050006" ]},
        {"command":[ "SETCHARA", "0", "char_00007201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「帰ってくれ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "049_010103050007" ]},
        {"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},	
		{"command":[ "FADEIN", "NORMAL" ]},
        {"command":[ "WAITMOVE" ]},		
        {"command":[ "DISPIMAGE", "0", "FALSE" ] },
        {"command":[ "FADEOUT", "NORMAL" ]},
