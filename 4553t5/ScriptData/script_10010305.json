        {"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ね？　だから二人で……いえ、三人で探しに行きましょ。カツマ隊長を」", "NORMAL" ]},
