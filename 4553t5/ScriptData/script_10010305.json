		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "014_010103050002" ]},
        {"command":[ "SETCHARA", "0", "char_00001401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「まりあ……？　どうしてここに」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "002_010103050004" ]},
        {"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「あなたが出ていくのが見えたから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "014_010103050003" ]},
        {"command":[ "SETCHARA", "0", "char_00001401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「……邪魔をしないで。カツマを探しに行く」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "002_010103050005" ]},
        {"command":[ "SETCHARA", "0", "char_00000201_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「……はぁ。だろうと思った。私も行くわ」", "NORMAL" ]},
