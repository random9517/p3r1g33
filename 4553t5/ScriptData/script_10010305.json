		{"command":[ "WAITINPUT" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
        {"command":[ "SETIMAGE", "0", "bg_0002" ]},
        {"command":[ "DISPIMAGE", "0", "true" ] },
        {"command":[ "FADEOUT", "NORMAL" ]},
        {"command":[ "PLAYBGM", "BGM_005" ]},
        {"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「――なるほどのう。そのような状態にのう」", "NORMAL" ]},
        {"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "PLAYVOICE", "007_010103050001" ]},
        {"command":[ "SETCHARA", "0", "char_00000701_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「はい。陛下、あのままでは姫様の心労、察するに余りあります」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "003_010103050003" ]},
        {"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ま、そんなに気にせんでよかろう。なんといってもルナは余の娘よ。そこま\nで繊細――ゲフンゲフン、ひ弱ではあるまいて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "007_010103050002" ]},
        {"command":[ "SETCHARA", "0", "char_00000701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「さようでございましょうか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "003_010103050004" ]},
        {"command":[ "SETCHARA", "0", "char_00000301_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「さようじゃさようじゃ。お主らさえついていてくれれば、心配することもあ\nるまいて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "007_010103050003" ]},
        {"command":[ "SETCHARA", "0", "char_00000701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「承知いたしました。しかしながら陛下……おそれながら、お伺いいたします\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "003_010103050005" ]},
        {"command":[ "SETCHARA", "0", "char_00000301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「おう、なんじゃ。わしとお主の仲じゃ。遠慮せずなんなりと聞いてみ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "007_010103050004" ]},
        {"command":[ "SETCHARA", "0", "char_00000701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「なぜ、カツマを隊長にすることをお認めになられたのです？　あやつはとて\nも人の上に立つ器ではございません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "003_010103050006" ]},
        {"command":[ "SETCHARA", "0", "char_00000301_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「そうかの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "007_010103050005" ]},
        {"command":[ "SETCHARA", "0", "char_00000701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「……陛下は、違うとお考えで？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "003_010103050007" ]},
        {"command":[ "SETCHARA", "0", "char_00000301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「さあ、それもどうかのう？　なあ、エファよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "007_010103050006" ]},
        {"command":[ "SETCHARA", "0", "char_00000701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「はっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "003_010103050008" ]},
        {"command":[ "SETCHARA", "0", "char_00000301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「そう結論を急がず、もう少し長い目で見てやってはどうかの？　意外とこの\n先、あやつも化けるかもしれんぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "007_010103050007" ]},
        {"command":[ "SETCHARA", "0", "char_00000701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「は、はあ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "003_010103050009" ]},
        {"command":[ "SETCHARA", "0", "char_00000301_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ま、今のところ、余から言えるのはそんなもんじゃな。それではエファ、し\nっかりと務めを果たしてくれよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "007_010103050008" ]},
        {"command":[ "SETCHARA", "0", "char_00000701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「しかと承知……いたしました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "003_010103050010" ]},
        {"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
