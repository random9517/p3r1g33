        {"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「なんだかんだ言って、ジュンジローさんもカツマさんのことが心配みたいだ\nし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "014_010103050006" ]},
        {"command":[ "SETCHARA", "0", "char_00001401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「まあ、さほど心配してはおりませんがな。ただ、あのご主人を野放しにして\n世間様にご迷惑をかけては、と」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "009_010103050001" ]},
        {"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ジュンジローも……」", "NORMAL" ]},
