		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「……あなたも？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "002_010103050006" ]},
        {"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「まさか、あなたカツマを……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "002_010103050007" ]},
        {"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「か、勘違いしないで！　わたしは、あの人がインクレディブル・スクワッド\nに必要だと思ってるだけ！　それに――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "014_010103050005" ]},
        {"command":[ "SETCHARA", "0", "char_00001401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「それに？」", "NORMAL" ]},
