{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「あー……綺麗な海！　風も気持ちいいし、砂浜も素敵だし……けど日差しが\nちょっと強すぎるかなーって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0304101" ]},
		{"command":[ "SETCHARA", "0", "char_00010203_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「え？　日焼け止めローション、塗ってくれる？　確かに、この日差しじゃ絶\n対必要ですよね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0304102" ]},
		{"command":[ "SETCHARA", "0", "char_00010203_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「ここに横なればいいんですね？　わかりました……じゃあ、お願いしまーす\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0304103" ]},
		{"command":[ "SETCHARA", "0", "char_00010203_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「ん……んん、はぁ……やだ、いきなり、触り方がエッチなんですけど……あ\n、ああ……はぁ……んふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0304104" ]},
		{"command":[ "SETCHARA", "0", "char_00010203_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「やだ……隊長さん、もうパンツ脱いでる……うっわ、ギンギンじゃないです\nか……はぁ……もう、仕方ないんだからぁ──」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0304105" ]},
		{"command":[ "SETCHARA", "0", "char_00010203_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「……最初っから、エッチするつもりだったんですね？　もう、手回しいいん\nだからぁ……まあ、あたしも予想してましたけどねー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0304106" ]},
		{"command":[ "SETCHARA", "0", "char_00010203_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「ってか、マジでカッチカチですねー……もう、どんだけやりたかったんです\nか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0304107" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00010203_02_02" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「そもそも、エッチするだけならビーチにわざわざこなくてもよかったんじゃ\nないですかー？　あたし、言ってくれればいつでも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0304108" ]},
		{"command":[ "SETIMAGE", "0", "still_00010203_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「へ？　せっかく水着なんだから、ピッタリのチュエーションでしたかった…\n…ですって？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0304109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「エッチのために、そこまで手間掛けるだなんて……どんだけあたしのこと好\nきなんですかー……うう、恥ずかしくなってきました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0304110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「あっ、あはぁぁぁぁん……う、後ろから、挿れられるの……好き、かも……\nあぁん、気持ち、いいですぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0304111" ]},
		{"command":[ "SETIMAGE", "0", "still_00010203_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「これじゃ、すぐにイッちゃう、かも……。ん、ふぅ……おちんちん、すごぉ\nい……硬くて、大きくて……これ、ヤバい、です……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0304112" ]},
		{"command":[ "SETIMAGE", "0", "still_00010203_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「いきなり濡れ濡れになってる？　ええ、それはもう……ローションを塗られ\nた時から、こんな感じでした……ん、あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0304113" ]},
		{"command":[ "SETIMAGE", "0", "still_00010203_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「最近、濡れやすくなっちゃんですよねー……誰かさんの、ん、んん、おかげ\nで……はぁ、んふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0304114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「あ、ああ、はぁ……あああ……入って、くる……おまんこの中で、おちんち\nんがずるずる動いてる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0304115" ]},
		{"command":[ "SETIMAGE", "0", "still_00010203_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「ふぐぅ、あはぁぁ……お腹の隙間が、おちんちんにこじ開けられていく……\nはぁ……おまんこがいっぱいになっちゃう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0304116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「ん、んんっ、はぁ……あはぁぁぁあん……奥まで、届いちゃった……先っち\nょが、子宮にぶつかってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0304117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「んくぅ、あっ、あっ、ああぁ……コツコツぶつかってる……うくぅ、あはぁ\n……すごぉい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0304118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「や、やだ……駄目、気持ちいい……こんなの、すぐにイッちゃうよぉ……あ\nはぁ、はぁ……ひやぁぁぁん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0304119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「隊長、さん……もっと気持ちよくしてぇ……はぁ、ふぅ……もっと激しいの\nがいい……お願い……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0304120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「んひぃ！　あはぁ……はぁ、はぁ……ああぁぁん……出たり、入ったりして\nる……ぐぅ、うぅ、はぁ……あひぃぃ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0304121" ]},
		{"command":[ "SETIMAGE", "0", "still_00010203_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「おまんこが締め付けてる……はぁ、んん……おちんちんの形が、くっきりわ\nかります……はぁ、ふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0304122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「先っちょの、傘が開いた部分……ん、はぁ……おまんこの内側が引っかかれ\nて、あ、はぁ……絡みついてる、みたい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0304123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「ひうぅ、あはぁ……気持ちいい……膝が、ガクガクしちゃう……ああぁん、\nはぁぁあん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0304124" ]},
		{"command":[ "SETIMAGE", "0", "still_00010203_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……お日様が眩しい……。砂浜がキラキラしてる……こんなに明\nるい中でセックスするだなんて……変な感じ、です……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0304125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「はぁ……ふぅ……あたし、そろそろイキそう、です……え？　隊長もイキそ\nう……？　それじゃ、一緒にイキましょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0304126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「あひぃ！　きゃううぅ……ヤバい、これ……そんなに激しく、されたら……\nあ、ああ……駄目ぇ……んひぃぃぃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0304127" ]},
		{"command":[ "SETIMAGE", "0", "still_00010203_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「おちんちんが、ぶつかってる……っ！　おへその奥で、ゴンゴンぶつかって\n……火花が散ってるみたい……あ、ああ、ダメェ……壊れちゃうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0304128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「ふぐぅ、はへぇぇ……隊長、さん……あ、あたし、もう駄目ぇぇ……イッ、\nイキ、ます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0304129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「え？　隊長さんも……？　あはぁ、嬉しい……はぁ、んっ、あ！　ひぃ！！\n　ひゃうぅぅぅぅん！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0304130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「あああぁぁぁぁん！！　うくぅ……あはぁ……イクッ、イッ……イッてる…\n…いっぱい、イッちゃうぅぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0304131" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010203_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「出てる……あああ、あたしも、いっぱい出しちゃう……はぁ、んん、あぁぁ\nああん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0304132" ]},
		{"command":[ "SETIMAGE", "0", "still_00010203_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「す、すごぉい……お腹の中で、射精されてる……ビュルビュル精液が溢れて\nるのが、伝わって、くる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0304133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、イクっ……気持ちいいのが、止まらない……！　あたし、イッ\nてる……ずーっと、イッちゃうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0304134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「ああぁぁん……射精が、治まっていく……はぁ、ふぅ……でも、まだビクン\nビクンしてる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0304135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「はー……あはぁぁ……いっぱい、出しましたねー……ふぅ、あたしもこんな\nに……はぁ、ふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0304136" ]},
		{"command":[ "SETIMAGE", "0", "still_00010203_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「目の前が、クラクラします……ふぅ、熱中症かもしれませんね……はぁ、は\nへぇぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0304137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「あれぇ？　おちんちん、まだ硬いみたいですけど……これ、どうしたらいい\nですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0304138" ]},
		{"command":[ "SETIMAGE", "0", "still_00010203_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「続きをする？　あはぁ、ですよねー……そう言ってくれるって、思ってまし\nた。はぁ……ふぅ……嬉しいなぁ……えへへー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0304139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「まだ気持ちいいのが、残っています……すぐイッちゃいかもしれませんね…\n…はふぅ……それじゃ、始めましょう──」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0304140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「あぁぁ！　はぁ、あはぁぁ……じゅぽじゅぽ音がする……おまんこの中が、\nおちんちんに掻き混ぜられてる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0304201" ]},
		{"command":[ "SETIMAGE", "0", "still_00010203_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「はぁ……はへぇ……いきなり気持ちよすぎて、ん、んん、力が入らないん、\nです、けどぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0304202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「おちんちん、奥まで入ってくる……はぁ、ふぅ……お腹の奥が、先っちょに\n持ち上げられてるぅ……！　んひぃぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0304203" ]},
		{"command":[ "SETIMAGE", "0", "still_00010203_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「あっ、はぁ……はぁあん……おまんこが、引っ張られちゃう……おちんちん\nに、中身がくっついちゃうよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0304204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「はへぇぇ……肌が日差しでチリチリする……ん、あぁ、ローション、塗って\nもらってよかったぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0304205" ]},
		{"command":[ "SETIMAGE", "0", "still_00010203_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「隊長さん……あたし、また気持ちよくなって、きちゃったぁ……ああ、水着\nの中で、おっぱいがタプンタプンしてる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0304206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「乳首が、ん、んん、気持ちいい……はぁ、はへぇえ……ああ、すごぉい、精\n液が、おまんこの中で泡立ってるよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0304207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「ああ、身体から汗が溢れてる……ん、んん、水着がビチャビチャ……はぁ、\nあふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0304208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「頭が、ぼーっとするぅ……ああ、駄目ぇ……気持ちいい……隊長さん……あ\n、あたし……ヤバいです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0304209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「これ、マジで熱中症の可能性、ありますけど……でも、ん、んあぁ、はぁ…\n…気持ちいいよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0304210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「ふぐぅ、はへぇぇ……あ、ああ、イク……イキ、そう……ああん、おちんち\nんが、おまんこ、いっぱい気持ちよくしてくれてます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0304211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「ふえぇ……？　また潮吹きするのか……ですって？　はー……ふぅ……どう\nでしょう？　また、出ちゃう、かも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0304212" ]},
		{"command":[ "SETIMAGE", "0", "still_00010203_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「砂浜で、よかったぁ……それに、水着だし……ふぅ、ふふ、おっぱい出して\nも、誰の迷惑にもなりませんね……はぁ、あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0304213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「ひやぁ、あああん、駄目ぇ……あたし、もうそろそろ……でも、隊長さんと\n、一緒にイキたいです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0304214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「ん、んん、お願い、です……もっと、動いてぇ……はぁ、はふぅ……いっぱ\nい、気持ちよくしてぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0304215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「ひゃぐぅ……あはぁぁ……はぁ、あぁああん……！　す、すごい……お腹に\n、ずんずん来るぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0304216" ]},
		{"command":[ "SETIMAGE", "0", "still_00010203_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「んぎぃ、あはぁ……いっぱいぶつかってくる……ひやぁ、駄目ぇ……おまん\nこ、壊れちゃう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0304217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「おちんちんが、中で暴れてる……子宮の奥まで掻き混ぜられちゃう……駄目\nぇ……気持ちよすぎて、なんだか……あ、あ、あああ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0304218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「ひうぅ、隊長さん……何か、来る……なんだか、おまんこが、変だよぉ……\nはぁ、はぁ……あぁぁぁあん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0304219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「ひうぅ……あはぁ……あたし、もうイッちゃうぅ……隊長も出してぇ……あ\nたしに、いっぱい精液ぶちまけてぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0304220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「きゃうぅぅぅぅ！！　はぁ……はぁぁん、出したて精液、中でうねってる…\n…！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0304301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010203_02_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「子宮の中に、んん、あはぁ……熱いのが、流れ込んでくる……ひうぅ、あは\nぁ……中で渦巻いてる、みたい……んくぅ、はへぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0304302" ]},
		{"command":[ "SETIMAGE", "0", "still_00010203_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「あぁぁ、熱いので、いっぱいになってる……はぁ、ふぅ……おへその裏が、\nホカホカしてるよぉ……これ、妊娠、しちゃうんじゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0304303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……あぁん、どうしよう……？　妊娠したら、学生、続けられな\nい……かも……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0304304" ]},
		{"command":[ "SETIMAGE", "0", "still_00010203_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「あぁん、精液がどんどん入ってくるぅ……はぁ、ふぅ……子宮が、破裂しち\nゃいそう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0304305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「はへぇぇ……すごかったぁ……はぁ、ふぅ……頭がぼーっとしてる……あふ\nぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0304306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「けど、もし妊娠しちゃったら……もう試験とか、赤点とか関係なくなっちゃ\nうんでしょうか……だとしたら……はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0304307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「妊娠したら、サムライテール、卒業……？　あはははぁ……まさか、そんな\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0304308" ]},
		{"command":[ "SETIMAGE", "0", "still_00010203_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「姉さんを差し置いて、サムライテールをサボッたりなんてできません。急（\nいそぐ）は全然頼りにならないし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0304309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「ふぅ……ともかく、すっごく気持ちよかったです……しばらく、ここで休み\nましょう……波の音を聞きながら、ね……ふふふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0304310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「ああぁぁぁあん……熱いぃ……はぁ、あぁあん……白いのが、降ってくるぅ\n……はぁ、はぁ……あへぇぇぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0304401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010203_02_17" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「精液、こんなに、いっぱい……はぁ、ふぅ……あああん、熱いのが、肌に張\nり付いてくる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0304402" ]},
		{"command":[ "SETIMAGE", "0", "still_00010203_02_16" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「ん、はぁ……滴ってくる……はへぇ……水着がドロドロのぐちゃぐちゃ……\nはぁ、ふぅ……洗濯しなきゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0304403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「ん。ふぅ……お亥さまに頼んだら、着替え用にもう一組、水着もらえるかな\nぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0304404" ]},
		{"command":[ "SETIMAGE", "0", "still_00010203_02_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……あふぅ……精液が染み込んでくる……肌に染み込んで、妊\n娠しちゃいそうです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0304405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「はぁ……ふう……おまんこが、ぽっかりと口を開いています……はふぅ……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0304406" ]},
		{"command":[ "SETIMAGE", "0", "still_00010203_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「見て下さい……ほら、ほらほら、奥からさっき出された精液が、ゆっくりと\n滴って……あ、ああ……はぁ、この感触、気持ちいい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0304407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「はぁ……ふぅ……あはぁぁ……まだイッてます……ああ、身体に力が、入り\nません……はぁ、ひうぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0304408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「ふぅ……ジッとしてると、日差しが強く感じますね……ふぅ、ふふ、隊長さ\nん……今度はあたしが日焼け止めを塗ってあげましょうか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0304409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「うふふ……じゃあ、もう少し休んだら、あたしが塗ってあげますね……ふふ\nふ、楽しみにしてて下さいね……」", "NORMAL" ]},
