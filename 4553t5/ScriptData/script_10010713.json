{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "bg_0133" ]},
		{"command":[ "DISPIMAGE","0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "PLAYBGM", "BGM_007" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「やった！　完！　俺達の戦いはこれからだ……！」", "NORMAL" ]},
	{"command":[ "DISPTEXT", "TRUE" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「きゃぁあ～～ん！　すんごいです！　カツマ様ぁ～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010107130001" ]},
	{"command":[ "SETCHARA", "0", "char_00000601_01", "8", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「最高です！　カツマ様！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010107130001" ]},
	{"command":[ "SETCHARA", "0", "char_00000401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はっはっ、そう褒めるな褒めるな。お前達にはまだまだこれからも働いても\nらわねばならんからな！」", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「わーっはっはっはっはっ！　ここが俺の国！　食い倒れカツマ帝国だ！　わ\nははは！　わーっはっはっは！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYBGM", "BGM_004" ]},
		{"command":[ "SETTEXT", "極限までのけぞって、大声で笑っていると……遠くから、妙な音が聞こえてき\nた。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ん？　なんだ？　空を何かが……？」", "NORMAL" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「ん……？　あれは……ヘリではないか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090107130001" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ヘリ？　……よく見えない……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「待て！　あのマークには見覚えがある。あれは……ＥＤＯのマークではない\nか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090107130002" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ＥＤＯ……！？　バカな、とうの昔に滅んだはずでは！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "俺の叫びを掻き消すように、接近し、降下してくるヘリコプター。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "その機体をよく見ると……？", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……本当にＥＤＯのヘリだ……」", "NORMAL" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「と、いうことは……？　えーと……ど、どういうことだ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010107130001" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "1", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「……ここは、未来の世界でも、別宇宙でもないということでしょうね。おそ\nらく」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010107130001" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「な、なんだと……！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そして、そんなオボロの言葉を裏付けるように、ヘリの中から出てきたのは…\n…。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「みんな！　無事だったか！　いやぁ～！　よかったよかった！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010107130001" ]},
	{"command":[ "SETCHARA", "0", "char_00004901_01", "8", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ち、ちっともよくねえええええええ～っ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "と、叫ぶ俺を押しのけ、みんなは長官に駆け寄る。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「長官！　助けに来てくれたのか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010107130002" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "8", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「うぇえええ～ん！　ダイヤナちゃん寒かったのぉ～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010107130002" ]},
	{"command":[ "SETCHARA", "0", "char_00000601_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「長官！　ちょうかぁ～～ん！　うわぁあああ～ん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010107130001" ]},
	{"command":[ "SETCHARA", "0", "char_00001201_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「いやいや、すまなかった。ロケットが札幌市郊外に落下するとわかって、す\nぐに救助に来るつもりだったのだが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010107130002" ]},
	{"command":[ "SETCHARA", "0", "char_00004901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「観測史上まれにみる吹雪とかで、身動きが取れなくなってな。それに、襲来\n者（インベーダー）が現れたとの情報もあって、心配していたんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010107130003" ]},
	{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "bg_0134" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "そんな長官の言葉を裏付けるように、徐々に吹雪が止んでいく。すると、そこ\nに現れたのは……。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「こ、ここは……公園か！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090107130003" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「うむ。札幌市の中心部にある公園だな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010107130004" ]},
	{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「人の姿が、まるで見えなかったのは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010107130002" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「まあ、あの吹雪では誰も出てこられんだろう。それに襲来者が現れたので\n、屋内避難の指示もあったしな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010107130005" ]},
	{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「あちらに見えるのは、もしかして有名なテレビ塔……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010107130001" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「うむ。上は展望台になっているぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010107130006" ]},
	{"command":[ "SETCHARA", "0", "char_00004901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「ロケットに見えたのは、あれだったのか……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090107130004" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「あ！　むこうに札幌ラーメンって看板が……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010107130002" ]},
	{"command":[ "SETCHARA", "0", "char_00000401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「コーンとバターのトッピングがおすすめだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010107130007" ]},
	{"command":[ "SETCHARA", "0", "char_00004901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「で、ではここは……不毛の大地、前人未踏のパラレルワールドではない、と\n……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010107130003" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「あんた札幌なめてんでない？　なんぼなんでも、そこまで田舎でねえべさ！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010107130008" ]},
	{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「なるほど……街の様子が様変わりしていたのではなく、吹雪でよく見えてい\nなかっただけ、ということでしたか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010107130003" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「すると、我々が先ほどまで戦っていた相手は……猿ではない！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090107130005" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「ウソ！　あんな毛むくじゃらで、言葉も話さなかったのに！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010107130002" ]},
	{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「捕虜を尋問したところ、あまりの寒さで口も聞けなかったらしいな。毛皮に\n見えたのは、彼らの防寒装備だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010107130009" ]},
	{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「そ、そうだったんですか……じゃ、あれは、襲来者（インベーダー）……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010107130002" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「……誰かの口車に乗せられて、鍋にしなくてよかったよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010107130001" ]},
	{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そうだな……まったくそうだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010107130004" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あ、あれ！？　あれ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "みんなの！　みんなの視線が冷たい！　あんなに俺を持ち上げてくれてた、あ\nの熱狂は！？　さっきまでの信頼は！？　そして……", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ここに築くはずだった、俺の帝国は……？」", "NORMAL" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ていこく？　ああ、地下鉄に遅れは出ていないようだが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010107130010" ]},
	{"command":[ "SETCHARA", "0", "char_00004901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うっ……ううううっ……ううっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「まあ、とにかく諸君が無事でよかった。それに寒かっただろう、ヘリの中に\n暖かいココアを用意してある」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010107130011" ]},
	{"command":[ "SETCHARA", "0", "char_00004901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「ココア……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010107130003" ]},
	{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「……ごくっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010107130001" ]},
	{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「それに毛布とおやつもだ。大人には、熱燗とつまみも少しばかりな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010107130012" ]},
	{"command":[ "SETCHARA", "0", "char_00004901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「熱燗……っ！　ちょ、長官……っ！　あんたって人は……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010107130002" ]},
	{"command":[ "SETCHARA", "0", "char_00000301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「やぁ～ん！　ダイヤナちゃん、一生長官についていっちゃう～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010107130003" ]},
	{"command":[ "SETCHARA", "0", "char_00000601_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「はははは！　それは光栄だなぁ！　さあ、みんな。本部へ帰ろう。あ、いや\n……せっかくだし、札幌ラーメンを食べてからにするか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010107130013" ]},
	{"command":[ "SETCHARA", "0", "char_00004901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「おおおおおー！　長官！　長官！　長官！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010107130003" ]},
	{"command":[ "SETCHARA", "0", "char_00000401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「長官最高～～～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010107130004" ]},
	{"command":[ "SETCHARA", "0", "char_00001201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「信じていた！　私は、貴方を信じていたぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010107130005" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「暖かいラーメン……！　魅力的なお誘いです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010107130004" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あ、あああああ……あああああ……み、みんな……」", "NORMAL" ]},
