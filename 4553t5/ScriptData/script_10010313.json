		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……ん？　あ、ああ……あれ？　他の連中は」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「みんな先に帰ったよ。明日も仕事だから、ってよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "034_020103130002" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんだなんだ……帰るんなら、起こしてくれりゃいいじゃねえか。ったく、\n気がきかねえなあ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「とはいえ、あいつらもいいとこあるんだよ。わざわざ俺のために『復帰祝い\n』なんか開いてくれたりしてさ？　そう思わねえ？　ほむらちゃん」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ほむら『ちゃん』言うな。もう閉店なんで、そろそろ帰ってもらっていいか\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "034_020103130003" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ん？　ああ……もうそんな時間か。それじゃ、帰るわ。ごっそさん」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ちょっと待った」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "034_020103130004" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ん？　どした？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「お勘定だよ。ほら、これ伝票」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "034_020103130005" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「え？　でも、今日は俺の復帰祝いで――」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「隊長の復帰祝いだから、隊長からもらえってさ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "034_020103130006" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんじゃそりゃぁ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「隊長手当つくから、大丈夫だろうってよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "034_020103130007" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「つかねえよ、そんなもん！　残業手当だってろくにつかねえ！　そんな俺に\n、この――なんだよ、この金額！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「そりゃまあ、あの人数であんなに飲み食いすりゃなあ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "034_020103130008" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「これを全部？　俺に払えと……？　手取り１７万の俺に？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「誰も月収は聞いてねえよ。とにかく、払ってもらいますよ、お客さん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "034_020103130009" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "0", "CENTER", "0" ]},
