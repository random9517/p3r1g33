{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0081" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "小休憩が終わって競技が再開し、再び小休憩の時間となった。", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「みんなお疲れ。どうだ、このコンテストは？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「変な競技ばっかりだけど、それなりに楽しめてるわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070021520022" ]},
		{"command":[ "SETCHARA", "0", "char_00000107_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「それはよかった。そういえば、次はなにをやるんだ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「わからん。チラシにも書いてあったが、競技内容ははじまる直前までわから\nないんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090021520024" ]},
		{"command":[ "SETCHARA", "0", "char_00000111_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピースムーン" ]},
		{"command":[ "SETTEXT", "「ビーチフラッグ、高飛び込み、騎馬戦、水着コンテスト、尻相撲と来てるの\nで、そろそろ団体戦が来ると思いますが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_040021520015" ]},
		{"command":[ "SETCHARA", "0", "char_00000811_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なっ、なんだ！？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者" ]},
		{"command":[ "SETTEXT", "「はははははっ！　愚かな原住民どもよ、ひれ伏すがいい！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「大変ですぞ！　会場の外に襲来者（インベーダー）が現れて、暴れておりま\nす！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021520060" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なにっ！？　なんでよりにもよって、こんなタイミングで……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「その襲来者（インベーダー）……もしかしたら、僕たちがコンテスト前に見\nつけたヤツらかも……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010021520024" ]},
		{"command":[ "SETCHARA", "0", "char_00009602_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「アイツらやたら強かったからな……！　オレたちだけじゃ、手に負えねぇ！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_010021520013" ]},
		{"command":[ "SETCHARA", "0", "char_00009702_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「でも街のみんなを守るためにも、戦わないと……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021520014" ]},
		{"command":[ "SETCHARA", "0", "char_00009802_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「そうだね。このままだと、大変なことになっちゃうし～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_010021520013" ]},
		{"command":[ "SETCHARA", "0", "char_00009902_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「よし、すぐに戦闘準備だ！　行くぞ、スクールガール・ミュータント・ニン\nジャ・ラビッツ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010021520032" ]},
		{"command":[ "SETCHARA", "0", "char_00010002_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "４人" ]},
		{"command":[ "SETTEXT", "「イエーーーーーイ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010021520025" ]},
		{"command":[ "SETCHARA", "2", "char_00009802_01", "3", "CENTER", "200" ]},
		{"command":[ "SETCHARA", "1", "char_00009702_01", "3", "CENTER", "-600" ]},
		{"command":[ "SETCHARA", "0", "char_00009602_01", "3", "CENTER", "600" ]},
		{"command":[ "SETCHARA", "3", "char_00009902_01", "3", "CENTER", "-200" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "DISPCHARA", "2", "TRUE" ]},
		{"command":[ "DISPCHARA", "3", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「カツマさん！　私たちも行くですよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021520021" ]},
		{"command":[ "SETCHARA", "0", "char_00010103_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "DISPCHARA", "2", "FALSE" ]},
		{"command":[ "DISPCHARA", "3", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「古人曰く、旅は道連れ世は情け。情けない世の中とおさらばするには、やっ\nぱ道連れが大事ってことです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_010021520013" ]},
		{"command":[ "SETCHARA", "0", "char_00010203_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「ボクにかかれば襲来者（インベーダー）なんて、真っ二つのズンバラリンだ\nよ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021520017" ]},
		{"command":[ "SETCHARA", "0", "char_00010303_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お前たち……！　助かるよ！　ありがとな！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「礼には及びません。それでは、失礼するです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021520022" ]},
		{"command":[ "SETCHARA", "0", "char_00010103_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「お姉ちゃん！　私たちも変身して戦おう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_030021520022" ]},
		{"command":[ "SETCHARA", "0", "char_00001203_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「わかったわ……！　モード『ＳＩＬＶＥＲ・ＳＴＡＲ』スタンバイ！　シル\nバドライブ・リンケージ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_020021520029" ]},
		{"command":[ "SETCHARA", "0", "char_00001402_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「月夜に蠢く悪を断つ！　銀星装甲シルバスター、オーバードライブ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_020021520001" ]},
		{"command":[ "SETCHARA", "0", "char_00001302_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「私も先に行って、少しでも敵の数を減らしておくね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_020021520002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああ、頼んだぞ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おい、みんな！　俺たちも襲来者（インベーダー）を倒しに行くぞ！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「イヤよ。私たち、まだコンテストが残ってるんだもの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021520013" ]},
		{"command":[ "SETCHARA", "0", "char_00000306_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「そうよ～。それにここにはバカンスで来たんだし、戦うなんてゴメンだわ～\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_050021520013" ]},
		{"command":[ "SETCHARA", "0", "char_00000605_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「私も次の競技に備えて、体力を温存したいしな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040021520013" ]},
		{"command":[ "SETCHARA", "0", "char_00000404_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「どうぞカツマさん一人で頑張ってください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_060021520014" ]},
		{"command":[ "SETCHARA", "0", "char_00000506_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「せっかくの休暇なのよ。仕事なんてやってられないわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070021520023" ]},
		{"command":[ "SETCHARA", "0", "char_00000107_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お、お前ら……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「か、カツマ……落ち着いて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_050021520018" ]},
		{"command":[ "SETCHARA", "0", "char_00000205_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピースムーン" ]},
		{"command":[ "SETTEXT", "「正義は悪を倒し、悪は悪を放置する。ある意味、正しい言動ですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_040021520016" ]},
		{"command":[ "SETCHARA", "0", "char_00000811_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「だがこのままでは、この世界が襲来者（インベーダー）の手に堕ちてしまう\n！　それだけは避けなければ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090021520025" ]},
		{"command":[ "SETCHARA", "0", "char_00000111_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうだぞ！　それにこのまま襲来者（インベーダー）が暴れれば、コンテス\nトが中止になる可能性だってある！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうなれば、豪華賞品がもらえなくなるぞ！　それでもいいのか！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「っ……！？　それは盲点だったわね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070021520024" ]},
		{"command":[ "SETCHARA", "0", "char_00000107_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「私が活躍して目立てば、優勝するより注目されて、ナンパされるかも……！\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021520014" ]},
		{"command":[ "SETCHARA", "0", "char_00000306_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「賞品が貰えなかったら、食うモノがなくなるじゃないか！　そんなことさせ\nないからな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040021520014" ]},
		{"command":[ "SETCHARA", "0", "char_00000404_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「コンテストが中止になるのはよくありません。仕方ないですね……戦うとし\nましょうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_060021520015" ]},
		{"command":[ "SETCHARA", "0", "char_00000506_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「それでも、ディアナちゃん戦いたくな～い」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_050021520014" ]},
		{"command":[ "SETCHARA", "0", "char_00000605_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「ディアナ……このリゾートが襲来者（インベーダー）の手に堕ちれば……街\nで売ってるブランド品が買えなくなるわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_050021520019" ]},
		{"command":[ "SETCHARA", "0", "char_00000205_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「それもそうね。なら、ちょっとやる気出しちゃおっかな～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_050021520015" ]},
		{"command":[ "SETCHARA", "0", "char_00000605_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ま、まあ……やる気になってくれたならなによりだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「よし！　それじゃ、俺たちも襲来者（インベーダー）退治に行くぞ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}