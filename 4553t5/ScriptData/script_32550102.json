{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0129" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「……いらっしゃい、私の学園長室へ。でも、良かったのかしら？　こんな夜\n更けに、のこのこと訪ねてきてしまって……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0104101" ]},
		{"command":[ "SETCHARA", "0", "char_00025501_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「なんて。私のことを、信用……してくれていると思っていいのかしら？　す\nごく嬉しいわ。でも、実は……今日の私はとても悪い女なのよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「ほらっ……♪　貴方が来てくれるのを、今か今かと待ちわびて……こんなに\n熟れたオマンコを一人で濡らしてしまっていたの。もっと近づいて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0104103" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00025501_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「よぉーく観察して……♪　はぁ、はぁ……♪　わかる、わよね？　もう限界\nなの……胸の先も軽く勃起してしまっているわ……。はぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0104104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「貴方のことを考えると、日に日に我慢ができなくなっていくの……。私に触\nってほしい、私も触ってあげたい、二人で理性を忘れて愛し合いたいって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0104105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「愛液と精液でドロドロに濡れそぼるまで交じり合いたいの……♪　どうかし\nら……どこが一番美味しそうだと思う？　ぱっくり開いた割れ目……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0104106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「それとも、潤んだ肉壺の穴かしら？　もしかしたら、ビンビンに敏感になっ\nて反応しているクリトリス？　愛液の量もね、普通じゃないの……ずっと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0104107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「これって、貴方のことを愛しているからだと思うのだけれど……。んッ、こ\nのまま、私……オナニーしちゃおうかしら？　そ・れ・と・も……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0104108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「貴方のおちんちん、その期待に膨れ上がった巨大なおちんちんをこの穴に挿\n入してみたくはない？　きっとぬちょぬちょで気持ちいいと思うのよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0104109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「っふっ……♪　うふふふっ……♪　そうよね、入れてみたいわよね……♪　\n逞しくて、若くて、荒々しいそのおちんちん。ズボンの中のソレを……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0104110" ]},
		{"command":[ "SETIMAGE", "0", "still_00025501_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「見下ろしているだけで妄想でイッてしまいそうなの。ね……私を助けると思\nって、エッチ……してくれるかしら？　可愛い可愛い私のぼうや……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0104111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「貴方のおちんちんを欲しがって、濡れたヒダヒダをうねうねさせているこの\n熟女オマンコに、一番硬いのをください♪　早く……はやくぅう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0104112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「んあっはッ♪　んぁあああああっ♪　来たわぁっ、太いおちんちん奥まで入\nってきたぁああ♪　嬉しいっ……嬉しい、素晴らしいわっ、もっとよぉっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0104113" ]},
		{"command":[ "SETIMAGE", "0", "still_00025501_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「もっとギリギリまで、限界まで奥に突き入れてっ！　子宮が持ちあがるくら\nい♪　子宮口をグリグリ亀頭で突き刺して！　ああっ、あぁ、ふぁああ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0104114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「絶対抜いてはいけませんからねぇええ♪　あんっ！　あぁ、最高ですっ……\n！　夢にまでみた貴方の生おちんちんっ……！　あぁあああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0104115" ]},
		{"command":[ "SETIMAGE", "0", "still_00025501_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「想像よりっ、１００倍いいのっ……！　百点満点をさしあげますっ！　っぅ\nううっ♪　ためらいもなく、生のおちんちんを挿入してくれるだなんて♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0104116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「貴方は天使の生まれ変わりか何かかしらっ……！　あんっ！　そうなの！　\n私……貴方と生でしたかったの！　ああ……♪　膣内全部が喜んでる♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0104117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「わか、りますか……！？　あっ♪　オマンコが歓喜してっ、あっあっ♪　貴\n方のおちんちんを離すまいと咥えこんできているのがっ……！　はぁあっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0104118" ]},
		{"command":[ "SETIMAGE", "0", "still_00025501_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「え……？　私の腰が動いているから、よくわからない……？　んまぁっ♪　\nご、ごめんなさいね……っ！　本当に、劣情の限界で……！　ふぁッ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「貴方のおちんちん、体験したらもう自動で腰がっ♪　お尻が揺れてしまうの\nよ……！　あっ！　あっ！　だって！　だってだってだってぇええ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0104120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「おちんちんっ！　おちんちんの形がよくわかるんですっ……♪　貴方もそう\nでしょう……っ、はぁ、はぁ、私が感じているのがわかる、はず」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0104121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「トロトロに柔らかくなったオマンコから、たくさん愛液が分泌されて……は\nぁあっ♪　完全におちんちんを受け入れている……迎えているっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「粘膜と粘膜をこすりあわせて、同じ快感に溺れたいと言っているのが……伝\nわってくるわよね？　あっ♪　こんなに、何度も締め付けて……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0104123" ]},
		{"command":[ "SETIMAGE", "0", "still_00025501_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「狂おしいくらいに貴方のおちんちん、欲しがって……あ、あ、あぁ……！　\nんぁああっ……！　恥ずかしい、下品なママでごめんなさい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0104124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「貴方の腰使い……とってもいいわ。続けて……っ、絶対にやめてはダメよ…\n…！　は、ぁ♪　あぁっ、あぁあ……！　すごく愛液が溢れてくる♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「貴方のおちんちん、気持ちいい……！　ぐりゅっ、ぐりゅって子宮口を突き\n上げてくる……！　幹も太くて♪　んんんっぅう♪　激しくて♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「肉笠が……中をぐちゅぐちゅ刺激してくれるの……っ♪　……あっ♪　そこ\n、そこよ……！　そこが気持ちいいっ、もっとして、もっとえぐって♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0104127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「……いいえっ、私から……動きます！　はぁっ……こ、うかしら？　貴方が\n気持ちいい動かし方はどれかしら……？　うふふふふっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0104128" ]},
		{"command":[ "SETIMAGE", "0", "still_00025501_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「こうやって、じっくり探っていくのって不思議な感覚だわ……♪　あぁっ♪\n　貴方のおちんちんを探検して、深く深く知っていくの……っ、はぁっはぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「前後に揺らすのがいい？　んッ♪　グリグリ回転させると感じる？　っぁ♪\n　私、は……♪　ズポズポ縦に……あっ、上下に出し入れするのが好き♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「あぁ……♪　ここね♪　ここを刺激されるのがいいのね……♪　わ、かりま\nした……♪　たくさんたくさん刺激しましょう……♪　はぁ、はぁ、あぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「あら……♪　おちんちんが素直に反応してくれていますよ？　ピクピク中で\n痙攣して……♪　また、おちんちんから精子出ちゃいそうなんですね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0104132" ]},
		{"command":[ "SETIMAGE", "0", "still_00025501_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「なんて……なんて可愛いおちんちんなんでしょう……♪　敏感で、私のする\nことにすぐ反応して……。ふふっ、貴方は今何を考えているのです？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「このまま……私を孕ませたいですか？　中出しして♪　種付けしてみたいと\n……思いますか？　であればこうです、オマンコを締めつけて……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「逃がしてなんてあげませんよ……♪　ほぉら、中出しです♪　この中に♪　\nオマンコの奥の子宮に……貴方の体液を注入してみせなさい……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0104135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「はぁああああっ♪　出しましたね……っ、いたずらっ子さんっ……♪♪　そ\nうですよ、そのまま……そのまま射精し続けてくださぁいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0104136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00025501_02_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「あッ♪　膣内に……オマンコにドッと流れこんでくる……！　押し寄せてき\nます、貴方の種が……！　ああああっ、熱い……！　気持ちいいです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0104137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「く、ふ……♪　んくぅううううっ！　っあぁ♪　ご、めんなさい……！　絶\n頂を止められませんでした、だって、だって中出しなんてされたら！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「私っ……！　その事実だけで何度でもイッてしまいます！　すごい……っ、\nすごい！　これが貴方から精を受け取る感覚……激しすぎますっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0104139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「あぁ……♪　体液と体液で溶け合って……お互いの粘膜が一つになっていく\n♪　これが♪　本物の快楽なのですね……うっとりしてしまいます♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「っん……♪　どうしましょう、イクのがずっと止まりません……♪　それに\n、貴方も貴方です。中出しをしてもまったく萎えず衰えていない……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0104201" ]},
		{"command":[ "SETIMAGE", "0", "still_00025501_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「これはもっともっと、確実に私を孕ませたい、絶対に私の卵子を奪いたい、\nという意思表示だと思っていいのですよね？　もし、間違っていたとしても」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「もう、やめてなんてあげられませんから。はぁ、はぁ♪　したい……貴方と\n永遠にしていたい♪　んんっ、わかりますね？　また締めつけました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「おちんちんを私の中から抜くことなんてできないでしょう。……安心してく\nださい、ここからは私が動きます。っふ……♪　ふふふ、うふふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0104204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「あぁんっ、んんっ、おちんちんで掻き回すほどに精液が……子種が私の膣内\nに塗りたくられて……どんどん妊娠の確率があがって……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0104205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「なんて危険な行為でしょうか……っ♪　これこそ究極の愛、至高の奉仕……\nっ♪　あっ♪　あっ♪　いやだ、勝手にオマンコが蠢いてしまう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0104206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「恥ずかしい……っ、なのにどうしてもコレがしたいのです！　……あら？　\n貴方も腰を揺らして……ふふふ♪　私をもっと突きたいんですね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「どうぞ♪　全力で突いてくださいっ、貴方のピストンに合わせます……！　\nっう……♪　若いのね、抜かずの二回戦でもこの硬さ、羨ましいわ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「ふ……、あっ♪　あぁんっ、ああっ、あああ……！　す、ごい……っ♪　私\nが動く以上の力で……ズポズポおちんちんを上下させて……！　はぁあっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0104209" ]},
		{"command":[ "SETIMAGE", "0", "still_00025501_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「も、もう私のオマンコの扱いを覚えてしまったのね……！　あっ、あっ、貴\n方ってとっても優秀な生徒だわ……んぁあっ、私の知る限りで一番！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0104210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「一番上手に女を……っ、はぁんんっ♪　女性器を感じさせることが出来る…\n…ぅっ！　あっ♪　いやっ、私ったら貴方よりも年上、なのにっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0104211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「翻弄されちゃってる……！　っんんんっ！　ねえっ、あまり焦らないでぇ♪\n　私が貴方に奉仕してあげたい、のにっ、いつもいつも逆になっちゃうぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0104212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「貴方の最高のおちんちんで♪　私が喜ぶだけになっちゃってるわっ♪　あん\nっ♪　ダメ……っ、だめ、乱れちゃう……！　こんなの困るのぉっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0104213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「んッ♪　あぁっ、あっ、おっ！？　おほッ……！？　あああっ♪　いやだ、\n下品な声が漏れてしまって……んぁんんっ！　んほっ！？　おほぉっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0104214" ]},
		{"command":[ "SETIMAGE", "0", "still_00025501_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「や、ぁ♪　気持ちいいわ……！　私の子宮、貴方に完全になついてしまって\nる……！　あっ♪　あぁっ、突き上げる力、強い……素敵、あっあっあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0104215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「今っ……！　中でおちんちんが太く……大きく膨らんで……！　ひっぅっ♪\n　また精液が溜まってきた、のですか？　この中に注ぎ込みたいのですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0104216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「い……いですよ♪　ですが、どうせ出すのであれば……んぁああっ♪　一番\n量が多くなった時に♪　一番濃くてねばつく精液が出る時にっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0104217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「私のっ、私の子宮口めがけて勢い良く発射してくださいっ！　あああっ！　\n欲しい……ッ、欲しいのです、貴方の子種が……精液が……♪　う、あぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0104218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「おね、がいぃ♪　私の淫らなオマンコが、真っ白に染まってしまうまで容赦\nなく発射してぇ♪　こちらからも絞り上げますっ……いきますよぉ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0104219" ]},
		{"command":[ "SETIMAGE", "0", "still_00025501_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「はぁっ♪　ああああっ……大きいっ……！　締めつけるだけでこちらも……\nこちらも快感が！　身体中に駆け巡って……ああああああッ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0104220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「ひぃいいいいんっ♪　あひいぃいっ、んひぃいいいっ♪　これですっ、これ\nぇっ♪　熱い濁流が私の中に再びぃっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0104301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00025501_02_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、子宮の入口を突破して……ドクドクと中に流れこんできます！\n　さきほど出した量よりもずっと多い……なんと情熱的な！　あぁあっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「こんなのっ♪　絶対受精してしまいますっ、あっ♪　二回目なのにぃいいっ\n……すごすぎます！　出てる……出てるのがはっきり感じ取れて……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0104303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「貴方の種を受け取っている、と♪　受精しているとわかります……！　ひぃ\nんっ♪　あぁうううっ♪　なんて熱烈な種付け……！　あっあっあっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0104304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「好きになってしまいます、貴方のおちんちんしか愛せなくなってしまうぅう\n……っ！　あああっ、ママのオマンコでパパになりたいんですねぇえっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0104305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「赤ちゃんのお汁♪　ビュルビュル射精して、深夜の学園長室で子作りだなん\nてっ♪　スキャンダルも良いところです！　でも……でも、でもぉおっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0104306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「おちんちんからの直接の種付け、気持ちいいんです！　あぁ……！　熱い、\nじゅわじゅわと染みこむような……♪　最高の中出し……！　んんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0104307" ]},
		{"command":[ "SETIMAGE", "0", "still_00025501_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「一生忘れられない膣内射精をぉ……あり、がとうございました……♪　ふぅ\nっ、ふぅっ……♪　こんな風に孕めるなんて、女として最高の喜びです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0104308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「貴方と貴方のおちんちんは……女を、いいえ……私を♪　虜にする優秀なお\nちんちんです。最優秀……天才、オールA、トリプルS……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「あぁ……貴方が私の生徒であれば、いくらでも褒めたたえて、通知表に花丸\nを書いてあげるのに……それが出来なくて、少し残念です……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「あうっ！？　ま、待ってください！　力をこめたらおちんちんがズルリと抜\nけて……！　あっ！　精液が、胸に……顔に……ふぁああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0104401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00025501_02_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「だ、だめ……！　ダメですっ、この精液は！　私が子宮で飲み干す予定で…\n…！　っんぅううう♪　だめ、だめぇ♪　だめなのに……嘘っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0104402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「わ、私……かけられて絶頂してしまっているっ、あッあっ！　貴方の体液を\n浴びせかけられることで、マーキング……されているように感じますっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0104403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「私が貴方のオンナだと♪　身体に教え込まれているみたいで……！　くふぅ\nううっ♪　イクッ、イクぅ……！　あぁっ、ヌルヌルがそこかしこにぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0104404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「あ、あぁ……♪　私……貴方のものになってしまったのですね……♪　っん\nんんっ♪　肌の上を流れる精子……貴方の臭いを覚えこまされて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0104405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「あっ、あぁ♪　ゾクゾクするのはなぜなの……？　精液まみれになるのが心\n地いい……ずっとこうしていたいのぉっ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0104406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「……ん……♪　ごめんなさい……♪　気持ちが良すぎて……あまりの快感に\n我を失ってしまっていました。年上なのに情けないですね……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0104407" ]},
		{"command":[ "SETIMAGE", "0", "still_00025501_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「それにしても、改めて貴方の才能と素質を全身で感じることができました。\n私が認め、愛するにふさわしいその身体。心。全て……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0104408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「こんなにじっくりと堪能させていただいて、ありがとうございました……。\nあ、ま、まだもう少し離れないで。そばにいてください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0104409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「この素晴らしい時間を終わらせたくありません。ふふふふ♪　大人になると\n、これほどまでに陶酔できる時間はなかなかありませんから……」", "NORMAL" ]},
