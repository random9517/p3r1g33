		{"command":[ "PLAYVOICE", "007_0103402" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「オチンチンの先っぽから、びゅうっ、びゅうっってぇ……！　白くてネバネ\nバしたのが……あぁんっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0103403" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「あぁんっ、クサくてキタナいお汁がお顔にいっぱいかかっちゃってるぅ……\nやぁん、すごくエッチなニオイだよぉ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0103404" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ニオイがしみついたら、みんなにバレちゃうね……？　おにいちゃんにイヤ\nらしいことをさせられて、せーえきをお顔にかけられたって……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0103405" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「やぁんっ……！　また出てきたぁ……！　どぴゅっ、どぴゅってぇ……！　\nあぁん、おにいちゃんの、エッチぃ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0103406" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「……む？　これで終いか？　くっはぁ……！　またずいぶんと出してくれた\nのう？　顔中がお主のザーメンでベタベタだぞ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000701_01_10" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0103407" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ペット扱いされたのがよほど腹に据え兼ねたとみえるな。それで……どうじ\nゃ？　もう満足したかのう？　余はそろそろ飽きてきたのじゃが……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0103408" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「それにしても、哀れなものよの。これだけの精子が、女を孕ませることもで\nきず、ムダ撃ちをされてしもうて……まるでお主そのもののようじゃな？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0103409" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「んん？　どうしたのじゃ？　またオチンポが固くなってきておるぞ？　怒っ\nたのか？　それとも、罵られてまた悦んでしまったのか？　くくくっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0103410" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ならば、ほれ、もっと出すが良い。お主の気が済むまで何度でもシてやろう\n。存分に精液をムダ撃ちして、余の顔や手を汚すがよい。ほーっほっほ」", "NORMAL" ]},
