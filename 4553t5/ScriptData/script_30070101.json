{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},		
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "PLAYVOICE", "007_0103101" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「女王たる余をこんな部屋まで呼びつけるとは……お主もまた、ずいぶんと偉\nくなったものよのお？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0103102" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「まあ、よかろう、余も暇しておったところじゃしな。退屈しのぎにはちょう\nど良い。それで？　一体、余に何の用事じゃ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0103103" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「……ぬぁにぃ？　貴様……月の女王たる余に……チンポへの性奉仕をせよと\n……そう申したか……？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0103104" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「どうやらちと、甘やかしすぎたようじゃのう……余の態度があまりにもヌル\nすぎたと、そういうことじゃろうなあ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0103105" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「……あるいは、余を見かけどおりの小娘とでも思うておるのか……？　だと\nしたら、とんだ愚か者よ……！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0103106" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「よかろう。グレート・ルナリアムが女王、ルナルバース１３世の恐ろしさ…\n…骨身に染みるまで、存分に思い知らせてくれるわっ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0103107" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「……と、いうのはもちろん冗談じゃ。……ん？　どうしたのじゃ。そんなに\n怯えて……ちょっとしたお茶目だというのに」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0103108" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「なにせ最近は、余の威厳を見せつける機会が少なくてのう……ちと不満が溜\nまっておったのじゃ」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0103109" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ともあれ、最近のお主はなかなかに頑張っておるようじゃしな。部下に報い\nるのも、上司たる女王の勤め」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0103110" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「よってお主に褒美をとらす。余が自ら、お主に性的な奉仕を施してやろうで\nはないか……そう、たっぷりと、な……くふふっ、じゅるりっ……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0103111" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「おほっ、もうすっかり、チンポが勃起しておるではないか？　くくくっ、ヤ\nる気まんまんだのう」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000701_01_01" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0103112" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「余にしてもらえると思って、イチモツをおっ立てておったのか？　ういやつ\nよのう……よしよし、余が存分に可愛がってやるぞ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0103113" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「そぉら、余の小さな手で、お主の魔羅を擦ってやろう。竿を握りしめて、上\n下にシコ、シコと……根本から先っぽまで、丁寧にシゴいてやろう」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0103114" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「カリ首のところも、ほれ、こうして握りしめて、ねっとりとこねくり回すと\n……たまらぬであろう？　余の巧みなチンポ捌きに酔いしれるが良い」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0103115" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「余は特に玉磨きという技が得意でな……敏感な亀頭と鈴口を手のひらで包み\nこみ、くるくると擦ると……そら、男はたまらず、潮を撒き散らすのじゃ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0103116" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「くくっ……ほれ、ほれ……どうじゃ？　小さくて、温かくて、そして柔らか\nな幼女の手ひらに、チンポを弄ばれる気分は……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0103117" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「なんじゃ、その顔は？　余が直々に性の奉仕をしてやっておるのじゃぞ？　\n光栄に思い、好きなだけむせび泣くがよい……くっくっく」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0103118" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「……しかし、なかなかどうして……お主のチンポは、少しナマイキじゃな？\n　ゴツゴツとして、ビンビンに固く反り返っておって……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0103119" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「長さも太さも、申し分ない……この小さな手のひらには到底収まりきらぬほ\nど、大きくて立派なペニスじゃ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0103120" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「カリも鋭く尖っておるし、まさに女泣かせの名器と言えよう……お主のよう\nなヘタレ男には、ちともったいないのう……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0103121" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「んん？　なんじゃ、先走りの汁が漏れてきたぞ？　余の小さな手の平にイジ\nられて、チンポが気持ちいい、気持ちいいと泣いておるわ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0103122" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「まったく、いたいけな幼女にチンポを握らせて興奮するとは、とんでもない\n変態よのう。お主にそのような趣味があったとはとんと知らなんだ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0103123" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「無垢な手のひらを醜悪なオスの欲望で汚して悦ぶなど、実に業が深い……く\nくっ。ならば、どれ、少しサービスをしてやるとするかの……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0103124" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「……ねぇ、おにいちゃん！　オチンチン、すっごくおっきくなってるよ？　\nわたしにオチンチンをゴシゴシされると、きもちいいの？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000701_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0103125" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「じゃあ、もっとマッサージしてあげるね！　どこがきもちいのかなぁ。さき\nっぽのところ？　ここをクルクルされるのがスキなの？　こ～う？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0103126" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「えぇ～、ダメなの？　でも、オチンチンはよろこんでくれてるよ？　こんな\nにビクビクして、うれしいうれしいって、泣いちゃってるよ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0103127" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「わわ、オチンチン、またおっきくなってきた……！　さきっぽのところがパ\nンパンにふくらんで……うふふ、もっともっと、みがいてあげるね！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0103128" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「あはっ！　さきっぽのお口が、きんぎょみたいにパクパクしてる！　ヌルヌ\nルのなみだをい～っぱいながして、おねだりしてるよ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0103129" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「もう出そうなの？　ネバネバした白いオシッコ、たくさんおもらししちゃう\nの？　いいよ、じゃあね、も～っと激しくしてあげるね……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0103130" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「いいよ、出してぇ……ちっちゃなおんなのこにオチンチン、シコシコされな\nがら、きもちよくなっちゃえ……ほらほら、イっちゃえ……イけ、イけ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0103131" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「きゃぁああんっ！！　すごいよぉ、やぁんっ、へんなお汁が、いっぱい出て\nるぅ……！」", "NORMAL" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000701_01_06" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0103132" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「白くて、ドロドロしたお汁が……あぁんっ、オチンチンのさきっぽから、ど\nぴゅ、どぴゅうって、出てるぅ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0103133" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「きゃぁんっ、熱いよぉっ……！　お汁が顔にまでかかっちゃってる……お手\n手にもいっぱいかかって、ドロドロ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0103134" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「やんっ！　すごぉい、まだ出てる……！　オチンチンがビクビクってすると\n、さきっぽからまた、お汁がぴゅっ、ぴゅうっって……", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0103135" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「もっといっぱい出るように、オチンチン、応援してあげるね。ほら、シコシ\nコ、オチンチン、ガンバレ、ぴゅっぴゅ、ガンバレ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0103136" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「……む？　そろそろ終いかの？　まったく、好き勝手に出してくれよって…\n…くっはぁ！　精液のむせ返るようなニオイ！　なんという濃さか……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000701_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0103137" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「いたいけな幼女に手コキ奉仕をさせて、どれだけ興奮したのじゃ？　手のひ\nらから顔までお主の子種汁でベタベタではないか、まったく……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0103138" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「……おにいちゃんってぇ、とぉ～っても、ヘンタイさんなんだね♪　ものす\nっご～く、キモチワルイよ？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000701_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0103139" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「おおっ！？　また出よった！　おっ、おぉっ……くっはははっ！　なんじゃ\n、幼女に罵られて漏らすなど、とんでもないオチンポじゃな！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000701_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0103140" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「しかし、お主……よほどこういうプレイが好きと見えるな。ちと今後の関わ\nり方を考えねばならぬかのう？　……犯罪にだけは手を染めてくれるなよ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0103201" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「……んん？　なんじゃ、あれだけ出したというのに、オチンポは固いままじ\nゃな。まだ出し足りないというのか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0103202" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「物欲しげにチンポをびくびくと跳ねさせおって……それは、おねだりのつも\nりか？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000701_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0103203" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「余にもっと手コキ奉仕をせよと？　またずいぶんと厚かましいチンポだのう\n……しかたのないヤツじゃ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0103204" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「よかろう。今回は特別じゃぞ？　お主が満足するまで、た～っぷりとオチン\nポ奉仕をして……玉が空になるまで、精液を絞り尽くしてやろう……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0103205" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「……だからね、おにいちゃんは、オチンチンのさきっぽから、クサくて、キ\nタナい、白いオシッコをぴゅっぴゅって、い～っぱいおもらししてね？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000701_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0103206" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ほらほらぁ～、こういうのがスキなんでしょ？　ちっちゃい女の子のお手手\nで、オチンチンをにぎにぎしてほしいんだよね？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0103207" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「せーえきを出したばっかりの、ネチャネチャのオチンチンにさわって、ぐち\nゅぐちゅ、シゴいてほしいんでしょ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0103208" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ちっちゃくて、やわらかくって、あったか～いお手手が、あなたのクサくて\nバッチイ、ネバネバのお汁で汚れるのを見て、こうふんするんでしょ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0103209" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「……あはっ！　オチンチン、すっごくビクビクしてる！　おにいちゃんのお\n顔も、すっごく、だらしなくなってるよぉ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0103210" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「おにいちゃんって、ホントにサイテーの、ヘンタイさんなんだね……あのね\n、いまのおにいちゃんね、ものすっご～く……ホントにキモイよ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0103211" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「おぉうっ！　くっ、はははっ！　なんじゃ！　オチンポが先走りの汁を吹き\n出しおったぞ！　くははっ！　大興奮じゃな！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000701_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0103212" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「よほどロリっ娘手コキプレイ、罵りオプション付きがお気に召したとみえる\n。とんでもない変態じゃな、お主は。正直、余も少し引いておるぞ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0103213" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「……なんじゃ？　なにやら不満そうな顔をしておるが……まさかお主、手コ\nキ以上のことを、余に期待しておるのではあるまいな？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000701_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0103214" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ふんっ、あまり調子にのるでないぞ？　そも、お主にそこまでの価値はない\n。余にとってお主は男ではなく、ただのオスじゃからの」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0103215" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「いわば催した飼い犬の性欲を発散させてやっているに過ぎぬ。さすがの余も\nペットのペニスを口やマンコでシてやるほど酔狂ではないぞ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0103216" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「……くっくっく、良い顔をしおる。悔しいのか？　ならば、ほれ、その劣情\nを余に向けて吐き出すが良い」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000701_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0103217" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「そろそろイきそうなのであろう？　チンポがまた大きくなってきよった。ペ\nット呼ばわりされて興奮したのか？　んん～？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0103218" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「どれ、風船のようにふくれあがった亀頭をキュッキュと磨きながら、血管の\n浮き出た竿をネチュネチュとシゴいてやろう」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0103219" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「そぉら、犬の尻尾のようにチンポを振って、ぴゅっぴゅと、臭くて、汚らし\nい精液を吐き出すが良い」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0103220" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ちっちゃな幼女の手で精液まみれのオチンポを弄くられて、情けなくオチン\nポ汁を漏らすのじゃ、そら、イけ、イくのじゃ、イけ……イけっ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},
		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "PLAYVOICE", "007_0103301" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「きゃあんっ！！　やだぁっ、おにいちゃんのせーえき、またいっぱい出てる\nよぉ……！　今度は、わたしの手マンコのナカに、いっぱい……！」", "NORMAL" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000701_01_09" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0103302" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「熱くて、ドロドロしたのが、どぴゅ、どぴゅうって……やぁん、そんなに出\nしたら、ナカにこびりついて、こびりついて取れなくなっちゃうよぉ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0103303" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「わたしの手マンコ、そんなに気持ちいいの……？　あぁん、出しすぎだよぉ\n、そんなにナカに出されちゃったら、お手手が妊娠しちゃうぅ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0103304" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ふぁぁっ、まだ出てるぅっ、どぷどぷって、ザーメンがいっぱい……わたし\nのナカに吐き出されちゃってるぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0103305" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「いいよぉ、もっといっぱい出して……ほら、ほら、オチンポぎゅっぎゅって\nしぼってあげる……きゃんっ、またいっぱい出てきた……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0103306" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「……ふむ、こんなものかの。まったく、しつこいくらいに手マンコにナカ出\nしをしおって。よほど本物のロリマンコに種付けをしたかったと見える」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000701_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0103307" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ま、むろんそんなものはお断りなんじゃがな。お主のような情けないオスの\nチンポなど、余の手マンコでも、贅沢すぎるというものじゃ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0103308" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「まあ、お主がどうしてもと言うのなら？　これからもたまには、余の手マン\nコを貸してやっても良いがのう？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0103309" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「寛大で慈悲深い、女王たる余に感謝をするのじゃぞ？　ほれ、お礼の言葉は\nどうした？　言うてみよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0103310" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「女王様の手マンコで、ボクのオチンポを射精させていただきまして、どうも\nありがとうございました、とな。くっ、くくくっ……はーっはっは！！」", "NORMAL" ]},
