		{"command":[ "PLAYVOICE", "v2_251_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「あぁぁ……滑りやすくなって……んんっ、さっきより……ずっとっ……出入\nりが……しやすくっ……なって、ますっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0104204" ]},
		{"command":[ "SETIMAGE", "0", "still_00025101_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「精液が……いっぱいオマンコに……入ってるから……あっ、んくぅっ……そ\n、それだけじゃない……？」", "NORMAL" ]},
