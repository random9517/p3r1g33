		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「今夜……どのような形でのお仕置きでも……お受けします……その、それで\n……私は……どうすれば……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0104103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
