		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「はっ、んっ、ふっ……あぁっ、おっぱいも、そんなっ……んんっ……！　あ\nっ、ぎゅってされると……変な、感じ……ですっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0104120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「あふっ、あっ、あぁっ……うくぅっ……そ、そのまま……奥に……来て下さ\nい……あ、ひぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0104121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「んくぁっ……あっ、あぁっ……やだ……声が、あっ、出ちゃう……んっ、く\nふぅっ、はっ、んんぁっ……あくぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
