		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「んぁぅっ！　あっ、あぁっ、そこっ、ですっ、あ、ひっ！　オ、オマンコの\nっ……奥のっ……とこぉっ、オチンチンでっ、擦られてぇっ……！」", "NORMAL" ]},
