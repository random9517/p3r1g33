		{"command":[ "PLAYVOICE", "v2_251_0104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「はいっ、いっぱいっ……いっぱい突いて下さいっ……！　何回でもっ、奥ま\nでっ……！　んくぅっ、おっぱいもっ……ぎゅってしてっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「あぁっ……大丈夫ですっ……少し、乱暴なくらいでも……感じ……やすくな\nっててっ……んっ、くぅぅんっ、ひぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0104209" ]},
		{"command":[ "SETIMAGE", "0", "still_00025101_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「どんどん口にするっ……あぁっ、はいっ、オチンチンがいいっ……！　オマ\nンコっ……オチンチンで犯されて、すごく気持ちいいですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0104210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「あぁっ、わたし……すごいこと言っちゃってるっ……！　オマンコなんてっ\n……い、言わないのにっ……でもっ、でもぉっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0104211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「はぁんっ、エッチなことっ……言うほどっ、あぁっ、乳首もっ……硬くなっ\nてっ！　オマンコもっ、じぃんって痺れてっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0104212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「あぁっ……かき回されるのがっ……たまらないですっ！　オチンチンしてっ\n……オチンチンいっぱいして下さいっ……んぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0104213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「恥ずかしいっ……あぁっ、恥ずかしいに決まってますっ！　いっぱいに足を\n広げさせられてっ……こんな太いの入れられてぇっ……！」", "NORMAL" ]},
