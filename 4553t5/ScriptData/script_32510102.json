		{"command":[ "SETIMAGE", "0", "still_00025101_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「んんっ、あぁ……はぁぁ……頭ボーッとする……ふぁぁ……気持ちいい……\nダメ……こんなの味わっちゃったら……わたしぃ……」", "NORMAL" ]},
