		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「うぁ……これ、スカート……全部めくれて……あぁ……ショーツ……脱がさ\nれちゃうなんて……恥ずかしい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0104106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「そ、そんなに……み、見ないで下さい……あぁ、こんな……何もかも、間近\nで覗き込まれるなんてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0104107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「濡れて……そ、それは……その、違うんです……期待していたとか、そうい\nうことじゃなくて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0104108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「恥ずかしいって思ったら……何もしなくても、どんどん……溢れて……あぁ\n、指……んっ、ダメです……はっ、あぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0104109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「んぅっ……い、いえ……逆らうつもりじゃ……あぁ……はい、あっ、んんっ\n……準備……ですよね、あぁ……お願い、します……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0104110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「はぁっ、んんっ、うぅっ……でも、もう……そんなに、しなくても……わた\nしの……あっ、準備……できてて……んっ、あっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0104111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「はい……入れて、下さい……オチンチン……こ、ここに……わたしの……そ\nの、あそこに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0104112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「あ……は、はい……オ、オマンコですか……その、オチンチン……オマンコ\nに……入れて、下さい……あっ、あぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0104113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「んぁふっ……あぁぁぁ……入って……んんっ、来るっ、んくぅぅぅんっ……\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0104114" ]},
		{"command":[ "SETIMAGE", "0", "still_00025101_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「あぁぁ……嘘……こんなにぬるんって……簡単に入っちゃうなんてぇ……あ\nっ、あぁぁ……広がって……行き、ます……んっ……ふっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0104115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「い、いえ……痛みは……ないです……んっ、ただ……お腹の圧迫感が……す\nごくて……はぁぁ……太い……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0104116" ]},
		{"command":[ "SETIMAGE", "0", "still_00025101_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「大丈夫、です……これは……お仕置きですから……少し痛くても……我慢、\nしますから……動かして、下さい……は、んっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0104117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「あっ、あぁっ……ゆっくり……されて、るっ……んくっ、あぅっ、はっ、ん\nぁっ……あぁっ、あ、はっ、あんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_251_0104118" ]},
		{"command":[ "SETIMAGE", "0", "still_00025101_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「やだ、わたし……ぬぷんって……オチンチン……しっかり飲み込んじゃって\nる……オマンコ……いやらしくなってるぅ……」", "NORMAL" ]},
