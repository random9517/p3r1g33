		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「だって、こんなに……あっ、感じやすいなんて……思わなくてっ……あっ、\nあぁっ、は、ひぁぁあんっ！」", "NORMAL" ]},
