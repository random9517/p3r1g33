		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「い、今の場所……あっ……は、はい……すごい……ですっ……んっ、あぁ…\n…も、もう一回……しても……？」", "NORMAL" ]},
