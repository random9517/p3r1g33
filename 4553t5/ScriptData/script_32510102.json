		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「けどっ、もうっ……戻れないですっ！　はぁぁんっ！　こんな気持ちいいこ\nとっ……知っちゃったらっ……あぁっ、そこぉっ！」", "NORMAL" ]},
