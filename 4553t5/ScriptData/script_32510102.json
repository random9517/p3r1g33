		{"command":[ "SETIMAGE", "0", "still_00025101_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "統制局局員Ａ" ]},
		{"command":[ "SETTEXT", "「ぐりぐりっ……壁のっ、場所っ……当たる度にっ……あひぃっ、あぁっ、身\n体っ……浮き上がっちゃい……ますぅっ！」", "NORMAL" ]},
