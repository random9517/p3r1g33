{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "PLAYVOICE", "034_0103101" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「隊長……呼び出しに応じて来てはみたけどさ……。ココってアレだよな？　\n仕置き部屋とか呼ばれてる、ウワサの……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00003401_01", "2", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0103102" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「あー……そっかそっか。や、いいんだ。俺、最近暴れまくってたし……。マ\nトモだったとはとても言えねえし。仕置きされるのは当然だ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0103103" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「で？　一体何してくれるっての？　鞭打ちか？　ッハッ……スタンガンで電\n流でも流してみっか？　その程度じゃ泣きもしねえけどな！　アハハハ！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00003401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0103104" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「……は？　パイズリ……？　パイズリって、あ、アレかよ？　かー……隊長\n……。そんなん仕置きになんねぇだろ？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00003401_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0103105" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「もっと、もっとこう、ガツンと喰らわせてこいよ！　……は？　絶対に仕置\nきになる？　ふぅん……だったらやってみてもいいぜ？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00003401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0103106" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「後悔すんなよ。今の俺にハンパな躾（しつけ）をしようとしたこと……。飢\nえた獣に甘っちょろい罰を与えたことをさ……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00003401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0103107" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「ん……はぁ、はぁ……。ンだよ、フツーよりでかいからって自信があるって\nか？　いくらデカくてもチンポはチンポだろ……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003401_01_01" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0103108" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「牙を剥いて襲ってくるわけじゃねえ。俺をボコボコに出来るわけでもない。\nコイツでお仕置きぃ？　笑っちまう」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0103109" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「こんなん見た目のグロさだけだろ。あー、ご立派ご立派。でもよぉ……俺、\n胸筋も相当鍛えてっから……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0103110" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「隊長こそ、途中で音をあげるんじゃねーぜ？　ハハ、……じゃ始めるか……\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0103111" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「う……くっ……！　ふぅっ……ふぅ、ふぅ……！　はぁ、はぁ、はぁ、はぁ\n……んんんっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003401_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0103112" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「胸全体で絞り上げるように……っ、……はぁっ……はぁ、はぁ、あっ、あぁ\n……っ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0103113" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「ほら……わかるだろ？　俺のオッパイ……他のやつらより硬い、よな……。\nはぁっ……重いし、ミッチリ詰まってるだろ……っ？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003401_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0103114" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「ズッシリ重い乳房にのしかかられるとさァ……やわなチンポじゃ相手になら\nねえんだよな。でも、隊長のはいい感じだぜ……？　っ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0103115" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「俺のパイズリに負けてねぇ。こちらのこすりについてきてる……。っはぁっ\n、はぁ……こっちがどんだけ押し潰して、も……はぁっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0103116" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「こんなもんかよって……逆に挑発してくる。すごい勢いで胸の肉はじき返し\nて……全力で来いよって言ってやがる……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0103117" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「大した性豪だぜ……、っ……はぁ、はぁ、はぁっ……。でも……力で俺に勝\nてると思ってんじゃねえぞ……？　ッ……ふぅっ……ふぅっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0103118" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「おらっ……！　おらっ、おらっ……！　アハハッ、どうだ？　堕ちた元正義\nの味方の胸……子供たちが熱く見守ってた女のパイズリは……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003401_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0103119" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「っ……はぁっ……たまんねえだろ？　マスク・ザ・レッドともあろうものが\n……今じゃこうして、男のチンポにご奉仕してる……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0103120" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「鍛えた胸で……オッパイでチンポをぐりぐり刺激してさ……。っはぁっ……\n谷間をカウパーまみれにしてるんだ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0103121" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「ほら、ヌチュ、ヌチュ、ニチャニチャってやらしー音たててさ……隊長のチ\nンポにまとわりつかせて……。っ……絡ませて……っ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0103122" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「力いっぱいぐにゅっぐにゅって……こんなん、もう教育番組じゃ流せないよ\nな……！　ニュースでも、朝の特番でもさ……アハハハッ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0103123" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「バトルスーツを汗やカウパーでねちょねちょにしながら……見ろよ、乳首ビ\nンビンにして大人のお遊戯だ……アッハ、最高で最低だよな……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0103124" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「……隊長……やっぱこんなんじゃ俺への仕置きになってねぇよ。硬くてデカ\nい肉棒ってやつで谷間ズられりゃ、そりゃ気持ちはいいぜ……？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003401_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0103125" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「でも、気持ち良くちゃ駄目だろう？　俺のデカパイを、胸マンコにしてヌル\nヌルに汚したぐらいじゃさあ……ビビらねえよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0103126" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「ほら、ほら、ほら……！　ちょっと胸をチンポの上でタプつかせてるだけで\n、悦んじゃってんじゃん。竿が震えてんぜ？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003401_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0103127" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「これじゃすぐにイッちまうよな……？　ほら。いいぜ、出せよ。出しまくっ\nて気持ちよくなれよ……。いっくらでもヤッてやるよ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0103128" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「一度や二度の射精で済ませなくてもいいんだぜ？　俺の胸も、スーツも、マ\nスクだってベタベタのドロドロ、くっさい液ぶちまけりゃあいい！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0103129" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「俺のパイズリに一方的に攻められまくって……、ふぅっ……！　情けなく出\nすとこ見せてくれよ？　そら、圧力がまだ足りないか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0103130" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「っクククッ……！　俺のオッパイは隊長の右手より強いぜ？　オナニーなん\nかより良くしてやる……！　っんっ……んっ、んんっ、んん……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0103131" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「んっ……ぁっ……ぉ……おっ……！　ハハ……！　チンポあっつくなってき\nてるぜ……？　っ、はぁっ、はぁ、はぁ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0103132" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「この、先っちょにあいてる穴からビュルビュル精液垂らすんだよなぁ？　楽\nしみだぜ……そーら！　出せっ、出せ、出せ出せっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0103133" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「イ……けよ！　正義の元ヒロインにチンポが立ち向かえるわけねぇだろっ…\n…！　このままなすすべもなくイッちまえっ……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003401_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0103134" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「オラッ！　おらっ、おらっ！　イけっ……イけイけイけっ！　ビュービュー\n出しまくれっ！　おらっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0103135" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「お？　イくのか？　出るのか？　出るんだな？　よぉっく狙えよぉ！？　俺\nが一番嫌がるところに出してみろっ……！　って、うぁっ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0103136" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「思ったより勢いがすげえっ……！　ま、マジかよっ！　隊長……てめえ、デ\nカいだけじゃなく量もすげえのかっ……！　見直したぜ」", "NORMAL" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003401_01_06" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0103137" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「でも……最初に言った通り、チンポはただのチンポなんだよ。俺に怪我させ\nることも、俺を屈服させることも不可能だ。わかるよな？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003401_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0103138" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「あは……ぴちゃっ……精液が口にちょこっと入ったくらいで泣くもんか。伊\n達に怪人とやりあってたわけじゃねえ……今だって用心棒だ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0103139" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「まだぶん殴られた方がキくんだよ。それがわかったら、すごすご店じまいし\nて自分の部屋に戻んな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0103140" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「堕落なんてしようがしまいが……俺は最強だ。俺は誰にも負けねえ。もちろ\nん、チンポなんかには当然な……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0103201" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「って……おい。んだこれ。まだ、勃起が続いてやがる……？　はァ？　あり\nえねえだろ……！　射精しおわったよな！？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003401_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0103202" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「あんだけ出しといて、俺の胸から抜く間もないまま抜かずの二発目ってか！\n？　あはっ……アハハハ！　いいね！　やってくれんじゃん！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0103203" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「リベンジマッチってか……？　ハハハ、だったらその喧嘩、買ってやるよ。\n俺はタフな男は好きだぜ？　諦めの悪いヤツもなぁ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0103204" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「おらっ！　……おらっ！　てめぇの先走りと精液でますますヌメりが増して\nんだろ？　いつまで勃起を維持できるか見ものだぜ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0103205" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「っふぅっ……ふぅ、ふぅ……！　ゼリーみてぇなブルブルの白濁液出された\n時は気持ち悪かったけどさ……潤滑油としては優秀だろ？　違うかぁ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0103206" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「くっさい汁でも、滑りがよくなりゃあ……摩擦による快感は爆増する……！\n　一瞬で暴発させてやるよ！　おらっ、おらイけっ、もう一度イけっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0103207" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「……ん……？　あはっ、何してやがる？　てめえでも腰振りたいってか？　\nカクカクヘコヘコ突き上げて反撃のつもりかよ……ってんんんっ！？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003401_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0103208" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「ん、だこれ……！？　んだコレぇ！？　おいっ……おっかしいだろっ！　て\nめえが腰を動かしただけで……っ、はぁっ！？　俺が感じてる！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0103209" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「なッ……なんだァ！？　チートでも使ってやがんのか！？　それとも……魔\n法のたぐいか！？　ひ、卑怯なことしてんじゃねえ！　っうあああっ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0103210" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「はぁ！？　何もしてねぇ！？　じゃあなんだ、単なるピストンで……俺のオ\nッパイガン突きしてブルンブルン揺らしまくって……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0103211" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「はぅっ！？　あっ！？　隊長のテクとザーメンだけで俺をイかせにかかって\nんのかよっ……あぅっ、ぁっ、し、信じらんねえっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0103212" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「おぁっ！？　アッ、ふっ……んあっ！？　はぁああっ！？　適格にチンポで\n乳首……狙ってズリやがるっ……こらっ……やめ、やめ、っろっ……！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0103213" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「俺が一方的に攻める勝負のはずだろっ……！？　え……？　勝負じゃない、\nお仕置き……？　っ、んぁああっ！　ざ、ざっけんな！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0103214" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「マンコにぶちこまれたわけでもねえのに、デカいだけのチンポ一本で、俺に\n下剋上するだァ！？　あっ……乳首と乳房だけでイかせるつもりなのかよっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0103215" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「誰がんな弱っちいメスに成り下がるかよ……！　俺は……俺は！　マスク・\nザ・レッドだぞ……！　あっ！？　あっぁっやめっ、やめっろっ！　あっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0103216" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「くっそ……！　負けねえっ、絶対に負けたくねえっ……！　こっちからもガ\nン攻めだ！　もう手加減なんてしねえ！　食らえっ……そりゃっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003401_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0103217" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「そりゃっ！　そりゃっ、そりゃっ……んんんああああああっ！？　何っ！？\n　なんだよ、この快感んんん……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0103218" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「ちくしょう、ちくしょうちくしょううう！　一度射精して敏感になったチン\nポくらい……俺が先にイかせてやるっ！　くそっ、くそっ、くそっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0103219" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「あああああああっ！　感じるっ！　感じる、感じる……！　や、やめろっ、\nやめろ、やめろぉおお……イくのはてめえだぁっ！　おらっおらぁっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0103220" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「イッけ……！　イけっ！　イけぇっ！　俺がイク前に……んんっ！　んあっ\n！　あああァッ！　あひっ！？　ああっ、あああああッ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},
		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "PLAYVOICE", "034_0103301" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「ん゛ぉっおおっ！？　んぉおおっ……ごぷっ……！　んっぐっんぶぅっ！？\n」", "NORMAL" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003401_01_09" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0103302" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「くっそッ……口に、口にザー汁ぶちこみやがってぇ……っ！　イ、イけとは\n言ったけどよぉっ……ってまだ出るのかっ……んぐっ、んんぶっ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0103303" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「ごぷ……！　ごほっ！　げほぉおっ……！　ああ、くせぇ、やっぱりくせぇ\n……隊長のザー汁臭すぎて……ああ……や、やっばい……っ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0103304" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「んぶっ……！　イクッ！　俺もイクっ、イグぅっ……！　んっおおおおっ、\nんぉおおおっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0103305" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「おぶっ……んっ、んんんっ……あああああっ……！　ううう……くそっ……\n。パ、パイズリなんかでイかされるなんて……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0103306" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「悔しすぎるぜ……。でも、隊長の力は認めざるを得ないようだからな……。\n力あるものには敬意を、だ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003401_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0103307" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「……今度はぜってー負けねえから。また、ガチのタイマン勝負してくれよな\n。やくそく……って、げほっ、げほっごほっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0103308" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「くっそ、喉に、口ん中に精液が絡みついてやがるっ……うう……！　コレ、\nもう飲んじまった方が良さそうだ……くそ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0103309" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「んくっ……。むぐ、んぐ、んん……ごきゅっ……！　ごくっ、ごくっ……ぷ\nぁあああ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0103310" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「確かに仕置き、完了したぜ。だけどよ、お、俺の心を折りてえんなら……ま\nだまだだ。必ず再戦を申し込んで来いよな……ッ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003401_01_07" ]},
