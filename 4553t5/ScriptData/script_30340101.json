		{"command":[ "PLAYVOICE", "034_0103401" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「んぐぅっ！？　んぶっ、おっおいっ！　バッ、バッカじゃねえのかっ……ん\nああああああっ！！」", "NORMAL" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003401_01_11" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0103402" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「だ、出せとは言ったが二度目でこの量かよっ……ううううっ！　あっ、頭に\nドピュドピュと……あああっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0103403" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「くっそっ……！　マスクの上からでもわかるくらい大量で……んっ、く、く\nせえ……！　あっ、ぅ……うううう……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0103404" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「どんっだけ出しやがる……！　隊長、お前とんでもねえヤツだな……おい…\n…ッ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0103405" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「っはぁっ……はぁ、はぁ……！　こんなん、洗っても絶対臭いとれねえぞ…\n…。それに……どういうこった……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0103406" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「この臭い、このえぐい量……。なんでか俺の中の女が疼きやがる……。まる\nで、命をかけたバトルの後みてえに……ムラムラがおさまらねえ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0103407" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「お、覚えてろよ……。俺に火ィつけたこと……。俺の胸で二回も射精しやが\nったこと……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003401_01_10" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0103408" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「っ……それにしてもマジでなんて臭いさせてんだよ……。兵器級だぜ、その\nチンポ……。大丈夫か？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0103409" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「って！　し、心配なんかしてねえからな！　俺は堕ちた。もう正義の味方で\nもなんでもねえ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0103410" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「つ、次こそ決着つけてやる。再戦まで、せいぜいチンポを研ぎ澄ましてろ！\n　いいなっ……！」", "NORMAL" ]},
