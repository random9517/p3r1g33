{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0138" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_016" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "そして、翌日からルナテミス、というかルルーナは……。", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「いいですか？　この活用を覚えないことには、古文を読みこなすこともでき\nませんからね。覚えるまで何度でも、みっちり練習しましょう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020113080001" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「ううう～……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113080001" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「……ルルーナさん、がんばりましょう。がんばって、休憩の前にこのページ\nだけ読んじゃいましょう？　ね？」」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010113080001" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「ううううううう～……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113080002" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "教育バトルに参加する教師たちに、しごかれる日々がルルーナを待っていた。\n教室では、明日楽や夜日楽……。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0149" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_016" ]},
		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「ですから、そこは昨日教えた公式を使うんです！　あの公式、ちゃんと覚え\nてますか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060113080001" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「え、えーと……えーと……えーと……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113080003" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「ああ～ん、ダメよぉ、もっと落ち着いて。ここの数字、見落としてるわよ～\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040113080001" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「う、う、ううううう～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113080004" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "寮に戻ってからは、エファとディアナにしごかれ、勉強は深夜にまで及んだ。\nそのせいで……。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「うふふふふふふ……ありおりはべり２Xの３乗……サインコサインいとあや\nし……ウフ、ウフフフ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113080005" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「ル、ルルーナさん……大丈夫……？　目の焦点が合ってないみたいだけど…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130113080001" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「しょうてん……？　わからにゃい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113080006" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「かわいそうに……ほら、こっちに来て。休み時間のうちに、少し眠っておく\nといいわ。膝枕してあげましょうか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130113080002" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「ひざ？　ひざまくら……おさきまっくら……なんにも、わからにゃい……あ\nひゃ、あひゃ、あひゃひゃひゃひゃひゃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113080007" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「ルルーナさん、しっかり！　ルルーナさぁん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130113080003" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ルルーナはだんだん追い込まれていった。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「さすがに、ちょっと無理があるんじゃねえかなぁ……」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "まあ、もともと勉強が大の苦手なアイツに、無理に勉強させようったって、限\n界があるんだよなあ……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0149" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_016" ]},
		{"command":[ "SETTEXT", "と思いつつ傍観していたら、案の定その「限界」がやってきた。ルルーナたち\nが「勉強」を始めて、３日目の夜……。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「ですから、そこの途中式をちゃんと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060113080002" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「う……う……う……うわああああああああああああーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113080008" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「ど、どうしたの！？　ルル様！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040113080002" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「もうだめ！　もう限界！　やってられないわ！　これ以上勉強なんかさせら\nれたら、頭が爆発四散してしまうわよぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113080009" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「ちょ、ちょっとぉ！　ルル様落ち着いて座ってぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040113080003" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「ルルーナ様、わかりました！　わかりましたから、少し落ち着きましょ！　\nあ、そうだわ。お茶でも飲んで――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060113080003" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「お茶なんかいらないわ！　私もう限界！　私は……私は……もうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113080010" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「こんなところにいられるかぁあああああああーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010113080001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「え！？　ルナ様どこへ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040113080004" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「私は脱出する！　まだ見ぬ未来へ向かってな！　さらばだーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010113080002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「あ！　ちょっと待ちなさいルナテミス様！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060113080004" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0000" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "……と、言うわけで俺をはじめグレート・ルナリアムの面々は、外に逃げ出し\nたルナテミスと深夜の追っかけっこを演じるハメになった。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "bg_0150" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ルナ様、待ってぇ～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010113080001" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「来るなー！　追ってくるなーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010113080003" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「ルナテミス様、止まってーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010113080001" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「ルナテミス！　落ち着いて！　冷静にお話しよっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010113080001" ]},
		{"command":[ "SETCHARA", "0", "char_00001205_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「数学できんが、なんで悪いとやーっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010113080004" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「どこの方言ですか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010113080001" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「追いかけろ、みんな！　早くルナテミス様を止めるんだよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113080001" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "やれやれ……だから無理があると思ったんだ。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
