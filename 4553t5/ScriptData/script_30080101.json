		{"command":[ "PLAYVOICE", "008_0103101" ]},
		{"command":[ "SETNAME", "ピースムーン ルナテミス配下.ver" ]},
		{"command":[ "SETTEXT", "「た、隊長……本当に、これはパワーアップのために……んっ……必要なこと\n、なのか……？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000801_01", "5", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0103102" ]},
		{"command":[ "SETNAME", "ピースムーン ルナテミス配下.ver" ]},
		{"command":[ "SETTEXT", "「いや、もちろん疑っているわけではないが……その、胸を……揉まれるとは\n思っていなくて……あっ、くっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0103103" ]},
		{"command":[ "SETNAME", "ピースムーン ルナテミス配下.ver" ]},
		{"command":[ "SETTEXT", "「は、はあ？　感じてなどいないっ……！　そんなこと、あるはずが……ない\n……ンンっ、だからって……そんなに強く揉んでいいわけでは……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0103104" ]},
		{"command":[ "SETNAME", "ピースムーン ルナテミス配下.ver" ]},
		{"command":[ "SETTEXT", "「もういいだろう……十分、揉んだから……パワーアップ……して……あっ、\nはっ……え？　違う……のか？　まだ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0103105" ]},
		{"command":[ "SETNAME", "ピースムーン ルナテミス配下.ver" ]},
		{"command":[ "SETTEXT", "「じゃあ、どうすればいい……というか、それならなんで胸を揉んでるんだ…\n…ちょ、ちょっと……待て……なぜズボンを脱ぐ……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0103106" ]},
		{"command":[ "SETNAME", "ピースムーン ルナテミス配下.ver" ]},
		{"command":[ "SETTEXT", "「ひぅっ！　な、なにをいきなり……む、胸で挟む？　隊長のち、ちんぽ……\nを……？　冗談ではなく、本気なのか……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000801_01_01" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0103107" ]},
		{"command":[ "SETNAME", "ピースムーン ルナテミス配下.ver" ]},
		{"command":[ "SETTEXT", "「これが必要だというなら……し、仕方ない、が……んっ、ンンっ……勝手に\n胸を、ちんぽに押しつけないでくれ……あ、あぁンっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0103108" ]},
		{"command":[ "SETNAME", "ピースムーン ルナテミス配下.ver" ]},
		{"command":[ "SETTEXT", "「くどいようだが……本当にこれでパワーアップできるんだろうな？　ウソだ\nったら、許さないからな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0103109" ]},
		{"command":[ "SETNAME", "ピースムーン ルナテミス配下.ver" ]},
		{"command":[ "SETTEXT", "「いや、うん……わかった……待ってくれ！　疑っているわけではない……お\n願いだから、隊長……続けてくれ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000801_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0103110" ]},
		{"command":[ "SETNAME", "ピースムーン ルナテミス配下.ver" ]},
		{"command":[ "SETTEXT", "「くっ、ふぅっ……擦れて、少し痛いから……ゆっくり、優しく頼む……んっ\n、ああっ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000801_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0103111" ]},
		{"command":[ "SETNAME", "ピースムーン ルナテミス配下.ver" ]},
		{"command":[ "SETTEXT", "「き、気持ちいい……？　こんな行為のどこが、いいのか……私には全然、理\n解できない……くぅっ……あぁっ、ンっあぁ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0103112" ]},
		{"command":[ "SETNAME", "ピースムーン ルナテミス配下.ver" ]},
		{"command":[ "SETTEXT", "「どう、と言われても……隊長に胸を揉まれながら、谷間にちんぽを擦りつけ\nられているだけで……恥ずかしい以外の感情は、ない……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0103113" ]},
		{"command":[ "SETNAME", "ピースムーン ルナテミス配下.ver" ]},
		{"command":[ "SETTEXT", "「本当だっ……ウソなどではない……どうして私が、こんな屈辱的な行為で…\n…感じるなど……はっ……ふっ、くぅっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0103114" ]},
		{"command":[ "SETNAME", "ピースムーン ルナテミス配下.ver" ]},
		{"command":[ "SETTEXT", "「こえ……んっ、あぁ……それは隊長が、胸を揉むから……べつに、胸でちん\nぽを……してるから……では、ない……あっ、くふぅっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0103115" ]},
		{"command":[ "SETNAME", "ピースムーン ルナテミス配下.ver" ]},
		{"command":[ "SETTEXT", "「ひうっ！　だ、だからっ……乳首を摘むなっ……そこは敏感だから……ひっ\n、あっ、あぁっ……胸、が変になるっ……うぅっ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000801_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0103116" ]},
		{"command":[ "SETNAME", "ピースムーン ルナテミス配下.ver" ]},
		{"command":[ "SETTEXT", "「だ、だめっ……ちょっと待って……くれ……はっはっ……そんな風に……ち\nんぽを、擦りつけるなっ……あぁっ、んっはぁぁっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0103117" ]},
		{"command":[ "SETNAME", "ピースムーン ルナテミス配下.ver" ]},
		{"command":[ "SETTEXT", "「乳首も勃ってるって……いちいち言わなくても、わかってる……あっ、やめ\nろっ……今、さわったら……くひっ、ひぃンっ！」　", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0103118" ]},
		{"command":[ "SETNAME", "ピースムーン ルナテミス配下.ver" ]},
		{"command":[ "SETTEXT", "「だ、だから……胸を弄りながら……ちんぽを擦りつけるなって……言って…\n…あぁ、胸が……熱ぃ……ヤケドしそう……だ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0103119" ]},
		{"command":[ "SETNAME", "ピースムーン ルナテミス配下.ver" ]},
		{"command":[ "SETTEXT", "「……なに？　正直になれ……？　正直もなにも……本当に私は、感じてなど\n……くひっ……んっ、あぁあっ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000801_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0103120" ]},
		{"command":[ "SETNAME", "ピースムーン ルナテミス配下.ver" ]},
		{"command":[ "SETTEXT", "「はぁ……はっ、ふぅ……息が荒いのは……だから、違うっ……く、ふぅっ…\n…ちょっと、なんか……ヌルヌルしてきた……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0103121" ]},
		{"command":[ "SETNAME", "ピースムーン ルナテミス配下.ver" ]},
		{"command":[ "SETTEXT", "「た、隊長が感じている証拠？　こ、これが本当に気持ちいい……のか……ん\nっ、ふぅ……だったら、このままで……いい……んんっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0103122" ]},
		{"command":[ "SETNAME", "ピースムーン ルナテミス配下.ver" ]},
		{"command":[ "SETTEXT", "「くっううっ……先っぽが膨らんで……きて……胸と擦れるっ、んんっ、あぁ\nっ……こ、こんな……硬いものを押しつけるなぁ……ああっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0103123" ]},
		{"command":[ "SETNAME", "ピースムーン ルナテミス配下.ver" ]},
		{"command":[ "SETTEXT", "「はっあぁっ、くっ、はっ……んっ……は、激しいっ……そんなに強く擦りつ\nけられたら……胸が、あ、熱い……ンンっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0103124" ]},
		{"command":[ "SETNAME", "ピースムーン ルナテミス配下.ver" ]},
		{"command":[ "SETTEXT", "「うぅ……すごく、変だ……隊長のちんぽが、胸の間から……出たり、入った\nりして……見てるだけで、変な気分になってくる……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0103125" ]},
		{"command":[ "SETNAME", "ピースムーン ルナテミス配下.ver" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……そ、それに……さっきからちんぽが、びくびくいってるが…\n…」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0103126" ]},
		{"command":[ "SETNAME", "ピースムーン ルナテミス配下.ver" ]},
		{"command":[ "SETTEXT", "「なに……もう出そう？　え、ちょっと待て……心の準備が……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0103127" ]},
		{"command":[ "SETNAME", "ピースムーン ルナテミス配下.ver" ]},
		{"command":[ "SETTEXT", "「あっ、や、やめ……はっ、くふっ……んんっ！　隊長、そんな胸を物のよう\nに……くっ、はぁっ……あっああっ……んっあぁぁあっ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0103128" ]},
		{"command":[ "SETNAME", "ピースムーン ルナテミス配下.ver" ]},
		{"command":[ "SETTEXT", "「ひっ、あぁぁぁぁっ！　や、やめっ……ひゃんんっ……はっ、あぁぁっ……\nくはぁぁっ、あぁあぁっ……ンっ、ふぅぅぅっ……」", "NORMAL" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000801_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0103129" ]},
		{"command":[ "SETNAME", "ピースムーン ルナテミス配下.ver" ]},
		{"command":[ "SETTEXT", "「ひゃっ……ま、まだ出てる……どうなってるんだ、隊長のちんぽは……ん、\nはぁぁ……こんなに出して……はっんんっ、あぁぁぁっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0103130" ]},
		{"command":[ "SETNAME", "ピースムーン ルナテミス配下.ver" ]},
		{"command":[ "SETTEXT", "「はっあぁ……はっ、ふぅ……なんだこの量は……胸がドロドロになってるじ\nゃないか……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000801_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0103131" ]},
		{"command":[ "SETNAME", "ピースムーン ルナテミス配下.ver" ]},
		{"command":[ "SETTEXT", "「それにすごい匂い……ク、クサいぞ……鼻がまがりそうだ……ふうっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0103132" ]},
		{"command":[ "SETNAME", "ピースムーン ルナテミス配下.ver" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……はっ、はぁぁぁ……精液……これが隊長の精液……白くて、\nねばっこくて……熱い、な……はっ……あぁ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0103133" ]},
		{"command":[ "SETNAME", "ピースムーン ルナテミス配下.ver" ]},
		{"command":[ "SETTEXT", "「え？　私の胸が気持ちよかったから……こんなに大量に出たというのか……\n？　そ、それは……まあ……よかった、が……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0103134" ]},
		{"command":[ "SETNAME", "ピースムーン ルナテミス配下.ver" ]},
		{"command":[ "SETTEXT", "「ちゃんと奉仕ができた証拠なのか……いや、喜べと言われても……困る……\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0103135" ]},
		{"command":[ "SETNAME", "ピースムーン ルナテミス配下.ver" ]},
		{"command":[ "SETTEXT", "「んっ、ふぅ……いいおっぱいだった？　な、なにを急に言い出すんだ……ま\nったく……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0103136" ]},
		{"command":[ "SETNAME", "ピースムーン ルナテミス配下.ver" ]},
		{"command":[ "SETTEXT", "「べつにこんなことを褒められても嬉しくないっ……ううっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0103137" ]},
		{"command":[ "SETNAME", "ピースムーン ルナテミス配下.ver" ]},
		{"command":[ "SETTEXT", "「それより本当にこれでパワーアップするんだろうな……？　ウソだったら、\n許さないからな！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000801_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0103138" ]},
		{"command":[ "SETNAME", "ピースムーン ルナテミス配下.ver" ]},
		{"command":[ "SETTEXT", "「う、うん……それならいい……これからも隊長の力が必要だ……奉仕が必要\nなら、もちろん相手をするから……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000801_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0103139" ]},
		{"command":[ "SETNAME", "ピースムーン ルナテミス配下.ver" ]},
		{"command":[ "SETTEXT", "「これからも付き合って欲しい……なあ、隊長……頼む……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0103140" ]},
		{"command":[ "SETNAME", "ピースムーン ルナテミス配下.ver" ]},
		{"command":[ "SETTEXT", "「い、いや私はべつに奉仕を気に入ったわけではないっ……本当だからな！　\nパワーアップのためだ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
