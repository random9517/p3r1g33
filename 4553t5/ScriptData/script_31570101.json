{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「失礼します～……ご主人様～、お呼び出し通り来ましたけど、何かご用です\nか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0103101" ]},
		{"command":[ "SETCHARA", "0", "char_00015701_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「え？　メンテナンス……じゃなくて、マッサージをしてほしい、ですか？　\nふふっ、それぐらいお安い御用ですよ♪」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00015701_01", "8", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_157_0103102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「お疲れな所はどこですか～♪　肩？　腰？　遠慮せずおっしゃってください\nね、どこでもほぐしちゃいますよ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0103103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「そういうのじゃない？　上じゃなくて下？　あー……なるほどなるほど、そ\nーゆーことですか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0103104" ]},
		{"command":[ "SETCHARA", "0", "char_00015701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ビンビンに発情しきっちゃって……にゃふふ、ほんと、どーしようもないご主\n人様ですねぇ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0103105" ]},
		{"command":[ "SETCHARA", "0", "char_00015701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「――いえ、もちろんいいですよ、お任せくださいな。上だろうが下だろうが\n、た～っぷり気持ちよくして差し上げます♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0103106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「え？　折角ならおっぱいで挟んでほしい？　もう……リクエストが多いご主\n人様なんですから……では、失礼しま～す♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0103107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んっ……思ったよりも大きいですね……んっ……どうですか、私のおっぱい\nは。人間とはまた違った感触でしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0103108" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00015701_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「想像以上に柔らかくて驚いた？　……にゃふふ、最新とは言い難いですが、\n結構いいパーツを使ってる自慢のボディですからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0103109" ]},
		{"command":[ "SETIMAGE", "0", "still_00015701_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ほら、心ゆくまで堪能してください……んんっ……私の身体は、ご主人様専\n用です……なんちゃって♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0103110" ]},
		{"command":[ "SETIMAGE", "0", "still_00015701_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んふ……根元を抑えて、搾りあげるように、っと……んっ、んふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0103111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んっ……こうして改めて間近で見ると、結構グロテスクですよね～人間の生\n殖器、おちんちんって。こんなに膨張して痛みはないものなんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「――いえ、知識としてはインプットされています。ただやっぱり、実際にご\n奉仕するとなると勝手が違うと言いますか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んっ……でも、心配はいらないみたいですね……んっ、んぁ……おちんちん\nのさきっぽ、こんなにヒクヒクさせて……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んふっ……んっ……にゃふふ、おっぱいの間でピクンと跳ねるのが、なんだ\nか可愛く思えてきました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0103115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「それにこう、目の前で左右に揺れられると……にゃふふ、なんだかじゃれつ\nきたくなっちゃうなって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「え？　顔で、頬っぺたで擦ってほしい、ですか……？　にゃふふ、私のご主\n人様はほんとーにわがままなんですから♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0103117" ]},
		{"command":[ "SETIMAGE", "0", "still_00015701_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んっ、んふっ……ほーら、これがお望みなんですよね？　すりすり、すりす\nり……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0103118" ]},
		{"command":[ "SETIMAGE", "0", "still_00015701_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「知っていますよ、このぷっくり膨らんでる所が気持ちいいんですよね……ん\nふっ、んんっ……すりすり、すりすり……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「腰が引けてますよーご主人様♪　ほらほら、逃がしませんよ、ご主人様のだ\nーい好きなおっぱいでぎゅ～って♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0103120" ]},
		{"command":[ "SETIMAGE", "0", "still_00015701_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んふっ、んんっ……ガマン汁もたくさん出てきましたね……んっ……これを\nおっぱい全体に広がるように塗りたくって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0103121" ]},
		{"command":[ "SETIMAGE", "0", "still_00015701_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んんっ、んふっ、あっ……もう少し、大きく動いて……んんっ、んふっ、ん\nっ……全部包み込むように、ゆっくり……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ほら、いやらしい音、聞こえてますか？　んんっ……私のおっぱい、ご主人\n様のガマン汁で大変なことになっちゃってますよ？　気持ち良いですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0103123" ]},
		{"command":[ "SETIMAGE", "0", "still_00015701_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「――にゃふふ♪　素直なご主人様も悪くないですねー♪　お顔もすっかり蕩\nけちゃってますよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0103124" ]},
		{"command":[ "SETIMAGE", "0", "still_00015701_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「分かってます、止めたりなんてしないですよ。こうやって……おっぱいを両\n手で挟んで……んんっ……思いっきり擦って……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ゆっくりシコシコ……はやーくシコシコ……ほーら、扱き上げるだけじゃあ\nりませんよ、根元から押さえて、左右にいっぱい揺すって……んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「またほっぺでもすりすりしてあげちゃいます♪　ご主人様の弱い所は学習済\nみですよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「すりすり、すりすり……にゃふふ、こうしてると、私の顔もご主人様のガマ\nン汁でべとべとになっちゃいますね……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んふっ、んんっ……すりすり、すりすり……んんっ……ご主人様の匂い……\nなんだかちょっと、頭がぼーっとする、かも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んんっ……！　おちんちんが胸の中でビクンッて……もしかして、もうイキ\nそうなんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0103130" ]},
		{"command":[ "SETIMAGE", "0", "still_00015701_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふふ、いいですよ、もっともっと激しくしてあげますから、このまま出\nしちゃってくださいな♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「おっぱい弾ませて、さきっぽの入り口をほっぺですりすりぃ～♪　すりすり\nぃ～♪　敏感な括れの部分もしっかり擦ってあげちゃいます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0103132" ]},
		{"command":[ "SETIMAGE", "0", "still_00015701_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「知ってますよ、人間の男性はこーゆーのが好きなんですよね？　いち、に、\nいち、に……にゃふふ、好きなタイミングで射精していいですからね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「いち、に、いち、に……気持ちよくなってくださいご主人様♪　おちんちん\nビクンビクンって跳ねさせて、精液いっぱい出してください！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ひゃっ……！　す、すごい、こんなに勢いよく噴き出して……んっ……これ\nが人間の射精、ですか……間近で見ると中々の迫力ですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0103135" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00015701_01_04" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「どうですか？　私のマッサージお気に召していただけました？　……にゃふ\nふ♪　それはよかった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0103136" ]},
		{"command":[ "SETIMAGE", "0", "still_00015701_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ですが……これ、一回じゃまだまだ足りないですよね？　これだけ精液吐き\n出したのに、おちんちん固いままですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0103137" ]},
		{"command":[ "SETIMAGE", "0", "still_00015701_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「知ってます、出したばかりのおちんちんは敏感になってるんですよね。こう\nやって……んんっ……おっぱいで締め付けてあげれば……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0103138" ]},
		{"command":[ "SETIMAGE", "0", "still_00015701_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「にゃは♪　おちんちんがビクンビクンって、かわいい♪　腰もこんなに浮か\nしちゃって、ほんと、どーしよーもないご主人様なんですから♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「言ったでしょう、心ゆくまで堪能してくださいって。このままご奉仕、続け\nちゃいますね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んんっ、んふっ……さっきの精液がおっぱいの間に絡まって……ぐちゅぐち\nゅ、ぐちゅぐちゅって、とってもエッチな音……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0103201" ]},
		{"command":[ "SETIMAGE", "0", "still_00015701_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「え？　またほっぺでも擦ってほしい？　ご主人様ってば、私のぷにぷにのほ\nっぺ、そんなに気に入っちゃいました？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0103202" ]},
		{"command":[ "SETIMAGE", "0", "still_00015701_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「――にゃふふ、そんなにまっすぐ見つめて頷かれるとこっちが照れちゃいま\nす。ほーら、ご主人様の大好きなほっぺたですよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0103203" ]},
		{"command":[ "SETIMAGE", "0", "still_00015701_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「赤く膨らんだ先端を、すりすり……すりすり……膨らんだここ……括れの部\n分が弱点なのはインプット済みです♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0103204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「すりすり、すりすり……んんっ……いいですねぇそのお顔♪　もっと蕩けさ\nせてもいいんですよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0103205" ]},
		{"command":[ "SETIMAGE", "0", "still_00015701_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んっ……それにしても……すんすん……やっぱりこれ、ご主人様の匂い……\nすんすん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「私、機械のはずなのに……全身のパーツが熱くなって、あるはずのない鼓動\nが高鳴る気さえしちゃいます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んんっ、んふっ、んぁ……すりすり、すりすり……んんんぅ、んんっ……ん\nあ、んふっ……ご主人様のおちんちん……んっ……好き……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0103208" ]},
		{"command":[ "SETIMAGE", "0", "still_00015701_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「――んにゃん！？　ご、ご主人様？　どうしました突然頭を撫でたりなんか\nして……いえ、確かになでなでされるのは好きですけど……ふあぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0103209" ]},
		{"command":[ "SETIMAGE", "0", "still_00015701_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「な、なんですかその顔！　聴いたこともないえっちな声が出てる？　し、仕\n方ないじゃないですか、ご主人様の手、気持ちいいんですもん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0103210" ]},
		{"command":[ "SETIMAGE", "0", "still_00015701_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「乳首も勃ってきたって……だ、だから、わざわざ言わなくてもいいんですよ\nそんなこと！　ご主人様！　そーゆーところですよ、そーゆーところ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「そっちがその気なら、私だって……んんっ、んふっ……もっと激しくマッサ\nージしちゃいますからね……おっぱい、ぎゅーって……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふふ、ご主人様だって私の事いえませんね♪　おっぱいタプタプって動\nかすたび、かわいい声が漏れちゃってますよ♪　んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「またこんな、おちんちんピクピクって跳ね回っちゃって……んんっ、すりす\nり、すりすり……んふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0103214" ]},
		{"command":[ "SETIMAGE", "0", "still_00015701_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んにゃん……なでなで、もっと……んんっ……ご主人様の手、優しくて、あ\nったかくて……あっ、んあぁんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0103215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「私も負けませんよ……根元から押さえて、先端まで搾り上げるように……ん\nんっ、んふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0103216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「すりすり、すりすり～♪　にゃふふ、おちんちんがまたドクドクって脈打ち\n始めました。そろそろイッちゃいそうなんですよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「――はい、分かってます。このまま最後まで、ですね。我慢なんて必要あり\nません、好きなだけ射精しちゃってください！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0103218" ]},
		{"command":[ "SETIMAGE", "0", "still_00015701_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んんっ、んふっ、んくっ……！　おっぱいでおちんちん、ぐちゅぐちゅ、ぐ\nちゅぐちゅって……いち、に、いち、に♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ほらほら、いっぱい出すんですよ♪　私のおっぱいマッサージで、た～っぷ\nり気持ちよくなっちゃってください♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んにゃんんっ！　せ、精液が顔に……んんっ！　……にゃふふ、知ってます\nよ、これが所謂ぶっかけ、というやつですね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0103301" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00015701_01_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「二回目でもこんなに出るものなんですね……すごい……全然止まりそうにな\nいや……んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んっ……顔にかかると、また匂いが……すんすん……んにゃん……やっぱり\nご主人様の匂い……んんっ……変な気持ちになっちゃいます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0103303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「え？　顔を汚してごめん、ですか？　……にゃふふ、何を謝る必要があるん\nですか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0103304" ]},
		{"command":[ "SETIMAGE", "0", "still_00015701_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「言ったでしょう『私の身体はご主人様専用です』って♪　好きなだけ汚して\n、無茶苦茶にしてくれていいんです♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0103305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「とはい、私はご存知の通り機械の身体。ご主人様の出した精液を飲んだりし\nて差し上げられないことが、少し残念ですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0103306" ]},
		{"command":[ "SETIMAGE", "0", "still_00015701_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んにゃん♪　なんですか、また頭を撫でて……え？　その気持ちだけで充分\n嬉しい、ですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0103307" ]},
		{"command":[ "SETIMAGE", "0", "still_00015701_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ご主人様ってば相変わらずお上手ですねー♪　……たまには私の方から甘え\nたくなっちゃうかも」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0103308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「さて、えっちなマッサージはこれでお終いです。どうします？　身体の方も\nしっかりほぐしておきましょうか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふふ、お任せください♪　私の全てはご主人様のモノ、しっかりご奉仕\nさせて頂きます♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んんんんっ！　二回目なのに、すごい勢い……熱い精液が、乳首にまでかか\nって……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0103401" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00015701_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ビクビクって必死に射精するおちんちん、やっぱりかわいい……私のおっぱ\nい、そんなに気持ちよかったですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「天にも昇る気持ちだった？　……もう、ご主人様ってば大袈裟なんですから\n♪　でも、私の身体、堪能していただいたようでなによりです♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0103403" ]},
		{"command":[ "SETIMAGE", "0", "still_00015701_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふふ、精液ですっかりマーキングされちゃいました。これで名実共に、\n私はご主人様のモノです……なんちゃって♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0103404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「それにしても……ほんとにいっぱい出しましたね。谷間のここ、ご主人様の\n精液が溜まっちゃってますよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0103405" ]},
		{"command":[ "SETIMAGE", "0", "still_00015701_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「こうしておっぱいを持ち上げると……んんっ、んっ……聞こえますか？　ぐ\nちゅぐちゅって、えっちな音ですねぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0103406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「恥ずかしいからやめろ？　にゃふふ、何を今更、ほらほら、目を逸らさない\nでくださいよご主人様♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0103407" ]},
		{"command":[ "SETIMAGE", "0", "still_00015701_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「それで、どうですか？　二回しましたけど、もう満足ですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0103408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「――それは、もちろん♪　ご主人様が足りないと言うなら、心ゆくまでご奉\n仕させて頂きますよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0103409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「言ったでしょう？　『私の身体はご主人様専用です』って♪　またムラムラ\n来たときは……遠慮なくお申し付けくださいね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0103410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}