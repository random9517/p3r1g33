{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「なあ、仲間から聞いたんだが、てめーは『パワーアップする』とか言ってほ\nかの連中とスケベなことしてるらしいな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0104101" ]},
		{"command":[ "SETCHARA", "0", "char_00022901_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「例えば？　ほら、アレだよ。その……セックス……とか？　この間してやっ\nたことも、その一環なんだろ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「で、どうなんだよ。オレとはしねぇのか？　日頃あんなにスケベなことして\nくるくせに、セックスはできねぇってか？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00022901_01", "2", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_229_0104103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「どうなんだよ？　んんぅ？　聞こえねぇなぁ。ほれほれ、こっちはとっくに\n準備して……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0104104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「……んひぃっ！？　お、おいおい、いきなり乱暴だなっ。ンッ、なんか尻に\n……ち、チンコかこれ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0104105" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022901_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「いや、胸で挟んだことはあるけど、尻でチンコを感じるのははじめてってか\n……んぅ、めちゃくちゃ熱い……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0104106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「こ、こんなのが本当にオレの中に入るのかよ……。んっ、てか、いつまでチ\nンコを尻に擦りつけてるんだ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0104107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「は、ハメる場所がわかんねーか？　オレがリードしてやらないと……って、\nそんなわけねぇか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0104108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「じゃあ、どうして……って、どこに入れて欲しいのか言ってみろだって！？\n　て、てめー調子にのんな……んぐっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0104109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「そ、そっちじゃねえ！　チンコ、んっ、そっちは尻……尻の方だからっ！　\nてめー、わざとやってるだろ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022901_02_02" ]},
		{"command":[ "PLAYVOICE", "v2_229_0104110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「わ、わかったよ、ちくしょう。だ、だから……前の……お、オマンコに……\nチンコ入れろって、ことだよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0104111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「てめーのチンコ、オレのマンコに入れて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0104112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「……んぁああぁっ！？　い、一気にチンコ、んくっ、入ってきた……ぁ……\nっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022901_02_04" ]},
		{"command":[ "PLAYVOICE", "v2_229_0104113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「大丈夫かって？　てめー、いきなりチンコぶち込んでからオレの心配してん\nじゃねーよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0104114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「そ、それに、大丈夫に、決まってるだろうが？　このオレを誰だと思って…\n…んぁあっ、ちょっ、動くのかっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0104115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「んはぁっ、んぁっ、んっ、んくっ！　て、てめっ、動くなら動くって……ん\nぁあっ、ああっ、んはっ、ああっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022901_02_03" ]},
		{"command":[ "PLAYVOICE", "v2_229_0104116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「そ、そんなに、腰……んっ、ああっ！　チンコ、んくぅっ、中で擦れる……\nんんっ、んっ、んふぅううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0104117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「んはぁっ、ああっ、んっ、んんっ！　んぁあっ、激しすぎだっ、んっ、少し\n加減……んぁっ、ああぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0104118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「んひっ、い、いや、別に平気だしっ！　んっ、てめーのチンコなんか、全然\n……んくぅっ、はっ、はっ、んはぁっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022901_02_02" ]},
		{"command":[ "PLAYVOICE", "v2_229_0104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「こ、このスケバンサンダーさまが、んぁっ、この程度で、ヒィヒィ言うと思\nったら、ンッ、お、大間違い……んひぃいっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0104120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「で、デカいチンコがっ、んぁっ、ああっ、マンコの奥に……んぐぅっ、さ、\n刺さる……っ、んっ、ひぃいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0104121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「おおっ、おおっ、奥……ッ！　んはぁっ、はぁっ、これっ、どこまで、チン\nコ届いて……んぁっ、ああっ、んふぅううっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022901_02_04" ]},
		{"command":[ "PLAYVOICE", "v2_229_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「んひっ、はぁっ、身体がっ、んぐううっ！　チンコに貫かれてっ、んぐっ、\n揺さぶられて……んはぁっ、ああっ、んっぐぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0104123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「そ、それにしてもどんだけ硬く……んっ、それに、こんなに太いのかよ、て\nめーのチンコ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0104124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「オレのマンコの中、いっぱいにして……んぅ、動かれると、中身がもってか\nれそうなんだが……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022901_02_03" ]},
		{"command":[ "PLAYVOICE", "v2_229_0104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「それはオレのマンコのせい！？　キツキツで処女みたいだって！？　しょ、\nしょしょ、処女じゃねーし！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「だから、てめーのチンコくらいどうってこと……んぃっ、み、見栄なんか張\nってねぇからっ、んっ、はぁんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0104127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「だったら遠慮なく中出ししていいなって、どうしてそうなんだよ！　てかっ\n、中出しはだめだっ、絶対にぃっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022901_02_02" ]},
		{"command":[ "PLAYVOICE", "v2_229_0104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「だ、だって中出ししたら……あ、赤ちゃん、出来ちまうだろうが……んひぃ\nっ！　て、てめー、オレの話聞いてたかっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「んぁっ、ああっ、中でチンコがっ、んふっ、膨らんで……んぁっ、はぁっ、\nはぁあ……っ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022901_02_03" ]},
		{"command":[ "PLAYVOICE", "v2_229_0104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「てめっ、本当にこのまま中出しする気だなっ、んっ、ああっ、それはっ、あ\nあっ、んっくぅっ、んふぅうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「だ、だめだって、言ってる……んはぁっ、ああっ、だめなのにっ、腰がっ、\nオレの腰も、止まらない……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「チンコにっ、んなっ、中ッ、ぐちゃぐちゃにされて……んぐっ、ああっ、な\nんか……く、クる……んっ、んぐぅ……っ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022901_02_04" ]},
		{"command":[ "PLAYVOICE", "v2_229_0104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「だ、出されるっ、中出しされるっ、んぁっ、ああっ、マンコにっ、精液が…\n…注がれっ、はぁっ、ああっ、ああ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「くはぁあああぁぁぁああぁぁ～～～～っ！！」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022901_02_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0104135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「んぁっ、ああっ、マジか……中出し……てめー、やりやがったなぁ……んっ\n、んふぅ……はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0104136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「精液……お、オレの……マンコに……ンッ、めちゃくちゃ、はいって……ん\nふぅ……はぁ……溢れそうなくらいにぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0104137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「イクほど気持ちよかったかって……な、なに言ってんだよ……てめーのチン\nコなんかで、イかされるわけねーし？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022901_02_05" ]},
		{"command":[ "PLAYVOICE", "v2_229_0104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「た、ただ、ちょっとビクビクっと全身が……って、それがイクってことだっ\nて！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0104139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「う、うるさいっ！　とにかく、イッてない！　俺はまだ、てめーにイかされ\nてなんか……ッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「んひぃいいいぃぃっ！　あ、あれで終わりじゃないのかっ、また腰が動いて\nっ、んはぁっ、ああっ、待てって……っ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022901_02_07" ]},
		{"command":[ "PLAYVOICE", "v2_229_0104201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「くぅっ、チンコがまだ、こんなにガチガチで……さっき射精したから、萎え\nると思ったのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「んぁっ、待てっ、待てって、本当にっ！　んっ、んくっ、今動かれると、マ\nジで……んはぁっ、ああぁっ、んぐぅうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「イッたあとだから余計に感じるだろうって、んぁっ、だから、イッてなんか\n……んぁっ、ああっ、感じても……んふぅうっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022901_02_06" ]},
		{"command":[ "PLAYVOICE", "v2_229_0104204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「はっ、激しいっ、激しいって！　んぁっ、ああっ、オレが認めるまで責めま\nくるって！？　んひっ、しょ、正気かよぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0104205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁっ、チンコがっ、んぁあっ！　ズボズボってマンコを、むぐっ\n、めちゃくちゃにぃ……んはぁっ、かき回して……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0104206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「こ、こんなにされたらっ、んはぁっ、ああっ、頭がっ、んぐぅっ、真っ白に\n……んはぁっ、はぁっ、ああ……わ、わかったからっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022901_02_07" ]},
		{"command":[ "PLAYVOICE", "v2_229_0104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「み、認めるっ、認めるからっ！　てめーのチンコで感じて、イッたの、認め\nるから……んぁっ、だから、少し加減を……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「んぉおっ！　おおっ、待てって、ますます激しくするなっ、んぁっ、バカぁ\nっ！　んぐっ、んっ、あっ、ああ……っ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022901_02_06" ]},
		{"command":[ "PLAYVOICE", "v2_229_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「そんなにっ、んっ、マンコめちゃくちゃにっ、んはぁっ、チンコでかき回さ\nれたらっ、また、キちまう……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0104210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「頭がっ、真っ白になって、全身が、はじけ飛ぶみたいなのが……んぁっ、そ\nう、イキそうにっ、イクッ、イクから……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0104211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「ならイかせてやるって！？　んぁっ、ああっ、イかされるっ！　てめーにま\nたっ、い、イかされる……っ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022901_02_07" ]},
		{"command":[ "PLAYVOICE", "v2_229_0104212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「マンコぐちゃぐちゃに、んぁっ、突かれまくってイクッ、また、イク……ッ\n！　ああっ、ああっ、ああ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0104213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「てめーも、また射精するのかよ。んっ、ああっ、オレに、精液……んっ、は\nぁ、はぁ……っ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022901_02_05" ]},
		{"command":[ "PLAYVOICE", "v2_229_0104214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「ああ、もう中だろうが外だろうが関係ねぇって！　んはっ、てめーの好きな\nトコに、射精して、いいから……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0104215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「ああっ、だからこのまま、オレのこと、またてめーのチンコでイかせて……\nんっ、んぁっ、ああっ、んくぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0104216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「そうやって、んぁっ、ああっ、チンコがますます膨らんでっ、マンコの奥っ\n、奥を……んぐっ、突いてっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0104217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁっ、チンコ気持ちいいっ！　んぐっ、初めてなのにっ、んぁっ\n、ああっ、めちゃくちゃ……感じる……っ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022901_02_06" ]},
		{"command":[ "PLAYVOICE", "v2_229_0104218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「腰動くっ、んぁっ、マンコでチンコしごくぅっ！　んぁっ、ああっ、気持ち\nいいっ、これ、んはぁっ、ハマっちまう……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0104219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「んぁっ、ああっ、もう限界っ、イクッ、イク、イク、イクイク……ッ！　ん\nぁっ、ああっ、ああ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0104220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「んぁあっ、ああっ、ああっ、んっぐぅうううぅぅぅ～～～っ！！」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022901_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0104301" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「ま、また……んぁっ、ああ……中に、中に精液……んぐぅ……注がれて、る\n……んぁっ、はぁ……はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「ああ……イッた……イかされたぁ……。てめーのチンコに……んふぅ……マ\nンコ……イかされちまった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0104303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「んふぅ……はぁ……ふぅ……。マンコがジンジンして……腰も……ガクガク\nだ……ちくしょう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0104304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「初めてなのに無理させすぎたかだぁ！？　て、てめーっ、そう思ったなら最\n初から加減しろっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022901_02_08" ]},
		{"command":[ "PLAYVOICE", "v2_229_0104305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「くっ。てめーの言う通り、オレは経験豊富なフリして処女だったわけだが…\n…って、最初から気づいてた！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0104306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「い、いつからだよ。俺にパイズリさせたときからか！？　それとももっと前\n！？　てめー、オレのことずっと泳がせてたんだなぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0104307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「くそっ、結局てめーの手のひらの上だったてのかよ。なーんか気に入らねえ\n、気に入らねえなあ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0104308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「せっかく気持ちよくイッたあとだってのに、イライラしてきたっていうか、\nああっ、むしゃくしゃする！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「あぁ？　それならもう一発イッてスッキリするかって？　いい加減にしろっ\n！　……だが、てめーとはまた、セックスしたいかもな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「んんっ、あっ、まっ、チンコ抜け……んぁっ、ああぁぁ～～っ！」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022901_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0104401" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「い、いきなり抜いてっ、オレの尻にぶっかけて……んはぁ……はぁ……んっ\n、くぅう……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0104402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「ドロドロした精液が、尻に……んっ、いっぱい、かかって……っ！　んぁっ\n、イクッ、ぶっかけられて……またっ、んぃっ、くぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0104403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁ……っ！　んんぅっ！？　ま、またオレの尻に、チンコ押し付\nけて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0104404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「押し付けてるのはオレの方だって？　そ、それは仕方ないだろうが！　てめ\nーがめちゃくちゃにマンコを突いてイかせるから！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022901_02_10" ]},
		{"command":[ "PLAYVOICE", "v2_229_0104405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「おかげで腰が抜けて、た、立ってられなくなっちまったじゃねぇかよ……ん\nぅ……気持ちよすぎて、膝も震えてやがるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0104406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「うぅ……。にしても凄い臭いだ……。てめーのオトコ臭い精液の臭い……染\nみついちまうじゃねぇか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0104407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「ほかの男の臭いを上書きしてやるって？　バカ、こんなことされたのはてめ\nーが初めてだっつーの！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0104408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「……はっ！　あっ、その……いや、初めてってのは……ああもう、そういう\n意味だ！　てめーがオレの初めての相手ってこったよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0104409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「だ、だから……その……。責任取れよ。てめーはこのスケバンサンダーをヒ\nィヒィ言わせた初めての男なんだからな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0104410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
