{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001102_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「にいさまとこんな風に手を繋ぐの、初めてかもしれませんね。なんだか落ち\n着きます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0204101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「あの……にいさま、こんな時に言うのもおかしいかなって思うんですけど、\nわたし、ひめさま……アナザールナテミスさまには感謝してるんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0204102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「あの、穏やかだけど滅びを待つだけの世界から、わたしを連れ出したのはひ\nめさまで、そのことを恨んだこともありました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0204103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「でも、あの世界から出たからこそ、わたしは今のわたしになれました。大切\nなお友だちや、大好きな人にも出逢うことが出来ました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0204104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「にいさま……わたしに『なりたい自分になっても良いんだ』って言ってくれ\nて、ありがとうございます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0204105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「ん……ちゅ、ふぁ……んっ、ちゅぅ……ぷぁっ、んっ、ふぅん……。言いた\nいこと、まだあるのに……キスで黙らせるのずるいです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0204106" ]},
		{"command":[ "SETIMAGE", "0", "still_00001102_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「にいさま、こういうの正面から言われるの、照れ臭いからって苦手ですもん\nね？　ふふっ、でも……そういうところも大好きですよ、にいさま」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0204107" ]},
		{"command":[ "SETIMAGE", "0", "still_00001102_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「ふぅ……んっ、ちゅ……んふ……っ、ちゅ……れろ……くふっ、んっ、はぁ\n……もっと……キスしてください……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0204108" ]},
		{"command":[ "SETIMAGE", "0", "still_00001102_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「ひゃっ、んっ、もう……、天邪鬼です、にいさま。おっぱいにキスしてほし\nいなんて、言ってません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0204109" ]},
		{"command":[ "SETIMAGE", "0", "still_00001102_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「でもっ、にいさまがキスしてくれるなら、どこでも嬉しいです。ん……っ、\nふふっ、今度はおでこですか？　くすぐったい……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0204110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「んっ、ふぅ……っ、ちゅ……っ、おなかににいさまのが当たってます……。\n熱くて、すっごく固いのが、わたしの中に入りたいって言ってます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0204111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「わたしの全部、にいさまにあげたいんです。だから、わたしの中に入れてし\nまっていいんですよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0204112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「んっ、きゃふ……さきっぽ、かきわけてっ、入って……きっ、たぁ……！わ\nたしの中、にいさまでいっぱいになってるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0204113" ]},
		{"command":[ "SETIMAGE", "0", "still_00001102_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「にいさまの、どくんどくんって、脈打ってるの分かります……っ　ぁは……\nっ、にいさまのおっきすぎて、おなかふくらんじゃってます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0204114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「はい、好きに動いてください……　にいさまのおっきいので、わたしのな\nか、めちゃくちゃにしてくださぁい……っ　」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0204115" ]},
		{"command":[ "SETIMAGE", "0", "still_00001102_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「奥ぅっ　子宮の入り口っ、にいさまのがコツンコツン叩いてますっ　ふぁ\nんっ、んぷっ……ちゅっ、れろ……ちゅうぅ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0204116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「はぁっ、キスしながらされるの好きぃ……　ああっ、もっとっ、もっとに\nいさまを感じていたいです……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0204117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「きゃふっ、んんっ　にいさまのっ、わたしの中、削ってます　えっちなお\nつゆっ、あふれてじゅぷじゅぷ音立ててますぅ……っ　」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0204118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「もっとぎゅって手を握って下さい……っ、気持ち良すぎてっ、飛んでいっち\nゃいそうだからあ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0204119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「ひあぁんっ　にいさまっ、激しっ、ぶつかった音が部屋中に響いてっ、ひ\nゅごひっ、わたしの壊れちゃっ　ひぃあっ　」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0204120" ]},
		{"command":[ "SETIMAGE", "0", "still_00001102_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「んふっ、おっぱいの先っぽっ、噛んじゃダメでひゅ……っ　腰が跳ねちゃっ\n、ひきゅっ　にいさまのっ、深くきちゃうっ　」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0204121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「ふぁんっ、おっぱいのさきっぽ……噛んで引っ張っちゃ……っ　ひぅっ、ひ\nぁっ　気持ち良すぎてっ、おかひくなりゅっ　」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0204122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「おなかの奥っ、ぐりぐりしながら突いちゃっ、きゃふっ、ふぁんっ　めのま\nえっ、ちかちかすりゅっ、へんでひゅ……っ　」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0204123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「背中ぞくぞくってしてっ、声っ、出ちゃいます……っ！こんな声ぇっ、聞か\nれるの恥ずかしいのにっ、とまらにゃい……っ　」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0204124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「恥ずかしいのに、気持ち良くてえっ、ひぁんっ、きゃふっ、ふあぁっ、あん\nっ、ふぁぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0204125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「入り口から奥まで、にいさまので全部えぐられてるのにっ、じゅぷじゅぷよ\nだれ垂らして喜んじゃってます……っ　」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0204126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「わたひっ、こんなえっちにゃこじゃないひのにぃっ　にいさまがっ、こんな\n風にしちゃってりゅ……っ　」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0204127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「ひっきゅぅ……っ！？　そんにゃっ、叩きつけりゅみたいにしちゃっ、頭の\nおきゅっ、しびれてぇ……っ　」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0204128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「おっぱい吸いながらぁっ、そんなに速く動かすのらめえっ　ふきゅっ、ひぁ\nっ、くぅんっ、あああ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0204129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「にぃさまぁっ、にいさまぁ……っ！　わらひっ、もっ、だめでひゅっ　もう\nイッひゃいまひゅ……っ　イカせてくらひゃい……っ　」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0204130" ]},
		{"command":[ "SETIMAGE", "0", "still_00001102_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「やだあっ、ガマンなんてむりでひゅ……っ　さっきからぁっ　ちょっとず\nつイッてるのにっ　これ以上なんてむりぃっ　」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0204131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「ふぁあっ！？　奥に、ぐりぐりって押しつけてっ、子宮、こじ開けるみたい\nにしてりゅ……っ　あかちゃんっ、作るつもりのっ　」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0204132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「ぜったいにっ、あかちゃん作ってやるって動きぃっ　にいさまっ、わたしを\nお母さんにするつもりなんだぁっ　」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0204133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「んぁっ、あっ、あっ！　くるっ、きちゃうっ、ふぁっ、ひぁあっ、ぁああっ\n、あぁぁぁぁぁぁっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0204134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「にいさまのあちゅいの、子宮に入ってきてるの分かりゅう……　わたしの子\n宮、ごくごくって飲んでりゅ……　」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0204135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001102_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「んきゅっ、奥にぎゅうって押しつけてぐりゅぐりゅするのらめぇ……っ　に\nいさまのびくびくして、まだびちゃびちゃ出てりゅ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0204136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「んっ、ちゅ……んふ……ちゅっ……れろ……ぷぁ、キス、もっとぉ、ちゅっ\n、れろ……っ、ちゅぅっ、ぷはぁっ、んふ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0204137" ]},
		{"command":[ "SETIMAGE", "0", "still_00001102_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「にいさま、まだ出てます……　気持ち良かったんですか？良かったあ……\n　」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0204138" ]},
		{"command":[ "SETIMAGE", "0", "still_00001102_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「んっ、引き抜かれる時ぃっ、中をぞりぞりってされてっ、背中がぞくぞくし\nちゃいます……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0204139" ]},
		{"command":[ "SETIMAGE", "0", "still_00001102_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「ぁ……にいさまの、あふれてきちゃう……。どろどろであったかいの……ご\nぽごぽって音して流れ出てる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0204140" ]},
		{"command":[ "SETIMAGE", "0", "still_00001102_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「……ぇ、あれ……？　全然小さくなってない……？あんなに出したのに……\n？　え？　ええ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0204201" ]},
		{"command":[ "SETIMAGE", "0", "still_00001102_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「あの、にいさま？　どうしてまだ手を繋いだままなんです……か？まさか、\n休憩無しで……とかは、ないです……よね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0204202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「そ、そんな顔でお願いされたら、ダメって言えるわけないです……。じゃあ\n……いいです……よ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0204203" ]},
		{"command":[ "SETIMAGE", "0", "still_00001102_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「んくっ、にいさまのが、入り口に当たってる……熱くて、どくどくして、ま\nたわたしの中、めっちゃくちゃにしちゃうんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0204204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「あっ、入ってる……さっき出したのちゅるちゅる掻き出しながら入ってっ、\nんっ、ふぅ……っ、あっ、あぁああああ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0204205" ]},
		{"command":[ "SETIMAGE", "0", "still_00001102_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「ぁは……にいさまのが、また子宮の入り口にキスしてます……。さっき出し\nたのが、押し出されてあふれちゃってます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0204206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「にいさま……手を……離さないでくださいね。こうしていると……身体だけ\nじゃなくて、心も繋がってるみたいなんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0204207" ]},
		{"command":[ "SETIMAGE", "0", "still_00001102_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「ふふっ、なんですか、にいさま？　笑わないでくださいよう……。いいじゃ\nないですか、こんな時くらい、思いっきり甘えても」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0204208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「なにかお願いがあるか……ですか？ええと……じゃあ……一番奥まで、来て\nください。そして、キスして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0204209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「んぅっ、ちゅっ、はぁ……んっ、一緒になってる……。呼吸も、鼓動も、体\n温も……１つになれたような……ふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0204210" ]},
		{"command":[ "SETIMAGE", "0", "still_00001102_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「……動いてください、にいさま。このままだと……えっと、生殺しになっち\nゃいますよね？　今度は、にいさまのしたいように……ね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0204211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「んきゅっ、あぁっ、こんなゆっくり……入り口から奥までっ、動いてっ、に\nいさま……にいさまあ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0204212" ]},
		{"command":[ "SETIMAGE", "0", "still_00001102_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「あはっ、なんだか今度はにいさまが甘えちゃってますね。おっぱい……あん\nまり大きくなくてごめんなさい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0204213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「小さくてもいいんですか？　よかった、ひめさまとか、おっきい人がたくさ\nんいるから……ちょっとだけ、不安だったんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0204214" ]},
		{"command":[ "SETIMAGE", "0", "still_00001102_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「ふふっ、一生懸命おっぱい吸って……赤ちゃんみたいです。んっ、きゃふ…\n…っ、もうっ、やっぱり違いますね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0204215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「赤ちゃんは、こんなえっちにおっぱい吸わないし、おちんちん動かしたりも\nぉっ、しないです……っ、んあっ、ふぁああ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0204216" ]},
		{"command":[ "SETIMAGE", "0", "still_00001102_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「にいさまぁっ、深いところっ、ぐりぐりってするのっ、気持ちいいですっ！\nんきゅっ、きゃぅ……っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0204217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「ふぁっ、ぁああっ、にいさまぁっ、中でこすれてっ、きゃふっ、ひぁんっ！\nちゅっ、じゅるるっ、あっ、おちんちん、膨らんできてえ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0204218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「ひぅんっ、あっ、んきゅっ、わたしっ、もっ、またぁっ、またイッちゃいま\nすぅ……っ！　にいさまぁっ、にいさまあっ！　ふぁぁああ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0204219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「にいさまの熱いのっ、下さい……っ！　わたしににいさまの気持ち、全部ぶ\nつけてっ、にいさまのものにしてえ……っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0204220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「ふぁああああ……っ！！　出てっ、にいひゃまのっ、せーしぃっ、一番奥で\n出てりゅう……っ！！　ふぁっ、ああああ……っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0204301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001102_02_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「子宮に、びちゃびちゃびゅーびゅーってあたってます……っ。ふぁあっ、ん\nふっ、すごいです……まだこんなに出てる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0204302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「ちゅ……っ、ぁふっ、キスしながら、奥に押しつけてる……まだ子宮に注ぎ\n込みたいんですか……？　んっ、ぁはっ、入ってきます……　」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0204303" ]},
		{"command":[ "SETIMAGE", "0", "still_00001102_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「おなかのなか、にいさまのでいっぱいです……　あ、あふれちゃってる……\nもったいないです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0204304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「ふふっ、枕にするには、おっぱい小さいですけど……幾らでも甘えていいで\nすからね……？　にいさま、だぁいすきですよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0204305" ]},
		{"command":[ "SETIMAGE", "0", "still_00001102_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「あ……、やっと終わりみたいです……。とくんとくんってしてるの、すごく\n愛おしいから、名残惜しいですけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0204306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「え、いつでもしてあげるから、名残惜しむ必要ない、ですか？もうっ、そん\nなこと言って、にいさまは忙しいんですから、無理ですよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0204307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「ふぁっ、んっ、抜いてく時、熱が逃げてくみたいで寂しいです……。あ、わ\nわっ、精液こんなにあふれてっ、し、シーツが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0204308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「ああー……ちょっとびっくりしちゃう量があふれちゃってますね……。え、\nこれ、本当にわたしの中に入ってたんですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0204309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「おなかの中、ちょっと寂しい感じがします……って、ならもう一回とか、も\nう今日はダメです！　また、今度なら……いいですよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0204310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「あっ、にいさまの抜けて……っ！？　……くぅんっ、んふぁ……っ！中でこ\nすれてっ、もうっ、んきゅっ、ふあああぁぁぁ……っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0204401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001102_02_17" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「ああ……っ、にいさまの……すごい、わたしの全身にかかって……っ、こん\nなところまで飛んできちゃってます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0204402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「くぅん……っ、ぁはっ、にいさまので染められてくみたいです……。こんな\nにたくさん中に出してたら、おなかぽこってしちゃってました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0204403" ]},
		{"command":[ "SETIMAGE", "0", "still_00001102_02_16" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「ま、まだ出てます……すごい……。しゃ、シャワーみたいですね……？あと\nで本当のシャワー浴びないと大変なことになっちゃいそうですけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0204404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「ふぁっ、んっ、おなかにこすりつけると、まだ出ますね……。これが全部赤\nちゃんのもとなんですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0204405" ]},
		{"command":[ "SETIMAGE", "0", "still_00001102_02_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「こんなに出されても、子供は１人だけしか産まれてこないんですよね？なん\nだか、ちょっと勿体ないです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0204406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「……だからこれが有効活用って、絶対違うと思います。にいさま、わたしが\nこういうこと余り知らないからって、もう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0204407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「ぁっ、だ、ダメです、精液をおっぱいに塗りつけないでください……。ぬち\nゃぬちゃ音がして、すごくえっちですよう、これ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0204408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「にいさまの匂いでむせかえるみたいです……。まるでお風呂みたい……って\n、お風呂入らなきゃですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0204409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「一緒に入りたい、ですか？　んんー……へんなこと、しませんか？ふふっ、\nそんなに悲しい顔しないでください。ちょっとだけなら……ね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0204410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}