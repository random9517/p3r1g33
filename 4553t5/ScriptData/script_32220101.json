		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「アタシに……んっ、じゅるるっ！　また、オマエの、子種……んっ、たっく\nさん……出して……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「んむぅううっ！　んっ、んくぅっ！　んっ、んふぅううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_0103301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022201_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「またぁ……また、お前の子種ぇ……んっ、んくぅ……たっくさん……んじゅ\nるっ、じゅるるるぅ……じゅっぷぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「んぁあ……すっごい……。鼻が痺れるような……オスの臭い……んくっ、た\nまらない……んちゅぅ、ちゅばっ、ちゅるるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_0103303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「ああ……んぅ……。これが、人間の子種ぇ……。やはり……実際に、行為に\n及ぶ方が……学びが、多い、ナ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_0103304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「ア……アア……。不思議な、感覚、ダ……。交尾をした、わけでもない、の\nに……。んふぅ……この、満足感……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_0103305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「オマエから……子種を、搾ったことに対して……この感情……んぅ……ウレ\nシイ……のか？　アタシ、は……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_0103306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「とにかく、アア、学習した甲斐は、あった、ナ。オマエがこんなにも子種を\n出した。つまり、気持ちよかった。そう、ダロ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_0103307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「だから、ウレシイ。アタシは、オマエがたっくさん子種を出してくれて、ウ\nレシイんだ、と、思う」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_0103308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「んふっ、もっと、もっと、オマエが悦ぶような、コト、してやりたい気分に\nなった、ゾ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_0103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「オマエの反応……とても、学びが多いから、ナ。ククッ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「んぁっ、ああっ、チンポ……暴れて……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_0103401" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「んんっ、んっくぅううっ！　あっ、ああっ、肌に……ドロドロ……熱い、子\n種がぁ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_0103402" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022201_01_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「んん……アア……すごい、ナ……。んふぅ……こんなに二度目の射精でも、\nこんなにたくさん出せるのか、オマエ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_0103403" ]},
		{"command":[ "SETIMAGE", "0", "still_00022201_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「アア……この感じ……んふぅ……アタシ……感じてる、ナ……。オマエの子\n種、肌に、浴びて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_0103404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「ネバネバした、子種に……ベトベトに、され、テ……。あ、アア……アタシ\nもどうやら、イッた、みたい、ダ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_0103405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「知ってる、ゾ。この、頭がふわっとする、感じ……。人間は、イク、と、言\nう。ビーチでエサが、よく言っていた……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_0103406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「アタシは、サメなのに……。そうカ……子種を浴びると、メスは『イク』の\nだな……んふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_0103407" ]},
		{"command":[ "SETIMAGE", "0", "still_00022201_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「なあ、オマエ。アタシ、この感覚をもっと、味わいたくなって、キタ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_0103408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「それにはオマエの子種と、チンポが必要、ダ。なあ、もっとアタシに、イロ\nイロ教えてくれないか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_0103409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「アア、アタシはもっと、かシコいサメになる、ゾ」", "NORMAL" ]},
