{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「隊長さん、時間を取ってもらってありがとうございます。その……お願いが\n、ありまして」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0103101" ]},
		{"command":[ "SETCHARA", "0", "char_00020501_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「わ……わ……私に、エッチな特訓をしてもらえないでしょうか！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0103102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「あの、私、その、知識はあるんですけど、経験は全くなくて……隊長さんな\nら、経験豊富だって皆が……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0103103" ]},
		{"command":[ "SETCHARA", "0", "char_00020501_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「え、自分で良ければ喜んで？　あ、ありがとうございます！！　さすがは隊\n長さんです！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0103104" ]},
		{"command":[ "SETCHARA", "0", "char_00020501_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「まずは自分の武器を知ることだ、ですか？　えっと、私の武器と言われても\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0103105" ]},
		{"command":[ "SETCHARA", "0", "char_00020501_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「真面目さ？　眼鏡とエロさのギャップ……？　それが、私の武器ですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0103106" ]},
		{"command":[ "SETCHARA", "0", "char_00020501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「百聞は一見にしかず、まずは隊長さんに奉仕してみせろ、と」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0103107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「分かりました。他ならぬ隊長さんの言うことです、頼母木マミ、誠心誠意務\nめてみせます！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0103108" ]},
		{"command":[ "SETCHARA", "0", "char_00020501_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「そんな固くならなくてもいい？　そうですね、リラックスリラックス……ふ\nふ、特訓でリラックスって、変な感じです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0103109" ]},
		{"command":[ "SETCHARA", "0", "char_00020501_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「まずはどうすれば……おっぱいを見せろ？　はい、分かりました。これでい\nいですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0103110" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00020501_01_02" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「大きいですか？　自分ではなんとも……たまに男の人の視線を感じることは\nありますけれど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0103111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「それで……あっ、これが隊長さんのおちんちん……ふあっ、すごい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0103112" ]},
		{"command":[ "SETIMAGE", "0", "still_00020501_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「手でしごくんですか？　はい……あっ、熱い……それに、なんか、触ってる\nと変な気分に……んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0103113" ]},
		{"command":[ "SETIMAGE", "0", "still_00020501_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、あっ、なんだか硬くなってきてます。これが勃起なんですね…\n…隊長さんのおちんちんが勃起してます……ふああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0103114" ]},
		{"command":[ "SETIMAGE", "0", "still_00020501_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「んっ……なんだか、しごいていると変な気分に……あっ、んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0103115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「どうしているか言うのもエロい、ですか？　えっと、隊長さんのおちんちん\nが硬くなって、上を向いて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「あんっ、しごくたびに震えて、このカリ首とか、すごくエラが張ってて……\n竿も太くて……んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「ビキビキって脈を打ってて……熱くて、匂いも……不思議だけど、なんだか\n好きな匂い……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「私の手とおっぱいでそうなってるんですか？　えへへ、だったら嬉しいな…\n…やんっ、またおちんちんがビクってなりましたよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0103119" ]},
		{"command":[ "SETIMAGE", "0", "still_00020501_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「あんっ、あっ、おっぱいを揺らしながらしごく……こうですか？　わっ、こ\nれだけでまた硬くなってる……んうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0103120" ]},
		{"command":[ "SETIMAGE", "0", "still_00020501_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「隊長さんのおちんちん、先端がぱくぱく開いて……どろっとしたものが出て\nきたのが眼鏡越しに分かります……凄い……んうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「ねとねとして……手袋越しに手に染みてきてます……んんっ、隊長さん、気\n持ちいいんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「なんだか、私も変な気分に……隊長さんの視線がおっぱいに来てるって思う\nと……んんっ、あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「手のひらも熱くなってきて、なんだか……んんっ、隊長さん、これ、舐めて\nみても……いいですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「んんっ、れろっ……れるっ……不思議な味……でも、嫌いじゃないです。隊\n長さんの、だからかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0103125" ]},
		{"command":[ "SETIMAGE", "0", "still_00020501_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「んむっ、私の唾液と隊長さんのお汁……ガマン汁っていうんですか？　はい\n、ガマン汁でおちんちんがべとべとです。れるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「ちゅっ、むっ、んんっ……凄い、キスしただけでビクって。ちょっと、可愛\nいかも……ふふっ、んむっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「あ、ここがいいんですね。このカリ首の裏側……この筋……れるっ、んっ、\nちゅっ、ふふ、隊長さんの顔、気持ちよさそう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「舐めるたびにとろとろ、どろどろお汁が先端から出てきて……んっ、ちゅっ\n、れるっ、んむっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「隊長さん、気持ちいいですか？　私のおちんちんペロペロ、気持ちいいです\nか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「フェラチオ、そう言えばいいんですね。私のフェラチオ……ふふ、気持ちい\nいの、答えなくても分かります。れるっ、ちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「キスしながらしごいて……なんだかだんだん分かってきました。隊長さんが\n気持ちいいやりかた……んっ、れろっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「あっ、おちんちんが震えてきてます。隊長さん、イくんですか？　知識だけ\nはあるから知ってるんです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「男の人、気持ちいいと精液が出るんですよね、いいですよ。私の手と口で、\nいっぱい出してください……ちゅっ、んむっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「んっ、あっ、凄い、びくびくって、大きく震えて、隊長さんの顔も……あっ\n、ひゃっ！？　ふああああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0103135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00020501_01_04" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「んんっ、んっ、ふあっ、あっ、これが、男の人の射精……すごい勢いで……\n眼鏡も顔もべたべたで……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0103136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「どろっとしてて……んっ、熱い……隊長さん、気持ちよかったですか……？\n　えへへ。なら嬉しいです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0103137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「匂いも凄い……なんだか、嗅いでるだけで身体が熱くなってきます……んう\nっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「隊長さん、特訓はどうでしたか？　及第点、ですか。やっぱり最初から上手\nくやるのは難しいですね……あん、眼鏡から精液が……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0103139" ]},
		{"command":[ "SETIMAGE", "0", "still_00020501_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「だからこそ訓練は何回もやる必要がある？　そうですね、さすがは隊長さん\n、これからもよろしくおねがいしますね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「へ……？　さっそく二回目の特訓？　え、でも男の人って一度出したらもう\n……わ、わ……隊長さんのおちんちん、もう硬くなってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0103201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「私のおっぱいと、さっきの気持ちよさでまた大きくなったんですか？　えへ\nへ、それなら嬉しいかも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「そ、それじゃあもう一回特訓をお願いします……んっ、今度はもうちょっと\n強く？　分かりました、こうですか？　あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0103203" ]},
		{"command":[ "SETIMAGE", "0", "still_00020501_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「ああ……隊長さんの精液と私の唾液でベトベトになって……ぬらぬら光って\n……んっ、ちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0103204" ]},
		{"command":[ "SETIMAGE", "0", "still_00020501_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「匂いも、味も凄い……私の手の中でどんどん硬く熱くなって……これが男の\n人の興奮なんですね。んうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「れるっ、じゅるっ、ちゅっ、んっ、出したばかりなのに、カリ首のエラも張\nって、竿も太くて硬くて……素敵……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「経験がないのに、隊長さんのおちんちんが素敵だって分かる……私も女だっ\nたってことなんですね……んうっ、ちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「胸を見れば分かる、ですか？　ふふ、あんまり意識したことはありませんで\nしたけど、隊長さんが言うなら嬉しいです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「それじゃあほら、眼鏡から落ちた精液が胸にかかってますよ……あはっ、こ\nういうの、好きなんですね隊長」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「おちんちんがまた硬くなって、隊長さんの視線も痛いぐらいおっぱいに注が\nれてるの、分かります」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0103210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「ふふっ、だんだん分かってきましたよ。隊長の特訓のおかげで、こうして胸\nを揺らしながらしごいてあげれば……んっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「そうしておちんちんにキスして……ちゅっ、むっ、んんっ、ふふ、またガマ\nン汁が出てきましたね。唇がべとべとです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「んっ、んっ、あっ……二回目はもっと強く？　こうですね、ふふっ、隊長さ\nんのおちんちん、すごく気持ちよさそうになってます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「匂いも、形も、味も……なんだか、すごくドキドキします。それに、隊長さ\nんの顔も見ているとお腹がじんじんしてきて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0103214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「え、私が可愛いから？　えへへ、そんなことあんまり言われたことないです\n。ふふ、でも隊長さんから言われるとなんだか嬉しい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0103215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「眼鏡もよく似合ってるって……んっ、誉め過ぎです……んんっ、ちゅっ、れ\nるっ、ちゅぱっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0103216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「あんまり褒めるから、なんだかおちんちんが愛おしくなってきました……隊\n長さん、好き……んっ、むっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「あっ、またおちんちんの先端が大きくなって、膨らんで……隊長さんの顔も\n切なくなってきて……ここから強く早くしごけば……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0103218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「んっ、ちゅっ、んんっ、隊長さん、出すんですね。またいっぱい精液、私に\n出すんですね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「私でいっぱいいっぱい気持ちよくなってくれたしるし、思いっきり出してく\nださい……んむっ、れるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "外して射精","LABEL1","そのまま射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「ふあっ、あああああっ、んんんんんっ！！　顔に……隊長さんのが……あう\nうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0103301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00020501_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「凄い……メガネのレンズが全部精液で塞がれて……匂いも……んんっ、はあ\nっ、顔が全部、隊長さんで塗りつぶされています」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「ふふ、なんだか私、隊長さんのものだってマーキングされてるみたい。嬉し\nいです……んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0103303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「ひゃあっ！！　今の言葉でまた興奮したんですか？　先端からまた精液が…\n…んっ、そんな腰を押し付けなくても、眼鏡にかけたいんでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0103304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「ん……あっ……ふふっ、追加の精液も受け止めましたよ。だんだん分かって\nきました、隊長さんが好きなこと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0103305" ]},
		{"command":[ "SETIMAGE", "0", "still_00020501_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「顔中ベットリで……今、私は隊長さんのモノになってるって感じがします…\n…ふふ、隊長さん、好き……好き……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0103306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「特訓してくれて、ありがとうございます。おかげで、素敵な体験ができまし\nた……隊長さんのおちんちんも見られたし。ちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0103307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「男の人は何度でも出せるっていうのも知れましたし……ふふっ、知識で知っ\nていたはずなのに、知らなかったことがいっぱいでした」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0103308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「隊長さん……また私に特訓をしてくれますか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「あはは、ありがとうございます。それじゃあまた、いっぱいっぱい、エッチ\nな特訓、してくださいね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「んあっ、あっ、どうしたんですか？　え、舌を出せって……はい、分かりま\nした。これでいいですか？　あー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0103401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00020501_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「んんっ、んぶっ、んっ……凄い……舌の上に熱い塊が……んうっ、味も……\nこれが隊長さんの精液の味……んんっ、くっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「はっ、あっ……喉に絡みついて……んぐっ、でも、おいし……んっ、舌に張\nり付いてるのも……んくっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0103403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「あ……あ……またおちんちんから精液が……ふあっ、んっ、ねばねばして、\n熱くて……それにどろっとした感触が舌に広がってます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0103404" ]},
		{"command":[ "SETIMAGE", "0", "still_00020501_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「えっ、今の顔がとってもエッチって……そうなんですか？　隊長さんもこう\nいう顔、好きですか？　ふふ、なら嬉しい……んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0103405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「顔も舌もベトベトで、なんだか私を隊長さんに塗りつぶされてる感じです。\n嫌じゃなくてむしろなんだか、お腹の奥まで熱くなって……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0103406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「匂いも凄くて……ふふっ、この後会う人には、私が隊長さんのものだってば\nれちゃうかもしれませんね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0103407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「エッチな特訓、最初は不安でしたけど、これなら何回やってもいいかなって\n……あんっ、隊長さん、おちんちん動かしちゃダメです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0103408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「やんっ、あっ、また残りの精液が……どれだけ貯めてたんですか……私がエ\nッチだから？　それは隊長さんの特訓のせいですよ、もう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0103409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「うふふ、でもそう言ってくれるなら、またいつでも特訓してくださいね。ま\nた、隊長さんの精液、一杯飲みたいから……ふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0103410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}