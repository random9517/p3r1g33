{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「今日はまた……突然の呼び出しだな。それで、どうしたんだ？　……んん？\n　クリスマスの思い出を１つ聞いてみたい？　私にか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0503101" ]},
		{"command":[ "SETCHARA", "0", "char_00001605_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「私にはそんなに、人に語れるような素晴らしい思い出は……。……と、そ、\nそうだな。１つくらいなら……ある。だが、他の誰にも言うなよ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0503102" ]},
		{"command":[ "SETCHARA", "0", "char_00001605_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「約束するなら教えてやろう。……あれは、とても寒いクリスマスの日だった\n。外にいたら凍えてしまうと言われて、ラブホテルに行ったことがある」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0503103" ]},
		{"command":[ "SETCHARA", "0", "char_00001605_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「そして……。あ、ああ、そうだ。聖夜に男と女が、密室ですることなんて１\nつだからな。私は胸をさらけ出し……熱いチンポを谷間に挟み込んでいた」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0503104" ]},
		{"command":[ "SETIMAGE", "0", "still_00001605_01_01" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「っくぅうっ……。こ、こんな……ムードもへったくれもないパイズリを、私\nに要求するなんて……。い、いや、確かに……先程キスくらいはしたが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0503105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「だからって、ホテルに入るなり……胸で奉仕しろなどと……！　あ……。も\nちろん、嫌では……ない。すまない。照れて暴言を吐いた……。うう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0503106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「そ、の……。クリスマスにラブホテルに来て、こういうことができると思っ\nていなかったから……嬉しくて空回りしてしまったというか……。んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0503107" ]},
		{"command":[ "SETIMAGE", "0", "still_00001605_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「だ、だが貴様だって、こういう展開を想像していたはずだ。そうだろう？　\n外で、二人で歩いている時からずっと……私の胸を意識していたな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0503108" ]},
		{"command":[ "SETIMAGE", "0", "still_00001605_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「この、鍛え抜いた乳房でチンポを思いっきりシゴかれたらどうなるのか……\n。寒さでかじかむ股間を、あたたかな胸のぬくもりで包みこまれたい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0503109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「そう考えていたから、こんなに今、硬く太くしている。違うか？　当然私も\n……んんっ、緊張しているが……とても興奮している……。んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0503110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「……と、前置きはもう、いいか……。今から私が、貴様のこの、たぎるチン\nポをしゃぶりつくし、シゴいていくから好きなだけ感じてくれ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0503111" ]},
		{"command":[ "SETIMAGE", "0", "still_00001605_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「れろっ……ん、ぅ……♪　ぴちゃっ……くちゅっ、ちゅぷ……♪　んはぁっ\n、はぁっ……！　も、もう先走りの汁が滲み出しているぞ……？　っちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0503112" ]},
		{"command":[ "SETIMAGE", "0", "still_00001605_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「んれろっ……。亀頭が期待して、ピクピク震えている……。んんっ、ほぉら\n……。濡れた舌の感触ばかり追いかけていると……。それっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0503113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「今度はチンポを根元から、私の胸がシゴきあげていくぞ……？　耐えられる\nか？　んッ……んっ、んっ……。貴様の感じるところなど知り尽くしている」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0503114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「それに……、ぴちゃっ。どこをどうすれば最速で射精してしまうかも、この\n身体で直接覚えた……。れろっ。つまり、もう逃がさないということだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0503115" ]},
		{"command":[ "SETIMAGE", "0", "still_00001605_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「貴様のチンポは、私が出せと命じた瞬間に射精してしまう……♪　んっ、さ\nあ、どうやってそれをギリギリまで引き延ばして快感を煽っていくか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0503116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「ん、くちゅっ、ちゅ、ちゅぅっ、チュッ、ちゅっ……むちゅっ♪　ちゅっ…\n…♪　んむ……、胸は強めにチンポを圧迫して……刺激するっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0503117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「フフ……。どんどんチンポの先端から、肉汁が溢れてくる……。どうした？\n　今日が聖夜だからと浮かれているのか？　あまり油断していると……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0503118" ]},
		{"command":[ "SETIMAGE", "0", "still_00001605_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「こうだぞ。……ぢゅるっ！　れろれろれろっ、じゅるるるっ！　じゅっ、じ\nゅるるるっ！　んぷ……っ。先走りごと亀頭を吸いたてて……ぢゅるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0503119" ]},
		{"command":[ "SETIMAGE", "0", "still_00001605_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「おっと？　腰がひけているぞ……。貴様が逃げたぶん、こちらは更に追撃す\nる……。んむっ♪　くちゅ♪　ちゅぷ、ぷちゅ、ちゅぷ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0503120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「ん、は……♪　気付いたか。尿道口に舌先をねじこんで、クチュクチュと動\nかしながら胸を上下させている……。股間にビリビリくるだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0503121" ]},
		{"command":[ "SETIMAGE", "0", "still_00001605_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「ん～～～……♪　肉厚な唇で、貴様の汁のついたチンポをはさんだり、口づ\nけをしたり……。むちゅっ♪　ちゅ、ちゅ、吸ったりぃ……ちゅぅうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0503122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「ぴちゃっ……じゅるっ！　じゅるっ、じゅる……？　なんだ？　さっきは腰\nをひいていたのに、今度は細かく揺らして……チンポを口に押しこんでくる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0503123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「んっ♪　んっ♪　がっつかなくともしっかり絞りとってやるから安心しろ…\n…。っくちゅっ、れろぉ……ぴちゃっ、にゅぷっ、ぷっちゅっ、ちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0503124" ]},
		{"command":[ "SETIMAGE", "0", "still_00001605_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「竿を締めつけて、絞る乳房の威力はどうだ……？　んぅっ♪　言葉で聞くま\nでもないか……♪　その表情、チンポの痙攣……そうか、そんなにいいか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0503125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「こちらも尽くしがいがあるというものだ……。はぁっ♪　んちゅっ♪　れる\nっ、れろ……くちゅっ♪　ちゅぷ、ぷちゅっ、ちゅぷ……ねろねろねろっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0503126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「はぁっ、チンポに集中していると……顔が熱くなってくる……っ。はぁ、は\nぁ、胸も……摩擦で少しずつ気持ち良くなってきて……んん、まずいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0503127" ]},
		{"command":[ "SETIMAGE", "0", "still_00001605_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「貴様を射精させるためのパイズリフェラだというのにっ……んぅっ、くちゅ\nっ……。か、感じてしまう……。っぁっ♪　ぴちゃっ……ちゅぷ、くちゅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0503128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「あ……あまり私の顔は見るな……っ。んっ……。そ、そうだ。私が感じる以\n上に……貴様に快楽を与えてしまえば、恥ずかしいこともなくなるはず」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0503129" ]},
		{"command":[ "SETIMAGE", "0", "still_00001605_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「全力で抜かせてもらうぞ……！　ンッ……ふんっ、隙間なくみっちり乳房で\nチンポを押し潰して……こすりあげながらっ……れろっ、くちゅくちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0503130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「亀頭を中心にぃ……っ。ぺろっ、チンポを舐め回し、派手な水音をたてなが\nらねぶり倒す……！　ぴちゃっ、ちゅるっ、じゅるっ、ぢゅるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0503131" ]},
		{"command":[ "SETIMAGE", "0", "still_00001605_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「ふ、む……っ♪　乳房でチンポを持ち上げて……じゅるっ♪　あ、ぁ♪　先\n走りの汁が胸の方にまで垂れて……舐め取らないと。……じゅるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0503132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「……んっ？　チンポの存在感が増してくる……。ぐっちゅっ！　肉竿が硬く\n太く……んむっ！？　舐めづらいくらいに膨張して……。んっぅっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0503133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「射精……したいのか？　精液が上がってきているようだな……。わかった、\nそれなら私が今、楽にしてやる……。そのまま身を委ねていろ……。れろっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0503134" ]},
		{"command":[ "SETIMAGE", "0", "still_00001605_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「じゅるっ、ぴちゃっ！　ぐちゅっ、ぐっちゅっぐちゅっ！　そらっ……出し\nてひまえっ♪　受け止める準備はできてる……出せぇっ♪　ぢゅるるるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0503135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「ふぐぅううっ♪　んむぐっ……！？　んッ……んぅっ……！　んんんんんん\nッ……！　ひゅ、ひゅごい勢いだ……。飲み干すぞ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0503136" ]},
		{"command":[ "SETIMAGE", "0", "still_00001605_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「ごきゅっ……ごきゅっ、ごくっ……！　ごくんっ……！　ああああ、飲んで\nいる間にもどんどん溢れてくる……！　ぢゅるっ、じゅるるるっ、ぢゅるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0503137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「ごく……！　ごく、ごくっ……！　今日の精液は……、んぁっ。特別生臭く\nて濃い……気がするぅ……♪　口の中にまだこびりついたままだぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0503138" ]},
		{"command":[ "SETIMAGE", "0", "still_00001605_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「んっ、ンッ、んんっ……！　口の中で転がしてぇ……私の唾と混ぜて、飲み\n下すぅう……！　……ッごきゅっ。ごっくっ、ごく……ごくんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0503139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「ん！　喉奥から鼻に突き抜けていくこの青臭い、イカの臭いぃい……。それ\nにこの、歯でも噛みきれないような粘り気、そしてこの苦さぁああ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0503140" ]},
		{"command":[ "SETIMAGE", "0", "still_00001605_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「ん、ぷぅ……。一回分の射精で、腹がパンパンになるほどの満足感があるぞ\n……？　どれだけ溜まっていたんだ。絞り出したのは私だが……んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0503201" ]},
		{"command":[ "SETIMAGE", "0", "still_00001605_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「……はぁ、はぁ、はぁ……ふぁああああ……♪　息まで精液に染められてし\nまった。まったく同じ臭いがする……。……だが、その……だな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0503202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「今日は特別な日だ。そして、ここでは……。ラブホテルでは、欲望を互いに\n隠している方がおかしいだろう？　だから……私も我慢しないことにした」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0503203" ]},
		{"command":[ "SETIMAGE", "0", "still_00001605_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「……ああ。このままチンポを離さずに……んっ、まだ尿道に残っている分の\n精液を、潤滑油にして……抜かずの二回目だ。まさか一度で終わるなんて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0503204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「そんなことは言わないだろう？　それに……ん、チンポは賛成してくれてい\nる。まったく短くならないし、長くて硬くて太いままだからな……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0503205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「まずは精液と私の唾を……ンン、谷間とチンポにたっぷり絡みつかせて……\n。グニグニと乳房で広げながら性感マッサージしていく……。ん、んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0503206" ]},
		{"command":[ "SETIMAGE", "0", "still_00001605_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「思った以上にぬめりがすごいな……。あっ♪　それにチンポの力強さも、予\n想以上だ……。この回復力、素直に感心してしまう……。ん、ぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0503207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「ぴちゃ……♪　あ……♪　やはり、舌で亀頭をなぞると苦いな……♪　そし\nて臭い……。だが、そんなことでひるむ私ではない……。ぴちゃっ、くちゅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0503208" ]},
		{"command":[ "SETIMAGE", "0", "still_00001605_01_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「んんんむ……♪　れろっ、レロッ……、ぐちゅっ、ぢゅぷっ、じゅるっ……\nじゅるるるっ……。はぷっ、ンッ……ぴちゃっ、ちゅく……じゅるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0503209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「どうだ……♪　一度目と変わらず、丁寧にねぶれているだろう……？　れろ\nっ、れろ、ぴちゃ……ぐちゅっ♪　ちゅっぷっ、くちゅっ、ちゅぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0503210" ]},
		{"command":[ "SETIMAGE", "0", "still_00001605_01_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「ん、ぁ、精液の臭い……、このじっとりと蒸れた悪臭ぅう……♪　ぴちゃっ\n、んっ、とても口にできるような味ではない、のに……。ンッ、んっんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0503211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「貴様のモノだと思うと、舌を伸ばすのがやめられない……。くちゅっ、私は\nどうにかしてしまったようだ……。っちゅぷっ、れろっ、んれろっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0503212" ]},
		{"command":[ "SETIMAGE", "0", "still_00001605_01_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「気持ち、いいか……？　ンンッ……、私の前では貴様の劣情を隠す必要はな\nい……。ちゅぷっ、理性など捨ててしまえ……。っちゅぱっ、チュッちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0503213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「チンポだけに集中するんだ……。感覚を研ぎ澄ませて……。……くちゅっ！\n　ちゅっ！　ちゅっ！　じゅるっ……！　じゅるっ、ぐちゅっ、ぐっちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0503214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「あ、ぁ、私の唾と、お前の先走りと……チンポの熱とでもう、胸がびっしょ\nり濡れてしまっている……っ。んっ、ぴちゃっ、ぴちゃ、くちゅぅうっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0503215" ]},
		{"command":[ "SETIMAGE", "0", "still_00001605_01_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「んぷ、くちゅっ、ぬちゃぬちゃになったチンポを……舐め回して、胸でシゴ\nいて……♪　はぁ、はぁ、私はなんとはしたないことを……。っくちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0503216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「それなのに、興奮が止まらない……！　あっ、ぁっ♪　ちゅくっ……くちゅ\nっ、舐めたい、もっと胸で刺激したい、チンポ、チンポをねぶりたい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0503217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「んん……！？　むぐぅっ……！　急に胸の中でチンポが肥大化した気がする\n……っ。ずっしり重いぞ、これは射精したくなってきているな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0503218" ]},
		{"command":[ "SETIMAGE", "0", "still_00001605_01_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「さあ……私の口でこのまま射精したいか？　それとも、顔にかけたいか……\n？　せっかくの聖夜だ、一つくらいワガママをきいてやるっ……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0503219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「貴様の、好きな方に出せ……。いいな？　絞り上げるぞ！　じゅるっ……じ\nゅるるるっ！　ぢゅぼっ！　じゅっぷっ、じゅるるるるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0503220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「んぐっ……♪　んむぅううっ……！　そうかっ……ンンッ、二度目の射精も\n私の口の中に出ひたかったのらな……っ、愛おしいヤツめぇ……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0503301" ]},
		{"command":[ "SETIMAGE", "0", "still_00001605_01_19" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「んんんっ……じゅるッ……！　じゅるっ……じゅっ……！　ゴクッ……！　\nごくっ、ごくっ……！　ほら、まだ出せるらろう！　もっと出せぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0503302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「まだだ……まだ！　じゅるっ、ゴクッ……んむぅううっ♪　ちゅぱっ、じゅ\nぱっ♪　じゅるっ……じゅっ！　ごくっ……ごく、ごくっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0503303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「う、あぁ……♪　何度出しても味が薄くなるどころか……粘り気まで増して\nいる……っ。うまく、口が開けないくらい……口の中で粘っているぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0503304" ]},
		{"command":[ "SETIMAGE", "0", "still_00001605_01_18" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「ん、う……ごくっ……。ふぅうう……っ♪　これだけ濃厚な精液を大量に飲\nみ干せば……当分腹は減らないだろうな。喉奥まで真っ白だ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0503305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「ああ、動くな……。表面にこびりついた精子も全て舐め取ってやるから……\n。ぴちゃっ、ぺちゃっ、ちゅぷ……くちゅ♪　……ごくっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0503306" ]},
		{"command":[ "SETIMAGE", "0", "still_00001605_01_17" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「……それで、貴様の希望したパイズリフェラは……どうだった？　まあ、二\n度もこれだけ射精しておいて、気持ち良くなかったなんて言わないだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0503307" ]},
		{"command":[ "SETIMAGE", "0", "still_00001605_01_16" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「……セクシーサンタだなんて、私をおちょくっているのか、と腹を立ててい\nたこともあったのだが……貴様が喜んでくれたのならばそれでいい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0503308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「フフ。こういったイベントの日くらい……少し気を抜いて、素直に甘えてみ\nるのもいいものだ、と思ってな。ここには……ラブホには他に誰もいない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0503309" ]},
		{"command":[ "SETIMAGE", "0", "still_00001605_01_18" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「貴様と私の二人だけだ……♪　だから、……その。この後は、恋人同士のよ\nうに、せいぜいイチャイチャしようではないか……。いいだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0503310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「ん、ぷぅっ……♪　んぶっ……！　ぷぁっ……！　そ、そうか……っ。二度\n目は私の顔に精液をかけたかったのか……♪　うっ♪　んぶっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0503401" ]},
		{"command":[ "SETIMAGE", "0", "still_00001605_01_22" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「好きな方を選択していいと言ったのは私だから、文句はないが……。んんッ\n！？　だからといって遠慮がなさすぎるぞ、顔の中心を狙うなっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0503402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「う、ぁ……♪　熱い……。ドロリとしたぬめり……。んぶっ、口の中に入ら\nなくてもわかる……。この精液が特別に苦くて濃厚なことが……。あ、ぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0503403" ]},
		{"command":[ "SETIMAGE", "0", "still_00001605_01_21" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「そんなに勢い良く精液を飛ばして……、ぁっ♪　よほどパイズリフェラがお\n気に召したようだな……！　っんうっ、ど、どれだけ出すつもりだ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0503404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「このままでは私の顔が真っ白になってしま、う……。うぅっ！？　ぷぁっ…\n…んむ……♪　すごい……チンポがビクビク痙攣して、跳ねて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0503405" ]},
		{"command":[ "SETIMAGE", "0", "still_00001605_01_20" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「仕方ないな……。今日だけは全て受け止めてやる、だからこのまま……！　\nあッ……！？　ん、う、んぶっ……んんんんんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0503406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「ぷっはぁああああああ……♪　出しに出したじゃないか……。途中から、息\nを止めていないと溺れてしまいそうなほど大量に射精していたな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0503407" ]},
		{"command":[ "SETIMAGE", "0", "still_00001605_01_23" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「……自らの色に女を染めるのは、男の……夢というやつではないのか？　そ\nの夢が叶ったんだ、もっと幸せそうにしていいぞ……？　んぷ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0503408" ]},
		{"command":[ "SETIMAGE", "0", "still_00001605_01_25" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「いつも、貴様には……厳しく振るまってしまっているが。こうして、二人き\nりの……特別な日にはその分可愛がってやる。だから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0503409" ]},
		{"command":[ "SETIMAGE", "0", "still_00001605_01_24" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「クリスマス、正月、バ、バレンタイン……。そういう例外の日には、私のと\nころへ来るといい。絶対に後悔はさせない。……そ、そういうことだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0503410" ]},
		{"command":[ "WAITINPUT" ]},
