{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0162" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「やっと来てくれましたね。もう……遅かったじゃないですか。待ちくたびれ\nちゃいましたよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0503101" ]},
		{"command":[ "SETCHARA", "0", "char_00001405_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「誰もいない教室に呼び出してなんの用だ？　……って。それはもちろん、ダ\nーリンの好きなことをするためです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0503102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ほら、はやくズボンを脱いでください。私はもう、準備できていますから。\nふふふ、なにをするかというと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0503103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「どうですか？　こうやってオチンチンを足で……んっ、しごいてあげますか\nらね……ああ、すごい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0503104" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001405_01_02" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「こうやって足で触れているあいだに……オチンチンがどんどん硬くなってき\nています……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0503105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「私の足で、興奮してくれているんですか……？　え、それだけじゃない？　\nああ……そうですよね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0503106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ダーリンのところから、私のオマンコもおっぱいも……全部見えちゃってい\nるから……それで、余計に……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0503107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「オチンチンを硬くしちゃっているんですね……ンッ、それにビクビク暴れさ\nせちゃってる……もう、じっとしてくださいっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0503108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ほかの女の子にも、このオチンチンでいっぱいイタズラしたんですよね？　\n私、知っているんですからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0503109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「だから、今日は私がダーリンのオチンチンを足でオシオキしちゃうんですか\nら……んっ、こうやって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0503110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ガチガチになったオチンチンを、両足で……ぎゅって、して……シコシコ、\nいっぱい気持ちよくしちゃいます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0503111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ほら……どうですか……？　網タイツ越しの足が、ダーリンのオチンチンを\nしごいて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0503112" ]},
		{"command":[ "SETIMAGE", "0", "still_00001405_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ストッキングとはまた違った、すべすべした感触……敏感なオチンチンで、\n感じ取ってくださいね……ふふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0503113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……。オチンチンが震えて……。足の間で、膨らんでいるのを\n感じます……んっ、ああ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0503114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「それにだんだんと、オチンチンが汗ばんできて……。先っぽが、真っ赤にな\nって……パンパンになって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0503115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「もっと足を動かして……オチンチンをしごきますから……んっ、どうですか\n……こうやって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0503116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「竿を……しこしこって……。んっ、んんぅ……。ダーリンの感じる加減……\nよく知っているんですからね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0503117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「その証拠に……オチンチンがどんどん熱くなって……あんっ、ほら……こん\nなに反りかえってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0503118" ]},
		{"command":[ "SETIMAGE", "0", "still_00001405_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「んんっ、すりすりって……足の裏でこすられるの、気持ちいいですよね……\nふふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0503119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「でも、ダーリンのオチンチンを一番気持ちよくできるのは、私の足なんです\nから。ほら……その証拠に……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0503120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「オチンチンの先っぽから、トロトロ～ってお汁が垂れてきていますよ……。\nんっ、タイツがヌルヌルになっちゃう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0503121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……。もっと激しく、オチンチンしごいちゃいますね……。足\nでいっぱいシコシコして……っと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0503122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「あんっ、そんな辛そうな顔しないでくださいよ。気持ちよくなっているの、\n我慢しなくていいんですから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0503123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「私の足コキで、こんなに感じているでしょ？　オチンチンをガチガチにして\n、もう射精しそうになっているんじゃないですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0503124" ]},
		{"command":[ "SETIMAGE", "0", "still_00001405_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「図星ですか？　ふふっ、わかるのは当然です。だって、ダーリンのオチンチ\nンのことは全部知っているんですから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0503125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「誰よりも気持ちよくできるのは、この私なんです。だから、このまま射精し\nちゃっていいんですよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0503126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ほら、最後はこうやって、オチンチンをぎゅうっと強く挟んでしごく。網タ\nイツで、ゴシゴシ、オチンチンちょっと乱暴めに……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0503127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「んっ、オチンチンが暴れてるっ、あんっ、我慢しなくていいんですよ？　私\nが全部受け止めますからっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0503128" ]},
		{"command":[ "SETIMAGE", "0", "still_00001405_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ダーリンの精液は、私のものなんですっ！　だから、だからダーリンの精液\nを、思いっきり私に……かけちゃって……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0503129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「あああぁぁぁああぁぁあぁんっ！　んっ、すごいっ、噴水みたいに、びゅく\nぅって、真っ白いのがぁ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0503130" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001405_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ダーリンの精液が、いっぱい……。ああ……とっても素敵な匂い……。嗅い\nでいるだけで、身体が熱くなってしまいます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0503131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ああ……まだ足の間で、ビクンビクンって震えながら……。先っぽから、精\n液の残りがぴゅくぴゅくでてますよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0503132" ]},
		{"command":[ "SETIMAGE", "0", "still_00001405_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「かわいい……。お手伝いしてあげますね……。射精したばかりのオチンチン\nを、足でやさしくしごいて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0503133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「根元から……先っぽに向かって……。優しく、尿道に残っている精液を搾り\nだしてあげるように……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0503134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「んっ、はぁ……。ダーリンの精液が……まだまだこんなに、残っていたんで\nすね……ふふ……タイツがドロドロですよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0503135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「だしたてほやほやの精液……。ああ、足がやけどしちゃいそうなくらい熱く\nて……ねっとり、重たい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0503136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「こんなに濃い精液を射精できたのは、私の足コキが気持ちよかったからです\nよね？　うふふ、恥ずかしがらなくてもいいんですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0503137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「だって、私が一番なんですから。だからたくさん精液がでるんです。当たり\n前のことなんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0503138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「それで……当然まだまだ足りませんよね？　一回くらいじゃ、このオチンチ\nンは満足しませんよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0503139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「もっともっと射精させてあげます。私の足でしかイけなくなるくらい、感じ\nさせてあげますからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0503140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ほら……まだまだこんなにガチガチじゃないですか……。んっ、それじゃあ\nこの精液まみれの足で……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0503201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ダーリンのオチンチンを、またシコシコってしごいていきます。うふふっ、\nヌルヌルの網タイツが滑って、気持ちいいですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0503202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「こうやって、精液をぬりひろげるみたいに、足で、オチンチンをこすって、\nしごいて……あんっ、オチンチンがおっきく震えましたよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0503203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「んしょっ、あ……ん……っ。精液まみれのタイツが、こすれて……いやらし\nい音がしてしまっていますね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0503204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……。それに、ダーリンのいやらしい視線を……感じてしまい\nます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0503205" ]},
		{"command":[ "SETIMAGE", "0", "still_00001405_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「どこを見ているのか、わかりますよ……。オマンコ……おっぱいも……。ふ\nふっ、私も、興奮してしまっていますから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0503206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「オマンコ……濡れてしまっていますし……。おっぱいも……乳首、勃起しち\nゃっているんです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0503207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ああ……なんだか身体がジンジンと熱くなってきてしまいました……。ダー\nリンのオチンチンに奉仕しながら、オマンコ濡れちゃう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0503208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「だって……大好きなダーリンのオチンチンだから……。気持ちよくなってい\nるのを見たら、嬉しくなっちゃう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0503209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……。ヌルヌルのタイツで、もっと……ぎゅっと……ンッ、ア\nツアツのオチンチン感じながら、足コキ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0503210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「どうですか……気持ちいいですよね……？　またさっきみたいに、オチンチ\nンがビクビクと震えてきましたよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0503211" ]},
		{"command":[ "SETIMAGE", "0", "still_00001405_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「また、射精しそうになっているでしょう……？　わかっちゃうんですから、\nほかの誰よりも、ダーリンのオチンチンのことなら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0503212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「だから、誰よりも気持ちよくできるんです。私の足コキが一番なんですから\n。またいっぱい射精させちゃいますよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0503213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「んっ、んんっ、オチンチンまた膨らんで……射精、我慢しなくていいんです\nからね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0503214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「たくさん精液をだせるように……私、足コキがんばりますから……んっ、あ\nあ……こうですよね……足、動かし方……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0503215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「網目に精液が絡まって……んっ、それにまた、先っぽからお汁も溢れてきて\n……ああ……イキそうですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0503216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「精液……また、たくさん……。私にむかって、どぴゅどぴゅだしちゃいます\nか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0503217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「我慢しなくていいですから……。ダーリンが気持ちよくなって、射精しちゃ\nうところ……私に見せてください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0503218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「さっきみたいな濃厚精液を、びゅくびゅくって、噴き上げるところ……私に\n、また、見せて……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0503219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「いっぱいしごいて、射精させますから……！　だから、いっぱい……いっぱ\nい射精して……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0503220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ああっ！　ああああぁぁぁぁああぁぁあぁ～～～～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0503301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001405_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「また、すっごい……っ！　アツアツドロドロの精液が、私の脚に、たっくさ\nんひっかかって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0503302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ああ……またこんなにタイツが汚れてしまいました……。でも、嬉しいです\n……ダーリンの精液だから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0503303" ]},
		{"command":[ "SETIMAGE", "0", "still_00001405_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「こんなに、ネバネバした精液……。他の女の子に向けて射精したことないで\nしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0503304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「私の足だから、私の足コキだから、こんなにたくさん射精できたんですよ…\n…？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0503305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ふふっ、ほらほら……。またさっきみたいに、オチンチンの中のお残り精液\nも搾りだしちゃいますね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0503306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「んっ……よいしょ……っ。プリップリの精液が……オチンチンの先っぽから\n、ぷりゅって、顔をだしましたよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0503307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ダーリンにいっぱい悦んでもらえたみたいで、私もとても嬉しいです。でも\n、これくらいじゃ足りません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0503308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「まだまだダーリンには、これまで相手をしてくれなかった分まで、私につき\n合ってもらいますから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0503309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「誰が一番なのか、ダーリンにしっかりと教えてあげちゃいますからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0503310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「きゃああっ！　ああっ、すごい……っ！　あっ、あああぁぁぁああぁぁあぁ\n～～～～んっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0503401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001405_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「あっ、ああ……っ！　精液が、顔にまで……っ！　はぁ……はぁ……ダーリ\nンの精液の匂いに、包まれてしまいます……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0503402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「あんっ、そんな……ぶっかけられて、イッたのかだなんて……。そんな恥ず\nかしいこと、聞かないでくださいよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0503403" ]},
		{"command":[ "SETIMAGE", "0", "still_00001405_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「そんなの……イクに決まってるじゃないですか……。だって、大好きなダー\nリンの精液なんですから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0503404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「二回目なのに、こんなに勢いよく射精するなんて、やっぱり私の足コキが気\n持ちよかったんですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0503405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「うふふっ、それとも、私のいやらしいオマンコやおっぱいを見ながらだから\n、余計に興奮しちゃいましたか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0503406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「私だって、とっても興奮していたんですよ。ダーリンのオチンチンに足コキ\nしながら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0503407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「そうやって、昂っていたところに精液を浴びたものですから。そりゃあ……\nイッちゃいますよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0503408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ふふっ。ところでオチンチンはまだまだ勃起したままですね。射精し足りな\nい様子です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0503409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「教室には誰もこないんですから、このままずっと、ふたりっきりの放課後を\n楽しみましょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0503410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}