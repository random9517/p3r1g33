		{"command":[ "PLAYVOICE", "v2_028_0303116" ]},
		{"command":[ "SETIMAGE", "0", "still_00002803_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「あんなにバカにしてたクセに、興奮しまくってるじゃない……！本当に堪え\n性のないオチンチンね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0303117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
