		{"command":[ "PLAYVOICE", "v2_028_0303105" ]},
		{"command":[ "SETIMAGE", "0", "still_00002803_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「いいわ。その強がりがどこまで持つか、試してあげる……んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0303106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「あふっ、はあんっ……！あっ、あっ……！くっ、あぅ、はふっ……！ふふっ\n。そんなに我慢した顔してどうしたの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0303107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「なにしてるって……ちょっと身体を動かして、軽くおっぱいでオチンチン擦\nっただけじゃない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0303108" ]},
		{"command":[ "SETIMAGE", "0", "still_00002803_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
