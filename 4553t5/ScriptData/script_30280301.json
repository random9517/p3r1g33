		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「そもそも、パイズリに胸の大きさとか関係ないわ。小さいなら、小さいなり\nのやり方ってものがあるのよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0303102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「……ふふっ。そこまで言われたら、あたしも黙ってられないわ。いいわよ。\nこの胸でもパイズリできることを証明してあげる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0303103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「んっ……はあっ、ふっ、はっ……どう？小さくても、ちゃんとオチンチン挟\nめてるでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0303104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
