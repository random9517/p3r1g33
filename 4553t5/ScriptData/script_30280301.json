		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「そんなにあたしのこと、汚したかったの……？まったく、あんたって本当に\nどうようもない変態ね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0303407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「ああ、もう……このままじゃ、精液のニオイが身体に染み付いちゃうじゃな\nい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0303408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「こんないやらしいニオイをさせてたら……エッチな子って思われちゃうわ」", "NORMAL" ]},
