		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「熱いザーメンが顔にかかって……あっ、あああぁ……！？エッチなニオイが\n、すぐそこから漂ってくるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0303402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「だ、ダメっ……！谷間からのニオイだけでもキツいのに、こんなことされた\nら……あっ、あっ！これ、イッちゃうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0303403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「やあああぁ……！み、見ないで……！あたしのイキ顔、見ないでっ……あっ\n、あっ！イクッ、イクぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0303404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「あっ、あっ！やっ、ふああぁ……！あああっ、ザーメンで……エッチなニオ\nイで、イクぅぅぅんっ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0303405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「ふっ、はふっ……胸だけじゃなくて、顔にも精液を出すなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0303406" ]},
