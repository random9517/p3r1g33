		{"command":[ "PLAYVOICE", "v2_028_0303109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「気持ちよくないって言ってたクセに、オチンチンは素直に反応してるみたい\nね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0303110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「ほら……擦らずに押し付けてるだけでも、ビクビクして……今にも暴れ出し\nそうね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0303111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「あんたが気持ちいいって素直に言えば、もっと激しく動いてあげるわよ……\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0303112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
