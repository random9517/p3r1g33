		{"command":[ "SETTEXT", "「やっ、あっ……！あたしのおっぱい、真っ白に染められてるっ……！エッチ\nな色になってるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0303302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「こんなの、感じすぎるっ……！いやらしいニオイが、谷間からどんどん立ち\n込めてきて……あっ、あふうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0303303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「んひっ、ふくぅんっ……！はっ、はああぁ……！このニオイだけ、イッちゃ\nうっ……！あっ、イクッ、イクぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0303304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「小さなおっぱいにザーメン注がれながら……イッ、イクぅぅぅぅぅ……！！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0303305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「ふあああぁ……あんたのザーメンで、おっぱいドロドロになっちゃたじゃな\nい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0303306" ]},
		{"command":[ "SETIMAGE", "0", "still_00002803_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「でも、こんなに出したってことは……この小さな胸が気に入ったってことよ\nね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0303307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「……ふふっ。これだけ射精したあとだから、正直に頷くのね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0303308" ]},
		{"command":[ "SETIMAGE", "0", "still_00002803_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「でも、これで小さな胸でもパイズリできるって、ちゃんと証明できたようね\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0303309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「これに懲りたら、もう小さいおっぱいをバカにするんじゃないわよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0303310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「お、オチンチンが跳ねて……きゃあああぁ！？ちょ、ちょっと、どこに出し\nて……あぶっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0303401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
