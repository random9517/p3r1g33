		{"command":[ "PLAYVOICE", "v2_028_0303114" ]},
		{"command":[ "SETIMAGE", "0", "still_00002803_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
