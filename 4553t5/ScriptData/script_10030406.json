{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0027" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「……ちょっと遊び過ぎたね。セレーナ、いくよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100115140001" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「ぶっ潰した方がいいとおもうけど……エファナティカ様がそう言うなら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080115140001" ]},
		{"command":[ "SETCHARA", "0", "char_00000408_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「おい、逃げるな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115140001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ルナテミス、深追いする必要はない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090115140001" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「なるほどねー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115140001" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「鳳雛！　貴様どこにいっていた！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115140002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「僕は探偵だよ？　君たちが戦っている間に、ちょっと隠れていたのさ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115140002" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ちょっとは戦闘に参加しろ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115140003" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「そんなこと言われてもねぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115140003" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「しかし、どうして急に撤退したんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090115140002" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「あの偉そうな方が撤退するとき、ちらっとなにか確認したみたいだったね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115140004" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そうだったか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115140004" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「ふふふ、探偵の観察力を舐めてもらっちゃ困るね。そして、その視線の先に\nは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115140005" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「高級アンパ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115140006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「時計！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090115140003" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「アナザー・エファナティカたちは時間を気にしていたということか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090115140004" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「どういうことだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115140005" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「奴らが引き上げたのは、なにかの時間が迫っていたからなのだろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090115140005" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「なにかって、なんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115140006" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「わからない。だが、奴らの向かった方向に、なにかヒントがあるかもしれな\nい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090115140006" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「時間が関係しているのなら、目的地へできるだけ最短距離で向かうはずだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090115140007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「そ、そうだね。僕もそれを言おうとしていたよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115140007" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「あの人たちは商店街に向かったみたいだし、行ってみよう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115140008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0041" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「僕たちは商店街へと向かった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115140009" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「タヌキの置物になにかが起きているはず、というのが僕の推理だったわけだ\nけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115140010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「商店街で見つかるのはありふれた置物のタヌキだった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115140011" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「宝箱を持ったタヌキは見つからない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115140012" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「……そんな推理していたか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115140007" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「細かいことは気にしないで」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115140013" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「それにしても、この商店街ってこんなにたくさんのタヌキの置物があったん\nだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090115140008" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「普段生活している街を探検すると、いろんな発見があって面白いね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115140014" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そうだな……じゃなーいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115140008" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「時間帝国の連中より先にタヌキ像を見つけないといけないんだぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115140009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「お前ら、店先でなにやってんだ。まだ準備中だぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020115140001" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「すまない。ちょっと探し物をしていてだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090115140009" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「店の中まで聞こえてきたよ。タヌキの置物だろ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020115140002" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「そうなんだ。ところで……この箱、なにが入ってるんだい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115140015" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ん？　この段ボールか？　後で捨てようと思って出しているだけで、何も入\nってねえよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020115140003" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「そうか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115140016" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「また会ったね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100115140002" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「お前ら、まだ探していたのか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080115140002" ]},
		{"command":[ "SETCHARA", "0", "char_00000408_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「お前たちこそ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115140010" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「その様子だと、まだタヌキ像は見つかっていないようだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090115140010" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「なに、ちょっとアテが外れただけじゃ。それよりも余たちの後をつけてきた\nのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100115140003" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「オレたちが見つけたところを横取りするつもりだったんだな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080115140003" ]},
		{"command":[ "SETCHARA", "0", "char_00000408_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そんな真似するわけないだろ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115140011" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「これ以上付きまとわれるのも迷惑じゃ。ここで消えてもらおうかのう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100115140004" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「お前ら！　こんなところでおっぱじめる気か！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020115140004" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}