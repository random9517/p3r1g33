{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0101" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_005" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ねえねえ～？　さっきの関西弁の子、誰なの～？　アナザーのお友達～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010104040001" ]},
	{"command":[ "SETCHARA", "0", "char_00000601_01", "0", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
	{"command":[ "SPOTCHARA", "0" ] },
	{"command":[ "DISPTEXT", "TRUE" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうだな。なんか、知ってるような口ぶりだったけど。なんなんだ？　アイ\nツ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「なんというか……少々話が長くなりそうなので、あとで説明する」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090104040001" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「まったく！　あのマグナシアとか言う女、いったい何者なのだ！　いきなり\n攻撃をしかけてきて――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010104040001" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「お帰りなさい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_072_010104040001" ]},
	{"command":[ "SETCHARA", "0", "char_00007201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「げ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "クリスタル・コンツェルンのミス・パープル……！", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「隊長さん、いつもお世話になっております。実は本日はですね――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_072_010104040002" ]},
	{"command":[ "SETCHARA", "0", "char_00007201_01", "6", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いやいやいや！　待ってくれ待ってくれ！　またなんか、怪しげなものを売\nりつけに来たんじゃねえだろうな！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「『怪しげなもの』、とは心外ですが、その話はあとにしましょう。本日は招\n待状のお届けにあがりました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_072_010104040003" ]},
	{"command":[ "SETCHARA", "0", "char_00007201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「招待状？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「こちらです。これが……アナザーさん宛て。こちらは、ルナテミスさん宛て\nですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_072_010104040004" ]},
	{"command":[ "SETCHARA", "0", "char_00007201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「え？　私にもか？　招待状とはいったい……？」」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010104040002" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「もしかしてルナ様！　パーティとかに招待されたんですか！？　いいなぁ～\n！　豪華な料理がいっぱい出るんでしょ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010104040001" ]},
	{"command":[ "SETCHARA", "0", "char_00000401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「いや、これはおそらく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090104040002" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「……なんだ？　これは？　『第３２４回プリンセス・トーナメント』……出\n場要請と書いてあるが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010104040003" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「やはりそうか……私への招待状もそれだな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090104040003" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「ええ。もちろんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_072_010104040005" ]},
	{"command":[ "SETCHARA", "0", "char_00007201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「アナザー！　貴様、またそれか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010104040004" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「なんだ？　どうした、ルナテミス」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090104040004" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「なんだもなにも！　お前はいつもそうだ！　自分ひとりだけで何もかも分か\nったような顔で、他の者を置き去りにする！　私を馬鹿にしているのか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010104040005" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「いや、そういうつもりは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090104040005" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「先ほどのこともそうだ！　あのマグナシアとやらを貴様は知っているようだ\nったが、説明する素振りすら見せない！　どういうつもりなのだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010104040006" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「う……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090104040006" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「アナザー、悪いけどな。これは姫様の言うことも一理あると思うぜ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「まったくだ。もったいぶらずに、とっとと知ってることを全部吐きな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010104040001" ]},
	{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「……すまない。確かに、お前たちの言う通りだ。わかった、説明しよう。ま\nず、プリンセス・トーナメントとは――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090104040007" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「よろしければ、それは私からご説明いたしましょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_072_010104040006" ]},
	{"command":[ "SETCHARA", "0", "char_00007201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ミス・パープル！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090104040008" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「『プリンセストーナメント』とは多次元世界において、一番美しく強い王女\nを決めるための大会です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_072_010104040007" ]},
	{"command":[ "SETCHARA", "0", "char_00007201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「美しく……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010104040002" ]},
	{"command":[ "SETCHARA", "0", "char_00000601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「強い王女だって？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010104040002" ]},
	{"command":[ "SETCHARA", "0", "char_00000301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「そうです。多くの次元から、各王家を代表する王女たちが一堂に会し、戦っ\nて、戦って、そして美を競い合って――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_072_010104040008" ]},
	{"command":[ "SETCHARA", "0", "char_00007201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「最終的に勝ち残った、たったひとりの王女が『プリンセス・オブ・マルチバ\nース』を名乗る資格を得る。そういう大会なのです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_072_010104040009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「それに、私が招待されたと……？　アナザー！　貴様、この大会のことを知\nっていたのか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010104040007" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「噂は聞いていた。だが、はっきりしたことは知らなかったので、先ほどは説\n明できなかったのだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090104040009" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「なにしろ、ここ１０００年ほど開かれていなかった大会だ。急に開かれると\n聞いても、にわかには信じられなかったからな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090104040010" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「では、あのマグナシアとやらは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010104040008" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「マグナシア・カイザー・ナックル姫はすでにエントリー済みです。下馬評で\nは優勝候補のひとり――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_072_010104040010" ]},
	{"command":[ "SETCHARA", "0", "char_00007201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「いえ『最強の座に最も近いプリンセス』というのが、もっぱらの評判ですね\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_072_010104040011" ]},
	{"command":[ "SETCHARA", "0", "char_00007201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「最強だと……！？　あいつが！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010104040009" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「実力のほどは、試合で手合わせしてみればわかるかと。いかがですか？　お\n二人とも、ご出場いただけますか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_072_010104040012" ]},
	{"command":[ "SETCHARA", "0", "char_00007201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「え？　なんでミス・パープルがそんなこと聞くんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010104040001" ]},
	{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「これも業務の一環ですので。競技の主催は汎次元プリンセス・トーナメント\n協会、協賛はクリスタル・コンツェルンとなっております」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_072_010104040013" ]},
	{"command":[ "SETCHARA", "0", "char_00007201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「あ、そ、そうなんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010104040002" ]},
	{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "金の匂いがするところには、どこにでも首を突っ込むってことなんだろうなあ\n……。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「それはともかく、出場に関しては――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_072_010104040014" ]},
	{"command":[ "SETCHARA", "0", "char_00007201_01", "6", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「私は参戦する！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010104040010" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "うぉおおっ！？　ルナテミスのヤツ、すごい気合いだ！？", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「倒す……！　あのマグナシアを、この手で、観客の目の前で、必ず倒す！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010104040011" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「がんばってね！　ルナテミス！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010104040003" ]},
	{"command":[ "SETCHARA", "0", "char_00001201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「おう！　そして、マグナシアを倒したら……次は貴様だ！　アナザー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010104040012" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「わ、私だと！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090104040011" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「その通り！　二号呼ばわりされて黙っていられるか！　私が！　私こそがル\nナテミス一号だと！　実力で証明して見せる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010104040013" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "『Ｗルナテミス』は確定でいいのか。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「だ、そうですが、アナザーさんは？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_072_010104040015" ]},
	{"command":[ "SETCHARA", "0", "char_00007201_01", "6", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「正直、気は進まないが……招待を受けたとあっては断るわけにもいくまい。\nそれに、断ると言ってもルナテミスが納得してくれんだろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090104040012" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「では、ご参加と言うことで。ありがとうございます！　大勢のプリンセスた\nちが、お二人の参戦を楽しみにしておられますよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_072_010104040016" ]},
	{"command":[ "SETCHARA", "0", "char_00007201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「大勢のプリンセスが……ですか。たくさんの次元の……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010104040001" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「どうしたの？　まりあ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010104040001" ]},
	{"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「プリンセスが集まる大会ともなれば、その家族……つまり王族を始めとした\n、多くの次元の重要人物が一か所に集まることになりますよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010104040002" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010104040002" ]},
	{"command":[ "SETCHARA", "0", "char_00000201_01", "03", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「その機会を、襲来者（インベーダー）が黙って見逃してくれるとは思えない\nんですが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010104040003" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「たしかに、それはそうだねぇ……おい、ミス・パープルさんよ。もし、ルナ\nテミス様に何かあったら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010104040003" ]},
	{"command":[ "SETCHARA", "0", "char_00000301_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「はい！　実は我々も、その点にはたいへん懸念を抱いておりまして……本日\n、私がここにうかがったのは、実はそのこともあるのです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_072_010104040017" ]},
	{"command":[ "SETCHARA", "0", "char_00007201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「どういうことです？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010104040001" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「会場となるのは、とある次元の宇宙空間に作られた、人工のスタジアム惑星\nです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_072_010104040018" ]},
	{"command":[ "SETCHARA", "0", "char_00007201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「惑星周辺にはコンツェルンが誇る無敵の護衛艦隊を配備し、軌道上の守りは\n万全です。しかし、問題は会場内でして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_072_010104040019" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「なんとなく、話が読めてきたねえ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010104040004" ]},
	{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「つまり、ウチらに会場内の警備を手伝えと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010104040002" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「そういうことです。小回りの利く精鋭部隊を、できるだけ多く配備したいの\nです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_072_010104040020" ]},
	{"command":[ "SETCHARA", "0", "char_00007201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「ただ、正確に言いますと、この件はすでに長官からは承認をいただいており\nまして――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_072_010104040021" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「……長官？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010104040005" ]},
	{"command":[ "SETCHARA", "0", "char_00000301_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ギクッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010104040001" ]},
	{"command":[ "SETCHARA", "0", "char_00004901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「ですので、皆さんには当然お手伝いいただける前提で大会の準備は進んでお\nります。すでに報酬の前渡し分も振り込み済みで――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_072_010104040022" ]},
	{"command":[ "SETCHARA", "0", "char_00007201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「報酬！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010104040003" ]},
	{"command":[ "SETCHARA", "0", "char_00000601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ちょっと長官！　どうなってんすか！　俺たちは聞いてませんよ、そんな話\n！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「さっきからやけに長官が無口だと思ったら、そういうことでしたか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010104040003" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「待て待て待て待て！　黙って聞いていれば聞き捨てならんな！　私がコンツ\nェルンからの報酬をポッケに入れたとでも思っているのか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010104040002" ]},
	{"command":[ "SETCHARA", "0", "char_00004901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そこまで言っちゃいませんよ！　ただですね、俺たちも、おこぼれぐらいは\n期待していいんでしょうね！？　臨時ボーナスとか！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「きゃぁ～ん！　ボーナス！　臨時ボーナス！　なんて素敵な響きぃ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010104040004" ]},
	{"command":[ "SETCHARA", "0", "char_00000601_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「出るわけがないだろう！　出撃するたびに街を破壊しておいて！　あれを誰\nが弁償していると思う！　もちろん部隊の経費なんだぞ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010104040003" ]},
	{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「今回の報酬は、部隊運営費用の穴埋めとさせてもらう！　もちろん全額だ！\n　もう決めた！　というか、もうほぼ全額、行先は決まっている！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010104040004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「う、ううううううう……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ダイヤナちゃん、しょんぼり……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010104040005" ]},
	{"command":[ "SETCHARA", "0", "char_00000601_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うるせえ、しょんぼりはこっちだ……！　たまには牛丼にサラダと豚汁でも\n付けられるかと思ったのに……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "くそお……せっかくのチャンスなのに……なにか、少しでも報酬のおこぼれを\nこっちに回させて、薄給を補う方法はないもんか……。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETTEXT", "「いや……待てよ？　ミス・パープル！　この大会、賞金は出ないのか！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「賞金、ですか？　出場者は皆さん高貴なプリンセスですし、あくまでも最強\nのプリンセスという名誉をめぐる戦いですので――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_072_010104040023" ]},
	{"command":[ "SETCHARA", "0", "char_00007201_01", "6", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「じゃあ、出ないのか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「いえいえ、そんなこともありません。上位３名まで、ある程度は副賞が出ま\nす。具体的に言うと、このぐらいですが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_072_010104040024" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……っ！　なんだよ、そこそこの額じゃねえか。これなら、二人のうちどっ\nちか……いや、両方が入賞すれば――」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「……おい。下僕。顔が普段以上にいやしいぞ。何を考えている？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010104040014" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「姫様！　そしてアナザー！　なんとしてもこの大会、勝ってくれ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「な、何をいきなり！？　それはもちろん、優勝以外は眼中にないが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010104040015" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「私も、出るからには勝ちに行くつもりだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090104040013" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「よぉし！　いいぞ、その意気だ！　二人とも絶対、三位までに入賞……いや\n、二人でワンツーフィニッシュを決めてくれ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「カツマ、お前、さては……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010104040006" ]},
	{"command":[ "SETCHARA", "0", "char_00000301_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「姫様！　姫様！　あなたは賞金なんかよりも、最強のプリンセスっていう名\n誉のほうが大事ですよね！？　アナザーもだ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「もちろんだ！　賞金などはいらぬ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010104040016" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「私もだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090104040014" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「じゃあ、賞金をいただいたとしても、俺たちで分けちゃってかまわないって\nことだ！　おい、みんな聞いたか！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「うっそぉ～！？　ホントぉ～！　やぁ～ん！　ダイヤナちゃん嬉し～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010104040006" ]},
	{"command":[ "SETCHARA", "0", "char_00000601_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「まったく、何を考えているんですか……ですが賞金を分けていただけるので\nあれば、助かるのは確かです。最近、いろいろと物入りでしたので」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010104040004" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「おおおっ！　マジすか！？　賞金、私らに分けてくれるんですか！？　すっ\nげー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010104040002" ]},
	{"command":[ "SETCHARA", "0", "char_00000401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「お前たち、いいかげんにしないかい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010104040007" ]},
	{"command":[ "SETCHARA", "0", "char_00000301_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まあまあ。いいじゃないか、エファナティカ。応援するにしたって、それぐ\nらいの張り合いがあったほうが、気合が入るってもんだぜ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「姫様たちだって、賛成してくれますよね？　ね？」", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSe" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「お、おう！　当然だ！　日頃から私を支えてくれる皆のために、それぐらい\nの礼はするつもりだぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010104040017" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "8", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ほらな？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「まあ……ルナテミス様がそうおっしゃるなら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010104040008" ]},
	{"command":[ "SETCHARA", "0", "char_00000301_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「おおおお～！　やったぁ！　さすがルナ様！　そこにシビれる憧れるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010104040003" ]},
	{"command":[ "SETCHARA", "0", "char_00000401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ダイヤナちゃん、気合入れて応援しちゃう～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010104040007" ]},
	{"command":[ "SETCHARA", "0", "char_00000601_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「ル、ルナテミス？　わたしは別に、そういうのなしでも応援するからね？　\nはははははは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010104040004" ]},
	{"command":[ "SETCHARA", "0", "char_00001201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「でも、最近、つきみの食費がますますかさむようになったし、臨時収入があ\nるのならそれはそれで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010104040004" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「ちょっとお姉ちゃん！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010104040005" ]},
	{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そういうわけで二人とも！　なんとしても優勝してくれ！　頼んだぞ！　俺\nたちみんなの、少しはましな生活のために！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「お、おう！　任せておけ！　私はかならず優勝してみせる！　皆の期待に応\nえてみせよう！　はははは！　はーっはっはっは！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010104040018" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「なんだか、おかしなことになってしまったな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090104040015" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
	{"command":[ "EXIT" ]}
	]
}