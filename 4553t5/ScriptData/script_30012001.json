{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「ご主人さま……今日は何の日か……ご存知ですか？　ふふっ、今日はメイド\nの姿ですので、そうお呼びするのが自然かなと思いまして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2003101" ]},
		{"command":[ "SETCHARA", "0", "char_00000120_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「それで……はい、そんな勿体をつける必要もありませんよね。ええ……今日\nは、バレンタインデーです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2003102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「女の子が……好きな男の人にチョコレートを送る日……そういう訳ですから\n、僭越ながら私もご主人さまにご用意させて頂きました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2003103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「えぇと……それで、ですね……少しだけ準備をしてもよろしいでしょうか？\n　はい、ありがとうございます。それでは、失礼しまして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2003104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「んっ……ちゅぷ……んふっ……ふふっ、びっくりされてしまいました……？\n　直接チョコレートを味わって頂きたくて……あら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2003105" ]},
		{"command":[ "SETCHARA", "0", "char_00000120_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「凄い……あっという間に前がパンパンに……待って下さいね……んっ……し\nょっと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2003106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00000120_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あぁ……私ったらお行儀が悪いです……チョコで汚れた手でオチンポを触っ\nたら……チョコがついてしまいました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2003107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「メイドとしてあるまじき粗相をして申し訳ありません。すぐに綺麗に致しま\nすので……どうか、そのままお身体を楽になさってくださいね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2003108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「は……んむっ、ぴちゃ……ちゅぱ……んちゅ……ぴちゃ……んっ……れろ、\nんちゅ……あぁ……んちゅぷ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2003109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「本当に申し訳ありません……こんなにチョコまみれにしてしまって……でも\n、んっ、オチンポについたチョコ……とっても甘いです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2003110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「れろ、ぴちゃ……ちゅぱ……んちゅ……あぁ……こちらにもついてしまって\nいます……ちゅぷ……ぴちゃ、れろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2003111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「んちゅぅ……えっ……もうチョコレートは取れてる……そう、ですね……そ\nうかも知れません……ぴちゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2003112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あっ、でも……手についたのが、んっ……またオチンポについてしまいまし\nた……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2003113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「これは、また綺麗にしないといけませんね……ちゅぷ……ぴちゃ、んちゅっ\n、あ……んちゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2003114" ]},
		{"command":[ "SETIMAGE", "0", "still_00000120_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「んんっ、はぁ……甘い……んっ、本当はご主人さまに食べて頂かないといけ\nないチョコレートなのに……私ばかり味わってしまっています……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2003115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「でも、あぁ……オチンポが……どんどん大きくなって……もう、抑えきれな\nい程になってしまっています……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2003116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「これは、先に……なんとかしないといけませんよね……お待ち下さい……今\n……お世話を致しますから……んちゅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2003117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「ちゅぷっ、ぴちゅ……んちゅっ、ちゅ……はぁっ、んっ……れろ、えろぉ…\n…えろ……れろぉぉぉぉっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2003118" ]},
		{"command":[ "SETIMAGE", "0", "still_00000120_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「ちゅぱ……チョコの甘さと……オチンポの塩加減が……んんっ、とてもよく\n合わさって……あぁ、癖になるお味がします……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2003119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「んふぅ……ちゅぷっ、ぴちゃ……ダメです……これは、あぁ……ちゅぷっ、\n私の方が我慢出来ないかも知れません……ちゅぱ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2003120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「その、はしたないお願いをしてしまいますが……このまま、射精するまで…\n…オチンポを……おしゃぶりさせてもらってよろしいですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2003121" ]},
		{"command":[ "SETIMAGE", "0", "still_00000120_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「はい、ご主人さまのオチンポをもっと味わいたくて……舌が止まらなくなっ\nてしまいました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2003122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あぁ……ありがとうございます。失礼致します……んちゅぷっ、ぴちゃっ、\nはむ……んむっ、りゅぷっ、んちゅぷぅぅぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2003123" ]},
		{"command":[ "SETIMAGE", "0", "still_00000120_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「んりゅぱっ……あぁ、んっ……ちゅぷっ、おいひぃ……んちゅぷぅぅ……あ\nぁ……オチンポ……止まらないれふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2003124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「もっと、深く……咥えてひまいまふね……じゅぷっ……んじゅるるっ、ちゅ\nぷぅっ、んむっ、くぷぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2003125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「んふふぅ……お行儀悪く頬張ってひまい……もうひわけ……ありまひぇん…\n…んじゅぷっ、ちゅぽっ、くぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2003126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「れも……ご主人さまの……オチンポも……んりゅっ、ビクビク……震えて下\nさってまひゅのれ……じゅぽっ、ちゅぷぅっ、んちゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2003127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「ふぁい……んふっ、もっと……奥まで味わわせて……いたらきまひゅっ……\nんりゅぷっ、くぽっ、んふぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2003128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「んぶっ、おぷっ、んふぅっ……おひんぽ……喉の奥まれ……とろいてまひゅ\nぅぅ……りゅぷっ、じゅぱっ、ちゅぱっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2003129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「はぁんむっ……もう、チョコの味はひなくて……ほとんどオチンポの味れふ\n……んじゅるっ、お汁も……少し滲んで来てまひゅ……んぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2003130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「はひ……わらひの口の中れも……涎が……どんどん、溢れて……来て……ん\nじゅるっ、ちゅぷっ、んふぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2003131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「不思議れふ……んじゅぷっ、このメイド服ですと……もっともっとご奉仕し\nなきゃって……そんな気持ちが湧いてくるんれふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2003132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「自分でも……こんらに……大胆になるらんて……思わなくて……あぁ……じ\nゅぱっ、れも……フェラチオがきもひいい……んちゅぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2003133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「んんっ、あぷっ、じゅぷっ……はぁ……出そうなんれふかっ……？　はひっ\n……大丈夫れふ……このまま、飲ませて下さいっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2003134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「思いっきり……吸い上げまひゅっ、じゅぷっ、んちゅぷぅっ……んじゅるっ\n、んちゅうぅぅぅぅぅぅぅーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2003135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「んんんんんっ……！　んふっ、むぐっ……んんんんっ……！　んむっ、こく\nっ、んっ、んくぅんっ……んぐっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2003136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000120_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「んふぁっ……はぁっ、はぁっ……あふっ、あぁ……おいひぃ……れふ……全\n部飲んでしまいまひた……んふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2003137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あ……お汁が少し垂れて来てますね……待って下さい……ちゃんと綺麗にし\nますから……んちゅっ、ちゅぷぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2003138" ]},
		{"command":[ "SETIMAGE", "0", "still_00000120_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「んっ……これでいいと思います。んふっ……いえ……どういたしまして……\n私の方こそ嬉しいです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2003139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「んふ……やっぱりご主人さまのオチンポ……最高でした。私の方が味わって\nしまって……申し訳ない位です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2003140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「んちゅぱっ……さて……まだオチンポは硬いままですね……これは、満足と\nは程遠い状態と……そういう解釈でよろしいでしょうか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2003201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「いえ……ご主人さまに失礼な言い方でした。私がまだオチンポをおしゃぶり\nしたいままなんです……ですから、ご主人さまにおねだりします……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2003202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「どうか、ご主人さまの立派なオチンポを……もう一度射精されるまで……フ\nェラチオご奉仕をさせて下さい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2003203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「んふっ……ありがとうございます。では……せっかくですし……少し残った\nチョコレート……ちょっとだけオチンポに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2003204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「また先の方がドロっとしちゃいましたね……今日だけお行儀悪いままで……\n失礼致します……はむ……んちゅぷっ、ぴちゃ……んちゅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2003205" ]},
		{"command":[ "SETIMAGE", "0", "still_00000120_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あふっ……とっても甘い……れろ……舌が自然に動いちゃいます……れろ、\nんぴちゃ……んちゅぷっ、ちゅぱ……ぴちゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2003206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「えっ……し、舌の動きが……いやらしい……ですか。そ、そんな風に言われ\nると……は、恥ずかしいですけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2003207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「でも、ご主人さまがそれで喜んで下さるのなら……はい、もっと……舌……\nいやらしくしてしまいますね……ぴちゃ……えろっ、れろぉっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2003208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あぁんむっ……こうひて……はっきり舐めてる所が見えるようにしてぇ……\n唾液をいっぱい乗せてぇ……ぴちゃ、んちゅぱ……りゅぷぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2003209" ]},
		{"command":[ "SETIMAGE", "0", "still_00000120_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あぁ……んんっ、れろ……美味しいれふ……舌が止まらないれふ……オチン\nポ、おいひすぎへぇ……ちゅぱ……んちゅぱぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2003210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「舐めてるだけじゃ……止まらない……んりゅっ、れろっ、またクポって咥え\nひゃいまひゅぅ……んぽっ、りゅぷぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2003211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「うん、んふっ、じゅぷっ、んりゅぷっ、じゅるっ……んじゅるるっ、はぁ…\n…んちゅぷっ、んふぅぅんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2003212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あぁ……私……とってもいやらしい顔をして……オチンポ……おしゃぶりし\nています……れろ、んりゅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2003213" ]},
		{"command":[ "SETIMAGE", "0", "still_00000120_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「だって、止まらないんです……んちゅぷっ、ご主人さまにお仕えするという\n使命感と……このオチンポの味が……私を狂わせるんです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2003214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「はぁんむっ、じゅぱっ、んちゅぱっ……でも、こうして……んちゅぷっ、お\nしゃぶりしているのが幸せで……んちゅぷっ、じゅぷぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2003215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「ずっとこうしていたい位……はぁん……りゅぱっ……あぁ……でも……オチ\nンポがまた先走りを出して……ビクンって震えて……んちゅぷうっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2003216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「はい、んちゅぷっ……もちろん我慢なんかなさらないで下さい……気持ちよ\nく射精していただく為に……していることれふから……じゅぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2003217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「私のお口で……いっぱい感じて……りゅぷっ、ふぁひっ……イッて……じゅ\nぽっ、くぷっ、んじゅるっ、じゅるるるるうぅーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2003218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「んぁんむっ……オチンポッ……出ますねっ？　射精……ひちゃいまひゅねっ\n……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2003219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「んんっ、らひてっ……くらひゃいっ……んじゅぷっ、オチンポッ……びゅる\nびゅるっ……してっ、くりゃひゃいまひぇっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2003220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「んんんんんんんっ！　んぐっ、ふぶっ、んんっ……んくっ、こくっ、んくっ\n、んんっ、んくっ、んくんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2003301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000120_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「んぁぷっ……あぁ……れてる……すごい量……あぷっ、いっぱい……れてま\nひゅ……精液ぃ……んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2003302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「こくっ、んちゅぷっ……美味しい……ご主人さまの精液……あぁんむ、いく\nらでも……飲めちゃいまひゅ……んくっ、こくんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2003303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「んちゅぷっ……はぁ……んふっ、あぁ……一気に飲んで……しまいました…\n…ちょっと勿体なかったかも知れません……ぴちゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2003304" ]},
		{"command":[ "SETIMAGE", "0", "still_00000120_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「でも、この味……やっぱり……虜になってしまうんです……ちゅぷ、口の中\nにまだ残ってる……れろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2003305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あ……すみません。せっかくのバレンタインデーなのに、私の方がいっぱい\n楽しんでしまったみたいで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2003306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あ、ごめんなさい……ちゃんとお掃除も致しますね……ぴちゃ……れろ……\nちゅぱ……はい、ちゃんと奥のも吸い出して……んちゅうぅぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2003307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「はふ……お疲れさまでした。気持ちよかったですか……それなら、はい……\n何よりです、あ……あの、えっと……ですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2003308" ]},
		{"command":[ "SETIMAGE", "0", "still_00000120_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「実は、その……本当のチョコレートは……また、別に用意してあるんですけ\nど、そ、その、も、もし良かったら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2003309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「は、はいっ！　よかった……ふふ……ちゃんとお口にあってくれるといいん\nですけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2003310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「ひぁんっ！　んぁふっ、あぁっ……んんっ、かおっ……あっ……れて……ま\nふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2003401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000120_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「んぁっ……精液……びゅるって……はぁぁんっ……浴びせられてぇ……んふ\nぁぁぁ……わらひもっ……あっ、イ、イキまひゅっ……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2003402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「んぁっ、あふっ……ちゅぱっ……全然薄くなってない……んんっ、濃いの…\n…やっぱりおいひぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2003403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「れろ……んんっ、あっ、まだ出るんですね……はい、お願いします……全部\n……浴びせて下さい……私の顔にぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2003404" ]},
		{"command":[ "SETIMAGE", "0", "still_00000120_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「んんっ……ご主人さまの色に染めて欲しい……私はその為のメイドなんです\nからぁ……んぁ……はふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2003405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あ……終わりましたか……？　はい、お疲れさまでした。あ……すぐにオチ\nンポ綺麗にしてしまいますね……ぺろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2003406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「れろ、ぴちゃ……んちゅぱ……んっ……とんでもありません……これは、私\nの大事な役目ですから……んちゅぱ……はい……大丈夫です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2003407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「えっと……結局、チョコレート……私ばっかり頂いちゃったみたいになりま\nしたね……あ、あの、でも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2003408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「もし、よろしければ……その、改めてちゃんとご用意したものがあるんです\nけど……もし、ご主人さまさえ受け取って下さるのなら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2003409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「は、はいっ！　よかった……ふふ……ちゃんとお口にあってくれるといいん\nですけど……」", "NORMAL" ]},
