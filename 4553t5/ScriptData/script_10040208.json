		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「おっと危な～い。今度は大丈夫だった～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_010116600001" ]},
		{"command":[ "SETCHARA", "0", "char_00009901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ええ。どうにか避けられました。ですが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110116600002" ]},
		{"command":[ "SETCHARA", "0", "char_00000511_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「やっぱりまだ、前の戦い方は思い出せない感じ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010116600001" ]},
		{"command":[ "SETCHARA", "0", "char_00009801_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「そうですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110116600003" ]},
		{"command":[ "SETCHARA", "0", "char_00000511_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「困ったもんだな。どうしたらいい……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_010116600001" ]},
		{"command":[ "SETCHARA", "0", "char_00009701_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「私にいい考えがある！　いったん、訓練相手を変えてみるのはどうだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_020116600001" ]},
		{"command":[ "SETCHARA", "0", "char_00000702_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「え？　誰に？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_020116600001" ]},
		{"command":[ "SETCHARA", "0", "char_00009601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「ハルノブの、オボロ時代をよく知っている相手とだ。例えばカツマとか……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_020116600002" ]},
		{"command":[ "SETCHARA", "0", "char_00000702_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「えええ！？　俺、さっきのウサギ跳びでヘロヘロなんだけど……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「なんだよ、カツマ。冷てえなぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_010116600002" ]},
		{"command":[ "SETCHARA", "0", "char_00009701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「ハルノブが困ってるのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_020116600002" ]},
		{"command":[ "SETCHARA", "0", "char_00009601_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「い、いや、だってさ……こんな状態で模擬戦やったって、俺が一方的にボコ\nボコになるだけで訓練にもなんにも……あ！　そうだ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「どしたの～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_010116600002" ]},
		{"command":[ "SETCHARA", "0", "char_00009901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「セレーナを呼んできて、相手してもらえばいいんだよ！　あいつなら、なん\nだかんだでオボロとは一番仲がいい――」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「あんなアホ犬と、仲良くなんかねーです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110116600004" ]},
		{"command":[ "SETCHARA", "0", "char_00000511_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「なんだとー！？　またアホ犬って言いやがったなコイツ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010116600001" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「え！？　セレーナ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハイッパーマッポーサムライ" ]},
		{"command":[ "SETTEXT", "「なんと！？　もうすでにセレーナを呼んでおったのか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_020116600001" ]},
		{"command":[ "SETCHARA", "0", "char_00014502_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「違う違う！　呼んでない呼んでない！　まさか、ベルガマスク？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「違う違う！　呼んでない呼んでない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_020116600003" ]},
		{"command":[ "SETCHARA", "0", "char_00000702_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「じゃ、誰……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010116600002" ]},
		{"command":[ "SETCHARA", "0", "char_00009801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「こんなこともあろうかと思って！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010116600001" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「わたしたちが連れてきました！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010116600001" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まりあとカグヤ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「なんか、わたしも付き合わされてま～す……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010116600001" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんか知らんけど、ご苦労さんだな。つきみも……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「なんだか知らんが、まあよし！　セレーナが来たのなら、模擬戦につきあっ\nてもらおう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_020116600004" ]},
		{"command":[ "SETCHARA", "0", "char_00000702_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「おう！　なんだかわかんないけど、バトルなら付き合うぜ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010116600002" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「では、対戦の組み合わせはハルノブ＆ニンジャラビッツ組対セレーナ＆カツ\nマ組！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_020116600005" ]},
		{"command":[ "SETCHARA", "0", "char_00000702_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「結局俺も参加するのかよぉ～！　っていうか……カグヤ？　まりあ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「なに？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010116600002" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんでお前らここにいるの？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「無駄口を聞いてるヒマはありませんよ！　さあ、訓練スタートです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010116600002" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "7", "CENTER", "0" ]},
