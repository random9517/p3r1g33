{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0088" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_007" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「放て！　竜の咆哮（ドラゴンズロア）！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090111090001" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0001" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「いいぞー！　いけいけー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_020111090001" ]},
		{"command":[ "SETCHARA", "0", "char_00001302_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「さすがだな、ドラグソード！　襲来者（インベーダー）のロボットを次々と\nやっつけていくぜ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「もう、ドラグソードちゃんひとりでいいんじゃなぁい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010111090001" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、そういうわけにもいかねえだろ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「そういえば、避難のほうはどうなってるかね。ちょっと確認してみようか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010111090001" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「長官！　脱出船団の様子はどうだい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010111090002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「いまのところ、避難は順調に進んでいる。半分程度は無事月を離れた、とい\nうところだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010111090001" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「よし！　もうひとふんばりだな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010111090001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「よかった……どうやらこの次元では……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090111090002" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うわぁっ！　なんだ、いまのは！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「くっ！　敵の反撃か！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010111090002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「でも、レーザーの飛んできた方角が違うよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_020111090002" ]},
		{"command":[ "SETCHARA", "0", "char_00001302_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「レーザーが飛んできたのは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010111090001" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「――っ！　みんな！　あれ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010111090002" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「え？　あ！　いやぁああん！　なにあれっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010111090002" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「くそっ！　新手のロボット軍団じゃねえか！　どっから現れやがった！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「ロボットだけじゃないよ！　空見て！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_020111090003" ]},
		{"command":[ "SETCHARA", "0", "char_00001302_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「なんだいあれは……円盤？　いや、女の子……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010111090003" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "円盤少女" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_010111090001" ]},
		{"command":[ "SETCHARA", "0", "char_00016201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090111090003" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あいつ、ルナパレスを攻撃しているぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010111090003" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「くっそぉ、なんてこった！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あのままじゃ、ルナパレスがやられちまうよ！　どうする！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010111090004" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「しかたねえ！　姫様！　４人つれてあっちの応援に――」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「その必要はないぞ！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "7", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_007_010111090001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「陛下！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「こちらのことは心配いらん。余に任せよ。自動迎撃システムもあるしの。お\nぬしたちは、脱出船団の防衛に専念せよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010111090002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ですが、このままじゃ――」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「余をなめるでないぞ！　謎の円盤娘と鉄板人形ごとき、余ひとりで片付けて\nみせるわ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010111090003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「母上様おひとり？　護衛の者たちはどうしたのです！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010111090004" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「城内の全員を退避させた。だから言うたじゃろうが！　余と迎撃システムだ\nけで大丈夫じゃと！　そういうことで、そちらは頼んだぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010111090004" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ルナパレスの中は、女王だけ……？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「大丈夫なの？　本当に……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010111090003" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「くそっ！　向こうのことばかり心配してられねえ！　船を守るんだ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「そうだな……！　こちらのロボットどもを片付けるのが先だ。そうすれば、\nルナパレスを救援に行ける！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090111090004" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「よし……！　やるぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010111090005" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0002" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "PLAYBGM", "BGM_005" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ふん！　たったひとりで宮殿内に乗り込んでくるとは、いい度胸じゃの！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010111090005" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者リーダー" ]},
		{"command":[ "SETTEXT", "「失われた名誉を取り戻す、唯一のチャンスだからな。女王ルナルバース！　\nこの命に代えても、貴様を仕留める！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010111090001" ]},
		{"command":[ "SETCHARA", "0", "char_00090101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「でかい口を叩くわりには、腕のほうがついてきとらんようじゃな？　余ひと\nりに、なにを手間取っておる？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010111090006" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者リーダー" ]},
		{"command":[ "SETTEXT", "「ふん。へらず口を叩いていられるのも今のうちだ。そろそろ――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010111090002" ]},
		{"command":[ "SETCHARA", "0", "char_00090101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「そろそろなんじゃと――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010111090007" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「くっ！　外からの攻撃じゃと！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010111090008" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者リーダー" ]},
		{"command":[ "SETTEXT", "「ふふふふふふ！　はははははははは！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010111090003" ]},
		{"command":[ "SETCHARA", "0", "char_00090101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「うぁああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010111090009" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「くぅうう……っ！　おい！　ロボットたちに、ルナパレスを攻撃させたのか\n！？　正気か！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010111090010" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者リーダー" ]},
		{"command":[ "SETTEXT", "「当たり前だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010111090004" ]},
		{"command":[ "SETCHARA", "0", "char_00090101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ここが吹き飛ぶようなことがあれば、おぬしも巻き込まれるんじゃぞ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010111090011" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者リーダー" ]},
		{"command":[ "SETTEXT", "「言っただろう！　命に代えても貴様を仕留めると！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010111090005" ]},
		{"command":[ "SETCHARA", "0", "char_00090101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「……そうかそうか、大した根性じゃ。さっきの攻撃の激しさからすると、か\nなりの数のロボットを、この周りに差し向けたようじゃな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010111090012" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者リーダー" ]},
		{"command":[ "SETTEXT", "「ああ。新任指揮官どのは、しびれを切らしているようでなぁ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010111090006" ]},
		{"command":[ "SETCHARA", "0", "char_00090101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「そうかそうか……そんなに戦力をこちらに集めたか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010111090013" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ずっぽし罠にハマってくれたようじゃなあ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010111090014" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者リーダー" ]},
		{"command":[ "SETTEXT", "「……なに？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010111090007" ]},
		{"command":[ "SETCHARA", "0", "char_00090101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「そろそろ、こっちも本気でやらせてもらうかの。それこそ『命に代えて』っ\nてヤツでな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010111090015" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者リーダー" ]},
		{"command":[ "SETTEXT", "「なんだ？　それは――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010111090008" ]},
		{"command":[ "SETCHARA", "0", "char_00090101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「なあに、呼び出しボタンじゃよ。ちょっとばかり、余計な機能もついとるが\nの。こいつを３回押すと――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010111090016" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者リーダー" ]},
		{"command":[ "SETTEXT", "「まさか！　自爆スイッチ――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010111090009" ]},
		{"command":[ "SETCHARA", "0", "char_00090101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「体を張っとるのはおぬしだけじゃなかった、ということじゃよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010111090017" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0112" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "PLAYBGM", "BGM_012" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "カツマ" ]},
