{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「隊長ちゃ～ん？　来たわよ。どうしたの、わざわざ呼び出したりなんかして\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0103101" ]},
		{"command":[ "SETCHARA", "0", "char_00018701_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「え？　ママにご奉仕してほしい？　ん、急にそんなこと言われても、心の準\n備が……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0103102" ]},
		{"command":[ "SETCHARA", "0", "char_00018701_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「いえ、隊長ちゃんはいつも頑張ってるものね。いいわ、ママ頑張っちゃう。\n任せて！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0103103" ]},
		{"command":[ "SETCHARA", "0", "char_00018701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「それじゃあ早速……え、胸と口でしてほしい？　うふふ、分かったわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0103104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「隊長ちゃん、いつも私の胸見てるものね。いいわよ、このおっぱいとお口で\n、隊長ちゃんをたっぷり癒やしてあげる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0103105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「それじゃあ、やるわね。ん……しょっ。あ……隊長ちゃんのおちんちん、大\nきい……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0103106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00018701_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「まずはおっぱいで……ふふ、熱くなってるわね。期待していたのかしら？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0103107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「んんっ、ふっ、あんっ、隊長ちゃんのおちんちん、硬くなってきた……んん\nっ、うっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「んふうっ、んっ、凄い……おっぱいだけでこんなに大きくなって、隊長ちゃ\nん、気持ちいいのね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「ふあ、匂いも凄い……隊長ちゃんの興奮が伝わってくるみたい……ふああっ\n、あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「え、もっと強く？　分かったわ。こう……？　んっ、ふっ、あっ、これ、お\nちんちんの形が凄く……んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0103111" ]},
		{"command":[ "SETIMAGE", "0", "still_00018701_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「ふうっ、うっ、隊長ちゃん、凄く気持ちよさそうな顔してるわ……ママも嬉\nしくなっちゃう。ふっ、んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「んん、隊長ちゃんの顔、言わなくても分かるわ。そろそろお口でもしてほし\nいんでしょう？　ふふ、じゃあ、あー……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「ちゅっ、れるっ、れろっ、んっ、ふうっ、これが隊長ちゃんの味……んっ、\nおいし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0103114" ]},
		{"command":[ "SETIMAGE", "0", "still_00018701_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「んぐっ、うっ、んんっ！！　お口の中で、さっきよりも大きくなって……ん\nむっ、んうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0103115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「隊長ちゃんのおちんちん、逞しくて、硬くて、凄い……おっぱいとお口だけ\nで、私も気持ちよくなってきたわ……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「もっと言ってほしい？　ふふ、いいわよ。隊長ちゃんのおちんちん、熱くて\n、血管が浮いてて、先端の筋がぱくぱくしてて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「れるっ、んっ、先走りがとろとろ出てて、今にもはちきれそう。それだけ、\n私のおっぱいとお口が気持ちいいのね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「ね、ね、お口とおっぱい、どっちが気持ちいい？　え？　どっちも気持ちい\nいって？　やん、隊長ちゃんたら、褒め上手ね、うふふ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「んふふ、なら、お言葉に応えてもっといっぱいご奉仕してあげるわね。んむ\nっ、りゅっ、れるっ、ちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0103120" ]},
		{"command":[ "SETIMAGE", "0", "still_00018701_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「んむっ、れるっ、ちゅっ、ふふ、隊長ちゃんの顔、気持ちよさそう。じゃあ\n、こういうのはどう？　おっぱいサンドイッチよ。ぎゅう～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「んんっ！！　ママのおっぱいの中で、隊長ちゃんのおちんちんがびくびく跳\nねてるわ。ふふ、おっぱいオマンコ、気持ちいいのね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「ぎゅっ、ぎゅっ、ぎゅう～！！　からの、こね、こね、こね。ふふ、おっぱ\nいがおちんちんに吸い付いて動いて、いいでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0103123" ]},
		{"command":[ "SETIMAGE", "0", "still_00018701_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「まだ終わらないわよ。ここから、あー……んんっ、ほら、唾液のローション\nつきよ、んっ、んんっ、あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「ぬるぬる、ぎゅっ、こねこね。ふふ、隊長ちゃんの腰が震えてる。そんなに\n気持ちいいのね。じゃあ、もっとしてあげる。んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「ほら、隊長ちゃんのおちんちんと私のおっぱい、いやらしい音をたててるわ\n。聞こえるでしょう？　耳からも気持ちよくなりましょうね……ふふふ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「んん、おっぱいでこねながらお口でもしてほしい？　ふふ、いいわよ。隊長\nちゃんのおちんちんは大きいから、こうして深く挟めば……んっ、先端が出て\nきたわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0103127" ]},
		{"command":[ "SETIMAGE", "0", "still_00018701_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「それじゃあ、あむっ、んっ、んんっ、んっ、おっぱいで締め付けて、お口で\n吸い付いて、隊長ちゃんのおちんちんが凄く熱く硬くなってきているのが分か\nるわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「んっ、んぐっ、んっ、ふっ、ママのおっぱいとお口、気持ちいいのね、おち\nんちんがびくびくしてるわ。隊長ちゃん、いいのよ。いつでも好きなときにイ\nっていいのよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「んっ、んぶっ、んっ、んぐっ、ああ、おっぱいがやけどしそう。イくのね、\n隊長ちゃん、イくのね、んっ、んんんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「きゃっ！？　ふあ、あっ、ああああっ、おちんちんから、凄い、ああっ、ん\nんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0103131" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018701_01_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「んっ、んんっ、口にも……ふうっ、あっ、すごい勢いと匂い……これが射精\n……んっ、くっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「味も濃い……隊長ちゃんの精液……んんっ、なんか、頭がぽうっとする……\nでも、おいし……んくっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「ふあっ、あっ、隊長ちゃん、気持ちよかった？　ん、なら、私も嬉しいわ…\n…あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0103134" ]},
		{"command":[ "SETIMAGE", "0", "still_00018701_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「ほら、隊長ちゃんの精液と私の唾液が混じって、ぐちゅぐちゅって音がして\nるわ……もったいないから、舐めとるわね、んっ、じゅるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0103135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「んぐっ、くっ、ふふっ、凄い味。でも隊長ちゃんのだと思うと、好きになれ\nそう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0103136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「良かったわ、隊長ちゃんが満足できて。ママのお口とおっぱいで奉仕、悦ん\nでくれた？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0103137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「ふふ、いいお返事。気にってくれたなら私も嬉しいわ。頑張った甲斐があっ\nたもの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「ん、隊長ちゃんのおちんちん、汚れちゃったわね。きれいにしてあげる。れ\nるっ、ちゅっ、んっ、むっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0103139" ]},
		{"command":[ "SETIMAGE", "0", "still_00018701_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「れろっ、んっ、くっ、んむっ、れるっ……はい、きれいになったわ。ふふ、\nごちそうさま」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「へ？　え？　出したばかりなのにまた大きくなって……え、もう一回してほ\nしい？　ん……分かったわ。隊長ちゃんのおちんちん、苦しそうだし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0103201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「凄い……唾液と精液でぬらぬらして……硬さも大きさもそのままで……そん\nなに期待していたの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「私のお口とおっぱいがそんなに気持ちよかったって？　うふふ、嬉しいわ。\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0103203" ]},
		{"command":[ "SETIMAGE", "0", "still_00018701_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「じゃあ、もう一回。ほら、おっぱいでぎゅっ……こねこね……からの、お口\nであー……むっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0103204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「んぶっ、うっ、じゅる、ちゅっ、んふ、もうお汁がとろとろ溢れてきてるわ\n……濃厚な味、おいし……んくっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「ふふ、そんなに腰を動かしておねだりしなくても、ちゃんとやってあげるか\nら。ほら、お口でも、んむっ……ちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「隊長ちゃん、お口で吸いながら挟まれるの好きよね。反応で分かるわ。んん\nっ、むっ、れるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0103207" ]},
		{"command":[ "SETIMAGE", "0", "still_00018701_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「ふっ、うっ、あっ、深く挟んでるから、私の鼓動が隊長ちゃんのおちんちん\nに響いてるのが分かる？　そうね、隊長ちゃんが好きだからこんなに激しくな\nってるのよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「ふうっ、うっ、んむっ、ぐっ、お口の中で反り返って、びきびきして、また\n出したくなってるのね。でもまだ、もうちょっと我慢、我慢よ隊長ちゃん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「あんっ、あっ、んんっ、おっぱいのなかで、おちんちんがぐつぐつに煮え立\nっているのが分かるわ。でももうちょっと頑張って隊長ちゃん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0103210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「気持ちいいの、貯めて、貯めて、貯めて、貯めきって、それをママにちょう\nだい。隊長ちゃんなら、できるわよね？　あむっ、んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「んぶっ、んっ、んぐっ、ふふ、我慢してくれてるのね、隊長ちゃん。嬉しい\nわ。好き、好きよ。んくっ、んうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「ああ……熱い、隊長ちゃんのおちんちんで、おっぱいがやけどしちゃう……\n口の中もいっぱいで、ふううっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「んくっ、んっ、もう、先走りのお汁にも隊長ちゃんの匂いと味がついてるわ\n……ふうっ、んぐっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0103214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「エッチな顔をしてるって？　そうね、隊長ちゃんがそうさせてるのよ。こん\nな立派なおちんちんに奉仕したら、誰でもこんな顔になっちゃうわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0103215" ]},
		{"command":[ "SETIMAGE", "0", "still_00018701_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「ふふ、それよりも……もう隊長ちゃんも限界みたいね。おっぱいの中で、何\n回も暴れているのが分かるわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0103216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「先端もぱくぱく開いて、射精したがってる。私のために、いっぱい我慢して\nくれて嬉しいわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「いいわ。今まで貯めたもの、全部出していいわ。ママに向かって、隊長ちゃ\nんをいっぱい出して！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0103218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「んっ、んんっ、出して！！　ママに全部、隊長ちゃんの全部出して！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「隊長ちゃん、隊長ちゃん、もう我慢せず、イっていいのよ！！　隊長ちゃん\n！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「んんっ、あっ、あふうっ、んんんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0103301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018701_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「あうっ、凄い……二回目なのに、一回目と同じぐらい勢いが強くて……匂い\nも……んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「んくっ、んっ、味も濃い……隊長ちゃん、気持ちよかったのね……ふふ、あ\nんっ、あっ、まだ出てる……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0103303" ]},
		{"command":[ "SETIMAGE", "0", "still_00018701_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「んはぁっ、あっ、あうっ……おっぱいも、お口も、隊長ちゃんのでどろどろ\nになっちゃたわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0103304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「れろ……ぺろ……じゅるっ、んっ、んくっ、隊長ちゃんの精液、おいしい…\n…んんっ、くっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0103305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「ん……ふっ、ごちそうさまでした。全部飲んだのかって？　だって、隊長ち\nゃんの出してくれたものだもの。残したらもったいないでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0103306" ]},
		{"command":[ "SETIMAGE", "0", "still_00018701_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「味も匂いも濃くて……どろっどろだったからまだ喉に残ってる感じがするわ\n……うふふ、私のお腹も嬉しくてきゅんきゅん言ってる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0103307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「もしもこれを中に出されたら……隊長ちゃんの子供ができちゃうわね。うふ\nふふふ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0103308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「なあに？　子供、ほしいの？　私もほしいわ。でも今日はおあずけ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「隊長ちゃんと子作りするときは、中に全部出してもらわなきゃ……ね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「きゃん！？　隊長ちゃん、いきなりおちんちんを抜いてどうしたの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0103401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018701_01_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「ふあっ、あああっ、私の顔に……んんっ、精液、いっぱい飛んで……あうっ、\nんんっ、ああああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「あんっ、熱い……匂いも……ふうっ、うっ、隊長ちゃんの気持ちよさが全部\n、私の顔に吐き出されてるのね……んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0103403" ]},
		{"command":[ "SETIMAGE", "0", "still_00018701_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「凄い……顔中どろどろで、目も開けられない……んんっ、あっ、唇に……ん\nんっ、んくっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0103404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「垂れてきたのを舌ですくい取ってほしいって……？　変なことばかりお願い\nしてくるのね。いいわよ、れろっ、れるっ、んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0103405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「味も凄いわね……んっ、くっ、飲み込んだら、匂いが鼻に抜けてくるわ……\nんっ、れるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0103406" ]},
		{"command":[ "SETIMAGE", "0", "still_00018701_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「身体の中まで隊長ちゃんの匂いにされた感じだわ……うふふ、私は全部隊長\nちゃんのものなのね、嬉しい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0103407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「やんっ、またおちんちんから出てきたわ。最後の一滴まで顔にかけたいのね\n。ふふ、欲張りさん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0103408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「私の顔を精液で汚したかったって？　マーキングかしら。そんなことしなく\nても、私は隊長ちゃん以外にこんなことしませんからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0103409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「うふふ、でもその独占欲は嬉しいわ。ね、隊長ちゃん、また疲れたら私が奉\n仕してあげますからね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0103410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}