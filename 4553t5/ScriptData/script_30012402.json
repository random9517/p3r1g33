		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁ……気持ちいい……お腹……いっぱいに……精液……チンポミルク……\n溜まって、溢れて来るぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2404302" ]},
