		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「本当にいっぱい出してくれたな……ありがとう……やっと身体も落ち着いた\nと思う……んっ……ふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2404307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
