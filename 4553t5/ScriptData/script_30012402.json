		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁぁ……んっ、すごい勢いだ……おっぱい……お腹に……ちゅぷっ、んっ\n……顔にまで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2404402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ、んふぅっ、あぁ……まだ濃い……トロトロザーメン……れる……\nちゅぷっ、味もいい……れろ、んちゅぷぅ……」", "NORMAL" ]},
