{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0150" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はああああああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010113110001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「くっ……！　なかなかの太刀筋……！　できる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113110001" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あたりまえだ！　私は、やればできる子なんだああああーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010113110002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ルナテミス様……どうしてこれが普段からできないんですかっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113110001" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "と、無駄に熱いバトルを繰り広げている連中をよそに――", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「ふあぁああ～……夜中に私らを叩き起こしといて、なにやってんだかなぁ…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010113110001" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ルナさま、ほんとめんどくさいわよね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010113110001" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「うちの姉も、ご迷惑をおかけしてます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010113110001" ]},
		{"command":[ "SETCHARA", "0", "char_00001701_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まあ、気が済むまでやらせとくしかねえんだろうなぁ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "俺たちは完全に観戦モードだったが、突然、そこに現れたのは――", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ジュンジロー" ]},
		{"command":[ "SETTEXT", "「警告！　警告！　危険！　危険！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_040113110001" ]},
		{"command":[ "SETCHARA", "0", "char_00000904_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お？　メカじゃねえか。どうした」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ジュンジロー" ]},
		{"command":[ "SETTEXT", "「学生寮付近に、襲来者（インベーダー）出現！　現在、バッケンローダーら\nが応戦中！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_040113110002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんだって！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「学生寮に！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113110002" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "知らせを聞きつけた修羅姫も戦いを一時中断し、こちらに注意を向ける。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ジュンジロー" ]},
		{"command":[ "SETTEXT", "「敵は、続々と戦力を増強している模様。ただちに対応されたし！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_040113110003" ]},
		{"command":[ "SETCHARA", "0", "char_00000904_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「このままでは学生たちが……！　ルナテミス！　勝負はあずけた！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113110003" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「な、なに！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010113110003" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「襲来者（インベーダー）を片付けたら、いくらでも相手をしてやる！　いく\nぞ、夜叉！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113110004" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「はいっ！　それでは皆さん、失礼します！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010113110002" ]},
		{"command":[ "SETCHARA", "0", "char_00001701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "修羅姫と夜叉は、学生寮のほうへと走っていく。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「こうしちゃいられないね！　あたしたちも行くよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113110002" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「わかった！　急ごう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010113110001" ]},
		{"command":[ "SETCHARA", "0", "char_00001205_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そして、Ｇ・ルナリアムの連中も、二人を追って次々と学生寮へ向かうが……\n。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「お、おい……？　おまえたち……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010113110004" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ルナテミスは、さっきまでのテンションの行き場を見失ってしまったのか、戸\n惑った様子でその場に立ち尽くしている。しょうがねえなあ……。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「姫様！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ん！？　な、なんだ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010113110005" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「俺たちも行きましょう。さっきの勢いで、襲来者（インベーダー）をぶちの\nめしちゃってくださいよ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「お、おう！　そうだな！　行くぞ下僕！　私についてこいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010113110006" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ルナテミスはそう言って、満面に笑みを浮かべると走り出した。やれやれ、い\nつものことながら、世話の焼ける姫様だ……。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYBGM", "BGM_007" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0151" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あー、もう！　襲来者（インベーダー）ちゃん、なんでこんなに大勢で来る\nのよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010113110002" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「ちょっと疲れてきました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010113110003" ]},
		{"command":[ "SETCHARA", "0", "char_00001701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「ん……？　あれは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010113110001" ]},
		{"command":[ "SETCHARA", "0", "char_00001801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「うおおおおおおおー！　襲来者（インベーダー）ども！　私が相手だぁああ\nあああーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010113110007" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「ルナテミスか……面白い！　どちらが多く襲来者（インベーダー）を倒せる\nか、勝負と行こう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113110005" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「勝負はいいけど、また話をこじらせないでね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010113110004" ]},
		{"command":[ "SETCHARA", "0", "char_00001701_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}