		{"command":[ "SETIMAGE", "0", "still_00000113_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あぉぉっ……おっ、くぉぉぉんっ！　はっ、あぁっ……オチンポも震えてっ\n……また、出したがってるの……分かりますっ……！」", "NORMAL" ]},
