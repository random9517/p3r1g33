		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……あっ、んっ……あん……は……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1304101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「この格好……やっぱり、恥ずかしい……です……こんなに大きく足を開いて\nしまうなんて……はしたない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1304102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「それに、身体の方も……んっ、乳首……くにくにされて……硬く……なって\nしまってますぅ……は、んふぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1304103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「んっ、確かに……最初に準備しておくことは大切です……お互いの気持ちを\n高めあっておきたいですが……ひゃ、んふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1304104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「でもっ……あっ、あぁっ……こんな、立派なオチンポを前に、ずっとお預け\nされてるの……辛い、です……はっ、んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1304105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「今日の為に、ずっと開発されて……もう私のオ、オマンコは……完全にその\n気になってしまってます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1304106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「後は、もう……ずぶって……一番奥まで……ハ、ハメて頂くのを待つばかり\nなのに……あぁっ、おっぱい……そんなにされたらっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1304107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「んっ、ちゃんとセックスする前から……イッちゃうのはダメです……だから\n、焦らさないで……します、おねだりちゃんとしますから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1304108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「お願いします……貴方の、太くて硬い……逞しいオチンポを……涎を垂らし\nて……欲しがってる、ス、スケベなオマンコにハメて下さい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1304109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「もう、こんなにヌルヌルが溢れて……切なくて、堪らないんです……どうか\n、あぁ……オチンポぉ……そこ、そのまま……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1304110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あぁっ……はい、そこです……ぶすって……突き刺してっ、ヌルヌルの割れ\n目ぇっ……こじ開けてぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1304111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「んぁっ……あっ、あぁぁぁぁぁーっ！　来ましたっ……あっ、オチンポッ、\n入って来ますっ……あぉぉっ、オチンポッ、深いぃんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1304112" ]},
		{"command":[ "SETIMAGE", "0", "still_00000113_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あぁっ……あっという間に……奥に……全部、入っちゃいました……あぁ、\n広がってくぅ……オマンコ、こじ開けられてますぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1304113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「みっちり……熱いのが、んくぅ……凄い……これが貴方のオチンポ……！　\nあぁ……道具なんかと……全然違うっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1304114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「ま、待って下さいね……今日は、頑張ってオマンコでご奉仕しますから……\nゆ、ゆっくりですけど……動かしてみます……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1304115" ]},
		{"command":[ "SETIMAGE", "0", "still_00000113_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あんっ、ふっ、あっ、はっ、こうして……あっ、腰を……くねくね回す感じ\nで……ど、どうでしょうか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1304116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「んっ……気持ち、いいですか……？　よかった……あぁ……でも、これ、恥\nずかしい……こんなポーズで、大胆に動くなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1304117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「そ、そんなに……繋がってる所……見ないで下さい……オマンコがいやらし\nくオチンポを咥えてる所……恥ずかしい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1304118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……あんっ、はんっ……あぁっ、ぐちゅぐちゅって……音がしま\nす……全部、私の出したお汁の音ぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1304119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「うんっ、あっ、くふっ……んんっ……奥を……こつんって小突いてくるのが\n分かります……オチンポの先端が気持ちいい所に当たってます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1304120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「円を描いた後は……上下に動いてみます……ね？　んっ、あんっ、あふっ、\nんくんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1304121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「腰を持ち上げて……また、落としてぇ……はんっ、あんっ、あっ、あぁっ、\nはぁうんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1304122" ]},
		{"command":[ "SETIMAGE", "0", "still_00000113_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あぁ……お腹の中で……すごい存在感です……オチンポの感触が……全身に\n広がって……肌がピリピリしていきます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1304123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「ひゃ……ふっ……あんっ、また……そんなにおっぱい触って……本当にお好\nきなんですね……おっぱい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1304124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「でも……こうして、しながら……触ってもらえると……一緒に気持ちを一つ\nにしていく感じがして……好き、です……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1304125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あんっ……やだ……尖ってる所……そんなにつまんじゃ……あっ、ちゃんと\n動けなくなりますからぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1304126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「んっ……んふんっ、太もも、あっ……わき腹も……弱いです……あんっ、ど\nこも感じすぎて……はぁんっ……あっっ、変になりそうです……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1304127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「はぁっ、んぁっ……私も負けてられません……もうちょっと……速くして、\nみます……あっ、あんっ、はっ、うんっ、あっ、ふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1304128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「はい……大分、慣れてっ……あんっ、動きやすくなって……来ましたっ……\nあっ、あぉっ、あっ、ひぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1304129" ]},
		{"command":[ "SETIMAGE", "0", "still_00000113_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「で、でもっ……やっぱり、このっ……ずりゅって……オマンコが広げられる\n感じはっ……慣れない……ですっ、んひっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1304130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「んっ、オチンポがっ……あぁっ、ぐりぐりっ……来るぅっ……慣れてない筈\nなのにっ……開発されたからだっ……悦んじゃってますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1304131" ]},
		{"command":[ "SETIMAGE", "0", "still_00000113_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あぁっ、はいっ、オマンコいいっ……オマンコいいですっ、オチンポとくっ\nつきあうのっ、好きですっ、はひぁっ、好きぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1304132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「くぅんっ、もっとかき回してっ……あぁっ、止まらないっ、大好きな人とと\nのセックスっ、気持ちいいですぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1304133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「んぁっ、下から……突かれてっ！　あひっ、で、出そうだからっ？　はひぁ\nっ、はいっ、大丈夫ですっ……中に、下さいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1304134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「わらひもっ、気持ちいいのイキますからっ……貴方もっ、オマンコの中でっ\n……びゅびゅって！　熱いのっ……出しちゃって下さいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1304135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あぁっ、ズンズンされるぅっ、イクッ、んひぃっ、わらひもっ、オマンコ感\nじるっ……イッ、イキますぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1304136" ]},
		{"command":[ "SETIMAGE", "0", "still_00000113_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「んぁぁぁぁぁぁーーーーーっ！　出てっ……ますかっ？　なかっ……あひっ\n、んぁぁぁぁっぁあんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1304137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000113_02_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「はぁぁ……やらっ、漏れひゃうっ……あぁっ、わらひ……おしっこ……ぁ…\n…ぁぁぅ……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1304138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「違う……？　これは潮吹き……わ、分からないです……どっちでも……いい\nの……よすぎてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1304139" ]},
		{"command":[ "SETIMAGE", "0", "still_00000113_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……お、終わった……？　あふぅ……セックス……すごかった\n……ですぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1304140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「んっ……く……んんっ……あっ、まだ、終わりじゃない……？　今までは…\n…ウォーミング、アップ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1304201" ]},
		{"command":[ "SETIMAGE", "0", "still_00000113_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あ……確かに、続けてすることもあると……聞き及びました……こ、これか\nらが本番なのですね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1304202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「は、はい、私なら大丈夫です。貴方にご満足頂ける為に、頑張ると……決め\nていましたから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1304203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「では……改めて……腰を回していきますね……んふっ、ひゃ……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1304204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あ……こ、これ……まだ、さっきの余韻が強くて……かなり、敏感になっち\nゃってます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1304205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「中に……精液がぐちゅって入ってるから……あふっ、音もすごくて……やだ\n、火照ってる……汗が滲んで来ちゃいます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1304206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「んっ、うんっ！　いえっ……頑張ります……この快感の中でご奉仕するのが\n、私のお務めですからっ……は、んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1304207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「うんっ、あふっ……はっ、んんっ……あぁ……でも、これぇ……すぐ……我\n慢……出来なくなって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1304208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あっ……はっ、あっ、あふんっ……あぁっ……ダメ……また、あっ……すぐ\nにっ、気持ちいいのっ……上がって来てっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1304209" ]},
		{"command":[ "SETIMAGE", "0", "still_00000113_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「くっ……んくぅんっ！　イッ……くぅぅぅぅんっ……！　あっ……ぉぉぉぉ\nぉっ……は……ぉぉぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1304210" ]},
		{"command":[ "SETIMAGE", "0", "still_00000113_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あふぁっ……申し訳、ありません……感じやすくなって……イ、イク感覚が\n続けて来てしまって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1304211" ]},
		{"command":[ "SETIMAGE", "0", "still_00000113_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「その、なるべく休まないように続けますから……んっ、お許し下さい……あ\nっ、んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1304212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「そんな……あっ、貴方の方から腰を……っ、私のお務めですのにっ……ひゃ\n……ひっ、んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1304213" ]},
		{"command":[ "SETIMAGE", "0", "still_00000113_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「このまま……一緒に……気持ちよく……それはっ、はいっ……あっ、でもっ\n……オチンポっ……止まらないのっ、あ、あぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1304214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あぁっ……くぅぅんっ、ずっと……ジンジンしてっ……んんんっ、おかしく\n……なってるっ……ダメっ……気持ちよすぎますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1304215" ]},
		{"command":[ "SETIMAGE", "0", "still_00000113_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あんっ、はぁんっ、オマンコすごいっ……さっきは……夢中で分かりません\nでしたけどっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1304216" ]},
		{"command":[ "SETIMAGE", "0", "still_00000113_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「中で……ビクビクしてる感じが内側から伝わって……あぁっ……奥に当たる\n度に……またお汁が出ちゃう……んぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1304217" ]},
		{"command":[ "SETIMAGE", "0", "still_00000113_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「はっ、んんっ、あぁっ……またイッちゃった……あっ、ダメ……イッてる途\n中なのに……グリグリされてるっ……ぎもぢっ……いひぃっ！」", "NORMAL" ]},
