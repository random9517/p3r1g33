{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「うむ、来たか。まずまずの早さだな。褒めてやろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1804101" ]},
		{"command":[ "SETCHARA", "0", "char_00000318_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「呼び出した理由じゃと？　ふん、それ位は当然察しがついておるのではない\nか？　ちょうど身体がそういう気分になったということじゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1804102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「無論、否やはないな？　お主は余の下僕であるし、逆らう理由もない筈。と\nいう訳で、勝手に使わせてもらうまでよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1804103" ]},
		{"command":[ "SETCHARA", "0", "char_00000318_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「さあ、分かったらそこに寝ろ。まあ、悪いようにはせぬ。お主に、極上の快\n楽をもたらしてやるからな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1804104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「どれ……ほほう、これは何もせずとも、しっかりとチ〇ポを勃起させている\nではないか。余のオマ〇コを楽しみにしていたのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1804105" ]},
		{"command":[ "SETIMAGE", "0", "still_00000318_02_01" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「余計な手間が省けてよい。とは言え……まずは軽く様子を見ておくか？　ふ\nふ……マン筋とチ〇ポを軽く擦ってやろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1804106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……おうおう、もうピクンと先端が震えておる。濡れた奥に入り\nたくて堪らないといった雰囲気じゃな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1804107" ]},
		{"command":[ "SETIMAGE", "0", "still_00000318_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「どうじゃ、ハメたいか？　余のオマ〇コは、十分に準備を備えておる。お主\nは、この中を味わいたいと思うか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1804108" ]},
		{"command":[ "SETIMAGE", "0", "still_00000318_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「くく……口より先にチ〇ポが何度も頷いて来るか。よかろう、正直なチ〇ポ\nに免じて、たっぷりと味わわせてやる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1804109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んっ、むっ……んふぅぅぅぅっ……ほぉら……どうじゃ……根元までずっぽ\nりとチ〇ポを咥えこんでいくぞ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1804110" ]},
		{"command":[ "SETIMAGE", "0", "still_00000318_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んふぅ……いきなり射精するでないぞ？　しっかり腰に力を入れて、余のオ\nマ〇コ肉を味わうがいい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1804111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「はっ、んんっ、どうじゃ……チ〇ポ全体がオマ〇コに包み込まれて……ねっ\nとりと絡みつく感じがいいじゃろう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1804112" ]},
		{"command":[ "SETIMAGE", "0", "still_00000318_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ゆっくり動かしてやるからな……ずるりとチ〇ポを抜き出して……はぁぁっ\n、んっ、肉襞によく引っかかりよるわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1804113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「そのまま、もう一度……腰を落として……またチ〇ポを咥え直すっ……んふ\nっ、余計なことは一切せずに、上下だけで感じさせてやる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1804114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ふふ……気持ちいいか？　それは結構……身も心も全て委ねて、余の言うこ\nとだけを聞いておればよい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1804115" ]},
		{"command":[ "SETIMAGE", "0", "still_00000318_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「まだまだ、もっとチ〇ポを蕩けさせてやるからな……ふんっ、んふっ、はぁ\nっ、んくっ、は、うんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1804116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ふふ……そうじゃ……うっとりした顔を見せるがいい。余のオマ〇コを味わ\nっておるのじゃからな……当然の反応じゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1804117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「お主の大好きなおっぱいも、存分に揺らして見せてやろう……んっ、んふん\nっ……こうして乳首が踊る様が好きなんじゃろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1804118" ]},
		{"command":[ "SETIMAGE", "0", "still_00000318_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「今日は特別に気分がいい……余の身体を隅々まで見ることも許すぞ。チ〇ポ\nだけは、簡単に出さぬよう気を張っていろ……よいな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1804119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「いい返事じゃ。さあ、もっとかき回してやる……チ〇ポを包み込んで……中\nで好きなだけ泳がせてやるぞ……んふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1804120" ]},
		{"command":[ "SETIMAGE", "0", "still_00000318_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ふふ……硬さが増しておるな……余のオマ〇コをもっと味わいたいという気\n持ちがチ〇ポに現れておるということか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1804121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ならば、この締め付けはどうじゃ……んんっ！　くふぅ……チ〇ポをギュッ\nと吸い付けて……特に根元に絡ませる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1804122" ]},
		{"command":[ "SETIMAGE", "0", "still_00000318_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ふんっ……んふんっ……！　こうして……余が息む度に……チ〇ポも、ビク\nビクと震えておる……あぁ……いい具合に擦れて来る……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1804123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「はっ、ふっ……ちょうどいい硬さのモノが暴れると、奥からどんどん新たな\n汁が湧いてくるな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1804124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んふ……見ろ……繋がった場所から、ポタポタと淫汁が溢れて止まらぬ。は\nぁぉ……それがまた滑りをよくさせていく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1804125" ]},
		{"command":[ "SETIMAGE", "0", "still_00000318_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「はふっ、んふっ……くふぅっ……奥にコツンと当たる感触が堪らぬな……も\nっと大きく上下させてみるか……んっ、くぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1804126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「おぉっ……！　んくぅぅっ……ふっ……！　あぁ……いいチ〇ポじゃ……気\n持ちいいところがどんどん増えていくぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1804127" ]},
		{"command":[ "SETIMAGE", "0", "still_00000318_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ふっ、はっ、んくっ、あぁっ……ズボズボと……いい音が響きおる……ふふ\n……汁がかき回される下卑た音じゃ……興奮を掻き立てるのう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1804128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「このくぱっと広がったオマ〇コの隙間がさせるのか……んっ、もっとみっち\nりと埋め込まなくてはダメじゃな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1804129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んくぅ……腰を落として……はぁぁぅっ……んんっ、あぁ……中の肉が広げ\nられる感触じゃ……くぉぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1804130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ、どうした……そろそろ顔色が変わってきたか？　射精したくて\n仕方ない……そんな疼きが顔に出ておるぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1804131" ]},
		{"command":[ "SETIMAGE", "0", "still_00000318_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「後もう少しだけ頑張りたい……？　くくっ、いいぞ……そのやせ我慢を聞か\nされると、逆に射精させたくなるというものじゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1804132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「となれば、本気でさせてもらおうかのう。ほぉれ……チ〇ポ扱きのラストス\nパートじゃっ、ふっ、はっ、んむっ、おぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1804133" ]},
		{"command":[ "SETIMAGE", "0", "still_00000318_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「くっ、ふっ……！　いよいよじゃな……チ〇ポの震えが大きくなって……口\n元も緩んでおるぞっ、はふっ、んぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1804134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「さあ……観念して……チ〇ポ……出せっ！　余のオマ〇コに、そのまま中出\nししてしまえっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1804135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「あぉぉぉぉぉぉぉっ！　くうぅぅっ……出てきたっ……熱いザーメンが……\n子宮に迸っておるっ……んぅぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1804136" ]},
		{"command":[ "SETIMAGE", "0", "still_00000318_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「おぉっ……イグっ……イグゥっ！　くぅぅぅっ……オマ〇コ中出しでっ……\nほぉぉっ、余の全身が……アクメするぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1804137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「はぁぁぁっ……あぁぁぉ……くぅぅ……ドロリと熱いのがいっぱいじゃ……\nはぁぁう……余も一気にイカされたぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1804138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んふっ……ふふ……軽く使ってやる気分でおったが……こんなにも、燃える\nことになるとは思わなかったぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1804139" ]},
		{"command":[ "SETIMAGE", "0", "still_00000318_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「あふ……余の身体をここまで火照らせるとは……全く、お主のチ〇ポは本当\nに特別な力を持っているようじゃな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1804140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「さて……まだまだ、余のオマ〇コの中でチ〇ポはしっかりと硬いまま残って\nおるな。これは、続きを求めておるということじゃな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1804201" ]},
		{"command":[ "SETIMAGE", "0", "still_00000318_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「皆まで言わずともよい。余も、満足していない訳ではないが、もっとお主の\nチ〇ポを味わっていたいと思っていた」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1804202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「お主がよければ続きをしてもよいか？　これは、命令ではなく……余の願い\nじゃ。無理強いをするつもりは……んんっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1804203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ほぉ……なるほど、その力強い突き上げが答えか。んふ……面白い……今度\nはお主がリードして余を楽しませてみよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1804204" ]},
		{"command":[ "SETIMAGE", "0", "still_00000318_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んっ！　んむっ……無論、余もじっとはしておらんぞ……お主のチ〇ポをし\nっぽりと包み込んで、法悦を与えてやるからのう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1804205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んくっ、ふっ……まずは……ゆっくりと、さっき出されたザーメンを、オマ\n〇コに塗り込めていくか……こいつをじっくりと馴染ませたい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1804206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んんっ……！　くぅぅ……めり込んで、戻して……ふっ、はっ、んんっ……\nこれは、さっきよりもチ〇ポの形がよく分かるぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1804207" ]},
		{"command":[ "SETIMAGE", "0", "still_00000318_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「はぁ……んくっ、柔肉が広げられて……チ〇ポを咥えている所も丸見えじゃ\n……ふふ……生々しいじゃろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1804208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「余も、もっと腰を突き出して、繋がっている所を見せつけてやろう。くぅぅ\n……はっ、んふっ、あぁ……汁が掻き出されておる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1804209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「はっ、ふっ、あぁっ……んぁっ、いいぞ……下からチ〇ポがしっかりとオマ\n〇コの肉を貫いておる……く、んっ、んふっ、んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1804210" ]},
		{"command":[ "SETIMAGE", "0", "still_00000318_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「また、おっぱいをじっと見ておるな……よいぞ？　触りたいなら、好きなよ\nうに触ってみるがよい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1804211" ]},
		{"command":[ "SETIMAGE", "0", "still_00000318_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んくっ……ふふ、随分と遠慮がちではないか。もっと乳首を摘んだり、全体\nを揉みしだいてもいいんじゃぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1804212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「あふっ……！　そうじゃ……余も遠慮はせぬからな。お主のチ〇ポを貪り尽\nくすように……徹底的に搾り取ってやろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1804213" ]},
		{"command":[ "SETIMAGE", "0", "still_00000318_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ふんっ、んぐっ、んふんっ……！　どうじゃ……このピストンはっ、全身を\nくねらせてっ……チ〇ポを吸い上げてやるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1804214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「はふっ……んんっ、ふふ……また表情が変わったな？　マン肉のうねりが\n堪らんじゃろう？　ここからもっとじゃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1804215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ふんっ、んむっ、んくんっ……！　はぁぅっ、チ〇ポがまた子宮に届くっ！\n　んくぅっ……直接打ち付けて来ておるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1804216" ]},
		{"command":[ "SETIMAGE", "0", "still_00000318_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「はぁっ、んんっ、もうすぐじゃな……分かるぞっ、お主のイク瞬間のことは\n、もうオマ〇コで感じ取れるようになっておるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1804217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「余も……また、次のが近いっ……！　んくぅっ、このまま一気にイクまで…\n…あぉっ、チ〇ポっ、かき回し続けるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1804218" ]},
		{"command":[ "SETIMAGE", "0", "still_00000318_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「はぁっ、んぁっ、くふぁっ……！　さあ……出していいぞっ、余はいつでも\nよいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1804219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「お主の出したい時にっ……思い切り欲望を撒き散らすがよいっ。余も……イ\nクぞっ……おっ、ふっ、あぉぉぉぉぉぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1804220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んんんんんんんんっ！　あぉぉっ……また、奥をっ……打ち付けておるっ…\n…お主のザーメンが……届いて来るぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1804301" ]},
		{"command":[ "SETIMAGE", "0", "still_00000318_02_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んはぁぁっ……んっ、ぐっ……イクっ……！　くぅぅんっ、中出しザーメン\nでオマ〇コっ……またイカされるぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1804302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「あふっ……チ〇ポがビクビク脈打って、まだ……後から後から流れ込んでく\nるぞ……あぁ、もういっぱいだというのに止まらぬではないか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1804303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ふふっ、この遠慮のない中出し……どうやら、余を本気で孕ませようとして\nいるようじゃな……それでこそ、お主らしい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1804304" ]},
		{"command":[ "SETIMAGE", "0", "still_00000318_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んっ……終わったか……抜かずの２発……余の疼きを満たす、素晴らしい射\n精だったぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1804305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「全身を心地よい感触が巡っておる……やはりお主の中には底知れぬ力が眠っ\nているのかも知れぬな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1804306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んっ……ふっ……隙間から汁がまた垂れて来た……少し泡立っておる……ふ\nぁふ……余のマン汁と混ざって……得も言われぬにおいじゃな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1804307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ふぅ……まだチ〇ポがオマ〇コの中でヒクついておるわ。もしかして、まだ\n３発目も続けてしたいということか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1804308" ]},
		{"command":[ "SETIMAGE", "0", "still_00000318_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「もう当分出ない……？　ふふん、どうじゃろうな、いざしてみれば案外どう\nとでもなるものかも知れんぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1804309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「まぁよい。ひとまずは、休みも与えてやらんとな。風呂を使おう。その先の\nことは……また、そうなってからじゃ……な？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1804310" ]},
		{"command":[ "SETIMAGE", "0", "still_00000318_02_11" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「くぅぅぅぅぅんっ！　あぁっ、チ〇ポ……抜けてっ……はぁぅっ……んっ、\nザーメン……身体にっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1804401" ]},
		{"command":[ "SETIMAGE", "0", "still_00000318_02_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「偶然か……？　いや、お主……最初から、余にぶち撒けるつもりでチ〇ポを\n抜いたな……？　んっ、ふぁっ、んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1804402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ふふ……不意打ちとはやってくれる……だが、不快ではない……もう中には\n出ておるからな……身体に浴びるのも一興よ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1804403" ]},
		{"command":[ "SETIMAGE", "0", "still_00000318_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「何より、この呆れた量だ……余を白濁に満たそうという気概……いい度胸じ\nゃ……んんっ、べっとりじゃな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1804404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んむ……終わったか。ふふ……部屋中にオスのにおいが立ち込めておる……\nれろっ、ちゅぷっ、強烈なザーメン臭じゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1804405" ]},
		{"command":[ "SETIMAGE", "0", "still_00000318_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「あぁ、まだ生温かいな……それにしても……お主を使ってやるつもりでおっ\nたが、余の方が使われることになるとはな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1804406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「くくっ、怒っているわけではない。それだけ、お主の正直な欲望を買ってお\nるのじゃ。余にここまで正面から対峙できるものはおらぬからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1804407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「終わったら、そのまま捨て置こうかと思ったが、興が乗った。今宵は、お主\nとじっくり過ごすのも悪くないな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1804408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ん……打ち止め？　くくっ、急に弱気になりおって、らしくもない真似を。\n心配するな、これ以上チ〇ポから搾り取る訳ではない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1804409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「じっくりと休みを入れて、また気が向くようならまぐわえばよい。まずは風\n呂を使おう。余の背中……流してくれるか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1804410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}