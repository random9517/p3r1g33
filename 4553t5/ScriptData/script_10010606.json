		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"] },
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「きゃぁああああああーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010106100001" ]},
	{"command":[ "SETCHARA", "0", "char_00000201_01", "9", "CENTER", "0" ]},
	{"command":[ "DISPTEXT", "TRUE" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「カグヤ―っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010106100001" ]},
	{"command":[ "SETCHARA", "0", "char_00000401_01", "7", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「大丈夫ですかっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010106100001" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "3", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ああっ！　あそこ！　倒れてる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010106100001" ]},
	{"command":[ "SETCHARA", "0", "char_00000601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「とにかく、手当てをします！　セレーナさん、まわりを警戒してください！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010106100002" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「……どうやら、誰もいないみたいだな。カグヤの様子は！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010106100002" ]},
	{"command":[ "SETCHARA", "0", "char_00000401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「やはり、遅かったようです……。６人目の被害者が……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010106100003" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「カグヤちゃんまで！？　ど、ど、どうしよう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010106100002" ]},
	{"command":[ "SETCHARA", "0", "char_00000601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「とにかく、カグヤをこのままにはしておけませんね。他の５人と同じように\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010106100004" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「わかった。じゃあ、そこの空き部屋に――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010106100003" ]},
	{"command":[ "SETCHARA", "0", "char_00000401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ね、ねえ？　早く食堂に戻らない！？　あんまりうろうろしてると危ないか\nも――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010106100003" ]},
	{"command":[ "SETCHARA", "0", "char_00000601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「そうですね。残ったのはウチたち３人だけのようですし、できるだけ固まっ\nていたほうがいいでしょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010106100005" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「だな。……あれ？　なんか忘れてる気が……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010106100004" ]},
	{"command":[ "SETCHARA", "0", "char_00000401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「っ！？　セレーナさん！　危ない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010106100006" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「おおっと！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010106100005" ]},
	{"command":[ "SETCHARA", "0", "char_00000401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「セレーナちゃん大丈夫！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010106100004" ]},
	{"command":[ "SETCHARA", "0", "char_00000601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「おう！　なんとかかわした！　まさか、こいつが――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010106100006" ]},
	{"command":[ "SETCHARA", "0", "char_00000401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「わかりませんが、ウチたちを始末する気は満々のようです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010106100007" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「ふざけんな！　返り討ちにしてやらぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010106100007" ]},
	{"command":[ "SETCHARA", "0", "char_00000401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
	{"command":[ "EXIT" ]}
	]
}