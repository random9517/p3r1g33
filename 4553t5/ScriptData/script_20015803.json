		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「っ！！　さすがに強い……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023770001" ]},
		{"command":[ "SETCHARA", "0", "char_00000813_01", "4", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「悪いけど、病に侵された人にカツマちゃんを渡すわけにはいかないわ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010023770001" ]},
		{"command":[ "SETCHARA", "0", "char_00011105_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「安心して。少しばかり、大人しくしてもらうだけだから。病気の治療法が見\nつかったら、そこに連れて行くからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010023770001" ]},
		{"command":[ "SETCHARA", "0", "char_00021203_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「ん……？　あれ、じゃあ、やっぱりお二方はウィルスに罹患していない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023770002" ]},
		{"command":[ "SETCHARA", "0", "char_00000813_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「そのようですな。ご主人、我々も正気ですぞ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023770001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「む……そういやジュンジローを連れているのはソレイユだけだな。姫様たち\nはお前をガン無視してたし」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「その言い草はなにか引っかかりますが……ともあれ、ソレイユ殿はご主人を\n守るために駆けつけたのです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023770002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "1" ]},
		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「なあんだ。じゃあ私たちと一緒じゃない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010023770002" ]},
		{"command":[ "SETCHARA", "0", "char_00021203_01", "0", "CENTER", "0" ]},
		{"command":[ "SETCHARA", "1", "char_00011105_01", "8", "CENTER", "-500" ]},
		{"command":[ "SETCHARA", "2", "char_00000813_01", "0", "CENTER", "500" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "DISPCHARA", "2", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「そうだったのね。早とちりしてごめんなさいね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010023770002" ]},
		{"command":[ "SETCHARA", "0", "char_00021203_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "2" ]},
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「いえ……私も接触の仕方が軽率でした。もうしわけありません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023770003" ]},
		{"command":[ "SETCHARA", "2", "char_00000813_01", "4", "CENTER", "500" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「いいのいいの。隊長さんを守りたいって気持ちは一緒だし。じゃあほら、\nこれ、お詫びの印」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010023770003" ]},
		{"command":[ "SETCHARA", "0", "char_00021203_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SPOTCHARA", "2" ]},
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「これは……チョコですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023770004" ]},
		{"command":[ "SETCHARA", "2", "char_00000813_01", "3", "CENTER", "500" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「ええ。友チョコよ。今日はバレンタインでしょう？　ＥＤＯの皆が来たら渡\nそうと思って全員分用意してたの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010023770004" ]},
		{"command":[ "SETCHARA", "0", "char_00021203_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "1" ]},
		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「私のエンジンで湯煎して溶かして、Ｍ．Ａ．Ｍ．Ａが２人のドライブモード\nの形に固め直したのよ。ふふ、いいでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010023770003" ]},
		{"command":[ "SETCHARA", "1", "char_00011105_01", "6", "CENTER", "-500" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "2" ]},
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「え、ええ。さっきまで戦っていた私にこんなものをいただけるなんて……嬉\nしいです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023770005" ]},
		{"command":[ "SETCHARA", "2", "char_00000813_01", "8", "CENTER", "500" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「いいのよ。ソレイユさんがいつも頑張ってるのも見てるから。お仕事の合間\nにでも食べてね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010023770005" ]},
		{"command":[ "SETCHARA", "0", "char_00021203_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「お二方の寛大さは海よりも深いですな……こんなご主人を受け入れるだけは\nあります」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023770003" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "4", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "DISPCHARA", "2", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「こんなってどういうことだお前。今回俺は純粋な被害者だからな。なんかい\nきなり襲ってくるし！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「それはともかく、これからどうするか……これが一過性のものであれば――\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023770006" ]},
		{"command":[ "SETCHARA", "0", "char_00000813_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「見つけたぞカツマ！！　私の特訓から逃げるとはいい度胸だ！！　罰として\n２４時間私の部屋で奉仕活動をしてもらおうか！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023770001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「カツマ、もう逃がさない！！　皆、ここよっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010023770001" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「呼び子って、時代劇かよ……って言ってる場合じゃねえ、逃げないと！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「カツマちゃん、裏口から逃げて！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010023770004" ]},
		{"command":[ "SETCHARA", "0", "char_00011105_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「助かるっ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「私たちも行きましょう！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023770007" ]},
		{"command":[ "SETCHARA", "0", "char_00000813_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人、単独行動は死亡フラグですぞっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023770004" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0027" ]},
		{"command":[ "PLAYBGM", "BGM_007" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……俺は真面目に働いていただけなのになんでこんな目に……！\n！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「待てカツマっ！！　大人しく私の側に仕えろ！！　栄誉だぞ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023770002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「カツマ、私と一緒になろう！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010023770002" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「絶対嫌だあああああっ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「カツマちゃん、乗って！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010023770005" ]},
		{"command":[ "SETCHARA", "0", "char_00011101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「Ｍ．Ｏ．Ｅ！！　ありがたい！！　もう誰も知らないところまで俺を連れて\n行ってくれ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「分かったわ。シートベルトしてね！！　飛ばすわよ～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010023770006" ]},
		{"command":[ "SETCHARA", "0", "char_00011101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023770003" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「カツマ……どうして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010023770003" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「ひとまずは逃れたけど……これ、行く先々で隊長が追われるだけになるので\nは？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023770008" ]},
		{"command":[ "SETCHARA", "0", "char_00000813_01", "1", "CENTER", "400" ]},
		{"command":[ "SETCHARA", "1", "char_00000902_01", "0", "CENTER", "-400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "1" ]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「根本的な解決にはなっておりませんな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023770005" ]},
		{"command":[ "SETCHARA", "1", "char_00000902_01", "1", "CENTER", "-400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「とりあえず、私たちも追いましょう。２人とも乗って！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010023770006" ]},
		{"command":[ "SETCHARA", "0", "char_00021201_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0041" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「くっ……差が縮まらない……っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023770009" ]},
		{"command":[ "SETCHARA", "0", "char_00000813_01", "4", "CENTER", "0" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「目一杯飛ばしてるんだけど……さすがにスポーツカーとバスじゃ馬力が違う\n！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010023770007" ]},
		{"command":[ "SETCHARA", "0", "char_00021201_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「市街地なので相手も全速力ではないのが幸いですな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023770006" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「でもこのままじゃ……ん、あれは？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023770010" ]},
		{"command":[ "SETCHARA", "0", "char_00000813_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ニャンコ先生ですな。ヒッチハイクでしょうか。えーと行き先の段ボールに\nは……明日へって書いております」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023770007" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「なんですかその微妙にアート感を出した映画のラストみたいな行き先は……\nいや、ともかく今は１人でも戦力が欲しい。拾いましょう！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023770011" ]},
		{"command":[ "SETCHARA", "0", "char_00000813_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「いやー助かったよ。皆で遊びに行こうって出かけたのに、なぜかＭ．Ｏ．Ｅ\nを見た瞬間、私以外全員が追っかけていっちゃってな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010023770001" ]},
		{"command":[ "SETCHARA", "0", "char_00010010_01", "8", "CENTER", "600" ]},
		{"command":[ "SETCHARA", "1", "char_00000813_01", "0", "CENTER", "0" ]},
		{"command":[ "SETCHARA", "2", "char_00000902_01", "0", "CENTER", "-600" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "DISPCHARA", "2", "TRUE" ]}, 
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "1" ]},
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「先生以外は恋の病に罹患してしまったのですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023770012" ]},
		{"command":[ "SETCHARA", "1", "char_00000813_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "2" ]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「おそらくはＭ．Ｏ．Ｅ殿から漏れるご主人の気配でそうなってしまったので\nしょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023770008" ]},
		{"command":[ "SETCHARA", "2", "char_00000902_01", "0", "CENTER", "-600" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "1" ]},
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「ん……？　じゃあこれって隊長がウィルスの基となっているのでは？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023770013" ]},
		{"command":[ "SETCHARA", "1", "char_00000813_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "2" ]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「あるいは、バレンタインという概念ゆえに、ＥＤＯでただ１人の男となった\nご主人がターゲットになってしまったか、ですな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023770009" ]},
		{"command":[ "SETCHARA", "2", "char_00000902_01", "0", "CENTER", "-600" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「恋の病？　ばれんたいん？　なにを言っているんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010023770002" ]},
		{"command":[ "SETCHARA", "0", "char_00010010_01", "3", "CENTER", "600" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "1" ]},
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「それが私にもよく分かっていないのですが……バレンタインに際してＥＤＯ\nの皆が隊長のことを過剰に求めるようになってしまいまして」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023770014" ]},
		{"command":[ "SETCHARA", "1", "char_00000813_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「サイレーンさんはそれをバレンタインによって引き起こされた恋の病だと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023770015" ]},
		{"command":[ "SETCHARA", "1", "char_00000813_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "2" ]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「罹患するのは個人差があるようで、ソレイユ殿やニャンコ先生など、耐性が\nある方とない方に別れているようです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023770010" ]},
		{"command":[ "SETCHARA", "2", "char_00000902_01", "1", "CENTER", "-600" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「なるほど……そのばれんたいんとやらはよくわからんが、その熱狂を醒ます\n薬ならあるぞ。忍びにはそういうものも必要だからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010023770003" ]},
		{"command":[ "SETCHARA", "0", "char_00010010_01", "3", "CENTER", "600" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "1" ]},
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「本当ですか！？　じゃあ、それを罹患した皆に飲ませれば……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023770016" ]},
		{"command":[ "SETCHARA", "1", "char_00000813_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「量があれば、そうだな。だが、さすがにどれほどの数になるともしれないだ\nけの薬はない。だから、これは隊長どのに飲ませればいい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010023770004" ]},
		{"command":[ "SETCHARA", "0", "char_00010010_01", "6", "CENTER", "600" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "2" ]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「なるほど、ご主人が原因であれば、その大本を解消すれば皆もまた冷静にな\nるというわけですな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023770011" ]},
		{"command":[ "SETCHARA", "2", "char_00000902_01", "3", "CENTER", "-600" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "1" ]},
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「さ……さすがニャンコ先生！！　なんという冷静で的確な判断力なんだ……\nどこかの先生とは大違いですね！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023770017" ]},
		{"command":[ "SETCHARA", "1", "char_00000813_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0000" ]},
		{"command":[ "SETNAME", "Ｄr.サイレーン" ]},
		{"command":[ "SETTEXT", "「むっ！？　今何か私を……いやそれよりもカツマくんを捕らえる算段が先だ\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010023770001" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "DISPCHARA", "2", "FALSE" ]}, 
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0041" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「しかしこれには問題があってな……この薬は解消ではなく反転させる効果な\nんだ。つまり、今好かれているのを反転させる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010023770005" ]},
		{"command":[ "SETCHARA", "0", "char_00010010_01", "5", "CENTER", "600" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "DISPCHARA", "2", "TRUE" ]}, 
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "1" ]},
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「それって……それを飲んだら、隊長は……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023770018" ]},
		{"command":[ "SETCHARA", "1", "char_00000813_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「好かれている分、嫌われることになるな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010023770006" ]},
		{"command":[ "SETCHARA", "0", "char_00010010_01", "4", "CENTER", "600" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "1" ]},
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「そ……それは……いや、しかし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023770019" ]},
		{"command":[ "SETCHARA", "1", "char_00000813_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "2" ]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ソレイユ殿、仕方ありますまい。ご主人は尊い犠牲となる運命なのです……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023770012" ]},
		{"command":[ "SETCHARA", "2", "char_00000902_01", "8", "CENTER", "-600" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「顔が笑っているぞ、ジュンジローどの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010023770007" ]},
		{"command":[ "SETCHARA", "0", "char_00010010_01", "3", "CENTER", "600" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "2" ]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「おっと、これは失敬。ですが、ニャンコ先生の薬を飲むしかないのも確か。\nこのままですと、嫌われる以前にご主人の身体がもちませんし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023770013" ]},
		{"command":[ "SETCHARA", "2", "char_00000902_01", "3", "CENTER", "-600" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "1" ]},
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「その薬……永続ではないですよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023770020" ]},
		{"command":[ "SETCHARA", "1", "char_00000813_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「身体から成分が抜けたら元に戻る。効いている間に体質も変化させるから、\n問題の解決もするはずだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010023770008" ]},
		{"command":[ "SETCHARA", "0", "char_00010010_01", "6", "CENTER", "600" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "1" ]},
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「う……む……やるしかないですね。隊長、ごめんなさい。誰に嫌われても私\nは、私だけは隊長の側にいますから！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023770021" ]},
		{"command":[ "SETCHARA", "1", "char_00000813_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「Ｍ．Ａ．Ｍ．Ａさん、アクセル目一杯踏みます！！　全力で飛ばしてくださ\nい！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023770022" ]},
		{"command":[ "SETCHARA", "0", "char_00000813_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "DISPCHARA", "2", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「了解っ！！　ってこれ、ソレイユさんの力が私に……これが日輪の暖かさ…\n…分かる……私の身体が日輪の力を……日輪の力がエンジンに！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010023770008" ]},
		{"command":[ "SETCHARA", "0", "char_00021201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「エンジンがオーバーレブしてる……フルスロットル！！　全力全開で行くわ\nっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010023770009" ]},
		{"command":[ "SETCHARA", "0", "char_00021201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}