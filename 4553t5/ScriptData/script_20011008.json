		{"command":[ "SETCHARA", "0", "char_00016701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「へっへへー、捕まえたっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0121340004" ]},
		{"command":[ "SETCHARA", "0", "char_00016602_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ちっ、なーにやってんだよ。おい、言っとくけど、今更人質にしようたって\nムダだぞ、こいつにそんな価値はないからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0221340001" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「さらっと酷い言い草だな！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「ふん、強がってられるのも今のうちだし。んっ……ちゅぷ……んりゅ……れ\nろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0121340005" ]},
		{"command":[ "SETCHARA", "0", "char_00016602_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「ア、アルマっ……何をするっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0121340004" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「おいおい……何で戦ってる最中にキスしてんだよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0221340002" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「見せつけるのが趣味とは……ご主人も、大概マニアックですぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_0121340001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「俺がしてるんじゃねーだろ！　って……うぉっ……！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「ふふふーっ、充電完了だし。そっちが数のぼーりょく使うなら、こっちも味\n方呼ぶもんね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0121340006" ]},
		{"command":[ "SETCHARA", "0", "char_00016602_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
