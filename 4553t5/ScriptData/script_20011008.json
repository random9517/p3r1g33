		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0121340001" ]},
		{"command":[ "SETCHARA", "0", "char_00016801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あれは……イグニス……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「いやしかし、どこかちょっと雰囲気が違いますぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_0121340002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「これは、まさか……私の……もう一つの、可能性……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0121340006" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「ふわぁぁーーーーっ、うぅぅ……眠っみぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0121340002" ]},
		{"command":[ "SETCHARA", "0", "char_00016801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「出てきたね！　イグニスの別人格、イグニス・アルター！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0121340009" ]},
		{"command":[ "SETCHARA", "0", "char_00016602_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「……いきなりなんなんだい？　誰がアタシを召喚したんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0121340003" ]},
		{"command":[ "SETCHARA", "0", "char_00016801_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「はいはーい、あたし！　あたしが、あんたのご主人様だから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0121340010" ]},
		{"command":[ "SETCHARA", "0", "char_00016602_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「んぁ……？　こりゃまた随分、若い主が出てきたなぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0121340004" ]},
		{"command":[ "SETCHARA", "0", "char_00016801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「見た目はどーでもいいでしょ！　ほらっ、ちゃんと呼んだんだから仕事して\nっ、主人のピンチなんだからあいつら蹴散らして！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0121340011" ]},
		{"command":[ "SETCHARA", "0", "char_00016602_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「んぅうー？　やー、わりぃな。今、あんまそーいう気分じゃねぇんで、また\n今度な」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0121340005" ]},
		{"command":[ "SETCHARA", "0", "char_00016801_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「んなっ！　こ、今度って……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0121340012" ]},
		{"command":[ "SETCHARA", "0", "char_00016602_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「気が向いたら、そのうちしてやっからよ。それより、腹減ったな……なんか\nメシとかねぇか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0121340006" ]},
		{"command":[ "SETCHARA", "0", "char_00016801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「何か……えらいフリーダムな奴が出てきたぞ。見た目はイグニスだが……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「これも、私に秘められた一部なのだろうが……こんな自堕落な……うぅっ…\n…い、戒めねば……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0121340007" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「んだよ、ごちゃごちゃうるせぇなぁ……おっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0121340007" ]},
		{"command":[ "SETCHARA", "0", "char_00016801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「えっ……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「何だよ、おい、いー男がいるじゃねぇか。へへ、なぁこっち来いよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0121340008" ]},
		{"command":[ "SETCHARA", "0", "char_00016801_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お、俺……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「他に誰がいるんだよ。その顔、めっちゃあたし好みじゃんか。いーことしよ\nうぜ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0121340009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「ほら、好きなだけオッパイ揉ませてやるしよ、そうだなメシより先に、こっ\nちを頂くってのも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0121340010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「向こうの奴らの美的感覚……どうなってんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0221340004" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「向こうでならご主人も超絶色男ですか……生まれる場所を間違えましたな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_0121340003" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「アルター！　あいつらをやっつけたら、カツマのこと好きにしていいよ！　\nめっちゃエロいこともやり放題だから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0121340013" ]},
		{"command":[ "SETCHARA", "0", "char_00016602_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「へぇ、そりゃいいや。ちゃんとご褒美があるってんなら、アタシもやりがい\nがあるってもんじゃないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0121340011" ]},
		{"command":[ "SETCHARA", "0", "char_00016801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「っ……！　また力が……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0121340004" ]},
		{"command":[ "SETCHARA", "0", "char_00017001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「これは……一筋縄ではいきませんわね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0121340003" ]},
		{"command":[ "SETCHARA", "0", "char_00016901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「へへっ、じゃあお楽しみの前に、ぶちかまそうか。楽しませてくれよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0121340012" ]},
		{"command":[ "SETCHARA", "0", "char_00016801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「うぬ……自らとの対峙……相手にとって不足はないっ。参る！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0121340008" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
