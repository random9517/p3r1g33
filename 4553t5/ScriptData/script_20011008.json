		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「さあ、観念なさい。大人しく降伏したら、悪いようにはしませんわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0121340001" ]},
		{"command":[ "SETCHARA", "0", "char_00016901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「うぬぬぅぅ……こうなったらぁ……隙ありっ！」", "NORMAL" ]},
