		{"command":[ "SETCHARA", "0", "char_00016901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「させるかっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0121340002" ]},
		{"command":[ "SETCHARA", "0", "char_00017001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「邪魔すんなっ！」", "NORMAL" ]},
