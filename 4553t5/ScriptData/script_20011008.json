		{"command":[ "SETCHARA", "0", "char_00017001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「こんな……めちゃくちゃ、多勢に無勢でっ……恥ずかしくないのっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0121340002" ]},
		{"command":[ "SETCHARA", "0", "char_00016602_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あらゆる卑怯な手を弄して来た貴様がどの口でそれを言うっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0121340002" ]},
