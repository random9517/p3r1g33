		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「パワーがまた増幅されたっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0121340005" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「出てこいっ、アルターワールドの使者っ！　我が命に従いて、ここに現せっ\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0121340008" ]},
