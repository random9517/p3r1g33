		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「どしたどしたー！　大分、疲れて来たんじゃないかー？」", "NORMAL" ]},
