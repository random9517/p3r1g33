{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「兄さん、緊急任務って聞いたから来たけど――そのにやにやした顔を見たら\nなんとなく分かった、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0403101" ]},
		{"command":[ "SETCHARA", "0", "char_00015804_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「……それで、何をしてほしいの？　いちおー聞いてあげる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0403102" ]},
		{"command":[ "SETCHARA", "0", "char_00015804_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「性欲解消に付き合ってほしい？　――え？　あ、足コキ？　足でしてほしい\nの？　うわぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0403103" ]},
		{"command":[ "SETCHARA", "0", "char_00015804_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「普通にえっちをさせろと言われると思ったのに……更に斜め下を来るとは思\nわなかった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0403104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「いいよ、兄さんがどーしよーもない変態なのは知ってたもん。気持ち悪いけ\nど……しょーがないから付き合ってあげる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0403105" ]},
		{"command":[ "SETCHARA", "0", "char_00015804_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「……これ、靴は脱いだけどこのまま足の裏でおちんちんを挟めばいいんだよ\nね？　えっと……こう、かな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0403106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00015804_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「うわぁ、うわぁ……なんかぐにゅってした感触が伝わってくる……でも、固\nくて熱くもあって……気持ち悪い、ほんとーに気持ち悪い、かも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0403107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ね、ねぇ兄さん？　なんで最初からおちんちんこんなに固くしてるの？　ま\nだ軽く挟んだだけだよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0403108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「――私の足でしてもらえると思うと興奮が抑えきれなかった、って……え、\nうそ……本当に足でされるのに喜んでるんだ……うわぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0403109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「このままゆっくり、足を上下に動かせばいいんだよね……んっ……固いはず\nなのにグネグネしてて、思ったより難しいかも……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0403110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「これ……んっ……皮の部分がずるっとなって、まっすぐ足動かせない……先\nっぽ、手で押さえたほうがやりやすいのかな……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0403111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「んっ、んふっ……そっか、足の指を竿にひっかければいいのか……ん、しょ\n……親指を、ポッコリ膨らんでる場所に引っ掛けて……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0403112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ああ！　またおちんちん逃げた！　でも、これも気持ちいいんだ……左右か\nらぺちぺち足で叩くと……ふふっ、おちんちん、びくびくしてる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0403113" ]},
		{"command":[ "SETIMAGE", "0", "still_00015804_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「兄さん、これ気持ちいいの？　見下ろされながら足で乱暴におちんちん叩か\nれるの気持ちいいの？　兄さんの変態、ど変態……ふふふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0403114" ]},
		{"command":[ "SETIMAGE", "0", "still_00015804_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「――思ったよりノリノリだな、って？　だって馬鹿な大人を……兄さんを一\n方的に虐められるんだもん……ちょっと楽しい、かも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0403115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「――へ、へたくそなのはしょうがないでしょ、こんなの初めてだもん！　い\nいよ、すぐに学習して、兄さんに参りましたって言わせてあげる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0403116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「今度こそ足の裏でしっかりおちんちんを挟んで……根元から抑えれば、きっ\nと左右には暴れないよね……ん、しょ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0403117" ]},
		{"command":[ "SETIMAGE", "0", "still_00015804_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「踵を根元の辺りにつけて、ぐにゅぐにゅのおちんちんをぎゅ～、って……ん\nっ、ピッタリ引っ付けると、やっぱり熱い……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0403118" ]},
		{"command":[ "SETIMAGE", "0", "still_00015804_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ここ、だよね……？　さっき、括れの部分指でひっかけた時、気持ちよさそ\nうにしてたもんね……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0403119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「何、兄さん、その情けない声。足で急所を好き勝手虐められてるに、馬鹿み\nたいな声出して……ふふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0403120" ]},
		{"command":[ "SETIMAGE", "0", "still_00015804_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「まぁ、兄さんはどーしよーもない変態だもんね。こうやって……んんっ！　\nぎゅ～っておちんちんを圧迫されるのも気持ちよくなっちゃうんでしょ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0403121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「足の裏をしっかり竿に添わして……ん、しょ……んんっ……ゆっくり上下に\n、皮を巻き込むように……んふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0403122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「今度はできた……このまま、何度も往復させて……んっ、んふっ……血管を\nなぞるように、足をすりすり、すりすり……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0403123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「うわぁ……先っぽからいっぱいお汁が溢れてきて……兄さん、聞こえる、ぐ\nちょぐちょって、恥ずかしい音がしちゃってるよ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0403124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「みっともなく、馬鹿みたいに腰をビクビクさせて……んふっ……兄さんって\nば、口を開けて、情けない顔……んっ、んふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0403125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「――もっと早くしてほしい？　ふふっ、ダメ、してあげない。兄さんはじ～\nっくり私にいじめらてればいーの、ふふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0403126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ん、しょ、っと……足を左右に振るようにしてぐりぐり……んっ、こうかな\n……？　擦り合わせて、お汁をいっぱい塗り込んで……んふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0403127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「またぺちぺち叩いてもあげるね。変態の兄さんが気持ちよくなれるように、\nおちんちん振り回してぐりぐり、左右からぺちぺち……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0403128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「んっ、んふっ……力加減も、分かってきた……少しおちんちんの形が変わる\nぐらいの力で……兄さん、これが好きなんだ……んふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0403129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「――ふふっ、なーに、そんなに大声出しちゃって。兄さん大人でしょ？　み\nっともなく騒ぐのは、馬鹿みたいだよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0403130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「分かってる、もう出したいでしょ？　おちんちんの先っぽ、さっきからビク\nンビクン大暴れしてるもんね……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0403131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「いいよ、我慢なんてせずに出しちゃっても。んっ、んんっ……私も、兄さん\nが情けなく射精しちゃう姿見たいからさ、ふふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0403132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「根元からぎゅ～って絞り上げるように……ん、しょっ……んふっ……踵で根\n元をぐりぐり押し付けで、ぎゅ～……んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0403133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「おちんちん、今までで一番熱くなって……んっ、んんっ……！　ドクドクっ\nてせーえきが上っていくのが、わかるよっ……んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0403134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ほら、出しちゃえ！　大人なのに足でおちんちん苛められて、情けなくびゅ\nーびゅー射精しちゃえ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0403135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「きゃっ！？　えっ、ちょ、ちょっとまって、こんな飛ぶなんて聞いてない！\n　ひゃんっ！　ボディにまでかかってっ、んんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0403136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015804_01_05" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「や、やだ、熱くて臭いのでドロドロになるの、気持ち悪い……んくぅんっ！\n　おちんちん、まだどくどくしてる、んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0403137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ほんとに足で弄るだけでも射精することってできるんだ……んっ……おちん\nちん馬鹿みたいにビクビクしてるの、足の裏から伝わってくる……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0403138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「確かに出しちゃえとは言ったけど……兄さん、人のボディにかけ過ぎだよ…\n…うわぁ……全身ドロドロ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0403139" ]},
		{"command":[ "SETIMAGE", "0", "still_00015804_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「むぅ……その満足そうな顔、うざい……私が馬鹿な兄さんをいじめてたはず\nなのに……ほんとにうざい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0403140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「……いいよ、そっちがその気なら、まだまだ苛めてあげるんだから。どうせ\n、一回じゃ満足なんて出来てないんでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0403201" ]},
		{"command":[ "SETIMAGE", "0", "still_00015804_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「兄さんのおちんちん、まだまだ固いままで……足でつつくとビクビクしちゃ\nってるね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0403202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「先っぽも赤く膨れ上がって……このでっぱりのところ、さっきよりも広がっ\nてる……んっ……もう一回足で挟んで、ぎゅ～……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0403203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「――まだ敏感だから一息つかせてほしいって？　えー、どうしよっかな～？\n　見ての通り、ボディーを気持ち悪い精液で汚されちゃったしなぁ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0403204" ]},
		{"command":[ "SETIMAGE", "0", "still_00015804_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「それに、さっきもっと早くしてほしいって言ったのは兄さんだからね。この\nまま続けて搾り取ってあげるんだから！　ん、しょ、っと！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0403205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ぬるぬるのせーえきを足の指に絡めて……んんっ……これでにゅるにゅるっ\nて、おちんちんを撫でて……んっ、んくぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0403206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「やっぱり、さっきよりも足動かしやすいね……んっ……でも、気を付けない\nと、足の間からおちんちん滑って逃げていっちゃうかも、んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0403207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「――だから、待たないってば。早くしてくれって言ったのは兄さんだよ？　\n大人なんだから、自分の発言には責任を持たないとね、ふふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0403208" ]},
		{"command":[ "SETIMAGE", "0", "still_00015804_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「知ってるんだ、おちんちんの裏側、下から上にずりゅずりゅって擦り上げた\nら気持ちいんだよね？　情けない声出しちゃうんだよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0403209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ん、しょ……んっ、んくっ……後はここ、先っぽの膨らんでることの繋ぎ目\n、親指でぐりぐりってしてあげると……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0403210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ふふふっ、兄さんのおちんちん、馬鹿みたいに暴れちゃってるね。……私の\n思い通りにビクビクするの、ちょっとかわいいかも……んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0403211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「あーあ、私の兄さんはほんとに変態だね。恥ずかしくないの、こーんな小さ\nなボディの私に足で好き勝手虐められてるの気持ちよくなちゃって？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0403212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「へんたーい、ド変態のお兄さん♪　潰れるぐらいの力でおちんちんぎゅ～っ\nてして、いっぱい振り回してるのに、それでも感じちゃうんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0403213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ぎゅ～ってして、離して、ぎゅ～ってして、離して……ふふっ、気持ち悪い\n音だなぁ、これぜーんぶ兄さんが出したえっちなお汁だよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0403214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「……ねぇ、兄さん、さっきからどこ見てるのかな？　こーんなロリロリボデ\nィの私なのに、ずっとパンツ見てるよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0403215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「気持ち悪い、ほんとーに気持ち悪いよ、兄さん♪　兄さんのようなダメな大\n人は、私の足で虐められて、何も抵抗できないまま射精しちゃおうね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0403216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「んんっ……また根元から、今までで一番激しく……んくっ……！　兄さんの\n弱い動きは、全部学習したから、こうっ……んんんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0403217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「先っぽのふくらみに指を引っ掛けて、弾いてっ、あっ、んんんっ！　また皮\nも巻き込んでシコシコしてあげるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0403218" ]},
		{"command":[ "SETIMAGE", "0", "still_00015804_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「あっ、んくぅっ……！　足の裏でぐちゅぐちゅってえっちなお汁かき混ぜて\n、竿の部分いっぱいシコシコ、いっぱいシコシコ、んんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0403219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ほら、我慢なんてせずに出しちゃえ！　気持ち悪～いって馬鹿にされながら\n、私の足でビクビク射精しちゃえ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0403220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ふふっ、おちんちんから精液出たっ！　馬鹿みたいな声出しながら、みっと\nもなく射精してる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0403301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015804_01_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「んんんっ！　こ、今度は足にいっぱい掛けられちゃってる……あっ、んくぅ\nっ……！　ドロドロのせーえき、すごい量……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0403302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「やっぱり、このせーえきが飛んでくる感触、気持ち悪い、けど……んくぅ！\n　兄さんのこと、最後までいじめるのっ……んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0403303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ぐちゅぐちゅって、精液でおちんちんかき回して……んくっ……おちんちん\nの中に、せーえきを一滴も残させないんだから、んんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0403304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「これ……匂いもすごい……嗅覚センサーがえっちなエラーを起こして……頭\nがくらくらしちゃう、かも……んぁんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0403305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ふぅ……これで出し終わった、かな……？　兄さん、ちょっと出し過ぎじゃ\nない……？　見て、私の足、大変なことになっちゃってるよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0403306" ]},
		{"command":[ "SETIMAGE", "0", "still_00015804_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「――私の足が最高過ぎるのが悪い？　足コキ最高？　……うわぁ、うわぁ…\n…兄さん、気持ち悪い。ほんとーに気持ちが悪いよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0403307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「……確かに、私もちょっと乗っちゃったところあるけど……だから、そのに\nやにや顔、うざい！　兄さん、こっち見るな！　見ーるーなー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0403308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「はぁ……まぁ、でもこれで性欲処理の任務は終わりでいいよね。まったく…\n…馬鹿で変態な兄さんを持つと大変で仕方ないね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0403309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「これ、匂い落ちるかなぁ……？　兄さん、もちろん、責任をもって私のメン\nテナンス、してくれるんだよね？　ふふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0403310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「んんんっ！　すごい勢いっ！　またボディにまで精液が飛んできてっ！　ん\nあぅんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0403401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015804_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「二回目だから、身構えてはいたけど……あっ、んんんっ！　やっぱり、全身\nドロドロにされるに、ちょっと気持ち悪い、かもっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0403402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「んくっ……！　せーえきがついたところ、熱くなってきて……何、この気持\nち、ドロドロ嫌なのに、嫌じゃない気持ちして……んんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0403403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「に、二回目なのに、こんな量出るんだ……！　んんっ！　ダメ、ほんとに頭\nから足の先まで精液まみれになっちゃうよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0403404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……んっ……やっと出し終わった、かな……？　あ……おちんち\nんも柔らかくなってきた……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0403405" ]},
		{"command":[ "SETIMAGE", "0", "still_00015804_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「それで、兄さん……こーんな小さなボディの私に足で虐められて、馬鹿みた\nいな量を射精した感想はどうなの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0403406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「――最高だった？　ありがとうございます？　……これが私の兄さんか……\nねぇ、大人がそれでいいの？　恥ずかしくないの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0403407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「はぁ……もういいよ、変態の兄さんに大人としての普通を求めるのが間違っ\nてた」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0403408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「でも……これが足コキなんだ……アブノーマルだったけど、なんか、ちょっ\nとゾクゾクするというか……精液まみれの足……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0403409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「な、なに、そのにやにや顔！　うざい、兄さんほんとにうざい！　別に癖に\nなんてならない、ならないからね！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0403410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}