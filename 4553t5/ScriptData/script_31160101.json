{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「よ、よぉ……来たぜ。あんま、夜中に呼ぶなよな……。葉金に変に思われっ\nだろ……。……や、呼び出し自体は嬉しい……ケド……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0103101" ]},
		{"command":[ "SETCHARA", "0", "char_00011601_01", "4", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「ってか……。この姿の時って、アタシん中にも葉金がいるわけだからさ……\n。その、エロいこととかは……。って、うん……そうだよな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0103102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「隊長はそれもわかってて、あ、アタシを呼んでるんだろーけど……。で？　\nきょ、今日は何がしたいんだよ。今、アタシの中の葉金がおとなしいから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0103103" ]},
		{"command":[ "SETCHARA", "0", "char_00011601_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「気づかれないうちに……。い、今のうちにさっと終わらせちまおうぜ。はぁ\n……。戦いの後で良かったよ。じゃなきゃアイツに……知られるとこだった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0103104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「アタシが……隊長とエロいことするって……。してもいいくらい、まいっち\nまってるってこと……。……ん？　『ふぇらちお』？　をしてほしい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0103105" ]},
		{"command":[ "SETCHARA", "0", "char_00011601_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「ふぇらちおってなんだ？　悪い……。フツーのセックスとかは知ってるんだ\nけどさ……それは知んないな。ふぇらちお……うん。何……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0103106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「お、おい、なんでごそごそチンポ出してんだよ！？　はぁ！？　アタシが口\nで……ソ、ソレ舐めたりしゃぶったりすんのが……ふぇらちおぉ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0103107" ]},
		{"command":[ "SETCHARA", "0", "char_00011601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「は……？　マ、マジにガチ……？　うぁっ！　や、やめろ！　チンポにアタ\nシの顔近づけんな……ちょっ、おいっ！　うぁっ、あっぁっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「んん……！　でっか……。ぁ……あ、ぁ……。ア、アタシの顔くらいあんじ\nゃねーか……。そ、それにもうガン勃ちしてんだ、けど……？　ごくっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0103109" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00011601_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「そ……そりゃ……。隊長が気持ち良くなるっつーなら、ちょっとは舐めたり\nしても、いいけどさ……。しゃぶるのは、無理だろ……サイズ的に」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「へ？　とりあえず試すだけでも？　……わ、わーったよ……。どっから舐め\nてほしいんだ？　アタシ、作法とかよくわかんねーから……教えろ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0103111" ]},
		{"command":[ "SETIMAGE", "0", "still_00011601_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「うん……うん。精液を作るところ……。き、キンタマを触りながら……舌で\n舐めていきゃいいんだな？　って、うわ、こ、このタマってやつさぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0103112" ]},
		{"command":[ "SETIMAGE", "0", "still_00011601_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「どう扱っていいかわっかんねぇよ……。優しく？　お、おう……。優しく指\nでなぞったり……揉みながら……。わ、や、柔らかい……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0103113" ]},
		{"command":[ "SETIMAGE", "0", "still_00011601_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「ここに精子が……詰まってるんだよな？　え？　今も作ってるとこ？　そ、\nそっか……大事なとこなら大切にしないといけないよな。えー、そんで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0103114" ]},
		{"command":[ "SETIMAGE", "0", "still_00011601_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「タマをいじりながら……舐める。舐め……うう。見れば見るほどゴツくてデ\nカい……。ホントに口つけたりして大丈夫なのかよ、これ……まいいや」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0103115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「れ、れろー……ぴちゃっ。ぅ……ヘンな味……。ぺろ、ぺろ……ぴちゃっ…\n…。オイ……だいぶ汗くせーぞ、蒸れてるし……。ん、でも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「自分にねぇ部分だからか？　意外と面白い……かも。ぴちゃっ……ぺちゃっ\n、ぴちゃ……。こ、こうか……？　わ、わっかんねぇ……んん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「うん。先っちょから丁寧に舐めてって……。れろっ、れろっ……カリ首？　\nとかいう段差も舐めて……。うん、ぺちゃ、ぴちゃ、ぴちゃ……んー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「サオの部分をねっちり攻めながら……ぁ。ん、ちゅ、ちゅ、キスしたり……\n焦らしたりしつつ、根元まで……。ふんん♪　んんっ、ぺちゃ、ぺちゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「なんか、タマに近づけば近づくほど……クサいんですけど。ちゃんと洗って\nんのかよぉ……。はぁ？　アタシのフェラに興奮してるから？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「だからチンポが張り切ってる？　あ、あっそ……。んじゃ、アタシのせいか\n……。クサいところも舐め……る。ちゅぷ、ぷちゅ、ちゅぷ……ぴちゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「タマ？　も舐めといた方がいいよな？　ん……はむ……くちゅ、くちゅ、く\nちゅ……れろれろ……。んー……！　なんかシワシワしてんなぁ。んむ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「んで？　舐めながら裏筋に舌を這わせて……舐め上げる……。なるほど。れ\nろ……れろれろれろ……ちゅぷちゅぷちゅぷ……。ああ、わかったぜ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「あとはそれを繰り返し、ながら……。なんか反応がデカイとこを入念に攻め\nてきゃいいわけだ。こんなもん、バトルと一緒でコツだよな、コツ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「へへ、教えてくれてありがと……。じゃ、後は身体を楽にして、アタシに任\nせていてくれよな。ん……ん、ん……ん、ぺろ……ぺろ、れろ、れろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0103125" ]},
		{"command":[ "SETIMAGE", "0", "still_00011601_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ、ちゅぱっ、ちゅぱ……れろれろれろ……。れる……れるぅ……。\nふん……♪　んむ……。はむ、はむ、ちゅ……チュ、チュ……ちゅぅ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0103126" ]},
		{"command":[ "SETIMAGE", "0", "still_00011601_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「ぴちゃっ、ぴちゃ、ぺちゃ、ぴちゃ、ぴっちゃっ……♪　ちゅっ、ぷちゅっ\n……ぷちゅっ、チュッ♪　ちゅる……ちゅ、ちゅ、れろ……れろ、ぷっちゅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「んむぅ……♪　先っちょから……ぁ、カリ、そんで竿ぉ……。れろ……れろ\n……れろれろ……。んぁっ、めっちゃ脈打ってる……！　っちゅぱっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「ドクドク血管に血が流れてる……。ってことはこれでイイってことだな。タ\nマをにぎにぎしながら……。れろぉ……れろ、れろ……ぴっちゃっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「んん？　なん、か……ますます顔の方にチンポが反り返って……はむっ。お\nい……。あんま動くなよ、舐めにくいからぁ……ぴっちゃっ、ちゅぱっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「暴れなくてもちゃんとしてやっからさぁ……。ん……ん……んむ……。あれ\n……。竿がどんどん硬くなってくる……。気持ちいいのかぁ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「ハハ……そんならいいんだけど。アタシ、初心者まるだしで……ゴメンな。\nそのかわり、舌伸ばしてめいっぱいがんばる、から……れろっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「えろ……れろ……れろれる……んむ、むぅ……ちゅるっ、ちゅ、ちゅ……は\nぅ……♪　はむ……んむ……ぴっちゃっ……ぴちゃっぴっちゃっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「ヤッバぃ……チンポ長すぎて……っ、全然舌が回らねぇ……。んんー……れ\nろっれろっれろっれろぉ……。ちゅっちゅっちゅぅ……んっぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「ぎ、ぎこちなくてヤんなるよな……？　アタシ、ふぇらちお、上手くないけ\nど……。すぐに覚えるから、誰よりもうまくなっから……見捨てないでくれ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0103135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「んちゅ……ちゅ、ちゅぅ……。ちゅっ……ぁ……ぁ、うぅ……。チンポ……\n隊長のチンポ……。アタシ、今、チンポ舐めてる……ぅ、っちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0103136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「や、だ……。なんか、女の子女の子した感覚が、アソコに……。んぅ、マ、\nマンコがゾクゾクする……。ぅ、ぁ、あ……ぴちゃっ、ぴちゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0103137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「こんなぶっといの舐めさせられたら……アタシ、想像しちゃって……。っぁ\n……これ、エロいことする棒だって意識しちゃって……そんで、そんで」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「……んんっ！　ご、ごめん……なんか、なんか、頭がぼーっとしてきた……\n。がんばっから……がんばって舐めるから……ッちゅっ、ちゅぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「ぺろぺろぺろぺろ……ぷっちゅっ！　ぴちゃっ、ぴちゃ、ぴちゃ……んんっ\n、ヤバイ、おいし……美味しい、チンポ……くちゅっ、ちゅぷ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「んんむぅうううっ！？　んぶっ！？　ぶひゅっ！？　んぶふっ！？　んぷ…\n…んんぶっ！？　んぶぅううっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0103201" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00011601_01_05" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「や、やらぁああ……！　口の中に出て……んぶっ！？　嘘だろぉ……！　次\n々に……！　んっぅっ！！　うううっ、うーーっ！　うぅー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「んぐっ……はぁ……、んはぁあああ……。なんて量出ひてやがんだぁ……！\n　つか、い、いきなり口に入れてくる量じゃねえらろ……ごぽっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0103203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「……たいひょー……。こ、こりぇ……こっからどーすりゃいいんら……？　\nんぷぁ……口ん中ゴプゴプなんらけろ……。ぁ……うぁ……うう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0103204" ]},
		{"command":[ "SETIMAGE", "0", "still_00011601_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「ひょ、『ひょのまま飲みこめ』ぇ……？　えっ？　精子ぃ……？　アタシが\n？　ぁ……う……わーったよ、やって……みりゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「うまく行かなくても怒んらいれくれよぉ……。んぐっ！　……ごっくっ……\n。おえっ……！　なんかえづいちまったぁ、……んごくっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0103206" ]},
		{"command":[ "SETIMAGE", "0", "still_00011601_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「『自分の唾液と絡ませながら』？　……わ、わーったぁ……。ん……。ぐち\nゅっ、ぐちゅぐちゅぐちゅ……口ん中れ混ぜて混ぜて……ごくっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0103207" ]},
		{"command":[ "SETIMAGE", "0", "still_00011601_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「ぷ、ぷはぁああああ……♪　こ、これでいいかぁ？　って、あんだけ出しと\nいてまだギンギンじゃねえかよ……。これ、ふぇらちおが足りてない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0103208" ]},
		{"command":[ "SETIMAGE", "0", "still_00011601_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「ま、満足しきってねーならしょーがねぇ……。あの、さ……今度はもうちょ\nい深く咥えるっつーか……先っちょパクッってするから見ててくれ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「あーんっ……んむ！　ぐちゅっ！　ぐちゅっ、ぐっちゅっぐちゅっ！　んぶ\n！　ぐちゅぷっ！　ぐちゅっ、ぐっちゅっぐちゅっ……んんあっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0103210" ]},
		{"command":[ "SETIMAGE", "0", "still_00011601_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「せ、せーひの味でアタマくらくらすりゅ……！　でも……でも、負けね……\nぇ！　ぢゅるっ……ぢゅるるるっ、ぢゅる……れろぉおおっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0103211" ]},
		{"command":[ "SETIMAGE", "0", "still_00011601_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「ぐっちゅっぐっちゅっぐっちゅっぐっちゅっぐっちゅっ！！　ん、ぷぁ！　\nはむっ……！　ぢゅるっ……ぢゅるるっ、れろんっ、れろ、れろ……れろ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「んぁぅう♪　はむ！　ぐちゅるっ！　ぢゅっぷっ、ぢゅぷっ、ぢゅぷっ！　\nぐちゅっ……ぐちゅっぐっちゅっ、ぐちゅ……ふぁ……ああ……♪♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「すっげぇ……♪　チンポ……アタシの唾でネロネロだ……。ぁっ……、それ\nに……アタシ……アタシ、全身が熱くなって……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0103214" ]},
		{"command":[ "SETIMAGE", "0", "still_00011601_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「こ、れ欲しがってる……んんぅ♪　なんか、なんか……タマに触りながら、\n揉みながらチンポしゃぶってると……ぽーっとしてきて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0103215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「でもやめらんない……。なぁ、もっとくれよ。精液……。アタシの口と手で\n、気持ち良くなってブリュブリュ出してくれよぉ……んっんぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0103216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「今度はひゃんと待ち構えてるかりゃぁ……精子、いつでも飲めるようにスタ\nンバイしとくからぁ……。っぢゅるっ、ぢゅるるっ、ぢゅる……ぢゅる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「なぁ？　まだ出るんだろ？　出してくれよ……んむっ、遠慮なんかしないで\n、アタシのこと汚してほしい……。っぐちゅっ、ぐちゅっ、ぢゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0103218" ]},
		{"command":[ "SETIMAGE", "0", "still_00011601_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「精子出るまで舐めまくって、ひゃぶりまくってやる……！　んれろっ！　れ\nろっれろぉっ！　れるぅっ、れる……れるっれるっ！　あっ！　あっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「チンポ、膨らんで太く……！　あっ、出ひゅのか！？　出ひゅんだよな……\n！　いいぞ、いいぞ、くれぇ……出ひて……！　出せぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0103220" ]},
		{"command":[ "SETIMAGE", "0", "still_00011601_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「んっ、これっ、これぇ♪♪　うぐううっ♪　ぐぅ……♪　んんっ！　んっ、\nんんん～っ、んんー♪♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0103301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00011601_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「んぁああ……。うん、うん……まら……、まら出りゅんらな……？　うん、\nいいぞ……。来いっ……んぐぅっ！　んぶっ、んぅううう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「ごほっ！　ごほっ、けほっ……。ん……、ら、らいじょうぶりゃ……。へへ\n、見てくりぇ……一滴も残さず受け止めた、らろ……？　ごほっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0103303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「これをぉ……飲めばいいんだよな？　口の中で、自分のちゅばと……唾と混\nぜて……。ん……んぐっちゅっ……ぐっちゅっ……ごくっ、ごっくんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0103304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「ごくっ……ごきゅ……。んはぁああ……♪　そんで、口ん中が空になったら\nぁ……チンポに残った分を舐め取って……。っちゅっ、っちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0103305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「れる……れる、ぇう……。ん……あ、こっちにもちょっと飛び散ってる……\n。待ってろ。……ぺろっ、ぺろ……ちゅ……ちゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0103306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「ごきゅ……ごきゅっ……。ん、はぁ……。ま、まだ全体的にベタベタはして\nっけど……こんなもんか？　初めてにしては上手かったろ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0103307" ]},
		{"command":[ "SETIMAGE", "0", "still_00011601_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「うー……胃の中ずっしり、精子で重い……。二発分だもんなぁ……。でも、\nアタシの拙い舌技や口で出してくれたんだって思うと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0103308" ]},
		{"command":[ "SETIMAGE", "0", "still_00011601_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「やっぱ、むげには出来ないっていうか……。なんなら、かなり愛おしいっつ\nーか……。な、なんてな！　とにかく腹いっぱいだよ。……けふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「この臭いがとれるまで、葉金にバレねぇといいんだけど……。まいったな。\n当分、変身は解かない方がよさそーだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「ん゛っぁっ！？　えっ！？　うぁっ！？　か、顔……！　うぁっ！　顔はや\nめ……んんぉっ！　目に、目に入ったぁ……あっあっあぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0103401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00011601_01_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「すっげぇ……。顔だけじゃなくて頭にも……。びゅるびゅるかかって……目\nの前が真っ白になる……。んんんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「ぼ、暴発……しちまったのか？　それとも……アタシの顔にかけたかったの\nか……？　いや、かけてもいいって。いいんだけどさぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0103403" ]},
		{"command":[ "SETIMAGE", "0", "still_00011601_01_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「この量、限度があんだろ……。ほら、だらだら垂れてきちまってる……。ん\nぁ……どこもかしこも精液だらけ……。クサいったらないっつうの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0103404" ]},
		{"command":[ "SETIMAGE", "0", "still_00011601_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「……へ？　隊長の精子がぶっかかったアタシが綺麗？　……な、ななななな\nな、何言ってんだよんなわけねぇだろ！　精子だぞ精子！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0103405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「っ……で、でも……。アンタがそう思うんなら？　か、顔とか頭に出したか\nいあったかもな！　ア、アタシはめちゃくちゃ迷惑だけどなっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0103406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「……あぁー……こんだけ濃くてクッサい精液なんてさぁ……。適当に洗った\nだけじゃとれねーぞ……。葉金になんて言い訳すりゃいいんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0103407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「雑なアタシはともかく、アイツの髪は丁寧に手入れされててツヤッツヤなの\nに……。って、なんだよ。精液でツヤツヤになるかも……だぁ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0103408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「ぷっ、……あははは、んははははっ！　そうだったらいいよな、そうだった\nらさ！！　それ、時々聞くけどマジで効果あんのかなぁ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0103409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「え？　アタシのこと考えて出したからアタシには効くぅ？　……アハハハ、\nそーかよ。じゃあ今回は許す！　でも、洗うのは手伝ってくれよなぁ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0103410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}