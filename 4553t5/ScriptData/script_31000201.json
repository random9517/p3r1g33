{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0081" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「こうして海に来られたのも、隊長どののおかげだ。礼をしたいのだが、なに\nかして欲しいことはあるか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0203101" ]},
		{"command":[ "SETCHARA", "0", "char_00010002_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「日焼け止めを塗って欲しい？　それぐらいお安い御用だ。それじゃあ、まず\nはうつ伏せになってくれ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0203102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「って、どうして仰向けになるのだ！？　それに、こんなところで水着を降ろ\nしてペニスを露出させるなんて、一体なにを……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0203103" ]},
		{"command":[ "SETCHARA", "0", "char_00010002_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「私の胸に日焼け止めを塗って、ペニスをシゴいて欲しい……？　なるほど。\nそういう要求か」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0203104" ]},
		{"command":[ "SETCHARA", "0", "char_00010002_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「そんな遠回しな感じに言わなくても、素直に胸でして欲しいと言えばいいだ\nろうに……まったく、隊長どのは本当に変態だな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0203105" ]},
		{"command":[ "SETCHARA", "0", "char_00010002_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「アソコを見せつけながらペニスをシゴくこの体勢……やはり恥ずかしいもの\nがあるな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0203106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00010002_01_02" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「だが、この羞恥も修行の一環と思えば……んっ、はあぁ……で、では、はじ\nめていくぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0203107" ]},
		{"command":[ "SETIMAGE", "0", "still_00010002_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あっ、くっ……あっ、ふああぁ……ふふっ。どうだ、私の胸の中は。柔らか\nさには自信があるつもりだが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0203108" ]},
		{"command":[ "SETIMAGE", "0", "still_00010002_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふああぁ……！　ペニスがビクってして……！　な、なるほど。これが隊長\nどのの返事というわけだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0203109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「お気に召してくれたようでなによりだ……たくさん感じてくれ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0203110" ]},
		{"command":[ "SETIMAGE", "0", "still_00010002_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んっ……あっ、あんっ、ひゃうぅ……！　日焼け止めのヌルヌルのせいか、\nかなり滑りがいいな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0203111" ]},
		{"command":[ "SETIMAGE", "0", "still_00010002_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「軽く胸を擦るだけでも、ペニスがずちゅずちゅ音を立てながらヒクついて…\n…先端から透明な液体が出ているぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0203112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふくっ、んっ、あぁんっ……！　日焼け止めと我慢汁が混ざって、私の肌が\nベトベトになっている……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0203113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「それにこのむせ返るようなオスのニオイ……！　こんなモノを間近で嗅いで\nいたら、アソコが疼いて来るじゃないか……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0203114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「だ、ダメだ……！　隊長どの、見ないでくれ……！　私のアソコから溢れて\nくる、いやらしい蜜を……んんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0203115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あっ、ひぐっ、あっ、ふああぁん……！？　アソコに息を吹きかけるだなん\nて……！　そんなの、余計に感じてしまうじゃないか……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0203116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「私のアソコがトロトロになって、イヤらしいメスのニオイを振りまいてるの\nがわかる……！　こんなの、恥ずかしすぎる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0203117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ひゃううぅ！？　あまり擦ってないのに、どうしてペニスがもっと大きくな\nるんだ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0203118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「私のアソコのニオイに興奮した……？　そ、そんな報告は不要だ！　いいか\nら、隊長どのは私に身を委ねて……んきゃあああぁ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0203119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あ、アソコに隊長どのの舌と指の感触が……！？　やっ、やめっ……！　あ\nっ、はあああぁん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0203120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「クリトリスをペロペロされながら、指でアソコをぐちゅぐちゅにされて……\nやっ、これ……ペニスに集中できない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0203121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ちゃんとシゴかないと、もっと激しくアソコを弄るだと……！？　わ、わか\nった！　ちゃんと擦るから、指を抜いてくれ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0203122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んっ、くううぅ、はぁ、はああぁ……！　ペニスの熱を地肌で感じる……！\n　熱くてクサいのに、とってもたくましい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0203123" ]},
		{"command":[ "SETIMAGE", "0", "still_00010002_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「私の胸の谷間で、ずちゅずちゅ音が鳴って……アソコだけじゃなくて、耳か\nらも感じてしまいそうだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0203124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「はぐっ、んっ、ああぁ、んふぅ……！　胸で擦るだけなのに、いっぱい感じ\nて……こんなの我慢が……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0203125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あっ、はあぁ、んくううぅん！？　た、隊長どの……！　どうしてまたクリ\nトリスを舐めて、アソコに指を入れているんだ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0203126" ]},
		{"command":[ "SETIMAGE", "0", "still_00010002_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「私のアソコが切なそうにしてただと……！？　そ、そんなことは……！　な\nいとも、言い切れないんだが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0203127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「はあああぁん！　ダメだ、刺激が強すぎる……！　私のアソコがトロトロに\nなってしまう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0203128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んっ、んひいぃ！　あぁ、はあっ、ああぁあっ……！　感じすぎて、隊長ど\nのより先にイッてしまいそうだ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0203129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふあぁ！？　隊長どののペニスがビクビクして……！？　隊長どのもイキそ\nうなんだな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0203130" ]},
		{"command":[ "SETIMAGE", "0", "still_00010002_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「はぁ、はああぁ……！　上司の期待に応えるのも部下の務め……！　隊長ど\nのペニス、しっかりと射精に導いてやる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0203131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んっ、くううぅ、はぁ、んひゃうぅ……！　いつでも出していいからな……\n全部受け止めてやるぞ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0203132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふぁっ、んっ、んくうぅ……！　私がイキそうな動きに合わせて、隊長どの\nのペニスも激しくビクビク唸って……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0203133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「遠慮せずに出してくれ……！　私の胸を妊娠させるぐらい、たくさん……！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0203134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふああぁ……！　もう我慢が……！　あっ、あああっ！　イッ、イク……！\n　イクううううぅ～～～～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0203135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふあああぁん！　気持ちいいに混じって、隊長どのの熱い子種が胸の中に…\n…あっ、んんんっ、んふうううぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0203136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010002_01_05" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「この精子、日差しに負けないぐらい熱い……！　こんなのを浴び続けていた\nら、肌が焼け……いや、火傷してしまいそうだ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0203137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「はああぁ、あっ、あああっ……！　だ、ダメ……！　このニオイと感触でま\nたイッてしまう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0203138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あああっ、隊長どの……！　未熟な私を許してくれ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0203139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「いっ、イク……！　ふぐ、あっ……ふああぁああぁん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0203140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……二人同時にイッてしまったな……私は満足したが、隊長どの\nはどうだろうか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0203201" ]},
		{"command":[ "SETIMAGE", "0", "still_00010002_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んっ、あふっ……ペニスはまだガチガチのままだな……これはまだ満足でき\nていない、ということでいいのかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0203202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふふっ。隊長どのが満足できていないのは、私の腕が未熟だったからだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0203203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「己の快楽を優先してしまい、胸での奉仕を疎かにしてしまったからな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0203204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「お詫びと言ってはなんだが、もう一度胸でペニスをシゴかせてくれ……今度\nこそ、隊長どのを満足させてみせるぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0203205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んっ、くうぅ……ベトベトだった胸が、精液でさらにベトベトになっている\nな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0203206" ]},
		{"command":[ "SETIMAGE", "0", "still_00010002_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「それにこのオス独特の濃厚な香り……嗅いでいるだけで、またアソコが濡れ\nてきてしまうじゃないか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0203207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「胸でペニスをシコシコしないといけないのに、身体が疼いてくる……この程\n度の誘惑に負けるなんて、未熟な証拠だ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0203208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「はぁ、ううっ、あっ、んんっ……！　擦れば擦るほど、尿道に残っていた精\n液がびゅくびゅく出て、また私の胸を汚してる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0203209" ]},
		{"command":[ "SETIMAGE", "0", "still_00010002_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ひゃうぅんっ！？　た、隊長どの……！　また私のアソコに触れて……！？\n　やっ、もう舐めないでくれ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0203210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んっ、はああぁ、あっ、ああっ！　くっ……隊長どのがその気なら、こっち\nにも考えが……んっ、はうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0203211" ]},
		{"command":[ "SETIMAGE", "0", "still_00010002_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「こうして胸をもっと強く挟んで、ペニスを圧迫して擦れば……んっ、んんっ\n、あぐっ、ふああぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0203212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ペニスがすごく跳ねまわってるぞ……私のアソコを弄る余裕がないぐらい、\n感じているみたいだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0203213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふふっ。この傘の部分を圧迫されながら、シコシコされるのがいいのか……\n？　なら、もっと激しくしてやろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0203214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「くっ、うくっ、あっ、ふああぁ……！？　ちょ、ちょっと待ってくれ……！\n　どうしてまた私のアソコを弄って……んひゃうぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0203215" ]},
		{"command":[ "SETIMAGE", "0", "still_00010002_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「はぁ、はあぁ……！　んっ、ぐっ、ううぅん……！　そんなにされたら、ま\nた……イッ、イッてしまうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0203216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
