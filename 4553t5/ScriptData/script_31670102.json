{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016701_02_03" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んんっ、はぁっ、あっ、はっ、はぁぁぁっ……あっ、ひっ、あっ、あっ、ん\nぁぁぁぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0104101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「く……うぅぅんっ……振動が来るっ……んんっ、オマンコっ……ブルブルし\nて来るぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「ひっ、くふぅっ……おっぱいもぉっ、ちっ、乳首ぃっ……あぁっ、コリコリ\nされてぇっ……ダメらっ、感じるっ……ひっ、あひっ、ぎもぢいいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0104103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あっ、あぁぁぁぁっ、ふぐっ、イグっ……ぎもぢいいのイグっ、オマンコグ\nリグリされてっ、ひっ、オマンコイグのっ、くっ、んぅぅっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0104104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あぁっ……イ、イケないっ……！　ダメだ……紋様が出て……はぁぁ……ど\n、どうしても……最後までイケないぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0104105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「ひっ、乳首っ……またクリクリされてっ、ゆ、許してくれっ……こんな……\n生殺しなままっ、ずっと刺激されるなんてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0104106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「ひっ！　んひんっ、あぁっ、電マっ……またプルプルしてるのっ、おぉっ、\nそ、そこっ、弱いのっ、おひっ、いいのっ、にひぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0104107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あぁっ、なのにっ……ひっ、イッ……けないっ、あぁっ、ダメだ……主殿の\nオチンポじゃないとっ、オマンコ……イケないっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0104108" ]},
		{"command":[ "SETIMAGE", "0", "still_00016701_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あぁ……ち、近くにいるんだろうっ、主殿っ！　お願いだっ、も、もう限界\nなんだっ、こんな機械じゃっ、あぁっ、満たされないっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0104109" ]},
		{"command":[ "SETIMAGE", "0", "still_00016701_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「何でもするっ、恥ずかしいおねだりでもっ、みっともないことでもっ、何で\nもするからっ、あぁっ、直接してっ、ここっ、ここにぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0104110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あ……！　んんっ、それだ……あぁ……ここにっ、電マを当てられて、ぐし\nょぐしょになったスケベオマンコにっ……オチンポが欲しいんだっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0104111" ]},
		{"command":[ "SETIMAGE", "0", "still_00016701_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「分かってるだろうっ、私の身体の淫紋＜スティグマ＞がっ、主殿のオチンポ\nじゃないとイケないとっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0104112" ]},
		{"command":[ "SETIMAGE", "0", "still_00016701_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「こんな機械じゃ全然ダメなんだっ……本物の逞しいオチンポっ！　オマンコ\nに欲しいっ、ぶっといオチンポズボズボして欲しいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0104113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「お願いだっ、主殿っ！　開発されきった、淫乱なイグニスにお情けをっ！　\n本物のオチンポでオマンコしてぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0104114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んひぃぃぃぃんっ！　おおっ、来たっ……あぁっ、主殿のっ、ぶっといオチ\nンポっ！　中にっ、オマンコに来たぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0104115" ]},
		{"command":[ "SETIMAGE", "0", "still_00016701_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「ひっ、おひぃっ！　あぁっ、これだっ……これが欲しかったんだっ、おぉっ\n、イグっ、今度こそイグっ、イグゥぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0104116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「は……あぁぁぁぁ……んっ、ふぁっ、あ……あぁぁぁ……イ、イッたぁ……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0104117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「ふひぁぁ……ぎもぢいいっ……主殿のオチンポ、最高らぁぁ……んっ、あぁ\nぁぁ……オマンコ……キマったぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0104118" ]},
		{"command":[ "SETIMAGE", "0", "still_00016701_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はぁ、あふっ、す、済まない……私も……入れられただけでイッてしまうと\nは思わなかった……気持ち、良すぎて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0104119" ]},
		{"command":[ "SETIMAGE", "0", "still_00016701_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「だって……本物は全然違うから……あぁ……んふぁぁ……中ぁ……広げられ\nてぇ……熱いのがみっちり埋まってぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0104120" ]},
		{"command":[ "SETIMAGE", "0", "still_00016701_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「私のオマンコはもう……主殿のオチンポじゃないと駄目なんだぁ……はぁぁ\n……まだ、オマンコ……ジンジン痺れるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0104121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んっ……ふっ、分かっている……これで、終わりになる訳がない……ちゃん\nと、主殿がイクまで、私のオマンコを使って欲しい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「少し動きにくいが……精一杯、オマンコを締め付けて……気持ちよくさせる\nから……あっ！　そ、そうだっ、ずぶって来るぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0104123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はぁっ、ひっ、いいっ、もっとっ、オマンコ奥までっ、ぐりぐりかき回して\nぇっ、あぁっ、効くっ、オチンポ効くぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0104124" ]},
		{"command":[ "SETIMAGE", "0", "still_00016701_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「そうだっ、あぁっ、普段は……主殿の騎士を気取っているがっ……その本性\nはっ……主殿のオチンポに絶対服従の、ドスケベ騎士なんだっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「いつも、こうしてオマンコされることばかり考えてぇっ、あっ、だらしない\nメスにさせられるのを心待ちにしてぇっ、あぉっ、オマンコそこぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「ひぁぁぁっ！　あっ、ま、また乳首の機械も動いてるぅっ！　ひっ、コリコ\nリの勃起乳首っ、クリクリされてぇっ、い、一緒にぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0104127" ]},
		{"command":[ "SETIMAGE", "0", "still_00016701_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「は、ひぃっ、だ、駄目だっ……いやらしい顔見ないでぇっ、主殿にオチンポ\nで分からされてる、スケベ顔っ……み、見ちゃらめぇっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0104128" ]},
		{"command":[ "SETIMAGE", "0", "still_00016701_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はぁっ、あぁっ、ズボズボされてるぅっ、ひっ、お汁漏れちゃうっ、マン汁\n止まらないっ、おぉっ、かき回されるのっ、どんどん出るぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はひっ、あぁっ、またイグっ、ああっ、ダメっ……まだ主殿のオチンポまだ\nなのにっ、私ばかりっ……イク訳にはぁぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あぉぉっ！　また乳首ぃっ！　ひっ、オ、オマンコもぉっ！　が、我慢だっ\n……せめてっ、い、一緒にっ！　私だけじゃなくっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0104131" ]},
		{"command":[ "SETIMAGE", "0", "still_00016701_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あぁっ、出るんだなっ？　いいぞっ、主殿の……溜まりに溜めたっ、濃厚ザ\nーメンっ……！　中に出してくれっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0104132" ]},
		{"command":[ "SETIMAGE", "0", "still_00016701_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「そうだっ……私の発情オマンコが欲しがってるんだっ、ドロドロの濃い子種\nを飲んでっ、赤ちゃん……孕みたがっている……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はひぃっ！　あぁっ、それぇっ、グリグリされるのぉっ、らめっ、あぁっ、\nまらイグっ、わらひもイクからぁっ、い、一緒にぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0104134" ]},
		{"command":[ "SETIMAGE", "0", "still_00016701_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「出してっ！　中にっ……熱いのっ……いっぱい！　びゅくびゅくっ出してぇ\nぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0104135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んぐぅっ、だめっ、あぁっ、もうっ、あっ、んぁっ、んぁぁぁぁぁぁぁーー\nーーっっ！　」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0104136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あぁぁぁ……出てるっ……んひぃっ、主殿の熱いのっ……はひぃっ、いっぱ\nい出されちゃってるぅっ、んぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0104137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016701_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はひっ……イクっ、オマンコイグっ！　中出しオマンコ気持ちいいーっ！　\nはひぃっ、ずっとイッてるぅぅぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「おっ……おぉぉぉぉ……あちゅい……オマンコの中ぁ……主殿のザーメンが\n……いっぱいになってぇ……オマンコぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0104139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んふぁぁぁ……あぁぁ……幸せぇ……はぁ……ふっ、あぁ……これがあれば\n……もぉ……何でもいいい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0104140" ]},
		{"command":[ "SETIMAGE", "0", "still_00016701_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んくっ……ぁっ……あぁっ！？　中で、また……オチンポが……膨らんで来\nている……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0104201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「そ、そうだな……絶倫の主殿が、一発だけで満足される訳がない……まだ、\n私が務めを果たさなくては……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「このまま……抜かずに、続けて欲しい……今度は、私も……ちゃんとオマン\nコを締め付けて……オチンポにお尽くしする……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0104203" ]},
		{"command":[ "SETIMAGE", "0", "still_00016701_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んふっ、ふぐっ、んんっ、おぉっ、んっ、あぉっ……おっ、あぁぁ……ズコ\nズコされるぅ……ふひぁぁ……あぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0104204" ]},
		{"command":[ "SETIMAGE", "0", "still_00016701_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「ちゃんと、あぁっ……オマンコぉ……ど、どうだ？　ちゃんと締まっている\nか……？　緩くなってないか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0104205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「一応、わ、私なりに……あぁっ、頑張って……くぅぅんっ、だがっ、このオ\nチンポの太さはぁっ……おっ、おぉんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0104206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「うんっ、はっ、あっ、あぁっ、広がるぅ……オマンコ、戻らなくなっちゃう\n……あぁ……主殿のオチンポの形にさせられるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0104207" ]},
		{"command":[ "SETIMAGE", "0", "still_00016701_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あっ、おぉっ！　か、かき回されてぇっ！　あひっ、ち、力が抜けてしまう\nっ！　ひんっ、ま、また乳首も苛められてるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「待ってくれっ……今、そっちも、同時にされたらっ……ひっ、おぉっ、コリ\nコリ乳首っ……またはしたなく勃起してしまうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0104209" ]},
		{"command":[ "SETIMAGE", "0", "still_00016701_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あぁ……駄目だっ……に、逃げられないのにっ……こんなっ、気持ちよすぎ\nるのっ、続けられたらぁっ、ひぃんっ、オマンコっ、またぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0104210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「ひっ、んっ、ひぃぃっ……イッ、イクぅっ！　オマンコまたイクっ、オマン\nコイクぅぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0104211" ]},
		{"command":[ "SETIMAGE", "0", "still_00016701_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んふぁぁ……あぁぁ、ずっと……オマンコイキッぱなしになってるぅ……お\n汁……びゅるびゅる漏れてるぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0104212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はぁっ、んんっ、ま、負けないっ……ちゃんとっ、主殿のオチンポに……ご\n奉仕……するのだっ……ふぐっ、んぅぅぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0104213" ]},
		{"command":[ "SETIMAGE", "0", "still_00016701_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あぁあ……そ、そんなに顔を覗き込まないでくれっ……恥ずかしいっ……オ\nチンポでよがる顔を見せてしまうなんてっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0104214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
