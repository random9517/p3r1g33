{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「おう、来てやったぞ。約束の時間……間違ってねぇよな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1303101" ]},
		{"command":[ "SETCHARA", "0", "char_00000413_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「で……？　今日の用向きは？　どういうつもりで私を呼び出したんだ？　…\n…なーんてな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1303102" ]},
		{"command":[ "SETCHARA", "0", "char_00000413_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「おいおい、そんなまごまごするなよ。ふふん、ここまで呼び出しといて、今\n更ためらうようなことはないだろ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1303103" ]},
		{"command":[ "SETCHARA", "0", "char_00000413_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「ほら、言ってみろよ。今日は、どういう風なことがしたいのかってな。今更\nだ……私とお前の仲だろうが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1303104" ]},
		{"command":[ "SETCHARA", "0", "char_00000413_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「ふふん……なるほどな。今日の気分はおっぱいってワケだ。へへ……いいぜ\n、私もお前に呼ばれた時からちょっとムラムラしてたからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1303105" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00000413_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「で……上からしたいのか？　んっ……いいぜ……ほれ、こうして寝そべれば\nいいんだろ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1303106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「おっと……何だ、もうマジでガチガチにさせちまってるじゃねぇか。いつ見\nても、発情してるデカいチンチンだな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1303107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「んふふ……いいぜ、ほら……こうやって挟んじまおうな……ほら……どうだ\n？　身体は鍛えても……ここは柔らかいだろ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1303108" ]},
		{"command":[ "SETIMAGE", "0", "still_00000413_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ、それなりに弾力あるのも、私の自慢だからな……お前だけが味\nわえる、おっぱいの感触だぞ？　うりうり……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1303109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「んっ、ふふ……マジでチンチンが正直すぎておもしれーよな。ちょっとギュ\nッと詰めたら、ピンって動いて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1303110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「ここを……ずりずり動かしてやると……気持ちよさそうな息が漏れて来るん\nだ……おっぱいの動かしがいがあるってヤツだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1303111" ]},
		{"command":[ "SETIMAGE", "0", "still_00000413_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「待ってな……まだまだ、もっといい感じにチンチンを可愛がってやるからな\n……んっ、ふっ、んんっ、はっ、んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1303112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「こうして……先っぽの部分を……ぐぐってめり込ませて……そしたら、上下\nにずりずりずりっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1303113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「どうだ？　サンドイッチされた部分が、何度も擦れあって……いろんな場所\nが当たるだろ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1303114" ]},
		{"command":[ "SETIMAGE", "0", "still_00000413_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「一番好きなのは……どの辺だろうなー？　こっちかー？　それとも、この辺\nりかー？　んっ、ふっ、んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1303115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「おっと……ちょっと身体に力が入ったな……てことは……今日はここがゴキ\nゲンってことかー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1303116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「へへっ、いいぜ……けど、ただおっぱいでされてるだけじゃ、ちょっとばか\nり物足りないんじゃないか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1303117" ]},
		{"command":[ "SETIMAGE", "0", "still_00000413_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「ってことで……ここからは……れろ……んっ、えろっ、ぺろっ、れろぉ……\nんっ、れろぉ……んれる、れろぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1303118" ]},
		{"command":[ "SETIMAGE", "0", "still_00000413_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「ああ……私も、お前のチンチンを舐めたいって思ってたところだからな……\nれろ、ちゅぷっ……んっ、ちゅぱっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1303119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「先っぽ……気持ちいいか？　れろ、んっ、私の……唾でヌルヌルにしちゃっ\nてもいいよな……？　ぴちゃ、んちゅぱっ、りゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1303120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「りゅぷっ……んふっ、いいみたいだな……れろ、んちゅっ……このまま、お\nっぱいも……ぎゅっと集める……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1303121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「んんっ、あぁ……はっ、ふっ、んんっ……！　慣れるまでは、パイズリも難\nしかったけど……こうして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1303122" ]},
		{"command":[ "SETIMAGE", "0", "still_00000413_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「ちゃんと、チンチンが弱いところが分かってくると……かなり楽しんで、で\nきるようになってくる……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1303123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「ぴちゃ、ちゅぷっ、んっちゅ……もうちょっと深く……咥えちまってもいい\nよな？　はむっ、りゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1303124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「んんっ、くぽっ、んふぅっ、ちゅぷっ、んりゅぷっ、れる……れるぅ……れ\nろっ、えろっ、れろぉぉぉぉっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1303125" ]},
		{"command":[ "SETIMAGE", "0", "still_00000413_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「ほぉら……口の中れ……ヒクヒクしてる……んっふ……ちゅぷっ……ここで\n、またおっぱいが……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1303126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「ふふっ、マジでいい反応してくれるよな。もっとしてやりたくなる……んっ\n、どうした……自分でしたいのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1303127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「あっ……！　んんっ！　くっ、わ、鷲掴みにして……ぐりぐりっ、荒っぽく\n……！　あくぅっ、はっ、あぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1303128" ]},
		{"command":[ "SETIMAGE", "0", "still_00000413_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「んくっ……分かってるじゃねぇか……下手に遠慮して弱々しいのより……こ\nれくらいの力でされる方がいいぜ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1303129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「んぁっ、はぁっ、ぎゅっと……押し潰して……そうだ……めり込ませていく\nっ……んふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1303130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「れろ……ちゅぷっ、わらひは……フェラに集中するか……れろ、ぴちゃっ、\nんりゅっ、んふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1303131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「ふぁぁ……あぁ……んむっ、先っぽから汁が出てるぞ……ちゅぷっ、んんっ\n、もう少しだな……はむっ、んちゅぷっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1303132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「あぁんむっ……私のおっぱいも……感じて……よくなってる……お前と一緒\nに……軽く……イキそうだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1303133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「ん、ちゅぷっ……はむっ……んんっ、もう出そうだな……？　全部……受け\n止めるから……りゅぷっ、このまま口に出していいからな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1303134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「そうら……んんっ、もごっ……んふっ、おっぱいっ、締め付けてっ……思い\nっきり……中に……らせっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1303135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「んんんんんんっ！　ふぐぅっ……んんっ、あぶっ……！　むぐぅっ、んんっ\n、ふぶっ、おぶぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1303136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000413_01_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「ふぐっ……いっぱいっ、んぐっ……こくっ、んくっ、ぷぁっ、はぁっ、えろ\nっ、れろぉ……は、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1303137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「思ってたより……めちゃくちゃ出たな……んっ、ちゅぷっ……多すぎて、口\nからこぼれちまった……悪い……んちゅぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1303138" ]},
		{"command":[ "SETIMAGE", "0", "still_00000413_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「はふっ、垂れてきてる……ぺろっ……ちゃんと、残さず舐めとかないと……\nもったいないよな……ぺろ……れろ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1303139" ]},
		{"command":[ "SETIMAGE", "0", "still_00000413_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「ふは……チンチン……収まったか。気持ちよく出せたか？　そっか、それな\nらオッケーだ。私もいい感じになれたしな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1303140" ]},
		{"command":[ "SETIMAGE", "0", "still_00000413_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「ちゅぷっ……んっ、ふっ……だが、チンチンはまだ元気も残ってるみたいだ\nな。今度はちゃんと飲み切りたい……続けてもいいか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1303201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「へへっ、そうこなくっちゃな。じゃあ……またおっぱい……寄せてくところ\nからやってくからな……ちゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1303202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「ああ、今度は最初から舌を使っていくぜ……ちゅぷっ、れろっ、えろぉっ…\n…れる……ちゅぱっ、ぴちゅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1303203" ]},
		{"command":[ "SETIMAGE", "0", "still_00000413_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「精液の味……まだ、いっぱい残ってるな……んちゅっ、ちゅるっ……ぺろっ\n、んっ、りゅぷっ、じゅぱっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1303204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「しっかりキレイにしてから……れろっ、えろっ、んっ、ちゅぷっ、よし……\nおっぱいも、揉み込んで……あふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1303205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「ヤバいな……お前にしてもらったから、私のおっぱいも……今、めちゃくち\nゃ感じやすくなってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1303206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「乳首……ビンビンになって……くぅっ……んっ、チンチンにも……当たると\nっ……ビクってなる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1303207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「んっ、あぁっ……乳首も押し付けながら……おっぱい……揉みくちゃにされ\nるとっ……んんっ……！　気持ち……良すぎるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1303208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「ふぁぁ……ちゅぱっ、ぴちゃっ、んちゅっ……んふっ、あぁ……もちろん、\nただよがってばかりじゃいられないからな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1303209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「チンチンの感じる場所……もっともっとしていくからな……ちゅぷっ、んち\nゅぅぅっ……ぴちゃ、んちゅぱっ、れろっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1303210" ]},
		{"command":[ "SETIMAGE", "0", "still_00000413_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「りゅぶっ……あぁ……チンチン美味しい……れろ、ぺろっ……もう、この味\n……ハマっちまってるぅ……じゅぱっ、ちゅぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1303211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「んっ、あぁ……またぎゅっておっぱいしてくれ……はぁんっ、そうだ……お\n前に握り締められると……嬉しいんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1303212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「はぁんっ……！　乳首っ……両方同時につまんでるっ……！　あっ、引っ張\nられてぇっ……伸びちまうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1303213" ]},
		{"command":[ "SETIMAGE", "0", "still_00000413_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「んっ、あっ……谷間にも……あっ、精液……ぬるってしてぇ……あふっ、チ\nンチンがズリズリ滑るぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1303214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「それぇっ、すごくいいっ！　乳首と……チンチンのキスっ……ビリビリ来る\nぅっ！　はっ、んぁっ、あぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1303215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「あふっ、はぁんっ、あぁ……もっとだ……もっと私のおっぱいを犯してくれ\nっ……チンチンも、いっぱい舐めるからぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1303216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「あんむっ、ぴちゃっ、んちゅぷっ……はぁぁ……また汁が滲んでるっ……ん\nちゅるっ……射精……したがってるんだろうっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1303217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「今度こそっ、ちゃんと飲むからなっ……だからっ、あんっ、りゅぷっ……チ\nンチン、逃げないでっ……そのままだからなっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1303218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「んんっ、逃がさないぞ……ぎゅっと挟んで……グリグリっ、擦って……！　\nチンチンっ……全体を包み込んでっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1303219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「んぁぁっ、来いっ……出してっ……！　熱いのっ、いっぱいっ、びゅくびゅ\nくってぇっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1303220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「ふぶぅっ！　むぐっ……んっ、んぐぅっ、んっ、こくっ、んんっ、んぶっ、\nおふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1303301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000413_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「ふごっ……また、こんらにっ……いっぱい……あ、んむっ……んっぐ……お\nふっ、濃いのが……溢れ……てぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1303302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「んぁぁ……それに……おっぱいも……ふごい……イッてる……おっぱい、ジ\nンジン……するぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1303303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「んふっ、ぷぁっ……はぁっ、んんっ、ぷはっ、はぁ、はぁ……終わった……\nのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1303304" ]},
		{"command":[ "SETIMAGE", "0", "still_00000413_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……くっそー、また全部飲みきれなかった……。まさか、一発目\nより量が多くて、勢いもすごいなんて思わないだろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1303305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「こぼしたのはちょっとだけ？　ま、まぁ、そうだけどよ……けど、やっぱり\n悔しいぜ。余裕で飲み干す気満々だったのにな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1303306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「まぁいいや、こぼれた分は……今、ぴちゃ……ちゅぱっ、こうして……舐め\n取ってやればいい……ちゅぷ、ぴちゅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1303307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「んっ、はっ、あふっ……んんっ、れろ、ぴちゃ……よし、こいつで一応は飲\nみきったかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1303308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「あぁ、スッキリしたのか？　へへっ、そんならまあ、よしとするか。私も楽\nしませてもらったしな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1303309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「けど、やっぱり悔しいな……今度こそは、ちゃんと全部飲みきってみせるか\nらな。覚えておけよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1303310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「ぷぁっ！　あっ……お、おいっ……チンチン……抜けてっ、はぷっ、んぁっ\n、んふぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1303401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000413_01_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「何だよ……か、顔に掛けたかった……？　んぁっ、そ、そういうことは……\nもっと早く言えっ……んっ、ぷぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1303402" ]},
		{"command":[ "SETIMAGE", "0", "still_00000413_01_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「はぁ……んんっ、にしても……なんて量出してんだ……これ、さっきより…\n…多くなってるだろ……マジで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1303403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「ふぁぁ……ネバネバするぅ……鼻も……頬も、口の周りもベトベトだ……ん\nぷぁっ、はぁぁ……あふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1303404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「あ……ふっ、あぁ……勢いが……弱まってく……やっとだ……んちゅぷっ、\nぷはっ……はぁ……はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1303405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「ったく、全然飲めなかったじゃないか。リベンジするつもりだったのに……\n顔の方がベトベトだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1303406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「まぁ……でも、これはこれで悪くないか……ちゅぷっ、後からじっくり味わ\nうってのも悪くねぇし……れろ、んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1303407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「こんな風にお前がいっぱい出したってのは、それだけ気持ちよくできたって\nことだもんな……へへ、それは間違いないって？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1303408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「まあ、新鮮なミルクをたっぷり飲ませてもらったし、何か力が湧いてきた感\nじもするし……私は私で満足だな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1303409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「ただ……次はきっちりリベンジしたいからな。ちゃんと……精液……飲ませ\nてくれよ？　約束だかんな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1303410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}