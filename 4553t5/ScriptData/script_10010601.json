{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0089" ]},
		{"command":[ "DISPIMAGE","0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「よっ、と！　へへへっ！　一番乗り！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010106010001" ]},
	{"command":[ "SETCHARA", "0", "char_00000401_01", "8", "CENTER", "0" ]},
	{"command":[ "DISPTEXT", "TRUE" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「遠足に来たお子さまですか。まったく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010106010001" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「へえ、なかなかいいホテルじゃないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010106010001" ]},
	{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「おもったよりオシャレなとこじゃな～い？　立地はだいぶ辺鄙なとこだけど\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010106010001" ]},
	{"command":[ "SETCHARA", "0", "char_00000601_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「まったくだ。廃業予定のホテルを安く貸し切ったというから、どんなオンボ\nロかと思ったが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010106010001" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ま、１泊２日、ここでのんびりするのもいいんじゃねえか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「カツマと……ホホホホホホテルでのんびりっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010106010001" ]},
	{"command":[ "SETCHARA", "0", "char_00000201_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「カグヤ、落ち着いて！　遊びに来たんじゃないんだから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010106010001" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「その通りだぞ、インクレディブル・スクワッドの諸君！　ここに来たのは訓\n練のためだ。決して気を抜かぬように！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010106010001" ]},
	{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まあ……結局仕事なわけだよな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「というわけでさっそく訓練を開始する！　２チームに分かれて模擬戦を行う\n。ホテルの敷地は、常識の範囲内で自由に使って構わん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010106010002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「え！？　じゃあ、もしかして壊してもいいのか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010106010002" ]},
	{"command":[ "SETCHARA", "0", "char_00000401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「『常識の範囲内で』と言ったはずだ。それでわからなければ、追加料金や損\n害賠償が発生しない範囲で、と考えておけ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010106010003" ]},
	{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「ちぇっ、つまんねえなあ……それじゃいつもの訓練とかわんないじゃん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010106010003" ]},
	{"command":[ "SETCHARA", "0", "char_00000401_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「サバイバルゲームができる、って思えばいいんだよ。この辺、自然がいっぱ\nいで面白いゲームになりそうじゃない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010106010001" ]},
	{"command":[ "SETCHARA", "0", "char_00001201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「それもそうか！　おーっし！　やるぞぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010106010004" ]},
	{"command":[ "SETCHARA", "0", "char_00000401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「まったく。バカ犬は単純でいいですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010106010002" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「まあまあ元気でよいではありませんか。ワンコはあれぐらいおバカなほうが\n、かわいらしくてよろしい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010106010001" ]},
	{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「てめぇはなんなんだ、なに目線だ、このアホ犬」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「いいから早く訓練を始めろ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010106010004" ]},
	{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「わかりました。それでは、わたしはカツマさんのチームに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010106010002" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「わ、私もっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010106010002" ]},
	{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ちょっと待て、なぜ勝手にチームを決めている！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010106010002" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ルナテミスもカツマさんと組みたいというんですか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010106010003" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「なっ！　そんなわけがあるかっ！　私は……下僕とは別のチームを希望する\nっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010106010003" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「では、私と組むか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090106010001" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「なら、あたしもルナテミス様チームにしようかね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010106010002" ]},
	{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「お姉ちゃんがカツマさんチームなら、わたしもそっちだね。変身の都合もあ\nるし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010106010002" ]},
	{"command":[ "SETCHARA", "0", "char_00001201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「おいおい！　ガチで変身する気かよ！　じゃ、私はルナ様チームだ！　シル\nバスターと対戦したいもんな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010106010005" ]},
	{"command":[ "SETCHARA", "0", "char_00000401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「え～？　ダイヤナちゃんどっちでもいい～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010106010002" ]},
	{"command":[ "SETCHARA", "0", "char_00000601_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ウチもどちらでも。両チームのキャプテンが、適当に決めてください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010106010003" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「なるほど。ではカツマ、勝負だ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010106010004" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「望むところっすよ！　最初はグー！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「出さなきゃ負けよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010106010005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス＆カツマ" ]},
		{"command":[ "SETTEXT", "「じゃんけんぽんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010106010006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ふははははは！　私の勝ちだなぁ！　それでは……そうだな、オボロ！　こ\nちらにこい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010106010007" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「はい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010106010004" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「じゃ、こっちはダイヤナだ！　いいかぁ！　チームに入ったからにはしっか\nりやれよ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ええ～？　めんどくさ～い」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010106010003" ]},
	{"command":[ "SETCHARA", "0", "char_00000601_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「……まさかとは思うがお前ら、校庭でドッジボールなんかやるつもりでいる\nんじゃないだろうな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010106010005" ]},
	{"command":[ "SETCHARA", "0", "char_00004901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「訓練は模擬弾とダミーの武器を使うとはいえ、怪我をしないとも限らん！　\n安全かつ真剣にやるように！　本部に帰るまでが訓練だ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010106010006" ]},
	{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「長官も、もしかして担任の先生気分なんじゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010106010003" ]},
	{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「……コホン！　それでは訓練を開始する！　陣地を交代しつつ、２回戦勝負\nだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010106010007" ]},
	{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
	{"command":[ "EXIT" ]}
	]
}