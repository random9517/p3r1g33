{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0101" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_011" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "と、言うわけで……なぜか荒れているセレーナをなだめ、本部に引き揚げてか\nら、あらためてハルノブたちと顔合わせをする。", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈ・Ｍサムライ" ]},
		{"command":[ "SETTEXT", "「隊長たちとはすでに会っているが、こちらは我が最強のファーマーサムライ\nクラン『ザ・ハンド』の客分、ハルノブだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_020114990001" ]},
		{"command":[ "SETCHARA", "0", "char_00014502_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「どうもです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110114990001" ]},
		{"command":[ "SETCHARA", "0", "char_00000511_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈ・Ｍサムライ" ]},
		{"command":[ "SETTEXT", "「これからは彼女も、拙者ともどもインクレディブル・スクワッドに助太刀い\nたす。ドーゾ、ヨロシク！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_020114990002" ]},
		{"command":[ "SETCHARA", "0", "char_00014502_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そりゃありがたい。よろしく頼むぜ、ハルノブ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「あなたからそんな風に気安く呼ばれるのは気に入りませんが、仲間なので我\n慢してやるです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110114990002" ]},
		{"command":[ "SETCHARA", "0", "char_00000511_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「仲間？　そいつが？　はっ！　ふざけんな！　さっきはわたしらの足を引っ\n張りやがったくせに！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010114990001" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「まだ吠えてるですか、キャンキャンうるさいですね、バカ犬は」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110114990003" ]},
		{"command":[ "SETCHARA", "0", "char_00000511_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「てめえ！　やんのかゴラァ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010114990002" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「セレーナ！　いいかげんにやめないか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010114990001" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうだぞ！　おまえさっきから、なにをカッカしてんだ。ちょっと落ち着け\n！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「なんだよカツマ！　あいつの肩持つのか！？　だったらいいよ、わたし、も\nう辞めた！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010114990003" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お、おい！　セレーナ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「おまえらだけで勝手にやってろ！　わたしはあいつと組むのなんか……ぜっ\nたいにごめんだからなーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010114990004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おい！　セレーナ！　ちょっと待てって！　セレーナっ！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「あ。セレーナが行っちゃった。これ、いったいどういうことだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_010114990001" ]},
		{"command":[ "SETCHARA", "0", "char_00022601_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「縄張りを守ろうという本能かもしれませんね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_010114990001" ]},
		{"command":[ "SETCHARA", "0", "char_00022701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「あんたもしかして、とりあえず『縄張り』とか言っとけば、説明した気にな\nれるって思ってない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_010114990001" ]},
		{"command":[ "SETCHARA", "0", "char_00022801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「それはともかく、仲間たちの反応を見てみましょう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_010114990002" ]},
		{"command":[ "SETCHARA", "0", "char_00022701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あーあ、行っちゃった……カツマちゃんが責めるから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010114990001" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「不出来なご主人で、ご迷惑をおかけいたしております」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010114990001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「困ったもんだな、隊長にも」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010114990002" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「って！　俺のせいかよ！？　最初に言いだしたのは長官でしょ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「前回はカツマさんがいなくなったと思ったら、今回はセレーナかぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010114990001" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、それ言われると弱いけどさ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「まあとにかくだ。下僕！　なんとかしろ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114990001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「やっぱりそう来たか……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「あたりまえじゃないか、隊長なんだから。とにかく、あとのことは頼んだぞ\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010114990003" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うううう～……めんどくせぇ～！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「さて、とんでもない仕事を丸投げされたカツマ隊長ですが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_010114990003" ]},
		{"command":[ "SETCHARA", "0", "char_00022701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「見てて胃が痛い……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_040114990001" ]},
		{"command":[ "SETCHARA", "0", "char_00015604_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「ここから彼は、信じられないような行動を取るのです！　後半はＣＭの後で\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_010114990004" ]},
		{"command":[ "SETCHARA", "0", "char_00022701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「なんだよＣＭって！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_040114990002" ]},
		{"command":[ "SETCHARA", "0", "char_00015604_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}