{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0041" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「わたしみたいな、ダークエルフのえっちなおねえさんに誘われて……のこの\nこデートに来ちゃうなんて……本当に、あなたって良い人だねぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0203101" ]},
		{"command":[ "SETCHARA", "0", "char_00019502_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「えぇ～？　からかってるんじゃないよぉ。嬉しいの！　わたしもね……あな\nたのこと、すっごくすっごく気に入ってるし……好きだから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0203102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「だからいつもみたいに、お部屋でえっちするのもいいんだけど～。今日はち\nょっと面白い事を考えたの。わたしがえっちな服を着てるじゃない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0203103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「それで……。って、説明ばっかじゃつまらないよね。教えてあげるからこっ\nちに来て？　ぜ～ったい損はさせないから……。えぇ～い♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0203104" ]},
		{"command":[ "SETCHARA", "0", "char_00019502_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「はいっ、じゃぁ～ん☆　人気のない路地裏で～、ラケシスおねえちゃんと二\n人っきり……えっちなおっぱいで遊んじゃおう～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0203105" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00019502_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「ふふふっ、驚いたぁ？　このお洋服、胸が簡単にまろび出るようになってて\n～。ほらね？　脇から揉んだり触ったり、やりたい放題なんだよぉ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0203106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「この服を見つけた時に、すぐあなたの顔が思い浮かんで～。早く見せたいな\n、えっちなことしたいな～って思って呼んだの。いいでしょう～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0203107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「ふふ……♪　素直なおちんちんが、もうビッキビキに勃起しちゃってるね。\nおいしそぉ……わたしのおっぱいが、このおちんちんを食べちゃいま～す」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0203108" ]},
		{"command":[ "SETIMAGE", "0", "still_00019502_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「んっ♪　気持ちいい♪　おっぱいの先っちょの～……乳首でおちんちんを刺\n激するやり方って、乳首ズリって言うんだって。変な言葉だよね～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0203109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「あなたはモテモテだから～、普通のパイズリじゃつまんないかなって思って\n工夫したの♪　わたしの乳首……興奮するとすぐに硬くおっきくなるから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0203110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「これで、おちんちんをぷにぷにクニクニしてあげるね～……。んっ……♪　\nやぁだ、これ……結構感じるかも、ゾクゾクするぅ……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0203111" ]},
		{"command":[ "SETIMAGE", "0", "still_00019502_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁっ……♪　色んな角度でプニプニしたりぃ……あふっ♪　尖っ\nたところ、尿道口につぷつぷ入れたり出したりぃ……ふふふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0203112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「おちんちんを思いっきり胸の先にめりこませたりぃ……。なかなか斬新で面\n白いでしょ？　おっぱいのフワフワじゃなくて、乳首のコリコリが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0203113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「おちんちんをくすぐって、つっついて……。あ、そうだ♪　言い忘れてたん\nだけど～。こうやって乳首をいじくりまわしてると……んっ、ああんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0203114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「んふぅうっ♪　ふぅうううっ……♪　あぁあん♪　母乳っ……母乳が出ちゃ\nったりするんだよぉ……。あははっ、びっくりした？　んんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0203115" ]},
		{"command":[ "SETIMAGE", "0", "still_00019502_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「え？　妊娠してるんじゃなくて、これは魔法のおクスリの効果だよ♪　今日\nのデートのために、手に入れて飲んでおいたボニューデマクール……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0203116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「これってらぶらぶなカップルのためのおクスリなんでしょ？　人間の国って\nすごいよねぇ。母乳まで自由自在に操っちゃうんだから……ほら、ほら♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0203117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「あっま～い香りと優しいまろやかさ……。んっ……。母乳って、浴びてるお\nちんちんもあったかくって気持ち良くなれるし……わたしの方もね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0203118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「びゅっ！　びゅっ！　って勢いよくおっぱいの先端から熱い雫が飛び出す瞬\n間……おっぱいから射精してるみたいな不思議な快感が駆け抜けてくの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0203119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「それが今までにない快感で……♪　楽しいなって♪　えへへ♪　母乳乳首ズ\nリ、路地裏でのえっちな秘め事……忘れられないプレイになりそうでしょ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0203120" ]},
		{"command":[ "SETIMAGE", "0", "still_00019502_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「だから続けるよぉ？　はぁっ……はぁ、はぁっ……あっ♪　あっ、あぁん…\n…あんっ……♪　母乳のぬくもりをいっぱい感じてね……。んんん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0203121" ]},
		{"command":[ "SETIMAGE", "0", "still_00019502_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「くちゅ、ちゅぷ、ぷちゅっていやらしい水音が聞こえるね♪　あなたのカウ\nパーと私の母乳……絡み合って、おっぱいでエッチしてるみたい……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0203122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「はぁい♪　わたしのおっぱいオマンコで、好きなだけやらしくなっちゃって\nねぇ……♪　うん、腰を振ってもいいよ？　味わうように、打ちつけて♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0203123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「……あっ♪　ふふふっ、激しすぎておちんちんズレちゃう……乳首から外れ\nちゃうよぉ……♪　あっ♪　おっぱいの重みで押し潰しちゃお……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0203124" ]},
		{"command":[ "SETIMAGE", "0", "still_00019502_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「あっんっ、んっんんっ……♪　んふっ……♪　ねぇ、なんだか……えっちな\nおしくらまんじゅうしてるみたいだね♪　おっぱいとおちんちんで」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0203125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「押し合って、揉みあって……二人で興奮して、火照った肌をぶつけて、こす\nって……。あっ♪　あっ、わたし好きっ、これ、これ好きぃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0203126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「あなたも、どんどん腰が速くなってく……♪　うふふっ、可愛い……可愛い\n♪　わたし、一番えっちな顔をあなたに見せるから……あなたも♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0203127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「わたしに、えっちな姿みせて……♪　んっ♪　ふふ、スゴい……♪　おちん\nちんから滲み出すにゅるにゅる、増えてきた……わたしの母乳も……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0203128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「ここ……っ♪　ここ、路地裏だよぉ？　お外でこんなに興奮して……ダーク\nエルフのおねえさんの乳首でおちんちん気持ち良くするなんていけないんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0203129" ]},
		{"command":[ "SETIMAGE", "0", "still_00019502_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「や～らしい♪　えっち♪　えっちぃ……♪　って、それはわたしも同じだよ\nね……♪　あっ、んっ、誘ったのもわたしだしぃ……あんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0203130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「わたし、刺激的なことが好き、なのっ♪　いつでもおっぱいドキドキさせて\nいたいのっ、おまんこじゅわ～って濡らしていたいの……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0203131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「それで、それでね♪　叶うなら……興奮する相手は、えっちする相手はあな\nたと……あなたのこの、強～いおちんちんがいいの、本当だよぉ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0203132" ]},
		{"command":[ "SETIMAGE", "0", "still_00019502_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「あなたもっ、あなたのおちんちんもわたしと……わたしのおっぱいを好きに\nなってくれたらうれし……っ、うれしいの♪　もっと、もっと味わって♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0203133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「あはっ♪　おちんちん……すっかりわたしになついてる♪　ぐりぐりおっぱ\nいに頭をすりよせて……うんうん、可愛い可愛い……大好き♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0203134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「イっていいよぉ？　イッちゃうよーなこと、わたしにされてるんだから……\nイクのが自然なことなんだよ♪　せーし全部吐き出しちゃおっか♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0203135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「あ♪　あっ……一緒に♪　一緒にイこうねぇ♪　おっぱいっ……乳首コリコ\nリになってるのわかる？　わたしもイッちゃう寸前なんだよ……ほらぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0203136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「んぁふっ！　んんん～～～～～♪　精液ぃ！　精液びゅるぅって当たってる\n！　乳首にどぷどぷ流れてく、る……熱いよぉ……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0203137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019502_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「あッ♪　あっ♪　おっぱいおかしくなる、おかしくなるぅ……！　あなたの\nザーメンっ……わたしの乳首に当たって気持ちいい……気持ちいいっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0203138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「ふぁあああああ……♪　うっとりしちゃうような大量の精子……♪　わたし\nの母乳より色が濃いね、それにべっとりしてて……すごく臭い♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0203139" ]},
		{"command":[ "SETIMAGE", "0", "still_00019502_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「でも……それが好きなの♪　はぁあああ……♪　恍惚の瞬間ってこういうこ\nと……？　あっ……！　ぷるんっておっぱいにもかかってる……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0203140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「い～っぱい気持ち良くなってくれたみたいでうれしい……♪　んふふ……♪\n　なんだろ、すっごく心が満たされていく感じ……♪　ふふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0203201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「やっぱり……精液って母乳と違って、こってりしてて……臭いもつよぉい…\n…♪　この臭いがいやらしくて、本能をビンビン疼かせるんだよねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0203202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「……ぬりぬり……ぬりぬり……♪　ふふふっ、精液を乳首で塗り広げるのっ\nて新感覚……。ヌルヌルねちゃねちゃしてて、やめられない……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0203203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「……人が来ちゃう可能性、段違いに上がっちゃうけど……。もう一度だけ、\nこのまましない？　うん、乳首と……今度はおっぱいも加えて……ふふふ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0203204" ]},
		{"command":[ "SETIMAGE", "0", "still_00019502_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「やだって言ってもしちゃお～っと……♪　まだまだ終わりになんてしてあげ\nなぁい……。だって、こうしてエッチするの楽しみにしてたんだもん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0203205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「もう出ない、枯れちゃう、精魂尽き果てちゃう～ってあなたがギブアップす\nるまで……いつまでもしてあげる♪　はじめるよぉ……ちょんちょんちょん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0203206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「んふふふっ……。尿道口を丁寧に刺激……。ちょん、ちょん、ちょん……ぐ\nりぐりぐり……ぬぷっ♪　ぬぷっ……くにくにくに……あぁんん……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0203207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「これっ、わたしの方が感じちゃって続けられないぃ……♪　乳首って敏感す\nぎて……もどかしいなぁ。あなたも……協力して？　ん、ピストン♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0203208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「ズンズンぐちゅぐちゅってわたしのおっぱいを……あっ♪　そうやってこね\nくりまわして……。あんっ……うん……すごく上手い……そのままぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0203209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「んんっ♪　んぅっ……♪　んっ……んん……♪　リズムを合わせて……あぁ\n♪　ぉっ……♪　んっ……！　ふふふ、心臓押されてヘンな声出ちゃった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0203210" ]},
		{"command":[ "SETIMAGE", "0", "still_00019502_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「わたしも力いっぱいあなたのおちんちんに胸をこすりつけるね……♪　っぁ\n……♪　んん……♪　精液があると、さっきよりよくぬめるぅ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0203211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「あっ♪　やだ、かなり気持ちいいのきたぁ……♪　あぁ……だめ、だめかも\nぉ……！　あっ♪　おっぱいだけでイッちゃいそ……あぁあんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0203212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「んっ！？　んんんぁあ……ッ！　はぁああぁっ♪　イッ……♪　ああああっ\n……！　だめ、だめ、イクとまた母乳……母乳溢れて……ああああんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0203213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「ごめ、んなさい……っ！　おちんちんに母乳たくさんかかって……あぁあっ\n！　だ、出しすぎよね……！　気持ち良くて……止まらないのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0203214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「やぁんん……！　絶対クセになっちゃったぁ、乳首でイクのぉ……！　もう\nこうなったらぁ、あなたも乳首ズリ大好きな変態さんにしちゃうんだからぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0203215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「っぁ……♪　あっ、あぁん……！　肉と肉がぶつかりあう音……♪　柔らか\nいおっぱいと、硬ぁいおちんちんが交じり合う音ぉ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0203216" ]},
		{"command":[ "SETIMAGE", "0", "still_00019502_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「夢中になって、こんなところでおっぱい交尾しちゃってるわたしたちって、\n盛りすぎてて危険だよねぇ……♪　でも……でもこのままするのぉ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0203217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「ッぁ……！？　今、おちんちんがビクビクゥって震えたぁ……♪　うん、出\nしたいの？　どうしよっかなぁ～？　出させてあげよっかなぁ～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0203218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「なんて、もちろん良いよぉ♪　……わたしも母乳、ぴゅっぴゅするから、恥\nずかしくないよ……。はぁ、はぁ……っ、もっと、もっと混ぜて……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0203219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「お外で思いっきり射精すると最高に気持ちいいんだから……。ね♪　ね♪　\n一緒にぃ……一緒にイこ♪　あっ……あぁ、イ……く、イくぅううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0203220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「あっ♪　あはっ……そうなのねぇ、やっぱりお胸が一番いいのねぇ……♪　\n嬉しいっ……たっくさん出して……受け止めちゃうから～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0203301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019502_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「あはっ……、あなたってぇ何度でも無限に発射できちゃうタイプなのかなぁ\n？　あれだけ出したばかりで、すぐにこの量だもん……すっごぉい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0203302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「んんん～っ♪　んふっ♪　ふぁああ……♪　見てぇ？　わたしのおっぱい…\n…乳首も乳房もぜーんぶ真っ白に染められちゃったぁ～～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0203303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「あっ、あっ……！　ドロリ濃厚なザーメンが♪　わたしの胸の輪郭をなぞっ\nて……つたって流れてく……♪　熱いの、熱いのキてるぅ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0203304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「この瞬間がいいのっ……。男の人の欲望がわたしのおっぱいに注がれて、わ\nたしのぬくもりと１つになってく夢みたいな時間……素敵ぃ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0203305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「ふふふふ……♪　どうかな～？　あなたのドロドロでヌルヌルになったおっ\nぱい……♪　自分でもねぇ、思うんだ？　エッチだな～って……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0203306" ]},
		{"command":[ "SETIMAGE", "0", "still_00019502_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「ん……。わたしぃ、あなたの粘着力の強い精液がだ～い好き……♪　だって\n、せっかくの精子だよ？　出来るだけこぼしたりしたくないもん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0203307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「えへへ……♪　ぴっちり胸にはりついてくるこの子たち、わたしのおっぱい\nが好きなのねぇ？　よーしよーし、素直で良い子でちゅねぇ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0203308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「ずーっとずーっとラケシスおねーちゃんのおっぱいにくっついてていいから\nねぇ～♪　……なんちゃって。でも、半分本気かも」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0203309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「わたし……いつだって、あなたの精液まみれになっていたいの♪　それは…\n…おっぱいだけじゃなくて……ふふ。これからも期待してるね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0203310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「ひゃぁんっ！？　あぁんっ、あんっ……♪　お顔～……？　お顔に出すのが\n良かったのぉ～……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0203401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019502_01_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「あんっ、んんっ、んんん～～～～♪　すごいねぇ、いくらでも精液出せるん\nだね……かぁっこいい～♪　ますます大好きになっちゃいそう～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0203402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「うんっ、うん、うん♪　もっと……もっとかけて♪　わたしのお顔にかけて\nぇ……♪　ああ……この臭い、すっごく好きなの……蕩けちゃう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0203403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「シャワーみたいにドパドパぶっかけて、スッキリ気持ち良くなってねぇ……\n。あっ……♪　今の角度、良かったぁ……かかった感覚が生々しくて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0203404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「あぁ、精液だぁ～ってうっとりしちゃうぅ～♪　あんっ♪　あんっ……♪　\nいっぱいありがとぉ～。二回目なのにこんなに出してくれるなんてぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0203405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「ね～えぇ？　これってぜーんぶわたしが舐め取って、飲んじゃっていいのか\nな～？　もしそうだったら、すっごく嬉しいんだけど……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0203406" ]},
		{"command":[ "SETIMAGE", "0", "still_00019502_01_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「……見てて？　ん～～～、れろっ……れろ……ぺろ♪　ん～～～♪　おいし\n～い……♪　これが今日、わたしに出してくれた精液なんだぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0203407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「せっかくのラブのこもったプレゼントだもん……。無駄にしちゃったらもっ\nたいないよねぇ？　ということで～、いただきまぁ～す……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0203408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「ごくっ……ごく……♪　あ～ん♪　脳が痺れるぅ……。ごめんねぇ、もっと\nザーメンまみれのわたしの顔、見てたいよねぇ～？　でも……」", "NORMAL" ]},
