		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「やっぱり我慢できないかも……？　夢中でぺろぺろしちゃう……うふふっ。\nエッチなダークエルフでごめんねぇ～？」", "NORMAL" ]},
