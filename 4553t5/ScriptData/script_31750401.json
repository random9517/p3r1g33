{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0128" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「あっ、パパー。ほーら、こっち、こっち。早く来てってばー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0403101" ]},
		{"command":[ "SETCHARA", "0", "char_00017504_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「そうそう、緊急事態だったの。だから、呼んだんだケド？　てことで、お疲\nれさま」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0403102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「えっ、机の上に座るのはお行儀悪いって？　まーまー、いーじゃん。これか\nらもっとお行儀悪いコトするんだし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0403103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「どういう意味かって？　すぐ分かるって。ほら、もっとこっち来てよ。そう\nそう、もうちょっと近くまで……えやっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0403104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んっへへー、つーかまえたっと！　油断したわね、パパ！　もう捕まえたか\nら離さないし！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0403105" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00017504_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んふふ……何となくウズウズしちゃってたからぁ、パパにして欲しくなっち\nゃったんだよねー。ほら、見て……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0403106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「もう、準備しとこうと思ってさ。ね……パンツなんてとっくに脱いじゃって\nるワケ。どう、よく見える……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0403107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ほら……いーよ、ヤムのオマンコ……もっとアップで見せたげるんだから…\n…ね、どうなってる？　ヤムのオマンコ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0403108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んふ……せーかい。ずっとウズウズしてて……パパが来る前からもう、ちょ\nっとだけ……濡れちゃってたし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0403109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「で……そんなエロ娘の、オマンコを目の前に見て、パパは……どういうコト\nしちゃうのかな～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0403110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んひぁんっ！　あんっ、あっ、ふっ……そぉっ、あっ、んんっ……これっ、\nあっ、パパの舌がっ……ペロペロ……してるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0403111" ]},
		{"command":[ "SETIMAGE", "0", "still_00017504_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んふぁぁ……あふっ、これぇ……めちゃくちゃ気持ちいーの……んっ、カラ\nダの力……抜けてっちゃうぅぅぅ……ふぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0403112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「はんっ、あっ、んんっ……！　んふふ……めっちゃ遠慮なく舐めて来るし…\n…パパのスケベ……ヘンタイ……ひゃ、ふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0403113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「あっ、はぁんっ！　本気で……クリとかっ……舐めてっ、あっ、来てるしっ\n……！　あんっ、あっ、あひっ、はあぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0403114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「そ、そうだし……ヤムが……んっ、して欲しいから……パパに……オマンコ\n、クンニされてぇ……はふぁ……んくぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0403115" ]},
		{"command":[ "SETIMAGE", "0", "still_00017504_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「だからっ……ヤムも……スケベで……あふっ、へ、ヘンタイかもぉっ……ひ\n、ぅんっ……あっ、んくぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0403116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んんっ、うん……乳首……めちゃくちゃジンジンしてるぅ……こうしてね、\nんっ、指で触ると……ピリッてするカンジ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0403117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ヤバ……指……止まんないカモ……んっ、こーして……ずっとコリコリして\nたい……はんっ、あっ、おっぱい……感じるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0403118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「あふっ、パパぁ……奥の方も……来て……んっ、もっと……れろって……い\nっぱい舐めてぇ……んぁぁ、そこぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0403119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「うん……ヤムの好きなとこぉ……もう、パパには全部バレてるし……ひぅっ\n、ヒダヒダのとこ……気持ちいいー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0403120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ちょっ……においかぐのはっ……ちょっとヤバくない……？　んっ、やっ、\nそりゃ……鼻はすぐそこだからっ、仕方ないケドっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0403121" ]},
		{"command":[ "SETIMAGE", "0", "still_00017504_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「そんな……わざわざ言わなくてもっ……！　んふっ……あっ、あぁっ……メ\nスガキのニオイとかっ、知らないしっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0403122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「はぅんっ……ふっ、んふっ、あはっ、はぁっ……そんな、音させて……吸わ\nなくてもっ……ハズい……く、んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0403123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「マジ……パパ……スケベすぎぃ……あふぁ……ワレメから……オマンコ汁…\n…どんどん出てきちゃうってばぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0403124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んっ、はふっ……んくっ……あっ……やだ……ヤメちゃダメ……なんでっ…\n…ちゃんとしてってばぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0403125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「言うコトって……それって……あ……ハズい……おねだりしろって……コト\n……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0403126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んっ、それはぁ……でも……あっ、うん……分かったってば……ちゃんと言\nうからぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0403127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「パパ……お願い……ヤムの……イキたがってるメスガキオマンコぉ……パパ\nの舌で……もっとレロレロしてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0403128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「またトロトロになってるオマンコの中ぁ……パパにいっぱい気持ちよくして\n欲しいのぉ……あっ、あひゃうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0403129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んぁぁっ……また、舌……入ってきたぁっ……！　そこっ、あぁっ、そこぉ\nっ……！　オマンコっ……弱いとこぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0403130" ]},
		{"command":[ "SETIMAGE", "0", "still_00017504_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ひぁぅっ……手が止まんないっ……おっぱいもっ、どんどん気持ちよくなっ\nてっ……！　ひぁぁっ、すごすぎぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0403131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「はぅんっ……パパぁっ……んっ、あぁっ、ヤムのいじめてっ！　ふひぃっ、\nクリトリスっ……ビクってなるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0403132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「あふぁっ、奥から……またムズムズするのっ、出そうになってる！　このま\nまされたらっ、ヤムっ……イッちゃうからっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0403133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んひぁっ、いいのっ！？　イッていいんだっ……うんっ、もっ……ガマンし\nないしっ……このままっ、最後までしてっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0403134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「そこっ、あぁっ、オマンコレロレロされてぇっ……ヤムっ……もっ、ダメっ\n……あはぁんっ、ダメぇぇぇぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0403135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ひゃふぁぁぁぁんっ！　んぁっ、イクッ……！　イクイクイクッ！　んひぁ\nぁぁっ……あぁぁっ、出るっ……出るぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0403136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017504_01_05" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「はへぁぁ……オマンコのお汁……いっぱい飛んでる……ヤム……潮吹きしち\nゃってるんですケドぉ……はひぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0403137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んあぁぁ……ヤバぁ……これ、気持ちよすぎぃ……アタマ……ぽーっとして\n、何も考えらんなくなるぅ……ふぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0403138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……はぁ……潮吹き……止まったぁ……はふぁ……はぁ、はぁ…\n…んはぁ……はぁぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0403139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んっ……うん……めちゃくちゃ気持ちよかった……こんなの、病みつきにな\nっちゃうじゃん……ヤバいよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0403140" ]},
		{"command":[ "SETIMAGE", "0", "still_00017504_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「はふ……んっ……あっ……！　えっ……パパ、ちょっ……何して……ま、ま\nた……舌が、あっ、動いてるんですケド……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0403201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んんっ……！　ここからが……本番……？　あ、ひっ……！　で、でもっ…\n…その、オマンコ……まだイッたばっかで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0403202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ひゃっ、んふっ……！　あっ、び、敏感になってるからって……あぁぅっ、\nや、優しく……んんっ、あっ、んふぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0403203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「あひぁ……これ……さっきのともっ……違う感じ……はひっ、あぁっ……ん\nんっ、パパの舌が……ぬらってぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0403204" ]},
		{"command":[ "SETIMAGE", "0", "still_00017504_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「わ、分かんない……ケド……でも、あっ……なんか、もっと奥の方から……\nジワって出るような感じっ……んんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0403205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「このまま、されたら……はぁっ、んんっ……ヤムのオマンコ……本気でヤバ\nい感じになっちゃいそぉ……ぅ、あっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0403206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「乱れてるとこっ……みたいって……バ、バカぁ……また、ワザと……恥ずか\nしいことっ……もう……十分、見せてるしっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0403207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「え……自分でもっと乳首……コリコリ……させるの……？　んふっ……んぅ\nぅっ……こ、こう……あっ、あぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0403208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ウソ……おっぱいまで……さっきより、すごく……感じるの……んくっ……\nあっ、んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0403209" ]},
		{"command":[ "SETIMAGE", "0", "still_00017504_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んくぅ……はぁっ……ピンって弾くと……ビクってなるの……くぅぅっ……\nは、反対側も……はひっ、すごっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0403210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「やっ、ふっ……んぁっ、オマンコと一緒にしたらぁっ……もっと来るっ……\nうくぅんっ、パパ……してっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0403211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ヤムのオマンコ……もっとペロペロしてっ……ひぁぅっ！　あっ……いひぃ\nっ！　んぁぁっ、それぇっ、ひぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0403212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「あっ、あぁァァっ！　また……奥に入ってるっ！　パパの舌がっ……深いと\nこまでっ、ひぅっ、きゅぅぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0403213" ]},
		{"command":[ "SETIMAGE", "0", "still_00017504_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「に、逃げてないっ……！　逃げてないけどっ！　あっ、舌……されたらっ、\n腰が……勝手に動いちゃうからっ……ふひっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0403214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「やらっ、声……出ちゃうっ！　み、見つかっちゃうっ……！　しょこっ、ひ\nっ、弱くなってるしっ……くひぃんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0403215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「あぁぁっ……あひぃっ、きっ、気持ちいいっ……けどっ……でもっ、ダメに\nなっちゃうっ、これっ、ダメになるからぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0403216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「なってっ……いいのっ？　はひっ、あぁっ、うんっ……！　なるかもっ……\nそれっ、あっ、もぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0403217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ダメっ……またすごいのっ、そこまで来てるっ！　来ちゃうからっ、もぉっ\n、あぁっ、もぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0403218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「パパっ……あぁっ、ヤムっ……ダメっ、一回止めてっ！　じゃないとっ、あ\nっ、出ちゃうのっ、なにか……出ちゃうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0403219" ]},
