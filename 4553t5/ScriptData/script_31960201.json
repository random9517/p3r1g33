		{"command":[ "SETIMAGE", "0", "still_00019602_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「あぁ♪　あぁ、あぁあ……！　おにーさん、おにーさんはまだ！？　ねえ…\n…イッてるおっぱいにかけて、精子かけて……ぶっかけてぇ……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0203220" ]},
