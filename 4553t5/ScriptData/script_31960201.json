		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「ぶびゅっぶびゅって出てるのすっごいわかる、感じ取れるぅ……！　精液の\nっ、精液の質感……敏感に感じ取ってる……おクスリ、お薬スゴいぃい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0203302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「ん～～～～～♪　母乳……母乳出しながらクスリでおっぱいキメイキさせら\nれるっ、なんて……んぁあああ♪　ダークエルフの恥だよぉおお♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0203303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「でも、でも、気持ちいいのっ……おっぱい全部気持ちいい……！　ああああ\nあっ♪　こんなのっ、こんな快感知っちゃダメでしょぉおお……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0203304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「絶対絶対良くないぃ♪　でも……それがっ……ンンっ、快感……快感なのぉ\n……！　あっ、あぁ……ああっ、おっぱい溺れちゃうってばぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0203305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「あ……ッ……♪　ふぁああ……♪　むせかえるくらいのオスのニオイ、ニン\nゲンの精液のニオイぃ……。あたしの胸、マーキングされちゃったぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0203306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「んふふふっ♪　自分でもドン引きしちゃうくらい出ちゃったんじゃな～い？\n　はぁっ、はぁっ……♪　ま、アーちゃんがそれだけ魅力的だっていうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0203307" ]},
		{"command":[ "SETIMAGE", "0", "still_00019602_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「……ボニューデマクールの威力が凄まじかったっていうか……。きゃははは\nっ♪　まだまだあたしの知らない面白いことっていっぱいあるんだね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0203308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「こんなドキドキして、ムラムラして……エッチぃ気持ちになれるから……。\nおにーさんをからかうのってやっぱやめらんない……ぷぷぷ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0203309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「これからも、いろーんなイタズラでぶびゅぶびゅ射精させてあげるからぁ…\n…アーちゃんだけに注目しててよね？　や・く・そ・く♪　んふふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0203310" ]},
