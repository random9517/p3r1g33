		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「ひゃんっ！？　あンっ……あぅっ、はぷっ……！？　あっ、か、かけたくて\nかけてるのぉ……！？　アーちゃんのエロ顔をドロドロにしたくてぇ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0203403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「もぉ～っ……！　ヘンタイヘンタイドヘンタイ～っ……！　やっ！　あっ、\n髪にかけるのはおちないからダメぇ……！　顔も臭くなるからヤだぁ～っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0203404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「あっ♪　あっ、あ……！　んん……！　なんであたし……ぃ、自慢の美貌に\nぶっかけられて母乳……出しちゃってるんだろ、っあぁっ、ふぁあっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0203405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「だからっ！　ゴーインだからぁあ～っ……！　ううううう……うぁああん…\n…！　こんな事、他のヤツにはぜーったい許さないんだからっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0203406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「でも……んぷぷぷ♪　おにーさんが、アーちゃんを独り占めしたくて、カワ\nイイお顔に射精したかったって言うなら許してあげてもいーかな……♪」", "NORMAL" ]},
