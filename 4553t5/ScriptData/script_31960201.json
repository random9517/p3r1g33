		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「暴発……っていうより、狙ってかけてたもんね？　アーちゃんのお顔に精子\nぬりぬりしたかったんでしょぉ？　それって超独占欲じゃん……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0203408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「バカみたいな量出しちゃってさぁ～♪　精液でパックされちゃったみたいじ\nゃん～♪　それとも、ナマイキなメスガキへのお仕置きのつもりなの～？」", "NORMAL" ]},
