{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0041" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「ね～ね～え～、おにーさぁん。おにーさんってばぁ～。ねーねーねー、そん\nなトコロで何してるのぉ～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0203101" ]},
		{"command":[ "SETCHARA", "0", "char_00019602_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「んふふっ。労働中？　へぇ～。今日はすっごくマジメに働いてるみたいじゃ\nない。で～も～そういう風にお堅くされると～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0203102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「アーちゃん、邪魔したくなっちゃうんだよねぇ♪　ね～ねぇ、サボっちゃお\nうよ～。そんでさ……あたしとア・ソ・ボ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0203103" ]},
		{"command":[ "SETCHARA", "0", "char_00019602_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「ふふふふ……♪　こんなとこでさぁ、ぼーっとしてるなんて……ワル～いメ\nスガキに何されちゃっても文句言えないってことわかってるぅ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0203104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「ちょうどヒマしてたところだったし……少しだけ遊んで欲しいな～？　とか\n言って……もちろん、ノーなんて言わせないけど……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0203105" ]},
		{"command":[ "SETCHARA", "0", "char_00019602_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「あのさぁ、この服……おにーさんから見てどう思う？　んふっ……服よりお\nっぱいが気になる？　そうかもだけどよーく見てよぉ……いいでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0203106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「童貞を殺す服、なんだって～コレ♪　ニンゲンのオスを興奮させるマジック\nアイテムみたいなモノ？　男を挑発するヤバすぎな衣装らしくてさぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0203107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「……おにーさんに見せたかったの。そんでもって～……この服着たままでイ\nタズラしちゃおって思ってたんだぁ。だって、面白いじゃんか☆」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0203108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「ね～え？　こういう服好き～？　はっきり言ってよぉ。どうなの～？　カワ\nイイ～？　んぷぷっ……オチンチンはしっかり勃起してるけど？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0203109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「これって洋服がイイから？　それともアーちゃんのメスガキっぱい……ロリ\nロリ巨乳おっぱいが好きだからぁ？　どっちどっち～？　早く教えてよぉ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0203110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「答えるまでチンポ挟んで、おっぱいゆっさゆっさしてやるんだから。ゆっさ\nゆっさゆっさ～、ゆっさゆっさゆっさ～……ありゃりゃりゃ～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0203111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「……アブナいレベルでガチ勃起してきてるんですけど♪　なにこれ～？　こ\nんなんなっちゃったらもう、後戻りできなくない？　ちょっと大きすぎぃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0203112" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00019602_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「そっかそっか。アーちゃんのやわらかおっぱいぷにぷに責めとぉ～。この服\nのコンボは、おにーさんを容易く殺せちゃう威力ってことね、りょうか～い」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0203113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「んふっ♪　それなら、着た甲斐あったよねぇ。……で・も……♪　アーちゃ\nんのイタズラは、おにーさんの想像より更にもいっこスゴいから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0203114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「ちょっと乳首にちゅーもくして見ててくれる？　っン……っ、んんっ……ふ\n、ぅ……♪　乳首をねぇ……？　こうやって、ぇ、オチンポにぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0203115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「絡ませながら……。ンン、結構刺激していくじゃん……？　こすり、つけて\n……あっ、性的なシゲキ与えて……。そうするとぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0203116" ]},
		{"command":[ "SETIMAGE", "0", "still_00019602_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「はぁんんんン……♪　こーやって、母乳っ……母乳出てくんのぉ。す、スゴ\nくない……？　エッチでしょ……すっごいやらしいよねぇ……？　あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0203117" ]},
		{"command":[ "SETIMAGE", "0", "still_00019602_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「なん、か……おにーさんを驚かせたくってさぁ……♪　考えたの。コレ……\n。で、ボニューデマクールってクスリを手に入れてさぁ……？　あっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0203118" ]},
		{"command":[ "SETIMAGE", "0", "still_00019602_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「ここに来る前に飲んできちゃった……♪　知ってる？　性的快感を感じると\nぉ……。はぁ、はぁ♪　乳首からぴゅっぴゅ母乳が出るクスリ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0203119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「これねぇ……？　胸自体の感度もかなり上がるらしくって……ちょっと怖か\nったけど、どーっしても使ってみたかったの。ぷぷぷ、だってさぁ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0203120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「おにーさん、ぜーったいビビっちゃうし、チンポバキバキにしちゃうんだろ\nーなーって想像したらおっかしくて。絶対見たいって思ってさぁ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0203121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「んッ……♪　そしたら、想像通り……ううん、予想よりイイ反応もらえたか\nら……やった♪　って♪　イタズラ大成功～ってめちゃくちゃ嬉しい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0203122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「ね～え～？　母乳だよ～？　アーちゃんみたいなぁ、幼いダークエルフのお\nっぱいから……。フツー妊娠してないと出てこない母乳が出てきてるの♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0203123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「ぴゅっぴゅっ、ぴゅぅっ、ぴゅぅ～って……♪　見ててもエッチだし……匂\nいもさ？　やさし～くて甘くってトロ～ンとしちゃう良い匂いしない～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0203124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「んでもって……。はぁっ♪　こうやってパイズリ、してると……♪　潤滑油\nのかわりになるし、股間もおっぱいもトロトロで最高でしょ～……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0203125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「いつもと違う感覚っていうか……あっ、なんだろ……？　コレ、ハマっちゃ\nう、かも……たのし……♪　んふっ……胸の上でぷるぷるぷる～って……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0203126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「はぁっ……はぁ、はぁ……♪　なんだろ……、顔が熱くなってくる……。も\nしかして、ボニューデマクールってヤバいおクスリ……？　あっ……あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0203127" ]},
		{"command":[ "SETIMAGE", "0", "still_00019602_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「なん、か……パイズリ、やめらんなくなってくる……。あっ♪　んん……っ\n、んっ、んっ、んっ……気持ち良さがこう、マイルドっていうか……。あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0203128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「それなのに脳みそがトロトロ～ンって蕩けてきちゃう……っ♪　あッ♪　は\nぁっ……、はぁ、はぁ……おにーさん、おにーさぁん……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0203129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「おっぱい、イイ……？　アーちゃんの生意気ロリっぱい気持ちいい……？　\nはぁ、はぁっ……あっ、ぁっ、あっ……ホント夢中になってくるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0203130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「オチンポデカすぎて、挟むのも動かすのもタイヘンなのにぃ……ムニュムニ\nュしたくてたまんない……♪　あっ……なに？　なに、怖い……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0203131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「乳首ビンビンになってきた、しぃ……！　おっぱい全体、ジンジン熱いし…\n…！　チンポの変化もよ～くわかるぅ、すっごい伝わってくるよぉ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0203132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「ん、もぉ……！　これじゃあミイラとりがミイラになっちゃってるしぃ……\n！　あっ♪　やばっ、きもちぃ……♪　あんっあっあっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0203133" ]},
		{"command":[ "SETIMAGE", "0", "still_00019602_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「あはは……♪　あたしのおっぱいがムレムレになって感じまくってると……\nおにーさんのオチンポもビッキビキに硬さを主張してくるねぇ……っ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0203134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「あっ♪　やっぱり心地いい？　ロリ母乳ダークエルフパイズリぃ……♪　や\nぁだ、ホントやらし～♪　はぁ、はぁ、ドスケベぇ……♪　んっんんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0203135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「あは♪　チンポ、びっくんびっくん痙攣してるじゃぁん……♪　いい、よ…\n…？　母乳ロリっぱいに射精しちゃってもいいよ？　それそれぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0203136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「きゃはぁああっ♪　あはっ、あはははっ♪　出た出たぁ♪　びゅるるるっ♪\n　やっばい♪　も～簡単に精液搾り取られちゃってるしぃ……エロぉい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0203137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019602_01_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「いいよ、いいよ……んんっ！　かけてよぉ、その方がこっちもこーふんする\nぅ……♪　あっ、なんて絞り出しやすいチンポなのぉ、ホント好きぃ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0203138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「おにーさん、おにーさん、オチンポからミルク溢れ出ちゃってましゅよぉ～\n？　メスガキ母乳にす～ぐ屈服しちゃっておもしろ～い♪　んっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0203139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「ほぉら♪　尿道に残ってるのも、タマタマで待機してる精液もぜーんぶひり\n出して♪　こう？　こう絞られると全部出る？　あはっ、イイよぉお……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0203140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「くふぅうううう～……♪　濃厚な精子のニオイぃ……♪　くっさぁいい♪　\nうっとりしちゃう～……♪　そうなんだぁ、パイズリ良かったんだぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0203201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「だぁってぇ、真っ白いジュレみたいなぁ♪　ゼリーみたいな精液大量にかか\nってるんですけど？　あたしの胸、もーべっちゃべちゃなんですけど？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0203202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「んふふふ……。街中でさぁ、カワイイカワイイアーちゃんのおっぱいに中出\nしして、ぶっかけしたこの始末……ど～やってつけてくれるのかなぁ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0203203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「え？　あたしが誘って勝手にパイズリしたんだろって？　せ～いかい♪　で\nもさぁ……それっておにーさんがエッグいオチンポしてるのが悪いし♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0203204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「あたしを本気にさせるエッチおちんぽ持ってること自体、まず罪だし……。\nあ～♪　そ～だぁ♪　このまま……おっぱいエッチ続けよっかぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0203205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「えぇ～？　返事なんか聞いてないし～？　アーちゃんがするっていったらす\nるの～！　ほぉれ……ほれほれぇ～♪　乳圧責め、乳首攻めだよぉ～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0203206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「ザーメンぬるぬるチンポはもう、アーちゃんのモノだから……♪　逃がして\nあげないし、離してあげないよ……ってか、どこにもいきたくないよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0203207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「んっ……♪　色んな液体でにゅるにゅるのおっぱい……あははっ♪　興奮し\nてまた母乳滲みだしてきちゃう……。ね……♪　もっとしよ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0203208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「ぐっちゅぐっちゅにゅっぷにゅっぷって……♪　はぁっ、おっぱいで本番し\nちゃってるみたいな、はずかし～音立てて、オチンポまさぐるね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0203209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「いじって、勃起させて、おっきくして……んんっ。こうやってズリズリして\nぇ……♪　んふふふっ、いつまでもつか楽しみ～ぃ……♪　ん、ん、ん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0203210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「あれぇ？　なんかさっきより太くなってきてるんですけど！？　どうしてか\nなぁ～？　アーちゃんわかんない～♪　あはははっ♪　硬すぎぃ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0203211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「もう、こっちの谷間からガンガンはみ出して、きちゃってるし……欲張りな\nオチンポだよねぇ～♪　あはっ、かわいい～。ホント大好きぃ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0203212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「うんうん♪　メスガキおっぱい、みずみずしくて気持ちいいよねぇ？　母乳\nっ……あまぁいミルクまでつけちゃってるんだから……。はぁ、はぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0203213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「これ以上の……あんっ、パイズリなんて存在しえないでしょ♪　……あっ♪\n　おにーさんのオチンポも……過去最大級に勃起してるし、最高……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0203214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「肉と肉とのぶつかりあい、だね♪　超気持ちいい……♪　んんっ、あっ、あ\nっ、あぁ……！　っンン……！　や、やめらんない……あっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0203215" ]},
		{"command":[ "SETIMAGE", "0", "still_00019602_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「もうなんか、おっぱいっ……♪　自動でパイズリする機械みたいになってる\nっ、ザーメン絞り機だよっ、こんなの……！　あっ……や、やばいぃ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0203216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「また……母乳っ、母乳出るかも……！　ねえっ……！　なんかアーちゃんの\n方が先にイクかもっ……！　はぁっ、や、やだぁ、なにこれぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0203217" ]},
		{"command":[ "SETIMAGE", "0", "still_00019602_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「すっごい感じ、るぅ！　ああああっ♪　ぴゅるって！　ぴゅるって母乳出た\nぁ♪　乳首の先っ……気持ちいいの、熱くて……あぁ、また、また出るぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0203218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「出るッ……出る、出るぅ……出りゅうぅうう♪　あ～～～～♪　ぴゅっぴゅ\nっ出てるっ……あっあっあっ♪　パイズリで、イってるぅあたしぃ……っ」", "NORMAL" ]},
