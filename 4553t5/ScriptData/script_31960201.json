		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「んぉおお♪　おほッ……♪　ん、ほ……♪　ひゅ、ひゅごいぃい……！　二\n回目のぶっかけ、一回目の全然ち、がう、すっごい熱いぃい♪」", "NORMAL" ]},
