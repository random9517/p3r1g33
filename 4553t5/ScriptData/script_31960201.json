		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「ああっ、これこれぇっ……って、あれっ！？　ちょっ……そっちは違っ……\nきゃああんっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0203401" ]},
