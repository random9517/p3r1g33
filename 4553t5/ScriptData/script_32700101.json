{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「隊長さん、お呼びですか？　なんのご用でしょう……なんて、ふふ、この部 \n屋を見れば隊長さんのお求めなんて一目で分かります」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0103101" ]},
		{"command":[ "SETCHARA", "0", "char_00027001_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「クライアントの要求を言われずとも察するのもビジネスパーソンの努め…… \nそれに、隊長さんはずっと私のここを見てましたものね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0103102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「なにって……とぼけなくてもいいんですよ。うふふ、男の人の視線って、そ \nちらが思うよりバレバレですからね。私のこの胸、釘付けでしたよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0103103" ]},
		{"command":[ "SETCHARA", "0", "char_00027001_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「いいんですよ。私はサキュバスですからね……殿方が惹かれるのも無理はあ \nりません。どうです、このおっぱい、大きいでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0103104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「サキュバスの中でも大きくて形がいいって、自慢なんですよ。え、このおっ \nぱいでしてほしい？　うーん、それはいいんですけれど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0103105" ]},
		{"command":[ "SETCHARA", "0", "char_00027001_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「サキュバスのパイズリって、普通とは違ってザーメンだけじゃなくて精気… \n…気力も搾り取っちゃうものですよ。隊長さん、ミイラになっちゃうかも」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0103106" ]},
		{"command":[ "SETCHARA", "0", "char_00027001_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「え、それでもいい？　そうですか……それじゃあ、どうなっても知りません \nよ。一度始めたら、止まりませんからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0103107" ]},
		{"command":[ "SETCHARA", "0", "char_00027001_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「ふふ、そんな笑顔で頷かなくても……それじゃあ、よいしょっと……ほら、 \n隊長さん、これが見たかったんでしょう？　私のお、っ、ぱ、い」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0103108" ]},
		{"command":[ "SETCHARA", "0", "char_00027001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「やんっ！！　ふふ、もうガッチガチじゃないですか。私をこの部屋に呼んだ \nときから期待してたんでしょう？　いいですよ、よくありましたから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0103109" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00027001_01_01" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「私の身体を見た男の人って、皆同じように考えるみたいで……ふふ、何回も \n何回もお誘いを受けましたよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「まずはお食事、次におしゃれなバー、最後にホテル……いつもいつも同じで \n。だから今回の呼び出しはちょっと変わってるって思ってるんですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0103111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「でも、こっちの方はどうかしら。皆、私を抱こうとして鼻息を荒くするんで \nすけど、いつもいつもパイズリで終わっちゃうんですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「隊長さんのこの立派なチンポはどうかしら。サキュバスのパイズリ、味わわ \nせてあげますね。んっ……しょっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0103113" ]},
		{"command":[ "SETIMAGE", "0", "still_00027001_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「あんっ、んっ、もう、ちょっとおっぱいでハグするだけで、チンポが暴れて \nる。最初からこれじゃあ、身体が保ちませんよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「ほら、ほら、おっぱいでチンポをこねこね、ぎゅっぎゅって、マッサージし \nたら……ふふっ、隊長さん、気持ちよさそうな顔してます……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0103115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「それじゃあこんな風に、密着したまま動かないのはどうですか？　隊長さん \nのチンポと私のおっぱい、温かさと柔らかさと硬さ、伝わるでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0103116" ]},
		{"command":[ "SETIMAGE", "0", "still_00027001_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「んふふ、もどかしそうにチンポがぴくぴく動いてますね……密着おっぱいハ \nグはお嫌いですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「ふふ、冗談、冗談ですよ。今は密着よりも、こっちですよね。んっ、ふっ、 \nんんっ、やんっ、ほら、大人しくしてください。チンポステイです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「んんっ、ふっ、もう、暴れん坊なチンポですね。そんな悪いチンポにはこう \n……んっ、くっ、んうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0103119" ]},
		{"command":[ "SETIMAGE", "0", "still_00027001_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「おっぱいで締めつけながらパイズリするの、いいでしょう？　きっつきつの \n谷間でぎゅっぎゅってこすって、揉んで……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「んふふっ、おっぱいの中でチンポの形が分かりますよ……亀頭が大きくて、 \nカリ首も高くて……何人の女の人を虜にしてきたのかしら。んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0103121" ]},
		{"command":[ "SETIMAGE", "0", "still_00027001_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「でも、今は私のおっぱいがチンポを虜にする番です。ほら、ほらほら、サキ \nュバスのパイズリ、たんと味わってください……んんっ、ふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「くにゅくにゅって、溶けてしまいそうでしょう？　隊長さんもチンポ動かし \nて、んっ、ああっ、あんっ！！　そうです、腰をぶつけて、んうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0103123" ]},
		{"command":[ "SETIMAGE", "0", "still_00027001_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「ああっ、顔が、隊長さんの顔が、んんっ、気持ちよさそうで……私も感じて \nきちゃった……んっ、ふうっ、ああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「んふうっ、こうして胸の先端をこりこりってしたら、んんうっ！！　ふふっ \n、おっぱいがまた熱くなってきたでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「谷間に汗が浮かんで、それがにゅるにゅるってまた変わったパイズリになっ \nて……チンポがまた違った密着して……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「カリ首がおっぱいをごりごりと削ってるの、分かります？　ふうっ、んっ、 \n隊長さんのチンポからも、お汁が漏れて……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0103127" ]},
		{"command":[ "SETIMAGE", "0", "still_00027001_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「ふうっ、汗とお汁が混じってまた変わってきましたね……ふうっ、んっ、先 \n端、指で弄ったら私も気持ちよくなってきた、あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0103128" ]},
		{"command":[ "SETIMAGE", "0", "still_00027001_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「ふっ、あっ、んっ、隊長さんのチンポ、暴れ方が分かってきましたよ、んっ \n、ほら、ぎゅってしたら跳ねるから、そこを押さえて、やんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「こうすれば、腰が動いてもチンポがずっとおっぱいと密着して、ふふっ、気 \n持ちよさの逃げ場がないでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「これがサキュバスのパイズリですよ、んっ、んんっ、あっ、ふっ、ほら、隊 \n長さん、気持ちいいの、チンポに全部溜めて、あんっ、ふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0103131" ]},
		{"command":[ "SETIMAGE", "0", "still_00027001_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「気持ちいいの、いっぱい溜めて私と一緒にイきましょう。んんっ、ふうっ、\nあっ 、んんっ、ぬるぬるのおっぱいでごしごしってチンポをしごいて、んっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「谷間でハグしながら揉み込んで、あんっ、ふうっ、んんっ、チンポが熱くな \nってきてます、んんっ、私、私もおっぱい弄ってるだけで、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「イきそう、んっ、ふうっ、ああっ、んっ、あっ、イく、イく、んんっ、パイ \nズリだけでイっく、隊長さんも、イって、ふああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0103134" ]},
		{"command":[ "SETIMAGE", "0", "still_00027001_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「私のおっぱいに、好きにザーメンかけて、汚して、いっぱい出してっ！！　 \nんんっ、あっ、あんっ、イっく、イっくううううううう！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0103135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「ふああああっ！！　んんっ、ザーメンきたあっ！！　チンポからザーメンい \nっぱいきたあっ！！　んっ、ふううううっ、あああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0103136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00027001_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「あんっ、ああっ、んっ、凄い、濃厚で……ふうっ、んんっ、おっぱいの中が \nたぷたぷになって……あんっ、ああっ、まだ出てる……んっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0103137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「いいですよ、全部、隊長さんの気持ちいいの全部出しちゃって……あっ、ん \nっ、ふうっ、んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「私も、乳首弄るだけでイっちゃった……んっ、ふうっ、ああっ、凄い匂い… \n…素敵……あくっ、んんっ、んっ、気持ちよかったですか、隊長さん？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0103139" ]},
		{"command":[ "SETIMAGE", "0", "still_00027001_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「ふふ、その顔を見れば分かります……良かった、サキュバスのパイズリ、お \n気に召したようですね。あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「それじゃあ……満足していただけたなら、リピーターになってもらわなきゃ \nですから……もう一回、ね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0103201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「ほら、さっきのザーメンでまた違った感触と音になってるでしょう？　隊長 \nのチンポでザーメンまみれのおっぱいまぜまぜしてください、んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「あんっ、あふうっ！！　ふふ、さっき出したばかりなのにもうガッチガチ… \n…素敵。男の人はそうでなきゃ……んんっ、んっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0103203" ]},
		{"command":[ "SETIMAGE", "0", "still_00027001_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「大抵の人はパイズリ一回だけでもう絞り尽くされちゃうから……隊長さんみ \nたいなチンポなら、奉仕のしがいがありますね、ふっ、うっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0103204" ]},
		{"command":[ "SETIMAGE", "0", "still_00027001_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「んうっ、んっ、私もまた、先端を指で……ふうっ、あっ、凄い、おっぱいの \n中に直接挿入されてるみたい……んんっ、あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0103205" ]},
		{"command":[ "SETIMAGE", "0", "still_00027001_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「おっぱいもチンポもどろどろで、私の身体に溶けていってるみたいで……ん \nっ、隊長さんも、気持ちよさそうな顔……ふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「ぐちゅぐちゅってチンポとおっぱいでザーメンがかき混ぜられて、んっ、濃 \nさも、匂いも、精気もたっぷりで……あっ、ふうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「こんなのを中に出されたら、一回で赤ちゃんができちゃいそう……チンポも \n、ザーメンも素敵……んっ、あんっ、ふあっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0103208" ]},
		{"command":[ "SETIMAGE", "0", "still_00027001_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「んっ、出されたザーメンが乳首まで垂れてきて……んんっ、指先までぬるぬ \nるに、ふうっ、んんっ、あはあっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「あんっ、隊長さん、そんなに腰をぶつけたら、私の心臓までチンポ届いちゃ \nう、んっ、あんっ、おっぱいの奥まで突かれてる、んんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0103210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「あうっ、あっ、凄い、こんな、こんなチンポ初めてっ！！　こんな人がいた \nなんて、あんっ、あっ、あっあっあっ、あうううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0103211" ]},
		{"command":[ "SETIMAGE", "0", "still_00027001_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「気持ちいいっ！！　おっぱいこすられてるだけで気持ちいいっ！！　んんっ \n、あっ、ふうううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「隊長さんも、私のおっぱいで気持ちよくなって！！　隊長さんなら、好きに \nしていいからっ！！　あんっ、ああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0103213" ]},
		{"command":[ "SETIMAGE", "0", "still_00027001_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「このいやらしいサキュバスザーメンおっぱいでチンポ気持ちよくなって、ん \nんっ、あっ、あくうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0103214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「あっ、ああっ、あんっ！！　おっぱいの中で、またチンポが膨らんでるのが \n分かるっ！！　んんっ、出すのね、またおっぱいに出すのねっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0103215" ]},
		{"command":[ "SETIMAGE", "0", "still_00027001_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「いいわっ、いっぱい出してっ！！　私のおっぱい、隊長さんのザーメンで染 \nめ上げてっ！！　ふあああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0103216" ]},
		{"command":[ "SETIMAGE", "0", "still_00027001_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「私、私も一緒にイくから、隊長さんともう一回一緒にイくから、んんっ、ザ \nーメンまみれの乳首こりこりってしてイくからあっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「ああっ、んっ、ふうっ、あっ、チンポが、ごりごりっておっぱいけずって、 \n暴れて、跳ね回って、んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0103218" ]},
		{"command":[ "SETIMAGE", "0", "still_00027001_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「おっぱいがオマンコみたいにチンポを入れられて、んんっ、自分で乳首を弄 \nって、んっ、あああっ、あっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「イくっ、おっぱいとチンポでイくっ、んっ、ふあああああああああああああ \nあああああああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「あくううううっ！！　あっ、ああっ、出てるっ！！　またおっぱいにザーメ \nンどぴゅどぴゅされてるっ！！　あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0103301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00027001_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「さっきよりも、もっと熱い……んっ、どくどくしてる……ふうっ、んっ、お \nっぱいがザーメンで溺れちゃいそう……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「んんっ、凄い……ふふっ、見てください、おっぱいがザーメンで真っ白…… \n谷間なんかもう、ねばねばで糸を引いちゃってます……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0103303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「ほら、こうしておっぱいを寄せたら、ザーメン溜まりができて……んんっ、 \n凄い匂い……香りから精気が吸えそう、んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0103304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「ふうっ、ふっ、んっ……ふふ、隊長さん、いっぱいいっぱい、気持ちよくな \nりましたか？　ふふっ、私も気持ちよくなっちゃいました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0103305" ]},
		{"command":[ "SETIMAGE", "0", "still_00027001_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「チンポをパイズリしたのと、胸を弄っただけで……んっ、ふっ、こんなに感 \nじたの、初めてです、ふうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0103306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「今までは精気をもらっても、気持ちよくなるなんてなかったのに……よっぽ \nど相性がいいのかもしれないですね、私のおっぱいと隊長さんのチンポ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0103307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「こんなにいっぱい出された事もなかったし……素敵なチンポとザーメンでし \nたよ、隊長さん。んっ、最後の一滴までおっぱいに……ふうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0103308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「おっぱいにかけられただけで、妊娠しちゃいそう……んっ、濃さも、量も、 \n匂いもこれまでで一番……おっぱいだけで味わうなんて勿体ない……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「ね、今度は下のほうで……オマンコで隊長さんのチンポ、味わいたいな…… \nふふふ、お願いします、ね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「あんっ！？　あ、チンポ抜けちゃう、チンポ抜けたらだめっ、ああっ、んん \nんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0103401" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「あうううっ、顔に、熱いっ、こんな濃厚ザーメン顔にかけられらたら、あう \nっ、ふっ、だめ、匂いで、匂いでもイっちゃう、んんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0103402" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00027001_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「あふうっ、匂いでイっく、ううううううっ！！　はっ、はっ、口にも、入っ \nてきてる、んっ、んくっ、んうっ……おいし……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0103403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「顔にザーメンパックしてもらって……んっ、お肌艶々になりそう……んんっ \n、まだ出てる……ふうっ、あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0103404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「んうっ、隊長さん、嬉しそうな顔……女の顔にかけるのがお好きなんですね \n。私の顔でよければ、いつでもかけていいですよ、やんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0103405" ]},
		{"command":[ "SETIMAGE", "0", "still_00027001_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「今の一言でまたザーメン出てきた、んっ、ふっ……ふふ、サキュバスを喜ば \nせる素敵な射精ですね、あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0103406" ]},
		{"command":[ "SETIMAGE", "0", "still_00027001_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「ふう……こんなにべっとりとつけられたら、サキュバスじゃなくても私が隊 \n長さんの女だって分かっちゃいますね。ふふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0103407" ]},
		{"command":[ "SETIMAGE", "0", "still_00027001_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「それとも、誰が見ても分かるように、顔とおっぱいだけじゃなく、お腹も、 \n背中も、手足も、全部ぶっかけちゃいますか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0103408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「なんて。でも、オマンコの中にぶっかけてほしいっていうのは、本当ですよ \n。隊長さんの濃いザーメン、たっぷりと出して欲しい……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0103409" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「もちろん、おっぱいでも顔でも、どこでもいいですよ。私、隊長さんのザー \nメンが好きになっちゃったみたい。だから……これからもお願いしますね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_0103410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}