{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「この服どうかな？　かわいい？　あーしに似合ってる？　隊長さん好み？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0203101" ]},
		{"command":[ "SETCHARA", "0", "char_00009902_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「って、聴くまでもないみたいだね。隊長さんのチンポ、な～んにもしてない\nのにガチガチになってるし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0203102" ]},
		{"command":[ "SETCHARA", "0", "char_00009902_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「あーしを見てそんなに興奮しちゃった？　まったく。隊長さんって、ほんと\nスケベだね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0203103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「それでこそ隊長さんって感じだけどね～。折角だし、このままいいことしち\nゃおっか♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0203104" ]},
		{"command":[ "SETCHARA", "0", "char_00009902_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「ふふふふっ、ホントにもうガッチガチだね？　このままあーしのおっぱいで\nパフパフしてあげる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0203105" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00009902_01_03" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「こうして日焼け止めローションでぬるぬるにして、っと……にゅるにゅる、\nしこしこ、しこしこ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0203106" ]},
		{"command":[ "SETIMAGE", "0", "still_00009902_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「ふふっ、軽くしごいただけなのに、そんなに気持ちいいの？　おっぱいの中\nで隊長さんのチンポ大暴れしちゃってるよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0203107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「顔も真っ赤にして、だらしなく蕩けて……なんか玩具みたいでおもしろーい\n♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0203108" ]},
		{"command":[ "SETIMAGE", "0", "still_00009902_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「そかそか。隊長さんはそんなにあーしのおっぱいが好きかぁ……ほらほら、\nたぷたぷたぷたぷ、にゅるにゅるしこしこ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0203109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「どうせなら情けない喘ぎ声も一緒に聴かせてよ。男の人でも気持ちよくなっ\nたらアンアン喘ぐんでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0203110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「流石にそれは恥ずかしいって？　えぇ～、いいのかなぁ？　素直に言う事き\nいてくれないと……これ、やめちゃうよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0203111" ]},
		{"command":[ "SETIMAGE", "0", "still_00009902_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「あははっ♪　なーにその情けない顔。うそうそ、そこまで意地悪なことしな\nいってば♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0203112" ]},
		{"command":[ "SETIMAGE", "0", "still_00009902_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「でも、隊長さんの可愛い喘ぎ声が聴きたいのもほんとだよ？　気持ちよくし\nてあげてるんだから、あーしのお願いも聞いてほしいな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0203113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「お！　さっすが隊長さん、わかってるぅ～♪　いいよ、約束だもんね。い～\nっぱい気持ちよくしてあげる♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0203114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「にゅるにゅる、しこしこしこしこ……ほらほら、まだまだ早くするよ！　お\nっぱいふよふよ、しこしこ、しこしこ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0203115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「えへへ、ガチガチチンポがますます真っ赤に腫れあがってきたねぇ♪　みっ\nともなくビクビクしててキモーい！　かわいいー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0203116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「匂いもすごいことになっちゃってるね……あはっ、隊長さんもしかしてもう\nイッちゃいそうなの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0203117" ]},
		{"command":[ "SETIMAGE", "0", "still_00009902_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「ほらほら、今更隠すことなんて何もないでしょ。正直に言っちゃいなよ～♪\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0203118" ]},
		{"command":[ "SETIMAGE", "0", "still_00009902_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「そうそう、素直が一番だよ！　でも、それだけじゃ物足りないなぁ？　そう\nだなぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0203119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「『美人でかわいいシャラク様のおっぱいで、私のみっともなく大きくなった\nチンポをいっぱいしこしこしてください。プリーズ！』って言ってもらおうか\nな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0203120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「気持ちよくなりたいなら言えるよね？　『チンポをいっぱい苛めて下さい、\nシャラク様』だよ……ほらほらぁ、正直になっちゃお？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0203121" ]},
		{"command":[ "SETIMAGE", "0", "still_00009902_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「きゃはは！　ほんとに言った！　隊長さんってば恥とかないのかな？　正直\nちょっとドン引きだよー♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0203122" ]},
		{"command":[ "SETIMAGE", "0", "still_00009902_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「でも、素直でかわいい隊長さんは嫌いじゃないよ♪　ちゃんと言えたご褒美\nに、もっとイイことしてあげるね？　ほーら、しこしこ、ぱふぱふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0203123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「チンポを根元から押さえて、ぎゅ～！　にゅるにゅる、しこしこ、しこしこ\n……あはっ、なるほど、この動きが好きなんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0203124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「どう？　気持ちいい？　チンポの反応を見てたらすぐにわかるんだけど、ど\nうせなら隊長さんの口からも直接聞きたいなぁ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0203125" ]},
		{"command":[ "SETIMAGE", "0", "still_00009902_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「あははっ！　どんどん素直になっていくねぇ。いいよいいよ、もっと感じて\nアヘ顔晒して、隊長さんのかわいい姿を見せて？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0203126" ]},
		{"command":[ "SETIMAGE", "0", "still_00009902_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「ぱふぱふぱふ、にゅるにゅるしこしこ……こすこすこすこす……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0203127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「え？　もっと強く圧迫するように？　左右に振り回すように激しくして欲し\nいって？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0203128" ]},
		{"command":[ "SETIMAGE", "0", "still_00009902_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「もぉ～、我儘な隊長さんなんだから。でもでも、お願いを聴いてほしかった\nら、どうすればいいか、分かるよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0203129" ]},
		{"command":[ "SETIMAGE", "0", "still_00009902_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「『シャラク様、我慢の効かない私のクソ雑魚チンポを激しくいじめてくださ\nい。プリーズ』って。気持ちよくなりたいなら、言えるよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0203130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「きゃははははっ！　隊長さんもう言われるがままじゃん！　なっさけないな\nぁ♪　でもでも、そんな隊長さんもかわいいと思うよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0203131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「それじゃあ、ご希望通りた～っぷりいじめてあげる！　ほーら！　しこしこ\nしこしこしこしこっ！　これがイイ？　イイんでしょ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0203132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「あれぇ？　隊長さんの先っぽがピクピクしてきたよ？　ふふふっ、みっとも\nない動きだねぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0203133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「ローションを絡めてにゅるにゅる、おっぱいたぷたぷ押し付けてこすこす、\nしこしこ……あはは、ま～たチンポがビクンって跳ねた♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0203134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「こんなに早くイっちゃうの？　我慢できないの？　知ってるよ、隊長さんみ\nたいな人、早漏って言うんだよね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0203135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「ほらほらっ！　このまま出しちゃえ♪　しこしこ、こすこす、しこしこ、こ\nすこす♪　いいよ、あーしのおっぱいの中にいっぱい射精しちゃえ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0203136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「あははっ、出た出た♪　隊長さんのあつ～い精液びゅるびゅるって出たぁ♪\n　匂いもくっさぁ～い♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0203137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009902_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「ほんと、すごい量だねぇ。どれだけため込んでたのさ？　ビクビクってチン\nポが震えて、全然止まりそうにないねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0203138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「それに顔も、ひっどいよぉ？　まさにアヘ顔って奴だ。あー、でも、その情\nけない声は好きかも……うん、かわいいよ、隊長さん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0203139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「えへへ、どうだったあーしのおっぱい。気持ちよかった？　……って、これ\nだけ出したんだもん、聞くまでもないか♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0203140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「それにしても、隊長さんのチンポ、固いままだねぇ。あれだけ苛めてあげて\nも、まだまだ足りなかったのかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0203201" ]},
		{"command":[ "SETIMAGE", "0", "still_00009902_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「あははっ、すっなお～♪　そっかぁ、あんなに臭いドロドロであーしのおっ\nぱい犯したのに、もっといっぱい出したいんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0203202" ]},
		{"command":[ "SETIMAGE", "0", "still_00009902_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「隊長さんってばホント変態だよねぇ～。エッチでスケベで、隊長さんみたい\nな人の事、猿って言うんだっけ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0203203" ]},
		{"command":[ "SETIMAGE", "0", "still_00009902_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「まぁ、いっか。それでぇ？　このままもう一回したい？　あーしにして欲し\nい？　……だったらぁ、どうすればいいか、分かるよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0203204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「あははははっ♪　そうそう、その情けなくてかわいい声が聴きたかったの！\n　隊長さん、上手におねだりできたね～、えらいえらい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0203205" ]},
		{"command":[ "SETIMAGE", "0", "still_00009902_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「さっき出した精液をおっぱいの間でぐちょぐちょ、ぐちょぐちょってかき混\nぜて、っと……ほぉら、またしこしこしてあげるね～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0203206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「ぐちゅぐちゅ、しこしこしこしこ……ふふっ、精液のヌルヌルのお陰で滑り\nが全然違うね。さっきよりもっと激しく動かせちゃうよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0203207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「なるほどねぇ～、こうやって……んんっ……余った皮を巻き込むようにして\n、おっぱいでずりゅずりゅするのが気持ちいいんだね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0203208" ]},
		{"command":[ "SETIMAGE", "0", "still_00009902_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「しこしこしこしこ、ぎゅ～……しこしこ、しこしこ……あははっ、ちょっと\n力を入れるだけで、あーしのおっぱいにチンポがぜーんぶ埋もれちゃうね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0203209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「ま～たかわいい声が大きくなってきた♪　ほらほらぁ、みっともなく蕩けた\n顔もいっぱい見せて？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0203210" ]},
		{"command":[ "SETIMAGE", "0", "still_00009902_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「おっぱいたぷたぷ、しこしこ、しこしこ……あはははっ、隊長さんのアヘア\nヘ～って顔、やっぱりいいなぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0203211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「チンポの先っぽもまた赤黒く大きくなって、ヒクヒクって震えてきちゃった\nね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0203212" ]},
		{"command":[ "SETIMAGE", "0", "still_00009902_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「それに、ビンビンチンポがドクドクって脈打ってるよ。ほんと、なんだか違\nう生き物みたい。ふふっ、キモ～い！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0203213" ]},
		{"command":[ "SETIMAGE", "0", "still_00009902_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「分かるよ、早漏チンポだもんね、もう限界なんだよね？　このまま出したい\nよね？　だったらぁ……こう言ってみてー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0203214" ]},
		{"command":[ "SETIMAGE", "0", "still_00009902_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「『シャラク様、私のみっともない早漏チンポにお慈悲をください。みっとも\nなくびゅーびゅー射精する許可を下さい。プリーズ』だよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0203215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「最後の『プリーズ』までしっかり言うんだよ。どうせなら、その情けなくて\n可愛い声で、こびこびに言ってくれたら嬉しいなぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0203216" ]},
		{"command":[ "SETIMAGE", "0", "still_00009902_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「は～い、よくできましたぁ！　もぉ～、隊長さんってばホントに可愛いんだ\nからぁ♪　いいよ、隊長さんの早漏チンポ、気持ちよくしてあげちゃう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0203217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「おっぱいを両側から締め上げて、っと！　いっくよぉ～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0203218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「しこしこぎゅっぎゅ！　にゅるにゅるしこしこ！　ほ～ら、もっと喘ぎ声出\nして！　いっぱいアンアン言った方が気持ちいいよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0203219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「根元から大きくしこしこ、しこしこ！　いいよぉ、出しちゃえ！　あーしの\nおっぱいに、くっさい精液たっぷり吐き出しちゃえぇ～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0203220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「んあぁんっ！　ふふふっ、出た出た♪　またドクドクって精液出てるねぇ～\n♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0203301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009902_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「オー、二回目なのにこんなに……というか、一回目より多くない？　流石変\n態お猿の隊長さん、底なしだねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0203302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「見て見て、あーしの谷間、精液のプ―ルみたいになっちゃってるよ。ドロド\nロのぐちょぐちょ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0203303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「いや、ほんとにすごい量じゃない？　いっとくけど、おっぱいの谷間にいく\nら射精しても、妊娠したりはしないからね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0203304" ]},
		{"command":[ "SETIMAGE", "0", "still_00009902_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「まぁでも、あーしはかわいいからね、これだけ出すのも仕方ないっていうか\n、当たり前か♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0203305" ]},
		{"command":[ "SETIMAGE", "0", "still_00009902_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「ふふふっ、隊長さん的にこのビキニもストライクだったんでしょ？　そりゃ\nあれだけジロジロ見られたら分かるよー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0203306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「それにしても、ほんとに可愛くてみっともない……いい声だったなぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0203307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「最後なんて甲高い声で『あんあん！　イクゥゥゥっ！！』なぁんて言っちゃ\nってさぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0203308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「ほんと、隊長さんってば、どれだけ苛め甲斐があれば気が済むのかなぁ～♪\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0203309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「いいよ、これからも我慢できなくなったらあーしに言ってね？　気が向いた\nら、た～っぷり苛めて、あ・げ・る♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0203310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「わわわっ！？　隊長さんのチンポが暴れて――んんっ！？　こ、これ、顔に\n……んんんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0203401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009902_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「た、確かに出しちゃえとは言ったけどさぁ！　んんっ！　ちょ、顔にかけ過\nぎ、びゅーびゅーし過ぎだってば！　んんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0203402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「うわぁ……まだ出てる、臭くてドロドロの精液をあーしの顔にぶっかけると\nか……隊長さんってば、なっまいきぃ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0203403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「それにしても……すんすん……精液ってホントにひどい匂いだねぇ。これっ\nて隊長さんだけ？　変態の精液は特別臭いとかあるのかなぁ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0203404" ]},
		{"command":[ "SETIMAGE", "0", "still_00009902_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「ん……やっと治まってきた……こうしてピクピク震えてる姿はかわいいんだ\nけどなぁ……この暴れん坊早漏チンポめ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0203405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「……ところで、あーしに精液をぶっかけた感想は？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0203406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「その満足そうな顔、むかつくなぁ～。苛めるのはあーしの役目！　隊長さん\nはみっともなくされるがままになってればいいの！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0203407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「ふんっ、いいよ～っだ！　隊長さんがそんなド変態でクズやろうっていうな\nら、あーしにも考えがあるんだからね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0203408" ]},
		{"command":[ "SETIMAGE", "0", "still_00009902_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「……隊長さんのみっともない喘ぎ声を、お姉ちゃんたちにソックリそのまま\nチクってあげる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0203409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「へへ～ん、今更謝ってもおそいよ～っだ！　アヘアヘ～って喘いでた事もぜ\n～んぶ話のネタにしてやるんだから！　ふふふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0203410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}