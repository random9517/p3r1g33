{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0129" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「……失礼します。ああ、やっぱりまだ起きていたのですね。私もなぜか寝付\nけなくて……貴方の顔を見にきてしまいました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0103101" ]},
		{"command":[ "SETCHARA", "0", "char_00025501_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「そういえば、貴方は知っていますか？　最近街でひそかに流行しているとい\nう、癒しの薬があることを。実は、それを手に入れたんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0103102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「もし時間があるのでしたら、使ってみましょうか。私は学園長として……い\nいえ、貴方のママとして、いつでも貴方を癒したいと願っているのですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0103103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「うふふふ……♪　なんて素直な子なのかしら。ええ、ええ。いいのよ。私に\n全てを委ねてね……♪　絶対に気持ち良くしてあげますから……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0103104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「……ああ、そうでした。お薬、お薬……。もしかしたら見た事があるかしら\n？　ボニューデマクールというお薬なの。その名の通り……ふふふ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0103105" ]},
		{"command":[ "SETCHARA", "0", "char_00025501_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「女性のおっぱいから、母性の象徴である母乳が出るというお薬だそうよ？　\nさあ、遠慮なく乳首をしゃぶってみてちょうだい。すぐに出るはずだから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0103106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「っん……♪　そう……そうよ、舌先で転がして、ねぶって……♪　あぁ……\n♪　上手よ、いっぱいちゅーちゅーしていいの。たくさん吸ってね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0103107" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00025501_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「あっ♪　あっ♪　くすぐったい……♪　んん？　どうしたの、うっとりした\nお顔をしちゃって……。ルシエルママのおっぱい気持ちいいですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「あったかくて、柔らかくて、甘い香りがする……？　うんうん、好きなだけ\n舐めて、顔をうずめていいのよ。その方が母乳も出やすくなると思うわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「……はぁっ♪　はぁ、可愛い……。そんなに夢中になっちゃって……。そう\nだわ、私もしてもらうばっかりではダメね。ちょっといいかしら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「はい、すりすりすり♪　貴方のおちんちんをこの手でなでなでしてあげまし\nょうね……。さっきから、大きくなっていたの、気付いていたのよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0103111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「こうやって、刺激してほちかったでちゅよねぇ？　おちんちん、良い子良い\n子してもらうの好きでちゅよねぇ？　っんん♪　すごく反応してますよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「敏感で、とっても素敵なおちんちん……♪　でも、ママの赤ちゃんにしては\n長くて、太くて……大きすぎるかもちれまちぇんねぇ。いけない子……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「でも大丈夫でちゅよ。責任をもってしっかりと、癒してあげますから……。\n貴方も気を抜かずに……あっ、おっぱいをレロレロして……んんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「あっあぁああっ♪　見てっ……！　私の胸の先端から真っ白なミルクが……\n！　噂には聞いていたけれど、本当に効果があるなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0103115" ]},
		{"command":[ "SETIMAGE", "0", "still_00025501_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「嬉しい……♪　これで私は本当に、貴方のママになれるのね。っふ……♪　\nふふふふ、飲んで。ママのおっぱいはぜーんぶ貴方だけのもの……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「ほら。ほら、どんどん飲まないと溢れちゃいまちゅよ？　んっ♪　力をこめ\nて、ちゅーちゅーって……あっ！　あぁ、いやだ、気持ちいい……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「あッんん♪　ごめんなさい、勢い余って溢れてしまったわ。飲みやすくなる\nように、おっぱい……お顔に乗せるわね。たぷん、たぷんって……えい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0103118" ]},
		{"command":[ "SETIMAGE", "0", "still_00025501_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「っあぁああああ……♪　すごいっ……！　ちゅぱちゅぱしてもらうのが、こ\nんなに心地いいなんてぇええ……♪　栄養たっぷりのママミルク……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0103119" ]},
		{"command":[ "SETIMAGE", "0", "still_00025501_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「たくさん飲んでおっきくなりまちょうねぇ～♪　ゴクゴク飲んでもらうお礼\nに……ママはおちんちんのミルクをたっぷり作ってあげる。溜めてあげる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「そうしたら交換で、びゅーって出してくれるわよね……♪　っあぁんんっ♪\n　んんっ、んん……！　乳首、乳首がジンジン疼くわ……最高の気分っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「おちんちん、シコシコしてあげる……♪　んんぁ……♪　力をこめないと握\nりきれない、とてつもない大きさ……。こんなにカチコチにして……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「私の手、感じるのね？　ん～♪　よちよちよち♪　身体の力を抜いて、おち\nんちんにだけ集中していいのよ。しこ、しこ、しこ。シコシコシコ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「うふふふ。甘いあま～い母乳を味わいながら、太いおちんちんをいじいじし\nてもらえるなんて、貴方はとっても幸せな赤ちゃんね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0103124" ]},
		{"command":[ "SETIMAGE", "0", "still_00025501_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「可愛いぼうや。どんどんミルクを出してあげまちゅから、なぁーんにも心配\nしないでね……。おいちい？　私のことちゅき？　私は好きよ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「貴方のことがだぁいちゅき♪　っんっ♪　今、おちんちんがピクピク～って\n動いたわ。どうして？　私に愛されて、褒められて喜んでいるのかしら？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……立派なおちんちんをした私だけの貴方……。愛しい貴方……\n♪　こんなことくらい、いつだって何度だってしてあげますからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「んん……！　またピクンって♪　力のこもったやんちゃなおちんちん……♪\n　いたずらしたくて、暴れたくて仕方がないのね。元気ねぇ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「なでなでなでなで♪　すりすりすりすり♪　ぐーっと根元を握って先っちょ\nまで……おててでぐにゅっ♪　ぐにゅっ、ぐにゅ♪　ぐにゅぐにゅう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「あっあっ気持ちいいのねぇ♪　尿道口からエッチな透明のお汁が漏れてくる\n♪　いいのよ。貴方のカウパー、もっと見たいわ。私の手につけて♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0103130" ]},
		{"command":[ "SETIMAGE", "0", "still_00025501_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「貴方の先走りを、指に……手に塗りたくって、ニュルニュルでシゴいてあげ\nちゃいまちゅねぇ……♪　にゅるにゅるにゅる♪　ヌルヌルヌル♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「ふふ、貴方のおちんちんの形……しっかり私の手で記憶するわね。惚れ惚れ\nしちゃうような大きさも……♪　見ているだけで疼いてきちゃう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「っぁっ♪　あんっ、ちょっと反抗的ね♪　だめよ……私の手からは逃げられ\nないの♪　はぁい、クニクニクニ♪　ぐにっ、ぐにっ、ぐに……ふふふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「あら……いよいよたまらなくなってきたみたいね。このまま射精させてほし\nいの？　ん？　上手におねだり出来たらぴゅっぴゅさせてあげまちゅよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「ね……？　ママに言って。ママのおっぱいペロペロしながら白いおしっこぴ\nゅっぴゅしたいですって。どーお？　言える？　うん、うんうん……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0103135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「そっかぁ。じゃあ出していいわよ♪　私が全部受け止めてあげる……♪　頑\n張ってビュルビュルしてみよっか♪　はーい、３、２、１……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0103136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「んんんんっ♪　ドピュドピュドピュって溢れ出しちゃったねぇえ♪　びゅー\nっびゅーっ♪　びゅるびゅるびゅー♪　びゅるびゅるびゅる～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0103137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00025501_01_05" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「一滴残らず絞り上げるねぇ♪　そぉれ……♪　それっ、そーれっ……♪　わ\nぁあ……こんなに限界まで溜めてくれたんだぁ。偉いんだねぇ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「私を喜ばせようと思って、濃くてくさーい精子になるまで我慢ちてくれたの\nねぇ♪　おかげでネバッネバのドロドロジェル精子がたくさん出ました♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「私の手の中でプルンプルンのゼリーみたいになってまちゅよぉ……♪　んん\n、量がすごい。若い男の子ってこんなに欲望を溜めているのね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「それなのに、毎日毎日健気に頑張って……。感心しました。ねえ？　貴方の\n精液の臭いを嗅いでいると……ますます母乳の出が良くなってくるんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0103201" ]},
		{"command":[ "SETIMAGE", "0", "still_00025501_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「どうかしら。このまま続けて、私に甘えてみるというのは……嫌かしら？　\n嫌なんてことはないでしょう？　おちんちんが硬いままだもの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「んっ……♪　一度抜いたくらいでは、スッキリしないのよね♪　私も……ま\nだ満足できていないから、お願い。甘えんぼさんのままでいて……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0103203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「おちんちん、すぐに回復して反り返ってきてる……♪　私の手、好きなの？\n　私は貴方のお口、好きよ……はぁっ、はぁ、両想いね……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0103204" ]},
		{"command":[ "SETIMAGE", "0", "still_00025501_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「あと少しだけ……んっ♪　激しくおっぱいを吸ってもらえるかし、ら？　っ\nあっ♪　そんな感じ……っ♪　いいわ、ぢゅーっぢゅーって吸って！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「ルシエルママね、さっきから、貴方のおちんちんをいじりながら……おっぱ\nいだけでずっとイキそうになってるの。イカせてくれる？　イキたいの♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「っんんん……！　甘噛みして……♪　乳首に軽く歯を立てて……♪　ッうぅ\nううっ♪　いいわ、いいわ……引っ張ってぇ……！　あっあっあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「イッちゃうぅううっ♪　母乳っ……！　母乳がドッと溢れ出すのがわかるわ\n、あぁ……！　胸だけでイカされちゃう、イッちゃうのっ……あ～っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0103208" ]},
		{"command":[ "SETIMAGE", "0", "still_00025501_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「んっうううう♪　ごめんなさい……っ♪　ごめんなさいね、貴方のお口に、\n母乳……いっぱい流しこんで、呼吸出来なくさせちゃって……！　あっあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0103209" ]},
		{"command":[ "SETIMAGE", "0", "still_00025501_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「すごく、すごくイイのっ……！　母乳を吸われて、乳首をいじめられるとす\nぐに絶頂しちゃう……。あぁ、ご奉仕にきたつもりだったのにぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0103210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「貴方の口が、ヌルヌルしていてあたたかくて……どんどん快感にハマってし\nまって……！　んん、苦しくなかった？　ミルクで溺れてなぁい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「んんん♪　ダメなママでごめんなさいねぇ♪　お詫びにおちんちん、もう一\n度ぴゅっぴゅさせてあげなくちゃ……こうかしら？　これでいい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「精子まみれの手のひらで、貴方のおちんちんを撫で回して……それに興奮し\nて、ますます母乳を出しちゃうエッチな女の人でごめんなさいね……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「でもやめられないのっ♪　おっぱい気持ち良くしてもらって♪　おちんちん\nに感謝を伝えているこの瞬間が♪　たまらないの♪　はぁ、はぁ、はぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0103214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「ねえ♪　一緒に気持ち良くなりましょう♪　あぁ……♪　ゾクゾクしちゃう\nぅっ♪　ありあまった母性本能と性欲が、一度に満たされてぇ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0103215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「貴方のこと、可愛くて可愛くてしかたないのっ♪　食べちゃいたいくらいっ\n……あぁあっ、ミルク、おっぱいミルク、お乳飲んでっ……飲んでぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0103216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「あぁ……♪　ママ、またイッちゃいそうよ……♪　貴方のおちんちんも、熱\nが高まっているのを感じるわ。ママが興奮してるの、わかるのね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「賢い賢いぼうや……♪　ねえ、一緒にイッてくれるかしら？　いやらしいマ\nマのおててに、またドクドクって精液発射してくれるぅ……？　はぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0103218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「ん、あぁ、あぁっ……あぁ♪　貴方、私の母乳を飲むのが上手すぎるわ……\n♪　あっ、あっ、ゾクゾクしちゃう……もうだめ、だめよぉ……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「どこに……どこに射精したい？　言って……そうしたら、私もそのタイミン\nグでイかせてもらうわ……！　あっ、あぁ、母乳、母乳噴き出しちゃうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「んっんんんッ……！　我慢しないで！　私の手に出して、出してぇっ……！\n　ああああっ……おちんちんの脈動を直に感じます……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0103301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00025501_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「そうなの、おててに出すの気持ちいいのね……！　私も……あっ♪　いいわ\n、貴方が出しているのがよくわかる、精液が射ち出される熱を感じるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「あ……♪　あぁああ、こんなにおててに射精されたら……臭いがとれなくな\nっちゃうわ、あっ♪　絶対、精子の臭い取れなくなっちゃうぅ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0103303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「私が何をしていてもっ♪　どんなにお堅い仕事をしていても……いつも貴方\nの精液の香りがするなんて……そんなの、淫らな気持ちが抑えきれない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0103304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「あぁあ……っ。ドロッドロね……。二回目なのに、貴方のおちんちんは本当\nに逞しいのね♪　ママの子宮、キュンとしちゃう……はぁっ、はぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0103305" ]},
		{"command":[ "SETIMAGE", "0", "still_00025501_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「これほどの良質な精子を、もし直接胎内に……アソコに注ぎ込まれてしまっ\nたら……妊娠が確定したようなものだわ。だって、この白さ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0103306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「赤ちゃんの種がみっちり詰まってるに決まっているんですもの……♪　でも\n、いけないわ……♪　貴方は私の大切なぼうや、それなのに……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0103307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「私ったら、メスの目で……卑猥な女の視線で見てしまう、なんて……♪　だ\nけど……もし、もしも、貴方も同じ気持ちだとしたら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0103308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「その時は、私……なんでもしてあげたい……。このお汁を、アツアツのまま\nオマンコで飲み干したら……ああっ、あっ、あっ、あぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「やだっ……♪　想像しただけでまた母乳が増えちゃったわ。貴方は罪な人で\nすね……これからもずっと、私をおかしくしてくださいね……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「はぁんんんッ……♪　わ、私の母乳と貴方の精液ぃ……！　もう、どちらが\nどちらかわからないくらいに……あぁ、溢れて、飛び散って……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0103401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00025501_01_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「ぷぁ……♪　んんぁっ……か、顔にかけるだなんて想定外でしたけど……。\nそれだけ興奮して、たまらなくなってくれたということですよね……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「あっ♪　一度出てしまったものは、もう止まらないでしょうからっ♪　ど…\n…どうぞ♪　好きなだけかけてください。あっ、熱い……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0103403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「濃厚な貴方の臭いぃ……♪　んぷ、ぷぅっ、あふっ……♪　ふぁ……♪　す\nごいのね、息をする余裕もくれなくて……溺れてしまいそうよ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0103404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「んっ、んんっ……！　もう、困った甘えん坊さんね……。そんなにたくさん\n出して……。あっ♪　いやっ、目が開けられないくらい……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0103405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「はーっ……♪　はーっ♪　白濁液がシャワーのように降り注いで……こんな\n経験初めてです。いつもこんなに飛距離が出るのですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0103406" ]},
		{"command":[ "SETIMAGE", "0", "still_00025501_01_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「それほどまでに性に貪欲で、体力も気力も精力もあり余っているとしたら、\nとんでもないことだわ。毎日欲求の発散場所を探しているはず……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0103407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「うふふ、恥ずかしがらなくていいのよ。私も同じ……。私だって、たまには\nハメを外して、こうして母乳を出してみたくなったりするの。だから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0103408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「二人の都合が合えば、またこうしてお互いに昂る劣情をなぐさめあいましょ\nうね……♪　貴方に甘えられるの、とってもとっても気持ちがいいわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0103409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「もしも願いが叶うのならば……もっともっと、私のことしか考えられなくな\nるくらいになってくれると嬉しいわ。楽しみに待っているわね……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0103410" ]},
		{"command":[ "WAITINPUT" ]},
