		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「ふぅ……今日も閉店処理は終わったよ。かなり待たせてしまったかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0204101" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「だが、もう邪魔は何もない。朝までたっぷり楽しめるよ……んっ、あっ、ち\nゅぷっ、んふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0204102" ]},
		{"command":[ "SETIMAGE", "0", "still_00016002_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「今日は……随分積極的じゃないか……んっ、ふっ、分かってる……邪魔なモ\nノは全部どけてくれて構わないから……あふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0204103" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETIMAGE", "0", "still_00016002_02_01" ]},
		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「あっ……ど、どうした？　どこに連れて行くつもり……なっ、こ、ここは…\n…あっ、はぁぅんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0204104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「あっ、んぁぁぁ……チンポッ……は、入って来る……！　んっ、だが……こ\n、ここはっ……あっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0204105" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00016002_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「ま、待ってくれ……確かに店は閉めたが……こんな窓際なんて……あっ、中\nは明るいのに……全部、み、見えて……あ、ひっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0204106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「はぁうっ……！　ふ、深いっ……んくぅぅっ……あっ、あぁっ、そんなっ、\nんくぅっ……あ、あぁぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0204107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、根元まで入ってしまった……んくぅ……熱い……んっ、オマ\nンコ……広がるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0204108" ]},
		{"command":[ "SETIMAGE", "0", "still_00016002_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「だ、ダメだ……何を考えている……窓の外は……駐車場で……んっ、誰か…\n…入って来るかも知れないのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0204109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「もし、同僚が忘れ物を取りに戻ったりしたら……あぁ……私は……んっ、ふ\nっ、はぁぁんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0204110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「はぁっ、んっ……ぬ、濡れて来ている……？　それは……違う……別に、見\nられたがっているという訳では……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0204111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「は……ぉぅっ……んっ、あぁ……おっぱい……弄られてる……あぅっ、乳首\nが……しこってしまってる……くぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0204112" ]},
		{"command":[ "SETIMAGE", "0", "still_00016002_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……あぁ……い、いつもより感じやすくなっているなんて……そ\nんな、ことは……あっ、んっ、ふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0204113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「今、ここで激しくされたら……あぁ……ん、くっ……ま、まだか……？　し\n、してしまわないのか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0204114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……欲しかったら、お、おねだり……こ、ここまでしておいて…\n…今更、何を……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0204115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「あっ、ま、待ってくれ……嫌だという訳じゃない……もし見つかったらと…\n…それが、心配なだけで……分かった、ちゃんと言う……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0204116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「お願いだ……私の見られたがってヌルヌルにさせている……オマンコを……\nキミの逞しいチンポでかき回して欲しい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0204117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「表向きは……体面を取り繕っていたが……本当は、見られながらすることを\n期待して……オマンコを疼かせてしまっているんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0204118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「頼む……もっと、激しく腰を打ち付けて……チンポを奥まで感じさせてくれ\n……見られてもいいから……もっとオマンコをかき回してくれっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0204119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「はぁんっ！　んっ、ふぁっ、あぁっ、チンポっ……はひぁっ、太いのっ……\nズンズンっ……来てるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0204120" ]},
		{"command":[ "SETIMAGE", "0", "still_00016002_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「はっ、ふぁっ、くぅんっ、んぁっ、あぁっ……！　あぁっ、いきなり……激\nしくっ……オマンコの中っ、突き回されてるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0204121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「はひっ、あぁっ……おっぱい……こんなに揺さぶられてぇっ……あぁっ、窓\nの外に……見せびらかすみたいにっ……は、恥ずかしいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0204122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「わ、私にも恥じらいの感情はあるっ……んっ、こんな格好で……バックから\nチンポで突かれている姿を誰かに見られたらっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0204123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「あぁっ、か、考えるだけで……胸が高鳴ってっ……あひぃっ！　あぁっ、オ\nマンコっ……熱くなっていくぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0204124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「ふっ、あぁっ、あぁんっ、こんな……明日も……ここで仕事をすることにな\nっているのに……接客や……掃除もっ……なのにっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0204125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「あぁっ、もし……このことを知られたらっ……私はっ……はぁんっ、もう任\n務どころではっ、あっ、チンポっ……奥ぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0204126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「はぁっ、あぁっ……ダメだ……いつも以上に感じてしまってるっ……！　あ\nぁっ、窓におっぱいを押し付けてっ……恥ずかしい姿を晒して……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0204127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「あぉっ、くぅんっ！　オマンコから汁が溢れるっ……！　はぁんっ、ポタポ\nタ……床を汚してしまうっ……んひぃぃんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0204128" ]},
		{"command":[ "SETIMAGE", "0", "still_00016002_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「あぁっ、はぁっ、あぁっ……目の前に火花が散って……も、もうイクっ……\nくぅぅっ……オマンコッ……もう、イクッ……んんんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0204129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「はぁっ、あふっ、あぁっ……イ、イカされた……あぁ……チンポすごすぎる\n……はぁ、はぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0204130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「あひっ！　あぁっ、ま、まだっ……腰っ……止まらないっ……イッてるオマ\nンコっ……ずっとかき回されてるぅっ！　あぉっ、あぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0204131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「こ、こんな……立ってられないっ……足がガクガクしてっ……んふぅっ……\n崩れ落ちそうだ……んっ、んふっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0204132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「もっと……窓にへばりついて身体を支える……そんな……これ以上見せびら\nかすようなことは……あひぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0204133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「んくぁっ！　あぁっ、チンポ来るぅっ！　おっぱい揺らされてっ……！　こ\nのままっ、最後までっ……あっ、されるのっ……ひぁぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0204134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「あぁっ、ずりゅずりゅ……擦られてぇっ……！　で、出るのっ……？　あぁ\nっ、またイクッ！　んぁひぃっ、イクぅぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0204135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「んくぁぁぁぁぁ……中……来てるっ……あぁっ……！　精液っ……オマンコ\nに……入ってきてるぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0204136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016002_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「はぁぁ……熱い……どぷどぷって……流れ込んでくるの……止まらない……\nんふぁぁぁ……あ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0204137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「あぁ……この中出し、すごい……気持ちよすぎて……何も考えられなくなっ\nている……はぁ……はぁ……んっ、ふぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0204138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「隙間から……あぁ……ザーメン……漏れてる……んっ、あぁ……ちゃんと締\nめ付けないと……んふぁ……はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0204139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「んっ、ふぁぁ……見られてるかもって……思うだけで……こんなに気持ちい\nいなんて……知らなかった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0204140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……あぁっ……んっ……あ……チンポ抜ける……んふっ、待って\nくれ……止めないで……もう少し続けて欲しい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0204201" ]},
		{"command":[ "SETIMAGE", "0", "still_00016002_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「んっ、そうだ……まだ足りない……もっと欲しい……んっ、この快感をもっ\nと味わいたい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0204202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「あふっ……も、もし見られてしまってもいい……それより……もっと、オマ\nンコ……気持ちよくして欲しいんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0204203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「またおねだりするから……私の……発情スケベオマンコに……キミのぶっと\nいチンポを挿し込み直してっ……グリグリ……ズボズボして欲しいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0204204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「んぁぁぁぁっ……！　あぁっ、はぁんっ、チンポっ……また来るっ……！　\n太いのっ、バックから届いてるぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0204205" ]},
		{"command":[ "SETIMAGE", "0", "still_00016002_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「ほぉぅっ……あぉっ……くぅぅぅっ……これぇ……このチンポぉ……絶頂オ\nマンコにめり込んでぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0204206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「あぁぁ……食い込むぅ……もっと、激しく……突き回してぇ……あっ、んく\nぁぁぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0204207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「はぁんっ……あっ、あぁっ……今……誰か通り過ぎたような……わ、私の…\n…オマンコ……おっぱいも見られたかも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0204208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「ダメだ……そんな、恥ずかしすぎることぉ……あっ、あぁっ……み、見せつ\nけるなんてっ……でもっ……あぁっ、オマンコ、ジンジンしてっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0204209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「あぁっ、はひっ、あっ、あぁっ、止まらないっ……パンパン打ち付けられて\nっ、おっぱいっ、震えるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0204210" ]},
		{"command":[ "SETIMAGE", "0", "still_00016002_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「あぁっ、窓に押し付けてっ……こんな見せびらかすようなことっ……ダメな\nのにっ、けどっ……いいっ、あぁっ、か、感じるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0204211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「くぅんっ……そ、そうだっ……もう認めるしかないっ……私は……あぁっ、\n恥ずかしいことが大好きなスケベな女なんだっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0204212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「外に向かって……おっぱいもっ、オマンコも見せつけてっ……浅ましく腰を\n振ってっ、汁をこぼしてっ……チンポでよがってぇっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0204213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「なのにっ、それが気持ちいいっ！　あぁっ、見られたくて仕方ないっ……チ\nンポ大好き女なんだぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0204214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「はぁっ、あぁっ、おっぱいもっと揺らすっ……はぁんっ、みっともなくお尻\nをくねらせてっ……ま、またイクっ！　オマンコッ……イクっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0204215" ]},
		{"command":[ "SETIMAGE", "0", "still_00016002_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「んぁぁぁぁぁ……はぁぁ……イキ顔見せてる……あぁ……見てぇ……恥ずか\nしいメスアクメ顔……もっと見てぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0204216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「あひぃっ！　あぁっ……まだっ、もっと激しくっ、んひぁっ！　チンポがっ\n……あぁっ、来てるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0204217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「今……ま、まだイッてる途中なのにっ、こんなっ……続けてっ、んひぃっ、\nイクッ！　続けてオマンコイクのっ、あっ、ひぃぃぃんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0204218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「ラスト……スパートっ……？　あぅっ、くぅっ、んくぅんっ！　あぁっ……\n来てっ……！　キミも出してっ……また、いっぱい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0204219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「私のオマンコっ……かき回してっ、どぴゅどぴゅっ……思いっきり……射精\nっ……してぇぇぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0204220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「くぅぅぅぅぅんっ……！　あっ……またっ、子宮にっ……中出しされてぇっ\n……はひぁぁぁっ、イクぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0204301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016002_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「はぁぁ……熱い……オマンコ……満たされてる感じ……良すぎる……あぁ…\n…最高だ……はふぁぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0204302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「んんっ、チンポ……まだ出し入れされてる……んくぅぅぅん……射精されな\nがらのピストン……すごい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0204303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「全部出して……はぁ……んっ、残さずに……精液出し切ってぇ……あぁ……\nふっ、んくぅ……は……ふぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0204304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「あっ、ふっ……全部……出し切った……？　そうか……はぁ、はぁ……ふぁ\n……あぁ、すご……かったぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0204305" ]},
		{"command":[ "SETIMAGE", "0", "still_00016002_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「あっ……ふっ……あぁ……でも、こんな姿を晒すなんて……私……明日から\nどうしたら……えっ……本当に見られた訳じゃない……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0204306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「あぁ……そ、そう言えば……そう、だったな。なんだか、そんな気になって\nしまっていた……そうか、大丈夫なんだな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0204307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「い、いや……別に本当に見せたかった訳じゃないんだ……ただ、このスリル\nは……刺激が強すぎて……鮮烈だった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0204308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「全く……キミのお陰で、何か目覚めてしまったらどうするんだ？　ちゃんと\n責任を取って貰わないとな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0204309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「ああ、そうだな……またしっかり相手をしてもらわないと……何もかも委ね\nてしまうからな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0204310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「ふぁぁぁぁぁぁぁっ！　あぁっ、おなかぁっ……お尻にもっ……熱いのっ…\n…出てっ……んぅぅぅんっ、またイクぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0204401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016002_02_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「ふぁぁ……身体にも掛けられてぇ……はぁぁ、んっ……全身……精液でドロ\nドロにされていくぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0204402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「あぁ……チンポ……お尻に当たってる……もっと擦りつけてくれ……残って\nいる精液……全部私に塗り込めて欲しい……あぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0204403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「まだ……少し飛んでくる……逞しすぎる……はぁ……はぁ……んっ、絶倫す\nぎるぅ……ふぁ……はぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0204404" ]},
		{"command":[ "SETIMAGE", "0", "still_00016002_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「これで……全部……？　本当か……？　まだ……残したりしていないな……\n？　んっ、なら……いい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0204405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……何とか落ち着いたよ……うぅ……だが……その、冷静になる\nと……かなりとんでもないことをしてしまった気がする……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0204406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「実際に見られた訳じゃない……そ、それは分かっている……ただ、その……\n私の中に、そういうスリルに興奮する癖があるなんて思わなくて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0204407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「いや、本当にそんなつもりはなかったんだ……だが、あぁ……こんな味も悪\nくないと……そんな風に思ってしまった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0204408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「ダメだ……こんな姿を見せるのはキミ一人だけでいい。そこは、間違えない\nでくれ……頼むぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0204409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「だが……決して嫌ではなかった……その、もしキミがいいなら……また、し\nてみても……いいかもな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0204410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}