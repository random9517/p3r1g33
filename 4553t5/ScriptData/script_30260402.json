		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「あぁっ……お腹のとこぉ……おっぱいまでぇ……びゅくびゅく溢れて……あ\nひぃっ……私も……イ、イッて……はぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0404402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「あぁっ……お汁……飛ばしちゃいます……オ、オマンコ緩んで……あぁぁん\n……は、恥ずかしい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0404403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「あふっ、あぁ……ザーメン……オチンポで直接お腹に塗られてます……はふ\nぁ……ゾクゾクっ……しますぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0404404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「んんっ、はぁ、はぁ……お、終わりましたか……？　はひ……あぁ、本当に\nいっぱい出して下さいました……」", "NORMAL" ]},
