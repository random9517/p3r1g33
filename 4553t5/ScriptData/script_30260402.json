		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「はぁぁ……イクっ、ずっとイッてますっ……あぉぉぉっ、オマンコっ……し\nゅごしゅぎてっ……お汁っ、で、出ますぅっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0404302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「あっ、あぁぁぁ……いやっ、オマンコ……漏れちゃうっ……あひっ、は、恥\nずかしいのっ、くぅんっ……らめぇぇ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0404303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「はひぃ……嘘……まだ……出てるんですか……？　あぉぉ……出しながら…\n…まだオチンポ動かすなんてぇ……はへぁぁ……」", "NORMAL" ]},
