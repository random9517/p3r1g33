		{"command":[ "SETTEXT", "「あんっ、ああっ……オチンポもっ……また出そうになってますかっ？　一緒\nにっ、あっ、イ、イケますかっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0404217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
