		{"command":[ "SETIMAGE", "0", "still_00002604_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「はい……お陰様で……なんとか、落ち着いた気がします……で、でも……身\n体に力が入らなくて……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0404406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「すみません……支えて頂いて……もう少しだけ、お願いしてよろしいですか\n……？　はい、こうして抱いて頂けるとホッとします……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0404407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「やっぱり、このバニー衣装は特別みたいですね……貴方の興奮の鼻息が、う\nなじをくすぐって……んふっ、ゾクゾクしましたわ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0404408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
