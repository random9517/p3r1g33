		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「んひぁぁぁぁぁぁっ！　ザーメンっ……熱いのっ……くひぃぃぃっ……出て\nっ……まひゅぅぅぅんっ♪　あぉぉぉっ……！」", "NORMAL" ]},
