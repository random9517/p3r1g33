		{"command":[ "SETIMAGE", "0", "still_00002604_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「あぁ……んっ、やっと……止まりました……んっ、ふぁぁ……この量……本\n当に種付けされたかも知れません……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0404305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「はい……満足致しました……あっ……でも、まだオチンポはもう少しこのま\nまで……勃起が落ち着くまでは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0404306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ、そんなことをしたら、また元気になってしまいますか？　でも\n、その時はその時で……また続きをしていただければ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0404307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「でも、本当にありがとうございました……この衣装を着るようになって……\nずっと視線を感じながら……自分でも持て余していたんです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0404308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「これからは、困った時には貴方にお願いして……私の疼きを鎮めてもらうよ\nうに致しますわ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0404309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「あぁ、もちろん私も……もっともっとご満足いただけるように……技を磨い\nておきますので……また、オマンコ……なさって下さいね♪」", "NORMAL" ]},
