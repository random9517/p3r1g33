		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「あっ……すみません、わざわざいらして頂いて……ご迷惑をお掛けしますわ\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0404101" ]},
		{"command":[ "SETCHARA", "0", "char_00002604_01", "2", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「その、お話と言いますか……ご相談がありまして……この前、貴方へのご奉\n仕をして以来なのですが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0404102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「は、はい……パ、パイズリです……パイズリご奉仕の後から……ずっと、あ\nの時のことが忘れられなくて……身体が火照って……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0404103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「ですから……その、お願いします……どうか、この前の続きをしてくれませ\nんか……私の疼きを貴方のオチンポで鎮めて欲しいんです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0404104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「こ、ここに手を……？　は、はい……後ろから足を開いて……あぁっ、は、\nはしたないポーズで誘えばいいんですね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0404105" ]},
		{"command":[ "SETCHARA", "0", "char_00002604_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「い、いかがですか……？　もう、全身発情して……乳首もしこって……オマ\nンコもぐしょぐしょに濡れてしまっているんです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0404106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00002604_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「あんっ……あぁ……硬いオチンポが……んふっ、オマンコの入り口のところ\nまで来ています……はぁ……んっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0404107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「そ、そこ……そこです……そのまま、ずぶっとハメて下さい……このスーツ\nは、すぐに入れられる筈ですからぁ……んっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0404108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「あぁん……そんな、ここまでして焦らすなんて……あぁっ、意地悪なさらな\nいで……欲しいんですっ、オチンポっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0404109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「お願いしますっ……貴方のぶっといオチンポをっ、オマンコにっ……奥まで\nズッポリっ……ハメて下さいませっ、あぁっ、オチンポ早くぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0404110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「んくぅぅぅぅぅんっ……！　あっ、はひぁぁんっ♪　あぁっ、これっ、これ\nですわぁっ♪　アツアツのっ、オ、オチンポぉっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0404111" ]},
		{"command":[ "SETIMAGE", "0", "still_00002604_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「あぁぁぉっ、一番奥まで……ずぶって届くぅっ！　あぁっ、そうですっ、こ\nれっ、このオチンポが欲しかったのぉっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0404112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「はぁぁ……んんっ、あぁ、はい……ずっと待ち遠しくて……オマンコのお汁\n……ジュクジュクにしてしまいましたわ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0404113" ]},
		{"command":[ "SETIMAGE", "0", "still_00002604_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「どうか、ご遠慮なく、中をかき回して……私の……はしたないドスケベオマ\nンコを……たっぷりと躾けて下さいませ♪　あ、あひんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0404114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「は、あぁっ、あんっ、あぉっ、はっ、んぅぅっ……あぁっ……思ってたのよ\nりっ、もっとすごいっ、太くて硬いのっ、気持ちいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0404115" ]},
		{"command":[ "SETIMAGE", "0", "still_00002604_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「あっ、あぁっ、はいっ、もっとズボズボなさって下さいっ♪　欲しがりオマ\nンコはっ、貴方のオチンポのピストンを心待ちにしていましたっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0404116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「あぉっ、おほぉぉんっ♪　あぁっ、もっと激しくパンパンしてっ♪　はっ、\nひっ、素敵ですっ、オチンポっ、いっぱい感じますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0404117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「あふぁ……あっ、もっと足を広げさせて……あぁっ、は、恥ずかしいですわ\n……こんな大股開きなんて……はぁぅんっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0404118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「も、元々いやらしい格好なんて……あぁっ、でも……そうかも知れませんっ\n……ずっと、胸と股間への視線は感じていました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0404119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「それを意識すればするほど……また、身体の内側が疼いて……欲しくて欲し\nくてたまらなくなっていたんです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0404120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「あっ、あひぁっ、あぁっ！　やっと……あぁっ、望みが叶いましたっ……あ\nっ、ああっ、オチンポいいっ、いいですぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0404121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「はぁっ、もっと速くして下さいっ……中っ、あぁっ、ズボズボされるの大好\nきなんですっ、あひぉっ、あぉっ、おぉぉんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0404122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「あんっ、あぉぉっ……ズンって来ますっ！　くぅんっ、あぁっ、激しいのっ\n、こ、腰が抜けてしまいそうですっ、あ、ひっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0404123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「い、いえっ、勢いは緩めなくて……大丈夫ですわっ……身体、しっかり支え\nていますから……もっとオマンコなさって下さいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0404124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「んふっ、くぅぅっ……あぁっ、バックからのオチンポピストンっ、逞しいっ\n！　はぁんっ、あっ、ごりゅって捻りが入ってますぅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0404125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「そっ、そこぉっ、あっ、は、はひっ、弱いですっ！　オチンポの先で、グリ\nグリされるのっ、腰が抜けそうになっちゃいますっ、あひぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0404126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「駄目です……あぁっ、こ、声が抑えられない……あひっ、あぁ……こんな、\nあぁっ、動物みたいにっ……サカってしまうなんて……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0404127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「あぉぉっ！　でもっ、もうこのオチンポに逆らえる訳ありませんっ♪　欲望\nに身を委ねてっ……メスの声っ、出しますぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0404128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「あひっ、あぉぉっ、ほぉぉぉんっ！　は、はひっ、言いますっ……全て、貴\n方にお伝えしますっ、あっ、んぁぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0404129" ]},
		{"command":[ "SETIMAGE", "0", "still_00002604_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「私っ……学園長のっ、古賀道子はぁっ、貴方のオチンポが欲しくてっ、いや\nらしくお尻を振ってっ……オマンコをおねだり致しましたっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0404130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「今はっ、ずっぽりと太いオチンポを咥えこんでっ、あひぉっ！　浅ましいメ\nス鳴きをさせていただいておりますぅっ、おひぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0404131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「はぁっ、チンポっ！　オチンポぉっ！　あっ、あぁっ、い、いやらしいオマ\nンコに入っているのっ、ゾクゾクしますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0404132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「じゅぷじゅぷっ、恥ずかしい音を響かせてぇっ……あぁっ、こんなにされた\nらっ、も、もうっ、イ、イッてしまいますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0404133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「はっ、んひっ……あぁっ、イッてもいいっ……う、嬉しいですがっ、貴方と\n一緒にイキたいんですっ、んくぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0404134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「だからっ、もう少しだけ……しっかりオマンコ締め付けてっ……イッてもら\nうようにしますからっ……ふぐっ、んふぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0404135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「ほら……すぐですよね……？　このオチンポの震え……イキそうになってる\n証拠ですわっ、んっ、あぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0404136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「はいっ、このまま……中に出してくださいっ！　エッチなバニーの欲しがり\nオマンコにっ、貴方の新鮮なザーメンミルクっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0404137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「はぁんっ、いっぱい奥にドピュドピュ出してっ！　あひぁっ、ドスケベバニ\nーの道子を孕ませてぇっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0404138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「あひぃぃぃぃっ！　出てるっ、あぉぉぉっ……濃いのが子宮に流れ込んでき\nますっ……ほぉぉっ、イグぅぅぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0404139" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002604_02_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「はぁっ、あふぁ……直接流れ込む感触がいい……ずっとこの瞬間を待ってい\nました……あはぁ……んっ……ふっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0404140" ]},
		{"command":[ "SETIMAGE", "0", "still_00002604_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「んっ、はぁ……あぁ……まだ勃起オチンポがしっかりとハマったままです…\n…オマンコが熱いです……くぅぅぅん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0404201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「そうですよね……貴方の逞しいオチンポは、一発出した位では物足りないで\nすよね……んっ、はぁ……んふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0404202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「あんっ！　んふふっ、ピストンでお返事なんて……はい、私も大丈夫ですか\nら……そのまま続けて下さい……もっとオマンコなさって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0404203" ]},
		{"command":[ "SETIMAGE", "0", "still_00002604_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「あぅんっ……！　あぁっ、オチンポ太いままでっ……あひぉっ、中っ……は\nぁっ、ぐちゅぐちゅっ……かき回されていますわっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0404204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「はんっ、あぁっ、んふんっ……あんっ、はぁっ、さっきより……ワイルドな\n感じがしますわっ、あひっ、あふっ、んくっ、んふっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0404205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「あんっ、はっ、あぁんっ、おっぱいがっ……たぷたぷ揺れてっ、あっ、あぁ\nんっ、お尻もっ……ぷるんって……は、はしたないっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0404206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「も、もっと足を開く感じで……？　あぁ……そんな、繋がってるところを見\nせびらかすみたいなポーズっ、は、恥ずかしいのにっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0404207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「あんっ、でもっ……気持ちいいっ、あはぁんっ、オチンポズコズコされたら\nっ、もうっ、何も考えられなくなってしまいますっ、あひぃんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0404208" ]},
		{"command":[ "SETIMAGE", "0", "still_00002604_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「あぅんっ、んふぅっ、あぁっ……このまま、私が一方的になんて……申し訳\nないですわ……ちゃんと、お返しもしませんと……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0404209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「んふぅっ……お尻に力を込めて……んんっ、キュンって……オチンポ……締\nめ付けます……あふっ、今の……お好きですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0404210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「ふふっ、お好きみたいですね……んっ、なら……もう少しっ、あふっ、んん\nっ……はっ、ひっ、あ、あひんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0404211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「あぁっ……ちゃんと締め付けて……オチンポ感じていただけるのは嬉しいで\nすが……これっ、んぅっ、私も……感じてしまいますわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0404212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「んんっ！　あっ、しかもっ……くぅんっ、貴方のオチンポの動きっ……はひ\nっ、よ、弱いところをっ……的確に突いてっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0404213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「はひっ、あひんっ♪　こ、腰くだけになりますっ……あひぃっ、はっ、あぁ\nっ……お尻……支えられて……あぁっ、また激しくぅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0404214" ]},
		{"command":[ "SETIMAGE", "0", "still_00002604_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「あっ、ひっ、こうしているとっ……全部……貴方のオチンポに支配されてい\nるみたいでっ……あぁっ、ゾクゾクしますっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0404215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「んぁぁっ、じゅぷって……いやらしい音ぉっ♪　あぁっ、オマンコ……そろ\nそろっ……限界かも知れませんっ……！」", "NORMAL" ]},
