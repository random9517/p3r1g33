{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「この拙者を呼び出すとは……なかなか豪胆な方でいらっしゃるでござるわね\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0203101" ]},
		{"command":[ "SETCHARA", "0", "char_00014902_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「……このようなことが、忍びの術のパワーアップにつながるなどと、なんと\n大胆な世迷い言をおっしゃるでござるのかしら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0203102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「え？　言葉遣いがおかしい？　前々から言おうと思ってた……ですって？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0203103" ]},
		{"command":[ "SETCHARA", "0", "char_00014902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「そんなの仕方ないですわ。いきなりくのいちになれと言われたのですから…\n…好きでござるござる言ってるわけではありませんのよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0203104" ]},
		{"command":[ "SETCHARA", "0", "char_00014902_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「まあ、それはともかく……はぁ……こんなことをさせるだなんて、本当に困\nったお方でござるわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0203105" ]},
		{"command":[ "SETCHARA", "0", "char_00014902_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「ん……ふぅ、おちんぽが、こんなになって……わざわざ射精させるために、\n呼びつけるだなんて……本来なら許せないことでござるわよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0203106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014902_01_01" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「まあ、今日はたまたま暇でしたから、別に構いませんですけども……いつも\nいつも呼び出しに応じられるわけではありませんでござるわよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0203107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「それにしても……なんてはしたないおちんぽ……。こんなに硬く膨らませて\n……はぁ……ふぅ、恥ずかしくありませんの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0203108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「ああ、もう……しっかりイカせて差し上げませんと……ん、んん、他の誰か\nに迷惑を掛けてしまいかねませんでござるわね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0203109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「大丈夫……じっくり時間を掛けて、ご奉仕つかまつるでござるわ……はぁ…\n…あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0203110" ]},
		{"command":[ "SETIMAGE", "0", "still_00014902_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「おちんぽが……指の中で、気持ちよさそうに息づいている……ああ、熱い…\n…おちんぽで、指がジンジンしてしまうでござるわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0203111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「傘の広がったところが……プクプクして……ああ、すごぉい……いやらしい\nで、ござるわね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0203112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「亀頭が、膨らんでる……スベスベしてて……はぁ、触っているだけで、気持\nちいいでござるです……ん、ふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0203113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「それで……いかがでござるかしら？　こうして扱くだけで気持ちいいのでし\nたら、こんなのご自分でするのと変わらないのではありません？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0203114" ]},
		{"command":[ "SETIMAGE", "0", "still_00014902_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「そう……そんなに違うの？　それならこうしてシコシコする甲斐があるとい\nうものですわ……ん、んん、はぁ……あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0203115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「まあ、本当にパワーアップできたのなら、言うことありませんでしたでござ\nるですけど……はぁ……んん、んんんぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0203116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「それにしても、なかなかおイキになられませんでござるわね……ふぅ、あふ\nぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0203117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「あまり、気持ちよくありませんの？　そう……そんなことないのでござるね\n。嬉しいでござるわよ……ふふ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0203118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「でしたら……ん、んん、このまま続けさせていただきますでござるわよ……\nって、ううん、やっぱ言葉遣い変ですわね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0203119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「……まあ、それはともかく……手でするだけで十分ですの？　意外と慎まし\nいでござるわね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0203120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「え？　もっと大胆なこと……？　ふふ、そんなこと、応じるわけありません\nでござるわよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0203121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「当たり前でござるわ。はぁ……ふぅ……だって、拙者と隊長氏は、ただの…\n…雇用契約をしただけでござるもの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0203122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……そんなこと、受け入れられるわけ、ありませんでござるわ\n……手でするだけで、精一杯……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0203123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「これだけでも、十分譲歩しているでござるですわよ……？　はぁ……はぁ…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0203124" ]},
		{"command":[ "SETIMAGE", "0", "still_00014902_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「拙者と隊長氏は、形の上では臣下の形を取らせていただいているとはいえ…\n…端女扱いは望んでいないでござるもの……おわかり？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0203125" ]},
		{"command":[ "SETIMAGE", "0", "still_00014902_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「ですが……もう少し関係が進めば、その限りではありませんでござるわよ…\n…はぁ……はぁ……ふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0203126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……隊長氏……ホンキで忍術のパワーアップをしてもらうつも\nり……でござったの？　呆れてしまうでござるわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0203127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「こんなことでパワーアップ出来るのでしたら、ヘルス嬢は世界最強になって\nしまうでござるですわぁ……はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0203128" ]},
		{"command":[ "SETIMAGE", "0", "still_00014902_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「はぁ……ふぅ……そろそろ、疲れてきたでござるわぁ……はぁ、んん、あふ\nぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0203129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「え？　持久力を鍛えるチャンス……？　ふぅ、ふふふ。ものはいいようでご\nざるわね……はぁ、ふぅ……ん、んんん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0203130" ]},
		{"command":[ "SETIMAGE", "0", "still_00014902_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「よくってでござる……はぁ、はぁ……ホンキでシコシコしてさしあげるでご\nざるわよ……ん、んん、はぁ、あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0203131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「ん……んん、ふぅ……はぁ……いかがでござるかしら？　痛かったりしませ\nん？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0203132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「そう、ふぅ……もうすぐイキそう……それはよかったでござるわぁ……はぁ\n、ふぅ……ああ、はぁ、すごぉい……ビクビク、してる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0203133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「根本から、精液が上がってきてるようですわぁ……はぁ、あはぁ……なんて\nたくましい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0203134" ]},
		{"command":[ "SETIMAGE", "0", "still_00014902_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「ええ、よくってでござるわ……このまま、全部出していただいても……はぁ\n、はぁ……んんぁ、あはぁぁぁぁ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0203135" ]},
		{"command":[ "SETIMAGE", "0", "still_00014902_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「きゃうぅぅ……！？　あはぁ……はぁ……はぁぁぁああん……ああん、もう\n、こんなに出すだなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0203136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014902_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「はぁ……あぁぁあん……飛び散ってる……身体が、こんなに汚されて……あ\nあ、はぁ……もう……もっとおとなしく発射させてほしいでござる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0203137" ]},
		{"command":[ "SETIMAGE", "0", "still_00014902_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「んん、ふぅ……精液の匂い……すごぉい……鼻の中に、精液が染みこんでく\nるみたいでござる……はぁ、あはぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0203138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「ふぅ……ふぅ……満足していただけたでござるかしら？　さて、と……それ\nじゃ、今日はこのへんでお仕舞いにしておきましょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0203139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「しからば御免──って、え？　まだ終わってないでござるか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0203140" ]},
		{"command":[ "SETIMAGE", "0", "still_00014902_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「ひゃうぅ……すごぉい……こんなに、いっぱい出したのに、まだ硬い……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0203201" ]},
		{"command":[ "SETIMAGE", "0", "still_00014902_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「ん、ふぅ……はぁ……はぁ……精液の匂いで、むせ返りそう……はぁ……あ\nふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0203202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「ああ、ヌルヌルしてる……ん、はぁ……これが、膣の中だったらと思うと…\n…ドキドキが止まりませんでござる……あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0203203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「え？　違うでござる……はぁ、はぁ……セックスしたいわけじゃありません\nのよ……んん、ふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0203204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……手がヌルヌルするでござるぅ……ああ、精液が指に絡みつ\nいて、薄い手袋をはめているみたい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0203205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「おちんちんを扱くと、にちゃにちゃして……あはぁ、はぁああん……変な気\n持ちになっちゃうでござるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0203206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「精液の匂いが……ああ、鼻に染み込んでくる……脳の中まで精液で満たされ\nているみたい……はー……はー……はぁあん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0203207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……なんだぁ、興奮して、しまいますわぁ……はー……はー…\n…あぁぁあん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0203208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「え？　口調？　もう……今ござるござる言ってる場合ではありませんわぁ…\n…はー……あああん、んん、くぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0203209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……あああ、おちんちん、すごぉい……気持ちよさそうに、ビ\nクビク震えてる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0203210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「手の中で、暴れてる……はぁ、はぁ……浮かび上がった血管が、すごくセク\nシーですわぁ……はぁ、あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0203211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「そろそろイキそうなのかしら……はぁ、はぁ……もう少し？　そう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0203212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「だったら、そろそろ、わたくしのホンキを、見せてさしあげますわぁ……は\nぁ、はぁ……ん、んん～～……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0203213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「ああ、握力が尽きてしまいそう……はぁ、ふぅ……パワーアップとは無縁、\nというわけではなさそうですわねぇ……んん、あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0203214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「んん、んんん……おちんぽ、気持ちよさそう……はぁ、ふぅ……なんだか、\n興奮してしまいますわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0203215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「あぁぁん……ニチャニチャしてる……精液が少し乾いて……あ、ああ……駄\n目ぇ……ゾクゾクしちゃう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0203216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「はー……はー……ああぁん、おちんぽ、震えてますわ……ほらぁ、根本から\n、ビクンビクンしてる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0203217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「そろそろイキそう……？　そう……ふふ、ええ、気持ちよくなってくれて、\nよかった、ですわぁ……はぁ、ふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0203218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「あっ、す、すごぉい……こんなにビクンビクンしてる……手の中で、飛び跳\nねてる……あ、ああ……駄目ぇ、そんなに暴れないでぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0203219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「え？　もう、出る……はぁ、はぁ……そう……いいのよ、出してぇ……たっ\nぷりぶちまけてぇ……ん、はぁ……はぁぁぁあん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0203220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、あああ……はぁ……はぁぁぁあん……出てるぅ……ん。んん、\nはぁ……いっぱい、溢れてるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0203301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014902_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「うわぁ、一瞬でドロドロにされちゃった……ああんもう、出しすぎぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0203302" ]},
		{"command":[ "SETIMAGE", "0", "still_00014902_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「う、くぅ……はぁ、はぁ……肌で妊娠、しちゃいそうですわぁ……ん、んん\n……ああ、まだ出てる……身体に飛び散ってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0203303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「あぁああん……熱いぃ……はぁ、はぁ……肌に、体温が染み込んでくる……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0203304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「はぁあ、あふぅ……精液で、汚されるだけで、気持ちよくなっちゃいます\nわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0203305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「はー……ふぅ……え？　わたくしが……いえ、拙者がドＭでござると……？\n　何をおっしゃってるのか、わかりませんでござるわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0203306" ]},
		{"command":[ "SETIMAGE", "0", "still_00014902_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「え？　急に口調が戻った……？　当然でしょう？　拙者はくのいちとして、\n雇われているのですから、当然でござるですわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0203307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「ともかく、拙者はドＭなんかじゃありません……次、そんなこと言ったら、\nおちんぽ、もっと搾って差し上げるでござる……ふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0203308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「はぁ……ふぅ……それにしても、疲れたでござる……はぁ、ふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0203309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「それでは、今度こそ、帰らせていただきますわ……では、しからば御免──\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0203310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「ひゃうぅ！？　か、顔に……あっ、あっ、精液が、こんなにぃぃ……！　ひ\nぅ、きゃうぅぅ……あっ、あっ、あぁぁああん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0203401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014902_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「はぁぁん……精液が、顔に膜を張っていく……ん、んんはぁ、息が、できま\nせん……あぁん、苦しい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0203402" ]},
		{"command":[ "SETIMAGE", "0", "still_00014902_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「んはぁっ、はぁ……苦しいのに、感じちゃうぅ……んっ、くぅ……はぁ、は\nぁぁぁん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0203403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「ああ、目の前が霞む……精液で、真っ白ですわぁ……はぁぁあん……んぶ、\nあふぅ……精液で、溺れてしまいそう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0203404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「はー……はぁあん……苦しい……息が、できません……あぁん、駄目ぇ……\nはぁ、はぁぁぁん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0203405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……ふぅ、や、やっと、射精が収まりましたわね……わたくし\n……いえ、拙者……溺れ死なずに済んだみたいでござる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0203406" ]},
		{"command":[ "SETIMAGE", "0", "still_00014902_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「え？　口調が戻ってる？　仕方ないでしょう？　拙者はくのいち……当然の\nことですわぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0203407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「ふぅ……ふぅ……気持ちよかった……じゃなくって、苦しかった、ですわぁ\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0203408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「……ドＭ？　拙者が……？　はぁ、ふう……そ、そんなわけないでござる…\n…適当なこと、おっしゃらないで欲しいでござるわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0203409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「さて、と……それじゃあ、これでお仕舞いということで……しからば御免─\n─」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_0203410" ]},
