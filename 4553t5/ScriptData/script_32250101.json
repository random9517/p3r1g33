{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022501_01_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「今日もカツマちゃんの手でメンテナンスしてもらえるなんて……すっごく嬉\nしくて、興奮してきちゃうわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0103101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「ところで、言われた通りエンジンオイルは抜いておいたけど、今日はどんな\nメンテナンスをしてくれるの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0103102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「なるほど……オイルパンの交換をするのね。でも、オイルパンの交換は少し\n難しいわよ。大丈夫？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0103103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「今まで何回か交換したことある……？　それって、私以外の車にもメンテナ\nンスしてたってこと！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0103104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「練習としてやっただけって……！　まあいいわ……昔の車のことなんて、私\nのボディですぐに忘れさせてあげるんだからっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0103105" ]},
		{"command":[ "SETIMAGE", "0", "still_00022501_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「んっ、あっ……！　カツマちゃんが車体の下に入り込んでくるぅ……！　ダ\nメっ……これだけで、すごく感じちゃうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0103106" ]},
		{"command":[ "SETIMAGE", "0", "still_00022501_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「あんっ……！　まずはオイルパンの近くにあるサブフレームや配管を取り外\nすのね……！　いいわ、思いっきり取り外して頂戴っ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0103107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「あああぁんっ……！　ラチェットがボルトにあたって……！　んふっ、あっ\n、んくうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「グリグリねじられて、ボルトがどんどん外れていくぅ……！　私の配管、取\nれちゃってるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「はぁ、んっ……！　次はフランジの取り外しなのね……そこは１２ｍｍと１\n４ｍｍのラチェットを同時に使って、優しく……あはあぁっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0103110" ]},
		{"command":[ "SETIMAGE", "0", "still_00022501_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「やっ、あっ、んんっ！　そのマフラー部分、熱がこもるからボルトもカタく\nなってて……！　あっ、あっ！　カタいの、無理やり外されてるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0103111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「んっ……あっ……！　フランジとマフラーもちゃんと取り外せたのね……そ\nれじゃあ、次はサブフレームよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「ああぁ……！　またラチェットが奥まで入ってくるぅ……！　私の大事なパ\nーツが、どんどん外されていって……あんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「はぁ……あっ、あふっ……次は本命のオイルパンね……いいわよ……覚悟は\nできてるから、思いっきり外していって……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「えっ、あっ……！？　ちょっとカツマちゃん……！？　それ、電動ラチェッ\nトよね……！？　手動でボルトを外すんじゃないの……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0103115" ]},
		{"command":[ "SETIMAGE", "0", "still_00022501_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「ボルトの数が多いから、電動の方が楽って……！　やっ、イヤっ！　私はカ\nツマちゃんの手で分解されたいのっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「ま、待って……！　お願いだから手動で……あはあああぁぁぁんっ！　強い\nブルブルで、私のボルト外されちゃってるぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ！　やああぁ！　電動で無理やり感じさせられてるぅ！　ダメっ\n！　強いのダメぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0103118" ]},
		{"command":[ "SETIMAGE", "0", "still_00022501_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「もう少しでボルトが全部外れるって……！　そんなのムリぃ！　もう我慢で\nきないわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「あああぁ……！　イッ、イッちゃうっ……！　ボルト外されながら……イッ\n、イクッ……んっ、んんんっ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「ああああぁ……！　気持ちよすぎて、少しイッちゃったわっ……！　残って\nたエンジンオイルがボディから垂れて……あふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「顔にオイルがかかるって……！　ご、ごめんね、カツマちゃん……！　\n私の廃液、汚いわよね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「別に気にしてないの……？　ああっ、嬉しい……！　私の廃液も嫌がらずに\n受け止めてくれるだなんて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0103123" ]},
		{"command":[ "SETIMAGE", "0", "still_00022501_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「んっ、あふっ……ボルトも全部外れてるし、あとはオイルパンを取り外すだ\nけよ……少し外しにくいと思うから、慎重にね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ！　そんな無理やり外そうとしないでっ……！　それに、まだな\nにかカバーみたいなのがあたって……あんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……！　どうしてオイルパンが取れないのかって……？　それ\nは多分、トルクコンバーターのカバーが外れてないからよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「タイヤ側にあるカバーを外せば、綺麗に取り外すことが出来るはずだから…\n…んっ、そうよ……！　そこのボルトも外してっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「ああっ！　やっぱり足回りのパーツはビンカンで……！　あっ、んふっ！　\nラチェットがあたるだけで、感じすぎちゃうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「はぁ……あっあっ……！　トルクコンバーターのカバーが外れて……ああっ\n！　私のボディ、どんどん丸裸にされてるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0103129" ]},
		{"command":[ "SETIMAGE", "0", "still_00022501_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「んっ、あふっ……！　ついにオイルパンの取り外しね……！　ちょっと重い\nから、取り外しには注意してね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「そ、そうよ……！　左右に小刻みに揺らしながら……優しくっ……！　あっ\n、あっ！　カツマちゃんの手が、直接ボディにあたってるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「やっ、あああぁ！　この温もり、すごく気持ちいいわっ……！　カツマちゃ\nんの指が、ボディの奥にまで入ってきて……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「ダメっ……！　こんなに気持ちよくされたら、またイッちゃうっ……！　エ\nンジンオイル溢れてきちゃうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「メンテナンス前にあれだけ抜いたのに……！　あっ、あっ！　オイルパンの\n奥に染み付いてるオイルが、漏れちゃうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「あっ、ダメっ！　イクッ！　イクッ！　あああぁ！　私、また……イッ、イ\nクうううぅぅぅぅぅっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0103135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022501_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「あはあああぁぁぁっ！　私の廃液、たくさん溢れちゃってるぅ！　またカツ\nマちゃんの顔に、びちゃびちゃかかってるのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0103136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「こんなはしたないこと、したくないのに……！　でも、ボディが悦んでて…\n…んっ、んんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0103137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「ダメッ！　イクの止められないわっ！　廃液びゅーびゅー出すの、気持ちい\nいのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ！　またイクッ！　カツマちゃんの身体、廃液まみれにしちゃう\nぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「あああぁ！　イクッ！　イクッ！　カツマちゃんの手でオイルパン外されな\nがら、イッちゃうのおおおぉぉぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……ご、ごめんね、カツマちゃん……！　また私の廃液で、い\nっぱい汚しちゃったわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0103201" ]},
		{"command":[ "SETIMAGE", "0", "still_00022501_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「汚れは拭けばいいだけだし、今は私のボディを綺麗にすることが大事って…\n…！　もう……！　どうしてそんなに優しいのっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「あっ、んんっ……！　カツマちゃんの手の感触と一緒にウエスの感触が……\n！　この優しく撫でられる感じ、たまらないわっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0103203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「あひっ……！？　そ、そこは液状ガスケットがついてたとこなのにっ……！\n　そんなとこまで磨いてくれるのっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0103204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「今から新しいガスケットを塗ってくれるなんて……！　んっ……！　嬉しい\n……！　オイルパン周りが、新品になっていくみたい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0103205" ]},
		{"command":[ "SETIMAGE", "0", "still_00022501_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「はあぁ……！　あっ、あっ……！　配管の奥の奥まで、ウエスで拭かれて…\n…！　あああぁ……！　すごく感じちゃうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「指の届かないところも、パーツクリーナーで綺麗にされてるっ……！　私の\nボディ、どんどん綺麗になっていってるわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「そろそろ拭き掃除も仕上げに入るのね……！　もっとカツマちゃんの手で感\nじたいけど、仕方ないわよね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「んっ……！　あっ……！　仕上げはペーパーウエスなのね……！　んっ、布\n地とは違う肌触りで、こっちも気持ちいいのぉ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0103209" ]},
		{"command":[ "SETIMAGE", "0", "still_00022501_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、あっ……！　配管がすごく綺麗になったわ……！　それじゃ\nあ、最後に新しいオイルパンを取り付けて頂戴……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0103210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「あっ、んふっ……んくぅ……！　新品のオイルパンがはめ込まれてるっ……\n！　あっ、あっ！　ボディにパーツががっちりハマるの、感じるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「それにボルトも最初みたいに、綺麗に取り付けられて……！　ひぐっ、あふ\nっ……！　あっ、ひあぁ、あはあぁ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「そ、そうよ……！　ボルトは対角線上に締めるていってっ……！　上を締め\nたら、次は下側を……！　んっ、あっ、あっ……ああぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「ひぐっ、あっ、あひっ……！？　か、カツマちゃんっ……！　オイルパンの\nボルトは、そんなに強く締めなくていいのっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0103214" ]},
		{"command":[ "SETIMAGE", "0", "still_00022501_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「オイル漏れするかも知れないっていう不安はわかるけど……！　あんまり締\nめすぎると、せっかく交換したパーツがダメになっちゃうからっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0103215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「ひぎっ！？　あっ、あっ！　ボルトがどんどん締まるぅ！　カツマちゃんの\n手で、私のボディが生まれ変わっていくのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0103216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「あああぁ！　こんな幸せ感じたら……！　ダメっ！　またイッちゃうっ！　\n今度はオイル漏れないけど、イッちゃうのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「あっ！　んひっ、あひっ！？　これが最後のボルトって……！　やあぁ！　\nメンテナンス終わっちゃうっ！　カツマちゃんの愛撫、終わっちゃうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0103218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ、あふっ！　くっ、んふっ！　もっとして欲しいのに……！　い\nろんなとこ弄って、触れて欲しいのにぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「まだ最後の仕上げがあるって……！？　な、なにっ！？　もうイキそうなの\nに、これ以上なにをするって言うのぉ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「ひぐうううぅぅぅ！？　締まってるボルトが、さらに締まって……！　ぐっ\n、あっ……！　締め付け、強すぎるからぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0103301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022501_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「あああぁ！　イクッ！　イクぅ！　カツマちゃんの手でボルトをギュってさ\nれて……！　また、イクううううぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「んっ、あふっ！　あっ！　ひぎっ！？　ウォッシャー液止まらないのぉ！　\nオイルの代わりに、びゅるびゅる出てるのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0103303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「締め付けが強くなるほど、ボディ感じるぅ！　ダメっ！　そんなに締め付け\n確認されたら、ボルトがバカになるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0103304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「あひっ、ぐっ、あはぁ！？　ギチギチに締めるのダメぇ！　でも嬉しくて、\nまたイッちゃうのおおおぉ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0103305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、あっ……カツマちゃんのメンテナンス、すごくよかったわ…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0103306" ]},
		{"command":[ "SETIMAGE", "0", "still_00022501_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「オイルパンも新品になったし、奥に溜まってた廃液もなくなって、車体が軽\nくなった気がするの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0103307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「それでね、あの……もしよかったら、今度は違うパーツを交換してくれない\nかしら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0103308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「い、いいの……？　うふふっ。嬉しいわ……！　カツマちゃんなら、どのパ\nーツに手を出してもらっていいからね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「それこそ、私の一番大事なところ……エンジンルームに手を入れてもらって\nも、大丈夫だから……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「あんんんっ！　カツマちゃんの手がオイルパン以外のところにあたってるぅ\n！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0103401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022501_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「車体の奥までウエスで拭かれるなんて……！　あっ、ひぐっ！？　そんなビ\nンカンなとこまで拭き拭きしちゃダメぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ！　イクッ！　イクぅんっ！　ウエスで配管を拭かれるだけで、\nイッちゃううううぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0103403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「ウォッシャー液もびゅーびゅー出て、止まらないからぁ！　あひっ、んっ、\nあっ！　ダメっ！　またイクッ、イクッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0103404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「イッくうううううぅぅぅぅぅ～～～～～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0103405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、んくっ……！　はぁ……あっ、くふっ……！　すごく気持ち\nのいいメンテナンスだったわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0103406" ]},
		{"command":[ "SETIMAGE", "0", "still_00022501_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「オイルパンだけじゃなくて、奥の配管にまで手を入れてくれるなんて……私\nのボディ、カツマちゃんの手で汚されちゃったわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0103407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「汚したんじゃなくて、綺麗にしたって……そ、それはそうなんだけど……！\n　私が言ってるのは、そういう意味じゃなくて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0103408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「私の車体は、完全にカツマちゃんのモノっていうことよ……絶対にカツマち\nゃん以外に触らせたりしないんだから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0103409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「だからカツマちゃんも、私以外の車に触ったり、乗ったりしちゃダメよ……\n約束だからねっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0103410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}