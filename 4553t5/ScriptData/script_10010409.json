		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「そんなことより、今は観客を避難させることが先です！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010104090001" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "7", "CENTER", "0" ]},
