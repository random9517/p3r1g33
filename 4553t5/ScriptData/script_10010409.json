		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「おーい！　みんな！　騒がず落ち着いて！　非常口はあっちだ！　押し合わ\nずにゆっくりと――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010104090001" ]},
	{"command":[ "SETCHARA", "0", "char_00000401_01", "7", "CENTER", "0" ]},
