		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「なんてこったい……！　軌道上はコンツェルンの艦隊が守ってたんじゃなか\nったのかい！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010104090001" ]},
