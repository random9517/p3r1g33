		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0119" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_022" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「なんなのだ。また妙な名前を付けているな、あのアナウンサー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010104090004" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "1", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「それはお前も人のことを言えないのではないか？　さっきの技名はなんなの\nだ。『ルナ・ドッキング』とかいう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090104090004" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あ、あれは勢いだ！　細かいことを気にするな！　だいたい、お前もノリノ\nリで叫んでいたではないか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010104090005" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「ちょいと、そこのお二人さん。漫才やってる場合とちゃうで！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_128_010104090001" ]},
	{"command":[ "SETCHARA", "0", "char_00012801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090104090005" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「もう、リングに立っとるのはウチらだけや。そろそろお相手してもらおか！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_128_010104090002" ]},
	{"command":[ "SETCHARA", "0", "char_00012801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「望むところだ！　アナザー！　私から行くぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010104090006" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「おっとっと、遠慮せんでええで？　一人一人は面倒や、二人まとめてかかっ\nてこんかい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_128_010104090003" ]},
	{"command":[ "SETCHARA", "0", "char_00012801_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「なんだとぉ！？　貴様、我々をなめて――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010104090007" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「な、なんだ、これは！？　おい！　マグナシア！　なにかおかしなことを―\n―」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010104090009" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「ちゃ、ちゃうちゃう！　ウチは何も仕掛けとらんで！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_128_010104090004" ]},
	{"command":[ "SETCHARA", "0", "char_00012801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「二人とも、上だ！　空を見ろ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090104090006" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「な、なんやあのでっかいのは……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_128_010104090005" ]},
	{"command":[ "SETCHARA", "0", "char_00012801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あれは……！　襲来者（インベーダー）の母艦だと！？」", "NORMAL" ]},
