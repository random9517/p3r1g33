		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "実況" ]},
		{"command":[ "SETTEXT", "「ザ・ショットガンズ快進撃！　高円寺クリス＆シロクマ姫の『ヘヴン・ミッ\nショネルズ』をチームワークで下しましたぁ～っ！」", "NORMAL" ]},
