		{"command":[ "SETNAME", "時間帝国兵たち" ]},
		{"command":[ "SETTEXT", "「うわああああああーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_924_010115060001" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「くっ！　兵士たちが……！　仕方がない、引きあげるぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100115060001" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「この次こそ、お前を倒す！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080115060001" ]},
		{"command":[ "SETCHARA", "0", "char_00000408_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「へっへーんだ！　毎回そうやって逃げてくくせに、偉そうなこといってんじ\nゃねー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010115060003" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「なにを調子に乗ってるんです、バカ犬。誰のおかげで勝てたと思ってるです\nか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110115060003" ]},
		{"command":[ "SETCHARA", "0", "char_00000511_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「んだとー！？　わたしのおかげに決まってんだろ！　おまえなんか、わたし\nのおまけだ！　お・ま・け！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010115060004" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うーん……やっぱりこれは……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「そうだな……これは確かに、どこかで見たような組み合わせだな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090115060001" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「だけど、いいコンビ。これから、戦力として頼りになりそう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010115060001" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうだな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「と、言うわけでカツマ隊長！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010115060001" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うわっ！　長官！？　なんなんですか、突然出てきて！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「頼りになるメンバー加入！　ということで、君には処理してもらわなければ\nならない書類が山ほどあるぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010115060002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「え？　え？　えっ！？　ちょ、ちょっと待って！？　それ、今言うこと！？\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「今言うことだ！　さもないとお前、このままサボって飲みに行きそうだから\nな！　逃がすと思ったら大間違いだぞ、さあ、キリキリ歩け！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010115060003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あ、ちょっと待って！　痛い痛い痛い！　自分で歩くから引っ張んないでく\nれっ！　長官！　長官～～～っ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「うるさい！　仕事がいっぱいあると言ったろう！　ハルノブの登録書類に、\n雇用契約関係、保険関係、その他もろもろ、あれこれ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010115060004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「カツマ！　本部に帰るんなら、ついでに交通費の清算も頼むよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010115060001" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんだぁ！？　どさくさに紛れてなに言ってやがる！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「あ、そうだ！　この前出した、訓練設備の使用申請もね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010115060001" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ついでに私の始末書もな！　ちゃっちゃと代筆しておけ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115060001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おまえら～っ！　ここぞとばかりに、俺に仕事をガンガン乗っけてくるんじ\nゃねぇ～～～っ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「リーダーの役割は、どこの次元でも変わりないようです。これも、自然の厳\nしい掟なんですね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_010115060001" ]},
		{"command":[ "SETCHARA", "0", "char_00022701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「仕方ないな。リーダーだもんな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_010115060001" ]},
		{"command":[ "SETCHARA", "0", "char_00022601_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「そだね。リーダーだし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_010115060001" ]},
		{"command":[ "SETCHARA", "0", "char_00022801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「まだ撮ってたのか！？　っていうか、おまえらも、私に仕事を押し付ける気\n満々なのか！？　いいかげんにしろぉ～～～～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_040115060001" ]},
		{"command":[ "SETCHARA", "0", "char_00015604_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「どこの次元にでも、貧乏くじを引かされっぱなしの方はいらっしゃるわけで\nすな。まあなんと申しますか、強く生きてくださいませ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010115060001" ]},
