		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「は～い♪　あ、な、た、の、沙世子さんですよ～♪　あらあら、そんなに驚\nいちゃうの？　かわいいわね～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0203101" ]},
		{"command":[ "SETCHARA", "0", "char_00025902_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「ここは男湯だろうって？　ええ、そうよ。でも、私の本業はサキュバスだも\nの……ね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0203102" ]},
		{"command":[ "SETCHARA", "0", "char_00025902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「こらこら、お風呂からでようとしないの～。いいじゃない、一緒に温泉に浸\nかりながら、気持ちよ～くなりましょうよ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0203103" ]},
		{"command":[ "SETCHARA", "0", "char_00025902_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「ふふ、ほかの客もいないみたいだし……ね？　湯煙に混じる淫魔のフェロモ\nン……クラクラしちゃうでしょ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0203104" ]},
		{"command":[ "SETCHARA", "0", "char_00025902_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「興奮して、おちんちんもガチガチになっちゃって……。うふっ、とっても美\n味しそう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0203105" ]},
		{"command":[ "SETCHARA", "0", "char_00025902_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「この温泉に着いたときからず～っと狙ってたんだから。おとなしく、わたし\nに食べられちゃいなさ～い♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0203106" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「あぁんっ♪　おちんちん、おっぱいではさんじゃったわよ。んふ、おちんち\nんアツアツで……おっぱい疼いちゃう……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0203107" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_01_01" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「先っぽも真っ赤になって……ふふっ、あなたの興奮が手に取るようにわかる\nわぁ♪　大丈夫、私にまかせて～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0203108" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「んれぇろ、れろ、れろぉん♪　おちんちんにぃ、私のよだれをトッピング～\n♪　んちゅ、ちゅぱぁ、おちんちん、美味しいわぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0203109" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「れろ、れろぉ、ちゅぱっ、ンッ、ちゅちゅぅっ♪　舌がとまらないわ。逞し\nいおちんちん……うっとりしちゃう……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0203110" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「こうして顔を近づけると……ああ、このおちんちんの匂い、たまらないの…\n…♪　れろれろぉ、ちゅぱぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0203111" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「身体を洗ったあとだから臭うはずないって？　んもう、そういうニオイじゃ\nないのよ、私が言ってるのは」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0203112" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「サキュバスだから感じ取れる、本能に訴えかけてくるような力強いおちんち\nんの匂いのこと♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0203113" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「もっと味わわせて～♪　んん……んぁ、あむぅ……んふっ、じゅるっ、じゅ\nるるぅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0203114" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「おちんちん……咥えちゃったぁ♪　じゅぷっ、じゅるるっ♪　私も興奮して\nるみたいね……どんどんよだれが溢れてきちゃうぅ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0203115" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_01_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「んふふ、ど～ぉ？　私のお口も、温泉に負けないくらいあったかくて、気持\nちいいでしょ～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0203116" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「んちゅぶっ、じゅる、じゅぶじゅぶぅっ♪　お口の中のおちんちん、いっぱ\nい舐めまわしちゃうわねぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0203117" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「じゅぷっ、じゅぷっ♪　じゅぷっ、じゅぷっ♪　おちんちんがビクビクって\n反応してる♪　舌……気持ちいい……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0203118" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「先走り汁がでてきてるわ♪　いいおちんちんは、先走りから美味しいのよね\n～♪　んじゅるっ、じゅるるぅ～っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0203119" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_01_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「ん？　なぁに？　フェラチオだけじゃなくて、おっぱいも？　あらあら、い\nいのかしら。サキュバス相手に、そんな命令しちゃってぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0203120" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「それじゃあ、お望み通り……え～いっ♪　ほら、こうよね？　おちんちんを\n、おっぱいでずりゅずりゅ～って♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0203121" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「サキュバスおっぱいまんこにおちんちんしごかれて、ちゅぶっ、もっと気持\nちよくなっちゃうでしょ？　ふふっ、先走りたくさ～ん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0203122" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「気持ちよすぎて、私におちんちん差しだすポーズになっちゃってる♪　いい\nのよ、いっぱい気持ちよくなってちょうだい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0203123" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「だって相手はサキュバスなんだから♪　パイズリフェラで負けちゃってもし\nかたないのよ。ねっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0203124" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「んふふ♪　じゅぷっ、じゅるるっ、んぁっ、じゅずずぅっ♪　おちんちん膨\nらんで、熱くて……私も、おっぱい気持ちいい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0203125" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「舌と、おっぱいで味わう、たくましい勃起おちんちん……♪　たまらないの\n～♪　んじゅるっ、じゅぷっ、じゅぷぷぅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0203126" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「腰が蕩けて、力が入らなくなっちゃう？　じゃあ、このまま射精しちゃいま\nしょうか。我慢しなくていいんだからね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0203127" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「たっぷりぴゅっぴゅできるように、おっぱいでぎゅ～ってしてあげる♪　よ\nだれでにゅるにゅるね～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0203128" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「おっぱいの間でおちんちんが暴れてるわ。んっ、れろっ、気持ちよくって、\nじっとしていられないのよねぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0203129" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「舌でもおちんちん、刺激しちゃう♪　裏筋……舌先でれろれろ～って、んふ\nっ、ほらほらぁ、れろれろれろれろぉ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0203130" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「だしちゃう～？　だしちゃっていいのよ～？　れろれろ、れろれろぉ、精液\nぃ、びゅ～って、だしちゃって～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0203131" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「あはぁああぁぁ～～～～んっ♪　びゅるびゅる～って、精液たくさんでてる\n～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0203132" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「おちんちんが、どっくんどっくん脈打って、射精してるわ～♪　熱くて、ド\nロドロ……おっぱいにのっかると、ずっしり重たぁい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0203133" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「あはぁっ♪　いやらしい気分になりすぎて、母乳まででてきちゃったぁ♪　\nサキュバスミルク温泉になっちゃうわね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0203134" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_01_14" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「んはぁ、んふぅ……♪　ほらぁ、見てぇ♪　おっぱいぎゅ～ってしながらパ\nイズリすると、ミルクぴゅ～ってでてきちゃうの♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0203135" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_01_15" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「たっぷりお射精よくできました♪　……って、あらあら。サキュバスミルク\nでにゅるにゅるになって、おちんちんがまた元気になってきたみたいね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0203136" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「ううん、さっきよりもガッチガチになっちゃってるかも。私のミルクパイズ\nリで興奮しちゃった？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0203137" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_01_13" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「ふふっ、いいのいいの。だって、人妻との温泉旅行なのよ。こういうことが\n起きないほうがおかしいじゃない♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0203138" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_01_15" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「人妻としても、サキュバスとしても、旅行先での刺激的なエッチを望んでい\nるの♥」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0203139" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「ねえ、まだまだイけるでしょ？　もっともっとあなたの精液をちょうだい。\nいっぱい気持ちよくしてあげるから♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0203140" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「うふふ♪　おちんちんはとっても素直ね♪　私にもっとパイズリフェラをさ\nれたいって言ってるみたいにピクピクしてるわ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0203201" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_01_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「おっぱいとお口でシてあげる～♪　んむ、じゅるる……っ、ちゅぶっ、ちゅ\nぶっ、ンッ、ちゅちゅぅ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0203202" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_01_12" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「おっぱい、すっごく気持ちよくなってる♪　ミルクだしながら、パイズリ…\n…んっ、にゅるにゅるこすれて、感じちゃう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0203203" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「感じると、どんどんミルク溢れて……んっ、あま～いエッチな匂いが、湯気\nにまじって漂ってくるわね～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0203204" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_01_11" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「んっ、んむっ、おちんちんが膨らんでる……。口に入りきらないくらい、パ\nンッパンになってるわぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0203205" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「あんなに射精した後なのに、すぐに復活して……んじゅぶっ、じゅるるっ、\n素敵なおちんちん……じゅぷっ、じゅぱっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0203206" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「サキュバスを虜にしちゃう、イケナイおちんちんなんだからぁ……じゅぱっ\n、んじゅるぅっ、ちゅちゅぅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0203207" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「にゅるにゅるにゅるる～んって、ミルクでパイズリも捗っちゃう♪　腰も浮\nいたり沈んだり、気持ちよくなっているのね～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0203208" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「もう、かわいいんだから♪　サキュバス母性本能くすぐられっぱなしでどう\nにかなっちゃいそう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0203209" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「ガチガチパンパンの勃起おちんちん、おっぱいとお口で蕩けるくらいお世話\nしてあげたくなっちゃう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0203210" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「サキュバスに責められて、おちんちん辛いでしょ？　射精したくてたまらな\nくなってるのよね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0203211" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「お口の中が、先走りでいっぱいになって……じゅるるっ、ンッ、私も期待し\nちゃってるの。あなたの射精」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0203212" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「んじゅぷっ、じゅるっ、じゅるっ、じゅるるっ♪　んんっ、また、イッちゃ\nうでしょ？　射精しちゃうでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0203213" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「おちんちんがまた膨らんできたもの。んじゅるるるっ♪　ほらぁ、たくさん\n出せるように、おっぱいで搾っちゃう～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0203214" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「口の中でも、舌で、先っぽいっぱいなでなでしてあげるわね。んじゅるっ、\nじゅるるっ、じゅぷじゅぷぅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0203215" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「精液、こみあげてきてるでしょ？　じゅぷっ、じゅぷっ♪　だしちゃってい\nいのよ、思いっきり、射精しちゃうの♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0203216" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_01_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「んふぅ、じゅるっ、じゅるぅっ♪　サキュバスのお口まんこに、じゅぷっ、\nまた、たくさん精液注いじゃって♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0203217" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「あなたの精液がほしいの。じゅるるっ、じゅぷっ、おちんちんに吸いついて\n、おねだりしちゃうのぉ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0203218" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「んぶっ、じゅるっ、じゅぶぶっ、じゅちゅちゅぅっ♪　だして、だしてぇ、\n精液、精液ぃ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0203219" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_01_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「おいしい精液ごちそうしてぇ♪　んっ、じゅるるっ、じゅぶっ、じゅぶっ、\nじゅるるぅっ、じゅるるるっ、じゅぶぶぶぅううっ！！」", "NORMAL" ]},
