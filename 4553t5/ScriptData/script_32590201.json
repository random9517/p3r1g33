		{"command":[ "SETIMAGE", "0", "still_00025902_01_17" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「んふぅ、ひゅごいわ、精液ぃ……んくっ、んくぅ……お口から、お腹に……\n流れ込むのぉ……んっ、んんぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0203302" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「２回目なのに、こってりドロドロぉ……♪　んくっ、喉が詰まりそう……だ\nけどこの息苦しさも、たまんなぁい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0203303" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「んくっ、んんんぅ……おちんちんが、まだ射精してる……♪　どっぴゅんど\nっぴゅん、お口に精液だしてるぅ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0203304" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_01_16" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「すごい、量で……んぁっ、飲みきれないわぁ……。あんっ♪　溢れちゃった\nのも、残さず舐めとるからねぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0203305" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「れぇろんっ♪　れろぉ～っ♪　んちゅ、ちゅっ、ちゅぅ～♪　本当にぃ、た\nっくさん射精したわねぇ。なんて素敵なおちんちんなのかしら♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0203306" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_01_15" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「このまま３発目までイけちゃいそうなくらい、ガッチガチのビンビンで……\nああん、惚れ惚れしちゃう～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0203307" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_01_14" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「ねぇ……いいわよね……？　おちんちん、もっと搾っちゃって……って、ど\nうしたの？　顔色が……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0203308" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「あ、頭がくらくらする？　サキュバスフェロモンのせいじゃなく……のぼせ\nちゃったの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0203309" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「あぁん、私ったらヤりすぎちゃった！　じゃあ、部屋で優しく看病するから\n、ゆるして～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0203310" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_01_15" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「じゅぱっ！？　んぁっ、おちんちんが抜けちゃった……あはぁああ～～んっ\n！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0203401" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_01_20" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「ひゃんっ、すごいっ、おちんちんから精液がびゅくびゅくって……！　あん\nっ、いっぱい顔にぃ、かかっちゃってるのぉ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0203402" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「すっかり私の誘惑に流されて、お口に射精すると思ったのに。やっぱりあな\nたってすごいわ。あの状況で、サキュバスに抵抗するなんて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0203403" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_01_19" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「でも、私としては少し残念。この濃厚精液を、お口で味わいたかったのにぃ\n……。んっ、でも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0203404" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「顔についたこの精液を、舐めとるだけで我慢してあげる。んふっ、それに、\nまだ射精は終わってないみたいだし♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0203405" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_01_18" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「ん～ちゅっ♪　れろ、れろれろ～♪　射精の残りを吐きだしてるおちんちん\nを、ぺろぺろおそうじしてあげる♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0203406" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「んふふ、イケナイ人妻よねぇ♪　夫がいるのに、旅行先で他の男のおちんち\nんをしゃぶっちゃってるんだもの♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0203407" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_01_19" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「でも、私は人妻であると同時にサキュバスだからぁ、こぉんな美味しいおち\nんちん、放っておくわけにはいかないの♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0203408" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「まだまだ旅行ははじまったばかり……次はどこでエッチしようかしら？　あ\nなたのおちんちん、独占できるんだもの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0203409" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_01_20" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「だから今度は、ちゃぁんと私のお口とか、おまんこに、あなたの精液を残さ\nず注いでちょうだいね♪」", "NORMAL" ]},
