{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0170" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_005" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「揃ったかい？　じゃ、改めて聞くけどね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_020113880001" ]},
		{"command":[ "SETCHARA", "0", "char_00002502_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「は……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113880001" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「祝日返上で参加した球技大会を滅茶苦茶にされ、敵には敗北し、あまつさえ\n警備員を攫われたと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_020113880002" ]},
		{"command":[ "SETCHARA", "0", "char_00002502_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒサイレーン" ]},
		{"command":[ "SETTEXT", "「や、やだなあ……さっきのはちょっとした冗談ですってば」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010113880001" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒサイレーン" ]},
		{"command":[ "SETTEXT", "「とはいえ確率的には、あの集団による乱入とカツマくんの略取なんて、想定\n外に類する事象なわけで」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010113880002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「同感なのです。あの集団がいったい何者だったのかも、まだわかっていない\nのですし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010113880001" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「行動原理も分析不可能な状況では、軽率に行動するのは自滅行為だったので\nす」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010113880002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「責任はむしろ、為す術なく攫われたカツマ自身にあるのでは？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_010113880001" ]},
		{"command":[ "SETCHARA", "0", "char_00002001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「そうそう。あいつがちゃんと警備してりゃ、変な連中に乱入されずに済んだ\nかもしれないし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010113880001" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「お黙り」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_020113880003" ]},
		{"command":[ "SETCHARA", "0", "char_00002502_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "みんな" ]},
		{"command":[ "SETTEXT", "「ひいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010113880002" ]},
		{"command":[ "SETCHARA", "1", "char_00000401_01", "3", "CENTER", "600" ]},
		{"command":[ "SETCHARA", "2", "char_00000501_01", "3", "CENTER", "-200" ]},
		{"command":[ "SETCHARA", "0", "char_00002001_01", "3", "CENTER", "200" ]},
		{"command":[ "SETCHARA", "3", "char_00002201_01", "3", "CENTER", "-600" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "DISPCHARA", "2", "TRUE" ]}, 
		{"command":[ "DISPCHARA", "3", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「経緯はどうあれ、私たちは恥をかかされたんだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_020113880004" ]},
		{"command":[ "SETCHARA", "0", "char_00002502_01", "4", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "DISPCHARA", "2", "FALSE" ]}, 
		{"command":[ "DISPCHARA", "3", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「目には目を。歯には歯を。『乱杰李威仏斗暴屡（らんじぇりい・ふっとぼう\nる）』には『乱杰李威仏斗暴屡』を」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_020113880005" ]},
		{"command":[ "SETCHARA", "0", "char_00002502_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「それらの故事通り、攫われた者は攫い返す。奪われたものは奪い返す。それ\nが、悪の組織だろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_020113880006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「それともあれかい？　お前たちはゼロかい？　ゼロの女幹部なのかい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_020113880007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒサイレーン" ]},
		{"command":[ "SETTEXT", "「ゼロ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010113880004" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「球技大会もぐだぐだ、仲間も攫われっぱなし――何ひとつ為しちゃいない。\nゼロだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_020113880008" ]},
		{"command":[ "SETCHARA", "0", "char_00002502_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「それは……確かに。なんの成果も得られていないのです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010113880004" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「そうやって、何をやるのもいい加減にして、一生ゼロのまま終わるのかい？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_020113880009" ]},
		{"command":[ "SETCHARA", "0", "char_00002502_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「それで良いのかい！？　お前たち、それでも幹部かい！？　悔しくはないの\nかい！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_020113880010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「それは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_010113880003" ]},
		{"command":[ "SETCHARA", "0", "char_00002001_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「……悔しい、です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113880002" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「お姉ちゃん？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010113880001" ]},
		{"command":[ "SETCHARA", "0", "char_00001701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「く゛や゛し゛い゛て゛す゛ぅぅぅ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113880003" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「おっ、お姉ちゃん！？　泣かないで、落ち着いて、ねっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010113880002" ]},
		{"command":[ "SETCHARA", "0", "char_00001701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「だ……って、だって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113880004" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「もっと早く、私が『乱杰李威仏斗暴屡（らんじぇりい・ふっとぼうる）』を\n始めて、強くなっていれば、こんなことには……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113880005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「いや……それは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010113880003" ]},
		{"command":[ "SETCHARA", "0", "char_00001701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYBGM", "BGM_027" ]},
		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「よーし、よく言った」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_020113880011" ]},
		{"command":[ "SETCHARA", "0", "char_00002502_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「ええ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010113880004" ]},
		{"command":[ "SETCHARA", "0", "char_00001701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「お前さえその気になれば、『乱杰李威仏斗暴屡』だってなんだって、やれる\nチャンスはいくらでもある」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_020113880012" ]},
		{"command":[ "SETCHARA", "0", "char_00002502_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「己の弱さと向き合い、悔しさを心に刻むことで、お前は強くなるだろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_020113880013" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「『乱杰李威仏斗暴屡』は、女幹部そのものだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_020113880014" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「ボールに対する執着心が勝利を呼ぶように、最後まであきらめない執着心が\n、女幹部には必要なんだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_020113880015" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「はいっ！！！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113880006" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「ええぇぇぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010113880005" ]},
		{"command":[ "SETCHARA", "0", "char_00001701_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「そのために私は、これからお前たちを殴る！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_020113880016" ]},
		{"command":[ "SETCHARA", "0", "char_00002502_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「はいっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010113880006" ]},
		{"command":[ "SETCHARA", "0", "char_00001701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「いいかい、殴られた痛みなど三日で消える」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_020113880017" ]},
		{"command":[ "SETCHARA", "0", "char_00002502_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「だけどね、今日の悔しさだけは絶対に忘れるんじゃないよ！　さあ、歯を食\nいしばりな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_020113880018" ]},
		{"command":[ "SETCHARA", "0", "char_00002502_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「お願いじますっ！！！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113880007" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「いや駄目お姉ちゃん、まともに殴られたらただじゃ済まないから――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010113880007" ]},
		{"command":[ "SETCHARA", "0", "char_00001701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「いくよ。せりゃ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_020113880019" ]},
		{"command":[ "SETCHARA", "0", "char_00002502_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「ひでぶっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113880008" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「あああっ、お姉ちゃーん！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010113880008" ]},
		{"command":[ "SETCHARA", "0", "char_00001701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「さあ。今度はそっちのお前たちもだよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_020113880020" ]},
		{"command":[ "SETCHARA", "0", "char_00002502_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒサイレーン" ]},
		{"command":[ "SETTEXT", "「……は？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010113880005" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「何故（なにゆえ）にであるか……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_010113880004" ]},
		{"command":[ "SETCHARA", "0", "char_00002001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「問答無用！　気合い一発！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_020113880021" ]},
		{"command":[ "SETCHARA", "0", "char_00002502_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒサイレーン" ]},
		{"command":[ "SETTEXT", "「はうっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010113880006" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「ぐはっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_010113880005" ]},
		{"command":[ "SETCHARA", "0", "char_00002001_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「痛ぇっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010113880003" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「いやあんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010113880001" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「コンプライアンス的にアウトなのですっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010113880005" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「不幸……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010113880001" ]},
		{"command":[ "SETCHARA", "0", "char_00001801_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「はあ……ふう……殴られて痛いだろう。が、殴った私だって心が痛い！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_020113880022" ]},
		{"command":[ "SETCHARA", "0", "char_00002502_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「だけど、こんなものではまだまだ、『乱杰李威仏斗暴屡』での勝利は遠い！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_020113880023" ]},
		{"command":[ "SETCHARA", "0", "char_00002502_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

