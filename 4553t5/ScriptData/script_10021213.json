	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「私が、お前の母だ。我が子よ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010114590001" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そんなの嘘だ……嘘だああああああーっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「なんだって……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114590001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「うそ……！　カツマが……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010114590001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「お前が手を貸してくれれば、時間帝国はさらに強大な力を得ることとなろう\n。あらゆる時を支配するのだ。さあ、息子よ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010114590002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「や、やめろ！　放せ！　放せーっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0177" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「カツマ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010114590002" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「カグヤ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「待てカグヤ！　早まるな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114590002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「姫様！　それにアナザーも！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスＤ" ]},
		{"command":[ "SETTEXT", "「おっと、邪魔はさせませんわよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_190114590001" ]},
		{"command":[ "SETCHARA", "0", "char_00000119_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "突然飛び込んできた３人の前に、ルナテミス・ダークが立ちはだかる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「っ！？　おまえは！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090114590001" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスＤ" ]},
		{"command":[ "SETTEXT", "「あらあら。私の偽者が二人もお揃いですの？　不愉快ですわね……いますぐ\n、消して差し上げます！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_190114590002" ]},
		{"command":[ "SETCHARA", "0", "char_00000119_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ダーク！　やめろっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスＤ" ]},
		{"command":[ "SETTEXT", "「あーっはっはっはっはっは！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_190114590003" ]},
		{"command":[ "SETCHARA", "0", "char_00000119_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「きゃああああーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010114590003" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「うわああああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090114590002" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「カグヤ！　アナザー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114590003" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ダークの一撃で、アナザーとカグヤが吹き飛ばされた！", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「くっ……！　」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090114590003" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「か、カツマ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010114590004" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「カグヤ！　アナザー！　大丈夫か！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「貴様……！　なにをする！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114590004" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスＤ" ]},
		{"command":[ "SETTEXT", "「なぁに？　なにか文句でもあるのかしら？　気に入らないのなら、体を張っ\nてでも止めたらいかが？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_190114590004" ]},
		{"command":[ "SETCHARA", "0", "char_00000119_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「体を……張って」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114590005" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "sbg_0170" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そうだ……！　母上様は、まさにそうした……！　女王として臣下を……仲\n間を守った！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114590006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「だったら、私にもできる！　王女として、仲間たちを……カツマを……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114590007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスＤ" ]},
		{"command":[ "SETTEXT", "「おやおや？　やる気を出したみたいですねえ？　よろしいですわよ。だった\nら、軽～くお相手を――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_190114590005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「もう誰も死なせない！　それが――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114590008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスＤ" ]},
		{"command":[ "SETTEXT", "「無理無理無理！　ぜーったい無理に決まってるじゃないの！　はーっはっは\nっはっは！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_190114590006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「できる！　それが――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114590009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0171" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_007" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「それが女王の役目だーーーーーーーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114590010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスＤ" ]},
		{"command":[ "SETTEXT", "「なっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_190114590007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ルナテミス様が……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010114590005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「でやぁああああああーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114590011" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0177" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "ルナテミスＤ" ]},
		{"command":[ "SETTEXT", "「うわぁあああっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_190114590008" ]},
		{"command":[ "SETCHARA", "0", "char_00000119_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "俺たちの見ている前で、突然ルナテミスの姿が変わった！　そして、ダークの\n剣を一撃で吹き飛ばす！", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ルナテミス……！　覚醒したというのか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090114590004" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「カグヤ！　アナザー！　こちらへ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114590012" ]},
		{"command":[ "SETCHARA", "0", "char_00000105_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「は、はい！　アナザー、立てる？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010114590006" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ああ、大丈夫だ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090114590005" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「これ以上、仲間たちに手出しはさせない。私は……私が！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114590013" ]},
		{"command":[ "SETCHARA", "0", "char_00000105_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ルナテミスは傷ついたカグヤとアナザーをしっかりと抱きかかえ、ダークをに\nらみ据える。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「月のプリンセスたる私が、皆を守る！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114590014" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスＤ" ]},
		{"command":[ "SETTEXT", "「面白いですわね！　だったら――やってごらんなさいなぁああああああーー\nーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_190114590009" ]},
		{"command":[ "SETCHARA", "0", "char_00000119_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}