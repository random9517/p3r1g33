{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0068" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「んん？　隊長さん？　そないなとこにおったんや。なあなあ、ちょっと休憩\nせえへん？　うちも今、お休みの時間やの♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0103101" ]},
		{"command":[ "SETCHARA", "0", "char_00027201_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「あんまり気ぃ張ったままじゃ、仕事の効率も落ちてまうよぉ～。そ・れ・に\n～。今お休みするんやったら、とびっきりええものをあげるんやけどな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0103102" ]},
		{"command":[ "SETCHARA", "0", "char_00027201_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「あはは、何か気になる？　それはねぇ……。サクヤお姉ちゃんに甘えていい\n権や♪　どや？　欲しいやろ？　そしたら、はようこっちにおいで♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0103103" ]},
		{"command":[ "SETCHARA", "0", "char_00027201_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「おお～♪　ええ甘えっぷりやねぇ～♪　なんてかわええ赤ちゃんなんやろ～\n♪　サクヤお姉ちゃんの～、おっぱい、どうでちゅか～？　あむあむ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0103104" ]},
		{"command":[ "SETIMAGE", "0", "still_00027201_01_02" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「おいちいでちゅか～♪　必死にチュッチュ吸ぅてますね～♪　……え？　い\nきなり乳首を吸われてイヤやないんか、って？　んふふふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0103105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「イヤやったらこないなことしてへんよ♪　安心して、バブバブしてくれてえ\nえんやからねぇ～……。もちろん、レロレロもちゅぱちゅぱもアリやでぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0103106" ]},
		{"command":[ "SETIMAGE", "0", "still_00027201_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「うちのおっぱい……なかなか悪くあれへんやろ？　これなぁ……。仕事中は\n重たくて重たくて、邪魔やな～って思うことも多いんやけども……。んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0103107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「こうやって、疲れた時に顔に乗せたり、吸ったりすると癒されるやろぉ？　\n疲れがじわ～って抜けていく感覚……っていうんかなぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「んっ……。ふふふふふ♪　そないに夢中で、一所懸命に舐められたら……照\nれるけど。このおっぱいは、今だけはぜーんぶ丸ごと隊長さんのモンやから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0103109" ]},
		{"command":[ "SETIMAGE", "0", "still_00027201_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「好きにしてぇな……♪　そのかわり～。うちも隊長さんのご立派なオチンポ\nを、思う存分ニギニギさせてもらうわ。等価交換ってやつやねぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「……ねえ。勃起しとるっていうのもあるやろけど。隊長さん……オチンポス\nゴいなぁ、強いなぁ、って色んなヒトに言われたことあるんやない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0103111" ]},
		{"command":[ "SETIMAGE", "0", "still_00027201_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「だって、手に持っただけでズシンって重たいんやもの。そして……、さわさ\nわさわ……♪　この硬さ。ゴツゴツした質感……これはアカンやつやでぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「女泣かせの、ワッルいオチンポや……♪　んん？　うちは好きよ。こういう\n凶悪なオチンポ……。大好物やし、イジりがいがあって最高やわ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「今から、この極悪オチンポ……。サクヤお姉ちゃんが、イジイジして、さわ\nさわして……撫で回したり、つついたり、た～っぷり遊んで焦らしてな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0103114" ]},
		{"command":[ "SETIMAGE", "0", "still_00027201_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「気持ちよ～くしてあげるさかいに、イケる！　って思ったらすぐにビュルビ\nュル射精してええよ♪　うん、うん。たくさん出してくれると嬉しいわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0103115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「オチンポに溜まった疲れ……。ピュッピュして解放していこな。それじゃあ\n、まさぐるで……？　そぉれ……そぉれ……。やん♪　太いわぁ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「わっ♪　太すぎて、うちの親指と人差し指では掴みきれんわ。オチンポの方\nが余ってまう……。えぇ～♪　これはとんでもない逸品やね～♪　っんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0103117" ]},
		{"command":[ "SETIMAGE", "0", "still_00027201_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「国宝級のオチンポ触らせてもろて、うちの方が感謝せんとねぇ～。……んッ\n……♪　こうやろか？　こうやって、てのひらで……根元からカリ首まで」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「シコ、シコ、シコってシゴいていきながら……。あんんっ♪　そうや♪　お\nっぱい吸われて、感じたり……。あぁん♪　喘いだりぃ……♪　あっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0103119" ]},
		{"command":[ "SETIMAGE", "0", "still_00027201_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「恋人同士みたいに、イチャイチャベタベタしながら二人で高まっていくねん\n……♪　はぁ、はぁ、はぁ……。ええよ。おっぱい吸うの上手やねぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「ちゅぅっ、ちゅぅって音をたてて吸って……。んんん♪　なんやろ、可愛ら\nしいわ。……ん？　どしたん。褒められたらオチンポ反応したねぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「そういう甘々なのが好きなんやったら……こういうんはどう？　エラ～い♪\n　エラぁ～い♪　隊長さん、オチンポ勃起させてカッコええねぇ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0103122" ]},
		{"command":[ "SETIMAGE", "0", "still_00027201_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「うちの手首、おかしくなりそうなくらいぶっといオチンポや……♪　こんな\nん見せつけられながら、おっぱい吸われたら……嫌でも想像してまうわ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「……うちのオメコにこれが入ったら……どんだけ気持ちええんやろって♪　\n想像しながらシゴいとるよ……♪　おっきすぎてなかなか入らんかも♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0103124" ]},
		{"command":[ "SETIMAGE", "0", "still_00027201_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「でも……。こないにエッグいオチンポで突かれたら……泣いてしまうかもし\nれへんなぁ～♪　男らしくて、逞しいオチンポ……好きなんよぉ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0103125" ]},
		{"command":[ "SETIMAGE", "0", "still_00027201_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……♪　わかるやろ？　うちの心臓の音……聞こえる？　隊長さ\nんのオチンポに触れて……このアッツアツの肉の棒を刺激してると」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「だんだん、くっさい男の臭いがしてきて……、あんっ♪　お股がウズウズし\nてくるんよ……♪　はぁっ、あんっ♪　これ……欲しいわぁ、素敵やもん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「んんぁっ……あぁっ♪　アカン……濡れてきたわ……♪　あ、でも隊長さん\nのオチンポも一緒やね……♪　先っちょ、お汁出てきとるわぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0103128" ]},
		{"command":[ "SETIMAGE", "0", "still_00027201_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「んんっ、カウパーやね……♪　これを人差し指ですくいとって……はぁい、\nクチュクチュクチュ♪　尿道口に指の腹当ててクチュクチュクチュぅ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「あっ♪　気持ちええ？　気持ちええの？　そしたらいっぱいしたげるね♪　\n亀頭をくりくり親指でイジメながら、尿道口をクチュクチュクチュぅう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「んっ、ンンッ……♪　ピクピク震えてる……♪　やらしいなぁ～……♪　見\nて……いやらしいお汁でオチンポがヌルヌルになってきとる……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0103131" ]},
		{"command":[ "SETIMAGE", "0", "still_00027201_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「うちのおっぱいと同じやね……♪　ん、ぁっ、あっ、あんっ……♪　ぢゅー\nって吸われて、ぴちゃぴちゃ舐め回されて……唾まみれ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「っあぁんっ♪　どうしたん？　ますますオチンポがお盛んになってきてるで\n？　あっ♪　うちの乳首もおっきくなってきとるからオアイコかぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0103133" ]},
		{"command":[ "SETIMAGE", "0", "still_00027201_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「なぁ……♪　うち、おっぱいだけで軽くイッてしまいそうやねん……♪　隊\n長さんも、そろそろ精子……出したくてしょうがないんと違う？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「な♪　一緒にイこ……♪　裏筋から先っちょまで、ぜーんぶ刺激したげるか\nら……♪　あっ、ぁっ、出して♪　ザーメン出るところ見たいんよぉ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0103135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「ひゃんっ♪　あぁんっ♪　出たぁ♪　出た出たぁ～……♪　あっ♪　すっご\nい溜まっとったんやねぇ～♪　すっごい勢いやん……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0103136" ]},
		{"command":[ "SETIMAGE", "0", "still_00027201_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「ええよええよぉ♪　一気に全部出してくれるぅ？　あっ……♪　あっつぅい\n……♪　それに、指でつまめそうなくらいネットリしとるぅ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0103137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「あはっ♪　あはははっ♪　どんどん溢れてくるぅ♪　ちゃーんと抑えとかん\nと、どこまでも飛んでいってしまいそうや……♪　っあっ、ぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「隊長さんのザーメン、真ぁっ白やん……っ♪　これは相当出すの、ガマンし\nとったんちゃうん？　あー、辛い思いさせてしもたねぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0103139" ]},
		{"command":[ "SETIMAGE", "0", "still_00027201_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「これからは、無理せずイキたい時にイッてええからねっ♪　その方が……う\nちも嬉しいし、感じるから……♪　ッんんっ♪　まだ出てるよぉ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「……ん……♪　ようやく出ぇへんようになったみたいやねぇ～♪　で・も…\n…完全に萎えたってワケでもない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0103201" ]},
		{"command":[ "SETIMAGE", "0", "still_00027201_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「いわゆる甘勃起っちゅうやつやね♪　ふぅ～ん……。まだ、ちょーっと疲れ\nが残っとるっちゅうことか。それなら、お付き合いしてあげんとねぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「そぉーれ、なでなで～♪　な～でなで～♪　……あ♪　ええやん♪　復活し\nてきたわ。し・か・も……一回目よりバッキバキ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0103203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「これはまだまだ、しっかり甘えてもらわんといかんみたいやし……。続ける\nで？　ほらっ、隊長さん。ボーッとしとらんとおっぱい吸っときぃ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0103204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「んっ……んふっ♪　どうしたん？　さっきより随分吸いつきが強いけど……\n♪　あっ♪　んぅっ……一回射精して、甘えんぼモードになってもうた？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0103205" ]},
		{"command":[ "SETIMAGE", "0", "still_00027201_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「……よぉーしよしよし……♪　サクヤお姉ちゃんが、癒しのオチンポなでな\nでをもう一回してあげような～♪　んっ、隊長さんの精子を指に……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「絡めながら、にちゅ♪　にちゅ♪　ってオチンポをいじくり回すんや……♪\n　っはぁっ、ザーメンが潤滑油がわりになって、なかなかエロいやろ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「隊長さんのオチンポが、精液でヌルヌルになってるの……見てるこっちも興\n奮するし♪　んっぅっ♪　おっぱいはずーっと連続で吸われとるしぃ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「おっぱい吸うてる時のぉ……、んっ♪　隊長さんのお顔、好きやわぁ……♪\n　目がとろーんとしてて、うちの乳首をちゅぱちゅぱレロレロしてくれてて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0103209" ]},
		{"command":[ "SETIMAGE", "0", "still_00027201_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「オチンポ握ってる手ぇに思わず力入ってまう……♪　はぁっ、あっ、甘やか\nしたいわぁ♪　もう、うち無しでいられんくなるくらい……ドロドロに♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0103210" ]},
		{"command":[ "SETIMAGE", "0", "still_00027201_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「甘やかして、抱きしめて、エッチなことだけずーっとするんよ……♪　一生\n、オチンポいじってあげまちゅねぇ♪　こうかなぁ？　ここはどうや～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「んっ……！　んっ、シコシコシゴいとるオチンポが、喜んでピックピク痙攣\nしとるわ……♪　はぁっ♪　反応、わかりやすくて参考になるぅ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0103212" ]},
		{"command":[ "SETIMAGE", "0", "still_00027201_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「こうやね……♪　オチンポ全部、うちの指で、手で包みこんで……ぐに、ぐ\nに、ぐに♪　シコ、シコ、シコ……♪　あぁあ、ま～た震えとるぅ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0103213" ]},
		{"command":[ "SETIMAGE", "0", "still_00027201_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「うんうん、気持ちええねぇ～♪　サクヤお姉ちゃんのシコシコは、オチンポ\nを元気にするシコシコやからねぇ♪　愛がい～っぱい詰まってるんよぉ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0103214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「ゆっくりゆっくり、おタマタマに精子を溜めて……またびゅーって出そうね\nぇ♪　一番気持ちええとこで、もいっちょ射精させたるから……。んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0103215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「うちのふわふわおっぱいに包まれて、コリッコリになった乳首……んんっ♪\n　飴ちゃんみたいに、お口ん中で転がして……。っはぁっ♪　あぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0103216" ]},
		{"command":[ "SETIMAGE", "0", "still_00027201_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「この世の極楽っちゅうのを堪能してなぁ♪　んんっ、はぁっ♪　上手やぁ、\n吸えば吸うほど乳首舐めが上手くなって……スゴいわぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「んっ……♪　あは、ほんっとドスケベなオチンポやなあ♪　精子出したくな\nったら、わっかりやすくおねだりしてくるしぃ♪　んっ、どしたん？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0103218" ]},
		{"command":[ "SETIMAGE", "0", "still_00027201_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「うちの手ぇにぐりぐりオチンポの先っちょ押しつけて、こすり始めたやん♪\n　腰も揺れてるで？　そやの？　出したいの？　ザーメン……んふふふっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「そんならサクヤお姉ちゃんに甘えとき♪　んっ……出してええよ♪　おいで\n、おいでっ……♪　うちにとびきりの射精見せてっ……♪　出してぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「あはぁっ♪　クるやんキテるやぁんっ……♪　んはぁ～～～♪　二回目の射\n精やのに、すっごい量……。音が出そうなくらいドックドク出とるしぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0103301" ]},
		{"command":[ "SETIMAGE", "0", "still_00027201_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「そんなにうちの手コキ、好きなん？　あぁっ♪　あ、ぁ、スゴいわぁ、止ま\nらへん……！　びゅぶ、びゅぶって手の中で暴れとるぅうう……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「んふっ、ふふふっ♪　まるでオチンポがはしゃいどるみたいやぁ……♪　サ\nクヤお姉ちゃんにびゅるびゅるさせてもらって嬉しい～って、なぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0103303" ]},
		{"command":[ "SETIMAGE", "0", "still_00027201_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「そないに慌てんでも、おタマタマが空っぽになるまで手で絞りあげたるさか\nいにっ……♪　ほれっ……どうやぁ？　下から上へシゴき上げていって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0103304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「はい、ビュク～ッ、びゅぶぶぶぶ～っ♪　あ～♪　めっちゃ上手に発射して\nくれるやん、見てるこっちも気分ええわ、それに……、あっんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0103305" ]},
		{"command":[ "SETIMAGE", "0", "still_00027201_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「うちの胸……キュンキュンしとる♪　母性本能でイキそうや……！　っ、ぁ\nっ♪　かわええなぁ♪　隊長さんの甘えんぼぉ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0103306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「ん～～～♪　ようやくストレス、無くなったんかな？　隊長さん……えっら\nい幸せそうな顔しとる。うちまで幸せになってくるくらいや……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0103307" ]},
		{"command":[ "SETIMAGE", "0", "still_00027201_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「たま～にこういうご褒美があると、仕事にも精が出るっちゅうもんやろ？　\nせやけど……うちかて、誰にでもこないなこと、するわけやないで？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0103308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「見込みのある、……んでもってサクヤお姉ちゃん好みの子ぉにしかせえへん\n特別なご奉仕っちゅうやつや。だから、他の子らには内緒……やで？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「秘密にしとったら……。んふふふふ♪　これからも、特別なご褒美があるか\nもしれへんやろ？　それを楽しみに、キリキリ働いてもらわんとねえ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0103310" ]},
		{"command":[ "SETIMAGE", "0", "still_00027201_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「っんぁっ♪　オチンポが跳ねて……！　あっ！？　アカンよっ……！　顔に\n、カラダにザーメンびゅるびゅるかかっとるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0103401" ]},
		{"command":[ "SETIMAGE", "0", "still_00027201_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「あっ♪　あっぁっ、もぉうちでは手に負えへんっ……♪　ここまで来てもう\nたら、止めろ言うたからって止まらへんやろっ……、好きに出しぃ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「サクヤお姉ちゃんが、隊長さんのザーメン……♪　精子♪　お疲れのモトを\nぜ～んぶぜ～んぶ受け止めたるわ♪　はぁっ、あ、ぁ、あっつぅい～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0103403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「これがザーメンシャワーってやつやねぇ♪　んっ、胸に……顔に……♪　あ\nぁん♪　本能が刺激される、くっさいくっさい男の汁の臭いやぁ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0103404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「はぁっ、あっ、あぁっ♪　このヌルつきを肌で感じたら……あっぁっあっ！\n　うちも、うちもイクっ……！　ザーメン浴びながらイッてまうっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0103405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「んぁあああああ～～～っ♪　あぁっ、あぁああぅううっ♪　かけてぇ♪　も\nっとかけてええよ！　欲しいねん、隊長さんのザーメンんんっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0103406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「はーぁ、男のコってスゴいなぁ～♪　一回射精して、な～んも残ってへんと\n思っとったのに……すこーし時間がたてばこんなに出すんやもん……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0103407" ]},
		{"command":[ "SETIMAGE", "0", "still_00027201_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「サクヤお姉ちゃん、隊長さんのコト……ちょこっと見くびっとったのかもし\nれへんなぁ。もしくは～、シてる間に成長したのかもしれへんけど～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0103408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「うちなぁ……♪　甘やかしがいのある、成長株の男のコが好きやねん。だか\nら、今日からは完全に目ぇつけさせてもらうわ。隊長さんを観察したい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0103409" ]},
		{"command":[ "SETIMAGE", "0", "still_00027201_01_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「隊長さんがどんだけええ男になっていくんか……。それを一番の特等席で見\nさせてくれたら助かるわ。んふふ、楽しみが増えて嬉しいわぁ～♪」", "NORMAL" ]},
