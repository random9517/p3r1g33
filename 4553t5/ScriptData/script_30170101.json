{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「また私の、エッチな話を聞かせて欲しい……？　言わないと、お姉ちゃんに\nあることないこと報告するって……そ、そんなの、脅迫じゃないですか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0103101" ]},
		{"command":[ "SETCHARA", "0", "char_00001701_01", "2", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「そもそも、もうこの手の話はしないという約束じゃ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0103102" ]},
		{"command":[ "SETCHARA", "0", "char_00001701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「ううぅ……！　わ、わかりました……！　話しますから、お姉ちゃんに言う\nのだけは許してください……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0103103" ]},
		{"command":[ "SETCHARA", "0", "char_00001701_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「それと、もうこんなセクハラみたいなことはしないと、約束してください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0103104" ]},
		{"command":[ "SETCHARA", "0", "char_00001701_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「今、首を縦に振りましたね！　絶対に、約束は守ってもらいますよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0103105" ]},
		{"command":[ "SETCHARA", "0", "char_00001701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「んっ、あふっ……オチンチン、もうこんなに大きくなってますね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0103106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00001701_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「それにいつもよりカタくなって、血管も浮き出てます……挟んでいるだけで\n、私まで熱くなってきちゃいます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0103107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「これ、私のおっぱいで気持ちよくなってくれてるってことですよね？　だと\nしたら、すごく嬉しいです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「どうしてって……私はお姉ちゃんみたいに胸が大きくないですから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「おっぱいでオチンチンをスリスリしようとしても、満足してもらえないんじ\nゃないかと思って……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「ですが、こうしてカタくなったオチンチンを見てたら、なんだか勇気が出て\nきました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0103111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「いっぱいスリスリするので、たくさん感じて、気持ちよくなってください…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「それじゃあ、はじめさせてもらいますね……んっ、しょ……んっ、んんっ…\n…！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「すごい……私、本当におっぱいでオチンチンをスリスリしてる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「熱い感触が直接肌に伝わってきて……んっ、あんっ……！　擦ってるだけな\nのに、感じちゃいます……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0103115" ]},
		{"command":[ "SETIMAGE", "0", "still_00001701_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「んっ、くっ……はぁ、あぁっ……ど、どうですか……？　オチンチン、気持\nちよくなってますか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0103116" ]},
		{"command":[ "SETIMAGE", "0", "still_00001701_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「は、はい……もっと強く挟んで、全身を使ってオチンチンをシコシコして欲\nしいんですね……わかりました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「大きくないので、そんなに強くは挟めませんが……はぁ、あっ、くぅ……！\n　が、頑張ります……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「おっぱいを寄せてから、全身を思いっきり動かして……んっ、しょ……はぁ\n、あふっ、くうぅぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0103119" ]},
		{"command":[ "SETIMAGE", "0", "still_00001701_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「あっ……んんっ！　オチンチンの先っぽから、透明なお汁が……！　はあぁ\nぁぁん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「おっぱいにたくさんかかってます……！　エッチなお汁で、ベトベトになっ\nちゃうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「それに、ニオイも濃くて……すんすん……はぁぁぁ……変な気分になっちゃ\nいます……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「オマンコに響くと言いますか……子宮がきゅんってしてくる感じです……！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「んっ、ふぐっ、くぅぅぅ……！　やっ、どうして……身体が勝手に動いてま\nすっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「オチンチンのニオイを嗅いだだけなのに……私、発情しちゃってるっ……！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「あっ、んっ、うぐっ……！　ふぁ、んんんっ……！　弄ってないのに、乳首\nも大きくなってきて……ああぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0103126" ]},
		{"command":[ "SETIMAGE", "0", "still_00001701_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「やっ……そんな目で見ないでください……！　おっぱいでオチンチンをシコ\nシコしてる、はしたない姿……見ないでぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「えっ、エッチで可愛いだなんて……！　そ、そんなこと言われたら、もっと\n発情しちゃいますっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「あなたのオチンチン、もっとおっぱいで感じたいって思っちゃいますぅ……\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「やっ、ああっ！　んっ、うあぁぁぁ……！　オチンチンのデコボコしてると\nこが、おっぱいに擦れて、気持ちいいです……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「オマンコをズポズポされてるわけじゃないのに……お、オマンコ感じて……\nはあぁぁっ！　やっ、ああっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「あぅ、くふっ、ふああぁ……！　オチンチンがビクンってしてます……！　\nあ、あなたもイキそうなんですね……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0103132" ]},
		{"command":[ "SETIMAGE", "0", "still_00001701_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「で、でしたら、一緒に……！　私と一緒にイッてくれると……う、嬉しいで\nすっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「あっ、あっあっ……！　ふぁっ、んっ、はあぁ……！　イクッ……イッちゃ\nいますっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0103134" ]},
		{"command":[ "SETIMAGE", "0", "still_00001701_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「オチンチンもイキそうで……あああっ……！　イッ、イクッ……！　オチン\nチンと一緒に、イッちゃうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0103135" ]},
		{"command":[ "SETIMAGE", "0", "still_00001701_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「はああぁ……！　おっぱいに精液がびゅるびゅる出てますっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0103136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001701_01_04" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「オチンチンより熱くて……透明なお汁より、濃いニオイがしますっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0103137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「もっと出してください……！　あなたの精液、全部私にかけてっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「オマンコに出すときみたいに……びゅーびゅー射精してくださいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「あっ……ああっ……！　くっ、んんっ……！　はぁ、ああっ……ふああぁぁ\nぁぁ～～～……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「はああぁ……たくさん出ましたね……私のおっぱい、精液でドロドロになっ\nてます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0103201" ]},
		{"command":[ "SETIMAGE", "0", "still_00001701_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「私も感じすぎて、イッてしまいました……オッパイでスリスリしただけなの\nに……うぅ……はしたないです……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「えっ……ま、まだ出したいんですか……？　こんなに出したばかりなのに…\n…？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0103203" ]},
		{"command":[ "SETIMAGE", "0", "still_00001701_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「私のパイズリが気持ちよかったって……あ、ありがとうございます……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0103204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「でしたら、もう一度……私のおっぱいで、オチンチンをスリスリさせてもら\nいますね……さっきみたいに、たくさん感じてください……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「んっ、くっ……はあぁ……！　精液のおかげで、すごく動かしやすいです…\n…これなら、もっと強くスリスリできますね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「ふふっ……オチンチンがおっぱいで暴れてますよ。さっきよりも気持ちいい\nんですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「えっ……あ、はい……私も気持ちいいです……オチンチンの感触が、より強\nく伝わってきてますので……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「それに……すんすんっ……すぅー……はぁぁぁ……精液のおかげで、ニオイ\nも濃くなってきてますから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「もっとおっぱいに圧をかけて擦ると、精液のニオイが濃くなるんですか……\n？　そうなんですね……では、やってみます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0103210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「くっ……あふっ、あっ……！　はぁ、あああっ……！　ほ、本当にニオイが\n濃くなってきました……すごく、エッチなニオイがします……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0103211" ]},
		{"command":[ "SETIMAGE", "0", "still_00001701_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「ああっ、んっ、んくぅぅぅ……！　はぁ、ああっ……！　これ、クセになり\nそうです……！　もっと、強くしますね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0103212" ]},
		{"command":[ "SETIMAGE", "0", "still_00001701_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「はあぁぁ……オチンチンの熱だけじゃなくて、脈を打ってるのまで伝わって\nきます……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0103213" ]},
		{"command":[ "SETIMAGE", "0", "still_00001701_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「あなたの心音がオチンチンから伝わってくるみたいで……んんっ！　とって\nも、興奮しますっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0103214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「ふっ、うぐっ……！　はぁ、あはぁぁぁ……！　ダメっ……またオマンコの\n奥が、疼いてきちゃってます……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0103215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「はぁ、あんっ……！　あっ、あっあっ……！　ひぐっ、んふぅ……！　お、\nお願いします……また精子をくれませんか……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0103216" ]},
		{"command":[ "SETIMAGE", "0", "still_00001701_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「あなたのドロドロな濃厚ザーメンで、イキたいんです……！　だ、だから…\n…はうっ、あっ、ふあぁぁぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0103217" ]},
		{"command":[ "SETIMAGE", "0", "still_00001701_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「やっ、あっ！　くっ、あふっ……！　オチンチンがおっぱいの中で暴れて…\n…ふぐっ、くぅぅぅん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0103218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「だ、出してくれるんですね……！？　ありがとうございます……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「ええ、いつでも……出してください……！　全部、受け止めますから……！\n　あっ、あっあっあっ……！　ひあぁぁぁんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「くっ、あふっ、んふうぅぅ……！　またこんなに、精液出してくれるなんて\n……あっ、はあぁ、ふああぁぁぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0103301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001701_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「射精するたびに、オチンチンがビクンって動くの……可愛くて好きです……\n！　もっと擦りたくなってきます……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0103302" ]},
		{"command":[ "SETIMAGE", "0", "still_00001701_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「あっ、うぐっ、ふあぁ……！　す、すごい……！　射精中にスリスリすると\n、勢いが増してきます……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0103303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「私のことは気にしないでください……あなたの精液を感じれることの方が、\n嬉しいので……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0103304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「それに……私も軽くイッてますから……！　だ、だから……もっと出して…\n…はぁ、あぐっ、んふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0103305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「ふぅ……ふぅ……どうでしたか？　気持ちよかったですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0103306" ]},
		{"command":[ "SETIMAGE", "0", "still_00001701_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「えへへ……私のおっぱいでも、ちゃんとシコシコできたんですね。嬉しいで\nす」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0103307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「別におっぱいの大きさを気にすることなんてない……？　で、ですが……男\nの人は、大きい方が好きなんですよね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0103308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「好みは人それぞれなんですね……なら、あなたは私のおっぱいが好きという\nことですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「ちょ、ちょっと！　どうしてそこで口を閉ざすんですか！？　そこは素直に\n、好きって言って欲しいです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「ひああぁぁぁ……！？　おっぱい全体に、精液がかかってます……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0103401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001701_01_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「やっ、熱っ……！　こんなにベトベトの精液を撒き散らされたら、肌に染み\n付いちゃいます……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0103402" ]},
		{"command":[ "SETIMAGE", "0", "still_00001701_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「それに……あっ、んぐっ……！　エッチなニオイがすごく伝わってきて……\n！　はあぁぁ……ダメっ……！　イッ、イッちゃいます……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0103403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「熱い精液を浴びながら……わ、私……！　はしたなく、イッちゃいますぅ…\n…！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0103404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「ああっあっ、ひぐっ……！　んっ、あふっ、ふぎゅっ……はぁぁぁ、あっ、\nああっ……んはぁぁぁん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0103405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「あんっ……早く拭かないと、身体にニオイが染み付いちゃいます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0103406" ]},
		{"command":[ "SETIMAGE", "0", "still_00001701_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「えっ……？　このまま拭かずに居て欲しい……？　ど、どうしてですか……\n！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0103407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「エッチなニオイを、身体に染み込ませたいって……そ、そんな変態みたいな\nこと、したくありませんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0103408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「うぅ……そんな目で見てもダメです……！　ニオイが染み付いたら、お姉ち\nゃんにバレちゃいますし……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0103409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「そ、それに……精液のニオイを感じ続けるだなんて……そんなの、発情しっ\nぱなしになっちゃいますから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0103410" ]},
