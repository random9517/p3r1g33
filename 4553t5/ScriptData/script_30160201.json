{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「えっ……？　エッチの経験はあるのか、ですって……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0203101" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「ば、バカにしないでください！　それぐらい、私にだってあります……って\n、なにを言わせるんですか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0203102" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「お堅いから、そういったことに興味がないと思ってたですって？　私だって\n鬼である前に、一人の女です。性欲だってあります」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0203103" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「今までどんなエッチをしてきたのか、教えて欲しい……？　べ、別にたいし\nたことはしていません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0203104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「学園の廊下でキスをしながら、オチンチンを手でシゴいたとか、その程度で\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0203105" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「んっ、あふっ……あっ、ああぁ……！　ちょ、ちょっと……！　そんなにオ\nチンチンを押し付けないで……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0203106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00001602_01_03" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「チカラを手に入れるためとはいえ、こんなところでオチンチンを触るだなん\nて……んっ、あぁあんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0203107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「ほ、本当に、オチンチンを手でシコシコすれば、強くなれるんですね？　嘘\nついたりしてませんよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0203108" ]},
		{"command":[ "SETIMAGE", "0", "still_00001602_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「手コキだけじゃなくて、キスもする必要がある……？　それって、キスしな\nがら手でオチンチンをシゴくということですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0203109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「い、イヤというワケではありません……！　ただ、その……キスをしながら\nというのは、恥ずかしいと言いますか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0203110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「オチンチンを手でシゴく方が恥ずかしい……？　そ、それは確かにそうなん\nですが……キスというのは、特別なモノだと思うので……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0203111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「ああ、もう！　わからないならいいです！　さっさと終わらせますよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0203112" ]},
		{"command":[ "SETIMAGE", "0", "still_00001602_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「上下に擦るだけなら、すぐに終わります……んっ、んんっ……！　くっ、あ\nはああっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0203113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「軽く手を動かしただけなのに、すごく膨らんでる……それにさっきよりも、\nオチンチンが熱くなって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0203114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「んっ、はぐっ、くううぅ……！　せ、先端からお汁が出てきましたね……こ\nのカリの部分が気持ちいいんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0203115" ]},
		{"command":[ "SETIMAGE", "0", "still_00001602_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「なら、もっとシゴいてあげます……こうやって手で亀頭の部分を包んで、ク\nリクリすれば……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0203116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「ふふっ。オチンチンがビクビク跳ねてますよ。根本の部分より、先端の方が\n刺激に弱いみたいですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0203117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「亀頭だけじゃなくて、全体をまんべんなくシゴいて欲しいんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0203118" ]},
		{"command":[ "SETIMAGE", "0", "still_00001602_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「わかりました……そうして欲しいというなら、そうさせてもらいます……ん\nっ、んんっ……！　あっ、あふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0203119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「えっ……あ、はい。そうでしたね……キスもする必要がありましたね……ん\nっ、ちゅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0203120" ]},
		{"command":[ "SETIMAGE", "0", "still_00001602_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ……ちゅ、くちゅ……ちゅぷ、ちゅ、ずちゅ……！　んっ、はあぁ\n……キスをしたら、もっとオチンチンが大きくなりましたよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0203121" ]},
		{"command":[ "SETIMAGE", "0", "still_00001602_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「私の手と唇で、興奮してくれたということですよね……ちゅ、ちゅぱっ……\nちゅ、ちゅちゅ……んちゅ、ぐちゅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0203122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「んっ、んんんっ……！　し、舌が絡まって……！　ちゅぱ、れりゅ、れろれ\nろっ……ちゅぷ、ちゅぴっ……んっ、ちゅるるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0203123" ]},
		{"command":[ "SETIMAGE", "0", "still_00001602_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「ぷはっ……はぁ、はぁ……そんなにがっつかないで……！　オチンチン、シ\nコシコしにくくなっちゃうわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0203124" ]},
		{"command":[ "SETIMAGE", "0", "still_00001602_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「我慢汁をオチンチンに馴染ませると、滑りがよくなってシゴきやすくなるの\n……？　確かに、言われてみればそうかも知れないわね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0203125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「早速試してみるわね……えっと、手で我慢汁をすくって、オチンチンに馴染\nませて……んむっ、ちゅ……んぐっ、んむううぅっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0203126" ]},
		{"command":[ "SETIMAGE", "0", "still_00001602_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「ちょ、ちょっと……いひなりキスすりゅなんれ……！　ちゅぱ、ちゅりゅ、\nちゅぷぷっ……くちゅ、ずちゅ、ちゅちゅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0203127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「そ、そんにゃに強く求めらりぇひゃら、私……！　んちゅ、ちゅぱっ……ち\nゅるっ、ちゅぱっ……れろれろっ、れりゅ、ぐちゅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0203128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「んぷっ……！　はぁ、はぁ……！　あんんっ……！　オチンチンがもっとカ\nタくなってる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0203129" ]},
		{"command":[ "SETIMAGE", "0", "still_00001602_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「シコシコするたびに、別の生き物みたいに動きまわって……そんなに動かれ\nたら、シゴきにくいわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0203130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……！　こんなにビクビクしてたら、そろそろイキそうね……い\nいわよ。好きなときに出して頂戴……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0203131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「んちゅ、ちゅちゅ……！　ちゅぷ、ちゅ、ぐちゅるっ……！　んちゅ、ちゅ\nぱっ……んぐっ、んむうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0203132" ]},
		{"command":[ "SETIMAGE", "0", "still_00001602_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「ちゅぱ、ちゅぴっ……んっ、ちゅちゅ！　ぷはっ……あっ、あああっ……！\n　す、すごいわ……！　オチンチンが何度も手の中で暴れてる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0203133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「もう出るのね……！　それなら、思い切りシコシコしてあげるわ……んちゅ\n、ちゅぱっ……れりゅ、ちゅ、ずちゅ、ぐちゅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0203134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「んっ、んんっ……んふううぅ……！　あっ、くりゅ……ザーメンくりゅ……\n！　ちゅ、ぷちゅ、ちゅぱっ……ちゅうううぅ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0203135" ]},
		{"command":[ "SETIMAGE", "0", "still_00001602_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「んちゅううぅぅぅぅ～～～……！？　あっ、ふああぁ……あ、あちゅいザー\nメン、手の中にびゅるびゅる出てりゅうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0203136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001602_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「んぐっ、ちゅぱっ……！　あっ、んんんっ……！　こんらに出さりぇたら、\n手にニオイが染み付いちゃうわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0203137" ]},
		{"command":[ "SETIMAGE", "0", "still_00001602_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ……ぐちゅ、ちゅ……！　んっ、んんんっ……！　あっ、ふあぁ…\n…ま、まら出りゅのね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0203138" ]},
		{"command":[ "SETIMAGE", "0", "still_00001602_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「あなたの精液が全部出るまれ……いっぱい、シコシコしてあげりゅわ……ち\nゅぱっ、ちゅちゅ……んっ、れろれるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0203139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「ちゅ……んちゅ、ちゅぷぷっ……！　ずちゅ、ちゅぷっ……ぷはっ……！　\nはぁ、はぁ……あっ、あんんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0203140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「いっぱい出たわね……目的も達成したし、これで終わりにしましょう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0203201" ]},
		{"command":[ "SETIMAGE", "0", "still_00001602_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「えっ……ちょ、ちょっと……！？　どうしてまたオチンチンを押し付けてく\nるの……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0203202" ]},
		{"command":[ "SETIMAGE", "0", "still_00001602_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「この程度じゃ強くなれない……？　もっとキスして、手コキをする必要があ\nる……？　あんなに出したのに、まだするの……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0203203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「べ、別にイヤじゃないけど……誰か来るかも知れないし、せめて違う場所で\n……あんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0203204" ]},
		{"command":[ "SETIMAGE", "0", "still_00001602_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「わ、わかったわ……！　もう一回ここでしてあげるから、少し落ち着いて…\n…あっ、やああっ……！　んむっ、んんんっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0203205" ]},
		{"command":[ "SETIMAGE", "0", "still_00001602_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ、ちゅちゅ……ぐちゅ、ずちゅるっ……くちゅ、ちゅぷぷっ……！\n　んちゅ、ちゅっ……ちゅうううぅぅぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0203206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「さっきよりも、舌が絡んできてりゅ……！　ちゅぱっ、ぐちゅ、ちゅぽっ…\n…！　ずちゅ、れろれろっ、ぐちゅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0203207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「んぐっ、ごくんっ……あっ、んむっ……！　だ、唾液がいっぱひ、口の中に\n押し込まれてりゅ……んちゅ、じゅるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0203208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「ちゅぷ、ちゅ……ぷはあぁ……！　キスに夢中だったせいで、シコシコでき\nてないわ……！　すぐに気持ちよくしてあげるから……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0203209" ]},
		{"command":[ "SETIMAGE", "0", "still_00001602_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……あっ、んふぅぅぅ……！　我慢汁だけじゃなくて、ザーメン\nもオチンチンに塗って……これで、シゴきやすくなったわね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0203210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「ヌルヌルの状態でオチンチンをシコシコされるの、気持ちいいみたいね……\n我慢できないって顔してるわよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0203211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「これなら、すぐにでもイケそうね……もっと私の手に身を委ねて……あっ！\n　ちょっと、また……！　んむっ、ちゅちゅうぅ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0203212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「れろっ、ぐちゅ……！　ちゅぱ、ちゅぷっ……！　お、落ち着ひて……！　\n私は逃げないかりゃ……んぐううぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0203213" ]},
		{"command":[ "SETIMAGE", "0", "still_00001602_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「あむっ、れろっ、ちゅぱぱっ……ぐちゅ、ちゅぷ……んっ、ちゅぽっ……！\n　んむっ、んんんっ……！　お、オチンチン押し付けないれぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0203214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「あぐっ、んんっ……！　はぐっ、んんん～～～～っ……！？　私の手の動き\nに合わしぇて、腰を振るなんてっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0203215" ]},
		{"command":[ "SETIMAGE", "0", "still_00001602_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「ずちゅ、れりゅ、ぐちゅちゅ……！　ああっ……！　精液のニオイが、どん\nどん濃くなってきてりゅわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0203216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「そりぇに、またオチンチンがビクビクし始めて……あむっ、くちゅ、ちゅち\nゅちゅ……！　もっとシコシコして欲ひいにょね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0203217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……れりゅれりゅ、ちゅぱ、ちゅぴっ……！　そんなに身震いひ\nて……またイキしょうなの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0203218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「じゅるっ、ちゅるるっ……！　いいわよ……ザーメンれマーキングひてっ…\n…！　私の手を……あなたの精液で、ぐちゃぐちゃにひてぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0203219" ]},
		{"command":[ "SETIMAGE", "0", "still_00001602_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「んむっ、ちゅ、くちゅるっ！　ちゅぱっ、れりゅ、ずちゅちゅ……！　んっ\n、んんんっ！　んむううううぅぅぅ～～～～～！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0203220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「んぐっ、ちゅうううぅ……！？　ぐちゅ、ちゅちゅ……！　ま、また手の中\nにザーメンがっ……！　んっ、れりゅうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0203301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001602_01_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「あっ、はあぁ……！　あちゅいの、いっぱい出てりゅわっ……！　こんにゃ\nの、火傷しちゃひそう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0203302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「んんっ……！　あっ、んちゅ……！　ちゅぱっ、くちゅっ……！　んっ、ん\nんっ……！　射精してりゅのに、まだ動くのっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0203303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「ちゅ、ぷちゅ、んちゅっ……！　んっ、わかったわ……最後まれシコシコし\nてあげりゅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0203304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「くちゅ、ずちゅ、れろっ……！　んっ、んんっ……んちゅ、れりゅ……！　\nぐっ、あはああぁぁぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0203305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ……はぁ、はぁ……たくさん出したわね……手がザーメンでふやけ\nちゃいそうだわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0203306" ]},
		{"command":[ "SETIMAGE", "0", "still_00001602_01_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「これだけ出したなら、さすがのあなたも満足したでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0203307" ]},
		{"command":[ "SETIMAGE", "0", "still_00001602_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「えっ……まだ出せるの……！？　私さえよければ、もっと手コキして欲しい\nって……！？　も、もう十分出したじゃない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0203308" ]},
		{"command":[ "SETIMAGE", "0", "still_00001602_01_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「チカラは欲しくないのかって……そ、それは欲しいけど……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0203309" ]},
		{"command":[ "SETIMAGE", "0", "still_00001602_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「だ、ダメっ……！　オチンチン押し付けないで……！　そんなことされたら\n、また精液出して欲しくなっちゃうから……！　あっ、あああぁん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0203310" ]},
		{"command":[ "SETIMAGE", "0", "still_00001602_01_13" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ、ちゅぷっ、ちゅるるっ……！　あっ、熱いザーメンが、私の手に\nかかって……んくうぅぅぅ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0203401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001602_01_17" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「爪の中にまで、精液が染み込んでくりゅうぅ……！　んちゅ、ちゅちゅ……\nちゅぱっ、ぐちゅ、れろぉ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0203402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「こんらに出さりぇたりゃ、ニオイが取りぇなくなっちゃうっ……！　あっ、\nんちゅ……ちゅちゅ、ちゅぱあぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0203403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「やああぁ……！　まだ出てりゅっ……！　ニオイが取れなくなるって、言っ\nてりゅのにぃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0203404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「あっ……んんっ……！　精液のニオイ感じりゅ……！　唾液のニオイと混じ\nって、しゅごくクサくて……んっ、んんん～～～～っ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0203405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「はあ、はあ、はああぁぁぁ……見て……あなたのザーメンで、私の手が真っ\n白になってるわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0203406" ]},
		{"command":[ "SETIMAGE", "0", "still_00001602_01_16" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「ベトベトして気持ち悪くて……酷いニオイなのに、ずっと嗅いでいたくなる\nわ……どうしてかしら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0203407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「私があなたの精液を、本能的に求めてるからですって……？　そ、そんなこ\nとあるわけないじゃない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0203408" ]},
		{"command":[ "SETIMAGE", "0", "still_00001602_01_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「そもそも、この手コキ自体、チカラを手に入れるための行為であって、あな\nたのザーメンを求めてるわけじゃないわ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0203409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「わかったら、さっさと離れなさい！　いつまでも私にオチンチンを握らせな\nいで頂戴っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0203410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
