		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んはぁああっ！　ああっ、すごい勢い……っ！　ああっ、あああぁぁぁあぁ\n～～～～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3203401" ]},
		{"command":[ "SETIMAGE", "0", "still_00000132_01_18" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「せ、精液……っ！　んぁっ、顔まで、飛んできて……んぶっ、かかっている\n、顔が、精液まみれになる……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3203402" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁっ、ドロドロになる、胸だけじゃなく、顔まで……っ！　んん\nっ、くふぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3203403" ]},
		{"command":[ "SETIMAGE", "0", "still_00000132_01_17" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁんっ！　そ、そんなに……っ！　射精しながら、乳首ぎゅっとするなっ\n、ああっ、ぶっかけられながらイクッ、イッてるのに……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3203404" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あっ、ああっ、イクの、またイかされる……っ！　はぁあっ、ああっ、ああ\nあぁぁぁ～～～～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3203405" ]},
		{"command":[ "SETIMAGE", "0", "still_00000132_01_18" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んはぁっ、はぁ……っ。や、やっと、落ち着いた……。まだオチンポが、ビ\nクビクとしているではないか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3203406" ]},
		{"command":[ "SETIMAGE", "0", "still_00000132_01_17" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「２回目だというのに、こんなに濃い精液を……。はぁ……しかし、お前がこ\nれほど気持ちよくなってくれたという証拠ではあるな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3203407" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ふふっ、精液まみれにされてしまったが、悪い気分ではないぞ。お前が悦ん\nでくれたのならな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3203408" ]},
		{"command":[ "SETIMAGE", "0", "still_00000132_01_16" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「だが……まだまだ身体の昂りは収まらないようだ。お前の悦ぶ顔を、もっと\n見たいと思ってしまっている……？」", "NORMAL" ]},
