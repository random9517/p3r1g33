		{"command":[ "SETTEXT", "「ああっ、このまま、イッてしまっていいから……。お前も、射精して……す\nきなように、出していいからぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3203216" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「私も、イきそうだから。乳首、お前に好き放題責められながら、もう……我\n慢できないからぁ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3203217" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁっ、パイズリで、射精しろぉ……っ！　オチンポ膨らんで、ビ\nクビクってしてきて……。んっ、くぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3203218" ]},
		{"command":[ "SETIMAGE", "0", "still_00000132_01_12" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「乳首っ、ああ、また強くされたら、い、イッてしまうだろうが……っ！　あ\nっ、ああっ、だめだ……イク、からぁ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3203219" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「お前も、一緒だ……一緒に、イかせてやる……！　ああっ、ああ……だせ、\n精液……ぃ……あっ、ああ……っ！」", "NORMAL" ]},
