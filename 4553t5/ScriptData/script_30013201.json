		{"command":[ "SETIMAGE", "0", "still_00000132_01_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ああっ、はぁっ、イク……イッてしまって……っ！　ああっ、乳首っ、また\nイッてる……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3203302" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「精液もすごい……またこんなに、びゅくびゅくってでて、私のおっぱいにこ\nんなに……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3203303" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ま……まだ脈打っている……。ドクドク射精している……。ああ、精液でも\nう、ドロドロだ……。", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3203304" ]},
		{"command":[ "SETIMAGE", "0", "still_00000132_01_14" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んくぅっ！　こ、こら、イッたばかりの乳首をまた、責めるなぁ……。んん\nっ、あはぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3203305" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「オチンポに残っている精液も搾りだせって？　まったく、仕方のないやつだ\nな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3203306" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「だが、お前にたくさん射精してもらえたから私は今とても気分がいい。お望\nみ通り、してやろうじゃないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3203307" ]},
		{"command":[ "SETIMAGE", "0", "still_00000132_01_13" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「こうだろう？　ぎゅっと、オチンポの根元から……。ンッ、精液の残りが、\nオチンポからでてきた……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3203308" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ふふん、どうだ？　龍神の奉仕は気持ちよかっただろう？　……龍神は関係\nないだろって？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3203309" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そ、そんなことない！　覚醒した私はお前への奉仕についてもパワーアップ\nしている！　ええい、もう一回だ、証明してやる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3203310" ]},
		{"command":[ "SETIMAGE", "0", "still_00000132_01_14" ]},
