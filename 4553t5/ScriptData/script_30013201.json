		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「さすがにもう初詣という時期でもないか。神社への参拝客もだいぶ減ってき\nたな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3203101" ]},
		{"command":[ "SETCHARA", "0", "char_00000132_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「これで私も、やっと一息つけるな。さて、お前には龍神となった私の戯れに\nつきあってもらうとするか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3203102" ]},
		{"command":[ "SETCHARA", "0", "char_00000132_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「しばらく神社にいたから、その……お前としてないだろ？　お前も、私とし\nたくなってきているのではないか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3203103" ]},
		{"command":[ "SETCHARA", "0", "char_00000132_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ええい、遠慮するな！　私が我慢できないと言っているのだから、お前は黙\nってヤられればいいのだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3203104" ]},
		{"command":[ "SETCHARA", "0", "char_00000132_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ふふ～ん。こうやっておっぱいでオチンポを押しつぶして……。ほらどうだ\n？　股間を刺激して……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3203105" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00000132_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「おっぱいで、オチンポをぐいぐいっと……。ンッ、オチンポがむくむくと膨\nらんで、私のおっぱいを押し上げようとしているのを感じる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3203106" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「オチンポは素直だな。すぐに硬くなって、勃起して……。ガチガチのオチン\nポを、挟んで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3203107" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「こうされると、お前は抵抗できないだろう？　お前の弱いところなど、知り\n尽くしているんだからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3203108" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ああ、久しぶりの、お前のオチンポ……。んっ、んくっ、こんなに硬くなっ\nて……脈打って……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3203109" ]},
		{"command":[ "SETIMAGE", "0", "still_00000132_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「すごく熱くなっている……。んんっ、おっぱいが、溶かされてしまいそうだ\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3203110" ]},
		{"command":[ "SETIMAGE", "0", "still_00000132_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「もっと、動かして……。あんっ、オチンポをしごいてやるから……。んふぅ\n、どうだ……気持ちいいだろう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3203111" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ぎゅうっと、私のおっぱいがいやらしく歪んで、お前のオチンポをしごいて\nいるのだからな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3203112" ]},
		{"command":[ "SETIMAGE", "0", "still_00000132_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「こういうのを見せられると、お前はますます興奮して、オチンポをもっとも\nっと硬くするもんな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3203113" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「オチンポの先をパンパンにして、真っ赤に腫らして……。ふふっ、腰も震え\nているじゃないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3203114" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「こう、おっぱいを勢いよく上下させたり、ンッ、左右互い違いに、動かした\nり……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3203115" ]},
		{"command":[ "SETIMAGE", "0", "still_00000132_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「私のパイズリに翻弄されて、オチンポから先走りが垂れてきているな……。\n射精が近いということか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3203116" ]},
		{"command":[ "SETIMAGE", "0", "still_00000132_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ふふん♪　いいんだぞ、このまま私の胸に射精してしまっても。我慢できな\nいほど気持ちよくなっているのだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3203117" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「気持ちよくなっているお前の顔を見ながらパイズリしていると、私もどんど\nん昂ってしまうな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3203118" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「さあ、このまま思いっきり、オチンポから精液をだしてしまえ。ほらほら、\n早くイッてしまったらどうだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3203119" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「……ひゃんっ！？　お前、じっとしていろと……んくっ、ち、乳首……ああ\nっ、いじるな……ぁ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3203120" ]},
		{"command":[ "SETIMAGE", "0", "still_00000132_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「きゅっとつままれたら、乳首、痺れて……あっ、んはぁっ！　このぉ……や\nめろって、言ってるだろう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3203121" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「だ、だいたい、龍神の乳首を責めるなど……ば、罰当たりだろうが……あっ\n、だから……んくぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3203122" ]},
		{"command":[ "SETIMAGE", "0", "still_00000132_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「神社でこんなことしてる方が罰当たりだろって？　う、うるさい！　私はい\nいのだ！　あぁあんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3203123" ]},
		{"command":[ "SETIMAGE", "0", "still_00000132_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「くぅ……このまま、乳首を好き放題されて、私の方がイキそうになって……\n。我慢ならん。私が先にお前をイかせてやる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3203124" ]},
		{"command":[ "SETIMAGE", "0", "still_00000132_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「もっと、おっぱいをぎゅうっとしてだな、ンンッ、オチンポを思いっきりし\nごいてやる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3203125" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んくぅっ、はぁっ、はぁ……。んぁっ、くっ、お前っ、わざと私の動きにあ\nわせて、乳首を……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3203126" ]},
		{"command":[ "SETIMAGE", "0", "still_00000132_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「乳首つままれたまま、おっぱい動かしたら、んぁっ、乳首、勝手に引っ張ら\nれるみたいになって……はぁっ、んっ、ああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3203127" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「か、感じてしまう……乳首ぃ……っ！　だ、だが……先にイクのは、お、お\n前の方なんだからな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3203128" ]},
		{"command":[ "SETIMAGE", "0", "still_00000132_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ひゃうっ、そんなふうに、私が気持ちよくなるように乳首をいじるなっ、あ\nあっ、コリコリするな、んくっ、あっ、んふぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3203129" ]},
		{"command":[ "SETIMAGE", "0", "still_00000132_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「負けるか、このまま、お前もイかせてやる。もうお前も、我慢できなくなっ\nていると、オチンポがビクついているのだから……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3203130" ]},
		{"command":[ "SETIMAGE", "0", "still_00000132_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「このまま、精液を搾りだしてやる。私の胸に、思いっきり射精させてやる…\n…っ！　はぁっ、はぁっ、はぁっ、はぁ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3203131" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「乳首っ、そ、そんなに強く……っ！　んぁっ、おっぱいにジンジンくるっ、\nわ、私も……私まで……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3203132" ]},
		{"command":[ "SETIMAGE", "0", "still_00000132_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あああぁぁぁああぁぁあぁ～～～～っ！！　んぁっ、あっ、でてる……っ！\n　はぁっ、ああ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3203133" ]},
		{"command":[ "SETIMAGE", "0", "still_00000132_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「オチンポが、ビクンと震えて、真っ白い精液をぶびゅっと噴き上げて……っ\n！　んはぁっ、私もお前に……乳首で……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3203134" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「イ……イッた……。イかされて……しまったぁ……。んはぁ……乳首……ジ\nンジンする……んふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3203135" ]},
		{"command":[ "SETIMAGE", "0", "still_00000132_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「それにしても……出し過ぎではないか？　いきなりこんなに射精するなんて\n……よほどため込んでいたのだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3203136" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ま、それを抜きにしても、龍神の私がパイズリ奉仕したのだから、たまらず\n大量に射精してしまったということだろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3203137" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁ……しかしまいったな。ちょっとお前で性欲を発散しようと思ったのに\n、こう責め返されてしまっては……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3203138" ]},
		{"command":[ "SETIMAGE", "0", "still_00000132_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ますます身体の疼きが強くなってしまうではないか。こうなったら、もっと\nつきあってもらうしかないな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3203139" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「お前のオチンポだって、ガチガチに勃起したまま私の谷間でヒクついている\nからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3203140" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ふふ、さっきたっぷりと射精してくれたからな。おっぱいがお前の先走りと\n精液でヌルヌルのベトベトだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3203201" ]},
		{"command":[ "SETIMAGE", "0", "still_00000132_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「なあ、さっきのように、乳首をもっといじってくれないか？　乳首が特にジ\nンジンと疼いているようなんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3203202" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んんっ！　そう……乳首……っ！　ああっ、お前の力加減……すごく、気持\nちいい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3203203" ]},
		{"command":[ "SETIMAGE", "0", "still_00000132_01_12" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「乱暴にぎゅうっとされるのもいいが、ンッ、やさしく転がすようにいじられ\nるのも……たまらない……ぃ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3203204" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「乳首……感じて……はぁ、はぁ……おっぱいまで快感で痺れてしまっている\nようだ……んく……うぅ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3203205" ]},
		{"command":[ "SETIMAGE", "0", "still_00000132_01_11" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んぁ……わ、わかっている……。私もちゃんと、パイズリでお前のことを気\n持ちよくするから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3203206" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んふぅ、んっ、あっ、あはぁ。またこうして、オチンポしごいてやるからな\n……んぁっ、ますます硬くぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3203207" ]},
		{"command":[ "SETIMAGE", "0", "still_00000132_01_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あんなに射精したのに、どんどん膨らんで……。ンッ、さっきよりもたくま\nしくなってるぞ、お前のオチンポ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3203208" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ヌルヌルのおっぱいに挟まれ……しごかれ……。お前も気持ちよくなってく\nれているみたいだな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3203209" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ああ……私も、お前に乳首を責められながら、パイズリで谷間にオチンポ感\nじながら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3203210" ]},
		{"command":[ "SETIMAGE", "0", "still_00000132_01_12" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「すごく……興奮してしまって……。はぁ、はぁ……んくっ、乳首いい……気\n持ちいい……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3203211" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そのままもっと、乳首責めて……ああんっ、いい、それいい……っ！　んく\nっ、んふぅ……はぁっ、あっ、んんぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3203212" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「おっぱいの快感が、どんどん膨らんでいく……はぁ、はぁ、このまま……イ\nかされて、しまいそうだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3203213" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「お前も……お前のことも、イかせるからな……。ああ、もっと激しく……さ\nっきみたいに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3203214" ]},
		{"command":[ "SETIMAGE", "0", "still_00000132_01_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「パイズリ……もっとぉ……。んぁっ、んふぅ……っ！　オチンポが、ビクビ\nクってして……るぅ……っ！」", "NORMAL" ]},
