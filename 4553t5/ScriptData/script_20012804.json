		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "２つの影が、俺達と黒いサンタの方に向かって駆けてくるのが見えた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
