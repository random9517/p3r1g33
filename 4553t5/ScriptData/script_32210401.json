{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022104_01_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「旦那さま♪　旦那さま……今宵はなんのイベントか覚えていらっしゃいます\nか？　はい！　そうです。ハロウィンです……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0403101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「この衣装、ミス・パープル様にお仕立ていただいた特別なお洋服なんですの\n。どうでしょう。可愛い……ですか？　ふふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0403102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「であれば、とりっく・おあ・とりーと、です！　イタズラかお菓子か……ど\nちらがよろしいですか？　え？　お菓子を持っておられないのですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0403103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「……でしたら、イタズラをご所望なのですね♪　今宵はわたくしに、すべて\nおまかせくださいませ。……こちらのおリボンについて、ですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0403104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「このおリボン、とっても愛らしいと思いませんか？　旦那さまのために一所\n懸命選んだ贈り物です♪　これでじっくり旦那さまの旦那さまが見られます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0403105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「……はぁっ……♪　わたくしの顔くらい大きいです……♪　そしてわたくし\nの手首くらい太い……。でも、吐息をかけられてピクピクしていますね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0403106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ちっちゃなサキュバスさんに、これからどんなイタズラをされるか心配して\nいるのですか？　大丈夫ですの。愛をもってイタズラしますから……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0403107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「んっ。つん、つん、つん……♪　何をしているのかって？　おちんちんさん\nを指でつんつんつついているんです。わ……♪　硬い……怒っているみたい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0403108" ]},
		{"command":[ "SETIMAGE", "0", "still_00022104_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「血管が浮いた、ゴツゴツのおちんちん……。わたくしの指なんて簡単に押し\n戻して、それなのにブルンッて揺れてます。ふふ、かわいいです……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0403109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あっ……♪　先っちょがぷるぷる震えています……。どうしたんですか？　\nかまってほしくて我慢できないんですか？　よし、よし、よし……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0403110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「うふふ♪　手のひらでなでなですると、プニプニしていて面白いですね。…\n…きゃっ、透明なお汁がにじんできて……。ん……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0403111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「このお汁を、ゆっくり塗り広げていきますね……。んん……♪　ぷっくり膨\nらんだところだけでなく、くぼみも丁寧に……ヌルヌルヌル……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0403112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「……わたくしの手、ひんやりしていて小さくて感じる？　そうなのですね…\n…！　ではもっといじります！　くに、くに、くに……ぐにぐに♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0403113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「この前、旦那さまが見せてくれた本に書いてありました。こうやっておちん\nちんさんを焦らして観察することを、射精管理と呼ぶのですよね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0403114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「どう、ですか？　わたくしのしゃせいかんり……上手ですか？　はぁ、はぁ\n……おちんちんさん、ちょっと辛そうです。でも、出しちゃだめですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0403115" ]},
		{"command":[ "SETIMAGE", "0", "still_00022104_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「今日の旦那さまは、わる～いサキュバスさんに見つかってしまった悲劇の男\n性の役なんですから……。おちんちんが切なくてもがまんです……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0403116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ん……ふぅ……ふぅ……。指先や、おててでおちんちんさんをぐりぐりして\nいると……場所によって反応がさまざまでとても興味深いです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0403117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「一番弱いのは先端、でしょうか……。ここが濡れてくるのは、摩擦にそなえ\nて……？　ふぁあ……クチュ、プチュってえっちな音がしてます……んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0403118" ]},
		{"command":[ "SETIMAGE", "0", "still_00022104_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「おちんちんは、とても不思議な形をしていますよね……。大きくなったり小\nさくなったり……その上せいえきがビュルビュル出たり、おどろきです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0403119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「……旦那さま？　せいえき、ぴゅっぴゅしたいですか？　したいですよね…\n…。手でいじられて、もてあそばれているだけじゃくるしいですよね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0403120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「それなのに、わたくし……おちんちんにいじわるをしていると、なぜか胸が\nどきどきしてしまうんです。いやらしい気持ちになってくるんです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0403121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「んっ……。ぺろっ……♪　ちゅ……♪　おちんちんを舌でペロペロされるの\nはどうですか？　おつゆが溢れてくる場所を……ちろちろちろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0403122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「それから、おててでたくさんおちんちんさんをしごきます。んっ……んっ…\n…♪　お口でくちゅくちゅ、ちゅぷちゅぷしながらおててで刺激して……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0403123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、すごい……♪　脈打ってきました。それに火照ってどんどん熱\nくなってきて……。すぅう……♪　あぁ、においも濃くなってきています」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0403124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「おちんちんさんのにおい、もっと近くでかぎたい……♪　はぁ、はぁ……っ\n。おててでぐいっとこちらに向けて……はぁあ……♪　んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0403125" ]},
		{"command":[ "SETIMAGE", "0", "still_00022104_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ちゅる、ぷちゅ……♪　舐めながら……んぅ、腕を上下に動かして……。っ\nあ……♪　うれしいですか？　もっと力をこめますね……。んっ、ンッ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0403126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「まだですよ……ぴゅっぴゅはまだです……。っふ……♪　ちゅる……ちゅる\n、ぺろっ、ちゅ……♪　あぁ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0403127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「好きな方に……だいすきな旦那ひゃまにイタズラをして、ウズウズしてしま\nうなんて……♪　もっと見せてください、そのお顔……♪　くちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0403128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「わたくしできもちよくなって……。あっ♪　あっ、ぁっ……暴れてます、こ\nぉら……♪　お菓子は……ごほうびはまだです……あっ♪　ぷちゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0403129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「カウパーがだだ洩れで限界……？　ふふ、わかります。くちびるに、透明な\nお汁がヌルヌルくっついて……おててもにゅぷにゅぷですから……あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0403130" ]},
		{"command":[ "SETIMAGE", "0", "still_00022104_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「でも、ここでぐ～っと焦らしてかわいいイジワルをするのがサキュバスさん\nなんですよね……？　力を強くして……んっ、弱めて……あっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0403131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「湯気が出そうなくらいあちゅい……♪　こうですか……？　それともこっち\n？　シコシコ続けますね……♪　はぁっ、はぁ、はぁ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0403132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あぁっ……♪　旦那さまの腰が跳ねています……！　そんなによろこんでい\nただけるなんて……！　はい！　わたくしは……アンはがんばります！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0403133" ]},
		{"command":[ "SETIMAGE", "0", "still_00022104_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「出したい？　せいしをですか？　それは……まだだめなんです。だめでも出\nちゃいそう、ですか？　それでもご命令には従えません……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0403134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「なぜなら、今のわたくしはサキュバス……ハロウィンの小悪魔だからです。\nだめですよ。出しちゃだめです。いいこですね……我慢ですよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0403135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あっ！？　んん……！？　じわぁ～って、白いカウパーがおちんちんさんの\n先っちょから漏れ出してます……。あっ、ど、どうしましょう。ええと！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0403136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022104_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「これ……はちゃんとした射精ではないんですよね？　ちょっとお漏らししち\nゃっただけですよね……？　すん、すん……うん、臭いも薄いですし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0403137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ぺろ……。お味もまだまだ苦味が足りません。これは……まだちゃんとは出\nていない、ということですね。あぁ……よかったです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0403138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あともう少しで全部出せたのに……ですか？　ふふふ、それを阻止するため\nのおリボンですから。あともうすこし、おつきあいくださいませ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0403139" ]},
		{"command":[ "SETIMAGE", "0", "still_00022104_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ん……んっ。おちんちんさんの、太さも長さも大きさもかわりなし……。\nこれなら『しゃせいかんり』を続けられそうです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0403140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「おリボンを結んでいるせいで、びゅーっ、びゅーってたくさんせいえきを出\nすことができませんでしたよね……？　でも、だいじょうぶです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0403201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「もう一度、わたくしが旦那さまのおちんちんさんをうんと気持ちよくいたし\nます。ですから白いおしっこを……精液を溜めて、溜めて、限界まで溜めて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0403202" ]},
		{"command":[ "SETIMAGE", "0", "still_00022104_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「そのあとびゅるびゅるびゅるって一度に放って気持ち良くなってもらいます\n……！　想像してください。何度もぎりぎりまで我慢して、我慢して……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0403203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「最後にびゅーってしたら、絶対にきもちいいとおもいませんか……？　とい\nうことで……ぺろぺろと、グニグニを続けますね……。はぁ、はぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0403204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「わたくしの小さな手のひらにはおさまりきらない逞しいおちんちん……。な\nのに、今、旦那さまのこれはわたくしの気分にすべてゆだねられている……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0403205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「どうしてでしょう。すごく……どきどきしてきました。んん……♪　あぁ、\nはぁ、はぁっ……パンパンに膨らんだおちんちん……すてきです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0403206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ここを、愛情をこめてこすっているだけで……内側からパァンっておリボン\nをちぎってしまいそうなくらい、いっぱいいっぱい張りつめていますね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0403207" ]},
		{"command":[ "SETIMAGE", "0", "still_00022104_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……♪　わたくしのだいすきな旦那さまの、たいせつな場所……\n。大事に、大切に……刺激します。やさしく……でも、情熱的に……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0403208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あああ……♪　両脚のビクビクが強くなってきましたね……！　そんなに力\nをこめて……。すぐに出させてあげられなくてごめんなさい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0403209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「んっ……♪　でもサキュバスという方々は、こうして特上の精液を作り出し\nて、それを飲んだり浴びたりすると聞きました。一番精が濃くなる瞬間」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0403210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「それを狙いすまして、一番美味しい時にごちそうになるものだと……♪　で\nすから、わたくしも、立派なサキュバスとして……はぁっ、期待します」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0403211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「旦那さまの一番濃いせいえき……。苦くて、ドロドロで……粘り気のつよい\n、素晴らしいせいし……。楽しみです、欲しいです、はやく……はやく♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0403212" ]},
		{"command":[ "SETIMAGE", "0", "still_00022104_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「んっ、あぁ……っ。おちんちんさんをしこしこしていると、だんだん身体が\nあつくなってきました……。わたくしまで気持ち良く……ふぁああ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0403213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「だいすき、です♪　旦那さま……♪　がんばれ♪　がんばれ……♪　ここに\n、この硬いおちんちんさんにたっぷり真っ白なせいえきを溜めてください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0403214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「そして……それをわたくしに、どうか……！　っふぅっ……♪　ふぅ……！\n　わたくしのおてて……気持ちいいですか？　ちゃんと感じてますか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0403215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「んふ……♪　カウパーさんの量が、どんどん増えてきました。指がにちゃに\nちゃしています。んっ、いいんですよ。わたくしの手、濡らしてください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0403216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「手のひらがぬるぬるすればするほど……あっ♪　じょうずにおちんちんさん\nをしごけます。しこ、しこ、しこ……あぁ、おおきいです……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0403217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「っんっ……！　わたくしの手から逃げ出しそうなくらい、おちんちんさんが\n太くなってきました。硬く反り返って……イキそうなんですよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0403218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「はい。今度は好きなだけ出していいですよ。いいえ……わたくしめがけてた\nくさんぴゅっぴゅしていただきたいです！　んん、待っています……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0403219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「だいすきな、だいすきな旦那さま……♪　わるいこのアンに、いけない小悪\n魔のわたくしに、おもいっきりせいえきをお恵みくださぁい……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0403220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「んっ♪　あああっ……♪　あ～～～～ん……♪　あふっ……！　あっぁっす\nごい量れひゅ……♪　おリボンが破裂して……！　んぷっ、んん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0403301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022104_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ん～～～～！　爆発ひたみたいにぃ……♪　どびゅっ、びゅぶって太いお汁\nが飛び出して……！　あ……ぅ、ひゅごい、お口でうけとめきれまひぇん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0403302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「んんんんん……！　ん、ぁ……舌が重いれひゅ……。旦那ひゃま、ありがた\nく一番濃いせいえき……ちょうだいします。いただきます……♪　ごくっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0403303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ごきゅ……ごきゅ、ごきゅ……！　んーーっ……♪　ゼリーのようにぷるっ\nぷるで、苦くてすばらしいですっ……ああ、もっとくだひゃい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0403304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「これを飲みたかったんれひゅ……！　ごくっ……ごく、あぁあああ……♪　\n口の端からボタボタこぼれて、シーツに、首に……胸にまで……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0403305" ]},
		{"command":[ "SETIMAGE", "0", "still_00022104_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「だらだらこぼれちゃってます……。ふぁ……♪　これも、それも、ぜんぶ、\nぜんぶ飲みますね……。んっ、ごく……ごく、ごく……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0403306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ぷはぁっ……♪　旦那さまの本気、ほんとうに、ほんとうに、ほんとうにス\nゴかったです！　あまりに量が多くて、溺れてしまうかと思いました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0403307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「こんなに男らしいおちんちんさんの持ち主が、わたくしの旦那さまだなんて\n……しあわせです♪　サキュバスになってよかったです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0403308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「……だって。いままでよりもさらに新しい旦那さまを知ることができました\nから。たまーには悪い子も……いいかもしれません……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0403309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「良い子のわたくしと、悪い子のわたくし……。どうぞ、旦那さまのお好きな\nわたくしに染めてくださいね……。その時を、ふふ、楽しみにしています♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0403310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「きゃあっ！　んぁっ……ああああっ……！？　んぷっ……んむ！　ふぁ……\n！？　あっ、やっ……んんんん！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0403401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022104_01_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「おリボンでしっかり押さえつけていたのに……あっ♪　それを簡単に弾き飛\nばすほどのしゃせい……♪　これです、わたくしが欲しかったのは！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0403402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あっ♪　あっ、すてき……♪　いいにおい……♪　たっぷりデコレーション\nしてください……♪　こってりミルクさんをたくさんふりかけて……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0403403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「っあぅうう♪　顔にも、髪にもこんなに……っ♪　んむ……♪　お口の中に\nも流れこんできます……。これが、旦那ひゃまの実力……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0403404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「限界を何度も超えると、ここまでの勢いでせいえきがどびゅどびゅって飛び\n散るのですね……！　あっ！　あはっ……♪　全然止まりませんの……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0403405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「はい♪　イタズラをして焦らしたわたくしがわるいのですっ、つつしんでお\n仕置きをお受けします……！　ぷぁ……！　せいしまみれ……んぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0403406" ]},
		{"command":[ "SETIMAGE", "0", "still_00022104_01_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「っはぁあああ……♪　出していただいて、ありがとうございました……♪　\nでも、おどろきです……。ここまでしゃせいがすごいなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0403407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「……わたくしのサキュバスさん姿と、小悪魔風の攻めにたかぶった？　……\nあっ♪　そんな♪　褒めていただけるなんて……あのっ、あのっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0403408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「も、もし……今日みたいなイタズラがお気に召しましたら……。わたくしに\nこっそり教えてくださいね。ときどき、いじわるしちゃいます……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0403409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「増えたせいえきについては安心してください！　サキュバスさんに変身して\n、ぜーんぶ回収しますから♪　えへへっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0403410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}