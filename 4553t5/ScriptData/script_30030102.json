{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000301_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "PLAYVOICE", "003_0104101" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……くぅぅっ、今日こそ、このあたしのオマ〇コに、ふぅ、ふぅ\n……そのオチ〇ポが挿っちまうんだね……？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0104102" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「こんなふうに拘束されて、ふぅ、ふぅ……身動きできないまま、あんたに犯\nされちまうなんて……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0104103" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「そのぶっといチ〇ポを、んふぅぅぅっ……あたしのオマ〇コの奥深くまで無\n理やりねじ込まれて……ごくっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0104104" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、あたしの身体のことなんておかまいなしに、んはぁうぅっ、力\n任せに腰を叩きつけて、あぁっ、乱暴に犯されちまうんだ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0104105" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あんたは、あたしがイこうがイくまいが気にもしないで、はぁぁっ、はぁっ\n！　あたしのことを、ただチ〇ポをしごくための道具にするんだ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0104106" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「そして、ふぅぅっ、ふぅぅっ、最後は、あたしのオマ〇コの奥深くに……ん\nあぁっ！　熱くてネバネバした精液を、吐き出して……っぅぅ～～っ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0104107" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「……っ、ふぅ、ふぅぅぅっ……い、いいだろう……望むところだよ……！　\nほら、早く犯しなっ……！　それとも、あんた……ビビってんのかい？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0104108" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「身動きできない女を前にして、チ〇ポを挿れる度胸もないだなんて……はん\nっ、とんだ玉無し野郎だね！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0104109" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「……なんだい、その顔は？　ふんっ、本当のことを言われて、何も言い返せ\nないのかい？　つくづくあんたは、ゴミみたいな男だねぇっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0104110" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「それなら、何度でも言ってやるさ！　あんたは下衆で、卑怯で、能無しで！\n　短小包茎早漏の、玉無しフニャチ〇野郎――」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0104111" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ぉんおほぉおおおおおおっ！！？　オ、オチ〇ポぉっ！　一気に、奥までぇ\nっ！　んほぉおおおっ！　太くて、固くて、熱い、オチ〇ポぉっ！」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000301_02_05" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0104112" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んひぃいいいいっ！　ガチガチの亀頭が、あひぃいっ！　オマ〇コの中、無\n理やりかき分けてぇっ、んひぃいいいっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0104113" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ぉひぃいいっ！　奥っ！　どちゅどちゅっ！　んぉおおおっ！　そこっ、行\nき止まりっ！　ぉんっ！　おぉんっ！　それ以上入らないよぉっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0104114" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んほぉおぉ～～～っ！？　ぐりぐりっ、子宮口っ、つぶれちまうぅっ！　そ\nこらめっ！　そこは弱いからぁああんっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0104115" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「っ、はぁっ、はぁっ……ふ、ふんっ……ようやくヤる気になったのかい……\nんんっ……とんだ、ウスノロ野郎だねぇ……んひぅぅっ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000301_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0104116" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ど、どうだい……エファナティカ様のオマ〇コは……んぉうぅっ……気持ち\nよすぎて、トロけちまいそうだろう……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0104117" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あんたみたいな種無し男にはもったいない、極上オマ〇コだからねぇ……ん\nふうぅっ……挿れさせてもらえただけ、感謝するんだよ……お、おっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0104118" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「オチ〇ポぉ、ナカで、ビクビクっ……！　ふぅ、ふぅっ、ね、ねぇ、もっと\n動いたらどうだい？　それとも……まさか、もうイっちまいそうなのかい？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0104119" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「はんっ、ちょっとは見直したと思ったら、相変わらずなっさけない男だねぇ\n。満足に女をイかせることもできないなんて、あんたには心底ガッカリだよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0104120" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あたしが今まで味わってきた男の中でも、ここまで情けない男はいなかった\nよ！　呆れたもんだね、本当にあんたは最低最悪のクズオチ〇ポ野郎――」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0104121" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「おぉおおおおおおおんっ！　おんっ！　おぉおおんっ！　オ、オチ〇ポぉっ\n！　いきなりっ、ひぃいいいんっ！　はげしすぎるぅっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000301_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0104122" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んひぃいいっ！　あぁあひっ！　あっあっあっ！　カリ首、ごりごりっ！　\nあはぁああっ！　オマ〇コのナカ、ほじくってるぅうっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0104123" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んぉっ！？　おっ、おっ、おほっ！　奥っ、ごちゅごちゅっ！　亀頭が叩い\nてるぅっ！　おっ！　んぉっ、おっ、んほぉっ！　オチ〇ポ固いぃっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0104124" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「お腹の奥っ、ずんずんってされてるっ！　んぁひっ！　おひっ！　ひぃっ！\n　苦しいっ！　お腹苦しくて、ジンジンするぅっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0104125" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あっあっあっ、そこ、ダメっ……！　そこ弱いから、擦られたら……ひぎゅ\nううううっ！　気持ちよすぎるっ！　オマ〇コ変になっちゃうぅっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0104126" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ひぃっ、ひぃぃっ……あっ、あっあっ、オチ〇ポ、太くなってきた！　んあ\nぁぁっ！　亀頭がぶくってふくれて、んはぁっ！　さっきより固いぃっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0104127" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁっ、イっちまうのかい？　んはぁああっ、あたしのマ〇コで、\nオチ〇ポごしごし擦って、んひぅうっ、精液出しちまうのかい？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000301_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0104128" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ナ、ナカはダメだからね、あひぅうううっ！　あんたの濃くてドロドロのザ\nーメン、中出しされちまったら、あひぃいっ、一発で孕んじまうからぁっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0104129" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「オマ〇コの奥に、あひっ、ひぃっ、んひぃっ、熱々の精液注ぎ込まれたら、\nんあぁっ、あたし、おかしくなっちまう、イっちまうからっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0104130" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あっあっあっ、ダメ、ダメだよ、ナカ出しはダメ、あたし堕ちちまうっ、あ\nんたの女になっちまうからっ、だからダメっ、ダメっ……ダメぇぇぇっ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0104131" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んぁああああああっ！！？　あひっ、あひぃっ！　オマ〇コ熱いっ！　奥っ\n！　ナカ出しされてるぅっ！　オマ〇コに精液出されてるっ！」", "NORMAL" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000301_02_08" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0104132" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んあぁっ、あっあっあっ！　ダメなのにっ！　ナカ出しされてるっ！　オマ\n〇コの奥にびちゃびちゃ当たってるぅっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0104133" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ひぃいいんっ！　ひぃっ！　ぃひいいっ！　精液、ドプドプっ！　種付けさ\nれてるっ！　オマ〇コ孕んじまうよぉぉぉっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0104134" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あひぃいいいいっ！　イくっ、イくっ、イくっ！　中出しされてイくっ！　\nオマ〇コ堕とされてイっちゃうぅっ！　イくっイくっ、イくううううっ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0104135" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「っ～～～～～、ひぃっ、ひぃっ、イっちゃった、オチ〇ポ無理やり挿れられ\nて、レイプされて……んはぁうぅっ、中出しされて、イっちまったぁっ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000301_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0104136" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁっ、すごい、こんなの、知らないっ……んひぅうううっ、こん\nなの初めてっ、んあぁっ、気持ちいいっ、気持ちよすぎるよぉっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0104137" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あ、あ、あっ！？　まだ、出てるっ……！？　ひぃっ！　オマ〇コの中に、\nびゅくびゅくっ、精液出てるぅっ、オチ〇ポまだ、中出ししてるぅっ……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000301_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0104138" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んあぁあっ！？　あっあっ、ダメっ、射精しながら動くんじゃないよぉっ！\n　んはぁううっ！　中出ししながら、オマ〇コほじくらないでぇっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0104139" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んひぃいいんっ！　またイくぅっ！　オマ〇コ、イっちゃうっ、射精されな\nがら、イかされるっ！　んあぁぁぁっ！　また、イくううう～～っ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0104140" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ひぃぃぃっ……ひぃぃぃっ……オマ〇コ、ジンジン……んひぅぅっ、精液、\n染み込んでるっ、オチ〇ポで擦り付けられて、なじまされてるよぉっ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000301_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0104201" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んぁあああっ！？　あっあっあっ！？　またオチ〇ポっ、ぬきさしっ！？　\nんひぃいいんっ！　激しすぎるぅっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000301_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0104202" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「待て、待っておくれぇっ！　んほぉおおんっ！　まだイってるからっ！　イ\nったばかりでオマ〇コびんかんだからぁ、待ってぇっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0104203" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ひぃっ、ひぃっ！　止まってぇっ！　気持ちよすぎるんだよっ、身体が変に\nなっちまうっ！　気持ちよすぎて狂っちまうよぉっ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0104204" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んぎっ！？　んぎぃいいっ！　またイくっ、イくっ、イぐっ、イっぐぅうう\nう～～～～～っ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0104205" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「っ、はぁっ、はぁっ、ひぃ、ひぃぃっ、止まって、お願い、止まってぇ……\nあひぃいいいんっ！　ほんとにおかしくなっちゃう、狂っちゃうからぁっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0104206" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「オマ〇コずっとほじくられてたら、またイっちゃうぅっ！　あっあっあっ、\nまたクるっ、くるっ、おっきいのクる、クるっ……っ～～～～～～！！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0104207" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「っ、はぁっ！　はぁっ！　はぁっ！　ひぃぃっ、オチ〇ポ止まらないぃっ、\nもうやめてぇっ、お願いぃ、オマ〇コ壊れちゃう、頭狂っちゃうぅっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0104208" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「もうダメっ、オチ〇ポしゅごいっ、こんなのはじめて、気持ちいいの止まら\nない、アクメどんどんおっきくなるっ、あたし、こわれちゃうぅっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0104209" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あ、あ、あ、クる、すごいのクるっ、今ままでで一番大っきいのクるっ！　\n頭おかしくなるくらい、気持ちいいのクるっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0104210" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「しゅごい、しゅごいっ、オチ〇ポしゅごい、あ、もうダメ、イく、すごいの\nクる、すごいアクメくるっ、あ、イくっ、イくイくイく、イっ…………」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0104211" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「…………はぇ？　……え？　あ……な、なんで……？　ど、どうして、止め\nちまうんだい……？　もう少しで、大っきいのがクるんだよぉ……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000301_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0104212" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「だから、ねぇ、動いておくれよぉ……こんなところでヤメられちまったら、\nそれこそ本当におかしくなっちまう……狂っちまうよぉ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0104213" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ほら、あんたの大っきなオチ〇ポで、あたしのオマ〇コをめちゃくちゃにか\nき回しておくれよ……あぁぁっ、お願いっ！　なんでもするからぁっ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0104214" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「フェラチオでも、パイズリでも、オマ〇コでも、なんでもするよっ！　これ\nからは好きな時に、あたしのこと犯していいからぁっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0104215" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「いつでもどこでも、ムラムラしたら、あんたのオチ〇ポを気持ちよくするっ\n！　あたしの身も心も、もうあんたのものなんだよぉ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0104216" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あたしはもう、あんたのオチ〇ポ奴隷だから！　オチ〇ポでズポズポ、乱暴\nに犯してぇっ！　あぁぁ～～、お願いぃっ、あたしをイかせておくれぇっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0104217" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あひぃいいいいいんっ！？　ひぎっ！　ひぃいんっ！　これ、これぇっ！　\nオチ〇ポきもちいいっ！　もっと、ズンズンっ、激しくしてぇっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000301_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0104218" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「オマ〇コ、もっとしてぇっ！　オチ〇ポでぐちゃぐちゃにかき回してぇっ！\n　んひぃいいいっ！　しゅごいっ！　オマ〇コしゅごいぃっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0104219" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「オチ〇ポっ！　オチ〇ポきもちいいっ！　もっと乱暴にしてっ！　あたしの\nこと、めちゃくちゃにしてぇっ！　オマ〇コこわしてぇっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0104220" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あ、あ、あ、クる、大っきいのクるっ、すごいのクるっ！　止めないでっ、\nお願いっ、このままオチ〇ポしてっ、オマ〇コ、イかせてぇえええっ！！」", "NORMAL" ]},
