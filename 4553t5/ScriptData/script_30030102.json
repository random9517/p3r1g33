		{"command":[ "PLAYVOICE", "003_0104305" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「っあ！？　あっあっ、あっ！？　精液、入ってるっ！？　子宮のナカ、びち\nゃびちゃっ！　あっあっあっ、入っちゃってるぅっ……！！」", "NORMAL" ]},
