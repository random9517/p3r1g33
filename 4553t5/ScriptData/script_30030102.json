		{"command":[ "PLAYVOICE", "003_0104306" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「……あっ！？　卵子、犯されてるっ、ご主人様の精子で卵子ぶちゅぶちゅ、\n犯されてるっ、受精してるっ、あへぇっ、またイぐっ、イぐっ、イぐっ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0104307" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
