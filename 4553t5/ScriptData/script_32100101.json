{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0027" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「今日の現場任務も終了。あ、隊長さん、お疲れ様です。隊長さんのお仕事も\n終わりですか？　なら、お願いがあるのですが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0103101" ]},
		{"command":[ "SETCHARA", "0", "char_00021001_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「あのですね……その……私に、奉仕というものを教えてほしいのです。男女\nの営みの意味での、奉仕です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0103102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「私の器であるマミから得た知識にそういうものがありまして、隊長さんにぜ\nひ奉仕させていただきたいと……日頃のお礼です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0103103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「いいんですか？　ありがとうございます！！　それでは……この場に認識阻\n害のフィールドを張りました。今、周りに私たちのことは見えません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0103104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「それでは失礼して……これが隊長さんの裸……んんっ、身体のサイズは違いま\nすが、私たちと作りは同じですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0103105" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00021001_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「股間にあるこれを……口でするのが地球の人は好きなのでしょう？　私とあ\nなたではサイズは違いますが……あー……むっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0103106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「んんっ、むっ、そんなにこわばらなくても大丈夫ですよ。力の加減は心得て\nいます。ちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0103107" ]},
		{"command":[ "SETIMAGE", "0", "still_00021001_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ……んっ、少し、硬くなってきましたね……唇の感触で分かります\n。これが男の人の……んむっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ん……指でも……凄い、私の指より小さいのに、熱くて硬い……これが勃起\nという現象ですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「え？　これとかそれじゃなくてちゃんと名前を言え……？　陰茎、でしょう\n？　違う？　おちんぽ、ですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「隊長さんのおちんぽに私の口マンコで奉仕します……これでいいんですか？\n　きゃっ、隊長さんのおちんぽがまた硬く……んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0103111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「唇に突き刺さるような硬さと熱さ……舌先でつついたら、おちんぽがぴくぴ\nくって跳ねてます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「んっ、ちゅっ、れるっ、ちゅう……ふっ、なぜでしょう、サイズも何もかも\n違うのに、口で吸っているだけで身体が……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「この行為はフェラチオというのですか？　隊長さんのおちんぽをフェラチオ\nしてるだけで股の間が……え？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「おまんこ……おちんぽをフェラチオしているだけでおまんこが熱くなってき\nます……んっ、むっ、ちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0103115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「んんっ、うっ、隊長さん、隊長さん……！！　私の手に乗るほど小さいのに\n、なんて逞しい……ちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ふっ、ふうっ、ふっ、隊長さんの味、なんだか癖になります……んっ、んむ\nっ、れるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0103117" ]},
		{"command":[ "SETIMAGE", "0", "still_00021001_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「隊長さんは私の奉仕……フェラチオ、気持ちいいですか？　ふふ、そうです\nか。気持ちいいですか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「今までも戦いで共闘した男はいましたが、こんな気持ちになったのは隊長\nさんが初めてです……ちゅっ、んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「んん、舌先でこの段差を……カリ首？　カリ首をなぞると隊長さんの腰が震\nえていますね。だんだんやり方が分かってきました。れるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「んむっ、んっ、おちんぽだけじゃなく、隊長さんの全部を味わいたくなりま\nす……れろっ、んっ、むっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「んうっ、んっ、どうしたのですか隊長さん……胸？　胸を……おっぱいを揉\nみながらフェラチオをしてみろですか？　分かりました、んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「んちゅっ、ふあっ、あっ、なに、これ……自分の身体を触っているだけなの\nに……ああんっ、んっ、むっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ふあっ、ああっ、んんっ、フェラチオして、おっぱい触ってると、おまんこ\nが……じんじんしてきて、ふああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「んぐっ！？　唇の中で隊長さんのおちんぽがまた硬くなって……私の姿で\n興奮してくれているんですか？　こんな、大きな女の姿で……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0103125" ]},
		{"command":[ "SETIMAGE", "0", "still_00021001_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「それが魅力、ですって？　ふふ、嬉しいことを……あんっ！！　またおちん\nぽが……お世辞じゃない証拠なんですね、んっ、ちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「それなら、心を込めて、誠心誠意フェラチオしますね……んっ、むっ、ちゅ\nっ、れるっ、ちゅぱっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「唇で挟んで、吸って、舌先でつついて、舐めて……んんっ、唾液を塗り込ん\nでねとねとになってますね……ふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「んっ、んぐっ、むっ、ふあっ、ああっ、んうっ、え？　出る？　なにが出る\nんですか？　ひあっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ひゃっ、ああっ、あっ、なに、これは……んんんっ、これが、射精？　隊長\nさんが絶頂した証拠ですか……？　んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0103130" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021001_01_04" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「あんっ、あっ……ふふ、私のようなものでも隊長さんが興奮してくれたとい\nうのは、嬉しいですね……あんっ、まだ出てくる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ふふ、ふ、それにしても、男の人の欲望を受け止めるというのは、案外恥ず\nかしくもありますね……隊長さんのなら、なおさらです……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「んっ、まだ出てくるんですね……すごい勢い……私の顔が、隊長さんの精液\nで塗りつぶされそう……んむっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「匂いも、熱さも……隊長さんのものと思えば……んんっ、病みつきになりそ\nうです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「隊長さん、隊長さんはその……よかったですか？　私のフェラチオ……ご奉\n仕は」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0103135" ]},
		{"command":[ "SETIMAGE", "0", "still_00021001_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「よかったからこんなに出てる？　凄くエロかった？　ふふ、嬉しいけれどち\nょっと恥ずかしいですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0103136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「初めてでしたけれど、うまくできてよかったです。私のおっぱいやおまんこ\nも、なんだか不思議な感覚になりましたし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0103137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「でもなによりも、この精液が隊長さんの気持ちよくなった証だと思うと……\nなにか勝利とは違う喜びがじんじんと湧いてきます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「隊長さん、素敵でした……私にご奉仕、フェラチオを教えてくださり、あり\nがとうございます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ふふ、こんな町中でこんなことをして……誰も気づいてないというのは不思\n議な気がしますね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「え、気づいていないならもう一回する？　あっ、隊長さんのおちんぽがまた\nムクムクと……私の、フェラチオがいいんですね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0103201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「それでは……もう一度、誠心誠意、フェラチオさせていただきますね。あー\n……んむっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ちゅっ、んっ、先程の精液と混じって、不思議な味ですね……でも、嫌いで\nはありません。隊長さんのものだと思うと……んくっ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021001_01_06" ]},
		{"command":[ "PLAYVOICE", "v2_210_0103203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「んっ、れるっ、ちゅっ……はっ、あっ、んん、隊長さんのを舐め取っていた\nら、また身体が……あうっ、ふあっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0103204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「私のおっぱいとおまんこが熱くなって……はうっ、うっ、こんな気持ち、初\nめてです……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「隊長さん、隊長さんのおちんぽが愛おしい……んむっ、ちゅっ、れるっ……\nこの味も、匂いも、形も……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「んんっ、隊長さんが、私のフェラチオで気持ちよくなってくれてる……ちゅ\nっ、それが嬉しくて……んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「んむっ！？　んっ、あっ、んんっ、隊長さんの方から腰を……んっ、あっ、\n唇に、おちんぽが刺さって……んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「んっ、あっ、だめ、駄目です隊長さん、おちんぽで口マンコ刺したら駄目で\nす、あんっ、んっ、んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「もう、悪い隊長さんにはおしおきです。んっ……ちゅうっ、うっ、捕まえた\n、ちゅっ、れるっ、んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0103210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「腰を引いても駄目ですよ。唇と舌で……んふふふっ、どうですか、フェラチ\nオ、うまくなっってるでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「んんっ、むっ、ちゅっ、れるっ、れろっ、ふふ、隊長さんのおちんぽ、おい\nしい……んっ、んんっ、びくびくしてきましたね……ちゅうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0103212" ]},
		{"command":[ "SETIMAGE", "0", "still_00021001_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「さっきみたいに、硬く熱くなってきました……私のフェラチオで、また射精\nしてくれるんですね？　んっ、んんっ、ちゅっ、れるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ふうっ、おっぱいの先がじんじんして、おまんこもきゅうってなって、隊長\nさんのおちんぽを咥えているだけなのに……んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0103214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「はっ、え？　私の顔が可愛い？　そんな風に言われたのは初めてです……で\nも、悪い気はしません。私は正義と平和の戦士なのに……んむっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0103215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「戦士なのに、こうして隊長さんのおちんぽをフェラチオしているととても心\n臓が高鳴って……おっぱいもおまんこもじんじんと疼いて……んんっ、あっ！\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0103216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「隊長さんのおちんぽが硬くなるのも、びくびくするのも、同じなんでしょう\nか……んっ、あっ、ああっ、また震えてきた……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「出るんですね？　隊長さん、また出してくれるんですね？　私のフェラチオ\nで……んんっ、ちゅっ、ちゅばっ、れるっ、れろっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0103218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「出して、いっぱい出してください。隊長さんの精液、いっぱいほしいです。\n私のフェラチオで、いっぱい出して！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「んむっ、んぶっ、んうううっ、ふっ、ちゅうっ、ちゅっ、れろっ、んんんん\nっ、ちゅうううううううう！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「んぐっ、むっ、んううううううううううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0103301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021001_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「んっ、ぐっ……ふっ、あ、今度も、いっぱい出ましたね……口の中が隊長さ\nんの味でいっぱいです……ふふ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「身体のサイズが違うのに、こんなに注ぎ込んでくれるなんて……気持ちよく\nなってくれた証拠ですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0103303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「んくっ、んっ、先程は分かりませんでしたが、味も匂いも濃厚で……私の身\n体全部が隊長さんで塗りつぶされてる感じです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0103304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「んっ……んんっ、ぷはっ、あっ、れるっ、ちゅっ……んくっ……ふふ、隊長\nさんのおちんぽ、綺麗になりましたよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0103305" ]},
		{"command":[ "SETIMAGE", "0", "still_00021001_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ふふ、私にご奉仕……フェラチオを教えてくれたこのおちんぽ、なんだか愛\nおしくなりますね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0103306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「隊長さん、丁寧に教えてくれてありがとうございました。おかげで、地球人\nの営みを知ることが出来ましたし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0103307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「私自身、なんだか隊長さんのことをもっともっと、好き……知りたくなりま\nした」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0103308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「また、フェラチオ以外のことも教えてくれますか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ふふ、ありがとうございます。ならまたお願いしますね。私の隊長さん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「んんっ、むっ、あっ、口から抜いて、どうしたんですか隊長さん、きゃっ、\nあっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0103401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021001_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ひああっ、あっ、私の、伝説の眼鏡に……んんうっ、あっ、凄い、眼鏡に隊\n長さんの精液が……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「あっ、ああっ、視界が白く塗りつぶされる……私の大切な眼鏡が、隊長さん\nの精液で……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0103403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「粘っこくて、どろどろで……匂いも……駄目なはずなのに、眼鏡を汚されて\nるはずなのに、なぜか身体が……んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0103404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ふあっ、あっ、私の顔がエロい……？　それで隊長さんが興奮するなら……\nもっとかけてくれていいですよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0103405" ]},
		{"command":[ "SETIMAGE", "0", "still_00021001_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ひゃっ！！　本当にまたいっぱい出た……んっ、んんっ、眼鏡に精液をかけ\nて喜ぶなんて、隊長さんは変な人ですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0103406" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021001_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「でも、私もそんな隊長さんの精液で喜んでいるので同じですね……ふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0103407" ]},
		{"command":[ "SETIMAGE", "0", "still_00021001_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「あっ、んんっ、そんな、先端の残滓まで塗りつけなくても、全部受け止めま\nすから……やんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0103408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「私がエロかったから、フェラチオが上手かったからこんなにたくさん出た？\n　そう言ってもらえると、なんだか嬉しいですね……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0103409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「また……私にフェラチオさせてくれますか？　ふふ、その顔を見れば返事が\nなくても分かりますね。これからもよろしくおねがいします」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0103410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}