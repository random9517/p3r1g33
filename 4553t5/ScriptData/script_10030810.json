{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0160" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "いったいどうなっているのか。", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "なぜまりあがつきみたちと戦っているのか。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お前ら、いったいどうしたんだ！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "俺が近くまで寄って声をかけた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ガンシスター" ]},
		{"command":[ "SETTEXT", "「カツマさんの声がしたよ！　お姉ちゃん、そこにカツマさんもいるんでしょ\n！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_010115740001" ]},
		{"command":[ "SETCHARA", "0", "char_00001301_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「カツマさんは……いないっちゃ、いないったらいないっちゃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010115740001" ]},
		{"command":[ "SETCHARA", "0", "char_00001405_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ガンシスター" ]},
		{"command":[ "SETTEXT", "「お姉ちゃん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_010115740002" ]},
		{"command":[ "SETCHARA", "0", "char_00001301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「いいから、ここからでていくっちゃーっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010115740002" ]},
		{"command":[ "SETCHARA", "0", "char_00001405_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ガンシスター" ]},
		{"command":[ "SETTEXT", "「きゃぁあああぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_010115740003" ]},
		{"command":[ "SETCHARA", "0", "char_00001301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "まりあの電撃がつきみたちを吹き飛ばす。そしてみんなが光の渦にのみこまれ\nて消えていった。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ん……あの渦、見覚えがあるような……ないような……。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0147" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「ああーっ！　もーちょっとだったのにー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010115740001" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「また最初からやり直しである」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_010115740001" ]},
		{"command":[ "SETCHARA", "0", "char_00002001_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「いったい何回繰り返せばいいんだろうね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010115740001" ]},
		{"command":[ "SETCHARA", "0", "char_00001801_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「あと少しでお姉ちゃんたちを助けられたのにーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010115740002" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「お姉ちゃんのバカーッ！　カツマさんのアホーッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010115740003" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0160" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010115740003" ]},
		{"command":[ "SETCHARA", "0", "char_00001405_01", "4", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お、おいまりあ、どういうことか説明しろ！　なんでまりあがみんなを攻撃\nしているんだ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「そ……それは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010115740004" ]},
		{"command":[ "SETCHARA", "0", "char_00001405_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「さっきの渦はなんだ？　というか、あれが出口だろう？　もとの世界に戻る\nための！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まりあ、いますぐあれを出せ。そして一緒に元の世界に戻ろう！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "やっとこの変な世界から脱出できる。まさかその手段をまりあがもっていると\nは思わなかったが。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「い……嫌だっちゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010115740005" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "しかし、まりあは首を横に振る。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まりあ……」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「嫌だっちゃ！　わたしたちの幸せを失いたくないっちゃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010115740006" ]},
		{"command":[ "SETCHARA", "0", "char_00001405_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「あいつらに、わたしたちのラブラブ生活は邪魔させないっちゃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010115740007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ラブラブ生活って、おい、なにを言ってるんだ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「もう……わかったっちゃ……。こうなったら、強行突破するしかないっちゃ\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010115740008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "俺を見るまりあの目がだんだん据わっていく。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「告白とかもうどうでもいい！　ぜーんぶすっ飛ばしてカツマさんをわたしの\nものに……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010115740009" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "まりあに肩を掴まれ、そのまま押し倒されそうになったが……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "sbg_0209" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「お姉ちゃんのバカーッ！　カツマさんのアホーッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010115740004" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "どこからともなくつきみの声が聞こえてきた……って、", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まてまてなんだあれ！　文字がこっちに飛んでくる……！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うわぁあああっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「きゃぁあああぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010115740010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "正直、なにが起きたのか理解できないのだが、俺たちはつきみの声に吹き飛ば\nされたのだった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}