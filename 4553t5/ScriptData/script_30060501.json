{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE","0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「はーい、待った？　うん、こっそり抜け出してきたから、みんな気づいてな\nいわよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0503101" ]},
		{"command":[ "SETCHARA", "0", "char_00000605_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「んふふふふ、大胆ね、ディアナちゃんだけを呼び出すなんて。しかも、誰も\nいない場所に」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0503102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「なにをするつもりなのか、もちろん分かってるわよ。だってディアナちゃん\n、大人のレディーですもの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0503103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「……ていうか、この歳でぶりっことか知らないふりとか、痛すぎるもんね。\nあーいうの、ディアナちゃんきらーい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0503104" ]},
		{"command":[ "SETCHARA", "0", "char_00000605_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「それに、あなたのあそこ、とっくに大っきくなってるんだもん。水着だから\n、もっこりしてるの、隠せないわよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0503105" ]},
		{"command":[ "SETCHARA", "0", "char_00000605_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「このままじゃあ、お外歩けないもんね～。ディアナちゃんがなんとかしてあ\nげるしかないわよね～。んふふふふ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0503106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「それじゃあ、早速水着をぺろんと……うわぁ……おっきい。こんな大きいの\n、初めて見たわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0503107" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00000605_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「違うわよ！　ネットで見たの！　こ、これ、生で見たのは、ダーリンのだけ\nだもん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0503108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「おまけに、今まで見た中で一番大きくて……んく。匂いも、むわってしてて\n、頭クラクラしちゃいそう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0503109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「ディアナちゃんも、だんだん我慢できなくなってきちゃってる。あなたのお\nちんちん、気持ちよくしてあげたくなってる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0503110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「これも、あなたの能力なのかしら？　パワーアップのためにエッチしたくな\nっちゃうのって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0503111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「どっちでもいっか。とにかく、始めちゃうわね。じゃあ、早速……あーむ。\nん、むぅ、んじゅぅ……ん、ふふふ、んふふふふふふ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0503112" ]},
		{"command":[ "SETIMAGE", "0", "still_00000605_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「ふあ、らっれ。んふふ。男の人でも、声、れちゃうんら？　そんらに、でぃ\nあなちゃんの、おくひ、きもひいい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0503113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「じゃあ、もっろもっろ、してあげるわね。それで、匂い……もっろ、かがせ\nれぇ……じゅる、じゅぶぅ、ちゅるぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0503114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「んむぅ……おくひのなかれ、ろんろん、かたくなっれるぅ。おひんひん、し\nゅごい。ぼっきぼきに、なっれるぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0503115" ]},
 		{"command":[ "SETIMAGE", "0", "still_00000605_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「むぅ、ん、じゅるるるるるぅ……ぷあっ。ふあぁぁ。口の中、入れてられな\nいぐらい、大っきくなっちゃったぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0503116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「あ、見て見て。ほら、こぼれた唾液、おっぱいの谷間にたまっちゃってる。\nんふふ。これってなんだか、凄くエッチくさいわね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0503117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「ひゃっ！？　おちんちんがびくって跳ねた！？　え？　息がかかってくすぐ\nったかったの？　へぇ、そんなので、気持ち良くなっちゃうんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0503118" ]},
		{"command":[ "SETIMAGE", "0", "still_00000605_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「いちいち反応しちゃうなんて、なんだか可愛いかも。じゃあ次は、おっぱい\nに軽く当てて見ちゃおうっと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0503119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「あはっ！　そんなに柔らかくて気持ち良いんだ？　ディアナちゃんのおっぱ\nい、気に入ってくれたんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0503120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「じゃあ、このまま、また……あーむっ、ん。むぅ、ちゅ、じゅる、じゅるぅ\n。ん、ぶぅちゅうぅぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0503121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「あははははは。腰がぞくぞくってしてるわよ。おちんちんも、寒さに震えて\nるみたい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0503122" ]},
		{"command":[ "SETIMAGE", "0", "still_00000605_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「なんだか、どんどん可愛くなってきたわ。だから、このまま最後までしてあ\nげるわね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0503123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「あむ、むぅ、じゅる、じゅぶぅ、ちゅ、ちゅ、ちゅぶぅ、んぶぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0503124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「んむぅ、ん、ちゅぎは、舌を使っれぇ。れるぅ、れるぉぉ、ちゅ、れる、じ\nゅるるるぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0503125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「あは、そうなんだ。涙滲んじゃうぐらい気持ち良いんだ？　じゅるるるる、\nじゅる、じゅぶぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0503126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「ディアナちゃん、だんだん分かってきたかも。ここれしょ？　おしっこと精\n液が出る場所、舌で擦られると、気持ち良いんでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0503127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「こんら、ふうに……れるぅ、ちゅぶぅ、れるぅ、れぶ、れる、れろぉぉぉぉ\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0503128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「んん！？　お、おひんひん、また、おっきくなっら。それに、どく、どくっ\nれ、脈打ってるぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0503129" ]},
		{"command":[ "SETIMAGE", "0", "still_00000605_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「ひょっろして、そろそろ……？　んふふふふ。それってぇ、気持ひいいから\n、なのよね？　ディアナちゃんのおくひ、気持ひ、いいのよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0503130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「じゃあ、らして良いわよ。おくひに、らして……んじゅ、じゅる、じゅぶぶ\nぶぅ。ん、んむぅ……ん！？　んんんん！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0503131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「んぶっ！　んんんんんん！　あぶぅ……れ、れたぁ。たくさん、どろどろに\n、あちゅいの、おくひの中ぁ、いっぱいぃ……」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000605_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0503132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「あふぅ……しゅごい、これぇ。青くしゃいの、くひの中、いっぱいになっれ\nるぅ。んぶぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0503133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「それに、えほえほっ、えほっ。勢い、凄すぎて、ちょっと、飲んじゃったぁ\n。うぅ、喉、いがいがするぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0503134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「でも、これ、身体がぽかぽかしちゃって、頭、ぼーっとしちゃって、なんだ\nか、不思議な気分」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0503135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「んふ。またやってあげても良いかな。ディアナちゃん自身は気持ちよくない\nけど、なんだか妙な達成感があるし」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000605_01_08" ]},
		{"command":[ "PLAYVOICE", "v2_006_0503136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「口の中、びゅーって、精液いっぱいになっちゃうの、癖になっちゃいそうか\nも～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0503137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「それに、気持ちよくなるとき、あんなに可愛い顔するんだもん。そっちの方\nが、やみつきになっちゃうかも。んふふふふ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0503138" ]},
		{"command":[ "SETIMAGE", "0", "still_00000605_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「って、おちんちん、また大っきくなっちゃった。普通は一度イクと、しばら\nく立たないんじゃないの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0503139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「そうなんだ。ディアナちゃんの口の感触思い出して、おっきしちゃったんだ\n？　えへへ。いいわよ、もう一回、してあげる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0503140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「じゃあ、二回戦、始めるわよ？　んふふ。またいつでも気持ち良くなってね\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0503201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「あーむっ。ん、じゅる、むぅ、んじゅるるるるぅ。んあぁ……二回目らのに\n、すっごく、おっきぃ……むぅぅ、むぅ、じゅるぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0503202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「しょれに、せーえき、くさいの、尿道の奥からろんろんれてきて、ますます\n頭、くらくらひひゃうぅ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000605_01_07" ]},
		{"command":[ "PLAYVOICE", "v2_006_0503203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「むぅ、じゅる、じゅぶ、じゅるるぅ……ん、ぷあっ。ふあぁぁ。匂い、一回\n目よりも、濃厚になってるぅ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000605_01_08" ]},
		{"command":[ "PLAYVOICE", "v2_006_0503204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「んふふ。まるで気持ちよさのバロメーターみたい。匂いが濃くなればなる程\n、気持ちいいのよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0503205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「あはっ。今びくって跳ねた。おちんちんでお返事しちゃうなんて、可愛いん\nだから～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0503206" ]},
		{"command":[ "SETIMAGE", "0", "still_00000605_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「あんまりにも可愛すぎるから、ディアナちゃん、興奮、止まらなくなってき\nちゃった。もっともっと、可愛いところ見せてね。あーむっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0503207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「じゅるぅ、ん、むぅ、んん、ちゅぶぅうぅ……んふ。おくちらけじゃなくれ\n、おっぱいも……ぐにぐにってぇ……んん！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0503208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「んぐっ！？　う、うそれしょ？　まだ、おっきく、なるの？　ふあぁぁ……\nくち、くわえきれなく、なっれるぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0503209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「ディアナちゃんのおっぱい、そんなに、気に入ってくれたの？　んふふ。嬉\nしい～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0503210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「じゃあ、今度は、おっぱいでぐにぐにってしてあげながら、先っぽ、舌でこ\nんな風に、ちろちろってぇ……れるぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0503211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「あはっ！　腰がびくびく震えてる。そっか、これ、そんなにいいんだ？　お\nしっこの出る穴、舌でくすぐられるの、いいんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0503212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「もっと、れる、してあげるね。れるぅ。じゅる、ちゅ、ん、んんっ。おっぱ\nいと、お口、両方、ちゃんと感じてね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0503213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「あっ、おしっこの穴、ぱくぱくしてる。開いたり閉じたりして、んふふふふ\n、イキそうなんでしょう？　だってさっきもこんな感じだったもん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0503214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「いいよ、ディアナちゃんで気持ち良くなってくれて。その方がね、嬉しいか\nら。可愛い顔、見せて。いっぱいいっぱい、気持ち良くなって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0503215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「んじゅるぅ、ん、うぶぅ、じゅる、じゅるる。んふっ。まら、おっきくなる\n、なんれぇ。おくひもおっぱいも、もう、いっぱいいっぱい……んじゅるる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0503216" ]},
		{"command":[ "SETIMAGE", "0", "still_00000605_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「んふふ。イキそうな顔、可愛い。れも、がまんなんか、しなくれ、いーんら\nよ？　何回でも、きもひよく、しれあげるから。ね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0503217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「らから、ほら……じゅるるるるるるぅ。しゅきな時に、しゅきなだけ、いっ\nれ、ね？　んむぅ、じゅる、じゅるぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0503218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「あっ、イキそうらの、伝わっれくる。おひんひん、びくびくっれ……うん、\nいいよ。イっれ、いいよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0503219" ]},
		{"command":[ "SETIMAGE", "0", "still_00000605_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「ディアナちゃんのお口れも、おっぱいれも、すきなところに、いっぱい、い\nっぱい、らしてぇぇぇっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0503220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「んぶっ！　ん、ぶぅ！　んぶぅううううううううう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0503301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000605_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「んんぶぅうう。で、出た、おくひに……ん！？　んんんん！　たくさん、た\nくさんんっ！　んむぅうぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0503302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「しゅごっ、んん！　まだ、出てる！　んぐぅぅ……お、おぼれ、ちゃう、こ\nんら、たくしゃん……むううううううう！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0503303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「ふむぅ、ん、むぅうう！？　うぶぅううぅ……おくひの、なか、いっぱいぃ\n……えぶぅぅ。れも、あったかくっれ、匂い、しゅごくれぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0503304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「んくっ……ん、ごく、じゅる、ごくっ。んく、んく、んんん、ごくっ。ぷあ\nぁぁ……えほっ、えほえほえほえ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0503305" ]},
		{"command":[ "SETIMAGE", "0", "still_00000605_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、はふぅ……の、飲んじゃった。ディアナちゃん、精液、口に出\nされて、飲んじゃった。あはは」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0503306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「口の中だけじゃなくて、身体の中から、匂い、するぅ。まるで、身体の中か\nら犯されてるみたい、これぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0503307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「えへへ。なんか、これ、癖になるぅ。もっともっと、したくなっちゃう。ま\nるでディアナちゃんをあなた色に染められた気分」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0503308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「それに、その顔……蕩けそうな顔してる。ふふふふふ。気持ち良くなってく\nれたのね、嬉しい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0503309" ]},
		{"command":[ "SETIMAGE", "0", "still_00000605_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「うん、またしようね。ディアナちゃんのお口、いつでもあなたのおちんちん\n待ってるから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0503310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},


		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「んあ！？　おちんちん、引き抜いて……あ、ふあああ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0503401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000605_01_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「ひゃんんんんんん！　顔にっ！　んんんんんんん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0503402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「うそ！？　まだ出てる！　んん！　んんんん～！　熱いのが、あちこち、へ\nばりついちゃってるっ！　んん～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0503403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、ふあぁ……す、すごい、二回目なのに、こんなにたくさん。ど\nろどろで熱いので、ディアナちゃん、真っ白に汚れちゃったぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0503404" ]},
		{"command":[ "SETIMAGE", "0", "still_00000605_01_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「ほら、顔だけじゃなくて、髪の毛にも、おっぱいにも、お腹にも……あ、や\nだっ、垂れてきてる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0503405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「ふふふ。ぬるぬるが身体中にべったり張りついちゃってる。匂い、染みつい\nちゃうかも」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0503406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「こんな風にディアナちゃんを汚しちゃいたかったんだ？　んふふ、へーんー\nたーい。そうだよー、とっても変態だよ、こんなのが好きなんて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0503407" ]},
		{"command":[ "SETIMAGE", "0", "still_00000605_01_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「でも、そんな変態なことされて嬉しくなっちゃうディアナちゃんも、同じく\n変態なのかも。えへへへへ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0503408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「あっ、なんで今のでおちんちん、ぴくってしちゃうの？　ひょっとして、ど\nろどろに汚れたディアナちゃんで興奮しちゃった？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0503409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「それとも、変態って言われたのが嬉しかったのかしら？　んふふ。本当に可\n愛いんだから。そういうところ、大好きよ。ふふふふふ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0503410" ]},
		{"command":[ "WAITINPUT" ]},
