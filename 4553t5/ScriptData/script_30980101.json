{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009801_01_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ] },
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "PLAYVOICE", "098_0103101" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「棒術……棒術ね。まあ、棒には違いないと思うんだけど。これで棒術のトレ\nーニングになるかっていうと……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "098_0103102" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「……え？　こういうデリケートな棒を注意深く扱う訓練も、棒術を究めるに\nは必要？　自分で自分のを『デリケート』とか言うかな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "098_0103103" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「まあ、いいけど。こっちの棒も、いずれは研究する必要がある、って思って\nたし。それで？　何をすればいいの？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "098_0103104" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「はあ、なるほど。こうして手を上下して。しこしこ、しこしこ、しこしこ、\nと」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "098_0103105" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「……ふむふむ。確かにこの反応は興味深いね。こうして隊長の棒を優しく握\nり、手を激しく上下すると――」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "098_0103106" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「このように、隊長がだらしなくアヘ顔をさらし、よだれを流す。……実に面\n白い反応が観測できたね」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "098_0103107" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「で、隊長？　これをこのまま刺激し続けて、隊長を射精させればいいわけで\n――うわっ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "098_0103108" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「んんん……っ！　ちょ、ちょっと！？　私の胸に何して……んんんっ！？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009801_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "098_0103109" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「え……？　このままじゃ棒術の修行にならない？　隊長がなんのために胸に\n顔を寄せてたと思う、って――アウッ！　し、知らないよぉ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "098_0103110" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「こ、こうして、舐めたり、吸ったりして……修行の難易度を増す！？　ふぁ\nああん！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "098_0103111" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「も、もう、修行とかいいよぉ！　どうせ嘘でしょ！？　実験に集中させ――\nあああんっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "098_0103112" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「え……！？　妨害を乗り越え、正しい結果にたどり着いてこそ真の科学？　\nそれこそが宇宙の真理！？　科学を何だと思ってるのぉ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "098_0103113" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「ひゃあああん！　でも気持ちいいっ！　そうやって、乳首を吸われると……\nはああん！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "098_0103114" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「わ、わかったよ。私の体の変化も、なんだか気になってきたし。男女の反応\nの違いを――あああん！　オー、イェッ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "098_0103115" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「ああああ……わ、わかってるよ、手を、休ませずに……こうやって、上下に\n……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "098_0103116" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「オー……これが、ペニスの手触り……あったかくて、コリコリしている部分\nと、ぷにぷにしている部分が……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "098_0103117" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「んんんんっ！？　何吸ってるのぉ！？　母乳の味を確かめる、って、そんな\nの出るわけないでしょお！？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009801_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "098_0103118" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「もう！　隊長にはおしおきっ！　隊長の副隊長を、もっと強く刺激してやる\nっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009801_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "098_0103119" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「えい、えい、えいっ！　こすこすこすこす……お！？　こ、これは、副隊長\nの硬度に変化が……！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "098_0103120" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「そ、それに膨張率もどんどん上がってきて……！　す、すごい！　もう、こ\nんなになってる！　副隊長、隊長より偉そう！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "098_0103121" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「隊長……？　もう、限界なんだね？　さすがにそれは、見ただけでもわかる\nよ？　だって副隊長が、破裂しそうなぐらい膨れ上がって……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "098_0103122" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「んんっ！　んんんっ！　ちょ、ちょっと……！　そんなに吸わないで――は\nあああん！　んっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009801_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "098_0103123" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「この妨害に負けずにイカせてみろってこと……？　わ、わかったよ……やっ\nてみるよ……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009801_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "098_0103124" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「しこ、しこ、しこ……こす……こす……んんんんっ！　舌で乳首そんな風に\nしちゃ……あああっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "098_0103125" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「だ、ダメダメ、手を休めちゃ……被験者への刺激を、継続的に……こ、これ\nは、難しい実験だね……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "098_0103126" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「手を……速めて……しこしこしこしこ……んんんんんっ！　あ、あああ……\nっ！　た、隊長も、舌の動きを速めてきた……！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "098_0103127" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「オーノー！　おっぱい甘噛みしちゃノーだよぉっ！　んんんっ！？　て、手\nは緩めないけどっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "098_0103128" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「あ、あれ！？　隊長の副隊長の先っぽから、透明な汁がダラダラ……そ、そ\nういえば聞いたことがある！　これは、カウパー氏腺液っ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "098_0103129" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「うわ……ダラダラ出てくる……隊長？　気持ちいいんだね？　こうすると気\n持ちい――」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "098_0103130" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「あああんっ！　き、気持ちいいっ！　そこ、そうやって舌でコロコロされる\nと――あああん！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009801_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "098_0103131" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「はあっ……あっ、あっ、あっ……あああ……た、隊長？　なんだか、副隊長\nがピクピクしてきて……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "098_0103132" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「イ、イクの？　イクんだね？　わかった！　イカせるよっ！　その瞬間は見\n逃せな――はああん！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009801_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "098_0103133" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「ま、負けない！　妨害には負けない！　隊長をイカせて……射精の瞬間を…\n…！　しこしこコスコス！　ラビットパワー！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "098_0103134" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「あ、あ、ああああ……っ！　た、隊長っ！？　なんか、私の手の中で副隊長\nがすごく熱く――あああああっ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "098_0103135" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「うあああああっ！　ふぁああん！　あ、あああああっ！　た、隊長のが、手\nの中で破裂したっ！？」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009801_01_05" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "098_0103136" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「う、うそ！？　こんなに出るの！？　ま、まるで白い噴水……！　わ！　ま\nだ出てる！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "098_0103137" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「す、すっごい！　こんなにドクドク出るものなんだね……！　え？　手を休\nめるなって？　まだ出るから？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "098_0103138" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「わ、わかった！　最後の一滴まで、だね？　すこすこ、こすこす……っと。\nあ、ホントだ、まだ垂れてくる……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "098_0103139" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「そっか……男の人の射精って、こんな感じになるんだ。いや、大変参考にな\nりました……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "098_0103140" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「ただ、まだちょっとわからない部分もあるから……また今度、射精するとこ\n見せてね！　隊長！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "098_0103201" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「え？　なに？　『ご希望なら、もう一度見せられる？』ほ、ホント！？」　", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009801_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "098_0103202" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「うわ！　ホントだ！　隊長の、私の手の中でまた大きくなってきた！　これ\nをもう一度刺激すれば、精液の出るところが観察できるんだね？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "098_0103203" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「それでは。実験の二回目。よーい……はあああん！　な、何！？　二回目も\n、私のおっぱいを吸う必要あるの！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "098_0103204" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「な、なるほど。私の胸を舐めたり吸ったりして興奮したから、出してすぐこ\nんなに元気に……。そ、そういうことなのね」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "098_0103205" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「え？　『あとは、ただ単におっぱい吸いたいだけ』？　あ、あのねえ！？　\nはぁああん！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "098_0103206" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「も、もう！　わかったよ！　隊長がその気なら……えいっ！　しこしこしこ\nしこ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009801_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "098_0103207" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「へへへ、どう？　気持ちいいでしょ？　さっきの実験で、どのへんを刺激す\nると隊長は感じちゃうかがわかったからね！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "098_0103208" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「ほおら、ここをこんな風にされると、隊長、だらしないアヘ顔に――ふぁあ\nあん！　あっ！　オー、イェッ！　イェッ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "098_0103209" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「わ、私もだらしないアヘ顔になった！？　しょ、しょうがないじゃん！　あ\nんな風に、乳首を舌でコロコロされたら……はぁああん！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "098_0103210" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「んっ……んんんんっ！　ま、負けないぞ！　えいっ！　ラビット・パワーッ\n！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "098_0103211" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「ほおら、隊長？　気持ちいいでしょ？　副隊長はとっても正直だよ。ほらほ\nら、こんなに膨れ上がってきて……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009801_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "098_0103212" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「くっ……！　あくまでも抵抗する気なの？　でも、そうはさせないよ……！\n　ほおら、こすこす、しこしこ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "098_0103213" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「ふふふっ、副隊長の先っぽから、カウパー氏腺液が。気持ちいいんでしょ？\n　隊長。いいんだよ、出しちゃっても……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "098_0103214" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「はぅっ……！　そ、それはまあ、私も気持ちいいけど……！　もう、それは\nいいから！　早く、精液出すとこ見せて……あああん！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009801_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "098_0103215" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「え……？　二回目はちょっと時間がかかるかも？　大丈夫！　そんなの、私\nのラビット・パワーで！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009801_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "098_0103216" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「ほらほらほらほら！？　しこしこしこしこ？　こすこすこすこす！？　ねえ\n、隊長？　そうやって私の胸舐めてると、興奮してくるんでしょ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "098_0103217" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「やっぱりね。それでもって、興奮してくると、こんな風に副隊長がピクピク\nって。どうやら、さっきの実験と同じ結果が出たみたいだね」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "098_0103218" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「ねえ……隊長？　絶頂が近いんでしょ？　もう、イキそうなんでしょ……？\n　いいんだよ？　出して」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "098_0103219" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「へへへ……こすってるうちに、私も興奮してきちゃったよ……早く、隊長が\nイクとこ見たいよ……！　いっぱい、精液出すところを観察したい……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009801_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "098_0103220" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「がんばって……隊長！　もう一度精液、出して！　私に観察させて！　こす\nこすこすこす……っ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},
		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "PLAYVOICE", "098_0103301" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「おおおっ！　で、出たぁ～～～っ！　わわわっ！　すっごいいっぱい！」", "NORMAL" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009801_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "098_0103302" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「すごいなあ……あっという間に、私の手がこんなにベトベトに……精液って\n、二度目でもこんなにたくさん出るものなんだね」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "098_0103303" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「まだドクドクいってる。しごいたら、さっきみたいにまだまだ出てくるかな\n？　しこ、しこ、しこ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009801_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "098_0103304" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「わあああ……まだこんなに残ってるんだ、すごいねえ……男体の神秘だねえ\n……興味深いものを観察してしまった」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "098_0103305" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「わわっ！　すごい！　精液を改めて観察してみると、すっごい濃厚！　ねち\nょねちょネバネバしてて、握った手が開けなくなりそう」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "098_0103306" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「セ、セックスをするとさ、これが、私の体の中にぶちまけられることになっ\nちゃうんだねえ……ゴクリ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "098_0103307" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「え！？　いや、興味って言うか……ま、まあ……なくもないんだけどさ？　\nでもそれは性欲っていうより純粋に科学的な探求心としてですね……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009801_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "098_0103308" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「あ、相手してくれるって？　私がその気になったら？　そ、それは、まあ、\nその……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "098_0103309" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「え？　セックスはおっぱいを舐められるのより、何十倍も気持ちいい？　そ\n、そうなの？　そうなんだろうねえ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "098_0103310" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「そ、それじゃあ、そのうちお願いしようかな！　あ、あくまでも研究の一環\nとしてだけどね！　へへへへ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009801_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]}, 
		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "PLAYVOICE", "098_0103401" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「あ、あれれ？　隊長？　もう、手で刺激しなくてもいいの？　どうして急に\n――」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009801_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "098_0103402" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「うわあああああっ！？　ちょ、ちょっと！？　なんで顔に！？　どうしてそ\nんなこと！？　なぜ！？　どうして！？　ホワイ！」", "NORMAL" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009801_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "098_0103403" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「ちょ、ちょっとこれ止めて！　なんでこんなに飛ぶの！？　顔も胸も、精液\nでベトベト！　え！？　出てるものは急には止められない！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "098_0103404" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「あ、あ、あああ……まだ出てる……？　まだ……あ、いや、だんだん勢いが\nなくなってきたね。なるほど、こんな風に……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "098_0103405" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「あ、そっか。尿道にはまだ残ってるんだったね。ほら、ぎゅっ、ぎゅっ、っ\nて絞ったら、こんなふうに……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009801_01_11" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "098_0103406" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「うん。これで最後まで出し切ったのかな。いやあ……すごかった。まさか、\nあんなに飛ぶなんて――」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "098_0103407" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「って！　感心してる場合じゃないでしょ！？　隊長！　なんでいきなり顔に\nかけたりするの！　私、もうベトベトじゃん！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009801_01_10" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "098_0103408" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「……え？　精液でベトベトになった私は、きっとすごく綺麗に違いないと思\nって？　どうしても見たかった？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "098_0103409" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「思った通り、とても綺麗だって？　そ、そうかな……？　っていうか、そう\nいう美的感覚もあるのね……なるほど、興味深い」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "098_0103410" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「え？　またかけていいかって？　そ、そうだね……また、観察させてもらえ\nるなら……いいかな。えへへへ……」", "NORMAL" ]},
