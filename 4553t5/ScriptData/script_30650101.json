		{"command":[ "PLAYVOICE", "065_0103140" ]},
		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「正直ですね、でしたら……んううぅん。んんっ……はぁ、全部飲み干しまし\nたよ。これで隊長殿がパワーアップして頂けるのなら何よりです」", "NORMAL" ]},
