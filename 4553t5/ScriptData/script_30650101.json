		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「非常識な時間に呼び出されたので、まぁ碌なことではないと思っていました\nが……隊長殿。これはどういう……？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "065_0103102" ]},
		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「私の任務にこの様なことは含まれていない筈ですが……これ以上の辱めをな\nさるおつもりでしたらこちらにも考えがあります」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "065_0103103" ]},
		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「は？　……この行為で能力が増幅する、と……。私を馬鹿にするのもいい加\n減に……え？　本当に、なのですか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "065_0103104" ]},
		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「そんな理由でお声をかけて頂いたのなら……仕方ありません。隊長殿は、我\nが隊の戦力の要ですからね」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "065_0103105" ]},
		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「敵に十分な力で対抗する為の、これが過程になるのであれば……仕方ありま\nせん。私も、是非協力させて頂きましょう」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "065_0103106" ]},
		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「それで、どうすれば宜しいのですか？　この屹立した男性器を射精すれば\n宜しいと、そんなお話しでしょうか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "065_0103107" ]},
		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「どんな手段を取っても構わないのならば……そうですね、現状の胸からの刺\n激だけでは物足りませんでしょう？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "065_0103108" ]},
		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「この様なことはことは時間をかけたところで、互いに気まずくなるだけでし\nょうから……隊長殿を絶頂に導く為全力を尽くさせて頂きます」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "065_0103109" ]},
		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「では、隊長殿。失礼させて頂きます。可能ならば、リラックスして下さいね\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "065_0103110" ]},
		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「はぁむ……んんぐぅ、んじゅるぅぅ……れろっ……れろぉぉ……はぁ、んぐ\nぅぅうぅ……じゅるるるぅぅ……あぁ、熱い」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00006501_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "065_0103111" ]},
		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「はぁ、すっかり硬く……興奮していらっしゃるようだ。んじゅるぅぅ……れ\nろぉ、ちゅぱぁぁぁ……はぁ……これならば、はぁ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "065_0103112" ]},
		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「私の、んじゅるるぅぅ……奉仕でも、はぁ……絶頂に導けそう、ですね。れ\nろぉ……ちゅぱぁぁ、はぁ……じゅっぽじゅっぽ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "065_0103113" ]},
		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「んぅ、先走りが……はぁ……出てきた。れろれろぉ……快楽を、得て下さっ\nている、と？　んじゅるぅ……はぁ、括れを舐め回されるのがお好みらしい」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "065_0103114" ]},
		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「んううぅぅ……血管が、浮いて……はぁ……ますます、硬く……じゅぽぉ…\n…じゅぽぉ……れろぉ、はぁ……胸に、性器の熱が、移る……んううぅ」　", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "065_0103115" ]},
		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……先走りで、口の中が……れろぉ、いっぱいで……んじゅる\nぅぅ……はぁ、そろそろ達されるのでは？　はぁ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "065_0103116" ]},
		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「は？　まだ……？　はぁ……そう、ですか。申し訳ありません、私はこの様\nな行為に、じゅるるぅ……不慣れ、故……れろれろぉ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00006501_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "065_0103117" ]},
		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……んじゅるぅ……ちゅぱぁ、はぁ……何か、勘違いをされて\nいるようだ。はぁ……私は、この様なことは……れろぉ……経験がなく……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "065_0103118" ]},
		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「れろぉれろぉ……じゅるるぅぅ……はぁ、つまりその……初めて、ですので\n……はぁ……慣れぬ愛撫は、ある程度、了解頂きたい……じゅるるぅ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "065_0103119" ]},
		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「はぁ、勿論……んううぅぅ……一生懸命やらせては、はぁ……頂いています\nが……れろぉ、じゅるるるるぅぅ……はぁ……んぅぅ、隊長殿……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "065_0103120" ]},
		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「そうだ、目を……はぁ……お閉じ下さい。ちゅぱちゅぱぁぁぁ……相手が私\nでは、はぁ……猛ったものも、んじゅるぅ、萎えてしまうのでは……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "065_0103121" ]},
		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「え……あ、何を……はぁ、おっしゃって……じゅぽぉじゅぽぉ……はぁ。私\nの、顔が……興奮する……？　れろぉ、あ、隊長殿……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "065_0103122" ]},
		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「じゅるるぅぅ……この行為、はぁ……私は、任務の一環として、じゅるぅ…\n…行って、おります。はぁ……ふざけるのは、お止め下さい、れろぉ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "065_0103123" ]},
		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「んうぅう……はぁ、先走りがまた……んぐぅ……口の中が、生臭い……んっ\nじゅるぅぅ……はぁはぁ……んぐぅ、また、血管が……はぁ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00006501_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "065_0103124" ]},
		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「ちゅぅちゅぅぅううぅ……んぐぅ、血管がこんなに、浮いて……はぁ……れ\nろぉ、んじゅるぅ……舌に、凸凹した感触が……れろぉ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "065_0103125" ]},
		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……性器の臭いが……れろぉぉ、強まってきました。んじゅる\nぅぅ……ちゅぱぁ……じゅるぅ、んううぅ、咽、そうだ……はぁ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "065_0103126" ]},
		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「んぐぅぅ……ぐぽぉ……ぐっぽぉぉおおぉ……れろぉ……ちゅぱぁ……じゅ\nるるるぅぅ……はぁ、んうぅぅ……れろっ、れろぉぉ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "065_0103127" ]},
		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「んぅぅ、何、ですか？　はぁ……隊長殿……？　れろぉ……え？　はぁん…\n…隊長の、顔を……？　見て……？　んじゅるぅ……そ、それは……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00006501_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "065_0103128" ]},
		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「はぁ……分かり、ました……んじゅるるぅぅ、はぁ……。それも、隊長殿を\n……んぅ、絶頂に導く、んぅぅ……はぁ、任務の一環なら……はぁ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "065_0103129" ]},
		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「仕方の、ないこと……です。んじゅるるぅぅ……はぁ、れろぉぉ、れろぉぉ\n……ちゅぅううぅ中ぅ……はぁ、はぁ……隊長殿、んううぅうぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "065_0103130" ]},
		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「それにしても、隊長殿は……はぁ、少々趣味が悪い、ようだ……。れろぉ、\n私の顔も、んじゅるぅぅ……興奮の要因の一つに感じられるとは……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "065_0103131" ]},
		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「んうぅ？　あぁ、隊長殿……陰茎が、はぁ……震えておりますが……れろぉ\nれろぉ……んくぅぅ、これ、そろそろ射精、が……？　れろぉ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "065_0103132" ]},
		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「んぐぅぅ、やはり。はぁ、では……隊長殿の敏感なところを、はぁ……重点\n的に……じゅるじゅるぅ……ぐぽっ……ぐぽっ……ぐぽぉおぉぉお……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "065_0103133" ]},
		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「隊長殿、達される時は……一言、お願いしますね。れろぉ……私にも用意が\n、はぁ……御座いますので……んじゅるぅぅ……じゅっぽじゅっぽ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00006501_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "065_0103134" ]},
		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「んぅぅ、性器の震える間隔が……れろれろぉ……早、？　隊長殿……あの、\nまさか……射精されるのでは？　あの、んんぐぅぅ、隊長殿……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "065_0103135" ]},
		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「んぶぅううぅぅ……お、おはぁぁぁ……んんぐうぅぅう……じゅるぅぅ……\nじゅるううぅぅぅ……んごぉぉ……ちゅぱぁぁ……はぁ……はぁ……」", "NORMAL" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00006501_01_09" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "065_0103136" ]},
		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「おごぉぉ……の、喉の奥に……熱い液が……はぁ、さっきの先走りとはんぐ\nぅ、全然違う。これが精液……？　んぶぅぅうぅ……はぁはぁ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "065_0103137" ]},
		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「んぐぅぅ……隊長殿、はぁ……達される時は一言声をおかけ下さいと、お願\nいした筈ですが……んじゅるるぅぅ……はぁはぁ……に、苦い……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00006501_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "065_0103138" ]},
		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「私の口淫が良すぎ、て……？　はぁ、隊長殿は口が上手い。れろぉ……。は\n？　上手いのはお前だと？　ハハッ、この場合は確かにそうか。れろぉ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "065_0103139" ]},
		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「あぁ、少し飲んでしまった。これ、吐き出しても……あぁ？　全部飲めと…\n…？　れろぉ、それは任務で？　……ふぅん、好みで、とは……はぁ……」", "NORMAL" ]},
