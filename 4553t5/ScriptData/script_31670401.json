		{"command":[ "WAITINPUT" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「二人の方が捗る……確かに。かなり時間が余ってしまってるな……ふむ……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0403102" ]},
		{"command":[ "SETCHARA", "0", "char_00016704_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「その、主殿……も、もしよかったら……ちょっと、こちらに来てもらえない\nだろうか？　ああ、この個室の方だ。そう、こっちに」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0403103" ]},
		{"command":[ "SETCHARA", "0", "char_00016704_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「……という訳で……これは、その日頃お世話になっているお礼と言うか……\n今日手伝ってくれた分のお返しと言うか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0403104" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00016704_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「いや、それだけではないっ。そのっ、私が……したいんだっ……主殿のオチ\nンポに……ご、ご奉仕をっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0403105" ]},
		{"command":[ "SETIMAGE", "0", "still_00016704_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「今、私が自信を持って出来るご奉仕と言えば……やはり、胸……パ、パイズ\nリしかないからな……大きさなら、そうそう他に引けをとることはない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0403106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「もちろん、大きければいいというものでないことは分かっている。とにかく\n……んっ、そのまま……オチンポを押し込んで……んっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0403107" ]},
		{"command":[ "SETIMAGE", "0", "still_00016704_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あぁ……主殿のオチンポ……どんどん勃起してくる……私のおっぱいの中で\n……んっ、存在感が大きくなっていく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0403108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「待っていてくれ……ちゃんとローションを用意してある。これを谷間に垂ら\nせば……んふっ……ヌルヌルするだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0403109" ]},
		{"command":[ "SETIMAGE", "0", "still_00016704_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あぁ……いつ、何時でもご奉仕が出来るようにと常備しているのだ。こうし\nて……滑らせてやれば……んぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0403110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んふっ、オチンポが反応してくれた……気持ちいいだろう？　そうだ……こ\nこは、もう一つの性器……おっぱいマンコだからな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0403111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「主殿は……ここを、オマンコと思って……オナホールのように、存分に使っ\nて欲しい……はっ、んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0403112" ]},
		{"command":[ "SETIMAGE", "0", "still_00016704_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「私も……ちゃんと喜んで貰えるように、精一杯のご奉仕をする。こうして…\n…ぎゅっと……挟み込んで……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0403113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んふっ、うんっ、はっ……んんっ……柔らかく……押し付けていく……んん\nっ、あっ……はぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0403114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んっ！　どうだろうか……少しは上達していると嬉しいのだが……いかんせ\nん、試す相手は主殿だけだからな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0403115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「後は、イメージトレーニングで……何とか……んっ、ふっ、している、感じ\nだ……んんっ、あっ、くっ、んふぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0403116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「だが、やはり……実際にするのと……イメージでは、全く違うな……この脈\n動……この硬さと柔らかさの共存する竿の感じ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0403117" ]},
		{"command":[ "SETIMAGE", "0", "still_00016704_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「おっぱいが、驚いている……んっ、主殿のオチンポと一体になったような…\n…そんな密着感が……何とも心地良い……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0403118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「おっと、済まない。私ばかり堪能していても仕方ない。もっとおっぱいをし\nっかりと活用しなくてはな……んっ、んんっ……ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0403119" ]},
		{"command":[ "SETIMAGE", "0", "still_00016704_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「制服には……かなりのゆとりを持たせて貰っているが……やはり、太いオチ\nンポを挟むと……はち切れそうになるな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0403120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「このまま……縦に……んっ、ズリズリと扱いてやるっ……んぁふっ、あっ、\nおっ、んんっ、はっ、んくんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0403121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あぁ……おっぱいが犯されていく……くぅ……んっ、主殿……動きたかった\nら、好きに動いていいからな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0403122" ]},
		{"command":[ "SETIMAGE", "0", "still_00016704_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はっ、んっ……寝たままの姿勢だと……結構な運動になるかも知れないが…\n…擦れた時の快感は格別だろう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0403123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「主殿の動きに合わせて、私も……おっぱいを……扱いていくと……あぁっ、\nぬぷっと……滑る感触が……たまらないっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0403124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「にゅぽにゅぽと……んんっ、肌の触れ合ういやらしい音が……興奮を増幅さ\nせて……後は、こうして……強くプレスするっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0403125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んんっ！　どうだ……主殿？　私のおっぱいマンコ……なかなかの味わいに\nなっていないか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0403126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「無論、本物と比べるものではないかも知れないが……だが、普段働いている\n居酒屋の一室で……こんなおっぱいご奉仕をする機会は滅多にない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0403127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「主殿には……この特別な感覚を、どうか……存分に楽しんで欲しい……あぁ\nっ、私のおっぱいも敏感になって……楽しんでしまっている……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0403128" ]},
		{"command":[ "SETIMAGE", "0", "still_00016704_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はぁっ、んふっ、あぁ……中に埋もれてどうなっているか分からないのが欠\n点と言えば欠点か……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0403129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「だが、見えないからこそ、色々な想像が捗るという話も聞く……んっ、とに\nかく、私は……主殿に、この肉奉仕を……楽しんで欲しいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0403130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はんっ、あっ、あぁっ、うんっ、んくぅんっ……あぁ……主殿……顔つきが\n変わったな……息も乱れて……ふふっ、色っぽい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0403131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「これは、そろそろ余裕がなくなって来たんだな？　なら、ここからは本気の\nご奉仕で一気に射精まで持っていくぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0403132" ]},
		{"command":[ "SETIMAGE", "0", "still_00016704_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んっ、んふっ、はっ、あんっ、ずぷずぷっ、言うっ……あぁっ、オチンポと\nおっぱいマンコ……んんっ、擦れるぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0403133" ]},
		{"command":[ "SETIMAGE", "0", "still_00016704_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はぁっ、あぁっ、オチンポがビクビクしてっ……出す時は、このまま……中\nにっ……おっぱいマンコに中出ししてくれっ……んっ、あぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0403134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「そうだ……腰を激しく振ってっ……あぁっ、オチンポっ……精液っ……出し\nてぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0403135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あぁっ！　出て……来たっ……主殿が……私のおっぱいマンコで射精してく\nれているっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0403136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016704_01_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あぁ……んんっ、ドロッとした感触が気持ちいい……はぁぁ……すごい……\n主殿……どんどん出てくるぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0403137" ]},
		{"command":[ "SETIMAGE", "0", "still_00016704_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「そろそろ落ち着く頃か？　うん、ここまで沢山出してくれれば、ご奉仕のし\nがいもあったというものだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0403138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「ふふ……主殿の表情がいいな……少し切なそうに見えるのが……何というか\n、色っぽく感じる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0403139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あぁ……おっぱいがあたたかい……あぁ、主殿が出してくれたお陰で、私は\nお仕えしているという実感を得ることが出来るんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0403140" ]},
		{"command":[ "SETIMAGE", "0", "still_00016704_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「さて……まだ、オチンポは大きいままだな。この先は、延長サービスになっ\nているが……ご利用頂けるだろうか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0403201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「もちろん、お代は必要ない……というより、十分貰っているからな……主殿\nがもういいというなら、やめておくが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0403202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「ふふ、そう言ってくれると思っていた。任せてくれ、続きはより濃密な特別\nパイズリご奉仕をするからな……んっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0403203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あぁ……ぐちゅってする……んんっ、このぬめり……あぁ……いやらしい…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0403204" ]},
		{"command":[ "SETIMAGE", "0", "still_00016704_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「どうだろう、はっ、あっ……んっ、一度出されたおっぱいマンコは……より\n、本物感が出てきているんじゃないか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0403205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「ローションに精液が混じって……んっ、私の汗も……じっとりとへばりつい\nて……あぁ……乳首が浮いてしまってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0403206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んぅっ……乳首が凝っている？　そ、それは……仕方ない……こんなにオチ\nンポを間近に感じているんだ……反応しない訳がない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0403207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「そうだ……私は、オチンポを側にして、発情している……淫乱なメス騎士な\nんだ……だから、もっとおっぱいを重ねて……乳首も……弄る……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0403208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んんっ！　あふっ、あぁ……いやらしい音が鳴るぅ……主殿のオチンポを独\nり占めして……揉みくちゃにしてしまってるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0403209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んっ、はぁっ、はんっ……あんっ、おっぱい……もっと押し付けてぇ……ん\nっ、チン先っ……亀頭をプレスしてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0403210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「こうして……ぎゅぅっと……あぁっ、主殿のオチンポがビクビクしてるっ、\nんふっ、快感を我慢している顔が……愛おしい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0403211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「お、お互い様……？　あっ……ぅっ……それは……んんっ、確かに……私も\n、気持ちよくて……あっ、ふっ……どうにかなりそうだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0403212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「もっと主殿のオチンポを感じたい……んっ、おっぱいを犯して欲しいっ……\nあぁっ、もっと激しくっ、私のおっぱいは主殿のものだからっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0403213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「くぅんっ！　おっぱいマンコがいいっ、あぁっ、オチンポっ……おっぱい全\n体に擦れてっ……あぁっ、熱いのっ、んぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0403214" ]},
		{"command":[ "SETIMAGE", "0", "still_00016704_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はっ、あっ、んんっ……んふっ、そうだ……私は主殿のオチンポが大好きだ\nっ……こうしてっ、おっぱいでご奉仕出来ることを誇りに思うっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0403215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「オチンポがいいっ、オチンポ好きぃっ！　あぁっ、おっぱい気持ちいいっ、\nオチンポもっとするっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0403216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はぁっ、そうだっ、いっぱいシコシコするからっ、はぁんっ、あぁっ、もっ\nとおっぱいっ、扱いてっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0403217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あぁっ、主殿っ……また出るのかっ？　私もっ……んんっ、おっぱいが……\n痺れてっ……イキそうになってるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0403218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はひっ、あぁっ、イッてっ！　また好きなところに出していいからっ、熱い\n精液っ……オチンポザーメンっ、いっぱいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0403219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「来てっ……あぁっ、出してっ！　主殿の欲望……全部っ……いやらしいオナ\nホールにぶち撒けてぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0403220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あぁっ、また……中にっ？　もちろん大歓迎だっ！　発情した、私のおっぱ\nいマンコにっ、もう一発中出ししてぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0403301" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んぁぁぁんっ！　ああっ、出てるっ……熱いのっ……オチンポザーメンっ…\n…また中出しされてっ……はぁぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0403302" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016704_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あっ、イクっ！　おっぱいでイクっ！　私の淫乱おっぱいがっ、中出しされ\nてイッてるぅぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0403303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んはぁぁぁ……あぁ……どぷっとしてる……かけてぇ……ねとねとぉ……気\n持ちよすぎるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0403304" ]},
		{"command":[ "SETIMAGE", "0", "still_00016704_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んんっ……最後の一扱き……あっ、出た……今ので……ちょうど出し切りだ\nったかな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0403305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁっ、んっ……あふっ……いっぱいだ……主殿……堪能していた\nだけただろうか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0403306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「そうか、それは何よりだ。私も、ちゃんとご奉仕が出来て嬉しい限りだ……\nふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0403307" ]},
		{"command":[ "SETIMAGE", "0", "still_00016704_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あぁ……しかし、すぐに綺麗にしないと……こんなことが知れては、流石に\n店長に叱られるどころではない気がする」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0403308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あ……主殿も手伝ってくれるのか？　うむ、かたじけない。ふふっ、そうだ\nな……私達は共犯だからな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0403309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「そうだな、今度はもっとプライベートで……特別なサービスをさせて貰えれ\nば……時間もたっぷり使って……ふふっ、期待していてくれ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0403310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あっ、主殿っ……オチンポ……えっ……顔にっ……あ、あぁっ、それはっ…\n…もちろんっ……ひぁぁんっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0403401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016704_01_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んぁぷっ！　あぁっ……主殿のオチンポザーメンっ……顔にっ……んっ、出\nてるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0403402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はぁんっ、あっ、イクっ！　おっぱいもイクっ！　ザーメンぶっ掛け気持ち\nよくてっ、私もイクぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0403403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はぁっ……んちゅぷっ、濃厚だ……主殿の精液は……いつでもすごい生命力\nに満ち溢れている……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0403404" ]},
		{"command":[ "SETIMAGE", "0", "still_00016704_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あぁ……んんっ、頬に塗り拡げてくれ……はぁぁ……んっ、主殿の匂い……\n染み込ませてくれ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0403405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んっ、あぁ……収まって来たか……主殿……パイズリご奉仕は楽しんで頂け\nただろうか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0403406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「よかった……その、今日はいつも以上に張り切ってしまった気がして……空\n回りでなければ、何よりだ」", "NORMAL" ]},
