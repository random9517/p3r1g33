		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「さて、開店準備もＯＫだ。済まないな、主殿にも手伝ってもらうなんて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0403101" ]},
		{"command":[ "SETCHARA", "0", "char_00016704_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
