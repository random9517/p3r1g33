{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0162" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "翌日からも桃花と夜日楽、そして巻き込まれた俺はルルーナとマーガレットに\n勉強を教えていた。", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「ちょっと、本当に忘れたの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020115830001" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「えっと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020115830001" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「あんな詰め込み学習じゃ身につかないわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070115830001" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「誰のためにやってると……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020115830002" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「桃花さん、聞いてください！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020115830001" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「夜日楽、どうしたの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020115830003" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "夜日楽が数名の生徒をつれてきた。なんでも、こいつらも成績不振で部活など\nを制限されていたらしいが、今回の小テストで急に高得点を取ったらしい。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「本当に！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020115830002" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「いったい、どんな手を使ったの！？　買収！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070115830002" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「先生に賄賂を贈ったとか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020115830003" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラの部下" ]},
		{"command":[ "SETTEXT", "「そんな汚い手はつかってませんよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_020115830001" ]},
		{"command":[ "SETCHARA", "0", "char_00002102_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロックの部下" ]},
		{"command":[ "SETTEXT", "「うん、とくに変わったことはしていないよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_010115830001" ]},
		{"command":[ "SETCHARA", "0", "char_00001902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーンの部下" ]},
		{"command":[ "SETTEXT", "「ええ、普通の塾に通い始めただけです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_030115830001" ]},
		{"command":[ "SETCHARA", "0", "char_00002302_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「塾……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020115830004" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラの部下" ]},
		{"command":[ "SETTEXT", "「最近、駅前にいい塾ができたんですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_020115830002" ]},
		{"command":[ "SETCHARA", "0", "char_00002102_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロックの部下" ]},
		{"command":[ "SETTEXT", "「成績があがったのは、きっとそのおかげね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_010115830002" ]},
		{"command":[ "SETCHARA", "0", "char_00001902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーンの部下" ]},
		{"command":[ "SETTEXT", "「問題を解くときに、『あ、ここ塾でやったところだ』となりましたから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_030115830002" ]},
		{"command":[ "SETCHARA", "0", "char_00002302_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「塾か……。でも、塾ってある程度の地頭がないと意味がないんじゃないか？\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「ふたりの成績と、学習態度でもなんとかなるの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020115830005" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラの部下" ]},
		{"command":[ "SETTEXT", "「なんとかなりますよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_020115830003" ]},
		{"command":[ "SETCHARA", "0", "char_00002102_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「ええっ、こんな状態（成績）からでも大丈夫なんですか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020115830002" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「ルルーナたちの成績をあげるなんて、普通に考えたら難易度ナイトメアよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020115830006" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETTEXT", "たしかに、ルルーナについては一度俺たちも成績をあげようとしたことがある\nが、無理だった。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},


		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0211" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "SETNAME", "サイレーンの部下" ]},
		{"command":[ "SETTEXT", "「たぶん、きっと大丈夫！　このパンフレットを見てください！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_030115830003" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		
		{"command":[ "SETTEXT", "そう言って、生徒たちは塾のパンフレットを見せてくれた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「刻蹄館塾……？　いかつい名前ね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020115830007" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「えっとなになに……。『０点から赤点まで入れる、あなたのための学習塾』\n？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "まさにルルーナたち向けの文句が書かれているじゃないか！", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「『どんなダメ生徒でも入れる塾があるじゃないですか！』……って、ずいぶ\nん煽りに煽ったキャッチコピーですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020115830003" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「でも見て？『赤点が、いくつ増えても、受かれるの？　……ええ！　ご安心\nください』だって！　すごい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020115830008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロックの部下" ]},
		{"command":[ "SETTEXT", "「しかも基本無料で、成績アップ保証つきなのよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_010115830003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「基本無料って……ちょっと話がうますぎませんか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020115830004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「いや、この塾にまかせちゃおうよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020115830009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「私たち素人が教えるより、そっちの方が絶対にいいって。マーガレットもい\nいよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020115830010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「そうね。どんなところかはわからないけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020115830004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「一度くらいなら、行ってみてもいいかもしれませんわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070115830003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まあ、お前たちがいいなら止めないけど。塾の勉強がつまらないからって暴\nれるなよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0162" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「失礼ね！　私たちをなんだと思ってるの！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070115830004" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「そうよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020115830005" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "いや、本当に暴れそうだから言ってるんだよ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "それ以外にも、この塾に対しては嫌な予感はしている。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "しかしここで塾に行かせれば、俺もこいつらの勉強につき合うことはなくなる\nだろう。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "結局その日の勉強会はお開きとなり、ルルーナとマーガレットは生徒たちと一\n緒に刻蹄館塾へと向かったのだった。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「ふふっ、これでゆっくりゲームできるわ。冒険しまくるわよ～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020115830011" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}