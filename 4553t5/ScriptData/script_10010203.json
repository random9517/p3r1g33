{
	"scriptCommands" :  [
        {"command":[ "FADEIN", "NORMAL" ]},
        {"command":[ "SETIMAGE", "0", "bg_0117" ]},
        {"command":[ "DISPIMAGE", "0", "true" ] },
        {"command":[ "FADEOUT", "NORMAL" ]},
        {"command":[ "PLAYBGM", "BGM_018" ]},
        {"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「だーっ！　終わらねえ！　どう考えても、今日中には終わらねえ！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "デスクの上に山と積まれた書類を前に、俺は思わず悲痛な声を上げる。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人。インクレディブル・スクワッド隊長ともあろうお方が、はしたない\n声を上げるものではありませんぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "009_010102030001" ]},
		{"command":[ "SETCHARA", "0", "char_00000901_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
        {"command":[ "SPOTCHARA", "0" ] },
        {"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "バカ犬め……相変わらず他人事だと思って好き勝手ぬかしやがって。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うるせえ！　これを全部まとめて処理しなきゃならねえんだぞ！　悲鳴のひ\nとつも上がるってもんだろうが！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「であれば、このような事態に陥らぬよう、常日頃から書類仕事はこつこつと\n片付けておくべきでは」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "009_010102030002" ]},
		{"command":[ "SETCHARA", "0", "char_00000901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「そもそも、面倒な仕事は全部後回しにして、溜め込むだけ溜め込んでしまう\n。ご主人のそんな勤務態度が、問題なのではありませんかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "009_010102030003" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「俺が溜め込んだわけじゃねえよ！　脳筋女幹部どもと、単細胞な正義の味方\n連中だよ！　あいつら、経費の精算書類もまともに出せやしねえ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "っつーか、そもそもなんで隊長の俺が書類を全部確認しなきゃならねえんだ！", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「カツマ、がんばって。わたしも手伝うから……」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "PLAYVOICE", "002_010102030001" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、そりゃありがたいけどさ。お前も書類仕事、得意なほうじゃねえだろ\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「……仕方ありませんね。わたしもお手伝いします。こちらの山はわたしが―\n―」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "014_010102030001" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「……必要ない。私が手伝う。余計なことをしないで」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "002_010102030002" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「余計なことではありません。隊長の事務処理が滞れば、隊の活動に支障をき\nたしますから。ここは、わたしがお手伝いを」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "014_010102030002" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「…………殺る気？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "002_010102030003" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「……お望みなら！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "014_010102030003" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「だーっ！　お前ら落ち着けっ！　なんでこんなことで張り合ってんだ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "この二人、同じ隊に編入されて毎日顔を合わせるようになってから、どうでも\nいいことで張り合うようになっちゃったんだよなあ……。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "どっちが俺にコーヒーを入れてくれるか、とか、どっちが先に俺に報告をする\nか、とか、移動中の車両で座る位置とか……。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "なんだろうなあ、この二人、そんなに気が合わないとは思わなかったぞ。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人の野暮天ぶりは世界遺産級ですな。いまどき、ハーレム系主人公でも\nもっと空気を読みますぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "009_010102030004" ]},
		{"command":[ "SETCHARA", "0", "char_00000901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんだぁ！？　なんか言ったかアホ犬！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「いえいえ、わたくしは別に何も」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "009_010102030005" ]},
		{"command":[ "SETCHARA", "0", "char_00000901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まあいい、それどころじゃねえ。とにかく！　わかったから！　二人とも手\n伝ってくれれば、すっげえありがたいから！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いいか？　こっちの山はまりあ！　こっちの山はカグヤ！　そしてこの山は\n俺！　そういう分担で――あ、あれ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「どうかしましたかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "009_010102030006" ]},
		{"command":[ "SETCHARA", "0", "char_00000901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ここにあった書類の山はどうした？　まさか、てめえ食ったんじゃ――」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「心外ですな。わたくしは犬であってヤギではありませんぞ。いくらご主人が\n甲斐性なしで、ろくな食事を与えられていないとはいえ――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "009_010102030007" ]},
		{"command":[ "SETCHARA", "0", "char_00000901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「カツマさん、あれ――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "014_010102030004" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "002_010102030004" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……なんだ？　二人ともどうした――って、あれ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「問題ない。こちらの山はすでに処理した」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_090102030001" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「は、はぁ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "Ａルナテミス！？　いつの間にあらわれたんだ？", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「記入された内容を確認し、判を押せばいいのだろう？　ならば、この山の処\n理は完了した」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "PLAYVOICE", "001_090102030002" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あ、ああ……そうなんだが。おまえ、さっきまでこの部屋にいなかったよな\n？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ああ。今来たところだが？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_090102030003" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「それで、もうこんなに片付けちゃったのか！？　あの書類の山を！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「何を驚いているのだ。さほど難しい判断を要する書類でもあるまい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_090102030004" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あ、ああ……まあ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「しかし、これは……この世界の私が提出した書類か？　ひどい悪筆だな。お\nまけに計算も間違いだらけだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_090102030005" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ぶふっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "思わず噴き出した。そうなんだよなあ！　あいつ、書類の書き方がホントにい\nいかげんで！　何度言っても直りゃしねえ！", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "あんなので、まともに学園生活やっていけてるのかねえ……。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「とにかく、残りの書類も手伝おう。その山もこちらによこしてくれ」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "PLAYVOICE", "001_090102030006" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ちょっと！　何なんですか、あなた！　いきなり現れて仕事を横取りするな\nんて！　これは、わたしの取り分ですよ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "014_010102030005" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「そうとは決まっていない。それは私が」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "002_010102030005" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「いいえ！　わたしがやります！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "014_010102030006" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「二人とも落ち着けって！　何をどうでもいいことで張り合ってんだよ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「二人とも、カツマを困らせないでやってくれ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_090102030007" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「って、何ですか、その妙な余裕は！　いきなり異世界からあらわれて、もう\nカツマさんの――その……パートナー気取りということですか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "014_010102030007" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんだよパートナーって！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「パパパパパパパパートナー！？　それはまさか配偶者的な意味で！？　カカ\nカカカカカカツマに私以外の……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "002_010102030006" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「わーっ！　カグヤ落ち着け！　落ち着いてくれ！　わかった！　わかったか\nらもういい！　書類は全部俺が片付ける！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「え！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "014_010102030008" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「カツマがそれでいいのなら、そうしてもらおう。しかし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_090102030008" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「大丈夫なの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "002_010102030007" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「大丈夫だ！　よく考えてみりゃ、秘書に手伝ってもらえばよかったんだ！　\nそのための秘書じゃねえか！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "そうだよ！　なんで最初からそこに気づかねえんだよ、俺は！", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "正直、秘書をつけるより給料上げてもらいたいとか思ってたけど、こういうと\nきは大助かりじゃねえか秘書！　いや、秘書さん！　秘書様！", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「秘書！　おーい！　秘書！　頼みたいことが……あれ？　秘書は？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「先ほど、忙しそうに部屋を出ていきましたが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "009_010102030008" ]},
		{"command":[ "SETCHARA", "0", "char_00000901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんでやねん！　あの子、俺付きの秘書じゃねえのかよ！　なんでフラフラ\n勝手に出て行っちゃうのよ！？　困るよ秘書！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "このままじゃ、また三人の争いが再燃して――", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
        {"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETNAME", "秘書" ]},
		{"command":[ "SETTEXT", "「隊長。お呼びですか」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああっ！　よかった戻ってきた！　いや、ちっともよくねえ！　困るぜ、出\nかけるときは声をかけてくれないとさぁ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "秘書" ]},
		{"command":[ "SETTEXT", "「隊長のご指示で、長官のところへ行っていたのですが」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……は？　俺の？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "秘書" ]},
		{"command":[ "SETTEXT", "「はい。先ほどの緊急呼び出しの際、手が離せないから代わりに聞いてきてく\nれと」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「え？　あ。あー……あー……ああ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「そういえば言っていましたな。書類の山と格闘しながら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "009_010102030009" ]},
		{"command":[ "SETCHARA", "0", "char_00000901_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
        {"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うん……言った。書類に追われて、半ば無意識に。うん……そうだった。す\nまん、悪かった」", "NORMAL" ]},
        {"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "秘書" ]},
		{"command":[ "SETTEXT", "「いえ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「それで？　長官はなんだって？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "秘書" ]},
		{"command":[ "SETTEXT", "「市街地をパトロール中の部隊が敵襲を受け、救援要請が出ている、とのこと\nです」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「襲来者か！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_090102030009" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "秘書" ]},
		{"command":[ "SETTEXT", "「襲来者の小部隊と交戦中に、未知の第三勢力からも奇襲を受けたと――」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「未知の第三勢力？　何者だ、そりゃ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "秘書" ]},
		{"command":[ "SETTEXT", "「正体は不明ですが、確認できたのは人間型が四体。かなりの戦闘力を有して\nいるそうです。インクレディブル・スクワッドに出動命令が出ました」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうか、わかった！　すぐ行く！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "何者かは知らねえが、ここで女の争いに巻き込まれてるよりは、現場に出たほう\nがずっとましだ！", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「了解した。まりあ！　他のメンバーに緊急呼集を！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "PLAYVOICE", "001_090102030010" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「もちろんかけますよ！　かけますけど！　なんであなた、カツマさんの副官\n気取りなんですか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "014_010102030009" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ななななななな納得いかない……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "002_010102030008" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああっ！　もう！　とにかく全員出動だ！　出動！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
        {"command":[ "WAITMOVE" ]},		
        {"command":[ "DISPIMAGE", "0", "FALSE" ] },
        {"command":[ "FADEOUT", "NORMAL" ]},
        {"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "………………", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "…………", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "……", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
        {"command":[ "SETIMAGE", "0", "bg_0027" ]},
        {"command":[ "DISPIMAGE", "0", "true" ] },
        {"command":[ "FADEOUT", "NORMAL" ]},
        {"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SETTEXT", "現場に急行した俺たちはすぐに第三勢力とやらを見つける事ができた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「いたよ！　あそこだ！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "PLAYVOICE", "003_010102030001" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「おー！　ホントに派手にやってやがるぜ！　おーっし！　私らもいっちょ暴\nれるとすっかぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "004_010102030001" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「戦闘のさなかにいきなり暴れこんでどうするのですか。これだから単細胞は\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "005_010102030001" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「そうだ。まずは戦況を見極めることが先決だ。どう攻めるかはその上で決め\nよう。それでいいな？　カツマ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_090102030011" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お、おう……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「だから！　なんであなたが副官気取りなんですか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "014_010102030010" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「………………どう考えても納得いかない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "002_010102030009" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「まったくだ！　新参者のくせに部隊を仕切るな！　だいたい、なぜ下僕に決\nめさせる！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010102030001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「Ａルナテミスの件はともかく、いいかげん俺が指示を出すのに慣れてくださ\nいって！　いちおう、俺が隊長ですから！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ぐぬぬぬぬぬぬ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010102030002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「な～んか、めんどくさいことになってるわね～。ダイヤナちゃん、知～らな\nいっと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "006_010102030001" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「あの、隊長さん？　あのビルを回り込めば、襲来者を前面の味方と挟み撃ち\nできるんじゃない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "012_010102030001" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「そうだな。幸いにも敵はまだこちらを察知していない。今なら奇襲効果も見\n込める。カツマ、どうだろうか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_090102030012" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「よ、よし！　わかった、その作戦で行こう！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "いつまでもギスギスした人間関係と重い空気に耐えるよりは、戦闘に突入しち\nまったほうが楽だ！　そうしよう！", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「よし！　インクレディブル・スクワッド前進！　襲来者を背面より攻撃する！　\nカツマは、私の後ろにいてくれ」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "PLAYVOICE", "001_090102030013" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「だから！　なぜお前が仕切るんだーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010102030003" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}