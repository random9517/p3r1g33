        {"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「おっしゃー！！　勝負あり、ですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "101_010021010021" ]},
		{"command":[ "SETCHARA", "2", "char_00010101_01", "0", "CENTER", "0" ]},
		{"command":[ "SETCHARA", "0", "char_00010201_01", "0", "LEFTEND", "0" ]},
		{"command":[ "SETCHARA", "1", "char_00010301_01", "0", "RIGHTEND", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "DISPCHARA", "2", "TRUE" ]},
        {"command":[ "SPOTCHARA", "2" ] },
        {"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「ふっふっふ♪　これで成績アップ……これは美味しい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "102_010021010019" ]},
		{"command":[ "SETCHARA", "0", "char_00010201_01", "2", "LEFTEND", "0" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「うん、せこせこ勉強するよりはずーっと楽かも」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "103_010021010018" ]},
		{"command":[ "SETCHARA", "1", "char_00010301_01", "6", "RIGHTEND", "0" ]},
		{"command":[ "SPOTCHARA", "1" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "女怪人" ]},
		{"command":[ "SETTEXT", "「ウソ、だ……なぜ……ぐはっ……！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "DISPCHARA", "2", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "三姉妹の連続攻撃を受け、倒れこむ女怪人。勝負は一方的な結果となった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "むしろ勝負というより、狩りと言った方が正しいかもしれない。それほど三姉 \n妹の力は女怪人を圧倒していた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「それにしても……なーんかあっけなかったねー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "102_010021010020" ]},
		{"command":[ "SETCHARA", "2", "char_00010101_01", "0", "CENTER", "0" ]},
		{"command":[ "SETCHARA", "0", "char_00010201_01", "0", "LEFTEND", "0" ]},
		{"command":[ "SETCHARA", "1", "char_00010301_01", "0", "RIGHTEND", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "DISPCHARA", "2", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「ボクたちが強すぎただけなんじゃない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "103_910021010018" ]},
		{"command":[ "SPOTCHARA", "1" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「とにかく、さっさと済ませましょ。さっ、悪党！　盗ったもの、返すです \n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "101_010021010022" ]},
		{"command":[ "SPOTCHARA", "2" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "三人は倒れている女怪人に近づいていく。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "DISPCHARA", "2", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "女怪人" ]},
		{"command":[ "SETTEXT", "「ぐぅ……お、おのれぇ…………」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「まだ動けるですか？　古人いわく『ブスッと情け』。トドメを刺すのも、ま \nた優しさですからね……では覚悟──」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "101_010021010023" ]},
		{"command":[ "SETCHARA", "2", "char_00010101_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "2", "TRUE" ]},
		{"command":[ "SPOTCHARA", "2" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「お姉ちゃん、ちょーっと待ってくんない？そうやって最後の美味しいところ\n持っていくの、悪いクセよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "102_010021010022" ]},
		{"command":[ "SETCHARA", "0", "char_00010201_01", "0", "LEFTEND", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「そうそう。実質やっつけたのボクだし。ボクがトドメさしていい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "103_010021010019" ]},
		{"command":[ "SETCHARA", "1", "char_00010301_01", "0", "RIGHTEND", "0" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "SPOTCHARA", "1" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ちょっと待ってよ。別に誰がトドメさしてもよくない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "101_010021010024" ]},
		{"command":[ "SETCHARA", "2", "char_00010101_01", "3", "CENTER", "0" ]},
		{"command":[ "SPOTCHARA", "2" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「なら、あたしでもいいってことよね？　はい！　じゃ、トドメの権利、いた \nだきまーす！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "102_010021010023" ]},
		{"command":[ "SETCHARA", "0", "char_00010201_01", "6", "LEFTEND", "0" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「駄目駄目っ、ボクがやる。ボクにまかせておいて？　ね？　いいでしょ？　 \nお姉ちゃん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "103_010021010020" ]},
		{"command":[ "SETCHARA", "1", "char_00010301_01", "7", "RIGHTEND", "0" ]},
		{"command":[ "SPOTCHARA", "1" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ストップ。どうして二人共、そんなにグイグイくるの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "101_010021010025" ]},
		{"command":[ "SETCHARA", "2", "char_00010101_01", "7", "CENTER", "0" ]},
		{"command":[ "SPOTCHARA", "2" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「……だってさぁ、ほら、ボーナスとかありそうじゃない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "103_010021010021" ]},
		{"command":[ "SETCHARA", "1", "char_00010301_01", "6", "RIGHTEND", "0" ]},
		{"command":[ "SPOTCHARA", "1" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「効率よくキルスコア稼ぎたいじゃん？　というわけで、ここはあたしに任せ \nて──」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "102_010021010024" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「二人共、そんなこと考えてたの？　お亥さまは、そんなこと言ってなかった \nじゃない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "101_010021010026" ]},
		{"command":[ "SETCHARA", "2", "char_00010101_01", "3", "CENTER", "0" ]},
		{"command":[ "SPOTCHARA", "2" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「そりゃ言わないでしょー。揉めること確定だもん。むしろ言わなかったこと \nで、あたし、確信しちゃったし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "102_010021010025" ]},
		{"command":[ "SETCHARA", "0", "char_00010201_01", "0", "LEFTEND", "0" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「そーいうこと……ということで、血なまぐさいことは、ボクに任せてよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "103_010021010022" ]},
		{"command":[ "SPOTCHARA", "1" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ああ、もうっ、なら私がやるです！　ほら、二人共下がって！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "101_010021010027" ]},
		{"command":[ "SETCHARA", "2", "char_00010101_01", "7", "CENTER", "0" ]},
		{"command":[ "SPOTCHARA", "2" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "女怪人を目の前にして、誰がトドメをさすか揉める三姉妹。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "DISPCHARA", "2", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "女怪人" ]},
		{"command":[ "SETTEXT", "「……はぁ、はぁ……よくわからんが……チャンスだ……」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "その隙に女怪人は足を引きずりながら、こっそりと三人から離れていく。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「古人曰く『年功序列』。ほら、『序』って言う字が入ってる！　だから私に \n任せるですっ」」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "101_010021010028" ]},
		{"command":[ "SETCHARA", "2", "char_00010101_01", "0", "CENTER", "0" ]},
		{"command":[ "SETCHARA", "0", "char_00010201_01", "0", "LEFTEND", "0" ]},
		{"command":[ "SETCHARA", "1", "char_00010301_01", "1", "RIGHTEND", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "DISPCHARA", "2", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SPOTCHARA", "2" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「どーいう理屈？　こーいうのは年下に譲るもんでしょ！　古人曰く『破天荒 \n』！　誰もあたしを止める権利はないの！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "102_010021010026" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「…………ねえ、なんかいなくなってない？　さっきの悪い人」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "103_010021010023" ]},
		{"command":[ "SETCHARA", "1", "char_00010301_01", "0", "RIGHTEND", "0" ]},
		{"command":[ "SPOTCHARA", "1" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「なっ！？　あ、あたしを出し抜くなんて、なかなかやるじゃない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "102_010021010027" ]},
		{"command":[ "SETCHARA", "0", "char_00010201_01", "3", "LEFTEND", "0" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "女怪人" ]},
		{"command":[ "SETTEXT", "「お前らがアホなだけだ！　そこで勝手にことわざ合戦でもしてろ！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "DISPCHARA", "2", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「あっ！　こらー！　逃げるなー！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "103_010021010024" ]},
		{"command":[ "SETCHARA", "1", "char_00010301_01", "7", "RIGHTEND", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "DISPCHARA", "2", "TRUE" ]},
		{"command":[ "SPOTCHARA", "1" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「とにかく後を追わなきゃ！　言い争いしてる場合じゃないでしょ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "101_010021010029" ]},
		{"command":[ "SPOTCHARA", "2" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「えー……序姉さんがソレ言う……？　まいいや、逃がすわけにはいかないも \nんねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "103_010021010025" ]},
		{"command":[ "SETCHARA", "1", "char_00010301_01", "0", "RIGHTEND", "0" ]},
		{"command":[ "SPOTCHARA", "1" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "傷ついたわりには女怪人の足はなかなか見事なもので、いつの間にかかなりの \n距離を移動していた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "DISPCHARA", "2", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "逃げていく女怪人を、三姉妹は慌てて後を追っかけていく。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "女怪人" ]},
		{"command":[ "SETTEXT", "「くそっ……なんだあの連中は……ともかく早く逃げないと……」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「どりゃぁぁぁぁ！！！　はぁ……はぁ…………お、お、追いついたぁ……！ \n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "101_010021010030" ]},
		{"command":[ "SETCHARA", "2", "char_00010101_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "2", "TRUE" ]},
		{"command":[ "SPOTCHARA", "2" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "女怪人" ]},
		{"command":[ "SETTEXT", "「なっ、速ッ……」", "NORMAL" ]},
		{"command":[ "SPOTCHARA", "1" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ふぅ、ふぅ……ナメるなです。私はクラスにどこにでもいる『成績ダメダメ \nの体力自慢』タイプの女子……はふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "101_010021010031" ]},
		{"command":[ "SETCHARA", "2", "char_00010101_01", "2", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "2", "TRUE" ]},
		{"command":[ "SPOTCHARA", "2" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「ふっふっふ、くしくもあたしも姉さんと同じタイプ……さあ、観念なさい！ \n　はぁ……ふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "102_010021010028" ]},
		{"command":[ "SETCHARA", "0", "char_00010201_01", "2", "LEFTEND", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「……ふう、疲れたー……あー、もう駄目ぇ……ボク、誰がトドメを刺すのか \n、なんだかどうでもよくなって来ちゃったぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "103_010021010026" ]},
		{"command":[ "SETCHARA", "1", "char_00010301_01", "4", "RIGHTEND", "0" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "SPOTCHARA", "1" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "女怪人" ]},
		{"command":[ "SETTEXT", "「……息があがってるようだな。これは形勢逆転のチャンス…………」", "NORMAL" ]},
		{"command":[ "SPOTCHARA", "3" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「……あれ？　やる気みたいだよ。ああ、もう……面倒くさい……とっととや \nられてくれればいいのにぃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "103_010021010027" ]},
		{"command":[ "SETCHARA", "1", "char_00010301_01", "2", "RIGHTEND", "0" ]},
		{"command":[ "SPOTCHARA", "1" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「まったくね。あたし達の成績アップのためにも、今度こそしっかりトドメを \n刺しましょ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "102_010021010029" ]},
		{"command":[ "SETCHARA", "0", "char_00010201_01", "0", "LEFTEND", "0" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "女怪人" ]},
		{"command":[ "SETTEXT", "「成績アップ……？　一体何を言ってるんだ？」", "NORMAL" ]},
		{"command":[ "SPOTCHARA", "3" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「あ、それはこっちの話。あなたは、黙ってやられてくれれば、それでいいで \nすよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "101_010021010032" ]},
		{"command":[ "SETCHARA", "2", "char_00010101_01", "0", "CENTER", "0" ]},
		{"command":[ "SPOTCHARA", "2" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "女怪人" ]},
		{"command":[ "SETTEXT", "「ぐぅ……どこまでも舐め腐りおって……！　いいだろう、次こそはお前たち \n全員ぶっ倒してやる！」", "NORMAL" ]},
		{"command":[ "SPOTCHARA", "3" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「……あれー？　この期に及んで逆らうわけー？　そーいうの、良くないな～ \n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "102_010021010030" ]},
		{"command":[ "SETCHARA", "0", "char_00010201_01", "0", "LEFTEND", "0" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「ねえ、諦めなよ。無抵抗ならこれ以上怪我せずにすむよぉ？　でも……逆ら \nうなら、まあ……普通にぶっ殺すけどね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "103_010021010028" ]},
		{"command":[ "SETCHARA", "1", "char_00010301_01", "0", "RIGHTEND", "0" ]},
		{"command":[ "SPOTCHARA", "1" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "女怪人" ]},
		{"command":[ "SETTEXT", "「黙れ、ガキども！！」", "NORMAL" ]},
		{"command":[ "SPOTCHARA", "3" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "挑発的な言葉に反応して、女怪人が素早い蹴りを繰り出してきた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
