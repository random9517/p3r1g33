{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0025" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "襲来者" ]},
		{"command":[ "SETTEXT", "「ウギーーーーー……！？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「お掃除完了～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_010021530021" ]},
		{"command":[ "SETCHARA", "0", "char_00009902_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「うーん……さっきから見張りばっかりで、肝心の本拠地が見つからないね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021530020" ]},
		{"command":[ "SETCHARA", "0", "char_00009802_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「でもこれだけ見張りが居るってことは、入り口が近くにあるってことだろ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_010021530023" ]},
		{"command":[ "SETCHARA", "0", "char_00009702_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「そうだな。複雑な構造をした洞窟だが、本拠地に近づいておるのは間違いな\nいだろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010021530020" ]},
		{"command":[ "SETCHARA", "0", "char_00010002_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「それにしても、ホク姉遅いね。どこまで偵察に行ってるのかな～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_010021530022" ]},
		{"command":[ "SETCHARA", "0", "char_00009902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「特に声も聞こえてこないし、無事だとは思うが……ん？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010021530021" ]},
		{"command":[ "SETCHARA", "0", "char_00010002_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「みんな、お待たせ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010021530026" ]},
		{"command":[ "SETCHARA", "0", "char_00009602_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「遅いよホク姉。心配したじゃない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021530021" ]},
		{"command":[ "SETCHARA", "0", "char_00009802_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「ごめん、ごめん。でも、ちゃんと収穫はあったわよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010021530027" ]},
		{"command":[ "SETCHARA", "0", "char_00009602_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「収穫？　もしかして、敵の本拠地でも見つけたの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021530022" ]},
		{"command":[ "SETCHARA", "0", "char_00009802_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「本拠地かどうかはわからないけど、変な建物の入り口を見つけたの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010021530028" ]},
		{"command":[ "SETCHARA", "0", "char_00009602_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「おお！　よくやったぞ、ホクサイ！　すぐに案内してくれ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010021530022" ]},
		{"command":[ "SETCHARA", "0", "char_00010002_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「うん！　こっちだよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010021530029" ]},
		{"command":[ "SETCHARA", "0", "char_00009602_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "bg_0136" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「ほらあれ。あの奥に見えるのが、入り口だと思うんですけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010021530030" ]},
		{"command":[ "SETCHARA", "0", "char_00009602_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「ふむ……洞窟の岩に偽装しているようだが、間違いなく入り口だろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010021530023" ]},
		{"command":[ "SETCHARA", "0", "char_00010002_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「だが見張りの数が多いな。ここは用心のために一度地上に戻って、準備を整\nえるとしよう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010021530024" ]},
		{"command":[ "SETCHARA", "0", "char_00010002_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「そうですね。みんな、一旦引き返して……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010021530031" ]},
		{"command":[ "SETCHARA", "0", "char_00009602_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「おいおい。なに弱気なこと言ってんだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_010021530024" ]},
		{"command":[ "SETCHARA", "0", "char_00009702_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「せっかく敵の本拠地を見つけたんだ。今ここでブッ叩いて、壊滅させりゃい\nいだけの話だろ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_010021530025" ]},
		{"command":[ "SETCHARA", "0", "char_00009702_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「そうだよ！　それに早く終われば、それだけ遊ぶ時間も増えるしね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021530023" ]},
		{"command":[ "SETCHARA", "0", "char_00009802_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「あーしもウタ姉の意見に賛成～。早く終わらせて、みんなで遊ぼ～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_010021530023" ]},
		{"command":[ "SETCHARA", "0", "char_00009902_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「えっ、ちょ、ちょっと……！？　みんな、なに言ってるの……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010021530032" ]},
		{"command":[ "SETCHARA", "0", "char_00009602_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「内部にどれだけ敵が居るのかわからないまま突入するのは危険だ！　少しは\n冷静になれ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010021530025" ]},
		{"command":[ "SETCHARA", "0", "char_00010002_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「そんなの、倒していけば分かるだろ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_010021530026" ]},
		{"command":[ "SETCHARA", "0", "char_00009702_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「おい！　待てと言って……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010021530026" ]},
		{"command":[ "SETCHARA", "0", "char_00010002_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ゲン！　シャラ！　行くぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_010021530027" ]},
		{"command":[ "SETCHARA", "0", "char_00009702_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "二人" ]},
		{"command":[ "SETTEXT", "「ラビットパワー！　イェーーーイ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021530024" ]},
		{"command":[ "SETCHARA", "0", "char_00009802_01", "8", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "1", "char_00009902_01", "8", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「み、みんな！　お願いだから戻ってきて～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010021530033" ]},
		{"command":[ "SETCHARA", "0", "char_00009602_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「くっ……！　こうなったら仕方ない！　ホクサイ、私たちも行くぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010021530027" ]},
		{"command":[ "SETCHARA", "0", "char_00010002_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「は、はい！　わかりました！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010021530034" ]},
		{"command":[ "SETCHARA", "0", "char_00009602_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}