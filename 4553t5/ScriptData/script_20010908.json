		{"command":[ "PLAYBGM", "BGM_007" ]},
		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「うぉおおおおっっ！　ブリキ１ッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_010021230001" ]},
		{"command":[ "SETCHARA", "0", "char_00011601_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「クラッド！　アンタも一生板金屋生活にしてやるからな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_010021230002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「できるものならやってみな！」", "NORMAL" ]},
