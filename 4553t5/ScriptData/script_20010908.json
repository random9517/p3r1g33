		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "オペレーター" ]},
		{"command":[ "SETTEXT", "「アンコクーカンからなにやら反応があります！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「反応？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010021230001" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「どうやら、私が渡した道具が役に立っているようですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_010021230001" ]},
		{"command":[ "SETCHARA", "0", "char_00011901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「あの反応のある場所に隊長さんがいるでしょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_010021230002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「そうなんだ。じゃあ、早く行かないと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010021230002" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「ですが、アンコクーカンに入るにはアマルガメイトの力が必要なんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_010021230003" ]},
		{"command":[ "SETCHARA", "0", "char_00011901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「そうなんだ。どうすればいいの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010021230003" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「葉金と一緒なら……って、あら？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_010021230004" ]},
		{"command":[ "SETCHARA", "0", "char_00011901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「あれ？　葉金ちゃんは！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010021230004" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0027" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SETTEXT", "一方、市街地", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "アンコクーカンの中で、変身できない状態で鈴は戦っていた。", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00011401_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「やはり人間の体では弱いな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_010021230001" ]},
		{"command":[ "SETCHARA", "0", "char_00012001_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「うるせぇ！　お前だってその人間相手に手こずってるじゃねーか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_010021230001" ]},
		{"command":[ "SETCHARA", "0", "char_00011401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「ふふ、この程度が本気だと？　笑わせるなっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_010021230002" ]},
		{"command":[ "SETCHARA", "0", "char_00012001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "クラッドの一撃が鈴の腹部を撃ち抜く。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETCHARA", "0", "char_00011401_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「んぐ……っ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_010021230002" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "鈴は吹き飛ばされ、アスファルトに転がる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「息の根を止めない程度に抑えたつもりだ。まだ立ち上がれるか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_010021230003" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00012001_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「へ……へへ……当然だろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_010021230003" ]},
		{"command":[ "SETCHARA", "0", "char_00011401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "よろよろと鈴は立ち上がる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「何故こうも我々に刃向かう。まったく理解できないな。非力な人間の分際で\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_010021230004" ]},
		{"command":[ "SETCHARA", "0", "char_00012001_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「理解、か……。お前たちに理解ができるのか？　アタシが、どうして街を守\nるのか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_010021230004" ]},
		{"command":[ "SETCHARA", "0", "char_00011401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「絶対に壊させない……。アタシの居る限り、みんなの日常を、生活を、壊さ\nせはしない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_010021230005" ]},
		{"command":[ "SETCHARA", "0", "char_00011401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "鈴が再びクラッドに向かっていく。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「……弱い」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_010021230005" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00012001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "しかし、今の鈴ではクラッドにダメージを与えることすらできなかった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "クラッドは回避すらせず、鈴の拳を受け止め、投げ飛ばす。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},

		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「ぐあぁあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_010021230006" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00011401_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「分断して正解だった。相方がいなければなにもできないのだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_010021230006" ]},
		{"command":[ "SETCHARA", "0", "char_00012001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「う……うるせぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_010021230007" ]},
		{"command":[ "SETCHARA", "0", "char_00011401_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「そろそろ、終わりだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_010021230007" ]},
		{"command":[ "SETCHARA", "0", "char_00012001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "仰向けに転がる鈴に、クラッドがとどめの一撃を振り下ろそうとした。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「なんだ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_010021230008" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00012001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "一発の銃弾がクラッドの足下をかすめる。クラッドは鈴から離れて、銃声のし\nた方を見る。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_010021230001" ]},
		{"command":[ "SETCHARA", "0", "char_00011501_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「葉金！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_010021230008" ]},
		{"command":[ "SETCHARA", "0", "char_00011401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「まったく。変身できないのに幹部と戦うなんて、無茶を通り越して無謀です\nわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_010021230002" ]},
		{"command":[ "SETCHARA", "0", "char_00011501_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "鈴に駆け寄る葉金。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETCHARA", "0", "char_00011401_01", "3", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "1", "char_00011501_01", "6", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おいおい、あれ、備品の武器じゃねーか。本部から勝手に持ってきたのか？\n　ていうか、なんで使えるんだよ！？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "この空間の中では、一般的な武器はさび付いて使い物にならなくなるはずだっ\nた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「おそらく、葉金さまがアマルガメイト、つまり石凝姥命さまの加護をうけて\nいるからでしょうな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021230001" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そんなのアリかよ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「まったく、貴女がいなくなったら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_010021230003" ]},
		{"command":[ "SETCHARA", "0", "char_00011401_01", "6", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "1", "char_00011501_01", "6", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「変身できなくなる……だろ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_010021230009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「それだけではありません！　貴女はわたくしの、とても大切な友人です！　\nアマルガメイトだろうとなかろうと関係ありません！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_010021230004" ]},
		{"command":[ "SETCHARA", "1", "char_00011501_01", "7", "CENTER", "400" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「葉金……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_010021230010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「いやぁ、青春ですな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021230002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、やってる場合か？　というか、あいつも手を出さないのか？　こんな\nに隙だらけなのに」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「今は大事なお話中ですぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021230003" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「今さら二人揃ったところで遅い。それがお前たちの最後の会話だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_010021230009" ]},
		{"command":[ "SETCHARA", "0", "char_00012001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「最後……？　バカ言ってんじゃねーよ。アタシはまだまだ、葉金と一緒に居\nたいんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_010021230011" ]},
		{"command":[ "SETCHARA", "0", "char_00011401_01", "7", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "1", "char_00011501_01", "7", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「もっともっと話して、ケンカして、でも仲直りして……ずっと、ずっとな…\n…！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_010021230012" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「鈴！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_010021230005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "葉金の手を取り、立ち上がる鈴。いつも以上にふたりの手は硬く繋がれた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETCHARA", "0", "char_00011401_01", "7", "CENTER", "-200" ]},
		{"command":[ "SETCHARA", "1", "char_00011501_01", "7", "CENTER", "200" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「葉金……アタシにやらせてくれ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_010021230013" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「……ええ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_010021230006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「真空蒸着！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_010021230007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「アマルガメーション！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_010021230014" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
