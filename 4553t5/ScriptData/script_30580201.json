{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「またかい？　あんたも好きだねぇ……なに？　パワーアップのため？　ああ\n、そういえばそんなこと言ってたね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0203101" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00005802_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「あれこれ言い訳しなくていいって、結局あたしとヤリたいんだろう？　いい\nよ、付き合ってあげるよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0203102" ]},
		{"command":[ "SETCHARA", "0", "char_00005802_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「ほら、お望み通りあたしの乳で扱いてやるよ……んっ……水着だからね、こ\nのまま挟んでやるから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0203103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「どうだい、気持ちいいかい？　まあ、これだけ大きくなってりゃ……ンっ、\n答えはわかるけどね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0203104" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00005802_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「たっぷり奉仕してやるよ……だから、あんたもいっぱい感じておくれ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0203105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「ふぅ、んっ……こんなことが……訓練だなんて……まったくひどい話だよ…\n…でも、あたしは……嫌じゃないけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0203106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「役得ってやつだろ？　あんたも遠慮せず感じていいんだよ……むしろ感じて\nくれないとあたしが困る」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0203107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「もっと強く？　……こんな感じかい？　もっと？　注文が多いね……ほら、\nどうだい……んっ、んふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0203108" ]},
		{"command":[ "SETIMAGE", "0", "still_00005802_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「これでいいんだろう？　あんたのこれ……硬くて、熱くなってるよ……自分\nでわかってるかい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0203109" ]},
		{"command":[ "SETIMAGE", "0", "still_00005802_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「そうだろ、気持ちいいだろうねぇ……あたしが、これだけ……してあげてる\nんだからね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0203110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「ふぅ……パワーアップするのも楽じゃないね……はぁ、あはぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0203111" ]},
		{"command":[ "SETIMAGE", "0", "still_00005802_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「ジッとしててくれないと……上手くできないじゃないか……気持ちよすぎて\n勝手に動くのかい？　じゃあ、仕方ないね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0203112" ]},
		{"command":[ "SETIMAGE", "0", "still_00005802_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「出そうなら……いつでも出して、いいんだからね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0203113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「んっ、ふぅうっ……ったく、だらしない顔しちゃって……そんな顔されたら\n、あたしもドキドキしちゃうよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0203114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「ほら、先っぽから透明な汁がいっぱい……早く出しちまいなよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0203115" ]},
		{"command":[ "SETIMAGE", "0", "still_00005802_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「そのためにはもっと乳を揺らせ？　わかったわかった……あんたの言うよう\nにするから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0203116" ]},
		{"command":[ "SETIMAGE", "0", "still_00005802_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「ンっ、ふうっ……これで、いいかい……？　はっ……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0203117" ]},
		{"command":[ "SETIMAGE", "0", "still_00005802_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「エロい声……じゃないよ……べつにこれは、感じてるとかじゃないからね…\n…胸を揺らし続けるのは大変なんだからさ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0203118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「余計なことは気にしなくていいから……さっさと出しちまいなって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0203119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁっ……それにしても本当に熱いね……あんたのこれ……胸がヤケ\nドしちゃいそうだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0203120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「それだけ興奮してる証拠？　そうだね、嬉しいよ……そのためにやってるん\nだからさ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0203121" ]},
		{"command":[ "SETIMAGE", "0", "still_00005802_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「上手い？　他人がどうかなんて知らないけど……あんたが喜んでくれるなら\n、それでいいんだけどさ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0203122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「んっ、また大きくなった……しかも胸の中でビクビク震えてるよ……もうす\nぐかい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0203123" ]},
		{"command":[ "SETIMAGE", "0", "still_00005802_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「はっ……んんっ……だろうね、限界が近づいてんだね。すぐわかったよ……\nこんだけ先走り汁も出てるしね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0203124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「あぁ……胸がベトベトだよ……でもまあ、おかげで滑りがよくなってるんだ\nけどね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0203125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「ほら、自分の我慢汁を塗りつけられる気分はどうだい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0203126" ]},
		{"command":[ "SETIMAGE", "0", "still_00005802_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「ふぅうっ……はっ、はあっ……んっ、滑って……しっかり胸を押さえてない\nと、上手く扱けないね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0203127" ]},
		{"command":[ "SETIMAGE", "0", "still_00005802_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「んんっ！　わかったよ、気持ちいいんだろう？　ちゃんと……んっ……擦っ\nててあげるから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0203128" ]},
		{"command":[ "SETIMAGE", "0", "still_00005802_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「はぁ……は、はやく……我慢しなくていいから……ほら、ほらぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0203129" ]},
		{"command":[ "SETIMAGE", "0", "still_00005802_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「あっ、んんぅぅっ！　あぁ、すごい……胸の中で……出てる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0203130" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00005802_01_05" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「なんだい、この匂いは……イカ臭くて、堪んないね……はぁ……あぁ……頭\nがクラクラしてくるよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0203131" ]},
		{"command":[ "SETIMAGE", "0", "still_00005802_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「あぁ……そう、いいよ……全部出していいから……あたしの胸の中に好きな\nだけ、ぶちまけておくれ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0203132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「んっ、んんっ……ま、まだ出てる……あぁ、熱い……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0203133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「だらしない顔しちゃって……気持ちよさそうだねぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0203134" ]},
		{"command":[ "SETIMAGE", "0", "still_00005802_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「ふぅ……たっぷり出したね……これで全部かい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0203135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「あーあー、もう胸が大変なことになってるよ。ほら、自分で見てみな……精\n液でドロドロ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0203136" ]},
		{"command":[ "SETIMAGE", "0", "still_00005802_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「すごい量だね、これ……それだけ気持ちよかったってことだろうし、いいん\nだけどね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0203137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「なあ、ところで……あんたのそれ……なんでまだ大きくなったままなんだい\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0203138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「一回出したくらいじゃ足りない？　そ、そうかい……確実にパワーアップす\nるためには仕方ないね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0203139" ]},
		{"command":[ "SETIMAGE", "0", "still_00005802_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「いいよ、とことん付き合ってあげるから……好きなだけ出しな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0203140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「んっ、くっうぅ……今、出したばっかりなのに……相変わらず無節操だね…\n…でも、男らしい……とも言えるしね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0203201" ]},
		{"command":[ "SETIMAGE", "0", "still_00005802_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「ふぅ……んっはぁ……熱い……こんなに熱くなって、どんな感じなんだい…\n…？　ちゃんと感じてるかい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0203202" ]},
		{"command":[ "SETIMAGE", "0", "still_00005802_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「ああ、気持ちいいなら……それでいいよ……ふぅっ……こうやって、ご奉仕\nしてるかいがあるってもんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0203203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「なんだい……急にお礼なんて言って……照れくさいじゃないか……いいんだ\nよ、なんだかんだあたしも……楽しんでるから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0203204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「ほら、余計なこと考えなくていいから……こっちに集中しなよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0203205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「はぁっ……はぁはぁ……んっ、あぁ……あんたが出したザーメンで……ぐち\nゃぐちゃになってるよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0203206" ]},
		{"command":[ "SETIMAGE", "0", "still_00005802_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「……聞こえるだろ？　やらしい音が鳴って……んっ……白く泡立ってきて…\n…あぁ、もう……卑猥すぎるよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0203207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「まったく……それなのにあんたは……こんなに勃起しちまって……この状況\nで興奮してるんだから、いい趣味してるよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0203208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「はぁ、あふぅっ……べつにあたしは嫌じゃないよ……パワーアップのために\n必要なんだろう、これ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0203209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「それにあんたの気持ちよさそうな顔、見てるの……あたしは好きだからね…\n…もっとその顔を見せておくれ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0203210" ]},
		{"command":[ "SETIMAGE", "0", "still_00005802_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「あぁ、わかってるよ。あんたのお願い通り、もっと強く胸を擦りつけてあげ\nるからさ……んんっ……はぁあっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0203211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「はっはぁっ……んはぁっ！　い、息が……荒くなってる？　仕方ないだろ…\n…こう見えて、結構大変なんだからね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0203212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「そうだよ……胸って、重いんだから……それをこうやってずっと揺らし続け\nてたら……こうなっちゃうよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0203213" ]},
		{"command":[ "SETIMAGE", "0", "still_00005802_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「だけど、あんたが喜んでくれるから……こうやって、一生懸命ご奉仕してる\nわけ、だよ……はぁっ、はぁっ……んっ、あぁはぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0203214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「ほら……水着まで着て……奉仕してるんだから……早く出しなって……もう\n出そうなんだろう？　さっきから腰震わせてさ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0203215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「バレてるに決まってるだろう？　これだけビクビクさせておいて……ほら、\nまた腰が動いてるよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0203216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「ンっ……出そうになってるんだろ？　さっきみたいに……思いっきり出しち\nまいなよ……んっ、はぁ、はぁぁあっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0203217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「あぁっ……また硬くなってる……くっ、うぅっ……トドメだよ……いっぱい\n胸で扱いてあげるから……んっ、んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0203218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「はっ、はんっ……は、早く……ザーメン……出して……くっ、ふうっ……あ\nぁ、あっあぁぁっ……んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0203219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「いいよ、あんたの好きなとこに出しな……胸の中でも……胸にかけてもいい\nからぁ……はぁっ、あっ、あふぅぅぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0203220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「んっ、くぅうぅぅぅっ！　はっ、あぁぁっ……んんぅぅぅぅ～～～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0203301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00005802_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「あぁっ……胸の中で、出てるっ……すごい震えて……あっ、くぅっ……さっ\nき出したばっかなのにっ……ンンっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0203302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「なんだこの量は……あぁぁっ……あ、熱いっ……んっ、んっ……脈打って…\n…ザーメンが……くぅっ……うぅうっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0203303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「き、気持ちよかったから……って、それにしても……多すぎるっ……あぁ、\n胸が……精液まみれになってるじゃないか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0203304" ]},
		{"command":[ "SETIMAGE", "0", "still_00005802_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「んっ、あぁ……べつに責めてるわけじゃないよ……だから安心しておくれ…\n…あんたは好きなだけ、射精してくれればいいんだよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0203305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「んふっ……そこは心配しなくてよかったね……思いっきり出してるみたいだ\nし……ふうっ……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0203306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「あぁ……すごい匂いだよ……肌に染み込んで取れなくなりそうだね、これは\n……ほら、わかるかい？　ここまで匂ってくるよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0203307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「それにしても……二回目だっていうのに……こんなに射精してくれるなんて\n……そんなに気持ちよかったのかい？　あたしの胸は」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0203308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「水着もエロいし、最高？　おおげさだね、まったく……でも、悪い気はしな\nいね。あんたに褒めてもらえて嬉しいよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0203309" ]},
		{"command":[ "SETIMAGE", "0", "still_00005802_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「ああ、いいよ。これからも奉仕してあげるよ。水着？　わかったわかった、\nあんたの好きな恰好してあげるから期待してな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0203310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「な、なにを……？　ちょっ……とっ……んあっ！？　あっ……あぁぁぁあぁ\nぁ～～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0203401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00005802_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「もうっ……胸にかけたいなら、先に言っておくれよ……びっくりするじゃな\nいか……んっ……くうっ……はぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0203402" ]},
		{"command":[ "SETIMAGE", "0", "still_00005802_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「あ、ああっ……謝らなくていいよ……あんたの好きなようにしていいから…\n…んっ……はぁぁっ……すごい出てるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0203403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「はぁっ……あ、熱い……なんだいこの熱さは……んっ、胸が……火照ってく\nるよ……あぁ、それにこの匂い……鼻にくるね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0203404" ]},
		{"command":[ "SETIMAGE", "0", "still_00005802_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁぁ……ほら、見てごらんよ……あたしの胸が……あんたのザーメ\nンまみれになってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0203405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「どうだい、好き放題に精液をぶっかける気分は……最高に興奮する？　それ\nはよかったよ……んっ……はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0203406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「これで全部かい？　好きなだけ出していいって言ったけど……すごい量だね\n……どれだけ溜めてたんだい？　水着もドロドロだよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0203407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「ふふっ……射精が終わったのに、まだピクピクしてるよ。あんたのそれ……\nなんだかこうして見ると可愛いねえ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0203408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「それで、満足してくれたかい？　それはよかった。ふふ、お礼なんていいよ\n。命令してくれれば、いつだって相手してやるさ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0203409" ]},
		{"command":[ "SETIMAGE", "0", "still_00005802_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「ああ。いつでも言ってくれ。たっぷり奉仕してやるから、楽しみにしてなよ\n」", "NORMAL" ]},
