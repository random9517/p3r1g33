		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ふふ……。まだまだ時間はたっぷりあるのだから、もっと母のマンコに甘え\nていいのだぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0104408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
