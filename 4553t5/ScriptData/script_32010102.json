		{"command":[ "PLAYVOICE", "v2_201_0104403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「いっぱい、びちゃびちゃ尻にっ、精液かけられてっ、はぁんっ！　母は、い\n、イッてしまってるっ、ああぁ、ぶっかけアクメ、してる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0104404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁっ、お前の精液の匂いが、漂ってくるぅ……。なんて男らしい\n匂いなんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0104405" ]},
		{"command":[ "SETIMAGE", "0", "still_00020101_02_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「んくっ、こんなの嗅いだら……子宮の疼きが、ますますひどくなってしまう\nではないか……はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0104406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「母はもっと、お前のチンポが欲しくてたまらなくなってしまうぞ……？　今\n度は、母からお前を襲ってしまうかもしれん……」", "NORMAL" ]},
