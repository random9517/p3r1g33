		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「いっ、イクッ、イキそうになってる……！　ラストスパートでマンコどちゅ\nどちゅって、されてぇ……っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0104219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「イクッ、イクッ、イクイクイク……ッ！　ああっ、ああっ、お前も、お前も\n一緒に……母と一緒にぃ、イッてぇえええぇぇぇっ！！」", "NORMAL" ]},
