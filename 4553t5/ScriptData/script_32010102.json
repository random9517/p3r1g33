		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「でてるっ、でてるぅうううぅぅぅっ！！　また、母のマンコにっ、息子の精\n液っ、アツアツのドロドロが、んぁっ、びゅくびゅく～ってぇええっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「んぁあっ、ああっ、イクッ、イクッ、マンコ、イッてる……っ！　ああっ、\n中出しされてっ、また、息子精液でアクメッ、きてっ、るぅっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0104303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁっ、中で暴れてっ、びくびくって、チンポ……んふぅっ！　気\n持ちいい……気持ちいいぞ……っ！」", "NORMAL" ]},
