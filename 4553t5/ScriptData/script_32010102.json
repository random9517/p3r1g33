{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00020101_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ふふ、今日はこっちの穴で相手をしてやろう。ほら、どうだ……？　母のマ\nンコが、よく見えるだろう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0104101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「どうした？　こんなふうにマンコを見たのは初めてか？　そんなことはない\nよな？　お前の活躍はすべて知っているからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「そのチンポで、たくさんの女を篭絡してきたのだろう？　母にも、お前のチ\nンポを味わわせてくれ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0104103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「なんだ？　もっと、いやらしくおねだりをしろと？　ふふ、仕方のないやつ\nだ。だが、そのほうが盛り上がるのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0104104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「こうやって、無防備なマンコを晒し……尻を、媚びるように振ってぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0104105" ]},
		{"command":[ "SETIMAGE", "0", "still_00020101_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「女王という身分でありながら、息子のチンポを、浅ましくおねだり……チン\nポ……チンポをハメてほしい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0104106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ほら……息子チンポほしくて、私のマンコはこんなによだれを垂らしている\nぞ……んふぅ……だから、挿れて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0104107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「このいやらしいオマンコにぃ……お前の、勃起チンポ……立派に育ったガチ\nガチのチンポを、ぶちこんでぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0104108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「んぁあっ！　あはぁあああぁぁぁんっ！！　そ、そんな一気にいぃっ！　\nチンポが、ぶちこまれて……んふぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0104109" ]},
		{"command":[ "SETIMAGE", "0", "still_00020101_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「すごく……感じるぞ……。硬くて、でかくて、太い……お前の、チンポ……\nんふぅ、あっ、ああ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0104110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ああっ、私の……母のマンコはどうだ……？　母のマンコも、気持ちいいか\n……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0104111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「そうだ……トロトロの、ぐちょぐちょになってぇ……お前のチンポに、ぎゅ\nうぎゅう絡んでるんだ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0104112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ああぁぁっ！　いいぞ、動いていいぞっ！　母のマンコの中で、思いっきり\nチンポ暴れさせていいからなっ！　ああぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0104113" ]},
		{"command":[ "SETIMAGE", "0", "still_00020101_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「すごいっ、こ、こすれてるっ！　チンポがっ、んはっ、私のマンコをいっぱ\nい、ずりずりって、んひぃっ、してる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0104114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「感じるっ、息子チンポがっ、ああっ、ああっ、立派なカリが、中をごりごり\nごりぃって、してっ、んんぅううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0104115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ああ、母は、感じているぞっ！　息子のチンポで、すごくっ、感じてしまっ\nてるぞっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0104116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「チンポで、奥まで突かれるたびにっ、全身がビリビリ、しびれてしまってる\n……！　ああっ、ああっ、いいぃぃっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0104117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「もっと、もっとだ……！　もっといっぱい、遠慮なく腰を振っていいぞ！　\n母のマンコを、奥の奥まで味わって……んひぃいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0104118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「届いてるっ、お前のチンポが、母の子宮にぃいいいぃぃぃっ！！　あっ、亀\n頭が、あたるっ！　子宮っ、突いてるぅっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0104119" ]},
		{"command":[ "SETIMAGE", "0", "still_00020101_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「んふぅっ、はぁっ、はぁっ、思いっきり腰を振っているなっ。母のマンコ、\n存分に味わっているなっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0104120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「もっと甘えていいぞ。母のマンコに、たくさん甘えていいからなっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0104121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「私も、マンコを締めて、お前のチンポをしっかり抱きしめて……んんぅっ、\nは、離さないから……っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ああぁぁっ！！　ますます激しいピストン！　子宮にごちゅんって、先っぽ\nぶつけてきてっ、んっ、ああぁっ、あはぁああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0104123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「いいぞっ、いいっ、いいっ、チンポ、チンポいいぃぃっ！！　息子チンポ、\nすっごく気持ちいいっ、マンコに馴染むぅっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0104124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「はぁっ、ああっ、愛液がとまらないなっ。さっきから、マンコがいやらしい\n音をたてて、悦んでしまっているっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「もっと動いてっ、母のことを感じさせろっ！　お前のチンポで、母のことを\nイかせてみろっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「んふぅっ！！　そうっ、そうっ、母はそこがいいぞっ！　一番奥より、ちょ\nっと手前辺りがっ、ああっ、ああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0104127" ]},
		{"command":[ "SETIMAGE", "0", "still_00020101_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「そこを何度も突いてっ、チンポで抉ってっ、んひぃいいっ！！　気持ちよく\nて、頭が真っ白になりそうだっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ああぁっ、お前もどんどん、腰の動きがはやくなっているようだなっ。んぁ\nっ、もう、お前もイキそうなのか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「母のマンコに、チンポをしごかれてっ、ンッ、ああっ、射精しそうになって\nいるのだな……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ふふっ、それなら遠慮する必要なあるまい。いいぞ、中出ししていいぞ。い\nつもほかの女にしているようにっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「母のマンコにも、お前の精液を注いでくれっ。とびっきり濃いのを頼む！　\n母も、お前の精液がほしくてたまらないのだぁっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0104132" ]},
		{"command":[ "SETIMAGE", "0", "still_00020101_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ああぁっ、チンポ震えてるっ！　射精っ、もう、射精しそうになっているの\nが伝わってくる……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「いいぞ、射精してっ、中にっ、母に中出しだっ！　んぁっ、ああっ、このま\nま、母を孕ませるように、中出しぃいいいぃぃぃっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「んぁああっ、あああぁぁぁっ！！　きたっ、きてるっ、息子チンポから精液\nびゅーびゅーでてるぅううぅぅっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0104135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00020101_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ああっ、凄いっ、熱いっ！　マンコ焼けるっ、マン襞焦げるぅっ！　あっ、\nああぁっ、あああぁぁぁんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0104136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「すごいっ、まだ、まだまだ射精してる……！　母の中で、びっくんびっくん\n脈打って、精液っ、たくさん……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0104137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁっ、子宮が、お前のチンポに吸いついて……んふぅ、精液を、\nごくごく飲んでる……あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「これほどまでに、濃いものを……。ああ、母にもたくさん射精してくれると\nは、母は、とっても嬉しいぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0104139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ふふ……。息子に中出しされて、イかされてしまった……。息子の成長に母\nは驚いているぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0104140" ]},
		{"command":[ "SETIMAGE", "0", "still_00020101_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ああ……それにしても、まだまだチンポは硬いままなのだな……。あれほど\n射精したというのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0104201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「お前はまだ、母のマンコに射精したりないということか……？　んふぅ、母\nもだ……もっと、お前の精液が欲しい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「中出しされて、母の子宮は火が点いたように熱くなっている……。もっと、\nお前の精液を欲しがっているのだぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「んぁあっ、そうだ、また腰を振って、母のマンコを突いて……ああっ、感じ\nるっ、息子チンポがっ、んひぃいいっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0104204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「イッたあとの敏感マンコを、容赦なく突くっ、じゅぼじゅぼって突きまくる\n動きぃっ！！　ああっ、母は、蕩けそうだぞぉっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0104205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「なんて男らしい腰遣いぃっ！　はぁっ、はぁっ、マンコが、めちゃくちゃに\nなるっ！　チンポに蹂躙されてるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0104206" ]},
		{"command":[ "SETIMAGE", "0", "still_00020101_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「んぁっ、そ、そうだっ、母のマンコ感じているぞっ！　お前のチンポで、ま\nすます汁を溢れさせているっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「いやらしい汁を、だらだら垂れ流すスケベマンコになって、お前のチンポを\n嬉しそうに咥えてしまっているぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ああっ、ああっ、凄いぞっ、お前のチンポ、母の子宮を完全攻略しようとし\nてるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「母の、大事なところを、全部制圧してしまおうと……んぁっ、ああっ、こん\nな凶悪なチンポに育っていたなんて……っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0104210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「はぁっ、ああっ、母の腰も動いてしまうぅ……！　お前のチンポがよすぎて\n、媚びるような腰振りして、んひぃいっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0104211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「勃起チンポ、もっと、もっと味わおうと、スケベな動きをして、マン汁飛ば\nしてしまうぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0104212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ああっ、ひぃいっ、マンコがっ、マンコがビクビクしてきたっ！　お前のチ\nンポで、母のマンコがイキそうになってる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0104213" ]},
		{"command":[ "SETIMAGE", "0", "still_00020101_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「息子の凶悪チンポに負けるっ、母なのに負けてしまうぅっ！！　このチンポ\nの快感に、抗えないよう堕とされるぅうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0104214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、またチンポがっ、ビクビクふるえて、先っぽが膨らんできて…\n…っ！　んひぃっ、母の弱いところっ、ぐりぐりぃっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0104215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「そのまま射精するのかっ、母にっ、母にまたお前の精液を、いっぱい……い\nっぱいくれるのか……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0104216" ]},
		{"command":[ "SETIMAGE", "0", "still_00020101_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ああ、たくさん気持ちよくなって、たくさん射精してくれっ！　母の身体は\n、そのためにあるのだからっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0104217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「息子が気持ちよく精液をコキ捨てられるようにっ、んあっ、ああっ、だから\nっ、だから我慢なんかせずに、んぁっ、ああっ、母ももう……！」", "NORMAL" ]},
