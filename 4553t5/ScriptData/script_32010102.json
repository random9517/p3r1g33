		{"command":[ "PLAYVOICE", "v2_201_0104305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ああっ、ああ……っ！　まだまだ、でてる……！　なんて長い射精……っ！\n　こんなにたくさんの精液、母の子宮に入りきらんぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0104306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……。息子のチンポに、こんなにイかされてしまうなんて……\n。しかし、母はとても、誇らしい気分だ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0104307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「こんなにも、たくましく育ったのだな……。射精する姿も、とても立派だっ\nたぞ……ふふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0104308" ]},
		{"command":[ "SETIMAGE", "0", "still_00020101_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ああ……ほら、見てみろ……。お前の精液……あまりにも量が多くて、マン\nコから溢れてきてしまっている……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ふふ……母のマンコがあまりにも気持ちよすぎたからか？　まあ、親子であ\nれば身体の相性がいいのは当然。であろう？」", "NORMAL" ]},
