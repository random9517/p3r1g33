{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0113" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_012" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、はぁ……こっちだ！　姫様！　アナザー！」", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「そこ！　そこの岩陰だよ！　がんばって、ふたりとも！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_020111120001" ]},
		{"command":[ "SETCHARA", "0", "char_00001302_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010111120001" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010111120001" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……みんな、無事逃げ込んだか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ええ、全員います」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010111120001" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「しばらくここに隠れて、態勢を立て直そうじゃないか。いまのところは、ド\nラグソードががんばってくれてるし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010111120001" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうだな。しかし……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「…………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010111120001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090111120001" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「姫様はともかく、アナザーまでどうしてこんな状態に？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「……同じだ。同じなんだ。あのときと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090111120002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「……？　同じ、といいますと？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010111120002" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「私の次元の……私のグレート・ルナリアムが……奴らに滅ぼされたときだ！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090111120003" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010111120002" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「滅ぼされた……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010111120002" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうか……！　そういえばアナザーは……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「私はこの場を借りて、自分の世界の遺志を継ぐもの――おそらくは、唯一生\nき残った者として語りたい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090111120004" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「私のいた世界は、先日この世界を襲った『襲来者（インベーダー）』たちに\nよって、完全に崩壊した」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090111120005" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……そのときと、今の状況が同じだってのか……！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「そうだ……！　あのときもこうだった！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090111120006" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「あのときも、いまと同じようにルナパレスが……ルナパレス２１が襲来者（\nインベーダー）のロボット軍団に襲撃を受けた」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090111120007" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0000" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_005" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「くっ……！　襲来者（インベーダー）どもめ、ついにここまで……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090111120008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザー・ルナルバース" ]},
		{"command":[ "SETTEXT", "「ルナよ、ここはいい。おぬしは脱出船団の護衛に回れ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「しかし母上様……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090111120009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザー・カツマ" ]},
		{"command":[ "SETTEXT", "「大丈夫だ、ルナ。宮殿と母上は俺が守る。ここはまかせて、船団のほうを頼\nむ。君が守ってくれると知ったら、民も皆安心するからな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「そうか……そうだな。民を守るのが王族の役目だ、行ってくる。だがカツマ\n、くれぐれも母上様のこと、頼んだぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090111120010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザー・カツマ" ]},
		{"command":[ "SETTEXT", "「わかってるさ。君の大事な母上だ。どんなことがあろうと、守り抜いてみせ\nる！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「ふふふっ、カツマはいつも頼もしいな。それでは、あとでまた！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090111120011" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザー・カツマ" ]},
		{"command":[ "SETTEXT", "「気を付けて。愛してるよ、ルナ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「な！　なんだ、もう！　こんなときにっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090111120012" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザー・ルナルバース" ]},
		{"command":[ "SETTEXT", "「ほらほら！　いちゃついとらんで、さっさと行ってこんか！　緊急事態なん\nじゃぞ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "FADEIN", "NORMAL" ]},

		{"command":[ "SETIMAGE", "0", "bg_0113" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「こうして私は、カツマと別れて脱出船団の護衛に向かった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090111120013" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「ドラグソード！　今度は左前方だ！　撃てっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090111120014" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「脱出船団が月軌道を離れるまではあと１５分……！　そこまでしのげば少し\nは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090111120015" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ジュンジロー" ]},
		{"command":[ "SETTEXT", "「危険！　危険！　後方でエネルギー反応増大！　危険！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_040111120001" ]},
		{"command":[ "SETCHARA", "0", "char_00000904_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「なにっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090111120016" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYBGM", "BGM_012" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「ルナパレスが！？　爆発！？　そんな……！　嘘だ！　宮殿がやられるなど\n……そんなこと。あるわけが――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090111120017" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「……母上様！？　カツマ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090111120018" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「いやだ……そんな……。信じないぞ、嘘だ……ありえない。あの母上様が、\nカツマが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090111120019" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「カツマ……カツマぁあああああああああーーーーーーーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090111120020" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ジュンジロー" ]},
		{"command":[ "SETTEXT", "「上空より、高熱源体さらに多数。エネルギー兵器による攻撃と思われる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_040111120002" ]},
		{"command":[ "SETCHARA", "0", "char_00000904_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「――っ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090111120021" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「上空！？　まさか、脱出船団に――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090111120022" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「う、うああああああああああーーーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090111120023" ]},
		{"command":[ "WAITINPUT" ]},


		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "bg_0113" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "PLAYBGM", "BGM_007" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「そう……私は、守り切れなかったんだ。グレート・ルナリアムの民も、母上\n様も、そしてカツマも……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090111120024" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「そして……私とメカ・ジュンジローだけが次元のはざまに放り出され……こ\nうして生き延びて――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090111120025" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「私たち……だけが……！　うっ……うううっ……うっ……ううううっ……！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090111120026" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そのときの敵が、あいつらだというのか……あの、ロボット軍団と、円盤女\nだと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010111120002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「そうなんだ……そっくりなんだ。あのときと。同じなんだ……同じなんだよ\n……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090111120027" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_020111120002" ]},
		{"command":[ "SETCHARA", "0", "char_00001302_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010111120002" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0089" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「…………いや。違う。違うぞ、アナザー！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「――っ！？　カツマ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090111120028" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETIMAGE", "0", "sbg_0090" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「よく見ろ。俺はここにいる。おまえの手をしっかり握ってる。俺は、いま、\nここでおまえと一緒に戦ってる。この世界は、おまえのいた世界と違うんだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「あ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090111120029" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そっちの世界では、俺は、おまえと最後まで戦えなかったかもしれない。で\nもな、この世界じゃ違うぞ！　最後まで、おまえと一緒に戦う！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「最後まで……私と……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090111120030" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「それだけじゃないぞ、ほら！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETIMAGE", "0", "sbg_0091" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「お、おい！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010111120003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「この世界にはもうひとりのおまえ。こっちの世界の姫様が、ルナテミスがい\nる。やっぱりおまえと一緒に戦ってる」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「…………！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010111120004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「もうひとりの私が……この世界のルナテミスが……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090111120031" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「…………そうだ。アナザーは別の世界の私、私はこの世界のアナザー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010111120005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「それだけだって、単純計算で戦力は二倍だろ？　それに加えてだ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010111120003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「……うん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010111120003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
