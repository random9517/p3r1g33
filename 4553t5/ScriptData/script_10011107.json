		{"command":[ "SETNAME", "Ａ・ジュンジロー" ]},
		{"command":[ "SETTEXT", "「出撃待機中」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_040111120003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「みんながいる！　グレート・ルナリアムの、幹部のみんなが！　みんなが一\n緒に戦ってくれる！　最後まで！　あいつらに勝つまでだ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「あ……あああ……あっ……！　みんなが……みんなが！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090111120032" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「どうだ？　アナザー。これでも同じか？　これでも、あのときと一緒か？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「違う……違うぞ！　あのときと同じのはずがない……いや、同じではいけな\nいんだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090111120033" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「私の世界とこの世界、同じ悲劇を繰り返してはならない！　こんどこそ、や\nつらを止めなければ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090111120034" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETIMAGE", "0", "sbg_0092" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そうだ……！　みんなの力で奴らを叩き潰し、母上様の……母上様の仇を…\n…っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010111120006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETIMAGE", "0", "sbg_0093" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「アナザー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010111120007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「ルナテミスっ！　……やろう！　戦おう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090111120035" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「やるんだ、みんなで！　女王陛下の為にも、アナザーの世界の人たちのため\nにも、そして――脱出船を無事発進させるためにも」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "みんな" ]},
		{"command":[ "SETTEXT", "「おーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010111120008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おっと！　こうしちゃいられねえ。ドラグソードが危ない！　援護するぞ！\n」", "NORMAL" ]},
