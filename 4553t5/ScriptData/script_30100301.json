{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0081" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「お、隊長殿ではないか。楽しんでいるか？　たまの休暇、楽しまなくては損\nだぞ。私も今しがた一泳ぎしてきたところだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0303101" ]},
		{"command":[ "SETCHARA", "0", "char_00001003_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「ん？　どうしたおまえさん、そんな挙動不審に……ああ、この身体が気にな\nるのか？　視線が胸と股間を行き来しているのがバレバレだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0303102" ]},
		{"command":[ "SETCHARA", "0", "char_00001003_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「ふふ、ふふふふ。こんなババアに発情するとはな。まあ、若い頃の私は魅力\n的だしなあ……しかたないなあ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0303103" ]},
		{"command":[ "SETCHARA", "0", "char_00001003_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「ほら、そこに寝ろ。こんなに股間をおっ立ててビーチを歩いたら、通報され\nるだろうが。私が鎮めてやろう。おまえさんも、期待してたんじゃないか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0303104" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001003_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「隠さなくてもいい。ほら、素直になってみろ……私をそういう目で見ていた\nんだろう？　ん？　つい身体に見とれて？　そうだろうそうだろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0303105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「それで、この私の美ボディで、なにをして欲しかったんだ？　んん？　言っ\nてみろ。正直に言ってみろ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0303106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「なに、胸で挟んで、舌先で舐めて欲しい……くはははははっ、本当に正直に\n言ったなあ！！　うむうむ、じゃあ望み通りにしてやろうか！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0303107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「ほら、どうだ？　おまえさんがじろじろ見てた胸でこうされるのを想像して\nたのだろう？　ほら、ほらほら、お望み通りに挟んで……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0303108" ]},
		{"command":[ "SETIMAGE", "0", "still_00001003_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「ふふ、乳の谷間が火傷しそうだな……おまえさんも物好きだな。若返ったと\nはいえ、私はババアだぞ？　そんな女に興奮して」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0303109" ]},
		{"command":[ "SETIMAGE", "0", "still_00001003_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「え？　ババアなんかじゃない？　いい女だと？　全く……おまえさんは口が\nうまい男だな。だが、女を喜ばせる男でもあるな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0303110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「じゃあ……そろそろ舌も……れるっ、れろっ、んっ、れるっ。んんっ、この\n味、さらに若返る気がするな。れろっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0303111" ]},
		{"command":[ "SETIMAGE", "0", "still_00001003_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「ふふ、腰が震えているぞ。そんなに私の舌が気持ちいいか？　今から胸でも\nしごいてやるからな。ほら、ほらほら、れるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0303112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「こうして挟みながら、舌で舐めて……ふふっ、腰が震えているぞ、隊長殿。\nそんなに気持ちいいのか？　私の手管も捨てたもんじゃないな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0303113" ]},
		{"command":[ "SETIMAGE", "0", "still_00001003_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「んふふっ、舌先に苦い味が広がってきているぞ。ガマン汁が漏れてきてるの\nが分かる。ほら、こういうのがいいんだろう？　れるっ、れろっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0303114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「んんっ、私の胸の中が唾液とガマン汁でべとべとだな。おまえさんの顔が気\n持ちよさそうでつい熱が入ってしまう。んっ、れるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0303115" ]},
		{"command":[ "SETIMAGE", "0", "still_00001003_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「もっと気持ちよくなりたいか……ふはっ、言い終わる前に頷いているじゃな\nいか。そこまで求められるならしかたない。大サービスだ。あー……むっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0303116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「んっ、んむっ、どうだ、口と舌の両方は。言っておくが私は安い女ではない\nからな。こんなことをしてやるのはおまえさんだけだ。あむっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0303117" ]},
		{"command":[ "SETIMAGE", "0", "still_00001003_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「んんっ、んくっ、んむうっ、んっ、ふふ、感想を聞くまでもないな。私の胸\nの中でおまえさんのちんぽがびくびく震えている。んむっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0303118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「んっんっんっ、ふっ、うっ、ああ、たまらないな、女に欲情したちんぽの味\nは……んっ、んんっ、んくっ、心も若返る……ちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0303119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「んむうっ、れるっ、ちゅっ。ほら、どれが一番いいんだ？　舐められるのか\n、咥えられるのか、吸われるのか。どれが一番おまえさんの好みだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0303120" ]},
		{"command":[ "SETIMAGE", "0", "still_00001003_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「全部、だと？　おまえさんは本当に欲張りだな……しょうがない、求めてく\nる雄に応えるのも女の甲斐性だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0303121" ]},
		{"command":[ "SETIMAGE", "0", "still_00001003_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「私のパイズリテクニックのフルコース、おまえさんに味わってもらうとする\nか。まずは舌だ……んんっ、れるっ、れろっ、れるるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0303122" ]},
		{"command":[ "SETIMAGE", "0", "still_00001003_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「ん、おいし……次はおしゃぶりだな。あー……むっ、んっ、んむっ、んうっ\n、くぷっ、んむうっ、んっんっんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0303123" ]},
		{"command":[ "SETIMAGE", "0", "still_00001003_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「ふふ、口の中で熱ーくなっているな。おまえさんのちんぽ、私のおしゃぶり\nでばっきばきになっているのが分かるぞ。で、最後は口づけだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0303124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「ちゅっ、んっ、ちゅうっ、ちゅううううっ、ちゅっ。先端もカリ首も、なん\nとも男らしいちんぽだ……口づけにも熱が入る……んちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0303125" ]},
		{"command":[ "SETIMAGE", "0", "still_00001003_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「胸の中でもちんぽが暴れている……ふふ、胸に挿入されておるようだな。こ\nれをまんこに入れられたら……想像するだけで濡れてくる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0303126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「だが、今は胸と口だ。れるっ、んっ、ちゅっ、んんっ、こら、ちんぽを暴れ\nさせるな。ちゃんと口でできないだろう、んんむっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0303127" ]},
		{"command":[ "SETIMAGE", "0", "still_00001003_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「んんんむっ、ガマン汁がねとねとしてきたな。そろそろイきたいんだろう？\n　いいぞ、いつでもイっていいぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0303128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「今の私はおまえさんに傅く雌だ。おまえさんが好きなときに、私を使ってい\nいんだぞ。ほら、んむっ、ちゅっ、れるっ、んむうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0303129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「んんんっ、むっ、ふふふっ、顔が切羽詰まってきているな。男のそういう顔\nを見るのも久しぶりだ……おまえさんのその顔、可愛らしくもある、んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0303130" ]},
		{"command":[ "SETIMAGE", "0", "still_00001003_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「ちゅっ、んむっ、れるっ、匂いも温度も高まってきた……いいぞ、私の胸と\n口で、たっぷりと濃い精液を出してくれ……んむうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0303131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「んんっ、ふっ、んっ、ちんぽが膨らんできたな、そら、ラストスパートだ。\n私の口でこうして……んっ、あっ、んんっ、ちゅっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0303132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「ふうううっ、あああああっ、精液が……んんんっ、んぐっ、んっ、んむっ、\nんんっ、んぐうっ！！　んっ、んくっ、んうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0303133" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001003_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「あっ、んっ、止まらん……んんっ、おまえさん、私の口を孕ませるつもりか\n……濃厚で、匂いも……んくっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0303134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「んんっ、味も濃い……こんなもの、腹の中に出されたら一発でおまえさんの\n子を孕んでしまうな。ふふ、年甲斐もなく身体が疼いてしまう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0303135" ]},
		{"command":[ "SETIMAGE", "0", "still_00001003_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「ほら、見てみろ隊長殿。おまえさんの精液、飲み干したぞ……私の身体でこ\nんなに興奮してくれたと思うと、少しばかり気恥ずかしいがな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0303136" ]},
		{"command":[ "SETIMAGE", "0", "still_00001003_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「ん？　私は男を興奮させるいい女だと？　はははっ、そう言ってもらえると\n若返った甲斐があったな。ふふ、ふふふふふ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0303137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「せっかく若返った新鮮な身体だ。これからその気になったらいつでも使って\nいいぞ。私もおまえさんなら喜んで相手してやろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0303138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「口も、胸も、顔も……もちろんまんこもだ。おまえさんがそこまで私に欲情\nするなら、猛る雄を鎮めるのもよい雌の条件だからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0303139" ]},
		{"command":[ "SETIMAGE", "0", "still_00001003_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「したくなったらいつでも言うがいい。私のこの身体全てはおまえさんのもの\nだ……分かったか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0303140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「ただ、今は私からの求めに応じてもらおうか。雌の求めに応じるのも、立派\nな雄の条件だぞ。ほら、んっ！！」　", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0303201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「おまえさんの精液を飲んで、ちょっとばかり火がついてしまった。ほら、お\nまえさんも満足しきっていないだろう？　ちんぽが硬いままだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0303202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「んむっ、はっ、こぼれた精液が混じって、さらに濃厚な味になって……んん\nっ、久しぶりだ、私にこんな風に射精してくれる男など……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0303203" ]},
		{"command":[ "SETIMAGE", "0", "still_00001003_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「本当はな、私をそんな目で見てくれるおまえさんがちょっと嬉しくてな……\nふふ、何百年ぶりかの奉仕で、もっともっと絞りたくなった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0303204" ]},
		{"command":[ "SETIMAGE", "0", "still_00001003_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「だからな、もっともっと私の胸と口で、そのおちんぽから濃厚精子を出して\nもらいたくてな。ほら、ほら、んっ、ちゅっ、れろっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0303205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「んふっ、うっ、ほら、唾液と先走りで胸の中でちんぽがぐちゅぐちゅと音を\n立ててるのが聞こえるだろう。んっ、ふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0303206" ]},
		{"command":[ "SETIMAGE", "0", "still_00001003_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「全く、こんな逞しいちんぽと射精で、その気にならん女などいないぞ……口\nもちんぽも女泣かせだな、おまえさんは。あむっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0303207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「んんっ、むっ、味も匂いも熱さも凄い……んんっ、硬さもな。これで何人の\n女を泣かせてきたのやら。悪いちんぽだ。んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0303208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「私みたいなババアにもところ構わず欲情して……んっ、ふっ、れるっ、ちゅ\nっ、悪いちんぽにはお仕置きフェラじゃ、んっ、んむっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0303209" ]},
		{"command":[ "SETIMAGE", "0", "still_00001003_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「んっんっん、ちゅばっ、れるっ、れろっ、どうだ、反省したか？　女を発情\nさせる悪いちんぽ、反省したか？　まだか……この、ちゅっ、んっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0303210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「んぐっ、じゅっ、れるっ、ちゅっ、んんっ、また胸の中で暴れて、反省の欠\n片も見えんな。ならばしかたない、もっと絞るしかないな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0303211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「ほら、ほらほら。胸でこうやってきつく締めつけて……そこから口で……ん\nっ、ちゅっ、れるっ、んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0303212" ]},
		{"command":[ "SETIMAGE", "0", "still_00001003_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「おまえさんのちんぽ、熱すぎて胸が火傷しそうだ……ふふ、びくびくって跳\nねて、またちんぽから精液を出したがっているの、分かるぞ。んむっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0303213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「んっ、んぐっ、ちゅっ、れるっ……また味が濃くなってきたな。顔も切なそ\nうになってるぞ……ふふ、もうちょっと、もうちょっとだけ我慢だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0303214" ]},
		{"command":[ "SETIMAGE", "0", "still_00001003_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「ふううっ、ん？　私の顔もエロいじゃと……当たり前だ。こんなちんぽが目\nの前にあったら、こんな顔にもなるだろうに、ちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0303215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「んむっ、鈴口が開いてきたな、腰も浮いてきている。ふふ、いいぞ。またイ\nってもいいぞ。私の口と胸で、また濃厚精液を出していいぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0303216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「ほら、我慢するな。雄が自分の思うままに振る舞う姿も、魅力の一つだぞ？\n　それとも、まだ奉仕が足りないか？　んむっ、れるっ、れろっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0303217" ]},
		{"command":[ "SETIMAGE", "0", "still_00001003_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「んぶっ、ちゅっ、じゅる、んぐっ、こうして、顔を早く動かせば、んっんっ\nんっ、じゅぶっ、んんっ、れるっ、んうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0303218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「胸で締めつけながら舐めるのはどうだ？　れるっ、れろっ、ちゅっ、んっ、\nんんっちゅうっ、れろっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0303219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「ああ、来た、来たな、雄の昂ぶり、感じるぞ。私に精液を出そうとしている\nのが、分かるぞ、んむっ、んっ、んんっ、んうっ、んむううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0303220" ]},
		{"command":[ "SETIMAGE", "0", "still_00001003_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},
		
		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「んぐうううううううっ！！　んんっ、んっ、んくっ、んぐっ、んっ、ふっ、\nうううううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0303301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001003_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「ふうっ、ふっ……二回目とは思えない程の濃厚さと味だ……やはりおまえさ\nんは素晴らしい雄だな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0303302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「んっ、んくっ、んぐっ……喉にへばりつくような濃さで、喉が妊娠してしま\nいそうだ。おいし……んっ……くっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0303303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「けぷっ、んっ。おまえさんの精液で腹がいっぱいだ……よくもこれほど出し\nたものだ。ふふ、だが、雄としては立派だな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0303304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「んっ、ちゅっ、んんっ、れるっ、れろっ……最後の一滴まで無駄にはしない\n。これで、綺麗になったぞ。ちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0303305" ]},
		{"command":[ "SETIMAGE", "0", "still_00001003_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「それにしても、こんなに濃厚な精液、口だけじゃもったいないな。やはり、\n雄は雌を孕ませてこそだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0303306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「せっかく若返ったんだから、おまえさんと色々やってみたいと思うのは当然\nだろう？　その中におまえさんとの子作りがあってもいいとは思わないか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0303307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「ふふ、私とおまえさんの子だ。きっと可愛らしくも強い子が生まれるに違い\nない。想像するだけで楽しみだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0303308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「そうだ、一人だけじゃなく、群れを作れるぐらいたくさん作るのもよいかも\nしれないな。おまえさんとの子なら、何人でも育ててみせよう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0303309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「ふふ、だから今度は私の胎の中に……な？　期待しているぞ、隊長殿」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0303310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「あうっ、んんっ、あっ、ちんぽ、胸から離れて……ああっ、んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0303401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001003_01_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「顔っ、顔に……くああああっ、んっ、ふううっ、熱い……んうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0303402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「おまえさん、顔を孕ませるつもりか……あっ、くっ、ふあああっ、どれだけ\nぶっかければ気が済むんだ……んんっ、ふっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0303403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「こんなに濃くて粘ついたものを私に飲ませていたのかおまえさん……ふうっ\n、んっ、匂いも……雄の匂いがぷんぷんしている……くあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0303404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「ふふ、これは濃厚なマーキングだな……この匂いが残っているうちは、私が\nお前の女だと誰もが一目で理解するだろうな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0303405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ、指でのばしてもゼリーみたいにぶるぶるして……なんという精\n力だ。他の女がおまえさんに秋波を送るのも分かる気がするな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0303406" ]},
		{"command":[ "SETIMAGE", "0", "still_00001003_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「女なら、おまえさんの雄としての強さを潜在的に感じ取って、おまえさんを\n欲しがるものだ。ふふ、私が見立てるのだから間違いない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0303407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「んんっ、こら、真面目な話をしているのにちんぽで返事をするな。まったく\n……しかたのない男だな、おまえさんは」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0303408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「まあそこが魅力的でもあるんだが。改めて言っておくが、私はこれでも身持\nちは堅いほうだからな。おまえさんだから、こんなことを許している」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0303409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「であるから、マーキングが薄れてきたらまたよろしく頼むぞ、隊長殿。私の\n所有権を主張できるのは、おまえさんしかいないからな。ふ、ふふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0303410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}