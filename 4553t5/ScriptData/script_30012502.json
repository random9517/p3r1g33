		{"command":[ "PLAYVOICE", "v2_001_2504216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈルナテミス" ]},
		{"command":[ "SETTEXT", "「んふぅっ、あぉぉっ、激しいっ……あぉぉっ！　ま、まだかっ？　私もっ…\n…もうっ、あっ、オマンコっ……ギリギリでっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2504217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈルナテミス" ]},
		{"command":[ "SETTEXT", "「あっ、あうっ、くぅんっ！　はぁぁっ……何でもっ、何でもいいっ！　貴様\nの欲望をっ……そのまま私に吐き出してくれっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2504218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈルナテミス" ]},
		{"command":[ "SETTEXT", "「ダメっ……あぁっ、もうダメだっ……！　オマンコ気持ちよすぎてっ、もう\nっ、ま、待てないからぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2504219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁんっ、イクっ……オマンコイクっ！　ぶっといオチンポでまたオマンコ\nイクぅぅぅぅぅぅぅぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2504220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "Ｈルナテミス" ]},
		{"command":[ "SETTEXT", "「んはぁぁぁぁぁぁぁーっ！　あぁっ、また出てるっ……！　中にっ……ザー\nメンっ、種付けされてるぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2504301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000125_02_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁぁぁ……溢れる……さっきあんなに出したのに……まだ、こんなにぃ…\n…んくぅ……ぁぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2504302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈルナテミス" ]},
		{"command":[ "SETTEXT", "「すごい……オマンコ全部いっぱいにされて……はぁぁ……トロネバの精液が\n……染み込んでいく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2504303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈルナテミス" ]},
		{"command":[ "SETTEXT", "「んんっ、ちゃんと出し切ってくれ……少しでも受精する確率を上げないとな\n……んっ、中出し着床……気持ちいい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2504304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈルナテミス" ]},
		{"command":[ "SETTEXT", "「ふぅぅぅ……やっとオチンポが大人しくなって来た……うむ……射精が終わ\nりそうだな……んく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2504305" ]},
		{"command":[ "SETIMAGE", "0", "still_00000125_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……んっ……あぁ、まだ硬いオチンポがオマンコの中で震えてる\n……全く……とんでもないオチンポだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2504306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈルナテミス" ]},
		{"command":[ "SETTEXT", "「うぅ……気持ちが高ぶっていたとはいえ、かなり浅ましい姿を晒してしまっ\nたな……貴様の顔をまともに見られないぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2504307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈルナテミス" ]},
		{"command":[ "SETTEXT", "「ば、バカモノっ！　可愛いとかっ……そんな真顔で言うものじゃないっ！　\nは、恥ずかしいだろうがっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2504308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈルナテミス" ]},
		{"command":[ "SETTEXT", "「こほんっ……とにかくだな、他の皆には私のこんな姿のことは言うんじゃな\nいぞ？　色々と……示しもつかないからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2504309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈルナテミス" ]},
		{"command":[ "SETTEXT", "「その……秘密にしたら……また、続きをしてもいいからな……そうだ……私\nの身体をもっともっと隅々まで……味わってくれ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2504310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "Ｈルナテミス" ]},
		{"command":[ "SETTEXT", "「ふぁぁぁぁぁんっ！　あぁっ、ザーメンっ……顔にっ……はぁんっ、いっぱ\nい……ぶちまけられてるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2504401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000125_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁっ……ずっとイッてるっ！　オチンポ抜けてるのにっ……オマンコずっ\nと気持ちいいままぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2504402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈルナテミス" ]},
		{"command":[ "SETTEXT", "「んふぁっ、おっぱいにも……びゅくびゅくっ……出されてぇ……あぁ……身\n体が……トロネバで満たされてくぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2504403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁ……臭い……なんてにおいだ……こんなものを染み込ませて……私を中\nからも外からも完全に支配してしまうつもりだな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2504404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈルナテミス" ]},
		{"command":[ "SETTEXT", "「だが……んっ、それでいい……ここまで来たら……全部出し切って……全て\n染み込ませてくれぇ……はぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2504405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ、あぁ……オチンポの震えが止まって……これで終わりか……本当にた\nっぷり出してくれたな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2504406" ]},
		{"command":[ "SETIMAGE", "0", "still_00000125_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈルナテミス" ]},
		{"command":[ "SETTEXT", "「んふぅ……にちゃっとしてる……ちゅぱっ……はぁ……この味だ……私を支\n配する粘っこいザーメン……ちゅぷっ、はっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2504407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈルナテミス" ]},
		{"command":[ "SETTEXT", "「な、何をニヤニヤ見ているっ！　別にいいだろうっ、私の身体に出したんだ\nからっ、もうこれは私のモノだっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2504408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈルナテミス" ]},
		{"command":[ "SETTEXT", "「全く……どうも貴様の前では色々と調子が狂う。それだけ、もう私は逆らえ\nなくなってしまってると……そういうことなんだろうな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2504409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈルナテミス" ]},
		{"command":[ "SETTEXT", "「まあいい。もう私の覚悟は決まっているんだからな。これからも、私の身体\nを開発するのは貴様だ……よ、よろしく頼むぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2504410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
