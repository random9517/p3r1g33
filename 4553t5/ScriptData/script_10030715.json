		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「さて、今回はどうしたのさ。また情けなく帰ってきちゃって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010115630001" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「仕方ないじゃろう。想定外のことがおきたのじゃから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100115630001" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「そうだそうだ！　だいたい、お前はなにしてたんだよ！　また城の中でゲー\nムでもしてたんだろ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080115630001" ]},
		{"command":[ "SETCHARA", "0", "char_00000408_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「違う違う。ボクは女王様から受けた別の任務をこなしていただけだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010115630002" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「そして、ダメダメな幹部にオシオキするのもボクの仕事さ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010115630003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「こ、この悪趣味な仕掛けのことですか……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010115630001" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "時間城に帰った三人は、ジェスタが用意した罰ゲームを受けていた。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ベルトコンベアの上を走る三人。その後ろには、宇宙ヒグマが口を開けて待機\nしている。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "宇宙ヒグマ" ]},
		{"command":[ "SETTEXT", "「はひゃぁあああんっ！　ふひぃいいん！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ほらほら、クマさんに食べられたくなかったら頑張って走る！　キビキビ走\nって反省しようね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010115630004" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁっ、このぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100115630002" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「食べられてたまるかぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080115630002" ]},
		{"command":[ "SETCHARA", "0", "char_00000408_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「悪趣味にもほどがあります！　このクマもゲテモノ食いですね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010115630002" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ああ……いいなぁ……。代われるものなら代わってあげたいけど、残念なが\nら、ボクは優秀な幹部だからねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010115630005" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ええい、ふざけるんじゃないよこの道化師ふぜいが！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100115630003" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「この屈辱……忘れませんから……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010115630003" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「インクレディブル・スクワッドめ！　次回こそ、ボッコボコにしてやるから\nな～！", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080115630003" ]},
		{"command":[ "SETCHARA", "0", "char_00000408_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "三人" ]},
		{"command":[ "SETTEXT", "「覚悟しろ～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100115630004" ]},
