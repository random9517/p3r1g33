{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0149" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "……それは、俺が非番でダラダラと、自分のベッドに転がっていた時に起こっ\nた。", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ご主人様、はっけ～ん！　やっぱりここにいたんですねっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022020001" ]},
		{"command":[ "SETCHARA", "0", "char_00015701_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「探しましたよ。姿が見えないのでサーチしました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022020001" ]},
		{"command":[ "SETCHARA", "0", "char_00015801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ロッテ……！　それにクララ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "２人の……いや２匹の？　ロボっ娘は、すたすたと部屋の中に入ってくる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「２人が来るなんて珍しいな。用事はなんだ？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「あの……私達、ハロウィンをしたいんです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022020002" ]},
		{"command":[ "SETCHARA", "0", "char_00015701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ハロウィンって……あれか？　あの、秋にやるカボチャの……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「はい。そのハロウィンです。前に、テレビで特集をしていたのを姉さんと見\nたんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022020002" ]},
		{"command":[ "SETCHARA", "0", "char_00015801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「子ども達がめいっぱい楽しめる行事。そういう行事を……ハロウィンってい\nうんですよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022020003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「面白そうだなって思って、ぜひぜひやってみたいって二人で話していたんで\nす！　にゃふふふ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022020003" ]},
		{"command":[ "SETCHARA", "0", "char_00015701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「へー。意外なとこに食いついたんだな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「で、例えば、どういう事をやりたいんだ？　ハロウィンったって色々あるだ\nろ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "あまりに漠然としているロッテとクララの話に、具体性をもたせるべく問いか\nける。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "と、２人は互いに視線を合わせ……困った様子でこちらを向いた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「それが……私達、あまり、ハロウィンについてよくわかってないんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022020004" ]},
		{"command":[ "SETCHARA", "0", "char_00015801_01", "4", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ネットにアクセスして、古代ケルト発祥だとか大体何日ごろにやるかはわか\nりました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022020004" ]},
		{"command":[ "SETCHARA", "0", "char_00015701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「でも……何人くらいで集まって、どういう服で何を……というのが、いまい\nちはっきりしないんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022020005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「はい。イメージがとても分散していて……。布をかぶるだけだったり、黒猫\n白猫の下着を着ていたり」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022020005" ]},
		{"command":[ "SETCHARA", "0", "char_00015801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「お菓子をもらっていたり、……え、エッチなことをしていたり……。人をお\nどかしたり、写真撮影をしていたり」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022020006" ]},
		{"command":[ "SETCHARA", "0", "char_00015801_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "あー……。なるほど。ネットのエロ画像が混じって正しいやり方が掴めなくな\nってるってわけか", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "まさにインターネット社会の弊害ってやつだ。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんだよ。それじゃ、何をするかもわかってないってことか？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「でも……楽しそうだなって事だけはわかります」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022020007" ]},
		{"command":[ "SETCHARA", "0", "char_00015801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「それだけわかっててもダメだろ～」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「そうですよね……。あっ！　でも！　１つだけ知ってることはありますよ。\nえ～っと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022020006" ]},
		{"command":[ "SETCHARA", "0", "char_00015701_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「トリック・オア・トリート！　って言うんですよね？　子どもが……大人の\n方に？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022020007" ]},
		{"command":[ "SETCHARA", "0", "char_00015701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「仮装をして、それを見せあうんでしょ？」　", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022020008" ]},
		{"command":[ "SETCHARA", "0", "char_00015801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「それで、カボチャ……。カボチャの中身をくり抜いて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022020008" ]},
		{"command":[ "SETCHARA", "0", "char_00015701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「何かお菓子を作るんだったはず」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022020009" ]},
		{"command":[ "SETCHARA", "0", "char_00015801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「カワイイお洋服を着るんですよね。オレンジとか。紫とか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022020009" ]},
		{"command":[ "SETCHARA", "0", "char_00015701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ペロペロキャンディーを持っている人を見たことがあるかも」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022020010" ]},
		{"command":[ "SETCHARA", "0", "char_00015801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「あとは、お化けです！　お化けがぴゅ～って飛んでいましたよね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022020010" ]},
		{"command":[ "SETCHARA", "0", "char_00015701_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「今まで、そんなイベントがあるってことを知らなかったから……興味があっ\nて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022020011" ]},
		{"command":[ "SETCHARA", "0", "char_00015701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「うん。姉さんが喜んでくれるならって思ったんだけど……無理かな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022020011" ]},
		{"command":[ "SETCHARA", "0", "char_00015801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ハロウィン……やってみたかったんだけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022020012" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、それ自体は俺も賛成だけど」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「本当ですか！？　わぁっ、ご主人様にお話して良かったです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022020012" ]},
		{"command":[ "SETCHARA", "0", "char_00015701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「けど……うーん」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「何か気になることがある……って顔してる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022020013" ]},
		{"command":[ "SETCHARA", "0", "char_00015801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「せっかくやるなら、もう少しハロウィンについて勉強した方がいいよなと思\nってさ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「おべんきょう……ですか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022020013" ]},
		{"command":[ "SETCHARA", "0", "char_00015701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「なんとなく楽しんじゃうのはだめなの？　ご主人」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022020014" ]},
		{"command":[ "SETCHARA", "0", "char_00015801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ピコピコと機械の耳を動かす２人に、俺は腕を組んで答える。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ハロウィンにはハロウィンの、行事の意味ってヤツがあるんだよ」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ええっ！？　そうなんですか！？　知りたいです、ご主人様～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022020014" ]},
		{"command":[ "SETCHARA", "0", "char_00015701_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「っていうか、ネットのエロ知識のまま適当な祭りをやったりしたら……俺が\nたぶん、各所から怒られる……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「そうですねっ、えっちなのはいけませんよねっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022020015" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「だからやるならさ。でっきるだけ正式なヤツにすべきだと思うんだよなぁ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「それは構いませんが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022020015" ]},
		{"command":[ "SETCHARA", "0", "char_00015801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「そこまではっきり言い切るからには、ハロウィンにご主人は詳しいんですよ\nね？　どうなんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022020016" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「教えてください、ご主人様！　私達、ご主人様の言いつけは絶対に守ります\nから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022020016" ]},
		{"command":[ "SETCHARA", "0", "char_00015701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「きらきらきら……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022020017" ]},
		{"command":[ "SETCHARA", "0", "char_00015801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「わくわくわくわく……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022020017" ]},
		{"command":[ "SETCHARA", "0", "char_00015701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "期待の目を向けてくる２人だが、こっちも寝耳に水で前準備ってもんがない。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「悪いが、俺もまったく詳しくない」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「がーん！　えっえっ、そ、そんなぁ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022020018" ]},
		{"command":[ "SETCHARA", "0", "char_00015701_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「がっくりです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022020018" ]},
		{"command":[ "SETCHARA", "0", "char_00015801_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「でもまあ、なんとなーく……聞くべき相手の予想はつくぞ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「だったらそれを教えてください！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022020019" ]},
		{"command":[ "SETCHARA", "0", "char_00015801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「う～ん……。ハロウィン……ハロウィンだろ……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "秋のイベント……怨霊とかイタズラとか……。イタズラといえば策略か……？\nとなると、ハロウィンに詳しいやつっていうのは……。オボロか？", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「悪だくみとか呪いとか、そういう話に詳しいのはオボロだな」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "もっとも、それが洋風のハロウィンにも適応されるかどうかは謎だが。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「オボロさん……。まだ会ってお話したことはありませんが、お名前を聞いた\nことはありますね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022020019" ]},
		{"command":[ "SETCHARA", "0", "char_00015701_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「そのオボロって人が、ハロウィンのことを教えてくれるってこと？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022020020" ]},
		{"command":[ "SETCHARA", "0", "char_00015801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あ、ああ。たぶん……。たぶんだけどな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "どちらかというと、名月にススキ……白いだんごに秋の夜長といったイメージ\nだが、他に候補も思いつかない。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「オボロに直接聞きにいこう。ちょうど俺も暇を持て余してたし」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お前らがそんなにやりたいってんなら……まあ。少しは協力してやらないと\nな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「わああ～！　ありがとうございます、ご主人様！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022020020" ]},
		{"command":[ "SETCHARA", "0", "char_00015701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「少し見直した。……あ、ありがとう……ご主人」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022020021" ]},
		{"command":[ "SETCHARA", "0", "char_00015801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いいってことよ。……って、うわっ、な、なんだ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "機嫌を良くしたロッテが俺の左の腕に、そしてクララは右腕に絡みついてくる\n。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ご主人様～大好きです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022020021" ]},
		{"command":[ "SETCHARA", "0", "char_00015701_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「やっぱり私達が仕えるべき相手はご主人しかありえない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022020022" ]},
		{"command":[ "SETCHARA", "0", "char_00015801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「おっ、ご主人。両手に花ですな！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「えへへへっ。いいでしょ～。私達、ご主人様とラブラブなんですよ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022020022" ]},
		{"command":[ "SETCHARA", "0", "char_00015701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「たまにはこれくらい……お礼をしてもいいかなって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022020023" ]},
		{"command":[ "SETCHARA", "0", "char_00015801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「めちゃめちゃ両手が重たいけどな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「むっ。それを言うのは機械差別……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022020024" ]},
		{"command":[ "SETCHARA", "0", "char_00015801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「重くないですよ！　重いとしたら、それは私達の愛の重さです～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022020023" ]},
		{"command":[ "SETCHARA", "0", "char_00015701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "プンプンしつつも、離れるつもりはないらしい。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あ～、わかったわかった！　そのままでいいからついて来い！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「わぁ～い！　はいっ、ついていきます、どこまでも！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022020024" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ご主人のこと一応……信用してるし……。うん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022020025" ]},
		{"command":[ "SETCHARA", "0", "char_00015801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「出かける前に着替えたり顔洗ったりしたいんだが……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「もちろんお手伝いします。なんなりと申しつけてください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022020026" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「なんでもさせていただきますよ、にゃふふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022020025" ]},
		{"command":[ "SETCHARA", "0", "char_00015701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「お洋服のお着替えも、乱れたシーツのベッドメイキングも♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022020026" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「朝食も用意します。その間、ご主人をまかせていいですか？　姉さん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022020027" ]},
		{"command":[ "SETCHARA", "0", "char_00015801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「わかりました。おヒゲを剃りますか？　歯磨きしますか？　何でもします！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022020027" ]},
		{"command":[ "SETCHARA", "0", "char_00015701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「私達は、ご主人様のメイドなんですから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022020028" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}