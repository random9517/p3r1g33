		{"command":[ "SETIMAGE", "0", "still_00021901_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「んっはぁ……ま、まだ……出て、るぅ……あぁ、すごい……なに、これぇ…\n…子宮が、溺れちゃうぅ……ひぃうっ……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「あぁ……あぁぁっ……オマンコ、が……ザーメンで溢れてる……んっ、んん\nっ……お仕置きで、妊娠しちゃう……はぅ、んふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0104139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「はぁっ……！　あ、あはぁ……いっぱい、出したのにぃ……んっ、ひぃうっ\n……中で、ビクビクいってるぅ……チンポぉ……あっ、あぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「んんっ？　まだ、足りないの？　あ、あんっ……待って、いきなり……あう\nっ、はぁぁっ……！　あんっ……あぁぁっ、はぁんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0104201" ]},
		{"command":[ "SETIMAGE", "0", "still_00021901_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「チンポ、まだギンギンになったまま……あっ、あぁっ……ンンぅ、ホント元\n気なんだからぁ……あっあっ……ひぃ、ひぐぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「も、もう……お仕置きじゃ、なくてぇ……普通に、んっ……はぁあっ！　セ\nックス、してるだけに……なってぇ……んっ、あぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0104203" ]},
		{"command":[ "SETIMAGE", "0", "still_00021901_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「ち、違う、んっ、はぁっ……！　私が、楽しんでるんじゃ……なくてっ……\nあっ、あんっ！　お仕置きって、わかってるからぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0104204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「ひゃうっ！　あっんっ、は、反省ぇ……して、るぅ……ひぃあっ、あっ、あ\nんっ……任務、は……絶対にぃ、マジメに……くひぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0104205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「そんな、こと……んんっ！　オマンコして欲しさに、わざと失敗なんて……\nするはず、ないぃ……あっ、あぁんっ！　チンポ、奥っ、うぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0104206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「んっ、ひぃぐぅっ！　また、子宮……亀頭で、グリグリって……んあっ！　\nそんなにされたらぁ……はっ、はひっ！　ひぃいんっ！！」", "NORMAL" ]},
