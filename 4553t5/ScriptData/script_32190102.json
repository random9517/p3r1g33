		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「お、おくぅ……感じ、すぎてぇ……はっ、あぁっ！　は、反省、どころじゃ\n……なくなって……んっ、んんっ！　ひぃあぁっ……！」", "NORMAL" ]},
