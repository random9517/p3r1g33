		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「あぁ……んんんっ！　んっ、ふぅう……あっ、あくっ……どう？　こんな、\n感じで……あっ、あぁっ！　あっ、はっ、はぁぁ……あぁっ！」", "NORMAL" ]},
