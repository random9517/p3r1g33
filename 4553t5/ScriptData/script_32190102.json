		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「ゆ、るしてぇっ……あっ、あんっ！　はい、おわびに……オマンコ、締めて\n……気持ちよくするから……あぁ、あぁんっ！　許してぇっ！」", "NORMAL" ]},
