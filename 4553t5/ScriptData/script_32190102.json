		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「許してぇ……任務に失敗したのは、本当に悪かったって……思ってるから…\n…でも、だからってこんな……うぅ、ひどい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「……お仕置き？　そんな……いくらなんでも、これは……ちょっと、まずい\nんじゃない？　えっ……任務失敗したら、みんなこうなる……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0104103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「えぇ、そんなぁ……ちょ、ちょっと……見せつけないで、それ……ねえ、ま\nさかと思うけど、お仕置きって……そういうこと？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0104104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「ひゃうっ！　んっ……あ、あぁ……押しつけないで……あっ……ひぃうっ…\n…あ、熱い……チンポ、あ、あつい、てばぁ……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0104105" ]},
		{"command":[ "SETIMAGE", "0", "still_00021901_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「わ、わかってない……！　とぼけてなんかないから……本当に許して欲しい\n、って思ってる、からぁ……ねえ、ねえ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0104106" ]},
		{"command":[ "SETIMAGE", "0", "still_00021901_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「はうっ……うう、はい……私、です……悪いのは私です……お仕置き、され\nても仕方ない……です……はい……はい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0104107" ]},
		{"command":[ "SETIMAGE", "0", "still_00021901_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「ええっ……！？　お、おねだり……？　あっ、ふぅ……い、淫語って……ど\nういうこと……んんっ！　それ、押しつけないでぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0104108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「わからない、ふり……とかじゃなくて……うう、わかったから……グリグリ\n、しないで……あっ、あぁ……あふぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0104109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「そ、その……チンポ……キミのおっきくて、硬くて、立派なチンポで……私\nのオマンコ、お仕置きして……ください……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0104110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「もっと……？　もっとエロく……？　ううっ……チン、ポぉ……キミのぶっ\nとくて、たくましい……チンポ欲しい……挿入れて欲しいの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0104111" ]},
		{"command":[ "SETIMAGE", "0", "still_00021901_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「私の、オマンコ……チンポ欲しくて、ヨダレ垂らしてぐちょぐちょの……欲\n求不満な……淫乱マンコにチンポぶちこんでぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0104112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「あっああっ……！　んっ、あぁぁぁぁぁぁぁ～～～っ！　ズプズプって、は\nい、はいって……くるぅ……チンポ、がぁ……あぁんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0104113" ]},
		{"command":[ "SETIMAGE", "0", "still_00021901_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「い、一気に……きたぁ……あっ、あふぅっ……奥まで、チンポが……ズブッ\nて、んっあぁっ……あ、あたってるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0104114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「はあぁ、あっ、はぁぁ……ま、待って……ひぃうんっ！　あんっ！　あっあ\nぁっ……ぶっといチンポぉ……ひぐっ、ひっ、ひくっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0104115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「お、奥ぅ、当たって、るぅ……うぅ、ひうっ……パンパンに膨らんだ亀頭が\nぁ……私の子宮、こじ開けようと、してるのぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0104116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「ひっはあっ……んんっ！　オマンコ、押し広げられてぇ……はぁあっ、んっ\nあっ……チンポで、いっぱいになってるぅ……んあぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0104117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「わ、私が締めつけてるんじゃなくて……キミのチンポが大きい、からぁ……\nんあっ、あぁんっ！　はっ、はぁっ……はひぃっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0104118" ]},
		{"command":[ "SETIMAGE", "0", "still_00021901_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「待って！　い、今……動かさないで……！　ひゃうっ、んっんんっ！　だっ\nて……いきなり挿入れられたからぁ……あっ、あぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0104119" ]},
		{"command":[ "SETIMAGE", "0", "still_00021901_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「だめぇ、そのじわじわ抜いていくの……ひっ、ひぐっ……！　んっ、あぁ…\n…カリが引っかかって、中……擦れちゃう……んぅうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0104120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「あっ、あぁんっ！　だって、こんなぁ……んんっ、！　ひぅんっ！　デカチ\nンで、オマンコかき回されたらぁ……あっあっ……はぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0104121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「お、お仕置きなのに……はっ、あっああっ！　感じちゃって、んんっ……は\n、恥ずかしい、から……ひゃあっ！　エッチな音、鳴らさないでぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「ああっ！　くっ、ひぃうっ……ぬ、濡れちゃうっ……あぁあ、気持ちよすぎ\nて、オマンコ濡れちゃう……んぅぅぅっ！　んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0104123" ]},
		{"command":[ "SETIMAGE", "0", "still_00021901_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「はっあっ、あんっ……あんっ！　感じるに決まってるぅ……あぁっ、こんな\n、激しく、されたらぁ……んっ、チンポぉ……チンポすごいぃぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0104124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「し、子宮が、圧迫っ、されて……んんっ！　ひぐっ、おっおおっ……！　お\n、奥ぅ、グリグリしないでぇ……ああっ、ズポズポくるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「はっ、んんっ……イクぅっ！　イッちゃうっ！　チンポ気持ちよすぎて……\nすぐ……！　ひっ、ひあぁっ！　あんっ、はぁあっ！　あぁんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0104126" ]},
		{"command":[ "SETIMAGE", "0", "still_00021901_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「はひっ……わ、私は、お仕置きで……感じちゃう、アクメしちゃう……淫乱\n、女……ですっ……んんっ！　あぁ、だめぇぇえっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0104127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「んぅうっ！　んはぁぁっ……！　もう、だめ、だめぇ……あぁっ、あふぅぅ\nっ！　チンポ、すごいっ！　あっあっ、チンポ好きぃぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「くっ、ひぅっ……くっほぉぉっ！　あぁ、な、中で……ゴリゴリって、いっ\nてるぅっ……もう、我慢できないぃ……！　あぁぁんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「ご、ごめんなさいっ！　お仕置きなのにっ……わ、私だけ、楽しんでぇ……\nはっ、あぁぁっ！　悪いって……思ってる、けどぉ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0104130" ]},
		{"command":[ "SETIMAGE", "0", "still_00021901_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「ひぅんっ！　く、口答えだなんて……そんな、つもりは……あっ、あぁあっ\n！　でもっ……チンポすごすぎてぇ……あぁ、はぁんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「感じないなんて、むりぃっ……絶対、すぐイッちゃう……！　チンポ気持ち\nよすぎて、イッ、イクッ……イッちゃうぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「は、ぁあっ……！　はひっ……！　中出しっ……中出し、してぇ……！　中\n出しザーメンでお仕置きしてぇぇぇ～～～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0104133" ]},
		{"command":[ "SETIMAGE", "0", "still_00021901_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「は、はぁぁぁっ……！　んっ、んんっ！　あっ、あぁ！！　ひぃいいいいい\nいぃぃぃ～～～っ！！！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「あぁぁぁっ！　で、出てるぅ……っ！　ザーメンが……あ、熱くて、ドロド\nロしたの……出てるぅぅぅぅ～～～っ！　んっ、んはぁぁっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0104135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021901_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「はっ……あはぁっ！　あ、あんっ！　イクうううっ！　イ、イッてるぅぅぅ\nぅぅぅっ～～～！　中出しアクメしてるぅ～～～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0104136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁん……オマンコが、ザーメンで満たされていくぅ……はぐっ、ん\nっ、あぁっ……あはぁぁ、はぁぁ……ひっ、あぁ……」", "NORMAL" ]},
