{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0129" ]},
		{"command":[ "DISPIMAGE","0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_007" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "泉" ]},
		{"command":[ "SETTEXT", "「これで、終わりだあああぁーーーーーっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_010021090044" ]},
	{"command":[ "SETCHARA", "0", "char_00013801_01", "7", "CENTER", "0" ]},
	{"command":[ "DISPTEXT", "TRUE" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「やったか……！？」", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……！　この私がここまで追いつめられるなんて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_010021090003" ]},
	{"command":[ "SETCHARA", "0", "char_00015901_01", "1", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サキ" ]},
		{"command":[ "SETTEXT", "「まだ息があるなんて、そうとうしぶとい奴ね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_010021090029" ]},
	{"command":[ "SETCHARA", "0", "char_00013901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "環" ]},
		{"command":[ "SETTEXT", "「うちはもう限界かな……！　腕がまったく上がんないし……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_010021090025" ]},
	{"command":[ "SETCHARA", "0", "char_00014001_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「魔力も残り僅かしかないし、この学園の力もほとんど残ってない……ここは\n諦めて、退散するしかないようね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_010021090004" ]},
	{"command":[ "SETCHARA", "0", "char_00015901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「覚えておきなさい……！　この借りは、いつか必ず返してあげるわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_010021090005" ]},
	{"command":[ "SETCHARA", "0", "char_00015901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "光が走り思わず瞬きをした刹那、ラー・サイアムはこつぜんと姿を消していた\n。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「逃げられたか……！」", "NORMAL" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYBGM", "BGM_012" ]},
		{"command":[ "SETNAME", "泉" ]},
		{"command":[ "SETTEXT", "「クソっ！　せっかく母さんの仇を討てると思ったのに！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_010021090045" ]},
	{"command":[ "SETCHARA", "0", "char_00013801_01", "7", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、お前の母親死んでないし……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サキ" ]},
		{"command":[ "SETTEXT", "「ラー・サイアム……！　絶対に許せないわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_010021090030" ]},
	{"command":[ "SETCHARA", "0", "char_00013901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「誤診はしょうがないにしても、返金だけじゃなくて示談金まで貰ってるんだ\nから、許してやれよ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "環" ]},
		{"command":[ "SETTEXT", "「ごめんねパパ……！　詐欺師の人、取り逃がしちゃったし……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_010021090026" ]},
	{"command":[ "SETCHARA", "0", "char_00014001_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お前の親父さんに至っては、完全に自業自得だからな？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYBGM", "BGM_018" ]},
		{"command":[ "SETNAME", "環" ]},
		{"command":[ "SETTEXT", "「っていうかさ……悔しい気持ちでいっぱいなんだけど、この人数を相手に互\n角の勝負するって、あいつかなりヤバくない……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_010021090027" ]},
	{"command":[ "SETCHARA", "0", "char_00014001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「サシでやり合ったり、この中の誰か一人でも欠けてたら、間違いなく負けて\nただろうな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "泉" ]},
		{"command":[ "SETTEXT", "「あいつがどれだけ強くても関係ない！　あたしはあの女を探す！　そんで、\n絶対にこの手で復讐してやる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_010021090046" ]},
	{"command":[ "SETCHARA", "0", "char_00013801_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「結構ボコボコにしたんだし、もう許してやれよ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サキ" ]},
		{"command":[ "SETTEXT", "「その気持ちは私も同じよ。でも環の言う通り、タイマンだと厳しいのは事実\nよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_010021090031" ]},
	{"command":[ "SETCHARA", "0", "char_00013901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "環" ]},
		{"command":[ "SETTEXT", "「うーん……あっ、そうだ！　もしよかったらさ、うちらでチーム作らない？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_010021090028" ]},
	{"command":[ "SETCHARA", "0", "char_00014001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「チーム？　どういうことだ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "環" ]},
		{"command":[ "SETTEXT", "「うちらの目的は、あのラー・サイアムって女に復讐することじゃん？　でも\n、タイマンはっても厳しいワケじゃん？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_010021090029" ]},
	{"command":[ "SETCHARA", "0", "char_00014001_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "環" ]},
		{"command":[ "SETTEXT", "「それなら、うちらがチームになって情報共有したり、喧嘩するとき助け合っ\nたりすれば、もっと早くあいつを倒せるかなーって！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_010021090030" ]},
	{"command":[ "SETCHARA", "0", "char_00014001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サキ" ]},
		{"command":[ "SETTEXT", "「……悪くないアイデアね。私たちは全員、あの女に復讐することを目的とし\nてるもの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_010021090032" ]},
	{"command":[ "SETCHARA", "0", "char_00013901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "環" ]},
		{"command":[ "SETTEXT", "「じゃあ、サキは賛成ってことで！　……カツマと泉はどーする？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_010021090031" ]},
	{"command":[ "SETCHARA", "0", "char_00014001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「俺は遠慮しとくよ。ただの臨時用務員だしな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "泉" ]},
		{"command":[ "SETTEXT", "「……………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_010021090047" ]},
	{"command":[ "SETCHARA", "0", "char_00013801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "環" ]},
		{"command":[ "SETTEXT", "「……やっぱ、泉は一人であの女を追いたい感じ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_010021090032" ]},
	{"command":[ "SETCHARA", "0", "char_00014001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "泉" ]},
		{"command":[ "SETTEXT", "「いや……あたしも仲間に入れてくれ！　あの女はあたしの仇で、同時にサキ\nや環の仇でもあるもんな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_010021090048" ]},
	{"command":[ "SETCHARA", "0", "char_00013801_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「だから仇でもなんでもないだろ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "環" ]},
		{"command":[ "SETTEXT", "「よーし！　それじゃ、うちらは今からチームってことで！　ヨロシクー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_010021090033" ]},
	{"command":[ "SETCHARA", "0", "char_00014001_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サキ" ]},
		{"command":[ "SETTEXT", "「チームを組むのはいいけど、せっかくだしなにかチーム名が欲しいところね\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_010021090033" ]},
	{"command":[ "SETCHARA", "0", "char_00013901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "泉" ]},
		{"command":[ "SETTEXT", "「確かに、なんかチーム名があった方が、分かりやすくていいかもな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_010021090049" ]},
	{"command":[ "SETCHARA", "0", "char_00013801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "環" ]},
		{"command":[ "SETTEXT", "「チーム名かー……んー、そうだなー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_010021090034" ]},
	{"command":[ "SETCHARA", "0", "char_00014001_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "泉" ]},
		{"command":[ "SETTEXT", "「……アベンジャーズ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_010021090050" ]},
	{"command":[ "SETCHARA", "0", "char_00013801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サキ" ]},
		{"command":[ "SETTEXT", "「アベンジャーズ……『復讐者たち』ね。いいと思うわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_010021090034" ]},
	{"command":[ "SETCHARA", "0", "char_00013901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "環" ]},
		{"command":[ "SETTEXT", "「アベンジャーズだけだと、なんか映画のタイトルっぽくない？　もう少しな\nにか加えて、うちららしさを出さない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_010021090035" ]},
	{"command":[ "SETCHARA", "0", "char_00014001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "環" ]},
		{"command":[ "SETTEXT", "「それなら、セーラーを付けるのはどう？　うちら全員セーラー服だし、セー\nラーなんとかってヒロインも居るよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_010021090036" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サキ" ]},
		{"command":[ "SETTEXT", "「なら『セーラー・オブ・アベンジャーズ』というのはどうかしら？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_010021090035" ]},
	{"command":[ "SETCHARA", "0", "char_00013901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "環" ]},
		{"command":[ "SETTEXT", "「いいねー！　それっぽい気がする！　それじゃ、うちらは今からチーム『セ\nーラー・オブ・アベンジャーズ』ってことで！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_010021090037" ]},
	{"command":[ "SETCHARA", "0", "char_00014001_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "泉" ]},
		{"command":[ "SETTEXT", "「……これからよろしくな。サキ。環」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_010021090051" ]},
	{"command":[ "SETCHARA", "0", "char_00013801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サキ" ]},
		{"command":[ "SETTEXT", "「ええ。一緒にあの女を倒しましょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_010021090036" ]},
	{"command":[ "SETCHARA", "0", "char_00013901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "環" ]},
		{"command":[ "SETTEXT", "「やるぞーーー！　おーーーーー！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_010021090038" ]},
	{"command":[ "SETCHARA", "0", "char_00014001_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「それでお前らの気が済むなら、別にいいか……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "こうして、不良娘たちはチーム『セーラー・オブ・アベンジャーズ』となり、\nラー・サイアムへの復讐に向け、新たな一歩を踏み出していった。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
	{"command":[ "EXIT" ]}
	]
}