{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「……ん。いきなりこんなとこに呼び出すなんて……どしたの？　お兄。……\nふうん……。その様子だと、私のウワサを聞いたみたいだね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0103101" ]},
		{"command":[ "SETCHARA", "0", "char_00028701_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「そうだよ。お兄が聞いた通り。今から私の真の姿ってヤツを見せてあげる。\n……怯えてるの？　見たかったんでしょ、パーカーの中の本当の姿……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0103102" ]},
		{"command":[ "SETCHARA", "0", "char_00028701_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「んっ……♪　この格好なら……よく見えるよね。そうだよ……。誰に聞いた\nかは知らないけど……。私は冥界きってのオナニスト……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0103103" ]},
		{"command":[ "SETIMAGE", "0", "still_00028701_01_01" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「バカ姉や他のコたちがどうかはまったく知らないけどね……。確かに、スト\nレスがたまるたびに……誰かに嫉妬するたびに、私は自慰に没頭してきた」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0103104" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「自分を罰しているわけじゃないよ。……ただ、フツーに……ホントーに、オ\nナニーするのが好きなだけ。……おかしい？　女の子がこんなことするの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0103105" ]},
		{"command":[ "SETIMAGE", "0", "still_00028701_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「……お兄だって一人でするよね。だったらこっちだって、し、したっていい\nと思わない……？　性別なんか関係ないし……。オ、オナニーはさぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0103106" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「セックスと違って相手とどうこうするわけじゃないから、人を傷つけるわけ\nでもないし。すぐにスッキリできて、最高のシュミだと思うけど？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0103107" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「……え？　だったらなんで恥ずかしそうなのかって？　……あ、あのさぁ…\n…。私をなんだと思ってるわけ……恥ずかしいでしょ、こんなポーズ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0103108" ]},
		{"command":[ "SETIMAGE", "0", "still_00028701_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「いくらエロエロなオナニストだって言ってもさ……。オナニーって、ほら…\n…。一人でこっそりするモノだし？　人に見せるとか初めてだし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0103109" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「で、でも……お兄にだったら見せてもいーかなって……思っただけ！　ねえ\n、誰にも言わないでよ。ここですること。バカ姉にも言っちゃダメだから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0103110" ]},
		{"command":[ "SETIMAGE", "0", "still_00028701_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「……ん……っ。お、男がどうやってシコシコするのかとか、ぼんやりとしか\n知らないけど……。女はさ？　こ、こうやって、指をつかって……するの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0103111" ]},
		{"command":[ "SETIMAGE", "0", "still_00028701_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「場所は、どこでもいい。ムラムラしたら、サックリヌくために……適当なと\nころで足を広げて……、指でアソコをイジりやすくして……こうやって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0103112" ]},
		{"command":[ "SETIMAGE", "0", "still_00028701_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「んぅ……♪　くちゅくちゅって、わざとおっきく水音をたてながら……おま\nんこを撫でたり……はぁっ、刺激したりするんだぁ……。んっ、あっぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0103113" ]},
		{"command":[ "SETIMAGE", "0", "still_00028701_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「気分がノッてる時だと……んんっ、こうやってぇ♪　空いてる方の手でおっ\nぱいの先っちょも、クリクリいじったり、つねったりして遊んだり……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0103114" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「頭の中で想像する……。えっちなことをしてる自分、時にはえっちなことを\nされている自分……。はぁ、はぁ、もしかしたらマゾなのかも……えへへ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0103115" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「優しく、ラブラブしながらキスしたり……んっ、触り合いっこしたりする妄\n想より……っ、ぁっ、ご、強引に襲われたり犯されたりする妄想が好き」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0103116" ]},
		{"command":[ "SETIMAGE", "0", "still_00028701_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「そういうの、頭の中で考えるだけで……ほら、あっ♪　おまんこがぐちゅぐ\nちゅになっちゃう……。はぁっ、はぁ、水っ気多いんだ、私……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0103117" ]},
		{"command":[ "SETIMAGE", "0", "still_00028701_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「……あれ？　もしかして……、はぁっ、お兄、私のオナニー見ながらおちん\nちんおっきくしてる……？　あは……♪　人の自慰とか見るの初めて？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0103118" ]},
		{"command":[ "SETIMAGE", "0", "still_00028701_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「だったらもっと近くで見ていいよ……。ほら♪　ほら、ほら、ほらぁ……♪\n　今指で、おまんこの中掻き回してる……何度も手を出し入れしてるよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0103119" ]},
		{"command":[ "SETIMAGE", "0", "still_00028701_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「すっごくヌルヌルしてて……んんんっ、スムーズにおまんこ、いじりまくれ\nるのは……あっぁっ、お兄のおかげ……♪　あんっ、もっと見て♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0103120" ]},
		{"command":[ "SETIMAGE", "0", "still_00028701_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「お兄に見られてるって意識すると……！　あっ♪　いつもより何倍も気持ち\nいい……！　あっ！　あっ、夢中でおまんこいじいじしちゃうぅ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0103121" ]},
		{"command":[ "SETIMAGE", "0", "still_00028701_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「あぁっ……！　んああああっ♪　あぁッ、ああああ……！　高速でっ、指を\n入れたり出したりっ♪　奥に突っ込んだり、ぬるぅって抜いたりぃっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0103122" ]},
		{"command":[ "SETIMAGE", "0", "still_00028701_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「こうやって♪　腰をくねらせながらオナニーしてっ♪　あっぁっ、一緒に乳\n首をこうやってギュゥ～ってつねると……！　っあああああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0103123" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「イクッ♪　イクイクぅううっ♪　ひぃっ、あぁっ！　あああああっ♪　ちっ\nちゃいおっぱい揺らしてイッちゃうぅっ、んんんん……！　あひぃいっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0103124" ]},
		{"command":[ "SETIMAGE", "0", "still_00028701_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「お兄ぃいい～っ♪　見てるぅ！？　見えてるぅう……！？　あっ、私のちっ\nちゃなおっぱいっ、ピンク色の乳首から今、母乳、母乳が噴き出したでしょ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0103125" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「こ、これ、ねぇ♪　乳首をいじりすぎて、一人で開発しすぎちゃって……っ\n！　妊娠してないのにおっぱい出るようになっちゃったのっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0103126" ]},
		{"command":[ "SETIMAGE", "0", "still_00028701_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「それくらい、たっくさんオナってるってこと♪　いやらしいでしょ、スゴく\nない……っ？　っあぁ、すればするほどどんどん身体が敏感になってっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0103127" ]},
		{"command":[ "SETIMAGE", "0", "still_00028701_01_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「少しこするとイッちゃう弱点もい～っぱいあるんだよ……、あっ、こことか\nっ♪　こことか、あっぁっ、少しグリグリするだけで……んぁあああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0103128" ]},
		{"command":[ "SETIMAGE", "0", "still_00028701_01_13" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「イクッ♪　イクぅううっ……！　はーっ♪　はーっ、はーっ、はぁあああ～\nっ……♪　でも、い、一番好きなのは……ここ。よく見ててぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0103129" ]},
		{"command":[ "SETIMAGE", "0", "still_00028701_01_14" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「イジりすぎてておっきくなってきちゃったクリちゃん……♪　んんんっ、わ\nかる？　クリトリス……っ！　ここ、すっごく好きなんだ……あっあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0103130" ]},
		{"command":[ "SETIMAGE", "0", "still_00028701_01_12" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「女の子のクリって、男の人のぉ……、あっ、おちんちんみたいなもの、らし\nいよね……♪　つまり、すんごい気持ちイイってこと……！　っあっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0103131" ]},
		{"command":[ "SETIMAGE", "0", "still_00028701_01_13" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「ここっ、クニクニって指先で押し潰したり……はぁっ、はぁ、コスコスって\nこすったりぃ……、つまんだり、夢中でイジってると……はぁうううっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0103132" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「すぐっ！　すぐ高まってきちゃうん、だよっ……！　あっはっ♪　クリトリ\nスオナニーってホントすぐ気持ち良くなっちゃうからっ、トんじゃうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0103133" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「あうっ♪　あんっ、あぁううっ♪　私、男じゃなくて良かったぁあ……♪　\n男だったら毎日シコるのやめられなかったと思うっ……！　あっ♪　んぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0103134" ]},
		{"command":[ "SETIMAGE", "0", "still_00028701_01_14" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「やっばいぃいっ♪　またイキそぉ、今度はすっごい深くイキそうっ！　見て\nて、私がクリでイクとこ見てて、お兄ぃ……！　ああああああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0103135" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「んふぅううううっ！？　ごめっ……ゴメンんんっ！　き、気持ち良すぎて潮\n吹いちゃった！　あッ……！？　あっぁっあっ、止まんな……いぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0103136" ]},
		{"command":[ "SETIMAGE", "0", "still_00028701_01_17" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「ぴゅっぴゅっ！　ぴゅっぴゅって出てる、潮出てるぅっ……！　はしたない\nオナニー大好きっコでゴメンねっ……！　今最高に感じてるよぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0103137" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「んぁああっ！　ああっ、あああああ……！　なにこれぇっ、なにっ……！　\nああああっ、ヤバイぃっ……！　お兄がいるだけで感じ方ハンパないぃっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0103138" ]},
		{"command":[ "SETIMAGE", "0", "still_00028701_01_16" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「んっ、ぁああああっ……！　意識保てないぃい……！　おまんこキュンキュ\nン疼きっぱなしぃいい……！　イクッ、イクっ、イクイクぅううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0103139" ]},
		{"command":[ "SETIMAGE", "0", "still_00028701_01_17" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「んはぅううっ♪　あぁうううっ♪　お兄ぃっ……！　お兄ぃっ……！　気持\nちいいよぉおっ！　オナニー気持ちいいぃっ！　あああああっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0103140" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「はー……。……あ、ごめん。自分の世界に入っちゃってた……。その、さぁ\n？　人に見られながらするオナニーっていうのも……悪くないかもね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0103201" ]},
		{"command":[ "SETIMAGE", "0", "still_00028701_01_12" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「じっくりねっとり視姦されながら……っていうのは新鮮で気持ち良かった。\nハマっちゃったかも。……あー……余韻がすっごい。これはイイね……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0103202" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「ねえ……っ、まだイキたりないから……。もう少しだけ、見ててくれない…\n…？　はぁ、はぁ、二度目はすぐにイッちゃうと思うし……あっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0103203" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「迷惑かけない、からっ……。ちょっと見ててくれればいいから……！　っん\nっ……。うん……♪　そこでジッとしてて、視線だけちょうだい……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0103204" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「はぁっ……、はぁ、はぁっ、あぁあああ……♪　一回大きくイッておまんこ\n、超敏感になってるぅ……。愛液で指がヌチャヌチャだぁ……♪　んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0103205" ]},
		{"command":[ "SETIMAGE", "0", "still_00028701_01_13" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「このまま……濡れた指で、クリちゃんくにゅくにゅしてみるね……♪　っん\nんっ……ふぁああっ……。あったかぁい……♪　指溶けちゃう……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0103206" ]},
		{"command":[ "SETIMAGE", "0", "still_00028701_01_12" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「イキたてホカホカおまんこって、あっ……♪　おツユでヌルヌルで、ホンッ\nト触ってて気持ちいいんだよねぇ……。んぅ……んっ、んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0103207" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「この愛液のヌルヌルをぉ……♪　ビンビンに勃起した、ちっちゃなクリちゃ\nんになすりつけて、滑りを良くしてシゴくんだぁ。こう……こうっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0103208" ]},
		{"command":[ "SETIMAGE", "0", "still_00028701_01_13" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「こんな、ふう、にぃいいい……♪　あああああっ♪　すっごい♪　腰がビク\nビク痙攣してきたぁ……♪　今、おまんこをまったく触ってないでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0103209" ]},
		{"command":[ "SETIMAGE", "0", "still_00028701_01_14" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「そうするとぉ……、おあずけ食らって焦らされて、中がうねうねうねっちゃ\nうんだよね……♪　で、極限まで我慢してから……指を入れるとぉ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0103210" ]},
		{"command":[ "SETIMAGE", "0", "still_00028701_01_13" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「は、ぁうううううっ♪　あぁんんんっ♪　イイっ、キくぅうっ♪　イクぅう\nううう……っ♪　最ッ高に気持ちいいんだよぉおっ、これがイイのぉおっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0103211" ]},
		{"command":[ "SETIMAGE", "0", "still_00028701_01_11" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「は、ぁっ♪　お兄のおちんちん、想像しながら……この指を♪　ちんぽに見\n立てて中に入れる、のっ……！　あっ、お兄♪　お兄のおっきいっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0103212" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「お兄のおちんちん気持ちいいっ……！　太くて、硬くてぇ……っ♪　熱くて\n最強ぉおお……っ♪　はぁああっ♪　あぁんっ、ああぁああっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0103213" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「お兄ぃっ、どうっ……？　自分のこと妄想しながらオナッちゃう女の子……\n♪　好き、かな……っ？　あっ……、照れちゃう？　ふふ、くふふっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0103214" ]},
		{"command":[ "SETIMAGE", "0", "still_00028701_01_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「お兄のおちんちん想像しながら、指入れてると……！　あっ♪　どんどんう\nっとりしてきちゃうよ……、あっ、こんなに興奮しちゃうとか……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0103215" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「私っ……あっ、お兄のこと、んんっ♪　自分で思ってたよりずぅううっと好\nき、なのかもぉおおっ……！　んぁっ♪　し、知らなかったぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0103216" ]},
		{"command":[ "SETIMAGE", "0", "still_00028701_01_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「私っ……本当のエッチ、したことない、けどっ……！　するんだったら相手\nはお兄がいい、なぁっ♪　お兄としたい、お兄のがいいぃっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0103217" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「ね、ぇ……お兄♪　選んで……？　私がクリちゃんとおまんこと、どっちで\nイクか……っ♪　お兄の好きな方で、あっ、イキたい……っ、いいっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0103218" ]},
		{"command":[ "SETIMAGE", "0", "still_00028701_01_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「お兄に一番えっちなとこ、見つめられて、イキ方決めてもらって……！　お\n兄のこと考えながらイクから、それを最後まで見ててほしいの……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0103219" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「っんぅっ、どっち？　どっちでイクとこ見たい？　決めて、お兄……！　私\n、お兄の好きな方でイクよ、あっ……！　だめ、イクぅっ……イクっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0103220" ]},
		{"command":[ "WAITINPUT" ]},
				
		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「んっ、んんんんんん～っ♪　おまんこっ……♪　おまんこでイクのが見たい\nんだっ……♪　いいよ、中でイクっ、膣イキするっ、決めた……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0103301" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「ああっ……！　んああああっ、ん～～～～っ！　んんっ、んん～ッ……♪　\nお兄っ……！　お兄好きだよぉっ！　お兄！　お兄ぃいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0103302" ]},
		{"command":[ "SETIMAGE", "0", "still_00028701_01_20" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「まだ誰も使ったことないメガイラのおまんこっ……！　私のおまんこ、お兄\nのためにあけてあるからっ、お兄以外に触らせないからぁあっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0103303" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「はぁっ、あっ、あぁあああっ……！　いっぱいイッて、イキまくってっ……\n！　お兄好みのキツキツおまんこにしておくから、だからぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0103304" ]},
		{"command":[ "SETIMAGE", "0", "still_00028701_01_19" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「今度、私の指とかじゃなくて……っ、お兄のおちんちん、本物のおちんちん\nで犯してほしい、初めて奪ってほしいぃいっ……！　んはぅううっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0103305" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「お兄に犯されたいっ、お兄のモノにされちゃいたいぃいっ！　あぁああっ♪\n　妄想だけで、イクっ、いくらでもイケちゃうよぉおおっ！　あ～～～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0103306" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「っんんんん……！　はぁっ……はぁ、はぁ、はぁ……。ご、ごめんん……！\n　純粋に、女の子がオナるところを見せてあげたかっただけなのにぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0103307" ]},
		{"command":[ "SETIMAGE", "0", "still_00028701_01_18" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「な、なんか愛の告白？　みたいになっちゃったね……。最後。ヒ、ヒいてな\nい……？　イヤじゃなかった……？　一人ですっごい盛り上がっちゃった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0103308" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「私……生まれてはじめてだよ。オナニーより、エッチしたいって思ったの…\n…。もちろん、一人でするオナニーって自由で簡単でイイんだけどさ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0103309" ]},
		{"command":[ "SETIMAGE", "0", "still_00028701_01_19" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「……今度はエッチも経験してみたい……な。その時は、やっぱりお兄に頼み\nたい……。だからその時はお、お願いします。待ってるからね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「あっ♪　クリっ……？　クリでイクとこ見たいのっ？　いいよっ……♪　お\n兄っ……♪　クリトリス気持ちいいよ、イクっ……イッちゃうぅうっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0103401" ]},
		{"command":[ "SETIMAGE", "0", "still_00028701_01_13" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「はぁああっ♪　あぁっ、んぁああああっ……！　クリちゃんくちゅくちゅし\nてると、どんどん硬くなって、尖って……無限に気持ち良くなれるのっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0103402" ]},
		{"command":[ "SETIMAGE", "0", "still_00028701_01_23" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「だ、だからっ……！　もしお兄とエッチすることがあったらっ……！　あっ\n！　私のオナりすぎな敏感クリもいじってほしいっ、いいいいっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0103403" ]},
		{"command":[ "SETIMAGE", "0", "still_00028701_01_22" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「んぁああっ！　お兄ぃいいっ♪　クリトリス気持ちいいいっ……！　気持ち\nいいいいっ……！　あひぃいっ！　ひぃいいっ、ひぃいいんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0103404" ]},
		{"command":[ "SETIMAGE", "0", "still_00028701_01_23" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「一人でするだけでっ！　こ、こんなにお尻ガクガク震えてっ、おつゆびちゃ\nびちゃになっちゃうのにぃいっ、二人でしたらもっとすごいんでしょっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0103405" ]},
		{"command":[ "SETIMAGE", "0", "still_00028701_01_22" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「そんなのっ、耐えられるかわかんない！　オナニーだけでこんなっ……こん\nなにイイのにぃいいっ！　ああああああっ！　イクイクイクぅううっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0103406" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「っ……はぁああああ、ふぁあああああ……♪　さ、最後まで……。イクのが\n終わるまで見ててくれてありがと……。お兄……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0103407" ]},
		{"command":[ "SETIMAGE", "0", "still_00028701_01_23" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「なんでだろうね……。お兄には何もかも、安心してさらけだせちゃうってい\nうか……。一番恥ずかしいところも見てもらいたいっていうか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0103408" ]},
		{"command":[ "SETIMAGE", "0", "still_00028701_01_22" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「……甘えちゃってるのかも……。ウザくない？　平気？　……ん……。これ\nからも、こうやってエロいとことか見せちゃうかもしんないけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0103409" ]},
		{"command":[ "SETIMAGE", "0", "still_00028701_01_21" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「それでも一緒にいてくれたら嬉しい、し……。実はお兄のオナニーとかも見\nてみたいから、見せてくれる気になったら教えて？　いつでもいいからね」", "NORMAL" ]},
