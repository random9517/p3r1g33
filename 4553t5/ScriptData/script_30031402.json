{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000314_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「おいっ！　なに気を抜いておる！　もっとしっかりチ〇ポを勃起させぬか！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1404101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「今日の貴様の役割は余の肉バイブだ！　それ以上でもそれ以下でもないと思\nえ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1404102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「……なに？　ストレスを発散するために、貴様のチ〇ポを使わないで欲しい\nじゃと？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1404103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「貴様は余の下僕だ。ならば余がどう扱おうと勝手じゃろうが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1404104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「いいからそのままチ〇ポをマ〇コに当てておけ。勝手に動いたり挿れたりし\nたら、オシオキどころじゃすまさないからなっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1404105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んっ、んんっ……！　あっ、くふっ……！　やはり貴様のチ〇ポはいい……\n！　亀頭がむき出しじゃし、カリのデコボコ具合も最高じゃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1404106" ]},
		{"command":[ "SETIMAGE", "0", "still_00000314_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「こうして太ももで挟みながら擦っていると、クリトリスにも当たって……！\n　あっ、あっ！　くふっ、んっ！　はっ、ああぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1404107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ふふっ……チ〇ポの先端から我慢汁が出て来たようじゃな……！　どれ、こ\nれをワレメとチ〇ポに塗って、さらに滑りをよくするとしよう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1404108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「あふっ、くっ、ああぁんっ……！　ヌルヌルした感触がマ〇コのあたりに広\nがっていく……！　やはり滑りがいいと気持ちいいな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1404109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んくうぅ……！　チ〇ポがビクビク跳ねるたびに、クリトリスがトントンさ\nれて……！　余のマ〇コからもエッチな汁が溢れてきよる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1404110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ふふっ……そんなに激しく息を乱してどうしたのだ？　よもや、チ〇ポをマ\n〇コに挿れたいとでもいいたいのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1404111" ]},
		{"command":[ "SETIMAGE", "0", "still_00000314_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「あひっ、んんっ……！　またチ〇ポが激しく跳ねてきよる……！　まったく\n、口ではなくチ〇ポで返事をするとは相当な変態じゃな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1404112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「だが、その素直な反応は嫌いではない。ちゃんとお願いすれば、挿れさせて\nやるが……どうする？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1404113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「あははっ！　挿れたがりの下僕チ〇ポを、女王様の高貴なマ〇コに挿れさせ\nてくださいと来たかっ！　自分の立場をよく理解しておるようじゃな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1404114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「いいだろう。余は寛大じゃからな。望み通りマ〇コに挿れさせてやるとしよ\nう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1404115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んっ、おっ、おおおぉ……！　下僕の勃起チ〇ポが余のマ〇コに入ってきて\nおるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1404116" ]},
		{"command":[ "SETIMAGE", "0", "still_00000314_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「この太さと硬さ……！　やはり貴様はチ〇ポだけは優秀だな……！　んっ、\nぐっ、あっ……！　はぁ、んんっ！　あっ、あああぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1404117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「しっかりと奥まで突き入れろ……！　忠誠を誓うように、余の子宮口にチ〇\nポの先端でキスをするのじゃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1404118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「はぁ、んっ、あはぁ……！　どうじゃ、余のマ〇コの感触は……決して怒ら\nぬから、素直に答えてみよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1404119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ほう……肉厚で引き締まっており、動かなくてもチ〇ポが締め付けられるよ\nうな感触がして気持ちいいと……悪くない感想じゃな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1404120" ]},
		{"command":[ "SETIMAGE", "0", "still_00000314_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ならばもっと締め付けてやるとしよう。貴様は余の締め付けに抗いながら、\nしっかりと腰を動かせ。いいな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1404121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んっ、あっ！　あっ！　そ、その調子だ……！　小刻みに動くのと、大きく\n動くのを、リズムよく繰り返せ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1404122" ]},
		{"command":[ "SETIMAGE", "0", "still_00000314_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「余のマ〇コのヒダをカリ首でひっかきながら、何度も出し挿れしろ……！　\nおっ、おおおぉ……！　そこ、気持ちいい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1404123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「Ｇスポットのあたりもしっかりと狙え……！　チ〇ポを思いっきり反らして\n、突き立てるようにするのじゃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1404124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「あっ！　んひっ、あはぁ！　浅いところと深いところを交互に擦られるたび\nに、余のマ〇コからエッチな汁が溢れてきよる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1404125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ふっ、ぐっ、んんっ！　チ〇ポからも貴様の我慢汁が出ているようだな……\n！　余のマ〇コがヌルヌルのドロドロになっておるぞ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1404126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「そのまま子宮口にもチ〇ポを押し付けろっ……！　腰を突き出しながら、亀\n頭でグリグリと撫でまわせっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1404127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「おほおおぉ……！？　それ、気持ちいいぞっ……！　余の赤ちゃんの部屋の\n入口が、チ〇ポを当てられて悦んでおるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1404128" ]},
		{"command":[ "SETIMAGE", "0", "still_00000314_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ひぐっ、あっ、あひっ！　あっ、あっ！　もっとだ！　もっと激しく腰を動\nかせっ！　余のマ〇コを気持ちよくすることに意識を集中させろっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1404129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んんんっ！　はぁ、あっ！　はぁ、っああぁ！　気持ちいいのがヘソの下あ\nたりから、どんどん溢れてくるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1404130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「マ〇コの奥が自然と震えて……！　も、もう少しでイケそうじゃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1404131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んひっ！？　あっ、あぁっ！？　チ〇ポも激しく脈を打っておるっ！　なん\nじゃ、貴様もイキたいのかっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1404132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「イキたいのならば、相応の言葉で余に懇願せよっ！　さもなくば、イクこと\nを許さんぞっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1404133" ]},
		{"command":[ "SETIMAGE", "0", "still_00000314_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ほらっ！　イキたいのであろう！　余の大切なマ〇コに、下僕如きの精子を\n吐き出させてくださいと言ってみせよっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1404134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「あっ！　あっ！　そ、そうだっ！　その調子で余に情けを乞いながら……無\n様に射精するといいっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1404135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んくううぅ……！　ドロドロした液体が、余のマ〇コに流れ込んできておる\n……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1404136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000314_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ぴったりと子宮口にチ〇ポの先端が当たって、キスをしながら射精されて…\n…おっ、おおぉ……！？　おほぉぉぉ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1404137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「この子宮が精子で満ちる感覚……！　やはり膣内出しはいいものだな……！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1404138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「あっ！　イクッ……！　イクッ……！　下僕の子種を受けながら、イッてし\nまうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1404139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「余がイキ終えるまで、射精を止めるんじゃないぞ……！　くっ、あっ……！\n　はぁ、あひっ……んはあぁぁぁぁぁっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1404140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、はああぁ……！　子宮で感じる幸福感……やはりセックスは\n膣内出しに限る……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1404201" ]},
		{"command":[ "SETIMAGE", "0", "still_00000314_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「余のストレスも解消されていっておる……やはりイライラしたときは、肉バ\nイブを使うのが一番じゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1404202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「……おい、貴様。なぜ勝手にチ〇ポを抜こうとしておる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1404203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「１回出したからもう終わりだと思ったじゃと……？　ほう……貴様は余が１\n回膣内出しされた程度で、満足するとでも思っておるのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1404204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「これはしっかりと、チ〇ポに教育を施してやる必要があるようじゃな……！\n　おい、下僕っ！　そのまま抜かずにチ〇ポをおっ勃て続けろっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1404205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んっ！　んんっ！　くっ、あっ！　あぐっ、んふぅ！　どうじゃ！　余の腰\n使いは最高であろうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1404206" ]},
		{"command":[ "SETIMAGE", "0", "still_00000314_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「こうして腰を動かし、尻を貴様に打ち付けるたびに、パンパンといやらしい\n音が鳴っておるぞっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1404207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「マ〇コからも精液が逆流して溢れ出しておる……！　カリが膣内をえぐるた\nびに、ヒダに精液が染みついてきよるわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1404208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ふふっ……！　こうして激しく動かし続けると、限界が早そうだな……！　\nならば違う責め方をしてみるとしよう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1404209" ]},
		{"command":[ "SETIMAGE", "0", "still_00000314_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ぐっ、んんっ！　こうして、奥の奥までチ〇ポを押し込んで……！　はぁ、\nあっ、ぐっ……あはあぁぁぁ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1404210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「子宮口にチ〇ポが刺さる感覚……これはヤミツキになりそうじゃな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1404211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ふふっ……貴様も気持ちよさそうな声が出ておるようじゃが……本番はここ\nからじゃぞ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1404212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ひっ！　んぎっ、あっ、あっ！？　ど、どうじゃ！　チ〇ポを締め付けられ\nながら、鈴口を子宮口でグリグリと撫でられるのは最高じゃろう！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1404213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「腰を前後に動かすのもいいが、気持ちのいいところを重点的に責めるのも…\n…んっ、ぐっ！　た、たまらないねぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1404214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「あまりの気持ちよさに、マ〇コの中でチ〇ポがビクビク跳ねておるわっ……\n！　ほれっ、余の動きに合わせて貴様も腰を思い切り動かせっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1404215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「あっ！　あっ！　んっ、あああぁっ！　そ、その調子だっ！　子宮の奥まで\n入るくらい、激しく突き入れるのじゃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1404216" ]},
		{"command":[ "SETIMAGE", "0", "still_00000314_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ぐっ！　おっ、おほぉ！？　んほぉぉぉ！？　チ〇ポが子宮口を突き抜けて\n、本当に奥まで刺さってしまいそうじゃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1404217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「こんなの、気持ちよすぎてイッてしまうっ！　くっ、来るっ！　気持ちいい\nのがすぐそこまで来ておるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1404218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ひぎぃ！？　き、貴様のチ〇ポも激しく脈打っておるなっ！　いいだろう！\n　余の絶頂に合わせて、貴様も果てるがいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1404219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「あっ！　あっ！　ひっ、んひぃ！？　イッ、イクッ！　イクッ！　あっ、う\nぐっ、んんっ！　あっ、イクッ……イクぅぅぅぅぅっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1404220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「おほおおおぉぉぉ！？　また熱い精子がびゅーびゅー出ておるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1404301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000314_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「開いた子宮口から、直接子宮に精子が流れ込んできて……！　あっ、あっ！\n　赤ちゃんの部屋にびゅくびゅく当たるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1404302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「この孕まされる感覚……！　本当にたまらないねぇ！　ぐっ、んふっ！　イ\nッ、イクッ！　こんなの、またイクぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1404303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「あああぁっ！　イクの止まらないっ！　気持ちいいのが、次から次に溢れて\nくるぞっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1404304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「おいっ、下僕っ！　そのまま最後まで精子を出し切れっ！　一滴たりとも余\nのマ〇コから溢れさせるでないぞっ！　んっ、んっ！　んんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1404305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、あはぁ……中々良い射精だったぞ……褒めて遣わす……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1404306" ]},
		{"command":[ "SETIMAGE", "0", "still_00000314_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「余の心も身体も満足じゃ……やはり持つべきものは変態で性欲の強い肉バイ\nブじゃな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1404307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「……ん？　そんなにチ〇ポを動かしてどうした？　肉バイブ扱いがそんなに\n不満か？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1404308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ふふっ……不満ではなく、チ〇ポが満足できていないという意味か……あは\nはっ！　やはり貴様は最高じゃな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1404309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「いいじゃろう。その性欲に免じて、もう１度余を満足させることを許す。し\nっかりと腰を動かし、余をイカせてみせよっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1404310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「あひぃぃぃ！？　ち、チ〇ポがマ〇コから抜けて……！？　あっ、あんっ！\n　そんな、チ〇ポが抜ける感覚が気持ちいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1404401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000314_02_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ひゃうっ！？　あっ、んんんっ！　余の身体に下僕の精子がびゅるびゅるか\nけられておるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1404402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「熱と臭いが身体に染みついてしまいそうじゃ……！　あっ、あっ！　まだチ\n〇ポが跳ねて、精子が飛び出て……んふぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1404403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「チ〇ポが動くたびにクリトリスに亀頭が当たっておるっ！　イキながら、ク\nリトリスを弄られておるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1404404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「こんなのまたイッてしまうではないかぁ！　んっ、あああっ！　ひっ、あぐ\nっ、あはぁぁぁぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1404405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「くっ、うぐっ……！　き、貴様……！　下僕の分際で、余の許可もなくチ〇\nポを抜くとはどういうことじゃっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1404406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「セックスは膣内出しに限ると言った余の言葉を忘れたのかいっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1404407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「……ほう。あまりの気持ちよさに勝手に腰が動いて、勢い余って抜けてしま\nったと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1404408" ]},
		{"command":[ "SETIMAGE", "0", "still_00000314_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「快感の不可抗力とはいえ、貴様が余の言いつけを守らなかったのも事実じゃ\n。しっかりとバツを受けてもらうぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1404409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「なぁに、そう不安そうな声を出すでない。ただ少しばかり、この射精し終え\nたチ〇ポを刺激させてもらうだけじゃ……覚悟するんだねっ！！」", "NORMAL" ]},
