		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……い、今……私の身体に……電流のような刺激が通り抜けて\nいった……目が眩むような……特別な感覚だ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0103303" ]},
		{"command":[ "SETIMAGE", "0", "still_00016301_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「イッた……そうか……今、味わったのが、イッたという感覚か……オルガス\nムスは、オマンコの刺激で到達するものと思っていたが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0103304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「乳首の刺激と……この精液の濃密な匂いでも、このような形になるのだな…\n…ん、ふぅ……あぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0103305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「まだチンポから出ているのか……んっ、もう少し挟んだら搾り出せるか？　\nんんっ……あっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0103306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「終わったか……ホッとした顔をしているな……なるほど、今のお前が賢者タ\nイムという状態か」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0103307" ]},
		{"command":[ "SETIMAGE", "0", "still_00016301_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「だが、私も似たような感覚かも知れん……もっと冷静に奉仕出来るかと思っ\nていたが……全く感覚は逆だった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0103308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「だが、思ったよりも悪いものではなかった。いや……確かに心地いい、生殖\nにこの感情が必要なのかはともかく、また味わいたい感覚だったぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「とにかく、上手くいったようで何よりだ。また、私を求めるようなことがあ\nれば、是非やらせてくれ……感謝する」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「チンポの先を見ろ……？　もしかして……私の顔に掛けたいのか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0103401" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「分かった……お前が、そうしたいならいいぞ……ぶっ掛けという奴だな……\n出してくれ……顔射……してくれっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「あっ！　んんっ、また……出てるっ……お前の精液が、私の顔に……降り注\nいでいるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0103403" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016301_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「んんっ！　はぁぁ……あっ、ふっ……あぁっ……ドロドロがへばりつく……\nんふぁ……すごい……量だ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0103404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「それに……今、電流が流れるような……全身に不思議な痺れが走って……あ\nれは何だったんだ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0103405" ]},
		{"command":[ "SETIMAGE", "0", "still_00016301_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「イッた……そうか……今、味わったのが、イッたという感覚か……オルガス\nムスは、オマンコの刺激で到達するものと思っていたが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0103406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「乳首の刺激と……この精液の濃密な匂いでも、このような形になるのだな…\n…ん、ふぅ……んわぷっ！」", "NORMAL" ]},
