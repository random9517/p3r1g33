{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016301_01_02" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「うむ……よし……こんな感じだった筈だ……は……ふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0103101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「どうだ……？　地球では女達がこうしてオッパイでチンポを挟んで、パイズ\nリするんだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0103102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「少なくとも、大きさについて地球の女達に遅れを取ることはない筈だ。それ\nとも、何か問題があるか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0103103" ]},
		{"command":[ "SETIMAGE", "0", "still_00016301_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「そうか、何も問題はないな。その割には、今ひとつ釈然としない顔をしてい\nるようだが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0103104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「何……？　妙に詳しいのが気になるのか？　ふむ……地球の男は細かいこと\nを気にするのだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0103105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「別に難しい話ではない。今日の、この絆を深めるという行為に当たって、オ\nスへの奉仕手段というものを予習しただけだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0103106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「お前達が使っている機械や書物など、資料には事欠かなかったぞ。更に言う\nなら、お前の仲間にも好みの傾向は聞いている」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0103107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「例えば、お前は卑俗的な言葉遣いが好きだと聞いた。ペニスよりもチンポ…\n…ヴァギナよりもオマンコだったか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「より羞恥的な感情が乗れば興奮度が増すと聞いたが……生憎と、その機微は\n私では上手く再現することが出来ない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「だから、この先は物理的な接触を密にすることで、足りない分を補っていこ\nうと思う。何か不満があれば、すぐに言うがいい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「ふむ、問題ないようなら始めるぞ。こうして……チンポを挟み込む……んっ\n……ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0103111" ]},
		{"command":[ "SETIMAGE", "0", "still_00016301_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「これは……なるほど……確かに、谷間の中で……チンポが大きくなっていく\nな……んく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「予想していたより、体温も高い……。これは、平常時よりも感情が揺れてい\nるからか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0103113" ]},
		{"command":[ "SETIMAGE", "0", "still_00016301_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「おっと……チンポ自体もよく動くんだな。しっかり挟んで捕まえていないと\n……滑り落ちてしまいそうだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「改めて……扱くぞ……んっ…………どうだ、この感じで……よさそうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0103115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「あ……ふっ、んっ……く……んっ……何とも言えない感触だな……硬さと柔\nらかさが共存し……熱が身体中に纏わりつく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「上に上げては……戻し……また、下げて……繰り返していく……んっ、くっ\n……チンポがおっぱいによく……吸い付いてくるな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「こうして……肌と肌が重なりあう刺激……敏感なチンポならば……心地いい\nのだな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「私のおっぱいはどうだ……？　んっ、柔らかいか……そうだな、この姿は…\n…私の本質的なイメージをお前に合わせて投影しているようなものだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「それで興奮するというのならば……やり方は合っていると、そういうことだ\nな……んっ、んふっ……は……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0103120" ]},
		{"command":[ "SETIMAGE", "0", "still_00016301_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「……んっ、だが……なるほど……単純な接触でどうにかなるものかと思って\nいたが……んふっ、予想以上に……心地いいな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「んくぅ……これは……私の身体にも……影響が出ている……奇妙だ……は…\n…ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「……普通に、任務をこなしている筈なのに……意識が……んっ、揺さぶられ\nる感覚が……ある……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「はぁ……んふっ、私の呼吸が乱れる……？　そんな筈は……だ、だが……ん\nっ、ふっ……んくっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「あぁ……身体が自然に動いてしまう……んっ、チンポに擦り付けたくて……\n堪らなくなっている……はっ、あっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「どうしたんだ……お前の方からも腰を振って……はぁっ、おっぱいを……犯\nしたくなった……んんっ、そう、なのか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0103126" ]},
		{"command":[ "SETIMAGE", "0", "still_00016301_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「ならば……私も、動きを合わせて……んっ、おっぱいで……強く挟むっ……\nんっくぅ……あっ、はっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「このまま、上に持ち上げて……下に戻して……大分……タイミングが掴めて\n来たぞ……はぁっ、んっ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「んっ……どうした、表情が変わったぞ……少し強くし過ぎたか……？　いや\n……違う、これは……射精が近い……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0103129" ]},
		{"command":[ "SETIMAGE", "0", "still_00016301_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「そういうことか……それで、チンポがこんなにビクビクと震えているんだな\n……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「はぁっ、くぅっ……更にチンポが……熱くなって……んんんっ、前より膨ら\nんでいるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……この調子で続けたら……出るんだな……あっ、ふっ、いいぞ\n……何も遠慮することはない……その為の行為だからな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「あぁ……構わない……このまま、私の中に出してしまってくれっ……おっぱ\nいだ……おっぱいの中にっ……射精しろっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「んんんっ！　あっ、はぁぁぁぁぁぁぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0103134" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016301_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「んぁっ……あぁ……射精が、始まった……私のおっぱいの中に……ザーメン\nが流れ込んで来る……ん、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0103135" ]},
		{"command":[ "SETIMAGE", "0", "still_00016301_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「生温かく……粘度があり……生臭い……んっ、気色のいいものではない……\nふっ、んく……あぁ……映像より、多く出ている……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0103136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「ぬかるんで……はぁ……ねっとりしたモノが……あ……ふ……肌に染み込ん\nでいくような……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0103137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「精液の味は……ちゅぷ……んっ、微かな甘みと苦味が混在して……複雑だ…\n…んむ、食事より美味いものではないようだな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「当たり前か……？　しかし、何事も実際に体験してみなければ分からない。\nそれは、私が地球に訪れて何度も感じたことだからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「いずれにしても、パイズリでチンポを射精させられたことは何よりだ。無事\nに任務完了だな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「と……思ったのだが、どうやらお前はまだ、これで満足という訳ではないよ\nうだな。知っている、抜かずに連発という奴だろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0103201" ]},
		{"command":[ "SETIMAGE", "0", "still_00016301_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「もちろん、その可能性は予め考慮に入れていた。だから何の問題もなく続き\nは出来るぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「ちょうど射精で、谷間もぬるぬるしているからな。より、チンポを気持ちよ\nくさせてやれる筈だ……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0103203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「あ……ふっ……んっ……おぉ……さっきより、よく滑ると……んっ、肌に伝\nわる刺激も……また変わってくるな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0103204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「確か、一度出した後は……敏感になっているが、ある程度は耐えられると…\n…そういう状態だったな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「うむ、これも参照したデータによる推測だ。だから、より動きを大きくして\nやる必要がある……こうして……んっ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0103206" ]},
		{"command":[ "SETIMAGE", "0", "still_00016301_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「同時にではなく、左右のおっぱいを交互に……すれ違わせるように……ずり\nずりと……擦り上げていく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「は……ふっ、こうすることで……あっ、んんっ……刺激に不規則性が生まれ\n……身構えないことで、快感が増していく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「はあ……んっ、どうだ……他にして欲しいことはあるか……？　ん……何…\n…乳首……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0103209" ]},
		{"command":[ "SETIMAGE", "0", "still_00016301_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「この先端を……チンポの先に、押し当てればいいのか……分かった、言う通\nりにしてみよう……んっ……ひぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0103210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「あっ……これは、い、いつの間に……私の乳首が、敏感になっていた……？\n　も、もう一度……あひぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0103211" ]},
		{"command":[ "SETIMAGE", "0", "still_00016301_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「あぁ……何だ、んっ……鮮烈だ……こ、この状態でパイズリをするのか……\nんっ、んふぅっ、んっ、くっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「あぁ……はっ、あっ……私の方が……あっ、冷静で……いられないっ……あ\nくぅんっ、あおっ、あ……くぅんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「んくっ……何をジロジロと見ているんだ……わ、私の表情……？　切なげな\n様子が……いい……？　んくっ、あっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0103214" ]},
		{"command":[ "SETIMAGE", "0", "still_00016301_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「確かに……お前の視線が……あっ、ふっ……はぁっ、私の意識を……乱して\nいるっ……んっ、これは、おっぱいの刺激だけじゃない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0103215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「心臓が……高鳴るっ……はぁっ、気持ちいい……そうか、これが気持ちいい\nのか……あっ、おっぱい……気持ちいいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0103216" ]},
		{"command":[ "SETIMAGE", "0", "still_00016301_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「お前のチンポも……震えている……んっ、感じて、いるのか……強く挟まれ\nるのが、心地いい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「また、出したくなっているんだな……よし……思い切り挟んでやる……その\nまま乳首をチンポに押し付けるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0103218" ]},
		{"command":[ "SETIMAGE", "0", "still_00016301_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「あひぁっ！　あくぅっ……チンポがまたビクビクしているっ……あぁっ、出\nしてくれっ……また精液っ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「どこに……んっ、どこでも……構わないっ……お前の欲望を、私の身体の…\n…どこにでもっ……思い切りぶちまけろっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「もう一回……おっぱいに……中出し……んっ、あぁ、いいぞ……出してくれ\n……私のおっぱいマンコに……中出ししてくれっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0103301" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「あっ！　んんっ……出てる……私のおっぱいが……精液に浸されている……\nんぁっ、はぁぁぁんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0103302" ]},
