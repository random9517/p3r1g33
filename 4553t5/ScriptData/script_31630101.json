		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「まだ残っていたのか……今度こそ終わりでいいんだな？　んふぅ……たっぷ\nり掛けて満足したか……？」", "NORMAL" ]},
