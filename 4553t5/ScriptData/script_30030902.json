		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んふっ、ちゅぱっ、もちろん……あんたのしたいようにしてっ……中でもっ\n……ザーメンシャワーでもっ、なんでもぉっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0904217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んっ、くぅっ、あたしもオマ○コ締めるからっ……んくぅっ、イキたいっ…\n…一緒にイクぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0904218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あっ、んぁっ、あぁぁぁっ！　最後のっ……激しいのっ、来てる！　オマ○\nコっ……ずぶって奥ぅっ……グリグリされてっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0904219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「はへぁぁぁっ、イクッ……も、もうイクッ……！　あたしもっ、んぁぁっ、\nオマ○コッ……イッくぅぅぅぅぅぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0904220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んへぁぁぁぁぁっ……中っ……あっ、あぁぁっ、また新しいのビュクって来\nたぁっ！　オマ○コ……熱いのっ、中出しっ……ビュクビュクっ……してるぅ\nっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0904301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000309_02_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あぁぁっ、受精オマ○コ……ピリピリするぅ……んはぁぁ……ずっと気持ち\nいいままぁ……ふわふわになってるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0904302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んっ、あぁ……出してぇ……もっと子宮いっぱいにしてぇ……あんたの子種\nぇ……残さずしっかり植え付けてぇぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0904303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「さ、最後の一発も……ちゃんと出してぇ……また、あたしのこと……イカせ\nてぇ……んぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0904304" ]},
		{"command":[ "SETIMAGE", "0", "still_00000309_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あっ、来たっ……来たぁっ……とどめの中出しぃっ……はぁぁん……気持ち\nいい……オマ○コ、もう入らない位出てる……あぁぁ……いい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0904305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ、はぁっ……あぁ……全部、出したか……？　ふふっ、そりゃ\nよかった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0904306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んふぅ……本当にすごいオチ○ポだよ……まだ、お腹の中で、しっかり存在\n感を残して……ちょっと震えてるかい……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0904307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あっ……繋がってる所……垂れちまって……だ、だめだ……せっかく出して\nくれた精液なのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0904308" ]},
		{"command":[ "SETIMAGE", "0", "still_00000309_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「え……ま、またイヤになる位出してくれるって……？　む……そうだね、あ\nんたがそう言うなら、細かいことは気にしないようにするよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0904309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「それで……次はいつになるんだい？　何だったら、この後すぐからでも……\nふふ……あたしは一向に構わないよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0904310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んぁっ……！　あっ、オチ○ポ……抜け……ひぁぁぁんっ！　あっ、精液っ\n……ビュクって出たぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0904401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000309_02_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んぁぷっ……はぁん……ぶっ掛けられてる……ドロドロのザーメンシャワー\n……はひぃ……きもひぃぃぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0904402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あふぁ……掛けてぇ……あんたのにおい……染み込ませてぇ……んへぁぁ…\n…また……あらひもイクッ……んんっ、イクぅぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0904403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あぁ……ま、またオチ○ポの先が震えてる……これ、出る瞬間だな……？　\nそこっ、ここにぃ……あっ、掛けてぇ……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0904404" ]},
		{"command":[ "SETIMAGE", "0", "still_00000309_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ふはぁぁ……んちゅぷっ、はぁ、べとべとだ……栄養たっぷりの新鮮なザー\nメンミルクぅ……中でも外でも味わってるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0904405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んふぅ……あぁ……終わった？　んっ、今度こそ落ち着いた……？　はふ…\n…そうか、お疲れだったな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0904406" ]},
		{"command":[ "SETIMAGE", "0", "still_00000309_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あぁ、ちゅぱっ……んっ、濃いな……これなら、中からじゃなくて外からで\nも孕んじまいそうな……ふふっ、流石に言い過ぎか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0904407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んっ、あぁ……漏れて来てる……んっ……駄目だ、ちゃんと締め付けないと\n……んふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0904408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「え……ま、またイヤになる位出してくれるって……？　む……そうだね、あ\nんたがそう言うなら、細かいことは気にしないようにするよ」", "NORMAL" ]},
