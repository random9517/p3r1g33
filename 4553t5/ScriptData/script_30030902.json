		{"command":[ "PLAYVOICE", "v2_003_0904119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「オチ○ポがっ……あたしをメチャクチャにしてるっ！　オマ○コっ……犯し\nまくってるぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0904120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「くぅんっ！　あぁっ、すごいよっ……んはぁぁんっ、硬くてっ……太いのっ\n……何度もめり込んでぇっ……オマ○コのヒダっ……よじれてぇっ……」", "NORMAL" ]},
