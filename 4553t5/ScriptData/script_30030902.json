		{"command":[ "SETIMAGE", "0", "still_00000309_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「そりゃあ、バレバレさ……何せ、あたしのオマ○コが……直接感じてるんだ\nから……って言うより……」", "NORMAL" ]},
