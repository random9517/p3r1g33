		{"command":[ "PLAYVOICE", "v2_003_0904131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「はぁっ、あんっ、あぁっ……腰が……勝手に動くぅっ、カクカクしてぇっ、\nあぁっ、こんなとこぉっ……絶対に見せられないっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0904132" ]},
		{"command":[ "SETIMAGE", "0", "still_00000309_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
