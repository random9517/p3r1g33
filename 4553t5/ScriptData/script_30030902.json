		{"command":[ "SETIMAGE", "0", "still_00000309_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ、やっと……落ち着いて来たよ……んくぅ……でも、まだ身体\nが疼いてる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0904201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「って訳で……落ち着いたら、このまま抜かずに……もう一回……いいだろう\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0904202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ふふっ、ダメだ……離さないよ……んっ、こうして……ほら、オマ○コを…\n…キュウッて……んくぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0904203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あんっ……締め付けると……んふっ、チ○ポがまたビクンって……んぁっ、\n暴れたがってるのが分かるよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0904204" ]},
		{"command":[ "SETIMAGE", "0", "still_00000309_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
