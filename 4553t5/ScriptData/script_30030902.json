		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あぁぁ……けど、あたしが欲しいんだから……あんたの、子種……気持ちよ\nく出して欲しいんだから……見せるしかないんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0904103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んっ、く……ほ、ほら……ここだよ……この……ひくひく震えて……入り口\nがじゅくって濡れてるオ、マ○コ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0904104" ]},
		{"command":[ "SETIMAGE", "0", "still_00000309_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あぁ……まじまじと見られてるぅ……ヌラっと、浅ましく汁を垂らしてる所\n……全部……バレてるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0904105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「はぁぁ……あっ、あぁっ、それだよ……あぁ、その、ビンと反り返ってる…\n…ぶっといオチ○ポぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0904106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「その赤黒い、ギチギチのオチ○ポを……この、ヌルヌルオマ○コの中に入れ\nて……いっぱいっ……ズボズボして欲しいんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0904107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「それで……中を、好きなようにかき回して……んっ、何度も何度も突いてっ\n……はぁぁっ、奥にっ……たっぷり精液を……注ぎ込んでっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0904108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あぁっ、とにかくっ、チ○ポが欲しいっ、オチ○ポがいいんだっ！　お願い\nだからっ……早く、その太いのをっ……ハメてっ……来てぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0904109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んぁぁぁぁぁぁぁーーーーっ！　あぁっ、はぁぁぁんっ！　入って……来た\nぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0904110" ]},
		{"command":[ "SETIMAGE", "0", "still_00000309_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あぁぁっ……一気に、届いてるぅっ！　オチ○ポっ、おぉっ、奥ぅっ、オマ\n○コッ……くぅぅ……ずりゅって、ハマるぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0904111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「はぁぁぁ……あぁ、んっ、分かるに……決まってるよ……こんな、ぶっすり\nとやってくれたらぁ……中で、オチ○ポ膨らんでる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0904112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んんっ、最初は短小……包茎……早漏なんて……勝手に思い込んでたけど…\n…実際は全く逆……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0904113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ぶっとくて……ズル剥けで……はぁっ、どこまでもねちっこくて……あぁっ\n、今も……はぁ、あたしをいっぱいにしてる……すごい、やつぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0904114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んんっ、あぁ……こうしてるだけでも、はぁぁ……中でとくんって脈打って\nるの……感じてぇ……き、気持ちいい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0904115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「さ、さあ……中がヌルヌルなのは分かってるだろう……？　あんたの……思\nうままに、んっ、グリグリ……動いて……はふっ、感じさせとくれよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0904116" ]},
		{"command":[ "SETIMAGE", "0", "still_00000309_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んぁっ！　はんっ、あっ、あぁんっ……そうっ、あっ……そこぉっ、それっ\n、はひっ、あぉっ、おぉっ、おんっ、あぉぉっ！」", "NORMAL" ]},
