		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「バ、バカっ……当たり前だっ……恥ずかしいに決まってるだろっ、こんな…\n…あぁっ、大股開きで全部見せちまうなんて……大胆なポーズ……」", "NORMAL" ]},
