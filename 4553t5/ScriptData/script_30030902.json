		{"command":[ "SETIMAGE", "0", "still_00000309_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あんっ、はぁんっ、うんっ、くぅっ……あたしもっ……ずっと受け身じゃ…\n…ないよっ、ちゃんとっ……オチ○ポ……気持ちよくするっ！」", "NORMAL" ]},
