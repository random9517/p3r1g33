		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あぁっ、逞しいオチ○ポがっ……お腹の奥っ……ずんずんっ、来てるぅっ…\n…！　んぁぁっ、こ、これぇっ、あぁっ、これがいいっ！」", "NORMAL" ]},
