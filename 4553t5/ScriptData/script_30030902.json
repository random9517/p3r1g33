		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あぁ……まだ中がジンジンしてる……はぁぁ、今日もあんたのチ○ポにメロ\nメロにされちまった……んふぅぅ……」", "NORMAL" ]},
