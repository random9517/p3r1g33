		{"command":[ "PLAYVOICE", "v2_003_0904134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あぁっ、は、激しいっ！　あっ、本気のスパートっ……も、もうっ……出る\nのっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0904135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んっ、来てっ……このままっ！　子宮に直接……ザーメン浴びせてっ、あた\nしのことっ……んぁぁっ、孕ませてぇぇぇっ！」", "NORMAL" ]},
