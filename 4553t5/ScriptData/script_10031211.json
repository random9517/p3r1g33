		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「なんか知らんけど、めんどくせえ姫さんだなぁ……」", "NORMAL" ]},
