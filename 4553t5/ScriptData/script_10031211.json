		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「やれやれだ……どうにか元に戻ったようだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010116340001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "4", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まったく……えらい目にあったぜ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「いいか、だいたい察しはつくと思うが、今、我々は新しい技を試そうとして\nいる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090116340001" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「それで体が入れ替わったり、カツマの中に３人が入り込んでしまったりした\nのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010116340002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「そうだ、この技が成功すれば、きっとこの状況を打開できる。だからルナテ\nミス！　しっかりするんだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090116340002" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「にゃにぃ！？　私のせいで失敗したというのか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010116340003" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「そういうわけじゃない。だが、お前のメンタルに技の成否が大きくかかって\nいるのも確かだ。だから――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090116340003" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「だから？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「エロいことばかり考えるな！　日頃の欲求不満とか、ムラムラとか、そうい\nうのはいったん捨てろ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090116340004" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「なっ！？　ち、違っ！　わ、私は、私はそんな――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010116340004" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「やっぱり……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010116340001" ]},
		{"command":[ "SETCHARA", "0", "char_00000212_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「わかりやすい……フフフフ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010116340001" ]},
		{"command":[ "SETCHARA", "0", "char_00001801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「ルナテミス、いつもそんなことを考えてたの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_020116340001" ]},
		{"command":[ "SETCHARA", "0", "char_00001302_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「まったく、油断も隙もないわね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010116340001" ]},
		{"command":[ "SETCHARA", "0", "char_00001499_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「い、いや、待て！　私は別に……そんな……そんな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010116340005" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「いいや、私にはわかる。お前の頭の中は、カツマとのあんなことやそんなこ\nとでいっぱいだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090116340005" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「う、う、う、うわーーーーっ！　ア、ア、アナザー貴様いきなりナニを言い\n出すんだ言いがかりだ冤罪だ私はエロくないムッキーーーッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010116340006" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ひ、姫様、落ち着いて！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「そうだ！　いいか？　カツマにキスするというので、お前が思わず鼻息を荒\nらげてしまうのはわかるが、これはそういうことじゃない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090116340006" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「なにもわかってないじゃないかっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010116340007" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「これは、二人でカツマにあんなことやそんなことをしようというんじゃない\n。私たちの紋章の力を、カツマを媒介として融合する技だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090116340007" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「うるさいうるさいうるさーいっ！　私は、私はやましいことなんか考えてい\nないぞ！　ホントだぞ！　エッチなのはよくないと思います！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010116340008" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「姫様こそわかってないじゃないスか！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「とにかく、これは意味のあることなんだ！　仲間たちを救うために、やらね\nばならないことなんだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090116340008" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「……！　そ、そうか……みんなのため……なんだな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010116340009" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「そうだ。わかってくれたな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090116340009" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あ、ああ……わかった。これは決して、その……やましいことでも、うれし\nはずかしアッハンウッフンなことでもない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010116340010" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ないよな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010116340011" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「そうだ！　違う！　わかったな？　わかったらもう一回だ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090116340010" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「お、おう！　わかった！　そういうことなら私は遠慮なくヤる！　ヤルぞー\nっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010116340012" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なぜ半端なカタカナ表記！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「もういい、時間がない！　とにかく行くぞ！　フュー、ジョン！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090116340011" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
