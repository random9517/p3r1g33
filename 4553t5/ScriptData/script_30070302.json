{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0187" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「うむ……新婚初夜……いつもとすることは変わらぬとは言え、なかなかどう\nして少し気分も違う気がするのう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0304101" ]},
		{"command":[ "SETCHARA", "0", "char_00000703_01", "2", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ふふ……緊張という訳ではないが、このソワソワと落ち着かぬ感じ……気持\nちが高揚している証じゃな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0304102" ]},
		{"command":[ "SETCHARA", "0", "char_00000703_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「この場にいる以上、女王と幹部という関係は一切忘れなくてはならん。夫婦\nとして共に愛を確かめようではないか。のう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0304103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「んっちゅ……ちゅぷっ……ほう、いきなりキスは悪くないぞ？　それなら…\n…今日は旦那様にリードしてもらうとするか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0304104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ベッドの上……うむ……これでよいか？　んふっ……余のオマンコが、準備\n万端で蜜を溢れさせておるのが見えるじゃろ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0304105" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00000703_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「余の欲しがりオマンコに……旦那様の太い勃起オチンポ……思い切り串刺し\nにして欲しいのじゃ……ここじゃ……ここぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0304106" ]},
		{"command":[ "SETIMAGE", "0", "still_00000703_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「あっ……ふっ、んんんんんんぅぅっ！　あぁっ……ずぶずぶっ……一気に入\nって……来るぅぅぅっ！　くっ、んふぅぅぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0304107" ]},
		{"command":[ "SETIMAGE", "0", "still_00000703_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「んっ、あぁ……深い……いっぱいじゃ……オチンポが余のオマンコを広げて\nいくぅ……く、んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0304108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「あぁ……気持ちいいぞ……んっ、好きに動かしてくれ……おふっ、あぁ……\nくぅぅっ……んっ、あふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0304109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「はぁんっ、あぁっ、硬いおチンポが……出たり入ったり……あふぅ……ぐち\nゅぐちゅしておる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0304110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「あふっ、どうじゃ……？　余のオマンコ……緩くなっておらぬか？　ちゃん\nと、オチンポは楽しめておるか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0304111" ]},
		{"command":[ "SETIMAGE", "0", "still_00000703_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「その……色々と心配なのじゃ……こんな未亡人でも、本当に好きになってく\nれるのか……どうしても、気に掛かってしまう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0304112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「んぁっ、くぅんっ！　あぁっ、オチンポっ、勢いが……強くっ……！　くひ\nぃっ、あぉっ、んんっ、はっ、あぉぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0304113" ]},
		{"command":[ "SETIMAGE", "0", "still_00000703_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「どうしたんじゃっ……急にっ……あっ、んんっ、これが……証拠っ？　未亡\n人とかっ……何も関係ないっ……あっ、あぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0304114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「それだけ、余のことを……愛して……はぁんっ、あっ、あぁっ、それがっ、\nこのオチンポのっ、答えということかっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0304115" ]},
		{"command":[ "SETIMAGE", "0", "still_00000703_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「あひぁっ！　あぁっ、太いのがっ……何度も何度もっ……奥を小突いてっ…\n…！　ズリズリっ……襞を扱き上げて来るっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0304116" ]},
		{"command":[ "SETIMAGE", "0", "still_00000703_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「んっ、あぁっ、そうじゃったっ……余が……お主に惹かれたのはっ、こうい\nう男らしいところを見せつけられたからっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0304117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「お主ならっ……余の隙間を埋めてくれると……そう信じることができたから\nっ、はぁんっ、全てを託すことができるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0304118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「あっ、あぉぉっ、そこがいいっ！　オチンポの先がっ……気持ちいいところ\nをっ、グリグリっ……押し込んでくるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0304119" ]},
		{"command":[ "SETIMAGE", "0", "still_00000703_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「はぁぅっ、あぁっ、汁が出るっ……溢れてくるっ……気持ち……良すぎるっ\n！　はぁひぃっ、オマンコ……感じすぎるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0304120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「んぁぁっ、もっと……激しくっ、あぁっ、奥にっ……あっ、そこじゃっ、あ\nぁっ、そこぉっ、はひ、あぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0304121" ]},
		{"command":[ "SETIMAGE", "0", "still_00000703_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「んんんんんっ！　あっ、ふっ、はぁっ、はぁっ、今……軽く……一回、イッ\nてしまったぞ……旦那様の本気オチンポ……すごすぎじゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0304122" ]},
		{"command":[ "SETIMAGE", "0", "still_00000703_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「んっ、大事ない。イッたと言っても、ほんの少しじゃ……ちゃんと射精まで\n、オチンポを突きまくってよい……あっ、んぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0304123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「はぅっ、あぁぅっ、余も……ちゃんと、オチンポをよくするから……んくぅ\nっ、こうしてっ……ぎゅっとオチンポを締め付けるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0304124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ふふっ、表情が変わったぞ……？　今のは、好きなやつだったのではないか\n？　んっ、こうして……尻穴に力を入れるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0304125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「んふっ……！　こうしてオチンポを絞り込むと……みっちりと襞に絡みつく\n感じが……あぁっ、余のオマンコにも響いてくるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0304126" ]},
		{"command":[ "SETIMAGE", "0", "still_00000703_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「あぁ……気持ちいい……ずっとこうしていられる……はぁ、んんっ、延々と\n……腰を振っていられる……はっ、ひっ、んぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0304127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「んくぁっ……！　また、ずぶっと深くぅっ！　はぁっ、感じやすい場所……\n狙われておるっ、はぁぁんっ、亀頭がっ……食い込むぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0304128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「はっ、ふぁっ、あぁっ、このワイルドさがたまらぬのじゃっ……！　あぁっ\n、初夜なのにっ……ゴリゴリ来るドスケベセックスぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0304129" ]},
		{"command":[ "SETIMAGE", "0", "still_00000703_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「んぁぁぁっ、悦んでいるっ……全身がっ……オマンコがっ、熱くなってっ！\n　涎を垂らしまくってしまってるぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0304130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「はぁっ、んふっ、あぁ……キスぅ……んちゅっ、旦那様……もっと繋がりた\nい……一つになって、絡み合いたい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0304131" ]},
		{"command":[ "SETIMAGE", "0", "still_00000703_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「あんむ、りゅぷっ、あぁ……熱い……身体が燃えるぅっ……はぁぁっ、また\n気持ちいいのが上がってくるっ……奥からじわじわ湧いてくるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0304132" ]},
		{"command":[ "SETIMAGE", "0", "still_00000703_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「あぁっ、密着したオマンコの中でっ……オチンポっ、ビクビク震えておるっ\n……！　あぁっ、出るのか……？　出そうなのかっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0304133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「んっ、いいぞっ……中出しがいいっ！　思いっきり種付けしてっ、余のオマ\nンコでっ、オチンポイッて欲しいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0304134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「はぁんっ！　ダメじゃっ、イクっ……あぁっ、余もイってしまうっ！　旦那\n様と一緒にっ、んぁぁぁっ、オマンコッ……イクぅぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0304135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「くひぃぃぃぃっ！　あぁぉっ……おおっ、出てきてるっ……！　熱いのっ…\n…とぷとぷっ、流れ込んでぇっ、はひぃっ、中出し……いいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0304136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000703_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「はぁぁ……これぇ……気持ちよすぎる……ずっとイッたままになって……あ\nぁっ、頭が……真っ白になっていくぅぅ……んんんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0304137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「あっ、ふぁぁぁぁぁ……あぁ……出した……？　終わったか……？　射精…\n…んっ……止まったのか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0304138" ]},
		{"command":[ "SETIMAGE", "0", "still_00000703_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「んぁふ……あぁ……何だか……まだ、出されたままでいるような気分じゃ…\n…中でオチンポがうねって……心地いい感覚が残ったまま……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0304139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「やはり、旦那様との身体の相性は最高なんじゃろうな……あふ……本当に余\nは幸せものじゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0304140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「おっと……そんなことを言っている間にも、またオチンポが中でウズウズし\n始めたようじゃな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0304201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ふふ……分からいでか。これだけオマンコを責めて、まだまだ足りないとい\nうんじゃろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0304202" ]},
		{"command":[ "SETIMAGE", "0", "still_00000703_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「さあ……夫婦なのじゃ。気兼ねせず、もっと余のオマンコを突くがよいぞ…\n…ふぁっ！　んんっ、くぅぅっ、んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0304203" ]},
		{"command":[ "SETIMAGE", "0", "still_00000703_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「んふっ、出したばかりの精液を……オマンコ全体に馴染ませるのじゃ……く\nぅぅ……んふっ、そうじゃ……子宮口や襞にねっとりとじゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0304204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「あぁ……んっ、待っておれ……余も、オチンポへのお返しをきっちりとして\nいくからの……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0304205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「んふっ……どうじゃ？　こうして……んっ、ズリズリと……竿を握り締める\nようにオマンコを収縮させて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0304206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「旦那様の腰使いに合わせて、うんっ、あっ、ふっ……回していくっ！　うん\nっ、んぁっ、はぁっ、は、ひっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0304207" ]},
		{"command":[ "SETIMAGE", "0", "still_00000703_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ほぉれ……んんっ、いやらしく、ねっとり絡みつく感じが最高じゃろ？　余\nの奥から新しいマン汁が溢れ出して……精液と絡み合う……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0304208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「それを……ぐちゅぐちゅと……いい音をさせてかき混ぜるぅ……はぁぁ……\nんっ、はぁぁぁっ……あぅっ、くぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0304209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「んぁぁ……奥に突き刺さるオチンポっ……強いっ！　はぁぁ……カリがっ、\nずっと粘膜をっ……擦ってくるぅっ、んふっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0304210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「はぁぉっ、おっ、おぉっ……！　オマンコっ……くにくにっ、ひぃぁっ、さ\nれるっ、ほぅぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0304211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「あふっ、んふぅっ……子宮への押し込みぃ……亀頭がずっと……めり込んで\nっ……はぁっぁ……最高なのじゃっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0304212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「なぁ……んっ、ふっ……産まれてくるのはルナテミスの弟か……はたまた妹\nか、どちらになるじゃろうな……？　はっ、んふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0304213" ]},
		{"command":[ "SETIMAGE", "0", "still_00000703_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「旦那様にそっくりの……元気な男の子か……余にそっくりの……可愛い女の\n子か……はぁ、んんっ、くぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0304214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「いずれにしても、活発で……きっとスケベな子になりそうじゃがっ……それ\nも愛おしいものよのう……あっ、んむっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0304215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「はぁんむっ、ちゅぷぅぅっ……んっ……仲睦まじい夫婦のあり方を見せつけ\nて……幸せな家庭を作らんとな……あっ、あぁぉっ、おぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0304216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「いかん……そんな幸せなことを考えていたらっ……！　あぁっ、また……オ\nマンコがっ、キュンキュンしてっ……イキたくなっておるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0304217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「旦那様はっ……？　も、もうすぐかっ？　んむっ……！　ならばっ、また…\n…一緒にイくのじゃっ、オマンコ……一緒にぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0304218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「あぁっ、オチンポが震えてっ……はぁぁんっ、あと……もう少しぃっ！　こ\nのままっ、続けてぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0304219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「はぁぅんっ！　ズボズボされてぇっ！　イクッ、オチンポでイクっ！　ぶっ\nといオチンポされて、オマンコアクメするぅぅぅぅぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0304220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ほぉぉぉぉぉぉっ……！　おぉっ……ま、また……奥にっ……ドロドロザー\nメン流れて来てるっ……くぅぅぅぅんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0304301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000703_02_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「熱い……あぁ……隙間から……出されたばかりのが……太ももの方まで垂れ\nていく……んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0304302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「あぁっ、ちゅぷっ、んむっ……気にしないでよいと……？　れる……まだ好\nきな時にいくらでも出してくれるのか……んふっ、そうか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0304303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「はぁぁ……うむ……旦那様に身を任せよう……んぁ……そろそろ射精も落ち\n着く頃合いじゃろう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0304304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「あふっ……はぁ……はぁ……んっ、あぁ……出し切ったようじゃな……お疲\nれ様じゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0304305" ]},
		{"command":[ "SETIMAGE", "0", "still_00000703_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「うむ……素晴らしい初夜であった。これ程までに満ち足りた気分になったの\nは、本当に久しぶりのことじゃな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0304306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「あ……まだ、もう少しオチンポはそのままでいてくれぬか？　しばしこの余\n韻に浸りたい……お主を強く抱きしめていたいのじゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0304307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ふふ……不思議なものじゃ。余の方がずっと母性をもって、お主を包み込む\n心持ちでいたのに、こんなにも甘えてしまうなんてのう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0304308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「んっ……あぁ、こうして抱きしめられていると、心が安らぐ。何と素敵な旦\n那様を持ったのじゃろうと実感する」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0304309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「これからも、ずっと共にあろうぞ？　余の素敵な旦那様よ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0304310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「んくぅぅぅぅんっ！　あぁっ……ザーメンっ……今度は……身体にっ、はぁ\nぁぁんっ！　あっ、んふっ、出てぇっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0304401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000703_02_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「オマンコの中だけでなく……身体にも浴びせたいのじゃな……んんっ、よい\n……旦那様の欲望の通りにしてもらおう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0304402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「はぁん……この粘液に浸される感覚……ちゅぱっ……オスの匂いが染み込ん\nで……余の身体を書き換えていく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0304403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「んっ……あぁ……そうじゃ、オチンポで直接なすりつけてくれ……熱くて硬\nいのが……お腹のところに当たってるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0304404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「はぁぁ……終わってしまったか……名残惜しいが、本当にたっぷり出してく\nれたな……嬉しいぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0304405" ]},
		{"command":[ "SETIMAGE", "0", "still_00000703_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「確かに、もう十分子宮には精液を貰った後じゃからな。れろっ、んむ……こ\nうやって、口で味わうのも乙なものじゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0304406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「うむ、本当に満たされた時間じゃったな。自分の精液がつくのが嫌でなけれ\nば、もう少し身体を寄せてもよいか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0304407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ふふ……自分でも不思議なものじゃが、今日は旦那様に甘えたい気分でな。\n初夜の日くらい、こういうことがあってもいいじゃろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0304408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「なに？　いつでも甘えてくれて構わんとな？　くくっ、言うではないか。い\nつも余の足元でご機嫌を伺っているというのに」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0304409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「それだけ逞しくなったということかも知れんな。うむ、それではまた甘えさ\nせてもらうとしよう。愛しているぞ、旦那様♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0304410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}