		{"command":[ "PLAYVOICE", "v2_049_0804138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「はぁ……あぁ……んっ、出た……たっぷり出た……あぁ……私も、一緒にい\nっぱい……イケたぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0804139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「はふぁ……お腹の中で……着床した感じ……んふ……今から赤ちゃんが楽し\nみだな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0804140" ]},
		{"command":[ "SETIMAGE", "0", "still_00004908_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「あふ……まだ、オチンポ……元気は残っているな……続けてしたい……その\n、ダメだろうか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0804201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「んっ……あぁっ、さすがは頼もしい旦那様だ……これ以上ない程に、オチン\nポでわかりやすく応えてくれている……んんっ……」", "NORMAL" ]},
