		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「もちろん、私も……受け身ではいないぞ？　ちゃんと……オチンポをよくす\nるように……オマンコ……引き締めるからな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0804203" ]},
		{"command":[ "SETIMAGE", "0", "still_00004908_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「はっ、ふっ、んんっ、あぁっ……んくぅっ……イッた後だと、また……感じ\n方が変わってくるな……は、んっ、んふぁっ、あぁっ……」", "NORMAL" ]},
