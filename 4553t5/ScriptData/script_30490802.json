		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「別に……本当の初めてという訳でもないが……緊張しないと言えば嘘になる\n……心臓がドクドク言って……張り裂けそうだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0804102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「あなたも緊張しているのか……？　あっ……でも……興奮もしてくれている\nんだな……オチンポ……すごく立派に反り返っている……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0804103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「もちろん、私の準備は整っている……後は、お腹の上のこれが入ってくるの\nが最後だ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0804104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「後は……お、おねだり……？　わ、分かった……その、上手くできるか分か\nらないが……今の気持ちを素直に伝えたい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0804105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「お願いだ……あなたの、その……熱くて逞しいオチンポを……私の……ヌレ\nヌレの……いやらしいオマンコに入れて欲しい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0804106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「旦那様と一つになりたくて……いやらしくヒクヒクしている、このオマンコ\nに……ぶっといオチンポをハメて欲しいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0804107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「あぁっ、そこっ……そのまま……はっ、んぅっ、くっ、んんんんんんんんー\nーーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0804108" ]},
		{"command":[ "SETIMAGE", "0", "still_00004908_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「あぁぁぁ……入る……んっ、硬いオチンポっ……あぁっ、中でお迎え……し\nて、いるぅぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0804109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「くぅぅ……んっ、あぁ……ゆっくり奥、までぇ……はぁっ、ふっ……根元ま\nで埋め込んでぇ……はっ、んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0804110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「あぁ……入った。これで、本当に……正真正銘の夫婦になれた気がする……\nあぁ……オチンポ……大きい……いっぱいだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0804111" ]},
		{"command":[ "SETIMAGE", "0", "still_00004908_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「すごい……今までした時の、どれよりも……ドキドキして……普通の格好な\nのに……身体が熱く疼いて……たまらなくて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0804112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「まだ、動いていないのにこんな状態なんて……あぁ……始まったらどうなっ\nてしまうんだ……私は……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0804113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「あ……い、いや、大丈夫だ……心配には及ばない。これは、嬉しくてこうな\nっているから……あなたのやりたいように動いて欲しい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0804114" ]},
		{"command":[ "SETIMAGE", "0", "still_00004908_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「んっ、あっ、うんっ……！　んくんっ、ふっ……ゆっくりしてくれるんだな\n……オチンポが通り抜けていく感じ……よく、分かる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0804115" ]},
		{"command":[ "SETIMAGE", "0", "still_00004908_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「はぁっ、んっ……中で……ぴったり吸い付いて……くぅぅ……んっ、柔らか\nく締め付けると……あぁ、すごく気持ちいい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0804116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「全部……何もかも受け入れて……はぁんっ、子宮が……自然におりてくる…\n…受精したいと……自然に準備してしまう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0804117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「えっ……男の子か……女の子……どっちがいいか……そ、そうだな……いや\n、もちろんどちらでも授かれば最高に嬉しいが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0804118" ]},
		{"command":[ "SETIMAGE", "0", "still_00004908_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「その、もし……図々しいことを言ってしまうなら、どちらも……欲しい。あ\nなたとの子供なら、何人でも……産んでみたい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0804119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「あっ……！　んんっ、あっ、オチンポっ……！　はぁぅっ、ぐりぐりってっ\n……こ、興奮したっ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0804120" ]},
		{"command":[ "SETIMAGE", "0", "still_00004908_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ、そうか……今日のセックスはもう、本格的な種付けをするのと\n同じだからな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0804121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「私も、あなたに気持ちよく射精してもらうために……精一杯……締め付けを\n頑張ろう……手を繋いだまま……もっと密着していいか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0804122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「あぁ……あなたのぬくもりが伝わってくる……はふっ、もっと……腰を大き\nく揺らして……あぅっ、んっ、んくぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0804123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「はぁぁっ……オチンポ……今日は一番深いところで、グリグリ……来ている\nっ！　はぁん……汁が後から後から溢れてしまうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0804124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「んんっ……恥ずかしい……！　いやらしい音が響くと……ゾクゾクしてっ…\n…あふぅっ……そこぉっ、あっ、弱いっ……！」", "NORMAL" ]},
