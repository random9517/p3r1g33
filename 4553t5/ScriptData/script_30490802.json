		{"command":[ "SETIMAGE", "0", "still_00004908_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「中の……ねとねとが……蕩けるように絡み合って……あぁぅっ……一つに溶\nけていくような……あっふ、んっ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0804205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「んぁっ、あっ、おっぱいを吸われてる……んっく、さすがにまだ母乳は出な\nいから……あっ、んんっ……程々で……あっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0804206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「お腹の近く……へそまで……あぁっ、首筋……腋まで……全身舐め回されて\nしまうのか……？　はっ、んぁっ、あっ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0804207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「んっ、私も……お返ししたいが……あっ、んぅんっ！　あぁっ、オチンポが\n……すごすぎて……あふっ、難しい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0804208" ]},
		{"command":[ "SETIMAGE", "0", "still_00004908_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「くっ……んんっ！　とにかく……オマンコだけは……しっかり、リズムを合\nわせて……締め付けてっ……んくぅっ、こうっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0804209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「ふふっ……んっ、オチンポが悦んでくれている……あなたの時折漏れる……\nその吐息がとても、ゾクゾクするんだ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0804210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「あっ、ひっ、お互い……さまっ……？　私の……喘ぎの方が……よっぽど…\n…？　そ、そうなのか……？　あっ、あぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0804211" ]},
		{"command":[ "SETIMAGE", "0", "still_00004908_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「はんっ、あっ、あぁっ、そんなっ、無理やり引き出そうとしなくてもっ、は\nっ、ひっ、あひんっ！　声はっ……出てしまうからっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0804212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「あひっ、あぁっ、あくぅんっ……また、オチンポの動きっ、激しくなったら\nっ、あっ、はぁぅっ……声っ、出るぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0804213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「んんっ、それなら、私もっ……んふぅっ！　くぅっ、んんっ、一緒にリズム\nを合わせてっ……オマンコをっ……んくぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0804214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「あふっ、あぁっ、あなたの声にも余裕がなくなってきたな……はっ、んんっ\n……いつ、イッてくれても構わないぞ……？」", "NORMAL" ]},
