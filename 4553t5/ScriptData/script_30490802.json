		{"command":[ "PLAYVOICE", "v2_049_0804129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「うんっ、んくんっ！　激しいっ……！　あぁっ、オチンポがっ、オマンコの\n中をっ……グリグリかき回してっ、好きっ、好きぃっ！」", "NORMAL" ]},
