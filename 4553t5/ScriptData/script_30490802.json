		{"command":[ "SETIMAGE", "0", "still_00004908_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……オマンコいいっ、オマンコがいいっ！　あなたはっ……？　\nちゃんとオチンポ気持ちいい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0804131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「んんっ……嬉しい……もっとオチンポとオマンコっ……ドロドロになりたい\nっ！　ぎゅっと抱き締めて……離さないっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0804132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「んっ、んふんっ……あぁ……子宮がウズウズしてるっ……赤ちゃんのもとを\n欲しがってるっ……オマンコっ、中出しされたがっているっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0804133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「はっ、ふっ、んんっ……！　このオチンポの震え方……そろそろ出そうにな\nっているの……分かるぅっ、はっ、んふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0804134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「お願い……どんな風にしてもいいからっ、最初は中にっ……貴方の精液っ…\n…子宮に出して欲しいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0804135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「妊娠したいっ……！　しっかり受精してっ……あなたの子供を授かりたいっ\n！　来てっ……出してっ、ビュクビュクッ……してぇぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0804136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「んぁぁぁぁぁぁぁぁぁーーんっ！　あぁっ、出てるっ、あぉっ……精液っ…\n…濃いのっ、中出しっ……はぁぁぁぁぁぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0804137" ]},
