		{"command":[ "SETIMAGE", "0", "still_00004908_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「私は、まだ……あっ、余裕はっ……あっ、あぉっ！　な、ないかもしれない\nがっ……それでもっ、後少しっ……なんとかなるっ……」", "NORMAL" ]},
