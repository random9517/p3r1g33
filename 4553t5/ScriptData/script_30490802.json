		{"command":[ "SETIMAGE", "0", "still_00004908_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「それぇっ……オチンポの先っ、オマンコの襞を……押し付けられるのっ、ん\nぁぁっ、良すぎるぅっ……あ、くひぃんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0804126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「はぅっ、あっ、あんっ……！　もっと……突いてっ……今の感じでっ……は\nぁぁんっ、ビクってなるっ……そこが、いいっ、うひぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0804127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「あぁっ、んむっ……あなた……キスしてぇ……はぷっ、んちゅぷっ、あんむ\n、れろ、ちゅぱっ、ぴちゃ、んちゅっ、りゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0804128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
