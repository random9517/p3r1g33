{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0155" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "俺が懸念していた通り……。", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "宿敵同士が詰め込まれた、マイクロバスの内部が……一触即発の地獄絵図にな\nるのに、そんなに時間はかからなかった。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……どうすんだこれ……」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「あははは、どうしたんですか隊長。そんなに目を白黒させて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_030021680001" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「まるでトリックを暴かれた真犯人みたいじゃないですか。楽しい人だなあ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_030021680002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ちゃっかりとバカンス一行にまぎれこんでいた鳳雛が、幸せそうにニコニコす\nる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「やんややんや。いいですねぇ、普段会えない人達と遊ぶっていうのは」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_030021680003" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そう思ってるのお前だけだぞ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "バスターミナルからリゾートまでの所要時刻はおよそ１時間。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "バチバチと火花を散らし続ける氷華とほむらに飽きたのか、七重が運転手に声\nをかけた。", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「あのう、運転手さん？　このバス、カラオケとかありませんか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_030021680001" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "運転手" ]},
		{"command":[ "SETTEXT", "「ああ、ありますよ。よろしければお使いください」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「カラオケ……？　そんな趣味があったとは初耳だな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_040021680001" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「親交を深めるにはコレですよ。長官さんも一曲いかがです？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_030021680002" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「わ……私はいい。人前で歌うだなんて……恥ずかしい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_040021680002" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「あら。そうですか、じゃあ私が女の情念……聞かせてさしあげましょ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_030021680003" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "慣れた手つきで選曲し、マイクを構える七重の頭上……スピーカーから聞いた\nことのある演歌が流れてくる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「こ、このメロディは……まさか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_040021680003" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「ええ。私の十八番です。……いきますよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_030021680004" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "拳の入ったド演歌を見事に歌い上げる獄門七重。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "とんでもなくうまい！", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「ふぅっ……。どないでしょ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_030021680005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「ほう……ここまでとは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_040021680004" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「素晴らしい歌唱力だ。ここまでのものを聞かせられては……私も長官として\n、黙っているわけにはいくまい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_040021680005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「へえ……。私より凄い歌声、聞かせてくれるってことですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_030021680006" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「ああ、もちろんだ。だがその前に……グイッと一杯いかせてもらうぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_040021680006" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "コンビニのビニール袋に入った缶ビールを取り出すやいなや、長官はそれを一\n気に飲み干した。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「な、なんやって！　こんな真昼間から……普通やあらへん！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_030021680007" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「私はこうやって、リミッターを外すんだ……。いくぞ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_040021680007" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「うぃー……。今日の地球の天使は～♪　わたしだけにハグする～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_040021680008" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「ぴょいぴょい♪　ぴょいぴょい♪　あーーーガチだっぴ♪　あーーー好きだ\nっぺ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_040021680009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「意外と可愛い選曲するもんだな、あの年で……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「貴様！　何か言ったか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_040021680010" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「い、い、い、言ってまひぇん……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「美鈴ちゃんは、つれぇことがあるたびこうやって、幼女になりきって歌うん\nだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_040021680001" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ＥＤＯ長官という重責、言うことを聞かない部下達をまとめる心労……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_040021680002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「そういったストレスが全部、酒とカラオケに出ちまう悲しき社畜モンスター\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_040021680003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「それが冴島美鈴……。ブラックな社会ってヤツが生んだ闇だぜ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_040021680004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「ずこんばこん～♪　抱きしめて～♪　びくんびくん♪　感じちゃーうーよー\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_040021680011" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「こんなハートは～♪　はーじーめーてー♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_040021680012" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「まァいつも酒かっくらってデカ声で歌いまくるもんだから、ちょっとした営\n業妨害ってカンジだぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_040021680005" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「管理職って大変なんだなぁ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「まあまあ。息抜き出来てるならそれでいいじゃねえか。勝負ってーほどガチ\nでもねぇみてえだし」」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_040021680006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「……フン。そういうあなたはどうなんです？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_030021680001" ]},
		{"command":[ "SETCHARA", "0", "char_00005002_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「傍観者の顔をして、自分だけ勝負から離れて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_030021680002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「コソコソと、歌わずにすむようにと……逃げ隠れしているように見えますが\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_030021680003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「カッチーン……なんだとコラぁ！？　誰が勝負から逃げただ！？　ふざけん\nな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_040021680007" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「テメェみたいな雑魚相手に、本気出すのもかわいそうかな～と思って見逃し\nてやったってのによ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_040021680008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「フフッ。図星を突かれて顔が真っ赤ですね。これだから単細胞は嫌なんです\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_030021680004" ]},
		{"command":[ "SETCHARA", "0", "char_00005002_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「……おーッしわかった。そこまで言うならキメてやらあ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_040021680009" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「カツマ！　曲を入力しろ！　オレの十八番を聞かせてやるよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_040021680010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「あとでほえ面かかないといいですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_030021680005" ]},
		{"command":[ "SETCHARA", "0", "char_00005002_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ツンと澄ました氷華にムッとしながら、ほむらが大音量でシャウトする。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ほえ面かくのはオ・マ・エ・だッッ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_040021680011" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "車内を揺るがす骨太なロックは、いかにもほむらのイメージ通りだ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「オラ、歌ったぜ。次はテメェの番だ、氷華」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_040021680012" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「……私はこんな、無益な争いに参加するつもりはありません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_030021680006" ]},
		{"command":[ "SETCHARA", "0", "char_00005002_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ハァ～！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_040021680013" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「あっ、そーかそーか！　氷の女王、いつも冷静沈着完全無欠な氷華チャンに\nも秘密の欠点があるってことだよな～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_040021680014" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「欠点？　とはなんです？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_030021680007" ]},
		{"command":[ "SETCHARA", "0", "char_00005002_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ずばり！　音痴なんだろ、アハハハッ！　だからカラオケできねぇってワケ\nだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_040021680015" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「今のは失言です。即刻取り消してください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_030021680008" ]},
		{"command":[ "SETCHARA", "0", "char_00005002_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「あ～やなこった～！　音痴、音痴～！　めちゃめちゃウケるぜ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_040021680016" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「……いいでしょう。その罵倒……すぐに後悔させてあげます！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_030021680009" ]},
		{"command":[ "SETCHARA", "0", "char_00005002_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "強引にほむらからマイクを奪い取り、憤りつつも冷静に曲を入れる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「お！　これは、私が学生らった頃のぉ～。トレンディードラマの主題歌じゃ\nないかぁ～♪　いいぞいいぞぉ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_040021680013" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「トレンディーっていう単語がもう……。いえ、なんでもありません……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_030021680008" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "しっとりとラブソングを歌いこなす氷華は、いつもよりも更に美人に見える。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "おお……。こうやって、イヤミ言ってないと相当キレーな顔してんだけどな\nあ……もったいない", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ぐすっ……名曲ですなあ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020021680001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「俺もそう思うけども……なんつうか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「全体的に、曲が古いんだよ……。このバスだけが昭和に戻っちまったみたい\nだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "慰安旅行の行き先も、メンバーも、酒臭い車内も……とてもじゃないが時代に\n追いつけていない。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ハワイっていうよりかは熱海、箱根ってカンジですなあ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020021680002" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おい。鳳雛、この中じゃお前が一番若そうに見えるんだが……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「どうする？　なんなら次に歌ってもいいぞ。女子に流行りの、最先端の曲で\n頼む」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「ぼ……僕ですかぁ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_030021680004" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「いやいや。僕はそんなに歌はうまくありませんから……そうですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_030021680005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「誰かの歌に合わせて、真顔でパラパラを踊るくらいしかできませんよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_030021680006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「だから例えが古いんだよ、このメンツ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「それでよければ……。こ～んな感じで、パラ、パラ、と……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_030021680007" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「……あなた、あまり表情が変わらないものね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_030021680010" ]},
		{"command":[ "SETCHARA", "0", "char_00005002_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「常に無表情のお前に言われたくねえだろうけどな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_040021680017" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「あはは。ん？　隊長。窓の外を見てください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_030021680008" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "さっきまで晴れ渡っていた青空は、いつの間にか暗雲たちこめる黒い空に変わ\nっていた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「げっ！　ちょっと目を離した隙に……！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「だが、まぁ……、スパは室内だから平気だろ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「いやぁ、でもこの雰囲気。何か事件が起こりそうですねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_030021680009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "のほほんと笑いながら、鳳雛はまだ淡々と両手で踊っている。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「これが二時間ドラマなら、スパで何人か死ぬ大事件が起こりそうです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_030021680010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「がるるるるる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_040021680018" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「ぐるるるる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_030021680011" ]},
		{"command":[ "SETCHARA", "0", "char_00005002_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……事件は今まさに、目の前で起こってるぞ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「ふむふむふむ……？　この名探偵の目には、和気あいあいとした楽しい光景\nしか見えませんけどねぇ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_030021680011" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お前って……本当に名探偵なのか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "俺の心に去来する一抹の不安。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "それを裏付けるように、鳳雛の笑顔にまったく知性は見当たらなかった……。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}