{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0025" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "謎の光を受けてパワーアップした俺たちは、宇宙ヒグマと時間帝国のロボ軍団\nを圧倒していた。", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「どうしちまったんだよ、オレの戦艦！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_010115610001" ]},
		{"command":[ "SETCHARA", "0", "char_00022901_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「なんじゃ、軌道が変態じみておる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100115610001" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ぶちかましてやれっ、ドラグソード！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "宇宙ヒグマ" ]},
		{"command":[ "SETTEXT", "「あっふぅん！　あひっ、おほぉおおおんっ！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "戦況が一気にひっくり返る。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「あのロボの装甲も硬くなってないか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080115610001" ]},
		{"command":[ "SETCHARA", "0", "char_00000408_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「この短時間で、いったいどんなパワーアップを……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010115610001" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「お前ら、よそ見していていいのかよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_010115610002" ]},
		{"command":[ "SETCHARA", "0", "char_00022901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そして、ドラグソードの強化に気を取られた時間帝国の連中を、スケバンサン\nダーが攻撃する。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「調子に乗るでないぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100115610002" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「いいや乗るね！　最後に勝つのは、調子を乗りこなしたやつなんだよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_010115610003" ]},
		{"command":[ "SETCHARA", "0", "char_00022901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「いくぜカツマ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_010115610004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああ、俺たちの力を見せてやろうぜ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0206" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "ドラグソードがスケバンサンダーの戦艦に乗った。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「……って、おいっ！　なに勝手に乗せてんだよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_010115610005" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まあいいじゃねぇか。それより、一発かましてやろうぜ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「しゃあねぇなあ！　食らいやがれっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_010115610006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー＆カツマ" ]},
		{"command":[ "SETTEXT", "「ダブル！　イグノラント！　サンダァァァアアアァァァアアァァッ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_010115610007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "戦艦に乗ったドラグソードの体当たりで、巨大ロボ軍団が蹴散らされる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0025" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「な、なんてめちゃくちゃな威力じゃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100115610003" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「あんなのくらったら、ひとたまりもねぇぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080115610002" ]},
		{"command":[ "SETCHARA", "0", "char_00000408_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「どうやら、それはこの洞窟も同じのようですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010115610002" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "その衝撃で、俺たちがいる洞窟が崩れ始めた。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「ちっ、今回も引き分けにしておいてやる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080115610003" ]},
		{"command":[ "SETCHARA", "0", "char_00000408_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「そのツキ、いつまでも続くと思わないことです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010115610003" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "時間帝国の連中は急いで脱出していった。宇宙ヒグマも逃げていく。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おい、やべぇぞ！　……って、ドラグソード！？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "仕事を終えたと言わんばかりに、ドラグソードが帰っていく。そんなに定時で\n上がりたかったのか、ドラグソード。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「カツマ、乗れ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_010115610008" ]},
		{"command":[ "SETCHARA", "0", "char_00022901_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "俺はスケバンサンダーの戦艦に乗り、洞窟をあとにした。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0190" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「それにしても、いったいどうなってんだ。俺の戦艦が、まるでドラグソード\nみたいなカラーリングになってやがる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_010115610009" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あの光のせいかもな。ところで、あのファックスにはいったい何の意味があ\nったんだ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「知るか！　ただのダジャレだろ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_010115610010" ]},
		{"command":[ "SETCHARA", "0", "char_00022901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ダジャレのために用意されたのかよあの仕掛け！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "本当に、わけのわからないダンジョンだったぜ……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「おい、カツマ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115610001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「カツマ！　無事だったか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090115610001" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「姫様、アナザー！　みんなも無事だったか！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「急に洞窟が崩れ出して、大変だったのよぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010115610001" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「幸い、帰る道にはトラップがひとつもなかったからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010115610001" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ああ、全部姫様が起動させていたからか。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「それで、カツマとスケバンサンダーはふたりでなにしてなんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010115610001" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「お宝は見つかったの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010115610001" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お宝どころじゃなかったんだよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「ああ。こいつのせいで穴に落ちるし、変な部屋に閉じ込められるし！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_010115610011" ]},
		{"command":[ "SETCHARA", "0", "char_00022901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ふたりっきりで閉じ込められたですって！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010115610001" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ちょっとカツマ、なにしてたの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010115610001" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「落ち着けカグヤ！　なにもしてねぇって」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「びっくりしたぜ。俺の上に乗って、立派な剣を振りまわしやがって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_010115610012" ]},
		{"command":[ "SETCHARA", "0", "char_00022901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「お、お前……！　そんな破廉恥なことをしたのか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115610002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「全裸のカツマさんが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010115610002" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「スケバンサンダーの上に、乗る……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010115610002" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「んなことしてねぇし！　あっ、こらスケバンサンダー！　どこへいくつもり\nだ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「秘宝は見つからなかったし、もうこの惑星に用はねーよ。じゃあな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_010115610013" ]},
		{"command":[ "SETCHARA", "0", "char_00022901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お前っ！　それより俺の誤解を……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「カツマさん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010115610003" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「カツマ、詳しく聞かせて。ナニをしてたの！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010115610003" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「密室で男女がふたりっきりだろ！？　貴様……不埒なことをしたんじゃない\nだろうな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115610003" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いいから話をきいてくれぇっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}