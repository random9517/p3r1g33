{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00006302_01_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「水着で部屋に来いなんて言うから、変だなって思ったんですけど……これは\nどういうことですか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0203101" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「はぁ……パワーアップ、ですか……？　それは、本当ですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0203102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「いえ、疑ってるわけでは……内容が内容でしたので……それにしても水着で\nする必要はあったのですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0203103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「え？　効果が全然違う……？　そうなんですか……それに脱がなくていいか\nら、奉仕しやすい……？　そう言われれば……まあ、確かに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0203104" ]},
		{"command":[ "SETIMAGE", "0", "still_00006302_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「こうやって、隊長さんの……オチ、ンチンを挟んでるわけですけど……これ\nで本当にパワーアップなんてするんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0203105" ]},
		{"command":[ "SETIMAGE", "0", "still_00006302_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「ジッとしてるだけじゃダメ？　隊長さんを気持ちよくさせないといけないん\nですか？　えっと……具体的にはどうすれば……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0203106" ]},
		{"command":[ "SETIMAGE", "0", "still_00006302_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「胸で強く挟んで扱く？　え、えっ……そんなことしなくちゃいけないんです\nか？　い、嫌というか……恥ずかしいんですよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0203107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「あ、当たり前じゃないですか！　いきなり水着を着て、隊長のコレを胸で挟\nむなんて……恥ずかしいに決まってます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0203108" ]},
		{"command":[ "SETIMAGE", "0", "still_00006302_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「ううっ、うぅ……わかってます。戦闘能力の向上のためと言われれば……私\nは何も言えません……お付き合いするだけです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0203109" ]},
		{"command":[ "SETIMAGE", "0", "still_00006302_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「で、では……早速始めますよ……だけど、ほとんどこういう経験はないので\n、あまり上手くないかもしれませんが……許してくださいね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0203110" ]},
		{"command":[ "SETIMAGE", "0", "still_00006302_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「んっ……んっ、ふうっ……こ、こういう、感じ……で……んっ……どうでし\nょうか？　はぁ……はふっ……ふぅうっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0203111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「その調子？　は、はい……では、続けますね……んっンっ……はぁ、はふぅ\nっ……なかなか、難しいですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0203112" ]},
		{"command":[ "SETIMAGE", "0", "still_00006302_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「私だって、隊長さんのお役に立てるなら……少しでも協力したいって思って\nますけど……こういうことは疎くて……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0203113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「そのわりには結構上手い……ですか？　ありがとうございます……なにか間\n違いがあれば、言ってください……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0203114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「とりあえずはこのまま続けていいですか？　わかりました、では……んっ…\n…んんっ……あっ、ふうっ……んぅんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0203115" ]},
		{"command":[ "SETIMAGE", "0", "still_00006302_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「はう、うぅっ……あの、隊長さん……あまりジロジロ胸ばかり見ないでくだ\nさい……恥ずかしいんですってばぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0203116" ]},
		{"command":[ "SETIMAGE", "0", "still_00006302_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「せっかく水着だから見たい……？　お気持ちはわからなくもない、ですけど\n……興奮した方がパワーアップの効率がいい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0203117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「それなら……仕方ないですね……隊長さんのお好きなように……ふぅ、ふっ\nうっ……あふぅうっ……んぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0203118" ]},
		{"command":[ "SETIMAGE", "0", "still_00006302_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「もっと強く擦っていいんですか？　わかりました、やってみますね……んっ\n……くぅ、くふぅっ……あうっ……どう、ですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0203119" ]},
		{"command":[ "SETIMAGE", "0", "still_00006302_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「いい感じ？　よかった……です……あんっ……あ、熱いですね……本当に熱\nくて、硬くて……ううっ、イヤらしい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0203120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「なんか卑猥で、勝手に動いてて……ちょっと怖いです……んっ……え？　ヒ\nクヒク動いてるのは気持ちいいから、ですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0203121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「喜んでる証拠……なるほど……そう思うと、ちょっと可愛い、かも……しれ\nません……ちょっとだけですよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0203122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「すぐには無理かもしれませんけど……だんだん慣れていければ、いいとは…\n…はい……んっ……思ってます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0203123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「そうですね、頑張ります……あっ、あふっ……でも、さっきよりは……怖く\nなくなってきました……はふっ、ふぅうっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0203124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「隊長さんも、いい感じですか……？　ああ、言われてみれば……さっきより\n大きくなってます……オチンチン……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0203125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「なるほど……気持ちいいと、どんどん大きくなるんですね……正直者？　ふ\nふっ……確かにそうですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0203126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「あの、先っぽから液が溢れてきてますけど……これも、感じてるってことで\nす……よね？　やっぱり、そうでしたかぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0203127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「一応それくらいは知ってます……もうすぐ射精しそうってことですもんね？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0203128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「よかった、です……このまま出せそうですか？　はい、はい……じゃあ、胸\nで……擦り続けますから……いつでも出してください……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0203129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「はぁっ……はっ、あうっ……んっ、すごい……硬さも、どんどん変わってき\nてます……ふっうぅ……熱い……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0203130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「あっ、あうっ！　どうしたんですか……急に腰を動かして……んっ、あぁん\nっ……！　はっ、はぅうっ……んふぅうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0203131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「このまま胸の中に……？　わかりました……んんっ……しっかり、胸で……\nオチンチンを挟んでますから……あっ、あふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0203132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁあっ！　え？　ええっ？　なんですか……イク？　出るっ？　わ\nかりまし……んっ、んっあぁぁぁぁぁぁっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0203133" ]},
		{"command":[ "SETIMAGE", "0", "still_00006302_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「ひぅぅぅっ！　あっあぁっ、あふぅぅぅっ……！　あ、あうっ……ほ、本当\nに出てるっ……胸の中で、たくさん……んんっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0203134" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00006302_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「あぁっ……こ、これが射精……なんですね……熱い、精液がこんなに……ん\nっ……ふううっ……ふっ、あぁうっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0203135" ]},
		{"command":[ "SETIMAGE", "0", "still_00006302_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「突然だったから、驚いちゃいましたよぉ……はふぅ……ほら、見てください\n……胸がベトベトになってます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0203136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「普段よりいっぱい出た……？　私の水着姿のおかげで……？　そういうもの\nなんですね……隊長さんが満足したなら、よかったです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0203137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「え？　満足はしてない……どういうことですか？　はい……ええ、オチンチ\nンは……大きいまま、ですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0203138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「ご奉仕が不十分でしたか……むしろよすぎた？　なるほど……では、このま\nま続ければいいんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0203139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「わかりました。隊長さんから、そこまでお願いされたら……ちょっと張り切\nっちゃいますよ……ふふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0203140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「えっと、さっき出した精液は綺麗にしなくてもいい……ですか？　隊長さん\nのオチンチンもベトベトになっちゃいますよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0203201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「はぁ……気にしなくていい……？　そうなんですね、わかりました……うっ\n、うぅん……あぅ……やっぱり、ヌルヌルしてて……うぅんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0203202" ]},
		{"command":[ "SETIMAGE", "0", "still_00006302_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「へ、変な感じです……これって、本当に気持ちいいんですか……？　大丈夫\nですか……？　うう、だって気になりますよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0203203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「谷間がベトベトになってて……おっぱいを動かすと……隊長さんのオチンチ\nンと擦れて……精液まみれになっちゃいます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0203204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「あふっ……こ、これがむしろ気持ちいい、なんて……本当に変態さんですね\n……確かに……滑るから擦りやすいですけどぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0203205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「んっ！　あっ、あうっ……オチンチンが、ビクって……！　今、すっごく震\nえましたよ……そんなに感じるんですか、これって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0203206" ]},
		{"command":[ "SETIMAGE", "0", "still_00006302_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「はい、硬くて熱いままで……ギンギンですね……うぅんっ……胸と擦れて…\n…私まで……身体が火照ってきちゃいます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0203207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「……興奮してる？　わからないです……んっ、あふぅっ……ただ、心臓がド\nキドキしてて……はぁっ……うぅ……不思議な気分です……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0203208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「でも、嫌な感じはないですよ……隊長さんのためですしね……だから、こう\nやって頑張ってるんです……んぅうっ、ふぅうっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0203209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「あっ、あうっ……またビクンってなりました……隊長さん、喜んでくれてる\nんですね……嬉しい、です……あんっ、んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0203210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁっ……ま、また出そうに……なってるんですか……？　さっき射\n精したばかりなのに……ふぅっ……あぁうっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0203211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「いえ、嬉しいですよ……遠慮しないで、いっぱい出してくださいね……んっ\n、んはぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0203212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「エヘヘ……隊長さん、とっても気持ちよさそう……はい、顔を見たらすぐわ\nかりますよ……あんっ……いっぱい感じてくださいね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0203213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「ふぅっ……こうやって胸で擦ってると……イヤらしい音が鳴って……どんど\nん匂いもキツくなってきて……あっふっ、うぅんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0203214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「隊長さん、さっきから腰が震えてますよ？　そろそろ限界なんじゃないです\nか……？　んっ……ねえ、隊長さん……ほら、ほらぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0203215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「えぇ、なんですか？　どこに出して欲しいって……？　私はべつに……隊長\nさんの好きなようにしてもらえれば……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0203216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「あ、あふぅっ！　もうっ……わ、わざわざ言わせるなんて……エッチで、し\nかも意地悪ですね……隊長さんは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0203217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「いいですよ……んっんっ……こうやって水着おっぱいで……シコシコします\nから……いっぱい、出してください……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0203218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「そうです、隊長さんのガチガチに勃起したオチンチンからぁ……あの濃くっ\nてドロドロした精液を……私のおっぱいに出してください……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0203219" ]},
		{"command":[ "SETIMAGE", "0", "still_00006302_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「ンっ……はっ、あぁっ……ほ、欲しいですっ……隊長さんの、ザーメンっ！\n　白くて、熱い……ザーメンをっ……出し、てぇぇっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0203220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「ひぃうっ！　あっ、あぁぁっ……んううぅうぅぅ～～～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0203301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00006302_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「あっはぁあっ……！　うぅっ、ま、また出てるっ……胸の中にっ……あっ、\nあうっ……くっひっ、あぅうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0203302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「に、二回目……なのに……さっきより、たくさん出てますよぉ……ふっ、う\nぅあぁっ……あふっ……うンぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0203303" ]},
		{"command":[ "SETIMAGE", "0", "still_00006302_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁっ、はあぁぁっ……胸が、熱い……はぁはぁ……まだドクドクい\nってますぅ……ンンっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0203304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「ちょっと出しすぎじゃないですか……あふっ……こ、こんなに出るものなの\nですか？　気持ちよかったから？　なら……いいですけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0203305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「はふぅ……見てください……胸が精液まみれですよ……ううっ、水着に匂い\nが染み込んでますよ、きっと……洗っても取れなそうです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0203306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「それが興奮するんですか……？　もぉ……隊長さんったらぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0203307" ]},
		{"command":[ "SETIMAGE", "0", "still_00006302_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「でも、これでしっかりパワーアップしたんですよね？　それなら、よかった\nです……お役に立てて嬉しいです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0203308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「またですか？　えっ……これで終わりじゃない……？　あ、そうなんですね\n……定期的にする感じ、ですか……？　水着も？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0203309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「はぁ～、仕方ないですねぇ……わかりました。他でもない隊長さんのためで\nすから、特別ですよ？　他の人には内緒にしてくださいね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0203310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「はっあうっ……！　あっ、なにをっ……んっ、んんぁぁぁぁっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0203401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00006302_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「ひぐっ！　あふっ……やっ、あぁああっ……！　胸にかかっちゃうっ……あ\nんっ……あ、はぁぁぁっ……はうっ、ンはぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0203402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「……ひゃう！　ひゃんっ！　さっきも出したのに……いっぱい、いっぱい…\n…出て、るぅっ……ンはぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0203403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「すごいっ！　こっちまで飛んできて……ひゃっ、あぁっ……なんですか、こ\nの量は……あっ、あんっ……はぁぁぁぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0203404" ]},
		{"command":[ "SETIMAGE", "0", "still_00006302_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「あぅうっ……水着まで、精液がかかって……ベトベトぉ……うぅっ……んっ\n、はぁ、はぁっ……匂いが取れなくなっちゃいますよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0203405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「んっふうっ、はぁっ……はぁ……いっぱい出ましたね……はぁあっ……すご\nい勢いでしたね……噴水みたいでした……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0203406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「それで……しっかりパワーアップできましたか？　私のおかげ……ですか？\n　ええ、それなら安心しました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0203407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「エヘヘ……お礼なんて……でも、嬉しい……隊長さんの役に立てて、よかっ\nたです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0203408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「え？　またして欲しいんですか？　もう～、本当にエッチですねー……そん\nなに気持ちよかったんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0203409" ]},
		{"command":[ "SETIMAGE", "0", "still_00006302_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「わかりました。そこまで言われたら、断れないですよ。またご奉仕しますね\n、もちろん水着で」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0203410" ]},
		{"command":[ "WAITINPUT" ]},
