{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0087" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「旦那さま……。あのう、少しだけ……いいですか？　夏の、ブライダルのイ\nベントでのことなのですが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0503101" ]},
		{"command":[ "SETCHARA", "0", "char_00022105_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA","0", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「皆様とても可愛らしくて、目を奪われてしまうのは当然だと思っています。\nでも、でも……わ、わたくしのことも……少しだけ見て欲しくて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0503102" ]},
		{"command":[ "SETCHARA", "0", "char_00022105_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「え？　拗ねているのか、ですか？　そ、それは……。……はい。他の方に旦\n那さまがお鼻の下を伸ばしているのを見たら、胸がモヤモヤして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0503103" ]},
		{"command":[ "SETCHARA", "0", "char_00022105_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「し……嫉妬、しています。こんな悪い子は嫌いですか？　……ひゃっ？　す\n、好き？　本当ですか？　愛してる！？　そ、そんな……、あっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0503104" ]},
		{"command":[ "SETCHARA", "0", "char_00022105_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あ……っ！　あっあっ、だ、旦那さま……？　ど、どうしてわたくしをこん\nな恥ずかしい体勢に……。それに、いきなりお股にキスだなんて……あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0503105" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022105_01_01" ]},
		{"command":[ "DISPCHARA","0", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「だ、だめです……！　い、いえ、嬉しいです、旦那さまがときめいて、わた\nくしを好きだと言ってくれたことは何より嬉しいです！　でも……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0503106" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「これはいけません……っ。ひゃ……！　あっ、ほ、本当に……そんなところ\nを舐めるんですか？　ま、まだお風呂にも入っていませんの……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0503107" ]},
		{"command":[ "SETIMAGE", "0", "still_00022105_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「なのにそんなに積極的に……！　あっ……ぁっ、ま、まさかわたくしのお股\nに何か異変が？　おかしなことでもありますか？　ちがうのですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0503108" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ただ、愛おしくて、むしゃぶりついてねぶりたおしたくなった……？　やっ\n♪　ぁっ、だ、旦那さま……！　この行為は愛の証……なのですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0503109" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「そ、そうだとしても……ほんとうに恥ずかしい、です……。んぅっ！　ぺろ\nって……ぴちゃっ、くちゅって、あったかい舌がわれめに触れて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0503110" ]},
		{"command":[ "SETIMAGE", "0", "still_00022105_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ひぅうっ♪　あぅっ、ううっ……んんんっ……！　こんな、腰を突き出すよ\nうな格好で、たいせつな旦那さまにおまんこを舐めていただくなんて！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0503111" ]},
		{"command":[ "SETIMAGE", "0", "still_00022105_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「……おねがいです……。えっちなことがしたいなら、わたくしがおちんちん\nを舐めたりおしゃぶりしたり、します……。だからはなしてください……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0503112" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「こんな行為、しらなくて……びっくりしました。お胸でもなくて、お股を口\nでれろれろするのが、ふつうなんですか？　この星の方々は……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0503113" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「……そうでもない？　んっ！　あ、愛情が特別にある恋人同士だけ？　……\nやぅっ♪　そ、そうなのですか、愛の行為……そ、それなら……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0503114" ]},
		{"command":[ "SETIMAGE", "0", "still_00022105_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「おしえてください。旦那さま……これはなんという行為なんですか？　くん\nに……。クンニ？　不思議な響きです。おまんこにたくさんキスをして」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0503115" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「われめを舌でなぞっ、たり……。んんんっ♪　その上のちっちゃなお豆さん\nをぱくってくわえ、たり、お口の中でころがしたり……。っぁああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0503116" ]},
		{"command":[ "SETIMAGE", "0", "still_00022105_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「わたくしの小さな穴、を……っ♪　旦那さま専用の、えっち専用おまんこを\n……旦那さまのお口がびちょびちょに濡らしていきます……っ、はぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0503117" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「んぁああっ♪　ああっ、あっ……あぁっ、うううっ……うう～！　は、はい\n……っ、き、きもちいいです、すごくすごくきもちいいです……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0503118" ]},
		{"command":[ "SETIMAGE", "0", "still_00022105_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「で、でも、愛する旦那さまにおまんこを舐めさせるなんて……およめさんと\nしては、失格、なのではとふあんです……。あっ、すごく気持ちいい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0503119" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「……んんぅっ！　ぴちゃぴちゃと、大きく舌が入口を舐めあげて……舐めお\nろして！　あっ♪　舐めあげて、今度はねろねろって舌が這いまわって！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0503120" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「くぅうっ♪　んぅううっ、こんなのしりません、……んぁあぁっ♪　これっ\n、お、おぼえてはいけない快楽です、き、きもちよすぎるんです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0503121" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「旦那さまのお口で気持ちよくなっちゃうんです！　あっ♪　ぁっ、わるい子\nの快感です！　……んっ、んっ、お股があつい、身体がぞくぞくします」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0503122" ]},
		{"command":[ "SETIMAGE", "0", "still_00022105_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ふぁ……あああ、とけちゃいますぅう……っ♪　んんっ、ぴちゃ、ぴちゃっ\nてえっちな音がして、おまんこがぬるっ、ぬるって濡れて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0503123" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁ、はぁ、旦那さまごめんなさい……♪　でも、あ、ありがとう\nございます……っ！　愛が、いっぱいつたわってきます……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0503124" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「んんんっ！　頭にびりびりって電気が流れたみたい、で……はぁううっ♪　\nおしりがもぞもぞして、じっとしていられませんんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0503125" ]},
		{"command":[ "SETIMAGE", "0", "still_00022105_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「……わ、たくしの蜜も……おつゆもたくさんあふれてきてます……。あっ♪\n　ゾクゾクがとまりません、んんんっ、旦那さま、じょうずすぎて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0503126" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「クンニ、好きになっちゃいます……！　っふぅうっ♪　うぅうっ♪　う～っ\n♪　ぺろぺろ、ぺろぺろ気持ちいい……♪　はぅうっ、ううぅ……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0503127" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「んんぁっ！？　だ、旦那さま……中に舌が入ってきてます、やっ……♪　ず\nぷっ、て……。あっ♪　ぁっあっ、内側を舐めまわされて……あっぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0503128" ]},
		{"command":[ "SETIMAGE", "0", "still_00022105_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ひぃんっ♪　出し入れしちゃだめですぅうっ……！　あ～～っ♪　ヘンなか\nんじです、ゾクゾクが止まらなくて……っ♪　ひぅ、んん、んぁんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0503129" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「お……おトイレにいかせてくださいぃ……！　こ、このままじゃ……ぜった\nいに……んんぅっ♪　だ、だんな、ひゃま……っ、らめ……♪　らめれすぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0503130" ]},
		{"command":[ "SETIMAGE", "0", "still_00022105_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「漏れちゃいますのぉっ！　あっ！　しーしーでちゃいますのっ……！　なに\nよりもたいせつで、だいすきな旦那さまのお顔にかかったりしたら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0503131" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「わたくし、申し訳なくて死んでしまいます……！　……んふっ！？　あ、浴\nびたい……？　むしろ出してほしい？　ど、どういうことですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0503132" ]},
		{"command":[ "SETIMAGE", "0", "still_00022105_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あっ、ぁっ、む、むずかしいです、旦那さま……！　ほ、ほんとうに、漏れ\nちゃいます……！　あぁっ♪　あぁ、は、恥ずかしい……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0503133" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ひぅうっ♪　腰が勝手に浮いて……、旦那さまのお口に、わ、わたくしのお\nまんこ……押しつけちゃってます、やめてもらわなきゃいけないのにっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0503134" ]},
		{"command":[ "SETIMAGE", "0", "still_00022105_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「こ、このままつづけてほしくて……っ♪　あぅっ♪　ぺろぺろ気持ちいいで\nす！　んんっ♪　ふぅうっ♪　おまんこ、おまんこきもちよくて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0503135" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ひぁああああああっ♪　ああああああッ♪　ふぁあああぁ……っ♪　あっ！\n？　あふれだして……！　旦那さまのお顔に、いっぱいぃ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0503136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022105_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ご、ごめんなひゃい……ごめんなひゃいぃい！　でもとまらない、ですの…\n…っ！　およめさん、なのに、わたくし、立派なオトナですのにぃっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0503137" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「しーしーおもらしして……！　赤ちゃんです！　がまんできないくらい気持\nちよくて……！　っああああっ♪　くぅうううっ♪　んぁああああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0503138" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あ～～っ♪　あっぁっあっ♪　ぷしゃーっ、ぷしゃーっておしっこが……！\n　……んん？　これはおしっこではなく、潮……というのですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0503139" ]},
		{"command":[ "SETIMAGE", "0", "still_00022105_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「わたくしが今、粗相をしたのは潮吹きという現象で……限界以上に快感をお\nぼえた時に自然とそうなる、しかたのないこと……？　ほんとうですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0503140" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「……およめさん失格かと思って、泣いちゃいそうになりました……。よかっ\nた……。で、でも、オトナの女性とはこれは違うかもしれません……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0503201" ]},
		{"command":[ "SETIMAGE", "0", "still_00022105_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「旦那さまは、こどものおよめさんでもいいですか……？　って、うぁんんっ\n♪　こ、答えるまえにまたおしゃぶりするのはずるいですぅうっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0503202" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「お股をれろれろされると、な、なにも、かんがえられなくなって……おばか\nさんになってしまい、ましゅ……っ。おまんこがヒクヒクして……んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0503203" ]},
		{"command":[ "SETIMAGE", "0", "still_00022105_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「だ、だらしのないお顔になってしまいますの……っ♪　やっ、あぁ、み、み\nないでください……。それに、敏感なところばかりをせめられているとっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0503204" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「涙が出てしまいそうになります……んぁあっ♪　き、気持ちいいのに泣いて\nしまいそうになるなんて……わたくしはどうなってしまうのですかぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0503205" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ふッ……んんんっ♪　んんんっ、ふぁあ……っ♪　旦那ひゃま……♪　おま\nんこの外も、中も、熱烈な勢いでねろねろとねぶって、舐めたりして……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0503206" ]},
		{"command":[ "SETIMAGE", "0", "still_00022105_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「お、おかしくなってしまいますよぉ……！　あっ♪　わたくしに愛、を与え\nてくださるのはうれしいです、でも、でも……ぉっ♪　あふっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0503207" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「そんなにおつゆをのまないでください、お股のシロップ……はぁっ！　あっ\nぁっ、それにさっきおもらししたお潮……ぜんぶゴクゴクって……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0503208" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あ、あまり刺激すると……またお潮がぷしゃあああって出ちゃいます……！\n　それとも、今度はおしっこでしょうか……っ、あうぅっ、困ります！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0503209" ]},
		{"command":[ "SETIMAGE", "0", "still_00022105_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「じ、自分できゅーってこらえて、がまんするのがすっごくむずかしいんです\n……！　お股、ジンジンうずいて……制御できなくて……っ、はぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0503210" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「んんぅ！？　こ、今度はおっぱいをくにくにしながらクンニしますの……！\n？　そ、それは……とけちゃいます、頭ゆだっちゃいますっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0503211" ]},
		{"command":[ "SETIMAGE", "0", "still_00022105_01_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あひぃっ♪　おっぱいも♪　おまんこも♪　どっちも気持ちよくて♪　なに\nもかも旦那さまも思うままで……も、もう、わたくし……わたくしぃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0503212" ]},
		{"command":[ "SETIMAGE", "0", "still_00022105_01_11" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「理性、が……もちません、……え？　お潮やおしっこが出る前にイかせれば\nだいじょうぶ……？　あふれる前にイかせてみせる？　ふぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0503213" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「だ、旦那さまのぺろぺろがとても上手なことはもうわかりました……っ、で\nすがわたくしがイくのが遅れれば出て、しまいますし……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0503214" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「た……たぶん、イッても出てしまうと思います～っ……！　水着だからだい\nじょうぶ？　わたくしではなく旦那さまが濡れてしまうのがつらいのです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0503215" ]},
		{"command":[ "SETIMAGE", "0", "still_00022105_01_12" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ああっ！　ぁっ♪　あっ、ど……どかなくて本当に後悔っ、し、しないので\nすか……っ！　ほんとうに……もう、すぐにでも漏れそうです……ぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0503216" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「い……いいんですの？　わたくしのお潮、もしくはおしっこが、旦那さまの\nお顔や身体に降りかかってもよろしいんですか？　っんんんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0503217" ]},
		{"command":[ "SETIMAGE", "0", "still_00022105_01_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁ、ほかの方にはぜったいにそんな姿お見せできません……！　\nそれでも……っ、あぁんっ♪　旦那さまにだけなら……あっあっぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0503218" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「見られてしまっても、いいです……！　いちばん恥ずかしいわたくしの姿、\nいちばんえっちなわたくしを見て……ください！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0503219" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「どうか、どうかきらいにならないでくださいませ……っ♪　イ、イキます…\n…っ、おまんこぴちゃぴちゃされていっぱいイキます～っ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0503220" ]},
		{"command":[ "SETIMAGE", "0", "still_00022105_01_12" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ふぁああああんんっ♪　んぁあああああっ♪　あああああ～～～～っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0503301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022105_01_16" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ちゃ……ちゃんとお潮、出ましたか……！？　おしっこではなく、イッた証\nが……っ♪　あっ、あああ……♪　よかった、お潮が出せたのですねっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0503302" ]},
		{"command":[ "SETIMAGE", "0", "still_00022105_01_14" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「透明で、サラサラで……香ばしいかおりのない、純粋なお潮……っ♪　あっ\n♪　ぷしゃあっ、ぷしゃあって……１回目とおなじです、……んんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0503303" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「勢いよく、旦那さまの目の前に……♪　はしたないことなのに、とてもすっ\nきりしてしまいます……！　ふぁあぁっ、次々にほとばしって……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0503304" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あんっ、あぁんっ！　こんなにたくさん……わたくしの中にお水が入ってい\nた、なんて……！　あぁっ♪　身体の中のわるいもの、が♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0503305" ]},
		{"command":[ "SETIMAGE", "0", "still_00022105_01_13" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「旦那さまのお口で吸い出されていくのをかんじますっ……！　おまんこの中\nからキレイになっていくような……っ♪　心が解放されていくようなっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0503306" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「はぁっ、んんんん……！　……あ……♪　ぜ、ぜんぶ出せました……。あり\nがとうございます、新しいことを教えてくれて……はぁ、はぁ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0503307" ]},
		{"command":[ "SETIMAGE", "0", "still_00022105_01_15" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「いつも旦那さまは、わたくしの思いもおよばないすごいことを……教えてく\nださいますの……。他のだれも教えてくれなかったこと……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0503308" ]},
		{"command":[ "SETIMAGE", "0", "still_00022105_01_14" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「……それなのに、わたくしはやきもちをやいたり、旦那さまの気をひこうと\n必死になったり……。こどもっぽくてはずかしいです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0503309" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「尊敬する旦那さまのことを、もう疑ったりなんてしません。宇宙一の男性に\nこれほど愛してもらえるなんて……感謝してもしたりませんの……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0503310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「んんんっ……！　……あっ！？　だ、旦那さま……っ、こ、これっ……！　\nさっきとは違って……！　あっ、あああっ、うううっ、うう……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0503401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022105_01_20" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「わ……わたくしがイこうとした直前に、おまんこがゆるんで……おしっこが\n、お潮ではなくおしっこがじょろろろって……飛び出してしまいました！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0503402" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ふぁっ……あああっ、だめ……だめ、だめっ！　旦那さまにお漏らしをかけ\nるなんて、ゆるされません……っ！　止まってぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0503403" ]},
		{"command":[ "SETIMAGE", "0", "still_00022105_01_19" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あっ！　も、もうこんなにかかって……。ふぅうう……っ！　と、とんでも\nない粗相をしてしまいましたの、なのにどうして笑っているのですかぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0503404" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あっ♪　ちょろろろって……んんっ、勢いがよわまっても……っ。旦那さま\nがよけてくださらないから、ぜんぶ、お漏らしかかっちゃいました……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0503405" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「机にもこぼしてしまって……、それなのに、ぜんぜん止まらなくて……！　\nふぁ……♪　はやく、はやく終わってくださいぃい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0503406" ]},
		{"command":[ "SETIMAGE", "0", "still_00022105_01_17" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「……ぐすっ。わたくしに……幻滅しましたか？　大好きな旦那さまをおトイ\nレがわりにしてしまうなんて……自分がしんじられません……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0503407" ]},
		{"command":[ "SETIMAGE", "0", "still_00022105_01_18" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「お潮だけでもはずかしかったのに……。え？　おしっこも、あたたかさや匂\nいがちがって堪能した……？　う、うそです、そんなはずは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0503408" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「……もしかして、本心で言ってますの？　わたくしの出したものなら、なん\nでも飲み干したいくらいだと？　なんて愛情の深い方……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0503409" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「まだまだ、旦那さまには……わたくしの知らない愛情表現があるのですね。\nそれを知りたいような、こわいような……すごく、すごく驚きです……」", "NORMAL" ]},
