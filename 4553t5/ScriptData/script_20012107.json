{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0156" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「それで？　あなたたちの目的はなんです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_030021720001" ]},
		{"command":[ "SETCHARA", "0", "char_00005003_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "鋭い氷華の一喝に、怪人・ハチ乙女と取り巻きの戦闘員達がビクッと震え上が\nる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETCHARA", "0", "char_00021901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハチ乙女" ]},
		{"command":[ "SETTEXT", "「えっ？　も、目的……。目的、目的は～……その～……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_010021720001" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「これっ、これです！　この紙を見てください！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_010021720001" ]},
		{"command":[ "SETCHARA", "0", "char_00018201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "戦闘員Ｈの差し出したカンペに目を通し、ハチ乙女はおずおずと宣言しなおし\nた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETCHARA", "0", "char_00021901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハチ乙女" ]},
		{"command":[ "SETTEXT", "「ス、スパリゾートの占領……です！　えっと！　さっきも一応言ったんです\nけどぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_010021720002" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハチ乙女" ]},
		{"command":[ "SETTEXT", "「聞こえていらっしゃらなかったようなのでもう一回言いますねぇ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_010021720003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハチ乙女" ]},
		{"command":[ "SETTEXT", "「えっ、えっと！　このスパリゾートは我々が乗っ取った！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_010021720004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "客１" ]},
		{"command":[ "SETTEXT", "「なんだって……？　やっぱり、あいつらワルじゃねえかっ」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "客２" ]},
		{"command":[ "SETTEXT", "「ひどいっ！　せっかく有給取って遊びにきたのに！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "客３" ]},
		{"command":[ "SETTEXT", "「バーカバーカ！　大人はなぁ！　休みを取るのも大変なんだぞ！　わきまえ\nろ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハチ乙女" ]},
		{"command":[ "SETTEXT", "「……めちゃくちゃブーイングされてるぅううう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_010021720005" ]},
		{"command":[ "SETCHARA", "0", "char_00021901_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「それに、残念だがその目論見は達成できんぞ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハチ乙女" ]},
		{"command":[ "SETTEXT", "「な、なんでですか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_010021720006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まったく、お前らも運が悪いぜ。よりにもよって今日、ここを襲撃しちまう\nんだから」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ここにはＥＤＯとΩ組、そして仮面戦隊マスカレードの２人まで揃っちまっ\nてる」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「よーく俺の後ろを見てみろ……。どう考えてもパンピーじゃない皆さんのお\nでましだ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「……今、この保養施設を乗っ取る、と言ったな？　怪人ども？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_040021720001" ]},
		{"command":[ "SETCHARA", "0", "char_00004904_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「ひっ、なんて目力！　その上ムチムチグラマラスボディ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_010021720002" ]},
		{"command":[ "SETCHARA", "0", "char_00018201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「あまりオイタは感心しませんねぇ。せっかくのバカンスが台無しじゃああり\nませんか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_030021720001" ]},
		{"command":[ "SETCHARA", "0", "char_00003303_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「ふあああああ！　怖いです……！　ごめんなさい、ごめんなさい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_010021720001" ]},
		{"command":[ "SETCHARA", "0", "char_00018301_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「つーか、面白くなってきやがったぜ。いい度胸じゃねえか、ちょうど運動が\n足りなかったところだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_040021720001" ]},
		{"command":[ "SETCHARA", "0", "char_00003404_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「同感です。……ほむら、あなたと同じ気持ちであることは誠に遺憾ですが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_030021720002" ]},
		{"command":[ "SETCHARA", "0", "char_00005003_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「あ～？　ウズウズしてんのはわかってんだぞ？　氷華」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_040021720002" ]},
		{"command":[ "SETCHARA", "0", "char_00003404_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「……知りません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_030021720003" ]},
		{"command":[ "SETCHARA", "0", "char_00005003_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「果てしなく運の無い人達ですよねぇ、昨日か明日なら助かったのに」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_030021720001" ]},
		{"command":[ "SETCHARA", "0", "char_00007903_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハチ乙女" ]},
		{"command":[ "SETTEXT", "「あ、あれ……？　なんか、ヤバいオーラが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_010021720007" ]},
		{"command":[ "SETCHARA", "0", "char_00021901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「さぁて、ケジメつけてもらいましょか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_030021720002" ]},
		{"command":[ "SETCHARA", "0", "char_00003303_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「リゾート警備の休日勤務……。面倒だが、準備運動と思って楽しむとしよう\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_040021720002" ]},
		{"command":[ "SETCHARA", "0", "char_00004904_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「圧倒的強者の迫力ぅううう！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_010021720001" ]},
		{"command":[ "SETCHARA", "0", "char_00018401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「氷華、テメェは何もしなくていいぜ？　オレが４人まとめてブッ飛ばしてや\nるからよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_040021720003" ]},
		{"command":[ "SETCHARA", "0", "char_00003404_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「冗談でしょう。この場で最大の戦果をあげられるのはこの私です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_030021720004" ]},
		{"command":[ "SETCHARA", "0", "char_00005003_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「勝利前提であたしたちを倒す数、競ってるしぃ～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_010021720002" ]},
		{"command":[ "SETCHARA", "0", "char_00018301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "全員からほとばしる威圧感に怯え、ハチ乙女と戦闘員たちはすでに涙目だった\n……。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}