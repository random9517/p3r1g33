		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ジュ……ジュンジロー……お前もか……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「彼女たち……夢で動けない私によってたかってブラッシングやなでなでを…\n…！！」", "NORMAL" ]},
