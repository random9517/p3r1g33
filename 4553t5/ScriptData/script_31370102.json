{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「あの……き、来ました。一体何のご用でしょうか、隊長殿。拙者、任務を終\nえたばかりで、早く休みたいのですが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0104101" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00013701_01", "0", "CENTER", "0" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「ひっ！？　ど、どうしてイチモツが丸出しなんですか！？　早く閉まってく\nださい、それ！　それとも、もしかして……ごくっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0104102" ]},
		{"command":[ "SETCHARA", "0", "char_00013701_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「よ、横になれって、そんな、まさか……エッチなこと、するつもりなんです\nね。しかも、拙者が命令されるの嫌いなのを知って、わざと命令を」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0104103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「なんて卑劣なんでしょうか、隊長殿は。普段は尊敬していますが、こういう\nところだけは本当にゲスですね。命令して、無理矢理……む、無理矢理……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0104104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「は、はい。これで、どうですか？　やけに素直って、命令したのは隊長殿で\nはないですか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0104105" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00013701_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「ひああ！？　し、しかも、言いながら、いきなり触った！？　い、息、吹き\nかかって、くすぐったい！　ぬ、濡れてるとか、言わなくていいですから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0104106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「って！？　イチモツが、あそこに！？　ひう！？　動くなって、また、命令\n……う、うぅ。命令されて、拙者の中に、隊長殿が……あ、ふああ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0104107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「はうううううう！　は、入った。入って来ました。隊長殿の、イチモツ。か\nたくて、たくましくて……ふああ！？　びくびく震えてるのがぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0104108" ]},
		{"command":[ "SETIMAGE", "0", "still_00013701_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「い、嫌では、ない、です。命令されるのは嫌いですが、まぐわること自体は\n、むしろ……ふあぁぁ、痺れるような感じで、好き、ですぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0104109" ]},
		{"command":[ "SETIMAGE", "0", "still_00013701_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「ん、あ、あ、あ、あ！？　動き出した！？　そんな、声、出すなって、命令\n……んぐっ！　ん、んん！　んむぅ……んん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0104110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「む、無理、です、隊長殿。声……ひああ！？　声、出ちゃう！　我慢……ん\nんんっ、ぐっ、無理ぃぃ……ひゃああ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0104111" ]},
		{"command":[ "SETIMAGE", "0", "still_00013701_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「声を我慢してる顔、可愛いなんて……うぅ、隊長殿は、やっぱり、特殊性癖\nの持ち主ですぅ……うぅぅぅぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0104112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「命令、嫌なくせに、反応が良いですって！？　ば、馬鹿！　馬鹿です、隊長\n殿！　そんなこと、あり得ませんから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0104113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「そんなこと──ふあああ！？　くぅぅ……イチモツが、気持ちいい場所、付\nいてくるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0104114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「も、もう、我慢、できないっ！　それに、隊長殿のイチモツも、びくびく震\nえて……あ、あ、あ、あ！？　駄目、です！　隊長殿～～～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0104115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「ひゃあああああああああああ！　熱い！　熱いのが、中にぃ！　んんん！　\nびゅくびゅく、出てる！　種付け、されてしまってます～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0104116" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00013701_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「はうぅぅ……たぷんたぷん、ですぅ、お腹ぁ……どろどろしたのが、拙者の\n中に、いっぱい、ですぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0104117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「言った通りでしょ？　隊長殿なら、道具に頼らずとも、相手を満足させられ\nるって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0104118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「拙者、命令されて、心まで縛られたような気分になって、そうしたら無理矢\n理犯されてるような気がして……こ、興奮、してしまいました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「か、勘違いしないでくださいよ！　誰に対してもレイプ願望があるわけでは\nなく、隊長殿だからですからね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0104120" ]},
		{"command":[ "SETIMAGE", "0", "still_00013701_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「命令されるのが嫌いなのだって、本当ですからね！　暗殺集団に教育されて\nいた頃を思い出して、辛いんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0104121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「んああ！？　ちょ、ちょっと、隊長殿！？　話の最中に、動くの、ずるいで\nす！　第一、イッたばっかりで、感じすぎる！　ひゃああ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0104122" ]},
		{"command":[ "SETIMAGE", "0", "still_00013701_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「湿っぽいのは嫌だって言われても～！　あ、あ、あ、あ！？　感じ過ぎちゃ\nいますぅぅ！　ひっ！？　我慢しろって、命令……うぅぅぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0104123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「命令、駄目！　ぞくって、しちゃう！　身体、ぞくぞくして、また、すぐに\n、キュンって！　お腹の奥、きゅんきゅんしてぇぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0104124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「う、うそ！？　こんなにすぐ、また！？　拙者、また！？　あ、ふあああ！\n？　隊長殿！　隊長殿～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「あ、あ、あ、あ！　イクイクイクぅ！　イッちゃいます！　イケって、命令\n、してください～！　ああ、嬉しいです！　んあああああ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「イクぅううぅぅううぅぅぅううぅ！　……はふぅ！　はぁ、はぁ、はぁ……\nふあぁぁぁ……い、イッちゃいましたぁ。二回目、すぐ、にぃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0104127" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00013701_02_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「子種も、子宮に直接注がれて、おかげでさっきよりも、たぷんたぷんで、お\n腹、膨らんじゃってます。まるで、妊娠してるみたいです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「も、もう、駄目ぇ。少し、休ませてくださ──いいいいいいい！？　あ、あ\n、あ、あ！　そんな、また、動いたぁぁ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「三回目……ひうううう！？　め、命令、でも、これ、無理ぃぃ！　んああ！\n？　駄目です！　駄目駄目駄目ぇ！　感じ過ぎるぅぅぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「気持ち良すぎて、苦しい、です！　隊長、殿～！　拙者、頭、駄目、全部、\n駄目になるぅぅ！　しゅごすぎて、駄目になりますぅぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「あ、あ、あああ！？　奥に！？　今までで、一番、奥にぃぃ！　ひううう！\n？　子宮の入り口、先っぽが、叩いてるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「こ、こんなの、こんな、の～！？　しゅごすぎて、死んじゃう！　死んじゃ\nいますぅぅぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「ほ、本当です！　これ……死ぬほど気持ちが良いんですぅ～！　ひああ！　\n頭、真っ白～！　もう、だめぇぇぇぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「ふああ！？　全身で、隊長殿の、精液を、全部！？　命令、なんです、か、\nそれぇ！？　は、はひぃ！　だったら、受け止めますぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0104135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「ふあああ！？　イクぅ！　こんな、短い時間に、連続して、三回もなんてぇ\nぇ！　イクぅぅ！　イクイクイクの～！　いくぅぅぅうう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0104136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「ひゃああああぁぁああぁあぁあぁああ！　あ、ああ、あ、あ……ふあぁぁぁ\n……本当に、死ぬかと、思っ、た、ですぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0104137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00013701_02_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「熱いの、身体に、へばりついてる……最後は、身体中に、白くてどろどろし\nたの、ぶちまけられちゃい、まし、た。しかも、こんなに、たくさん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「全部、受け止めました……命令どおり、全部ぅ。ちゃんと、受け止めました\n。えへへ。喜んでもらえて、嬉しい、です……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0104139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「だって、他人を傷つけることしかできなかった拙者が、こうして誰かから求\nめられて、喜んでもらえるなんて……嬉しすぎて、涙が出そうです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「ふぁああああ！？　な、なんですか！？　なんでまたいきなり挿入……はぁ\nああん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0104201" ]},
		{"command":[ "SETIMAGE", "0", "still_00013701_02_17" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「ちょ、ちょっと待って……！　拙者がいいお話をしてる最中に、いきなり挿\n入とか反則……はぁああん！　あっ！　あっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「んぁあああっ！　あ、あまつさえ、いきなり腰を……使いだすとかぁ！？　\n隊長殿、エロの鬼ですかぁ！　あああん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「あ、あ、あ、ああああっ！　そんなぐいぐいこすられたら……はぁああん！\n　あっ、あっ！　んんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0104204" ]},
		{"command":[ "SETIMAGE", "0", "still_00013701_02_18" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「んぁああん！　ど、どうしてぇ！　どうしていきなりこんなことするんです\nか……ふぁあん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0104205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「ふぇえ……！？　隊長殿が、拙者を必要としてるって……伝えたかった？　\nんあぁああん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0104206" ]},
		{"command":[ "SETIMAGE", "0", "still_00013701_02_16" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「あ、あ、あああああっ！　そんな……！　隊長殿、また反則ですぅ！　こん\nなことしながら、そんなこと言われたら……ふぁああん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0104207" ]},
		{"command":[ "SETIMAGE", "0", "still_00013701_02_18" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「拙者、胸がきゅんきゅんしちゃうじゃないですかぁ！　はぁああん！　ああ\nああっ！　胸がきゅんきゅん、子宮もきゅんきゅんで……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「あ、あああああっ！　腰が、腰がずんずん動いちゃって！　あああああ、子\n宮の入り口も、またまたぱっくり開いちゃってぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「あ、あ、ああああっ！　腰が勝手に、子宮をイチモツに押し当てに行っちゃ\nいますっ！　あ、あ、ああああん！　はぁあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0104210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「隊長殿！　隊長殿ぉ！　もっと、もっと動いて……そう！　そうですぅ！　\n子宮、ぐいぐい潰しちゃってぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0104211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「あ、あ、あ、あ、あああああああああ～っ！　四回目ぇ！　一晩でこんなに\nイクなんて拙者……はぁああん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0104212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「ああああん！　またぁ！　そうやって、拙者がイクとすぐ動くぅ！　ちょっ\nと待って休ませ……はぁあああん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0104213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「あ、あ、あ、ダメダメ！　そんなにされると、気持ち良すぎて……はぁあん\n！　あっ、あっ、あっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0104214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「ひゃうぅうん！　らめぇ！　んあぁああああっ！　あああん！　なんでぇ！\n　隊長殿の、拙者の中でまた大きくなってるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0104215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「なんでですかぁ！　もう、充分膨れ上がってると思ってたのに、なんで隊長\n殿のイチモツ、それ以上に大きくなるんですかぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0104216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「ふぇ？　え？　隊長殿もイキそうだから？　ああああ、やっとですか！　い\nいですよ！　イッてください！　拙者の五回目と共にっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0104217" ]},
		{"command":[ "SETIMAGE", "0", "still_00013701_02_17" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「あ、あ、ああああっ！　ホントだ！　隊長殿のイチモツ、ピクピク震えて\nますぅ！　わかります……っ！　くぅううっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0104218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「んあぁああああっ！　きましたね！？　ラストスパートですね！　いいです\nよ！　イッて！　イッてください……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0104219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「あ、ああああああああああ～っ！　ダメダメもうだめ！　拙者がイッくぅう\nうううううう～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0104220" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},
		{"command":[ "LABEL", "LABEL1" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「んっはぁあああああああああ～～～っ！　き、来たぁ～～っ！　来てます！\n　来てますぅ！　隊長殿の精液が！　熱いのがぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0104301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00013701_02_21" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「んぁあああっ！　あっ！　あっ！　すっごい勢いで！　隊長殿の精液が、拙\n者の子宮に飛び込んでいきますっ！　あっ！　あっ！　ふあぁあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「んんんんっ！？　まだ来るぅ！？　どっくんどっくん、隊長殿のイチモツが\n脈打ちながら、拙者の中に精液を送り込んで……はぁあん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0104303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「あ、あ、あ、あ、そんなに出されると、拙者、体の中から精液に溺れちゃい\nますぅ！　んあああああん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0104304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「ああああああ……も、もう終わりですか……？　んあっ！？　まだあったぁ\n！？　ひぃいん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0104305" ]},
		{"command":[ "SETIMAGE", "0", "still_00013701_02_19" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「あ……あ、あああ……だんだん……収まってきましたね……すごかった……\nすごい量でした」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0104306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「結局拙者、何発出されちゃったんでしょう……中と、外合わせて……考える\nだけで、気が遠くなりそうです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0104307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「もしかして、拙者、妊娠しちゃうんじゃないですかね？　そうなっちゃった\nら、どうしましょう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0104308" ]},
		{"command":[ "SETIMAGE", "0", "still_00013701_02_20" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「って、心配することないですね。今の拙者は暗殺者じゃないんだし、子供が\nできたら、普通に育てることだって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「もちろん！　隊長殿にも父親として協力してもらいますからね！　ふふふふ\nふふっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},
		{"command":[ "LABEL", "LABEL2" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「ふあああああああん！？　どうして急に抜いて……あああああっ！？　あっ\n！？　ま、またかけるんですかぁ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0104401" ]},
		{"command":[ "SETIMAGE", "0", "still_00013701_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「あ、あ、あん！　あああんっ！　はぁああああっ……熱くてどろどろの精液\nが、体中に降りそそいで……！　はぁああ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0104402" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00013701_02_24" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「あ、あ、んあぁああっ！？　まだ飛んでくるんですか！？　こ、これ、何発\n目でしたっけ！？　あああん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0104403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「ふぁああああ……もう、何度も出してるのに、まだこんなに濃くて……どろ\nどろで……ふぁあああ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0104404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「見てください、こんなにたくさん出すから、拙者もう、すっかり隊長殿の精\n液色に染まっちゃって……真っ白になっちゃって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0104405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「それにしても隊長殿、拙者にぶっかけるの好きですね……？　え？　中に出\nすのも好き？　はあ……知ってましたけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0104406" ]},
		{"command":[ "SETIMAGE", "0", "still_00013701_02_22" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「しかし、ちょっと冷静になってみると……この部屋、すごい匂いですよ。二\n人の汗と、精液と、愛液の匂いが入り交じって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0104407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「はぁああ……すごい匂い、空気全体が、なんていうかいやらしい匂い。その\nせいか、呼吸してるだけで……ああああ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0104408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「あああああ、もうだめ！　呼吸してるだけで、拙者また発情してきちゃいま\nす！　た、隊長殿っ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0104409" ]},
		{"command":[ "SETIMAGE", "0", "still_00013701_02_23" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「幸いにも隊長殿のイチモツ、まだ元気にそそり立ったままですよね？　せっかく\nですから……もう一回、お願いしてもいいですよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0104410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
	{"command":[ "EXIT" ]}
	]
}