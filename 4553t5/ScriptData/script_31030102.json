		{"command":[ "PLAYVOICE", "103_0104134" ]},		{"command":[ "SETNAME", "急" ]},		{"command":[ "SETTEXT", "「えええ？　やぁぁん……出しちゃ駄目ぇ……オマンコの中……きゃうぅ、あ\nはぁ……出して、中に……あ、あ、ああぁぁぁあん♪」", "NORMAL" ]},
