		{"command":[ "PLAYVOICE", "103_0104104" ]},		{"command":[ "SETNAME", "急" ]},		{"command":[ "SETTEXT", "「あぁ……オチンチンが、すごぉい……これが、ボクのアソコに……オマンコ\nに、入っちゃうんだよね？　うわぁぁぁ……緊張するぅ……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "103_0104105" ]},		{"command":[ "SETNAME", "急" ]},		{"command":[ "SETTEXT", "「え？　もう挿れちゃうの？　あぁ、来たぁ……とうとう、この時が……ボク\n、大人になっちゃうんだね……ああ、ドキドキするぅ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010301_02_01" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "103_0104106" ]},		{"command":[ "SETNAME", "急" ]},		{"command":[ "SETTEXT", "「んはぁぁぁ！！？　うぐぅ、あうぅぅ……ちょ、な、何、これ……痛いん、だ\nけど……あ、あぐぅ、ひゃうぅぅぅ……っ」", "NORMAL" ]},
