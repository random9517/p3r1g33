		{"command":[ "PLAYVOICE", "103_0104208" ]},		{"command":[ "SETNAME", "急" ]},		{"command":[ "SETTEXT", "「でも、ボクがセックスしただなんて知ったら……んくぅ、あはぁ……きっと\n叱られるんだろうなぁ……はぁ……はぁ……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
