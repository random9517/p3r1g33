		{"command":[ "PLAYVOICE", "103_0104203" ]},		{"command":[ "SETNAME", "急" ]},		{"command":[ "SETTEXT", "「ん……あぁぁ……動いてる……オチンチンが、中でズリズリしてるぅ……は\nぁ、はぁ……あはぁぁぁん……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "103_0104204" ]},		{"command":[ "SETNAME", "急" ]},		{"command":[ "SETTEXT", "「オマンコの感じ、さっきと違う……。これって、どーしてぇ？　精液のせい\n……？　ん、はぁ……んん……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "103_0104205" ]},		{"command":[ "SETNAME", "急" ]},		{"command":[ "SETTEXT", "「さっき、中で引っかかるような感触があったんだけど、今、そーいうの無い\nんだよね……あぁん……アソコが、オマンコが……気持ちいい……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
