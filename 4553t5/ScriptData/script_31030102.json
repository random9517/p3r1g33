		{"command":[ "PLAYVOICE", "103_0104210" ]},		{"command":[ "SETNAME", "急" ]},		{"command":[ "SETTEXT", "「ねえ、もっと激しくしていいよぉ……はぁ、ふぅ……多分ボク、だいじょぶ\nだから……だって、サムライなんだもん……んふふ」", "NORMAL" ]},
