{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000411_01_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「きゃあああぁぁぁっ！？　な、何チンポをおっぱいに挿れてやがるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1103101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「敗者は勝者の言うことを聞くものって……！　お、オレは別に負けてなんか\n……！　んっ、あっ、うぐっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1103102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「やっ、やめっ……！　これ以上さらしを締め上げるな……！　そんなことさ\nれたら、余計に胸が締まって……んふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1103103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「わ、わかった！　認める！　さっきの勝負はオレの負けでいいっ！　だから\nおっぱいを刺激するなっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1103104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「クソっ……！　そもそもオレが負けたのは、お前が変な勝負を持ちかけてき\nたからで……！　喧嘩だったらオレの勝ちなのに……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1103105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「な、何だよ、その目は……！　えっ……？　負けたメス犬にはエッチなオシ\nオキをする……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1103106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「はぁ！？　ふざけんなっ！　誰がお前の命令なんて……ひっ！？　あっ、あ\nっ……！　やっ、またさらしが締まって……！　んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1103107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「わかった……！　言う通りにする……！　お前の命令を聞くから、オレのお\nっぱいを虐めないでくれ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、あふっ……！　それで……？　オレは今から何をすればいい\nんだ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「おっぱいを使ってチンポをシゴいて、気持ちよくさせろ……？　くっ……！\n　わかった……やればいいんだろ、やれば……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「んっ、んっ……！　あっ、あふっ……！　こんな感じでいいのか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1103111" ]},
		{"command":[ "SETIMAGE", "0", "still_00000411_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「……もっと気合を入れてシゴけって……パイズリに気合もクソもないだろ…\n…！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「そもそも、おっぱいでチンポをシゴくっていう発想がどうかしてるんだ……\n！　おっぱいはこんな風に使うものじゃ……あんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「わ、わかったっ！　ちゃんとおっぱいでチンポをシコシコするっ！　口答え\nもしないからっ！　だからさらしを締め付けるなっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1103114" ]},
		{"command":[ "SETIMAGE", "0", "still_00000411_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「くっ、あふっ……！　この、変態野郎が……！　んっ、あっ……ふっ、あぐ\nっ……！　んっ、んっ……あんんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1103115" ]},
		{"command":[ "SETIMAGE", "0", "still_00000411_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「おっぱいがチンポをズリズリするたびに、チンポの熱と脈を打つ感じが伝わ\nってくるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「カリが谷間の中に埋まって、強く擦れて……！　ひっ、あっ……！　無理や\nり、感じさせられてる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「んっ、んんっ……！　こうしてシゴいてると、オレの乳首もどんどん大きく\nなってくるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「勃起した乳首が晒しに当たって……！　あっ、あぁんっ！　おっぱいを動か\nすたびに、チンポと乳首で感じさせれちまうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「ひぁぁぁ！？　チンポの先端からエッチな汁が垂れてきてるっ……！　お、\nオレのおっぱいが汁まみれにされてるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1103120" ]},
		{"command":[ "SETIMAGE", "0", "still_00000411_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「それに変な臭いも漂ってきて……！　お、おいっ！　このいやらしい汁を止\nめろっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「チンポが気持ちよくなると出る汁だから、止めようと思っても止まらないだ\nと……？　くっ……！　なら、無理やりでも止めてやる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「もっと強くおっぱいを挟み込んで、思いっきり圧をかければ……チンポが圧\n迫されて、汁も出てこなくなるだろ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「んっ！　んっ！　ぐっ、あっ、あひっ……！？　な、何でだよ……！　これ\nだけ強く押し付けてるのに、どうして汁が止まらないんだ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「この程度の圧迫具合じゃ足りないってことか……！？　なら、もっと強く挟\nみ込めば……ぐっ、あっ！　ああぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「強く挟めば挟むほど、おっぱいでチンポを感じるっ……！　オレのおっぱい\n、チンポの形になるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1103126" ]},
		{"command":[ "SETIMAGE", "0", "still_00000411_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「それに臭いもどんどん濃くなって……！　我慢汁の香りに交じって、精子の\n青臭い臭いまでしてきやがる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「これ、お前のチンポの奥に精子があって、それが少しずつ上がってきてるっ\nてことだよな……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「その通りだって言うなら、このままオレのおっぱいに精子が出されるってこ\nとに……！　お、おい！　出すときはチンポをおっぱいから抜けよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「何でって……そんなの当たり前だろ！　オレの身体をお前のドロドロした汁\nで汚すんじゃねぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「ひぃっ！？　ち、チンポがおっぱいでビクビク跳ねまくってきやがる……！\n　ま、まさか、本当に出す気じゃないだろなっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1103131" ]},
		{"command":[ "SETIMAGE", "0", "still_00000411_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「もう我慢汁で汚れてるし、精子をぶっかけても同じことって……！　精子と\n我慢汁じゃ全然違うだろっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「やっ！　あっ、んっ！　やめっ、やめろっ！　オレの身体にぶっかけるなっ\n！　谷間に射精しようとするなぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「おっぱいにお前の臭いが染みついちまうっ！　やっ、イヤだっ！　お前の臭\nいなんて欲しくないっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「あっ！　あっ！　やああぁ！　やめろっ！　出すなっ！　オレのおっぱい、\n精子まみれにするなぁぁぁっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1103135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「んんんっ！　ぐっ、あはぁぁぁっ！？　チンポの先端からびゅーびゅー精子\nが出てるぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1103136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000411_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「おっぱいに向けて勢いよく臭い汁が出されて……！　んっ、あっ！　あっ、\nあっ……あぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1103137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「チンポが跳ねるたびに、熱い感覚が次から次に襲ってくるっ……！　こんな\nの、火傷しちまいそうだっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「それに鼻の奥に精子の臭いが……！　ううぅ……！　呼吸するたびに、鼻の\n中まで犯される感じがするっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「あっ！　あっ！　もうやめろっ！　これ以上精子出すなっ！　オレのことを\n弄ぶなぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1103140" ]},
		{"command":[ "SETIMAGE", "0", "still_00000411_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「くううぅ……く、屈辱だ……！　お前なんかにおっぱいを好き勝手されるな\nんて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1103201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「だけど、これで終わりだ……！　１回出したんだから、もうお前の命令を聞\nく義理なんてない……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「えっ……？　なら今度は違う勝負をしようって……？　どっちが先にイクか\nで勝敗を決めるって……な、何だよそれっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1103203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「そんなの、今までしてたことと何も変わらねぇし……！　はぁ！？　誰が意\n気地なしだ！　オレがお前なんかに負けるわけねぇだろっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1103204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「い、いいぜ……！　オレの本当の実力ってヤツを見せてやる……！　せいぜ\nい先にイかないように、我慢するんだな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1103205" ]},
		{"command":[ "SETIMAGE", "0", "still_00000411_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「んっ、んっ！　どうだっ……！　精子のおかげでさっきより滑りがいいから\n、気持ちいいだろっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1103206" ]},
		{"command":[ "SETIMAGE", "0", "still_00000411_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「それに射精したばっかりなんだ……！　チンポが敏感になってて、すぐイク\nに決まってる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「第一、オレはオマンコを弄られたりするわけじゃねぇんだ……パイズリなん\nかでイクわけがねぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「この勝負、貰ったも同然だ……！　オレをメス犬扱いしたこと、後悔させて\nやるからなっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「ぐっ、んふっ、はぁ……あっ、あんっ……！　へへっ……！　チンポがヒク\nヒクしまくってるぜ……！　こりゃ楽勝……ひあああぁぁぁん！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1103210" ]},
		{"command":[ "SETIMAGE", "0", "still_00000411_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「ちょ、ちょっと待てっ！　何でまたさらしを引っ張って……！　あぁんっ！\n　ち、乳首がさらしで擦れるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「乳首が大きくなってるせいで、さらしが締まるたびに気持ちいいところに当\nたって……んっ！　あっ！　や、やめろっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「あっ、んっ！　はぁ、あっ……！　こ、こんなの、不公平だぞ……！　勝負\nはタイマン、ステゴロで正々堂々と……！　んんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「オレがさらしとかいう武器を巻いてるのが悪いって……！？　これは別に武\n器なんかじゃなくて……！　あっ、あああっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1103214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「クソっ……！　こうなったら、無理やりにでもチンポをシコシコして、先に\nイカせるしか……！　んっ、んっ、んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1103215" ]},
		{"command":[ "SETIMAGE", "0", "still_00000411_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「チンポを擦るたびに、ぐちゅぐちゅっていやらしい音とキツい臭いが濃くな\nってくるっ……！　耳と鼻でも感じさせられちまうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1103216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「は、早くイキやがれっ……！　じゃないと、オレももう……！　あっ、あっ\n！　やっ、ダメだっ……！　イキそうだっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「気持ちいいのが、オマンコのすぐ手前まできてるっ……！　やっ、イヤだ…\n…！　また負けるのだけはイヤだぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1103218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「うううぅ！　早くイケよぉ！　さっさとチンポから臭い精子びゅーびゅー出\nして、果てやがれっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「あっ！　ぐっ、んっ！　あっ、イクッ……！　イクッ……！　あああぁぁっ\n！　イッ、イクぅぅぅぅぅっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「あああああぁぁぁっ！？　また熱いのがびゅるびゅる出てやがるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1103301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000411_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「オレのおっぱいが真っ白に染められて……！　臭いもさらに濃くなってやが\nるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「こんなの味わわされたら、何回だってイッちまう……！　もうイッてるのに\n、またイクッ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1103303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「やっ、あっ！　イキたくない……！　ここでイッたら、また負け犬扱いされ\nるのに……んっ、んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1103304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「あっ！　あっ！　イクッ……！　チンポ汁感じながら、イカされるぅぅぅぅ\nぅっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1103305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、うぐっ……！　そんな……さらしで乳首とおっぱいを責めら\nれただけでイクなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1103306" ]},
		{"command":[ "SETIMAGE", "0", "still_00000411_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「で、でも……お前もオレと同時にイッたよな……！　なら、この勝負は引き\n分けってことで……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1103307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「お前は１回で、オレは２回以上イッたから、オレの負け……？　そ、そんな\n屁理屈が通るかっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1103308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「何回イッても、同じタイミングでイッたんだから勝負はお預けだろっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「ならもう１回勝負するかって……い、いいぜっ！　相手になってやる！　オ\nレが勝つまで、何回だって相手になってやるよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「あんんっ！？　こ、今度はおっぱいの中じゃなくて、顔に精子が飛んできて\n……んっ、んんっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1103401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000411_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「こんなの、反則だろ……！　不意打ちするとか、男らしく戦う気はねぇのか\nよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「これも相手をイカせるための戦略だと……！？　ぐっ、んんっ……！　顔に\n精子出されたくらいで、イクわけが……あっ、あっ、あんんっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1103403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「ぐううぅ……！　精子の臭いを顔全体で感じるせいで、気持ちよさが増して\nいくっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1103404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「こんなの、絶対おかしいっ……！　オレが精子を浴びて、気持ちよくなるな\nんて……！　そんなはずないのに……！　んっ、あっ……あはあぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1103405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「クソっ……！　おっぱいも顔も……精子まみれになっちまったじゃねぇか…\n…！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1103406" ]},
		{"command":[ "SETIMAGE", "0", "still_00000411_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「でも、勝負は引き分けだな……オレとお前、どっちも同じタイミングでイッ\nただろ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1103407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「引き分けだと勝負がつかないから、延長戦をしたい……？　は、はぁ！？　\nそんなことするワケが……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1103408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「なっ！？　オレが勝負から逃げるワケねぇだろ！　売られた勝負は買うし、\nタイマン上等だっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1103409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「次こそお前のチンポをオレのおっぱいで屈服させてやる！　覚悟しやがれっ\n！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1103410" ]},
