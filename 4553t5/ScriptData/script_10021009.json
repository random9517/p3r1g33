		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「わかってる！　だけどこれはどういうことだい！？　どうして学生たちがま\nた、敵の戦闘員にされてるんだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010114270002" ]},
