		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「というか襲来者（インベーダー）のしわざなら、どうすればいいかもわかる\nよね！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010114270003" ]},
