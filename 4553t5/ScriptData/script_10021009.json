		{"command":[ "SETCHARA", "0", "char_00015601_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そしてまたリーダーが、まるで円盤女たちの操り人形のように扱われていて―\n―", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "なんだよ、これ。さっきとまるで同じパターンじゃないのか……？", "NORMAL" ]},
