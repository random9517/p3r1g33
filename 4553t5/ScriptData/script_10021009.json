		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はい、そこ！　わかりきってることを真剣な顔で言わない！」", "NORMAL" ]},
