		{"command":[ "SETCHARA", "0", "char_00015601_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "円盤少女Ｂ" ]},
		{"command":[ "SETTEXT", "「ちゃんとやらないと、この学園を制圧できないでしょ！　まじめに働けー！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_010114270001" ]},
		{"command":[ "SETCHARA", "0", "char_00016301_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "屋上に行ってみると、さっきと同じように円盤女たちが怪しい機械を操作して\nいる。そしてＧ・ルナリアムの連中も駆けつける。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おい！　おまえら！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "円盤少女Ａ" ]},
		{"command":[ "SETTEXT", "「あー。来た来た～！　それじゃ、行けー！　リーダー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_010114270002" ]},
		{"command":[ "SETCHARA", "0", "char_00016201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者リーダー" ]},
		{"command":[ "SETTEXT", "「ま゛っ……」", "NORMAL" ]},
