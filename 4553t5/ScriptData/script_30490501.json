		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「隊長か。よく来てくれたな……。任務を中断させてすまない。今月、君には\nとても良く働いてもらったからな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0503101" ]},
		{"command":[ "SETCHARA", "0", "char_00004905_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「その礼と、個人的な欲求を兼ねて……私の部屋を訪ねてもらった。わざわざ\nご足労をかけた分、じっくり楽しんでくれると嬉しい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0503102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「この部屋には他に誰もいない。私と君だけだ……だから堅苦しいことは抜き\nにして、最高のオフタイムを共に楽しもうじゃないか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0503103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ふふ……。じっくりと脱がされて、陰部を露出した気分はどうだ？　いつも\n窮屈な思いをしていたチンポが解放されて……すがすがしい気持ちだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0503104" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004905_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「すん……すん……。ンン……♪　今日も臭いのこもった、男らしいオチンポ\nだな……。私はこの臭いが好きだ……蒸れていて、汗臭くてクセになる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0503105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……。こうして眼前に、巨大なペニスをぶらさげられて……おあ\nずけされるのもオツなものだ。どんどん体温が上昇して、火照ってくる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0503106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「……アソコも潤んできて……。あっ……♪　見てくれ。すんなりと人差し指\nが入ってしまった……。あっ……あっ、すごい……オチンポのこの臭い」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0503107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「それに……この大きさ。いびつな形……。見慣れない形のはずなのに、なぜ\nか本能が湧きたつ、興奮が抑えきれなくなる……。ふぅ、ふぅ、ふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0503108" ]},
		{"command":[ "SETIMAGE", "0", "still_00004905_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ずっと、本物のコレを見ながらオナニーしたかったんだ。妄想だけでは限界\nがあるだろう？　ホンモノにしかないこの質感、色、照り……ふぁあぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0503109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「リモートで仕事をしていると、たまにコレを思い出してしまって……ムラっ\nとくることがある。そうすると、頭はすぐにいやらしい事で満たされて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0503110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ここに……、くふっ……♪　オマンコに力強い、隊長の男性器をハメてほし\nくなる。無理やりねじこまれたくなる。欲しくて、おかしくなりそうで」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0503111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「……そんな時は、いつもEDOとの通信を切断してから……一人でこうして\n、指で慰めていたんだ。それどころか、最近は通信中ですらも……はぁ、はぁ\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0503112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「アソコをくちゅくちゅといじってしまう。んっ……。欲求不満のダメ長官と\n笑われても仕方ない、恥ずかしい行いなのはわかっている。しかし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0503113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「君のオチンポの魔力は、私の脳を侵して作り変えてしまった……。オチンポ\n狂いの女ですまない、……あぁ……食べてしまいたいくらい愛おしい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0503114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「君は何もしなくていいから……これをたっぷりしゃぶらせてくれ。たまに、\n適当に腰を動かしてくれればなおいい。隅々まで味わいたい……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0503115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「……ふぅっ……♪　ふっ、ふっ、ふぅっ……♪　何度見ても本当に逞しいペ\nニスだ……何度でも惚れ直してしまう。この、素晴らしい名器を……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0503116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ありがたく、感謝してごちそうになるとしよう……。んっ……。いただくぞ\n。あーん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0503117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「はむ……ぴちゃ、くちゅ……ちゅぱ……。ん、んんんん～……♪　この味…\n…この味らぁ……♪　ぴちゅ……ちゅっ、ちゅ、くちゅ……ぴちゃっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0503118" ]},
		{"command":[ "SETIMAGE", "0", "still_00004905_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁ、はぁ……全部……全部舐めふぁい……くちゅっ。先っちょも\n、肉笠も……茎も根元も……舐め回して唾液まみれにしたい……れろっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0503119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ちゅぷ……ぷちゅ、ちゅく……ぴちゃっ……。すこひ、ひょっぱいな……。\nシャワーを浴びずにここに来たのか？　まあ、それはそれでいい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0503120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「私は君の味が濃くなる、シャワー前のオチンポが好きだ。だから嬉しい……\n。熱が入る……れろぉ……れろっ、ぴちゃ……ぷちゅ、くっちゅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0503121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「んん……んむぅ……♪　どれだけ舌を伸ばしても、一度に舐めきれなくても\nどかしい……！　れろぉ……べろぉっ……ぴちゃっ、れるぅ……んんぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0503122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「オチンポに集中すると息を忘れる……。んふっ……♪　あ、ぁ、クリトリス\nをいじりながら舐める君のチンポは格別すぎる……くちゅ、くちゅ、ちゅぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0503123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「イカくさくて香ばしくて、最高のチンポに仕上げてくれてありがとう……♪\n　ちゅぱっ、ちゅぱ……相当に美味で、若干粘り気があって……ちゅぅうう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0503124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「おいひ……♪　くちゅっ……ぴちゃ、ちゅっぷっくちゅ……♪　れろっれろ\nっれろっ……舐めるのがやめられん……。もっと……もっとくれぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0503125" ]},
		{"command":[ "SETIMAGE", "0", "still_00004905_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「んちゅ……ちゅぱっ……んぅうう……♪　んむっ、むぐ……くちゅっ、ちゅ\nっぷっ……。何？　舌が長くて絡みつく？　チンポに伝わっていたか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0503126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「確かに、私の舌は吸着力が強くてよくまとわりつくだろう……？　んぁ……\nもっともっと感じていいんだぞ。ほら、わがままになるといい……ぴちゃっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0503127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「なんならこうして……ぬぷっ！　ぐちゅっ……チンポを咥えれ……ぢゅるっ\n！　舌で舐め回しながらご奉仕してやるぞ……。んっ、ぐっぷっぐっぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0503128" ]},
		{"command":[ "SETIMAGE", "0", "still_00004905_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ぐちゅぷっ！　じゅぷっ……ぢゅるぅ……れろっ！　んじゅるっ……じゅる\nじゅるじゅる……あぁ……チンポの熱で頭がぼうっとひゅるぅう……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0503129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「やっぱりこうひて、口いっぱいにチンポをほおばって……んぐっ♪　喉奥を\n広げられる感覚はいい……感じる……♪　ぐっちゅっ、ぷちゅっ、じゅるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0503130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「上の口を拡張されながら……、んんぁっ♪　下を自分でいじって、慰めて…\n…はぁあっ……。こんなに淫らなことがあるか……れろっ、れろれろっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0503131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「はしたない姿をさらしているのに、それが気持ちいいなんて……私はどうか\nしている……。ちゅっ……チ。チンポにキスがやめられない……くちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0503132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ギンギンのオチンポと濃厚にディープキスをしながら……あっ♪　あっぁっ\nあっ♪　オマンコくちゅくちゅ指で掻き回して、興奮ひて……。んぢゅるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0503133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「こんなの……こんなの、脳もアソコもイッてしまう……達してしまう……！\n　ぢゅるっ、ぢゅるっ……隊長、隊長も同じ気持ちでいてくれているか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0503134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「あっ♪　目の前で、下品にM字開脚しながら……物欲しそうにチンポをねぶ\nってしゃぶってすすり尽くしている私をもっと見てくれ……そして」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0503135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「この口の中に……ドロッドロのザーメンを発射してくれ……。んっ、んっん\nっ！　欲ひい……隊長のザーメンが……ぢゅるっ、じゅるっ、ぢゅるるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0503136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「んふぅうううッ……♪　んっぉっ……んぐ……！　んんんん……！　……ご\nくっ……ごくっ……！　んんん……！　ごきゅっ……ぢゅるぅうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0503137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004905_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「あぁあああああ……♪　これっ……これ……一気飲みで飲み干すとキクぅう\n……！　ぢゅるっ……じゅるる、ごくっ、ごく、ごく……もっと！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0503138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「おかわり……！　んんん！　ごくっ、ごく、ごく……っ。ふ、ぅ……♪　精\n子……精子一気しながらイクぅ……！　達っひゅるぅううう……んぐぅう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0503139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「んーーーーっ！　んぅううーーーっ！　あっ！　イ、イクの止まらない……\n勝手に自分の指、オマンコが締め付けて……気持ちいいっ、いいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0503140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「くうぅう……♪　あふ……ふぁああ……♪　す……すまない、あまりに絶頂\nに没頭していて……精液に酔ってしまっていたみたいだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0503201" ]},
		{"command":[ "SETIMAGE", "0", "still_00004905_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「はぁ……。正直、正義の酒も最高だが……隊長のコレも、飲めば飲むほど舌\nに残って忘れられなくなってくる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0503202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「独特のえぐみと青臭さ……ドロドロとした喉ごし……。熱くて苦い、君の欲\n望の塊……。たくさんご馳走になったが、まだだ……二杯目を要求する」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0503203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「あむっ……♪　拒絶などさせん……。無理やりにでも私が君のオチンポ汁を\nもう一度絞り出してやるぞ……。んっ……はむ……ぢゅる、くちゅぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0503204" ]},
		{"command":[ "SETIMAGE", "0", "still_00004905_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「んふ……。まだまだ精液の味がしっかりするな……。ヌルヌルひていて……\nんっ。しゃぶりやすい……。くぷっ……ちゅぷ、ちゅぷぷぷ……ぬちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0503205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ちゅぷ……ちゅぷ、くちゅ、くちゅ……♪　いいぞ……隊長もすっかりその\n気じゃないか。口の中でチンポが膨らんできた……。んっ、硬い……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0503206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「口の中ですら受け止めきれない、この肉棒が……。んぅ、いつも私のここに\n……アソコに深くねじこまれているんだと思うと……またイキそうになる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0503207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「んぁ……舌が押し戻されるくらい弾力のある肉棒……。あっ……♪　このペ\nニスの角度が、チンポのでっぱりが……段差のキツいカリ首が……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0503208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「舐めても舐めても尿道口から溢れ出してくる、先走り汁が……私を誘ってい\nる……っ。女を狂わせる、悪い……悪いオチンポだ……。好きすぎるぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0503209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ぴちゃっ……れろ……れろ……れりゅっ！　くぷ……くぷぷ……！　ぬちゅ\nっ……ぴちゃ……れるぅ……れろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0503210" ]},
		{"command":[ "SETIMAGE", "0", "still_00004905_01_04" ]},
