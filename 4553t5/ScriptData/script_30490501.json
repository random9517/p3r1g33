		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ん、はぁっ……表面だけをチロチロ舐めているんじゃ足りない……。深く…\n…限界まで……んむ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0503211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ふ、むっ……！　んちゅ……ぢゅっ！　じゅっ……じゅるっ！　ぐちゅ……\nぐちゅっ、ぶちゅっ！　ぬちゅ……じゅるっ！　ずっちゅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0503212" ]},
		{"command":[ "SETIMAGE", "0", "still_00004905_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ううぅん……♪　おいひぃ……ぢゅるっ、皆が……みんなが仕事をしている\n真昼間から……隠れてしゃぶるチンポって最高……っ♪　れろっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0503213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「んっぁっ……あっ、じゅぷ……♪　にちゅっ、くちゅっ、れろ……れろっ、\nぢゅるっ……ぢゅるるるっ……はぁ、はぁ、はぁああ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0503214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「か……身体はいくら見てもいいが、……あっ♪　あまり顔は見ないでくれ…\n…だらしない表情をしているだろう、恥ずかしいからな……ぺろっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0503215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ふむんんっ……ずっちゅっ！　ぢゅるぅ……れろぉ……♪　ぬぷっ、ぬぷぷ\nぷ……れろれろれろ……。はぁ、はぁ、はぁああ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0503216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「酸欠になりそうだ……。ぁっ……♪　マンコも口も気持ち良くて……あぁ…\n…っ。手が……愛液でヌルヌルになって……！　んふっ……ぐちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0503217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「膝がガクガク痙攣してきた……。あぁっ、ち、膣内も蠢いて……んむっ。チ\nンポを貪欲にほおばりながらの自慰……どこまでも昇っていける……ぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0503218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「あ、ああ、あっぁっあっ……！　た、隊長……また私はイッてしまう……！\n　深く……深く大きくイ、く……イキながらおしゃぶりするぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0503219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「にゅるっ……ぬるっ、ぢゅるっ、ぢゅるるる……！　は、ぁ、私の口マンコ\nに精液、精液を……！　アソコに種付けするみたいに……喉に……ぢゅるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0503220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「うくっ……！？　んむ……！　んう……んん……ッ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0503301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004905_01_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「凄い……、溺れてしまいそうなほど……。んぷっ……ま、待っれ……飲みき\nれない……精子、せいひ多すぎる……っ。ぷぁ……あああ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0503302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「こんなに……受け止めきれない……っ。ごく……ごくっ、ごく……っ。あぁ\n……まだまだ出てくる……さっき出したばかりだというのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0503303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「っぢゅる……ぢゅるるるる……ぢゅる♪　れろれろれろれろ……。じゅる…\n…ぢゅるっ……！　ん、ぷ……喉に絡みついて……。んっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0503304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ひゅごいぃ……わたひの喉、真っ白な濁液で……隊長くんの子種で詰まって\n……。……あ♪　あっ、あぁ……こんなの……イクっ、イクっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0503305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「んはぁあああ……♪　ザーメン、ザーメンを嚥下しながらアクメ……アクメ\nをキメるなんて……情けなくて……もう一度イく……んぅうううう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0503306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ふーっ……♪　ふぅーっ、ふー……♪　良い射精……だった。二度目でこれ\nだけ出してもらえたら本望だ……。堪能した……。れろっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0503307" ]},
		{"command":[ "SETIMAGE", "0", "still_00004905_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ど……どうだ。これで全て精液を飲み込んで……。と、なんだ？　精液を飲\nんでいた私がスッポンのようだった……だと！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0503308" ]},
		{"command":[ "SETIMAGE", "0", "still_00004905_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「そ……それは喉が渇いていて……！　自慰行為は喉が渇くんだ、……違う、\nアソコが洪水のように濡れているのは……別に水分がにじみ出たわけでは」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0503309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「……こら。親しき仲にも礼儀あり、だぞ……。私が君のモノを咥えて感じて\nいたことはあまり言わないでくれ……さすがに恥ずかしいからな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0503310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「あっ、こらっ……逃げるな……！　口から外れて……。っんぁんんっ！？　\n何っ……顔！？　顔がいいのか……！？　あっぷっ、んぷ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0503401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004905_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「わ……私の許可なく顔面に射精するだなんて、本当に君は傍若無人だな……\nっ。しかし……私はそこが……。……あっ、も、もったいない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0503402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「で……出来るだけ口の中に入れて、くれ……。んぁ……！　あっ……かけた\nいのはわかる……！　わかるが……。んぷぁ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0503403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「私は精液を飲みたかったんだ！　……っんッ！　いや、こうして浴びるのも\n……征服されているようで興奮するが……。ふぁっ……ああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0503404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「出来るだけ、貴重な子種を口内に受け止めたかったのに……。うう……、だ\nんだん……精液の勢いが減っていって……ああ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0503405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「二度目の射精も終了か……。あ……量は問題ない。二度目とは思えないくら\nいの大量発射だ。粘り気も色の濃さも申し分ない。だからこそ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0503406" ]},
		{"command":[ "SETIMAGE", "0", "still_00004905_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「それらをたっぷり飲み干して……私の一部にしてしまいたかったのに……。\nあっ、あぁ……おあずけされたから……オマンコも切なそうだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0503407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「んっ……んっ……。せめて、口のまわりの分だけでも……。ぺろ……れろ、\nれろ……。ごくんっ……。んんー……足りない……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0503408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「なにか……なにか、私の心を満たしてくれるものは……。はっ！？　そうだ\n……この後、一緒に正義に飲みにいかないか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0503409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「そうして、ゆっくり休んで……。と、いつもならそれでご機嫌になれるんだ\nが……やっぱり精子が……。うーん……。飲みたかったぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0503410" ]},
