{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0027" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「ねえ、カツマちゃん。そろそろ歩き疲れてない？　我慢できなくなったら、\nいつでも運転席に乗ってくれていいからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010022400001" ]},
		{"command":[ "SETCHARA", "0", "char_00011101_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「うふふっ。乗るなら私に乗って欲しいわ。隊長さんを乗せて運転すると、い\nつも以上に馬力が出る感じがするもの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010022400001" ]},
		{"command":[ "SETCHARA", "0", "char_00021201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ダメですよー。ご主人様は私たちと一緒に歩くんです♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022400001" ]},
		{"command":[ "SETCHARA", "0", "char_00015701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「そうだね……こうして、いっぱい腕にしがみ付いていたい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022400001" ]},
		{"command":[ "SETCHARA", "0", "char_00015801_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「ちょっと２人とも！　そんなにくっついたら、カツマちゃんが歩きづらいで\nしょ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010022400002" ]},
		{"command":[ "SETCHARA", "0", "char_00011101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「あらあら。喧嘩はダメよ。みんなで仲良くお散歩しましょ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010022400002" ]},
		{"command":[ "SETCHARA", "0", "char_00021201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……なんで俺は人間相手だとモテないのに、ロボット相手だとこんなにモテ\nるんだ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふふ♪　それはご主人様の魅力に気付いているのが、私たちだけだから\nですよー♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022400002" ]},
		{"command":[ "SETCHARA", "0", "char_00015701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「愛は性別どころか、種族も超えるよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022400002" ]},
		{"command":[ "SETCHARA", "0", "char_00015801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「そうよ、隊長さん。この想いは誰にも止められないわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010022400003" ]},
		{"command":[ "SETCHARA", "0", "char_00021201_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……まあ、相手が誰であれ、こうして俺を好いてくれるのは嬉しいけどな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「嬉しいだなんて……！　それってつまり、私たち相思相愛ってこと……！？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010022400003" ]},
		{"command":[ "SETCHARA", "0", "char_00011101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「今の会話で、どこをどう捉えたら相思相愛ってことに……うぐっ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ご、ご主人様っ！？　急にどうしたんですか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022400003" ]},
		{"command":[ "SETCHARA", "0", "char_00015701_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「お腹に手を当ててるけど……もしかして、お腹痛くなったの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022400003" ]},
		{"command":[ "SETCHARA", "0", "char_00015801_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あ、ああ……何か急に腹痛が……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「大変っ……！　急いで基地まで戻りましょ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010022400004" ]},
		{"command":[ "SETCHARA", "0", "char_00011101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、すぐそこにデパートがある……！　ちょっとそこのトイレに行ってく\nるから、みんなはここで待っててくれ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「わかったわ。もし漏れたりしたら、すぐに私たちを呼んで頂戴ね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010022400004" ]},
		{"command":[ "SETCHARA", "0", "char_00021201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「わかった……！　その時は、すぐに連絡させてもらう……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0027" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ご主人、大丈夫かな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022400004" ]},
		{"command":[ "SETCHARA", "0", "char_00015801_01", "4", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「心配ですけど、何かあったら連絡するって言ってましたし、大人しくここで\n待ってましょー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022400004" ]},
		{"command":[ "SETCHARA", "0", "char_00015701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「それじゃあ、隊長さんが戻ってくるまでエンジンを止めて――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010022400005" ]},
		{"command":[ "SETCHARA", "0", "char_00021201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「センサーに敵影反応あり！　みなさん、気を付けてください！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022400005" ]},
		{"command":[ "SETCHARA", "0", "char_00015701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「かなり反応が近い……！　すぐそこまで来てるよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022400005" ]},
		{"command":[ "SETCHARA", "0", "char_00015801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「こんな近くになるまでセンサーに引っかからないなんて……！　もしかして\n、ステルス機能が搭載された敵ってこと！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010022400005" ]},
		{"command":[ "SETCHARA", "0", "char_00011101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「そんな感じはしないけど……って、あら？　あれは何かしら？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010022400006" ]},
		{"command":[ "SETCHARA", "0", "char_00021201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「あれは……ワームホールだわ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010022400006" ]},
		{"command":[ "SETCHARA", "0", "char_00011101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「せっかくご主人とのデートなのに、襲来者が来るなんて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022400006" ]},
		{"command":[ "SETCHARA", "0", "char_00015801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者" ]},
		{"command":[ "SETTEXT", "「クククッ！　見つけたぞ、Ｍ.Ｏ.Ｅ！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者" ]},
		{"command":[ "SETTEXT", "「んっ？　Ｍ.Ｏ.Ｅだけでなく、Ｍ.Ａ.Ｍ.Ａやクララ、ロッテもいるの\nか。これは好都合だ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ふにゃ？　どうして私たちの名前を知っているんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022400006" ]},
		{"command":[ "SETCHARA", "0", "char_00015701_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「私の記憶領域に、この襲来者の情報はないよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022400007" ]},
		{"command":[ "SETCHARA", "0", "char_00015801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「私のメモリーにも存在しない襲来者ね。Ｍ.Ｏ.Ｅちゃん、何か知ってる？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010022400007" ]},
		{"command":[ "SETCHARA", "0", "char_00021201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「……あれは私がワームホールを通じてここに来る前に、何度も戦っていた襲\n来者よ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010022400007" ]},
		{"command":[ "SETCHARA", "0", "char_00011101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「私たちみたいに人の心を理解したり、感情を持つ超人口知能が気に食わない\nみたいで、何度も襲って来られたわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010022400008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「あらあら。それは大変だったわね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010022400008" ]},
		{"command":[ "SETCHARA", "0", "char_00021201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「ええ……でもまさか、こんなところまで追ってくるなんて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010022400009" ]},
		{"command":[ "SETCHARA", "0", "char_00011101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者" ]},
		{"command":[ "SETTEXT", "「この私の頭脳を持ってすれば、ワームホールを解析し、貴様の居る次元へ移\nるなど容易いことだ」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「次元を渡ってまで追いかけてくるなんて、すごい執念ですね。そんなに感情\nを持つロボットが気に食わないんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022400007" ]},
		{"command":[ "SETCHARA", "0", "char_00015701_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者" ]},
		{"command":[ "SETTEXT", "「当たり前だっ！　感情を持つ超人工知能など、この世に存在していいはずが\nない！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者" ]},
		{"command":[ "SETTEXT", "「機械とは創造主に服従し、命令をこなすだけの従順な存在であればいいのだ\n！　制御された超人工知能こそ、真の超人工知能だ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「なにそれ……！　そんなの、ロボット差別だよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022400008" ]},
		{"command":[ "SETCHARA", "0", "char_00015801_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「思想は人それぞれあってもいいと思うけど、それを押し付けるのはよくない\nわね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010022400009" ]},
		{"command":[ "SETCHARA", "0", "char_00021201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者" ]},
		{"command":[ "SETTEXT", "「黙れっ！　ロボットの分際で私に説教をするなっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「……この襲来者、かなり変わってますね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022400008" ]},
		{"command":[ "SETCHARA", "0", "char_00015701_01", "9", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「でも、敵なことに変わりないよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022400009" ]},
		{"command":[ "SETCHARA", "0", "char_00015801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「ああ、もう……！　せっかく記憶から消去できてたのに、イヤな思い出が復\n元してきちゃったじゃない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010022400010" ]},
		{"command":[ "SETCHARA", "0", "char_00011101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者" ]},
		{"command":[ "SETTEXT", "「クククッ！　それはいいことだ！　この私の恐ろしさ、この次元でもしっか\nりと味わわせてやる！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者" ]},
		{"command":[ "SETTEXT", "「出でよ、我がクローン体っ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふっ！？　あの襲来者、増殖しましたよ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022400009" ]},
		{"command":[ "SETCHARA", "0", "char_00015701_01", "9", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「大丈夫よ。あの襲来者、口では色々言うけどすごく弱いから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010022400011" ]},
		{"command":[ "SETCHARA", "0", "char_00011101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「科学者気質の人が、自ら前線に出るって感じなのかな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022400010" ]},
		{"command":[ "SETCHARA", "0", "char_00015801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「うふふっ。襲来者も人手不足なのね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010022400010" ]},
		{"command":[ "SETCHARA", "0", "char_00021201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者" ]},
		{"command":[ "SETTEXT", "「貴様ら機械に哀れまれる筋合いなどない！　いいから黙って消えろっ！！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「みんな。カツマちゃんがトイレを済ませる前に、速攻で片付けましょう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010022400012" ]},
		{"command":[ "SETCHARA", "0", "char_00011101_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「了解です♪　全力出しますよー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022400010" ]},
		{"command":[ "SETCHARA", "0", "char_00015701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
