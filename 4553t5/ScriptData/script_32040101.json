	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「あっはっ♪　……あたしもナメられたもんだねぇ。こんな夜中に呼び出され\nるなんて……。あんたやりたい放題じゃないか♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0103101" ]},
		{"command":[ "SETCHARA", "0", "char_00020401_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「……別に怒ってなんかいないよ。昼間は忙しいんだろ？　あたしとの時間を\n無理やり作り出してくれたんなら……怒る理由なんてないじゃない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0103102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「はァ？　今日のあたしは妙に優しい？　ククク……そうだねぇ？　せーっか\nく二人っきりになれたんだ。特別にイイ事をしてあげようか♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0103103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「あんたがしてほしくってたまらないこと。いつもあたしを見てよだれを垂ら\nしてたんだろ？　ご褒美ってヤツをあげてもいいよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0103104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「そぉら♪　……驚いたかい……ククク♪　いいんだよ、あたしだって色々鬱\n憤溜まってるんだ。ここでせいぜいはらさせてもらおうって事……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0103105" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00020401_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「ンフフフ……♪　なぁにぃ？　このデカチンは……。脱がしただけで硬くし\nちゃって……。躾のなってない暴れ馬だねェ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0103106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「まーだ何もしちゃいないってのに、先っちょからタラタラ汁を垂れ流してさ\n……。あたしに媚びて、甘えてきてるよ……。はしたない……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0103107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「あん？　なんだって？　胸が当たって、柔らかいから勃起しただぁ？　嘘つ\nけ。挟む前からガッチガチにしてただろ。あたしのせいにするんじゃない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「おまえは、女を見ればすーぐチンポを硬くする変態なんだよ。もったいない\nから、それをあたしが有効活用してあげる……。ん……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「この乳の重み……、ハリ、つやつやした色に弾力……♪　目ぇかっぽじって\nよーく見てな。こいつが今からおまえを粛正するんだよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「……フフ♪　谷間でシゴいてシゴきまくって泣かせてやる……。あたしの胸\nはさぁ……他のコみたいに優しくないよ？　ドＳで激しい女王様さ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0103111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「ひ弱なチンポならボッキリ折れちまうくらいの圧力で……。ン……！　絞り\n殺してあげる……！　はぁっ……はぁっ♪　は、ぁ……んっ、んッ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「アハ……♪　相性がいいの、かね……？　あたしのパイズリにすぐ反応して\n♪　そうかい、これがいいのかい……じゃあもっとご褒美だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「れろ……れろぉ……ぷちゅ♪　あたしのながーい舌でチンポを舐め回しなが\nらダブルで責めてやる……。んれろっ……レロ……れろれろれろ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0103114" ]},
		{"command":[ "SETIMAGE", "0", "still_00020401_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「エロい舌だろ……？　れる……ぴちゃっ、くちゅっ、ぷっちゅっ♪　怖くて\n怖くてたまらないだろ？　ぴちゃっ……ねちょっ、れろっ、レロレロ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0103115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「おまえの性感はあたしが今握ってる……。このチンポ、活かすも殺すもあた\nし次第……♪　アハッ、恐怖のパイズリフェラに震えなァ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0103116" ]},
		{"command":[ "SETIMAGE", "0", "still_00020401_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「んっ♪　ンッ、んっ♪　じゅぷっ♪　くちゅ……れろぉ♪　れろっ、れろ、\nぴちゃ……♪　ぢゅるっ♪　じゅるっ、ぢゅる……ぢゅるる♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0103117" ]},
		{"command":[ "SETIMAGE", "0", "still_00020401_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「アーハハハ♪　元々デカいマラ肉が、信じられない勢いで反り返って……な\nんだいこれェ？　笑えるくらい素直でカワイイチンポだね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「味も塩っぽくて飽きがこない……♪　れろ……れろれろれろぉおお……♪　\nいやらしい形、えぐれたカリのくびれェ……最高級チンポだよ、れろっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「あたしはコイツを気に入った……。持ち主がどう思おうが、コイツを嬲り回\nすのはあたしの権利……。ぺろっ♪　れろ、レロレロ……ぢゅるるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「は、ぁ♪　あああ♪　口ん中に入りきらない太さ♪　あむッ……♪　喉を突\nき破りそうな鋭いカタチ……。レロッ、れろ、あぁ、ああ、あああ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「凶悪なデカチンポを思う存分舐め回せて嬉しいねぇ……！　ぐちゅっ♪　レ\nロレロレロ……！　じゅぷっ、ちゅぷぅ……ぐちゅっ、ぐちゅぅうっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「あっは……♪　そのだらしない表情もご馳走だ……♪　隊長……おちんちん\nチュパチュパされて気持ちイーでちゅかぁ？　アハハハ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0103123" ]},
		{"command":[ "SETIMAGE", "0", "still_00020401_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「おっぱいでグニグニ絞られながら、……ぢゅぷ♪　あたしの舌にされるがま\nま……♪　変態性欲チンポ、気持ちいいかって聞いてんだよ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「ん？　なァ～にうっとり感じいってんだよ。これじゃ刺激が足りないって事\nかしら？　貪欲な豚だねぇ。いいよ、キッツいのをあげようじゃない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「んふっ♪　ンフフフ……どーぉ？　あたしの武器。ウィップ。これで責めら\nれて、泣かない男なんているわけない……嬉しいだろぉ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0103126" ]},
		{"command":[ "SETIMAGE", "0", "still_00020401_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「おまえには少しもったいない感触かもしれないけどねぇ……今日は特別だ。\nこいつでゴシゴシ亀頭を責めてあげる。ッフフ、わめいてもいいよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0103127" ]},
		{"command":[ "SETIMAGE", "0", "still_00020401_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「すぐにコレじゃなきゃイケない身体にしてあげる……。ねぇ？　腰をもっと\n突き出しな！　おチンポ様にご奉仕してほしいんだろう！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0103128" ]},
		{"command":[ "SETIMAGE", "0", "still_00020401_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「……ごし、ごし、ごしごし……ハハハ♪　どんな男も、先端はやーらかいか\nらね。弱点だろ……？　しかも……鞭で亀頭をこすってる間にもぉ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「レロッ……れろ♪　あたしの舌技は止めてやらないし……ぢゅる♪　オッパ\nイだって動かしまくってやる♪　三点責めだ……感じまくりな、豚♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「んれろっ……れろっ、レロレロレロ……♪　ぐちゅぷっ、ぐちゅっ、ぐちゅ\nぐちゅぐちゅ……！　腰を引くんじゃないっ、もっと耐えな！　バカ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0103131" ]},
		{"command":[ "SETIMAGE", "0", "still_00020401_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「ンフ……♪　ぐちゅっ♪　ぐちゅっ、ぐちゅ♪　はぁ？　なんだい？　言い\nたいことがあるなら大声で言いな！　なんだって？　フフフフ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「射精したいならしたいらしくお願いしてごらんッ！　……だからさぁ♪　声\nが小さくて聞こえないって！　はっきり言いな！　なんだって！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「気持ち良すぎて精子出ちゃいますぅ！？　イカせてください、出させてくだ\nさいぃ？　ハハッ、あはははっ、ははははは……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「……お願いしたって聞いてなんかやらないよ！　勝手にイキな！　女みたい\nに汁垂れ流して……みっともなく！　精子噴き出しなッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0103135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「ほぉら……尿道口をグリグリ刺激してやるからイキなよ！　ちゅるっ♪　ち\nゅるるる♪　ぺちゃっ、ぴちゃ、ぴちゃ……。お♪　出るね♪　んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0103136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「んっ！？　アハハハッ、アハハハハッ……。あはっ♪　いいね……いいねぇ\n……。んぷ……！　上手にぴゅーぴゅー出来たじゃないか……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0103137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00020401_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「ん、ぁ♪　あぁ……ああ♪　んぁあああ……♪　ハハ……♪　やっぱりデカ\nチンからは、とてつもない量の濁液が噴き出すねェ……見事だよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「おまえ……Ｍの素質でもあるんじゃないの？　いじめられて精子出すなんて\n……。んん？　あたしが責めまくるから？　本当にそれだけぇ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「ほら♪　ドピュッ、ブビュッてまーだ汚らしい精子が出てるよ！　みっとも\nなくてしつっこい精子……。でも、事前に予告できたのは偉かったね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「聞き分けのいい子はだーい好きだ。……でも……。んっ！　あたしの眼鏡に\n劣情吐きかけ散らすとはどういう教育されてるんだいっ……ンンっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0103201" ]},
		{"command":[ "SETIMAGE", "0", "still_00020401_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「ねばっこくて汚らしい精子……。はぁっ、はぁ♪　トロみのついた真っ白な\n精子を、あたしの眼鏡にこってりたっぷり塗り付けて……変態め……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「これじゃ……。んぁあ♪　この眼鏡、もう仕事で使えなくなっちまったんじ\nゃないか♪　臭いなんてそうそう落ちるもんじゃないし……それに」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0103203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「精子の跡がさぁ♪　どんだけ洗っても残っちまうだろぉ……♪　ん～～～♪\n　さーて、どうやって償ってもらうとするかねぇ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0103204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「……やっぱりここは、鞭責めパイズリフェラしかないよねぇ？　そら、チン\nポ出しな！　一度出したくらいで解放なんてしてやらないよ……あーん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「ぐちゅっ♪　グチュ……ぐちゅっ、ぢゅるるるる……♪　あ～～～♪　くっ\nさい……っ♪　くっさい精子の味が口内にひろがって……最悪ぅう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0103206" ]},
		{"command":[ "SETIMAGE", "0", "still_00020401_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「んむ♪　んむ、んむ……ちゅるるる♪　こんなネバネバした、あたしの眼鏡\nを汚す白濁は……ぜーんぶ舐め取って飲んでやらなきゃ気が済まないよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「ンッ、ぐちゅっ、ぐちゅぅうう……ぐちゅ♪　ごくんっ……れろぉ……！　\nれろっ……れろ……ぐちゅぅっ♪　ぶちゅっ、ぶっちゅっ、ぶっちゅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「んぁんん♪　レロッ、れろれろ……ぢゅるぅ♪　ごきゅ……ごきゅ、ごきゅ\n……♪　ぴちゃっ、くちゅ、クッチュッ……ぐちゅっ、れろ、れろっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「ん～～～？　ん～～～？　これはどういうことなんだい？　精子を舐めたら\n次はカウパーでチンポがくっさくなってきたよぉ……垂れ流しかい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0103210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「おまえは♪　スッキリ射精しても、まーたチンポをいじくられれば汁を出す\nド変態……。ンフ♪　童貞だってここまで性欲強くないんじゃないか？」", "NORMAL" ]},
