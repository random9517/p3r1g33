		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「んっちゅっ……チュッ、ちゅっ、ちゅ……♪　はぁあ♪　性欲しかない男の\n、性欲にまみれたゴッツいデカチン……胸に響くねぇ……♪」", "NORMAL" ]},
