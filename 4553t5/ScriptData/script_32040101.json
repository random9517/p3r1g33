		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「あぁん？　安心しなよ……コイツを一生構い倒して……。んれろっ♪　あた\nし無しじゃ生きられないあたし専用チンポに変えてやる……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「嫌だぁ？　口答えしてる場合かい……？　ほらッ……ウィップ亀頭ごしごし\nだよ♪　フフフフ♪　キくだろぉ？　おまえのカウパーで威力二倍♪」", "NORMAL" ]},
