{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0031" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「ブラックって……私はそんな、全然違います～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_010023600001" ]},
		{"command":[ "SETCHARA", "0", "char_00026101_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「あ、いや、悪い。なんか一瞬雰囲気を感じてな……今はなにも感じねえ。よ\nく見りゃ顔も身体も全然違うし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023600001" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「そのマスク・ザ・ブラックってどんな方なんですか～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_010023600001" ]},
		{"command":[ "SETCHARA", "0", "char_00027401_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ブラックは俺と氷華の後輩でな。真面目だし剣の腕も立つから結構面倒をみ\nてやってたんだが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023600002" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "01", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「だが？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ある日突然マスカレードを辞めちまった。なんでも一身上の都合らしいが、\n引き継ぎもなんもなしだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023600003" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「それきり連絡も取れねえし、会うこともない。なんか事情があったのかもし\nれねえが、寂しいもんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023600004" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まあ、人それぞれに事情はあるもんだしな。っと、悪いな。じゃあ、面接を\n始めていいか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「ははははははいっ！！　春風うららです、おねがいしましゅっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_010023600002" ]},
		{"command":[ "SETCHARA", "0", "char_00026101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "1"]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "（噛んだ……）", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00026101_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "（噛んだな……）", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023600005" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "（噛みましたね～）", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_010023600002" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「なんでしょうこの一体感……風……熱い風が吹いているような……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023600001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「んんんっ。ともあれ、なんでオーディションに来たか志望動機を聞いていい\nか？　見たところ、君は戦闘向きっぽくなさそうだけど」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「は、はいっ！！　実は、私の姉が昔ヒーローをやっていまして！！　その時\nの姿に憧れて、私も姉みたいに皆を守りたいって、そう思ったんです！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_010023600003" ]},
		{"command":[ "SETCHARA", "0", "char_00026101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「おお、いい志じゃねえか。気概、気合いってのは大切だからな。腕が立って\nても、志がなけりゃあそれはただの暴力だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023600006" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ほむらがまともなこと言ってる……あの酒とタバコとゲロの匂いしかしない\n女んげっ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人、あなたはどうしてこう、余計な一言を……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023600002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「すっごい音の拳骨でしたね～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_010023600003" ]},
		{"command":[ "SETCHARA", "0", "char_00027401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「一瞬意識飛んだぞ……ゴリラかよ……ぐぇっ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「で、だ。その逆もしかりだ。立派な志があっても、力がなけりゃそりゃただ\nの戯れ言だ。理想論ですらない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023600007" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「は……はいっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_010023600004" ]},
		{"command":[ "SETCHARA", "0", "char_00026101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「そこでお前の実力を見てみたい。俺と本気で戦えとまでは言わねえが、組み\n手をしてもらうぜ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023600008" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「く……組み手ですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_010023600005" ]},
		{"command":[ "SETCHARA", "0", "char_00026101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「俺だって元レッドだ。相手に不足はねえだろ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023600009" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「オーディションとか言いつつ、あれはそろそろ身体を動かしたくなった口実\nだよな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「さっきからなんかうずうずしてましたもんね～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_010023600004" ]},
		{"command":[ "SETCHARA", "0", "char_00027401_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「そこ、うるせえぞっ！！　よしこいっ！！　お前の熱い気持ちを拳に乗せて\nみろ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023600010" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「わ、わかりました！！　へあああああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_010023600006" ]},
		{"command":[ "SETCHARA", "0", "char_00026101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "1"]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023600011" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_010023600005" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023600003" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0"]},
		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「えいっ、えいっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_010023600007" ]},
		{"command":[ "SETCHARA", "0", "char_00026101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "1"]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023600012" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_010023600006" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023600004" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0"]},
		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「てやああああっ！！　へぶっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_010023600008" ]},
		{"command":[ "SETCHARA", "0", "char_00026101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「軽くはたいただけなんだけど……お前、絶望的に弱いな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023600013" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんか……なんかないのか？　１分溜めたら凄いビーム撃てるとか、ピンチ\nにロボット喚べるとか、興奮したら呼吸が毒になるとか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「そ、そんなのありません～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_010023600009" ]},
		{"command":[ "SETCHARA", "0", "char_00026101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「これだと、私の蔦が当たるだけで倒れてしまいそうです～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_010023600007" ]},
		{"command":[ "SETCHARA", "0", "char_00027401_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「うーん、心意気はいいんだがな。実力がないと最悪死ぬぞマジで」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023600014" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「そ、それは分かってます……隙ありぃっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_010023600010" ]},
		{"command":[ "SETCHARA", "0", "char_00026101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「甘いっ！！　っと、落ちてる木の枝を使うっていう狙いは悪くなかったけど\nな、組み打ちこそもっと技術が必要だぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023600015" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「うう……お姉ちゃんの技を真似したんですけど、やっぱりうまく行きません\nね……はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_010023600011" ]},
		{"command":[ "SETCHARA", "0", "char_00026101_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「今のがお前の姉ちゃんの技……？　なーんか引っかかるなあ。なあ、お前の\n姉ちゃん、マスク・ザ・ブラックじゃねえのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023600016" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「えーと……分かりません。お姉ちゃん、あまりその辺りの事を教えてくれな\nくて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_010023600012" ]},
		{"command":[ "SETCHARA", "0", "char_00026101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「姉ちゃんの名前は？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023600017" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「春風静夜です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_010023600013" ]},
		{"command":[ "SETCHARA", "0", "char_00026101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「よく考えたら本名覚えてねえな。最初に聞いたけど、いつもブラックって呼\nんでたし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023600018" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「大雑把すぎる」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「髪は黒くて、長髪をポニーテールにしてます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_010023600014" ]},
		{"command":[ "SETCHARA", "0", "char_00026101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ならブラックだ。あいつも黒髪長髪ポニーテールだったから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023600019" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「いつも優しくて、笑ってくれて、表情も豊かでした」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_010023600015" ]},
		{"command":[ "SETCHARA", "0", "char_00026101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ならブラックじゃないな。あいついつも仏頂面だったし、殺伐としてたし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023600020" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「どこぞの芸人のようなやりとり。なにか既視感がありますな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023600005" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なぁほむら。この子の姉がマスク・ザ・ブラックだったとして、それはこの\nオーディションに重要な要素なのか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「んー、まあそうだなぁ。うまく言えねえけど、重要な事だ。俺の勘がそう言\nってる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023600021" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「勘か」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「勘だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023600022" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ならしゃあねえな。うらら、お前の姉ちゃんの居所は分かるのか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "うらら" ]},
