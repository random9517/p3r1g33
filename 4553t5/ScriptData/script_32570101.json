{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0033" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「……来るのが遅くなってしまってすまない。私としたことが……お前の呼び\nかけに、即座に反応できないとは……不甲斐ない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0103101" ]},
		{"command":[ "SETCHARA", "0", "char_00025701_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「ああ、いや。別に悩みがあるわけではない……と、言いたいところだが、実\n際のところは、ある、のかもしれない。前に、話したことがあっただろうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0103102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「ボウチュウジュツというニンジュツを知っているか？　くノ一が使う強力な\nニンジュツだ。私は、他の術は努力で会得し終えているのだが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0103103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「ボウチュウジュツだけは、試す相手がおらず未獲得なのだ。それがどうにも\n気になって……。……ん？　どうした。それなら良い案がある……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0103104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「何？　お前がボウチュウジュツの相手をしてくれる？　い、いいのか？　あ\nあ、それならなんでもしよう。私は何をすればいい？　命じてくれ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0103105" ]},
		{"command":[ "SETCHARA", "0", "char_00025701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「……くっ……！　お、お前が言う通りに準備をしたが……。本当に、こ、こ\nれがボウチュウジュツの会得に必要なことなのか……？　ンンッ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0103106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00025701_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「これがボウチュツジュツの一つ、メス犬の術？　そ……そうだったのか。し\nかし、必要以上の辱めを受けているような。本当にこれで正しいのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0103107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「……い、いや……疑っているわけではないのだが。少々恥ずかしくて……。\nだ、だってこんな格好、いくらメス犬といえど下品がすぎる。うう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「だからこそ敵が油断する？　まあ、そうか……ご主人様に絶対服従すること\nでメス犬になりきれる？　わかった。つまりこれは変化の術の応用なのだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「それなら言う通りにするしかあるまい。それで、ここからはどうすればいい\n。……自慰？　自慰とは……一人でする手慰み？　わかった、やってみる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「んッ……はぁっ、はぁ、はぁ……！　ふ、不思議な気持ちだ……。こんな姿\nを誰かに見られたことなどないし……、んっ、すごく恥ずかしい……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0103111" ]},
		{"command":[ "SETIMAGE", "0", "still_00025701_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「あっ、ぁっ、あっ……！　自慰を人に見せる、など……！　んんっ、しかし\n、羞恥すら捨て去ることで敵の懐に入れるのならば……。あっんっんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「んぁああっ！？　な、なぜだ……いつもより感度があがっている。私は、人\nに見られると興奮するのか？　い……いやだ、初めて知った……！　ううっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「愛液……愛液、が、ぽたぽた落ちて……！　んんっ、み、見ないでくれ……\n！　でも、見られないと術にならない……あっ、ど、どうしたら！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「あっ！　あっ、敏感になりすぎてアソコが赤く充血してきた……。んふっ、\nこ、こうだよな？　これで上手く出来ているのだろう？　……ふぅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0103115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「くぅっ……んっ、んんっ、んっ、ぅ……っ。はぁっ、はぁ、はぁ……ふぅう\nっ♪　んぁっ！　あっ、あっ、ど、どうした？　モゾモゾして……あっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「私の淫らな姿を見て勃起した？　あッ♪　ボウチュウジュツ成功なのか？　\nんっ、まだこれは一段階目？　で……では二段階目を教えてくれ……って」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「んぷっ！？　んゃっ……！？　んんぉっ！？　い、いきなり何をする！？　\n突然私の口に男根をねじりこむなどと！　……んぷ！　んぅ、むぅうう！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0103118" ]},
		{"command":[ "SETIMAGE", "0", "still_00025701_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「んぉふうっ！　もご……もぐっ、んぐ……！　にゃ、にゃんら……？　もっ\nと深く咥えこめ？　じゅ、充分喉奥まで突き刺さっているのだがっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「むぐ、自分から喜んで肉棒を咥え、舐めてしゃぶってみせなければ敵の目は\n欺けないとそう言っているのか？　た……確かにそれは一理ある」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「これも、ジュツの一環なれば……迷わず実行するがニンジャ……。っぐちゅ\nっ、自ら舌を巻きつけて……ぢゅるっ、肉棒を受け入れ、るぅ！　んん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「っぐちゅっ！　ぐちゅっ、ぶちゅ！　ずっちゅっずちゅっずちゅっ！　んむ\n！　んぷ！　んん！　ま、待ってくれ、まだ動かすな……！　んぶ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「そんなに激しく口内を犯されてはジュツが使えな……んううううう！？　あ\nっ！？　じゅぷっ！　じゅぷっ、ぐっちゅっぐちゅっぐっちゅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「……ほ、本当はこうやって喉を、口の中をいっぱいに犯されたかったのだろ\nう、だと？　あッ……♪　そんなわけ……！　っじゅるっ、じゅるるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「ち、ちがう……。私が舌を動かしているのは！　男根をはしたなく頬張って\n味わい尽くしているのは、ニンジュツのためで……んっ！　んっんっうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「ん～～～♪　んぅ……っ♪　う……嬉しそうにしていりゅ？　そんな……！\n　わ、私はどうかしている。まだ処女で、清らかなりし身だというのに」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0103126" ]},
		{"command":[ "SETIMAGE", "0", "still_00025701_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「口づけよりも先に、んっ！　肉棒で口の中をまさぐられ、突かれ、貫かれて\n感じていりゅ……！　っん！　まるで本当に、盛りのついたメス犬だぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「んっぷっんっ！　そうだ……喉奥を突かれて苦しいのに、苦しければ苦しい\nほど心臓が高鳴って……全身が燃え上がって、……じゅぷ！　じゅっぷっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「あっうっ♪　じゅるっ……じゅるるっ♪　んぅうう……♪　ドスケベダーク\nエルフだなんて言わないでくれ……それを言われると……あむっ、むぅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「愛液が止まらなくなってひまう……っ！　んッうっ♪　じゅる……じゅるっ\n！　ぐっちゅっ！　じゅるっ……！　じゅるっ、じゅるるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「もっと……メス犬になりきって……ぢゅるっ！　口の中に溢れ出す先走り汁\nを、おいしそうに飲み干すぅ……♪　っじゅるっ！　ごく……ごくっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「は、はいぃ……♪　そうれひゅ、スザクは淫乱ドスケベニンジャれひゅ……\n♪　肉棒のことしか考えていにゃい、メス犬ダークエルフれひゅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「もっと、もっとお口の中を犯ひてくだひゃい……！　んっ！　んっ！　うれ\nひいれふ、男根だいひゅきれひゅ♪　もっとくだひゃいぃ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「ん～～～～～っ♪　んぅうううっ♪　ひゅっごぉお……っ♪　脳天を、突き\n上げりゅようなピストン……っ！　んっあっ、んぐっ、ううっ、ずちゅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「美味し……っ！　ああっ、男根美味しいれひゅっ♪　いやらひい味……！　\nんっじゅるっ！　じゅるじゅるじゅるっ！　ジュルッ、じゅるるるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0103135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「……うっ♪　舌の上で、男根が膨張ひて……！　えっ、精液、白濁液が出る\n？　あっ……あっあっ、そんな……そんな、口の中にぃ！？　んんッ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0103136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「んんんんんんんーーーーーーッ♪　んふっ♪　ンンッ！　んんーーーーーっ\nんんーーーーーーっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0103137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00025701_01_05" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「ひゅご、いぃいい♪　飲みきれない量の種汁がぁああっ♪　んうっ！　うう\n！　ううううっ♪　あひっ♪　あひ、ひぃいいっ♪　んんんんん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「すまない……っ♪　無理やり射精ひゃれて、絶頂して漏らしてひまった……\nっ♪　あああ、ジョロジョロと大きな水音を出して……んんんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「子種に溺れながら、尿を垂らすなど……♪　ニンジャとしてもダークエルフ\nとしても最低の所業……っ♪　ああ、それなのにとても気持ちいぃいい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「……んむ……♪　むぅ、んんん……！　あ、待って！　待ってくだひゃい！\n　飲みまひゅ……いただいた種汁は全て喜んで飲み干しまひゅ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0103201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「ごくっ……ゴクっ、ごく……んぁあ♪　なんと苦味の強い子種……。これは\nみっちりと精子が詰まっているに違いないぃ……♪　っごくっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0103202" ]},
		{"command":[ "SETIMAGE", "0", "still_00025701_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「お前の種汁はこんなに濃厚で……重たくて、ヌルヌルしていて……。ふぁあ\n……♪　いかん、頭がトロンとしてきた……いくらメス犬の演技だとしても」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0103203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「ここまでとろけた表情を見せては……♪　んッ？　な、なんだ？　今種汁を\n吐き出したばかりだというのに、再び男根が力を取り戻し……？　うっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0103204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「はへ……？　あっ？　あぁっ、ま、まさか萎えないまま……もう一度訓練に\n付き合ってくれるというのか？　あ、ありがたい……んうっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「じゅるっ、こちらも望むところ、だ……♪　はぁっ、先程よりもっと強くし\nていい、私の口を自由に使ってくれ、本物のメス犬にして欲しい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「んっ♪　んぁああ♪　んん！　んんっんっんっ！　すごいぃい……♪　ひゅ\nごい、ひゅごいぃいい……！　じゅるっ、じゅるるるっ、じゅぷっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0103207" ]},
		{"command":[ "SETIMAGE", "0", "still_00025701_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「お前の男根こそまさに無敵……！　あっ♪　あぁ、演技のはず、なのに、本\n当にメス犬の気持ちになってきた……逞しく強い肉棒……素敵だ……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「おしゃぶりしながら……んむっ♪　自慰をするのがやめられない！　あっ♪\n　んむっ♪　ぐっちゅっ！　ぬちゅ……ぬっぷっ！　ぐちゅっ！　んっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「ぐっぷっ♪　ぐちゅっ！　ぐちゅ……！　ん～♪　んんんっ♪　んむ……♪\n　れろ……れろ、ちゅるっ……くっちゅっ、れるれるれる……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0103210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「は、ぁ♪　私からも肉棒をおしゃぶりする、から……ああ♪　好きな時にま\nた出してくれ……！　いいんだ、私も舐めたいんだから……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「れろっ、レロレロッ♪　ぐっちゅっ！　じゅぷっ！　ぢゅるっ……じゅるる\nるるっ！　んはぁっ♪　じゅるっ！　じゅるっ、じゅるっじゅるるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「んっんん……ッ♪　これが……メス犬の気持ひ……♪　んくっ♪　んんっ♪\n　悪くないぃ……♪　んれろ……れろっ、じゅっぽっじゅっぽっじゅぽ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「あぁあ……♪　欲ひい♪　この太い男根を、ここにぃ……！　んぢゅっ、あ\nぁ……♪　こんな硬さで女陰を、肉壺をかきまわされたら……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0103214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「想像するだけで濡れてくるぅ……♪　んじゅるっ、ぐっちゅっ！　ぐちゅっ\n！　ぐちゅっ！　お……お願いがある……。んっ、あの、その……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0103215" ]},
		{"command":[ "SETIMAGE", "0", "still_00025701_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「私の肉壺を犯している気持ちで、口の中にキツく男根を叩きつけてほしいん\nだ……♪　激しく、強く、痺れるくらいに……！　早くぅ……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0103216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「ふむぅうううっ♪　そうだ、その強さ、でぇっ♪　んむぅううう♪　むうう\nうううっ♪　んむ～～～～っ♪　むふぅううっ♪　んん♪　んん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「だ、ダメだ♪　気持ちが良すぎて、腰をヘコヘコしてしまう♪　れろっ、れ\nろ、私はメス犬です♪　ご主人様の……お前のメス犬れひゅぅうう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0103218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「どうか……どうかご主人ひゃまの素晴らしい子種をお恵みくだひゃい……♪\n　ぐっちゅっぐちゅっぐちゅっじゅるっ！　れろれろれろ……れるぅ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「っんむむむむっ♪　種汁ぅ……種汁、もう一度喉奥で、口内で感じたいぃ…\n…種汁ぅ♪　じゅぷっ！　じゅぷ、じゅぷぷっ、出してぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「ごきゅごきゅごきゅごきゅっ！　ごくっ！　ごくっ！　ゴクッ、ごくっ！　\n出たぁああ♪　メス犬専用種汁ぅう♪　もっと、もっとぉお♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0103301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00025701_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「ぢゅる……じゅるじゅるじゅる、ごくっ……ごく、ごく……♪　あっああ…\n…♪　この肉棒から次々に発射される種汁の美味なこと……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「これが……メス犬の気持ちなのか。だとしたら、それは良いものだ……♪　\nっぢゅる……。舌の上で粘るこの感じ、嫌いじゃない……。んれろっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0103303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「苦くて、ねっとりしていて……。んん♪　飲みづらくて、本来ならば敏感な\n口粘膜で受け止め、飲み干すものではないのかもしれない。でも……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0103304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「私の本能が、ドスケベ淫乱ニンジャダークエルフの本心が告げているんだ♪\n　これが美味しいと、これを飲むことが幸福だと……♪　っぢゅるるるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0103305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「んぁんん♪　美味しい……！　美味しいぃ……！　ありがとう、こんなに美\n味しいものをたっぷりと出してくれて……♪　ごくっ♪　ごくんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0103306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「ああああああ……♪　どれだけ飲み干しても、まだ、種汁の臭いが口の中に\n残っている……。この主張の激しさ、まさに生命の力強さだ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0103307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「ボウチュウジュツ……。話に聞いていたよりも、実践してみることでその必\n要性と長所について理解させてもらえたかもしれない……。んっんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0103308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「このジュツを使うことで、女は快感を得られ、男は無防備になる……。互い\nの心と身体をさらけ出すことですか生まれぬこの感覚……♪　んんん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「これを応用すれば、どんな敵にも負けはしない。が、今は……いや、ずっと\n……このジュツはお前にだけかけていたい。そう感じるのはおかしいか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「んっあぁあッ！？　な、なぜだ！？　なぜ男根を私の口から奪うぅっ！？　\n……ひゃっ！？　あッ？　あっ、あああああっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0103401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00025701_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「い、いけないっ！　子種が……種汁が溢れてしまった！　こぼれて私の顔に\n……っ！　ち、ちがう！　それは私が飲む分でっ……待ってくれぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「んぁあああ……無駄撃ちなどさせるつもりはなかったのに……！　すまない\n……すまない！　ん？　何？　そうではなくて、顔にかけたかった？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0103403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「そういうのがメス犬にはお似合いだから？　な、なんだ……それならば良か\nった。いや、良かったのか？　ま、まあいい……だが、せっかくの種汁」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0103404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「どうせならばそのまま……♪　ふぁああ♪　私の顔に一滴でも多くかけて、\nメス犬の立場を教え込んでくれ……刻んでくれ……♪　っああああ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0103405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「どぴゅ、どぴゅ、とこのような猛烈な勢いで射精していたのだな……一度目\nも……♪　あぁあ、なんと凄まじき生命力のほとばしりだ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0103406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「んぁ……、全て出しきれたか……？　ああ、そうだ。顔にかけられた経験は\nないが……まったく嫌ではなくて、むしろ……あたたかくて心地いい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0103407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「うぁ……、子種とはこんなにいやらしい臭いがするものなのだな……。ニン\nジャともあろうものが、不覚にも驚愕させられてしまった……。うう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0103408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「ボウチュウジュツとは、なんと奥深きニンジュツなのだ……。何？　こんな\nことは、ジュツの入口にすぎない？　そ、そんな……すごすぎるぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0103409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「知りたい……。ボウチュウジュツのこと、なんでも……！　お前には教える\n才能がある、これからも、私にジュツを教え込んでくれ、頼む……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0103410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
