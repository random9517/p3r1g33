		{"command":[ "PLAYVOICE", "034_0104404" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、はぁ……。うーわー……すっげケモノの匂い……。隊長の精液\nの臭いで眩暈するぜ、これェ……」", "NORMAL" ]},
