		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「んぐっ！！　んんんんんーっ！　キタっ、キタキタキタっ！　入ってきた…\n…強いオスの種ぇえ……あああああっ！」", "NORMAL" ]},
