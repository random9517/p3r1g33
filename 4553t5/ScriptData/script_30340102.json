		{"command":[ "PLAYVOICE", "034_0104405" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「……ま……しゃあねえか……。ガキできちまったら困るもんな。本当は中に\n出して欲しかったけどさ、隊長を困らせるわけには……って」", "NORMAL" ]},
