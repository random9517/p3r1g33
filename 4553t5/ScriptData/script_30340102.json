{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "PLAYVOICE", "034_0104101" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「あっは……♪　ようやく俺を呼んでくれたな？　隊長？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00003401_01", "2", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0104102" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「俺……ずっと待ってたんだぜ？　隊長から果たし状が……真剣に俺とヤり合\nおうって連絡が来るのを、指折りさァ……クククッ」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00003401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0104103" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「でも、わかってて呼んだんだよな？　俺と決着つけるためにさ……。ああ…\n…待ちに待ってた……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0104104" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「早く、早く抱いてくれ……ぇっ、もう隊長じゃなきゃだめなんだ、どんな敵\nでも俺のくすぶった炎が消えねえ……！　アンタじゃなきゃダメだ」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00003401_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0104105" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「俺のこと、乱暴に抱いて、犯して、ぶっ壊してくれよ……っ！　今日までず\nっと……！　隊長のことばっか考えて濡らしてたんだ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0104106" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「避妊もいらねぇ、ガチのセメントだ。生チンポを生マンコに突き刺して……\n容赦なくガン突きしてくれ、孕ませてくれ、跪かせてくれぇっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0104107" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「……っはぁ……はぁ、はぁ……。スーツをさぁ、股間のとこだけ引き裂いて\n挿入するって興奮するだろ？　絶対に見えちゃいけないとこが見えて……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003401_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0104108" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「オマンコだけがくぱくぱって、濡れて糸引いて隊長を誘ってんだ……。あは\nはっ、こんなの絶対お子様には見せられない恥辱的な姿だよなぁ……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0104109" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「隊長のデカマラあてがわれて……、んっ、正義だ仲間だってイキってた俺が\nチンポ狂いになっていくところ……じっくり堪能してくれよ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0104110" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「ほら、ほら……入れちまうぜ……？　俺、ずーっと鍛えてきたからさ……ア\nソコもギュウギュウに締められるんだ、気持ちよさそうだろ……？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003401_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0104111" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「ギチギチに絡みつくヒダ肉をさぁ、その屈強なチンポでこじあけて、ねじ入\nれて、全力で突いてくれ……。ああ……想像だけでイキそうだ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0104112" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「隊長も、準備はバッチリ出来てるみたいだし……御託はいいからヤリまくろ\nうぜ？　んん……アアアッ、入るっ、入る……ぅ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0104113" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「んぐぅっ、んううううっ……！？　あヒッ？　あへっ、あひぇえっ！　あ、\nマジか……マジか、ここまで太いのか、よ……ありえねぇ……っ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003401_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0104114" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「隊長のチンポ、チンポやばいっ……！　ああっ……マジでこんなッ……！　\n奥に、奥にブッ刺さる……突き上げ、られる……ぅ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0104115" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「あ……あッおいっ、おいっ……！　も、もう動くのかよ、もう少し様子を見\nてからでも……ってうァッ！？　アアッ！？　あっ、ああっ！？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003401_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0104116" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「やっべ……やっべやっべぇっ……！！　アアッ、隊長のチンポ、イメージし\nてたのより何倍もすげェよ、熱くてデカく、て……ぇっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0104117" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「んぉっ！？　オッ、おおっ！？　アアッ……！　ちょっと中で動くだけ、で\n……ああっ！　俺の、俺のヒダヒダめくりあげられて……ぇっ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003401_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0104118" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「チンポにまとわりついたマン肉ごともってかれるっ！　は、腹ん中おかしく\nなるっ……アアッ！　無理やりオマンコ拡げられ、て……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0104119" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「うぁああっ！　アッあっあっ！　嘘だろぉっ……！　ピストンだけで俺の尻\nっ、腰っ、いや上半身までぶち上げてきやがるっ……つ、よすぎるぅっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0104120" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「ああっああっああっ！　ダ、メだだめ……っ！　ヌゴヌゴ音がしてやがる、\nチンポ、チンポがオマンコの中掻き回し……て……んぁああっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0104121" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「おいっ、馬鹿みてぇに変な声でちまうぅっ……！　ああっ、あはぁッあぁっ\n……ああぁんんっ！　ッ……い、いやだ……嫌だイヤだ……ぁあ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0104122" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「隊長とはヤりたかったしスッキリしたかった、けどさぁ……！　あんっ！　\nこん、な……オンナっぽい、メス声出るとか聞いてねぇよぉっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0104123" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「っあんっ！　あんっあん、アンッ、あぁんんっ！　ああ……ああ、ああっ…\n…あぁあっ……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003401_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0104124" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「さい、きょ……最強すぎる……隊長のチンポぉ……！　これに抗えるヤツな\nんかいんのかよ、アッ、規格外だろ、現実とは思えね……ぇっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0104125" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「デカい、硬い、深い、強いぃいい……！　あっ！？　アッひっ、アヒィッ！\n　あーっ！？　あっあっあっ！　く、クソぉ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0104126" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「この俺が一方的にヤられる、なんて……さすがは隊長だぜ、でも……ンンン\nっ……！　わかってんだろ、やられっぱなしでいるわけねェって！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003401_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0104127" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「ッ……ククク……ど、どうだぁ！？　俺のマンコっ……隊長のチンポつかん\nで、絡みまくって離れねぇ、だろ……！　っはぁっ、ハァ、はぁっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0104128" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「膣圧には自信あんだ……。そんじょそこらの弱っちい女と俺はちが……、ち\n、が……あああっ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0104129" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「んんんんぅっ！？　クゥンッ！？　くぅううんっ！？　じょ、冗談だろっ！\n　俺のマン圧こじあけ、て……ああああっ！　その上突いてくるぅっ！？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003401_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0104130" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「アアーッ！？　あっあっあっ！　嘘、だウソだ……あああああーっ！　つよ\n、い……このチンポ強すぎぃいいっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0104131" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「超気持ちいいぜ……あっ！？　だからやめ、やめろって……真剣勝負になん\nねぇだろっ、あっ！　イイとこ突きやがって……ぇえっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003401_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0104132" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「ンッ、んんぁっ、アアっ！　ああっ、ああ、ああああああ……！　んだよぉ\n、まだデカくなんのか、アッ！　待てっ！　待て待て待てぇっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0104133" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「それ以上太いので掻き回されたら……ああああっ！　ああ、やば、い……や\nばいやばい、イクっ！　イクッ、イクイクぅっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0104134" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「ンン！？　も、もしかして隊長もイク、のか……！　あ、いや、いいんだイ\nッても、イッても……でも今は……！　こっちが敏感で！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0104135" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「イキっぱなしのトコに精液なんか流し込まれたら、どうなるかわかんねぇ…\n…って、ああっ！　ヤバ、いチンポ痙攣してるっ、出すのかよぉおっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0104136" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「ンアっ！　あああああっ、ああーっ！！　出てるっ、出てる出てるっ！　え\n、えげつねー量……俺の子宮にビュルビュルかかってるっ」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003401_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0104137" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「ふぁ、あああ、あああっ……！　鉛の銃弾、みてぇに……っ！　クッソ、子\n宮口が押し上げられて……アーッ！　こんなのアリかよぉ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0104138" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「隊長の精液でまたイクっ！　イクッ、イクッ……！　ッんぉおおおお……っ\n！　負けたくねぇのに、俺が、したいのに……ッ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0104139" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「チンポ強すぎてオマンコ従順になっちまってるぅうう……！！　アッ！　お\nっほっ、おほっ！！　いぐっ、イグイグイグっ……イグぅうっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0104140" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「ひぃーっ！　ひぃいっ！　あひっ、あひぃっ！　あっつい精液、精液ぃ……\n！　俺、俺、おかしくなっちまうよぉおおっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0104201" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「……あがっ！？　なんっ、なんだァ！？　射精してたはずのチンポがまた、\n俺の腹えぐり出して……。ぬ、抜かずの二発目ェ！？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003401_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0104202" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「ああ、イイぜイイぜイイぜぇ……！　俺を完堕ちさせるつもりだなッ……隊\n長の本気チンポすげぇよ、鋼鉄、みてぇだ……アアアッ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0104203" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「あぎっィッ……！　精液吸おうと開いた子宮口に……トドメの汁を注入する\n気、だな……！　アッ、なんで出した直後が一番デケぇんだよぉおっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0104204" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「あっやめっ、やめ、やめりょっ！　やめっ……！　オマンコの一番奥、グリ\nュグリュグリュグリュゴリュゴリュすんじゃねっ、やめてくれぇっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003401_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0104205" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「ああーっ！　ああああっ！　開いてっからっ、もう開いてっから子宮とかァ\n……！　これ以上……んあヒッ！　えぐられたら戻んなくなっちまうっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0104206" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「いつでもどこでもチンポ汁待ちわびるガバガバの淫乱子宮口になっちまうか\nらぁああっ！　そしたら妊娠確実っ、じゃねえか、防げねえよぉっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0104207" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「隊長のチンポ汁好きなだけ注がれて……ミルクタンクになっちまうぅっ……\n！　精子欲しがるだけの肉奴隷に、あふぅっ、なっちまうよぉ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0104208" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「ああっ、ああっ、ああっ！　正義の味方としてもダメぇ、今度は用心棒とし\nてもダメぇ……ここまで堕とされて……なのに、なの、に……ぃいっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0104209" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「仲間裏切った時より、チンポ突っ込まれてる時の方が気持ちイイ……！　ア\nッ、なんにも考えらんなくて、チンポ、チンポ入っててっ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003401_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0104210" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「全身がオマンコになったみてぇに……どこもかしこも凶悪な亀頭でえぐられ\nて！　ズッポズッポされてっ……気持ちイイ！　気持ちイイんだよぉ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0104211" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「うぁ……アッあっあっあっあっ！　またイグっ、イグっ、イカされるっ、う\nあああっ……あぁんっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0104212" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「あぁんっ！　俺っ、もう正義も悪もどうでもいい、隊長のチンポの入れ物と\nして生きて……く、だって気持ち良すぎるンだよぉ……あええっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0104213" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「隊長っ、隊長隊長っ……俺っ、どっかで自分よりつえぇヤツにこうして犯さ\nれたかったのかもしれねぇ、屈して、全部さらけ出して……ぇえっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0104214" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「俺なんかただのマゾ雌なんだって、アヒィッ！　チンポでわからされたかっ\nたのかも……だって、だって、だってよぉ！　アアアッ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0104215" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「すっげ解放感、なんだ……隊長に犯されてっと……頭の中スッカラカンにな\nって、チンポ、チンポがすげえってそれだけんなって……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0104216" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「ッあああああッ！　イキ狂ってンのがっ、よがりまくってんのが本当の俺の\n姿なんだってぇ……！　チンポが教えてくれんだよぉっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0104217" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「アーッあっあっ！　アァッあっ！　チンポ様、チンポ様ぁ……！　俺をイカ\nせ続けてくだ、ひゃい、なんでもしまひゅ、なんでもひまひゅぅう……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0104218" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「オチンポひゃまの言うこと聞きまひゅからぁあ……！　だからズボズボやめ\nないでくだひゃい、やめないれ……ああ！　イクイクイクイクッ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0104219" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「マゾイキきめちまうっ！　あーっ！　おッおッおっ！　アハ……！　目の前\n火花飛んで、チカチカって……ああ、キレーだぁ……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003401_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0104220" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「アッ……隊長、隊長イクっ……！　勝負は俺のッ……俺の負けでいいから隊\n長の精子くれよぉ……それでイく、からさぁ……お願いだ……っ」", "NORMAL" ]},
