		{"command":[ "PLAYVOICE", "034_0104406" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「はァ？　マーキングぅ……？　俺に勝ったから、勝利の証にぶっかけてやっ\nたぁ……？　アハ……やるじゃねえか……！」", "NORMAL" ]},
