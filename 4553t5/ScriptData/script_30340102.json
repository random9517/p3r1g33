		{"command":[ "PLAYVOICE", "034_0104407" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「俺さ、隊長のそーゆー傲慢不遜なトコ、嫌いじゃないぜ？　実際俺に勝てる\nヤツなんて他にいねェし……」", "NORMAL" ]},
