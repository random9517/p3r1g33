		{"command":[ "PLAYVOICE", "034_0104303" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「アヒィイイイッ……！　イキっぱなしのトびっぱなしぃいいっ……！　さす\nがは俺のッ、俺の隊長だぜ……キくぅううううっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0104304" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「あ……あ……っ。たいちょ、の……隊長の精子、クセになっちまいそ……！\n酒よりも、クスリよりもカッ飛べる最高のガンギマリアイテムをぉおっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0104305" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「鍛えようもねぇ一番繊細で敏感な粘膜にドップドプ注がれて……脳細胞ブッ\n壊される経験なんて、他に出来るもんじゃねえぜ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0104306" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「あっあがっ……！　信じられねえ量出しやがってえええっ……俺の卵子が溺\nれちまってるだろぉおっ……プカプカってさぁああ……♪」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003401_02_11" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0104307" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「ッ……～っ……！　強烈で、シャレになんねえガチ種付け……。嫌じゃねえ\n時点で、俺の完全敗北だ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0104308" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「あは……ははは、聞こえるかぁ……？　俺の子宮がさ、隊長の精液でタポタ\nポちゃぽちゃぽ言ってんの……。ぜってぇこんなの妊娠してる……っ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0104309" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「これ、が……俺を負かした男の特濃精液ィ……。あは、あは、あははは……\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0104310" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「こうなっちまったら、もう俺は隊長のモノだ……。アンタのためならなんで\nもするって約束するよ……。あはっ、あはははっ……」", "NORMAL" ]},
