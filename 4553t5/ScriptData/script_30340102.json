		{"command":[ "PLAYVOICE", "034_0104302" ]},
		{"command":[ "SETNAME", "マスク・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「隊長ッ、隊長ありが、と……ありがとう、あっ……！　中出しキメられてイ\nクの最高だァっ……あーっ！　ずっと終わんねぇえっ……！」", "NORMAL" ]},
