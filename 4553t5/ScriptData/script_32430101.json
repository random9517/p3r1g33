{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0149" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「ん？　寝ていたのか？　すまないな……こんな夜更けに訪ねてしまって。体\n調が思わしくないのであれば、このまま帰るが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0103101" ]},
		{"command":[ "SETCHARA", "0", "char_00024301_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「……部屋に入ってもいいのか？　ありがとう。私？　私は先程まで、１人で\n鍛錬をしていた。……もしかして、汗臭かったり……するか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0103102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「うん……。その……入浴前に、一言あなたに告げてすぐ戻ろうと思っていた\nから……。シャワーを浴びずにここに来てしまった。……くさいか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0103103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「よくわからないから近くにきてほしい？　そ……それは……ええと……。と\n、私はそんな話をしにきたわけではなくて……。……あっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0103104" ]},
		{"command":[ "SETCHARA", "0", "char_00024301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「ど、どうした！？　急にベッドに倒れこんで！　貧血か！？　失神か！？　\n疲労が蓄積され過ぎて気絶したのか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0103105" ]},
		{"command":[ "SETCHARA", "0", "char_00024301_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「……も……もしそうなら、話は明日にしよう。私は帰るから、ゆっくり休ん\nで……。……何？　突然我慢ができなくなった？　何がだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0103106" ]},
		{"command":[ "SETCHARA", "0", "char_00024301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「汗まみれの私の身体から、甘い匂いがして……？　衣装が肌にはりついて、\nいやらしかったから？　……あ……ッ、も……もしかして、こ、これ、は」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0103107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「私は……押し倒されているということか？　ッぁ……。そ、それは……！　\n……前から、そうだったのか？　私の衣装に興奮して……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0103108" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00024301_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「……衣装だけじゃなく、乳房や尻、脚に首筋にも？　ずっと興奮していた？\n　あ……。し、知らなかった……。全然気が付かなかった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「それで……私をどうするつもりなんだ？　力づくで跳ねのければ、私はあな\nたから逃げられるが……。それでも押さえつけるのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「このままパイズリフェラをしてほしい？　パイズリ……？　パイズリとは…\n…？　ああ。私の胸に、肉棒をさしこんで……？　それで？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0103111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「衣装をつけたまま、それをシゴくこと……？　……うぁ……！？　ほ、本当\nにそんなことがしたいのか！　したいのか……そうか。えっと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「わ……わかっ……た。いや、実際よくはわかっていないが……日頃世話にな\nっている貴方のためだ。言う通りに……しよう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0103113" ]},
		{"command":[ "SETIMAGE", "0", "still_00024301_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「本当に、脱がなくていいのか？　うん。汗ばんだ乳房の谷間に無理やりチン\nポをねじこむから良い？　わ……、ぁ、あ、そ、そういうものか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「では……ど、どうぞ……。わからないことばかりで申し訳がないが……リ、\nリードをお願いしてもいいか？　あ……肉棒を近づけて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0103115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「んんッ……！？　あっ……！　ほ、本当に無理やり……！　無理やり胸の間\nにねじ込んで……！　あっ……！　え？　パイズリ？　パイズリとは……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0103116" ]},
		{"command":[ "SETIMAGE", "0", "still_00024301_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「こ、こういうことか……！　あっ！　わっ……！　熱い……！　だ、男根…\n…ッ。男の陽根はこれほどまでに熱く、硬く脈打って……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「うぅ……！　ほ……本当に、私には未知のことなんだ……。戦いのこと以外\n、なにもわからなくて……男の身体なんてもちろん知らない……だから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0103118" ]},
		{"command":[ "SETIMAGE", "0", "still_00024301_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「……男根も、存在は習ったと思う。でも……見るのも触れるのも初めてで…\n…。ああもう、わ、私の事情はいいから……はじめてくれ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「胸に入れた後はシゴく？　のだろう？　シゴくが何かわからないが……。ん\nっ……したいようにするといい。……ぁ、動かすのか？　肉棒を？　うっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「あ……ぅ、あぁ……！　は、ぁ……っ、あぁ……！　肉の海をかきわけるよ\nうに……あっ……！　あなたの肉棒が、私の胸を突いて、かきまぜて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「はぅ！　……あっ！？　妙な声をあげてしまってすまな、い……。あぅっ…\n…！　む、胸が押されておかしな声が出てしまうんだ……。……うぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0103122" ]},
		{"command":[ "SETIMAGE", "0", "still_00024301_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「あッ……うぅ、はぅ……！　うぅン……っ！　あっ……あっ、あっ、あぁ…\n…！　な、んだ……？　このパイズリという儀式……っぁっ！　あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「恥ずかしくて汗が止まらない……それに、……っんっ！　力強く突かれると\n……ただ胸を貸しているだけなのに、心臓が早鐘を打って……あうぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「体温が上昇する……、目の前がモヤのように霞む……っ。あっ……！　肉を\n打つ激しい音……。あぁっ！　胸が……弾んで、揺れて……ゆがんで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「あっ！　衣装にこすれて……くるしい。っふぁっ……あぁ……！　な……な\nんだ？　この衣装のここ……胸の下に穴が開いているのは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「こうやって肉棒を入れるため！？　そ、そうだったのか！？　私はてっきり\n、戦闘中に身体の熱を逃がす穴なのかと……！　パイズリ穴……っ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「あっ！　わたし、私の戦闘服には……そんな破廉恥な穴が……！　あっあぁ\n……！　そんなっ……知らなかった、皆にもそう思われていたのか……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「ぱ……パイズリ穴でパイズリをするXヴァルキュリーだなんて……私は、私\nはもうどうしていいのかわからない……恥ずかしい、恥ずかしい……ッ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「や、やめてくれ……あっ、パイズリ穴でパイズリするのはだめだ……！　あ\nぁっ！　みんなに、みんなにバレてしまう、今日……パイズリしたことが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0103130" ]},
		{"command":[ "SETIMAGE", "0", "still_00024301_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「……っぁっ……！　あっぁっあっ……！　と、とっくにバレている……？　\nそう、だったのか……。あっ……うう、はずかしい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「ッんっ……んぅっ……んっ、んん！　私がこうして、パイズリ穴を突かれて\n悶えてしまうのも……ピチピチの衣装が、はちきれそうでそうならないのも」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「この肉穴が……衣装の穴がこうするために存在するからだったなんて……！\n　べ、勉強不足だった……あっ、あっ、うぅう、はずかしい……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「……ん！？　な、なんだ？　なぜ腰を加速させる？　あっ！　こらっ！　こ\nれ以上速くしたらさすがに服が破けるっ……！　しゃ、しゃせい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「このパイズリ穴に精液を注ぎ込む！？　っ……正気なのか！？　あっ……！\n　や……！　らめっ、こんな狭いところに射精なんかしたら……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0103135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「私の胸が精液まみれになってしまう、それは……それはもう、私の理解を超\nえすぎていて……！　だ、だめだ！　出すな、出すなぁ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0103136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「っうぅうう……！　きゃあっ……！　あぁ……！　や、だ……ぁやだあ……\n！　精液っ、出てる、出てる胸にぃ……溢れてくる……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0103137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024301_01_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「んぁあああ……ッ！　ひっぅ……！　うう……！　やぁ……！　ま、待て…\n…待てぇ！　どっ、どれだけ出すつもりだ……もういい、もういいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「あっ……あっ、あっああああ～～～～！　ダッ、メ……あぁっ！？　衣装っ\n……大切な衣装が、私の胸が……ドロドロのネバネバだ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「な……なんということをしてくれたんだ……っ。パイズリは、許可した！　\nしかし……胸の穴に射精まで……！　やる事のレベルが高すぎる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「っ……うぅう……。し、しっかり全部吐き出してくれたようだな……！　は\nぁっ、はぁ……止めたのに……まったく聞いてくれなくて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0103201" ]},
		{"command":[ "SETIMAGE", "0", "still_00024301_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「んっ！？　な……なんだこの臭いは？　んぷ！？　臭い湯気が顔にかかって\n……あぅっ！？　せ、精子の臭い？　あ……なんてことを……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「……私の胸が心地良すぎて、衣装がエッチすぎてたくさん出た、だと？　…\n…そ、それなら……。って、ご、誤魔化されるものか……！　こらっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0103203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「早くこのドロドロを洗わないと……。って、ふぁんんッ！？　えっ！？　あ\nっ！？　えぇ！？　このまま……続けるのか！？　あっ！　パイズリを！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0103204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「やっ……！？　あぁ、ええっ！？　えええっ……！？　あうっ！？　精液、\nせいえきがついたままだぞ？　あっ！　そ、その方がいい？　なぜ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「このヌルヌルでパイズリが更に気持ち良くなる！？　……ヌチャヌチャにま\nみれた衣装と胸を楽しみたい？　えっ……？　えっえっえっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「……んくっ……！　い、嫌ではないが……！　素直に言って驚きで……口が\nふさがらない……。……ぅっ！　だって臭いのに、粘っているのにっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「……あッ♪　あっ、ぁっ♪　まるで私の胸、と……！　この衣装と子作りで\nもしているかのように……こんなに激しく腰を振って……あっ、困るぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「あふっ……うぅっ、あッ、ううぅん……！？　も、もう……！　なんという\n強引さだ……！　わ、わかったッ、わかった……！　していいから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0103209" ]},
		{"command":[ "SETIMAGE", "0", "still_00024301_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「あっ！　貴方の劣情を私の胸に……バトルコスチュームにぶつけていいから\n……あっ！　そんなに卑猥な腰使いをしないでくれぇ……あぁんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0103210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「そんなにガツガツされると……！　はぁっ、ガッツいて胸に襲い掛かられる\nと……こっちも乳房が敏感になってしまう……！　っあぅっ、あっあぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「あんまり高速でこすられる、と……もどかしい！　あっ……身をよじっても\nよじっても、ズンズン突かれて……皮膚がピリピリして……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「ゾクゾクする……！　あっ！　あっあっ！　あなたの精液……精液を胸に塗\nりたくられてる……貴方の肉棒で、精子塗られてる……！　ふぅうっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「衣装だって……もう精液の臭いがとれない……！　あっ、あっ、このコスチ\nュームで戦闘なんかしたら……絶対思い出してしまうだろうっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0103214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「パイズリっ、パイズリ穴……ズンズン貫かれて、突き上げられて……ああっ\n！　めまいがするほど、はぁ、はぁ……私、興奮して……んんんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0103215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「あ、あぁ……もうわけがわからない……。それなら……あ、貴方が喜んでく\nれる方が……いいのか……？　あっ……鼓動がおさまらない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0103216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「貴方の肉棒にも、きっとこの心臓の音……聞こえてしまっているんだろうな\n。それが、たまらなく気持ち良くて……。んっ……あぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「は、ぁ……あ、ぁ……あっあぁッ……ああｘ……！　も……もう限界だ、こ\nれ以上されたら……私は後戻りできなくなる……っ、た、頼む……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0103218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「先程みたいに、精液……精液を出して、私を解放してくれ……。でないと…\n…でないと……！　あぁあっ！　私は、私でなくなるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「出し、て……出して欲しい……！　いいからっ……衣装が濡れても……あぅ\nっ！　どれだけ汚れてもいいから……出してくれぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「んぁぅううう……！　あうっ！？　あうッ……！　はぁううぅうっ……ああ\nああっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0103301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024301_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「んっ！　うぁっ……ふぁっ♪　ふぉおぁっ♪　あぁ……♪　なんと元気で、\n健康な肉棒なんだ……。ドクドクとほとばしりが止まらない……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「あっ♪　あっ、跳ねる……！　お、落ち着いてくれ……。あッ♪　私は逃げ\nないから……！　ゆっくり胸に射精を……。っふ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0103303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「ふぅうう……♪　……ようやく……しずまってきたのか……？　先程出した\n直後だというのに、二度目にもまったく勢いが衰えない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0103304" ]},
		{"command":[ "SETIMAGE", "0", "still_00024301_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「貴方にとってこれは……凄く興奮することだったんだな……。はぁっ……。\nわ、私はどうか？　それは……あの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0103305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「誰かに押し倒されたりしたことも未経験だったし……パイズリも初心者だっ\nたし……。戸惑うことばかりだったが……。貴方が……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0103306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「この服に、私に発情して……せ、精液を放ったりしたことが嬉し……かった\n。だって、本気で劣情をもよおさなければ、ここまでの量はとても……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0103307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「そう思うと、衣装にたっぷり注がれた精液も……少し愛おしい。もちろん、\n洗うのが困難なほどの量だし、臭いだって落ちないかもしれないし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0103308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「……誰かに気付かれたり、自分が……戦闘中に思い出してしまうとは思うが\n……。貴重な経験だったと思う。それに……これからは」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「こういったことも、覚えていかないと……。え？　いやっ、な、なんでも…\n…。私の独り言だ。聞かなかったことに……してもらいたい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「うぁああっ！？　急に……急に肉棒を抜いて何を……！？　あっ……！　や\nっ、いやっ……！？　んぷ……！　ふぅううう……ッ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0103401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024301_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「ひゃ……ッ、あっ♪　きゃっ……ちょっ……ちょっと待て……ッ！　あっ…\n…！　顔っ……私の顔にかかっているからっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「ぷ、ぁ……あぁ……♪　髪に……顔に、精液を書けるなんて……どういうつ\nもりなんだ……！　あっ……♪　衣装と胸だけでは飽き足らず……ぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0103403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「待って……！　わっ……♪　私の上半身全て、精液まみれにされたら……絶\n対にセリオンにばれてしま……！　ッんぅうう！　待ってくれぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0103404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「っぁああああああ……！！　う、うぅ……。結局全て……ありったけ顔にぶ\nちまけられてしまった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0103405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「あ、貴方には私を辱めて楽しむ癖があるのではないか……？　何？　パイズ\nリされている私の顔が可愛くて？　……か、可愛い？　か……かわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0103406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「可愛い……と思ってくれたのなら……まあ……いいか……。うん……。二人\nの時は、どれだけ貴方に欲望をぶつけられてもかまわないが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0103407" ]},
		{"command":[ "SETIMAGE", "0", "still_00024301_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「テリオンや他の誰かがいる時には、絶対にこの衣装の穴……パイズリ穴を凝\n視してはいけないぞ……。賢い人達にはきっと、すぐさとられてしまうし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0103408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「わ……私も恥ずかしい……。だから、二人になった時だけだ。約束してくれ\nるか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0103409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テリオン" ]},
		{"command":[ "SETTEXT", "「……ああ。当然、二人の時はかまわない。お、押し倒すのも……劣情をぶつ\nけるのも……。そういう感じで、これからもよろしく頼む……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_243_0103410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}