		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ダメだこりゃ……」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "このカオスな状況を止めるためにも、俺は本気で、３姉妹が目立つ方法を考え\nてみることにした。", "NORMAL" ]},
