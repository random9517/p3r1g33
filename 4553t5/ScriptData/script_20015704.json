{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0186" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_005" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「儚く散ったバカ姉たちの仇を討つために……三女の私が、ここで一花咲かせ\nてみるね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_010023730001" ]},
		{"command":[ "SETCHARA", "0", "char_00028701_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「何１つ儚いことなんかなかったけどな！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "未だ、ピクピクと痙攣しているティシポネーを介抱しながら、メガイラはじー\nっと俺の顔を見上げた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「私には……そんなに自己紹介っていう自己紹介もない。けど……。聞きたい\nなら、教えるね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_010023730002" ]},
		{"command":[ "SETCHARA", "0", "char_00028701_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「私は……姉妹の中では頭脳要員。ティシポ姉と同じく、死者の魂を罰する役\n割を持ってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_010023730003" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「……あまり、目立つタイプじゃないから……。バカ姉たちの存在しか知らな\nい人も多い、のかな……。だけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_010023730004" ]},
		{"command":[ "SETCHARA", "0", "char_00028701_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「今回は頑張るつもりで……。……うん。『妹にしたいキャラ部門』を狙って\nいこうかなって……。どう思う……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_010023730005" ]},
		{"command":[ "SETCHARA", "0", "char_00028701_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うーん……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「……やっぱり……地味だから無理……かな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_010023730006" ]},
		{"command":[ "SETCHARA", "0", "char_00028701_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや。言っちゃなんだが、ティシポネーの後には何でも良く見えるな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「あぁ！？　なに突然罵倒してくれてんだ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_010023730001" ]},
		{"command":[ "SETCHARA", "0", "char_00028601_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「あっ♪　あぁっ♪　んおっ♪　あたしに面と向かってそんなこと言うヤツは\n初めてだぜ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_010023730002" ]},
		{"command":[ "SETCHARA", "0", "char_00028601_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「なんか気持ち良くなってきたぁああ……♪　んぉお♪　おっほっ、おぉっ♪\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_010023730003" ]},
		{"command":[ "SETCHARA", "0", "char_00028601_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「ティ、ティシポネー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_010023730001" ]},
		{"command":[ "SETCHARA", "0", "char_00028501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「完全にイッちゃってる……。コレと姉妹なのが足枷っていえば足枷……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_010023730007" ]},
		{"command":[ "SETCHARA", "0", "char_00028701_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まあインパクトはすごいけどな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "1" ]},
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「……ポ姉。ポ姉。よしよしよし、落ち着いて、落ち着いて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_010023730008" ]},
		{"command":[ "SETCHARA", "1", "char_00028701_01", "3", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "0", "char_00028601_01", "5", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「ポ姉は最高の妹キャラになれるよ～……。だいじょうぶ……だいじょうぶ…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_010023730009" ]},
		{"command":[ "SETCHARA", "1", "char_00028701_01", "8", "CENTER", "-400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「う、ううう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_010023730004" ]},
		{"command":[ "SETCHARA", "0", "char_00028601_01", "4", "CENTER", "400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "SETTEXT", "メガイラはティシポネーに優しく語りかけ、親身になって励ました。", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00028601_01", "4", "CENTER", "400" ]},
		{"command":[ "SETCHARA", "1", "char_00028701_01", "8", "CENTER", "-400" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「ほら、見てて。ポ姉は罵ったり馬鹿にすると興奮しちゃうけど……。こうや\nって優しく励ますだけで、元のトゲトゲ対応に戻るんだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_010023730010" ]},
		{"command":[ "SETCHARA", "0", "char_00028701_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「凄くめんどくさい奴だな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「まあ、扱いやすいといえば扱いやすいかな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_010023730011" ]},
		{"command":[ "SETCHARA", "0", "char_00028701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「……って、そんな場合じゃない！　やっと私の番なのに、危うく話題を持っ\nてかれそうになった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_010023730012" ]},
		{"command":[ "SETCHARA", "0", "char_00028701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「妹部門についての話に戻るね……。これはあくまで個人的な分析……の結果\nなんだけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_010023730013" ]},
		{"command":[ "SETCHARA", "0", "char_00028701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああ。わかっていることがあれば何でも教えてくれ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「妹系のキャラも……結構いるから。その中で飛びぬけた存在になるのは、相\n当難しいのかな……って感じた」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_010023730014" ]},
		{"command":[ "SETCHARA", "0", "char_00028701_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「めちゃくちゃ冷静に、自分の立ち位置を把握してるんだな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「うん。それでね。特に私の場合は……アン＝クァーやハルノブ、イルルって\nいう……根強い人気があるキャラたちがライバルになるだろうから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_010023730015" ]},
		{"command":[ "SETCHARA", "0", "char_00028701_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「……不安。だけど……もし、誰かが見つけてくれて……。投票してくれたら\n、すごく嬉しいと思うんだ……。だから、なんとかならないかなあって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_010023730016" ]},
		{"command":[ "SETCHARA", "0", "char_00028701_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「なりますわよ！　というか、なんとかしてみせます！　それに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_010023730002" ]},
		{"command":[ "SETCHARA", "0", "char_00028501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「私個人の気持ちを言っていいのでしたら、どうっっっしても……モイライシ\nスターズのアトロポスにだけは負けてほしくありませんわ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_010023730003" ]},
		{"command":[ "SETCHARA", "0", "char_00028501_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「メガイラはアトロポスとは、あんまり属性がかぶってない気がするが……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「うん。私はダウナー系だし……。おとなしい子たちと争うことになると思う\nけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_010023730017" ]},
		{"command":[ "SETCHARA", "0", "char_00028701_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「それでも、エリニュスの名において、モイライシスターズにはどうしても負\nけたくないのです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_010023730004" ]},
		{"command":[ "SETCHARA", "0", "char_00028501_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "意気込むアレクトに、メガイラもやれやれとジト目になりながらも付き合って\nあげている。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETCHARA", "0", "char_00028701_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "ティシポネーへの対応を見てもわかる通り、メガイラは姉２人のストッパー兼\n有能なアドバイザーなのかもしれなかった。", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00028701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「どうしたら、メガイラが勝てると思いますか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_010023730005" ]},
		{"command":[ "SETCHARA", "0", "char_00028501_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……今、必死に頭をフル回転してみてるが……名案と言える案は出てこない\nなあ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「そ……そんな……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_010023730006" ]},
		{"command":[ "SETCHARA", "0", "char_00028501_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "実際に、メガイラが名前を出したメンツに会ったことがある俺としては……メ\nガイラだけをえこひいきすることもできない。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "もちろん、メガイラを応援してやりたい気持ちもあるが……他のやつらの邪魔\nをしたくないのも本音だった。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「データだけじゃよくわからないかもしれないが、人気があるやつらは人気が\nあるだけの理由があるんだよな」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「可愛いとか、優しいとか、甘い匂いがするとか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_010023730018" ]},
		{"command":[ "SETCHARA", "0", "char_00028701_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そういうのもあるし……。性格が良かったり、一緒にいて癒されたり、落ち\n着いたり……守ってやりたくなったり……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「妹がいたらこんな感じなのかな、とかついつい妄想しちまうような……なん\nともいえない魅力があるっていうか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「……カツマは私じゃ、妹にしたいとは思えない……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_010023730019" ]},
		{"command":[ "SETCHARA", "0", "char_00028701_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、そんなことはないぞ。妹にはしたい。ただ……今の時点ではたくさん\nいる妹たちの中の１人っていうか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「そうだよね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_010023730020" ]},
		{"command":[ "SETCHARA", "0", "char_00028701_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「１度聞いたら忘れられないような、強烈なウリがあれば……メガイラじゃな\nきゃダメだってやつが出てくるはずだ。何かないか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「……無い。そんなスゴい魅力……。私には無い……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_010023730021" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "しゅんとしているメガイラを見て、ティシポネーは何かピンと来たらしい。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「あるぜ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_010023730005" ]},
		{"command":[ "SETCHARA", "0", "char_00028601_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「……え？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_010023730022" ]},
		{"command":[ "SETCHARA", "0", "char_00028701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「メガイラにしかない、メガイラだけの特徴ってやつが！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_010023730006" ]},
		{"command":[ "SETCHARA", "0", "char_00028601_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「……ほ、ほんとに……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_010023730023" ]},
		{"command":[ "SETCHARA", "0", "char_00028701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「やったな！　それを教えてくれ、ティシポネー！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「おう！　まかせやがれ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_010023730007" ]},
		{"command":[ "SETCHARA", "0", "char_00028601_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「あら……。意外と姉妹のことをよく観察していたのですね、ティシポネー。\n見直しましたわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_010023730007" ]},
		{"command":[ "SETCHARA", "0", "char_00028501_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「あ、ありがと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_010023730024" ]},
		{"command":[ "SETCHARA", "0", "char_00028701_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「へへへへっ。そんなに褒められちゃ、言わないわけにはいかねぇよなあ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_010023730008" ]},
		{"command":[ "SETCHARA", "0", "char_00028601_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「いいか！？　これはよぉ～、ガチでトップシークレットってやつだぜ！　で\nも特別に教えてやるよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_010023730009" ]},
		{"command":[ "SETCHARA", "0", "char_00028601_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "ワクワクしながら聞いている俺たちに、ティシポネーはキメキメの顔で言い放\nった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "PLAYBGM", "BGM_018" ]},
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「メガイラは生粋のオナニストでさ、マジで暇があればすぐにオナりまくるん\nだ！　１日に何度もだぜ、すげぇよな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_010023730010" ]},
		{"command":[ "SETCHARA", "0", "char_00028601_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「……ひぅっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_010023730025" ]},
		{"command":[ "SETCHARA", "0", "char_00028701_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「あたしたちが見てねぇ隙を狙って１発、夜寝る前に１発、１度目ぇ覚まして\n１発、朝にもう１発くらいしてるよな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_010023730011" ]},
		{"command":[ "SETCHARA", "0", "char_00028601_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「だからよ、変態性ならお前が１番だぜ！　ぜってぇ誰にも負けねえ！　そう\nだろ、これをウリにしてイこうぜ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_010023730012" ]},
		{"command":[ "SETCHARA", "0", "char_00028601_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「…………う、うう……うううううう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_010023730026" ]},
		{"command":[ "SETCHARA", "0", "char_00028701_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「やめろぉおお～～！！　バカ姉！！！　バカバカバカバカ！　嫌いキライ！\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_010023730027" ]},
		{"command":[ "SETCHARA", "0", "char_00028701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「あっ！？　やんのかコラっ！　あっ、いてぇ！　意外とパンチつえぇ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_010023730013" ]},
		{"command":[ "SETCHARA", "0", "char_00028601_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「誰にもっ……誰にも言うなってあれだけ言ったのに！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_010023730028" ]},
		{"command":[ "SETCHARA", "0", "char_00028701_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「あらあらあら……。ど、どうしましょう……困りましたわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_010023730008" ]},
		{"command":[ "SETCHARA", "0", "char_00028501_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "オロオロするアレクト、荒ぶるメガイラ、わりとボコボコにされているティポ\nシネー。", "NORMAL" ]},
