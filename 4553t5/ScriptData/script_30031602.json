{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「なにぼーっと突っ立ってるんだい？　この部屋にあんたを呼んだってことは\n、ナニをするかわかるだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1604101" ]},
		{"command":[ "SETCHARA", "0", "char_00000316_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「こっちは、ゆく先々で子ども扱いされてストレスがたまってるんだよ！　ポ\nケットの中はおばちゃんからもらった飴だらけだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1604102" ]},
		{"command":[ "SETCHARA", "0", "char_00000316_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「そういうわけだから、あたちの憂さ晴らしにつきあいな！　あんたはとっと\nと服を脱いで、そこによこになるんだよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1604103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「くくっ、いいながめだねぇ。こんな姿のあたちの尻に敷かれて、どんな気分\nだい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1604104" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00000316_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「……って、チ〇ポの方が正直じゃないか。こんなギンギンにおっ立てちまっ\nてさぁ……。ふ～ん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1604105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ほら、見てみなよ。このチ〇ポ、ハメたら腹のここまできちまうんだよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1604106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ちょっ、なにチ〇ポをヒクつかせて、あたちの腹を叩いてるんだい？　もし\nかして、あたちの腹の奥の奥までチ〇ポをぶちこむのを想像した？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1604107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「まったく、こんな小さい身体相手だっていうのに、あんたは節操がないねぇ\n。それとも、小さい身体の方がいいって？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1604108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ま、どっちでもいいさ。今回の主導権はあたちにあるんだ。あんたのチ〇ポ\n、ストレス発散のために好きに使わせてもらうよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1604109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んん……くぅ……っ！　はぁ、はぁ……こいつは……想像してた以上にデカ\nいじゃないか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1604110" ]},
		{"command":[ "SETIMAGE", "0", "still_00000316_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あたちのマ〇コをメリメリひろげながら、チ〇ポがはいってく……んんっ、\nくぅ……はぁ、ふぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1604111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「は……はは……。ほら、見てごらんよ……。あんたのチ〇ポが、あたちの中\nにずっぽり収まっちまったよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1604112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ここ……腹がぽこっと盛り上がっちまってるじゃないか……。んっ、こうし\nて撫でてやれば……くくっ、わかるだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1604113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あんたのチ〇ポが……さっき見せたとおりの場所にまではいっちまってる…\n…。はぁ……はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1604114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「たまらないねぇ。こんなにマ〇コをいっぱいにされたら……。んっ、なんだ\nい、あんたも辛そうだねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1604115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「いつもと違って、チ〇ポが食いちぎられそうなくらいに締めつけてるって？\n　……なんだいそりゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1604116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「まるで、ふだんのあたちのマ〇コがガバガバみたいな言い方じゃないか。ふ\nぅん、気に入らないね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1604117" ]},
		{"command":[ "SETIMAGE", "0", "still_00000316_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「こっちの、キツキツのマ〇コがいいんだったら、お望みどおりにこのマ〇コ\nで精液をしぼってやるよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1604118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ほら、こうやって、腰を思いっきり動かして、チ〇ポをしごいてやるからね\n！　んっ、んんっ、ああぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1604119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あんたのチ〇ポ、すごく感じるねぇ。中で、硬いのが、あたちのヒダという\nヒダをごりごりえぐってくるよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1604120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んんっ、いい肉バイブだよ……。それに、ンッ、あんたのうめき声もいいＢ\nＧＭになってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1604121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「たまらないねぇ。あんっ、ほら、あたちも興奮して……どんどんマ〇コから\n汁がでてきてるよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1604122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「こんな身体でも、一人前に濡れるもんだね。んっ、ああっ、チ〇ポがヌルヌ\nルになって、ンッ、腰、もっと動かせる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1604123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あぁんっ、はぁっ、はぁっ、すごくいいよっ！　亀頭が、一番奥を突きあげ\nてくるっ、んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1604124" ]},
		{"command":[ "SETIMAGE", "0", "still_00000316_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「子宮が揺さぶられてっ、そのたびに頭の中が弾けちまいそうだっ！　あっ、\nんっ、いいっ、これ……気持ちいいよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1604125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ああっ、あんたも気持ちいいんだろう？　こっちの、キツキツマ〇コの方が\nいいんだもんねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1604126" ]},
		{"command":[ "SETIMAGE", "0", "still_00000316_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「中で、チ〇ポを膨らませて、イキそうになってるじゃないか……。んっ、あ\nあっ、どうなんだい？　このまま、イッちまうかい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1604127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あたちの小さなマ〇コの中に、あんたの精液を思いっきりぶちまけちまいな\nよ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1604128" ]},
		{"command":[ "SETIMAGE", "0", "still_00000316_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あはぁっ、ほら、ほらほらぁっ！　チ〇ポ、ぎゅうっと締めつけるよっ！　\nんっ、ああっ、あんたの腰、浮いちまってるねぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1604129" ]},
		{"command":[ "SETIMAGE", "0", "still_00000316_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「気持ちよくて、たまらないみたいだね！　んっ、あたちも気持ちいいよ！　\nあんたのチ〇ポ、いつも以上に感じまくって……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1604130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ああっ、デカいカリにマ〇襞が削り取られちまいそうだっ！　でも、それが\nいいっ、気持ちいい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1604131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んんっ！　限界かい？　このまま、あたちのマ〇コに中出ししちまうかい？\n　くくっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1604132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「いいよ、イッちまいな！　あたちに、あんたの間抜けなイキ顔を晒すんだよ\n！　そらっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1604133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「はぁっ、ああっ、ああ……っ！　イきなっ、イきなっ！　だせ、だせだせ、\nだせ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1604134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ああぁぁあああぁぁぁ～～～～っ！　で、でてるっ！　ザーメンがっ、んっ\n、子宮に……注がれる……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1604135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000316_02_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁ……。だせとはいったけど、限度ってのがあるだろ？　あぁ？\n　あたちのマ〇コが気持ちよすぎるからだって？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1604136" ]},
		{"command":[ "SETIMAGE", "0", "still_00000316_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「そうやっておだてたところで、なんにもでやしないんだからね。そんな口を\n叩いてる余裕があるなら、もう１回つきあいな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1604137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「なにを驚いてるんだい？　若返ったせいか、体力が有り余ってるんだよ。イ\nライラも収まらないしね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1604138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あんただって、チ〇ポはまだまだ勃起しているじゃないか。この身体に興奮\nしすぎだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1604139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「さぁて、抜かずにもう１発。いや、２、３発はだしてもらおうかね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1604140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あぁんっ、んっ、んんっ、いい……。ぐりぐりと、マ〇コの奥を刺激するの\nもたまんないねぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1604201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「チ〇ポが、あんっ、ビクビクって暴れてるよ……。んふぅ、こうしてかき混\nぜると、ふふっ、見てごらんよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1604202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ぼこっと膨れた腹……チ〇ポの先端が動いているから、膨らんだ部分も動い\nているのがわかるねぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1604203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んっ！　そんな様子を見て、ますますチ〇ポを硬くさせてるのかい？　この\n変態は……。んん……はぁ、ふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1604204" ]},
		{"command":[ "SETIMAGE", "0", "still_00000316_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「いいっ、いいよ……！　チ〇ポで中がいっぱいになってる感じ……！　ああ\nっ、たまんないねぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1604205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んぁあっ、ほら、もっと激しく。んくっ、腰を動かしてやるからね……！　\nんっ、んんっ、ああぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1604206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「チ〇ポが、ぶっとくなって、ンッ、あたちのマ〇コが限界までひらいちまっ\nてる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1604207" ]},
		{"command":[ "SETIMAGE", "0", "still_00000316_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁっ！　チ〇ポが出入りするたびに、中から愛液がかきだされる\n……！　んっ、くぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1604208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「精液と混じって、ドロドロになった汁で……あはっ、あんたと繋がってると\nころが、ベトベトになっちまってるねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1604209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「おかげで、すべりもよくなって……腰も、止まらないよ……！　ああっ、す\nごく気持ちいい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1604210" ]},
		{"command":[ "SETIMAGE", "0", "still_00000316_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「はぁっ、んぁっ、あっ、ああっ！　チ〇ポ、ぶっといぃ……！　んくぅっ、\nますます膨らんでる。どこまでデカくなるんだいっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1604211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「こうやって、なすすべなくあたちに搾られて、興奮してるってことだね。そ\nういうことなんだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1604212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んんっ、本当にどうしようもない男だねぇ。でもまあ、しっかり肉バイブと\nして使ってやるよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1604213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ほらっ、ほらほらどうしたんだいっ！　さっきよりも激しく腰を動かしてる\nだけだよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1604214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あんたの腰からチ〇ポをひっこぬくつもりでマ〇コを締めて、ずぼずぼマ〇\nコキしてやってるんだ！　感謝しな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1604215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ああっ、んっ、このままあんたから精液を搾ってやるよ。我慢できないだろ\nう？　あたちのマ〇コの中で、チ〇ポが震えてるよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1604216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あはぁっ、暴れてるっ！　チ〇ポが、狭いマ〇コの中で暴れまわって、マ〇\nコをごりごり抉ってくる……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1604217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「いいねっ、肉バイブとしては上等だよ！　このまま、最後に射精しちまいな\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1604218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あんたの情けない顔を見ながら、あたちも……あたちも、イかせてもらうか\nらさぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1604219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ほら、ほら……っ！　んんっ、イきなっ、思いっきり、無様な顔であたちに\n中出ししちまいなぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1604220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あはぁあああぁぁぁああぁぁあぁ～～～～っ！！　いっ、イクッ、イッくぅ\nうううぅぅぅううぅぅ～～～～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1604301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000316_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁ……っ！　でてるっ、またたくさん、ザーメン中出しぃ……！\n　んんっ、くふぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1604302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「いい……すごくいい……っ！　熱いザーメンが、子宮を撃ちぬいてくる……\n！　んっ、ああ……たまらないねぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1604303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「はぁ……ほらごらんよ……。チ〇ポだけじゃなく、あんたの精液でもあたち\nの腹が膨れて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1604304" ]},
		{"command":[ "SETIMAGE", "0", "still_00000316_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ぼっこり、まるで妊娠したみたいになってるじゃないか……。んっ、んくぅ\n……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1604305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「こんなに中にだして……。この身体じゃなかったら、確実に孕まされていた\nだろうねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1604306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「……え、中身はそのままだから妊娠するんじゃないかって？　バカ言うんじ\nゃないよ、そんなわけないだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1604307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「でも……もし本当に孕んじまったら、あんたにはしっかりと責任を取っても\nらわないといけないねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1604308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「まあ、そのときのことは後で考えるとして、あんたにはまだまだつきあって\nもらうよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1604309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「当然だろう？　あたちはまだまだ満足してないんだ。くくっ、大人なんだか\nら、しっかりこどもの面倒をみるんだね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1604310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ああぁっ！　んっ、勢い余ってチ〇ポが……っ！　んんっ、あっ、あああぁ\nぁぁ～～～～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1604401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000316_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「せ、精液がっ、すごい勢いでとびだして……っ！　ああ、もう全身ベトベト\nになっちゃう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1604402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁっ、くっさいザーメンまみれ……。まさかこんなに射精するな\nんてねぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1604403" ]},
		{"command":[ "SETIMAGE", "0", "still_00000316_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「……まだおさまらないのかい？　チ〇ポがビクンビクン跳ねながら、まだザ\nーメンを吐きだし続けているじゃないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1604404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「こんなに大量のザーメンを中出しされていたら、あたちの子宮が破裂しちま\nったかもしれないねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1604405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「……さて、なに呆けてるんだい？　チ〇ポはまだ萎えてないんだから、もっ\nとできるだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1604406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「さっきも言ったとおり、いまのあたちは体力が有り余ってるんだよ。暴れた\nくてしかたがないのさ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1604407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「いつも通り、あんたをそのはけ口にしてるだけなんだから。ほら、あんたに\n拒否権はないよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1604408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ほら、ザーメンまみれでドロドロのチ〇ポを、またあたちのマ〇コでしごい\nてやるからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1604409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「こんな身体に欲情する変態にはお似合いの仕事さ。あたちが満足するまでチ\n〇ポ萎えさせるんじゃないよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1604410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}