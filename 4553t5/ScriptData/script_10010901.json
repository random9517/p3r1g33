{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0074" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "現場監督" ]},
		{"command":[ "SETTEXT", "「はーい、お疲れさまー。そろそろ時間なんで、撤収にかかってー」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "工事のお兄さんＡ" ]},
		{"command":[ "SETTEXT", "「お疲れさまっすー。ほむらのアネキもお疲れさまっしたー」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「うーっす。ほんじゃ、あたしはこれでー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020109010001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テロップ" ]},
		{"command":[ "SETTEXT", "「極道會系Ω組客分・赤塚ほむら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_999_980109010002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "工事のお兄さんＢ" ]},
		{"command":[ "SETTEXT", "「アネキ、これから居酒屋のほうっすか？　バイトかけもちとか、大変ですよ\nねー」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETIMAGE", "0", "sbg_0075" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「わはははは！　鍛え方が違うって、鍛え方がよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020109010002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「それにほら、この時期になると居酒屋のほうは、お七姐さん――じゃねえ、\n社長さんがさ、宴会で使ってくれるじゃん？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020109010003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "工事のお兄さんＡ" ]},
		{"command":[ "SETTEXT", "「ああ、親睦会とかって言ってましたね」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「まあ、そんなもんだ。とにかく、それのおかげで居酒屋は売り上げ大幅アッ\nプだからさ、ボーナスが出るんだよ！　ボーナスが！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020109010004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "工事のお兄さんＢ" ]},
		{"command":[ "SETTEXT", "「へえ！　このご時世に景気のいい話っすねえ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「へへへっ、こっちはそれが楽しみで、あの店ではたらいてるようなもんだか\nらな！　それじゃ、お疲れー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020109010005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0027" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「レッドを務めていた戦隊から追い出されて以来、Ω（オメガ）組に客分とし\nて身を寄せ、その表の顔である雄雌牙建設でアルバイトをしていたほむらであ\nったが――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_990109010001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「たばこ代の値上げなどによる深刻な生活費不足から、夜は居酒屋・正義でも\nバイトをするダブルワーク生活を余儀なくされていた」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_990109010002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0116" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_019" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ういーっす、こんちゃーっす。マスター、今日もよろしくー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020109010006" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「……ん？　マスター？　どしたー？　いるんだろ？　おーい、マスター？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020109010007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスター" ]},
		{"command":[ "SETTEXT", "「ううううう……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「おい！？　マスター！？　どうしたんだマスター！　しっかりしろぉーっ！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020109010008" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "bg_0141" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_011" ]},
		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「マスターの入院により、居酒屋・正義（まさよし）は当面の休業を余儀なく\nされる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_990109010003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「それは取りも直さず、悪の組織の互助組合である九姉妹（ナインシスターズ\n）の親睦会が、開催見直しを余儀なくされることを意味していた」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_990109010004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「事態を重く見た親睦会幹事、血桜（ちざくら）お七は、ただちに緊急会議を\n招集する」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_990109010005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「皆様、お忙しいところお集まりいただきまして、まことにありがとうござい\nます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010109010001" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「正義（まさよし）が臨時休業アルか……あのお店が使えないとなると、親睦\n会はどこで開けばいいネ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_038_010109010001" ]},
		{"command":[ "SETCHARA", "0", "char_00003801_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「あの店こそは正義の味方と悪の組織、対立する組織同士、その全てを受け入\nれる中立地帯であったのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_046_010109010001" ]},
		{"command":[ "SETCHARA", "0", "char_00004601_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「下手なお店で妥協すれば、九姉妹（ナインシスターズ）加盟組織の均衡が崩\nれ、ひいてはＥＤＯとの共闘体制が崩れることにもなりかねません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_043_010109010001" ]},
		{"command":[ "SETCHARA", "0", "char_00004301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「つまりこれは多元宇宙全体の危機でもある、ということじゃな。お七よ。幹\n事としてこの事態、どう収拾するつもりなのじゃ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010109010001" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「ふっ……ふふふふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010109010002" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「あら……？　その笑い、よほどの秘策があると見ました。ぜひともお聞かせ\nいただきたいですわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_043_010109010002" ]},
		{"command":[ "SETCHARA", "0", "char_00004301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「ご心配なく。はばかりながらこのお七、会場変更ぐらいでうろたえるような\nネンネじゃあございません。すでに第二候補が用意してござんす」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010109010003" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「おお……！　さすがは九姉妹（ナインシスターズ）随一の宴会部長とうたわ\nれた血桜（ちざくら）お七！　ぬかりがないのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010109010002" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「して、その第二候補とは？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_046_010109010002" ]},
		{"command":[ "SETCHARA", "0", "char_00004601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「その候補とは……『串焼き専門店・鳥Ω（おめが）　九重駅前総本店』！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010109010004" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「鳥……Ω（オメガ）……！？　ちょっと待ちなさい、ちょっと！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_043_010109010003" ]},
		{"command":[ "SETCHARA", "0", "char_00004301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「なにか問題でも？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010109010005" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「なにかどころではありませんわ！　問題おおありです！　そこはこの前、あ\nなたの組織が開業した居酒屋チェーンではありませんか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_043_010109010004" ]},
		{"command":[ "SETCHARA", "0", "char_00004301_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「もちろんです。急な会場変更ですからねえ。よく知っている自分の店にお連\nれするのが一番でしょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010109010006" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「んなこと言って！　自分の店の売り上げアップが目的じゃないアルか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_038_010109010002" ]},
		{"command":[ "SETCHARA", "0", "char_00003801_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「なにぃ……？　それは聞き捨てならないねえ！　私がそんなセコいことをす\nるとでも思ってんのかい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010109010007" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「おお、セコいアル！　ずるいアルぞ！　それだったら、ウチの中華料理店を\n会場にするべきナイか！？　おいしくて安くてボリューム満点ネ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_038_010109010003" ]},
		{"command":[ "SETCHARA", "0", "char_00003801_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「あら。それだったら我が魔女組合のワインバーでもかまわないはずですわよ\nね？　ご予算おひとり４０００円の範囲内でも、充分満足させてあげますわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_043_010109010005" ]},
		{"command":[ "SETCHARA", "0", "char_00004301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「我ら獣人協会の自然食レストランを無視する気か！？　自家製果実酒と無農\n薬野菜の宴会コースは伊達ではないぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_046_010109010003" ]},
		{"command":[ "SETCHARA", "0", "char_00004601_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「じゃかましいわ！　ウチの店でやるっちゅうたらウチでやるんじゃい！　な\nんぞ文句でもあるんかゴラァ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010109010008" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「幹事だからって、そんなゴリ押しが通るとでも思ってるアルか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_038_010109010004" ]},
		{"command":[ "SETCHARA", "0", "char_00003801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「あー！　もうお前らうっさいわ！　投票にせい、投票に！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010109010003" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「協議の末、会場は加盟９組織代表による無記名投票で選ばれることとなった\nが、その結果――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_990109010006" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「棄権したグレート・ルナリアムを除く８組織全てが自分たちの経営する店に\n投票し、会議は決裂したのであった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_990109010007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "bg_0029" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
		{"command":[ "SETNAME", "Ω（オメガ）組客引き" ]},
		{"command":[ "SETTEXT", "「居酒屋いかがっすか！　すぐご案内できますよー！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "客引き魔女" ]},
		{"command":[ "SETTEXT", "「いえいえ、こちらのワインバー『ぐりもあ屋』へどうぞー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_010109010001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "客引き獣人" ]},
		{"command":[ "SETTEXT", "「今や、お酒を飲むにも健康を考える時代！　自然食バル『人狼畑（じんろう\nばたけ）』でごゆっくりどうぞー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_020109010001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「かくして組織間の均衡は破れ、８組織は熾烈な営業合戦を繰り広げることと\nなったのである」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_990109010008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんか、最近このあたり、妙に客引きが増えたなあ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「カツマ、早く戻ろう。長官に報告書を出さないと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010109010001" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ω（オメガ）組客引き" ]},
		{"command":[ "SETTEXT", "「あ！　そこのお二人！　どうですか？　カップルで一杯！　お安くしときま\nすよ！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「カ、カ、カップル……！　カツマ！　入ろう！　このお店入ろうっ！　……\n二人で」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010109010002" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "2", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「って、仕事どーすんだ！　カグヤらしくねえな、仕事中にいきなり酒飲もう\nとか！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "客引き魔女" ]},
		{"command":[ "SETTEXT", "「そちらご夫婦ですかー！？　うちのお店、ご夫婦割引やってますよー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_010109010002" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
