{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0025" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「ルルーナさんチーム、グレーテルさんチーム、撃破！　シミュレーションを\n停止します！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_072_010113350001" ]},
		{"command":[ "SETCHARA", "0", "char_00007201_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "怪獣戦車にまたやられ、仮想空間から出てきてみると……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うわあああああああっ！　また壊されたぁっ！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「やっぱり負けちゃうと壊されちゃうのね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020113350001" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「ううううう……せっかく寝ないで作ったのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113350001" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「寝ないで作ったのは俺ですって！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「申し訳ありません……またこんなことになってしまいまして」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_072_010113350002" ]},
		{"command":[ "SETCHARA", "0", "char_00007201_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "さすがのミス・パープルもしゅん、となっている。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「よく考えてみれば、チャーフィーは軽戦車ですからね……怪獣相手には力不\n足だったのかも知れません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020113350001" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "4", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そういうことは、作らせる前に考えてくれよ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "っていうか『怪獣映画によく出る』って時点で嫌な予感がしてたんだ！", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「まあまあ、そう気を落とさないで。キミたちの努力は無駄じゃないぞ！　実\nに面白いことがわかった！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020113350001" ]},
		{"command":[ "SETCHARA", "0", "char_00002202_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ほほう？　面白いこととは？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113350001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「プラモデルがこうなってしまう原因さ。これは間違いなく、コンピューター\nウイルスの仕業だね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020113350002" ]},
		{"command":[ "SETCHARA", "0", "char_00002202_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「ウイルス……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_020113350001" ]},
		{"command":[ "SETCHARA", "0", "char_00001802_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「それもボクの見たところ、地球の技術じゃない。ミス・パープルと同等の技\n術力をもった、異次元の連中。つまり――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020113350003" ]},
		{"command":[ "SETCHARA", "0", "char_00002202_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「襲来者（インベーダー）ですか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020113350002" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「あいつらが私のプラモデルを……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113350002" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「そういうことになるね。いや、しかしホントに面白い挙動をするウイルスだ\nな。ミス・パープルにいきなり呼び出された甲斐があるな、これは」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020113350004" ]},
		{"command":[ "SETCHARA", "0", "char_00002202_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「退治できるのか？　そのウイルス」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「たぶんね。でも、そのためにはどうにかして、あの怪獣戦車をやっつけなき\nゃならない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020113350005" ]},
		{"command":[ "SETCHARA", "0", "char_00002202_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「結局そうなるのか……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「皆さん、お願いします！　怪獣戦車を倒してください！　かかった費用はお\n支払いしますので！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_072_010113350003" ]},
		{"command":[ "SETCHARA", "0", "char_00007201_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「いいわよ！　私たちにまかせなさーい！　ねっ！　カツマ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020113350002" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まあ……襲来者（インベーダー）が相手じゃ、放っておくわけにもいかない\nからな。でもなぁ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「でも？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020113350003" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「並みのプラモじゃ、あいつに勝てないぞ？　どうする？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「並みのプラモじゃ……勝てない？　そうか……！　そうだわ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113350003" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「どうしたの？　ルルーナさん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130113350001" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「並みのプラモで勝てないんなら、並みじゃないプラモを作ればいいのよ！　\nそれがいいわ！　そうしましょう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113350004" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「並みじゃないプラモって……具体的にどんな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_020113350002" ]},
		{"command":[ "SETCHARA", "0", "char_00001802_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「それは、これからみんなで考えるの！　大丈夫！　なにかいい方法を思いつ\nくわよ！　だって――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113350005" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「戦車のプラモは、どんな自由な発想で作ってもいいんだもの！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113350006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "いいのか！？", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0149" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "そして、その日の夜も……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「カツマ！　流々那の言っていたプラモデルと、改造用の材料！　買ってきた\nわね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113350007" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はいはい。今度はこれっすね。Ｍ４シャーマン……これは俺も聞いたことが\nあるな。こいつを３つ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "みんと" ]},
		{"command":[ "SETTEXT", "「１両は私たちのチーム用、ということですね。これで戦うんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_020113350001" ]},
		{"command":[ "SETCHARA", "0", "char_00001502_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "いつの間にかみんとが来ている。夜日楽と流々那が仲間に引き込んだらしい。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「はい。Ｍ４ならＭ２４より大きいですし、怪獣映画への出演経験でも負けて\nいません。なんとかなるのではないかと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130113350002" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……怪獣映画からは離れたほうがよくないか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「それより、材料のほうは？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113350008" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「えーと、プラ板、パテ、瞬間接着剤に、釣り用のおもり、その他もろもろ…\n…こんな感じでいいスかね」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "けっこう金はかかったけど領収書は取ってあるし、あとでミス・パープルに清\n算してもらえばいいや。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「ええ、いいわ。この材料を使って、プラモデルをとにかく重く、頑丈に作る\nの！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113350009" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「そうすればシミュレーションマシンはその戦車を、とても丈夫で硬い車体だ\nと判断してくれる。……そういう話だったわね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_020113350003" ]},
		{"command":[ "SETCHARA", "0", "char_00001802_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「そうよ！　戦車をとにかく硬く作って、怪獣戦車の攻撃を防ぐ！　名付けて\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113350010" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「バリカタ作戦です！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113350011" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ぶふっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020113350004" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "作戦名を聞いて、マーガレットが吹き出した。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「バリカタ……！　バリカタ！　あはははははははっ！　ラーメンみたいっ！\n　ラーメン！　あははははははは！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020113350005" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「な、なによ！　文句あるの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113350012" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「文句ないっ！　いいわね！　最高！　その作戦名大好き！　気に入っちゃっ\nた！　ルルーナ、センスあるじゃない！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020113350006" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「センス……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「あるんでしょうか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020113350003" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "思わず夜日楽と俺は顔を見合わせる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「……そっとしておきましょ。とにかく、プラモデルを作らないと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_050113350001" ]},
		{"command":[ "SETCHARA", "0", "char_00000204_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「深夜に友達の部屋に集まって、みんなでプラモデルづくり！　いいな！　実\nに青春している！　学生らしくていいぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_020113350001" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「な！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「誰！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_050113350002" ]},
		{"command":[ "SETCHARA", "0", "char_00000204_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「何者！？　姿を表しなさい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113350013" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「ひとーつ、人の世悪行三昧。ふたーつ不埒な悪行三昧。みっつ、醜い悪行三\n昧……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_020113350002" ]},
		{"command":[ "SETCHARA", "0", "char_00000702_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「悪行三昧しかしてねえじゃねえか！　っていうかあんた……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「悪の女幹部たちの友情を信じる女！　ベルガマスクッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_020113350003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「またあんたかよ！　なにしに来たんだよ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「いやぁ～。たまにはなにかアドバイスを、と思ってきてみたんだが。プラモ\nデルか！　私も昔はずいぶんと作ったもんだぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_020113350004" ]},
		{"command":[ "SETCHARA", "0", "char_00000702_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「は、はあ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020113350004" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「当時人気だった、ロボットアニメのプラモデルがなかなか買えなくてな。入\n荷する日の当日、模型屋の前で朝早くから並んだり！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_020113350005" ]},
		{"command":[ "SETCHARA", "0", "char_00000702_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「誰もそんなこと聞いてない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_050113350003" ]},
		{"command":[ "SETCHARA", "0", "char_00000204_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「でもって、ようやく買える！　と思ったら、売れ残った『そば屋』とか『ゼ\nンマイで歩くラジカセ』とかと抱き合わせで買わされたりな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_020113350006" ]},
		{"command":[ "SETCHARA", "0", "char_00000702_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「それはそれは」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113350002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「で、抱き合わされたロボット自体も、不人気な敵側の支援メカだったり、も\nっとひどいときは『武装セット』だったりしたんだぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_020113350007" ]},
		{"command":[ "SETCHARA", "0", "char_00000702_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……なんなんだ、あんた。思い出話をしにきたのか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「なにか、アドバイスがありますの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113350014" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「うむ！　よいかルルーナ！　ロボットの肩は、まず『ハ』の字に切ってから\n接着するのだ！　ぐっとスタイルがよく見える！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_020113350008" ]},
		{"command":[ "SETCHARA", "0", "char_00000702_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ふむ」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "8", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113350003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「また、商品によっては足首が動かないのもあるが、これは別のキットから足\n首の関節を移植することで……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000702_01", "8", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_007_020113350009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、足首とか肩とか言われてもな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「私たちが作ってるの、ロボットじゃなくて戦車なんだけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_050113350004" ]},
		{"command":[ "SETCHARA", "0", "char_00000204_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「え……？　あ、ほんとだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_020113350010" ]},
		{"command":[ "SETCHARA", "0", "char_00000702_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「なにか、戦車のプラモデルに役立つ話はないの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_020113350004" ]},
		{"command":[ "SETCHARA", "0", "char_00001802_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_020113350011" ]},
		{"command":[ "SETCHARA", "0", "char_00000702_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「……ないの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_020113350005" ]},
		{"command":[ "SETCHARA", "0", "char_00001802_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「で、では、さらばだ！　プラモ制作を楽しむがいい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_020113350012" ]},
		{"command":[ "SETCHARA", "0", "char_00000702_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「あ！　逃げた！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020113350007" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "みんと" ]},
		{"command":[ "SETTEXT", "「なにしに来たんですか、あの人は！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_020113350002" ]},
		{"command":[ "SETCHARA", "0", "char_00001502_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「ベルガマスク……いったい何者なの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113350015" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「声はどこかで聞いたことがあるような……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_050113350005" ]},
		{"command":[ "SETCHARA", "0", "char_00000204_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……まあ、いいや。とにかくプラモ作ろうぜ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0022" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SETTEXT", "そして、また翌日。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「ふふふふふ、パテとプラ板とその他もろもろでガッチリ固めた戦車……これ\nなら勝てるわ！　『バリカタ作戦』発動よ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113350016" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「シャーマン１号よりシャーマン２号！　聞こえるか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ウッキー！　聞こえるわ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020113350008" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あたりをしっかり見張って、怪獣戦車が出て来たらすぐ知らせてくれ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「りょーかいよ！　今日こそやっつけるわ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020113350009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「１号よりシャー子！　そっちも聞こえてるな？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "みんと" ]},
		{"command":[ "SETTEXT", "「聞こえてます。聞こえてますけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_020113350003" ]},
		{"command":[ "SETCHARA", "0", "char_00001502_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "みんと" ]},
		{"command":[ "SETTEXT", "「なんで私たちだけシャー『子』なんですかーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_020113350004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「３号ですので、仕方ありませんな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113350004" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああ。３号だからな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "みんと" ]},
		{"command":[ "SETTEXT", "「わけがわかりませんよっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_020113350005" ]},
		{"command":[ "SETCHARA", "0", "char_00001502_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「怪獣戦車発見！　正面から来る！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_050113350006" ]},
		{"command":[ "SETCHARA", "0", "char_00000204_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「来るぞ！　全車、戦闘用意！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "みんと" ]},
		{"command":[ "SETTEXT", "「ちょっとーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_020113350006" ]},
		{"command":[ "SETCHARA", "0", "char_00001502_01", "3", "CENTER", "0" ]},
