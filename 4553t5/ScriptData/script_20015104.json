{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0046" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_007" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「こうなったら、先手必勝です！　カグヤさん、戦いましょう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010023390001" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「……もちろん、そのつもり」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010023390001" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「フフ。この私に挑んでくるとは。力量の差を感じとることができないのかし\nら？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_010023390001" ]},
		{"command":[ "SETCHARA", "0", "char_00017302_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「これは正当防衛ですよね？　であれば……仕方ありません！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_010023390001" ]},
		{"command":[ "SETCHARA", "0", "char_00017202_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おいおいおいおい、やめろって！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「皆さん、ご主人の声なぞまったく聞こえていないようですぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023390001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "メイド服になってから、すっかり忘れてしまっていたが……元々、エルフたち\nは聖騎士団の騎士なのだ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「ご主人様は渡さない！　はぁああああああッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_010023390002" ]},
		{"command":[ "SETCHARA", "0", "char_00017302_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "バイオリンを奏で、そこから強烈な雷を放つディーネリンド。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "その激しい稲妻をかわしながら、カグヤは手裏剣をいくつも同時に撃ちこんだ\n。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「……この程度の攻撃なんか効かない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010023390002" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「奇遇ね。それはこちらも同じことだわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_010023390003" ]},
		{"command":[ "SETCHARA", "0", "char_00017302_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "キィイイイイン……！", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "ディーネリンドが演奏方法を変えると、目に見えない音の衝撃が広がり……全\nての手裏剣が跳ね返され、カグヤの顔すれすれを通過する。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「……なるほど。それなりの腕はあるみたい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010023390003" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「聖エルフ騎士団の軍楽隊に、敗北は許されないわ。あなたたちには消えても\nらいます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_010023390004" ]},
		{"command":[ "SETCHARA", "0", "char_00017302_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「それは、こっちの台詞だから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010023390004" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「大変なことになっちまったぞ……！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "間に入ったりしたら、絶対に二人の攻撃を同時に食らう。", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "7", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "1", "char_00017302_01", "7", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "それはごめんだと考えている俺の後ろで、ジュンジローがワンワンと吠えた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人！　こちらも険悪なムードですぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023390002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うあっ！　おとなしそうなアイナリンドとまりあまで！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「……あなたたちには何の恨みもありませんが。大切なご主人様を奪われない\nためです、辛抱してください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_010023390002" ]},
		{"command":[ "SETCHARA", "0", "char_00017202_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「敵陣では、ブレイン……。頭脳を担当する方を潰すのが定石です。ゆえに私\nはあなたと戦いたく思います」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_010023390003" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「っ……！　私を狙っているんですか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010023390002" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「当然です。あなたはとても賢そうな方。私達の味方だったら、どんなに心強\nいことでしょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_010023390004" ]},
		{"command":[ "SETCHARA", "0", "char_00017202_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「でも、敵であれば一番厄介なのもあなた。そうですよね？　ですから、見逃\nすことはできません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_010023390005" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「こ、困りました。私には、直接戦闘をする力が……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010023390003" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「……じゃあ、私はあなたにつこっかな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_010023390001" ]},
		{"command":[ "SETCHARA", "0", "char_00027101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "さっ、とまりあのそばに移動したラヴリエータは、可愛くウインクしてみせる\n。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「助けてあげるよ。ま、私で役に立つかはわかんないけど！　あはははっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_010023390002" ]},
		{"command":[ "SETCHARA", "0", "char_00027101_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「えっ！？　あなたもエルフさんのはずなのに？　どうして？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010023390004" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「あなたたち……。何か事情があってここに来たんですよね？　だったら私は\nその事情が知りたいです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_010023390003" ]},
		{"command":[ "SETCHARA", "0", "char_00027101_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「でも、そのためには……興奮している先輩たちを止めないと……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_010023390004" ]},
		{"command":[ "SETCHARA", "0", "char_00027101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「ディ、ディーネ先輩！　この人達、悪い人達じゃなさそうじゃないですか！\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_010023390005" ]},
		{"command":[ "SETCHARA", "0", "char_00027101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「少しだけ、お話を聞いてあげることって出来ないですかねぇ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_010023390006" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「先に刃を向けたのはあちらです。問答無用！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_010023390005" ]},
		{"command":[ "SETCHARA", "0", "char_00017302_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「私たちには、ご主人様……。カツマさんが必要なんです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_010023390006" ]},
		{"command":[ "SETCHARA", "0", "char_00017202_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「うぅ～ん、こりゃあ聞く耳無しモードっぽいですねぇ～。どーしましょお」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_010023390007" ]},
		{"command":[ "SETCHARA", "0", "char_00027101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「な、何か策があるわけではないんですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010023390005" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「さあ。ご相談は終わりましたか？　それではこちらから、仕掛けさせていた\nだきます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_010023390007" ]},
		{"command":[ "SETCHARA", "0", "char_00017202_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "スッ、とアイナリンドが自らの武器であるフルートを唇に当てる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "と、ラヴリエータは慣れたものなのか、やれやれとため息をついてまりあに向\nき直った。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「……先輩たち、完全に頭に血がのぼってるっぽいですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_010023390008" ]},
		{"command":[ "SETCHARA", "0", "char_00027101_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「あの。出会ったばっかで信用とか難しいかもしれないんですけど！　私を信\nじて任せてもらえませんか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_010023390009" ]},
		{"command":[ "SETCHARA", "0", "char_00027101_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「いい案があるんです、あなたを守って、先輩たちを止められる……たった一\nつの手が！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_010023390010" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "キラリと瞳を輝かせるラヴリエータに、まりあがこくこくとうなずいているの\nが見えた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「何をする気かわからんが、やらせてみるか……！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}