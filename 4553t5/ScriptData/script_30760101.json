{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「来たよ、隊長さん。なんの用か知らないけど、できれば手短にお願いね。私\nもう疲れちゃってさぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0103101" ]},
		{"command":[ "SETCHARA", "0", "char_00007601_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「時間がかかるかどうかは私次第って、どういう事？　あぁ、ふふ……ははーん。\nんー、なるほどねー。隊長さんとエッチなことすればいいんだー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0103102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「まあ、そういうことだったら付き合ってあげてもいいかな……って、なに、\n隊長さん。もしかして意外って思ってない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0103103" ]},
		{"command":[ "SETCHARA", "0", "char_00007601_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「それに、隊長さんとエッチなことするとパワーアップできちゃうんでしょ？\n　お姉ちゃんから聞いたよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0103104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「私、燃費が悪くて変身時間がお姉ちゃんより短いんだよね。そういう問題を\n解消できるかも」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0103105" ]},
		{"command":[ "SETCHARA", "0", "char_00007601_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「それじゃあさっそく……。ん、お口でして欲しいの？　隊長さんのおちんぽ\nを舐めればいいんだね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0103106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00007601_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「ん……。もうおっきくなってる……。すごい、こんなに勃起しちゃってるお\nちんぽ初めて見たよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0103107" ]},
		{"command":[ "SETIMAGE", "0", "still_00007601_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「ギンギンだね……。私たちの戦闘スーツを見ながら、いつもいやらしいこと\n考えていたんじゃないの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「んふふっ、まあ、男の人は仕方ないよねー……。じゃあ、お姉ちゃんにも負\nけないお口テク、味わわせてあげるねー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「ん……ぅ……れろぉ……。舌を……いっぱい使って……おちんぽを……舐め\nて……ぇ……。んれろ……れろぉ……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0103110" ]},
		{"command":[ "SETIMAGE", "0", "still_00007601_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「ぺろ……ぺろぺろ……べろぉ……っ！　隊長さんのおちんぽ、なんだかすっ\nごくしょっぱい味する……ちゃんと洗ってる……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0103111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「もしかして……れろ、れろ……。私におちんぽ洗わせるつもりだった……？\n　んちゅっ、女の子にこんなことさせるなんて、変態……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0103112" ]},
		{"command":[ "SETIMAGE", "0", "still_00007601_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「んふぅ……ちゅぷっ、べろぉ……。んまっ、おちんぽの匂い嫌いじゃないし\n……いいけどね……んっ、んちゅ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「れろ、れろぉ……。どう……隊長さん……？　んちゅっ、ここ……裏筋……\n舌でくすぐられるのとかぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0103114" ]},
		{"command":[ "SETIMAGE", "0", "still_00007601_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「ちゅぶっ、エラの部分……んちゅっ、んちゅ……っ。いっぱい、ちゅっ、ち\nゅっ、吸い付かれるの……とかぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0103115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「んっ、どんどんよだれまみれになっていくね。隊長さんのおちんぽ……。ん\nちゅぅ……ほらぁ……竿のところもぬるぬるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「んふふっ、どうかな、隊長さん？　おちんぽ……んちゅっ、いっぱい舐めま\nわされて、気持ちいい……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「隊長さんのおちんぽ、私の手の中でびくんびくん跳ねちゃってるよ……？　\nんちゅっ、ちゅっ、反応、かわいいなぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「なんだか、私もエンジンかかってきたかも……。おちんぽ舐めながら……す\nごく、興奮してきた……んふふ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0103119" ]},
		{"command":[ "SETIMAGE", "0", "still_00007601_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「隊長さんのこと、もっと気持ちよくしたくなってきちゃったよ……。ねえね\nえ、舐めてるだけじゃなくて、こういうのは……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「隊長さんの、パンパンに膨らんだ亀頭を……ぁ……むっ♪　んふふぅ……咥\nえちゃったぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「んふぅ……♪　んむぅ……♪　熱いね……口の中、火傷しちゃいそうだよぉ\n……んぢゅっ、ぢゅるるぅ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「ぢゅぶっ、んっ、んっ、んぢゅるっ！　じゅぶじゅぶっ、ンンッ、んふぅ…\n…じゅるるるぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0103123" ]},
		{"command":[ "SETIMAGE", "0", "still_00007601_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「口の中……じゅぷっ、よだれで、いっぱい……。んっ、んっ、ちゅるるっ！\n　じゅぶっ、じゅぶっ、じゅぶ……っ、んふぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「おちんぽ……んっ、膨らんで……んじゅるぅっ！　じゅぶっ、じゅぶ……っ\n！　それに、熱い……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「隊長さん、すっごく興奮しちゃってるみたいだね……。んじゅるるっ、おち\nんぽから、いやらしい味がしてきたよ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0103126" ]},
		{"command":[ "SETIMAGE", "0", "still_00007601_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「んっ、んっ、じゅるじゅるじゅるぅっ！　カウパー……んぢゅるっ、これ…\n…好きだよ……んふ……んふふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「なに……？　へぇ、もっと激しくしゃぶって欲しいんだ……。隊長さんのリ\nクエストなら、応えようかなー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0103128" ]},
		{"command":[ "SETIMAGE", "0", "still_00007601_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「んじゅるるっ、んっ、んっ、じゅぶっ、じゅっる……っ！　こう……？　じ\nゅるるるつ、んっ、んっ、んん……んじゅる……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0103129" ]},
		{"command":[ "SETIMAGE", "0", "still_00007601_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「竿……ぶぢゅっ！　しごき、ながらぁ……っ。ぢゅっぷ！　ぢゅっぷっ！　\nおちんぽに、吸い……付いて……ぇ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「んふぅっ、じゅるっ、じゅるっ、じゅぶじゅぶぅっ！　んっ、んっ、んっ、\nんじゅるっ、じゅぶじゅぶぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「んんんぅっ！　じゅるっ、じゅるっ、じゅるるぅううっ！　んっ、んんぅっ\n！？　んぐぅううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0103132" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00007601_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「んぐぅ……っ！　ちょ、ちょっとぉ……。隊長さんったらいきなり射精した\nでしょ……もぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0103133" ]},
		{"command":[ "SETIMAGE", "0", "still_00007601_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「射精するときは言ってくれないと、ちゃんと全部飲み干せないよー。ちょっ\nとこぼしちゃった。じゅるっ、もったいないなぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「んちゅっ、なに……？　それなら、もう一回するかって？　んー、そうだな\nー、隊長さんのおちんぽ次第……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0103135" ]},
		{"command":[ "SETIMAGE", "0", "still_00007601_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「……って、全然萎えてないし。ふふーん、まだまだ私にエッチなことさせた\nいんだねー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0103136" ]},
		{"command":[ "SETIMAGE", "0", "still_00007601_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「ぱぱーっと終わらせたいところだったけど、勃起したおちんぽ見せられたま\nま引き下がれないかな。正義の味方としては」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0103137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「ふふ、お姉ちゃんだって、こんなおちんぽを見たら放っておかないと思うよ\n、隊長さん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0103138" ]},
		{"command":[ "SETIMAGE", "0", "still_00007601_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「まだまだ、私のお口で精液を搾りだして欲しいってことだよね？　うんうん\n、わかってるわかってる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「ん？　急にノリノリになってきたみたいって？　お姉ちゃんと違って、私は\nスロースターターなんだー♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「んっふぅ、ちゅぶ、ちゅぶぅ……ちゅるる……。まだまだ、こんなにおっき\nいなんて……すっごいね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0103201" ]},
		{"command":[ "SETIMAGE", "0", "still_00007601_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「んじゅちゅちゅっ！　んん……。隊長さんのおちんぽ……んっ、もっともっ\nと、しゃぶっていたいな……んじゅるるっ、んぢゅぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「ちゅぶっ、我慢しなくていいんだよ、隊長さん……。んふふっ、ほらほら、\nよだれと精液まみれのおちんぽ、しこしこしこ～……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0103203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「根元をしこしこしながら、先っぽを舌でぺろぺろ～ってして～……。んふふ\n、隊長さん、気持ちいいでしょ、これ……んちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0103204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「一度射精したあとだから、おちんぽ、感じやすくなっちゃってるんだ……ん\nちゅっ、ちゅぱっ。じゃあ……もっと感じて……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「んふぅ……。あむぅ……。また、咥えて……んじゅるっ、じゅぽじゅぽって\n……お口で……してあげるね……んじゅるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「じゅぶっ、じゅぶっ！　じゅぶじゅぶぅっ！　ンンッ！　口の中のおちんぽ\n……また、ビクビクして……きたぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0103207" ]},
		{"command":[ "SETIMAGE", "0", "still_00007601_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「おちんぽが膨らんで……んぐっ、口の中で暴れて、また……射精したがって\nる……んっ、んっ、んん……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「んじゅるるっ、じゅぶじゅぶぅっ！　ま、また……射精したく、なってきち\nゃったんだね……じゅぷじゅぷっ、じゅるるるるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「んふふぅ、いいよ……隊長さんの精液、また……いっぱい射精して欲しいか\nら……んぢゅっ、んぢゅぢゅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0103210" ]},
		{"command":[ "SETIMAGE", "0", "still_00007601_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「たっぷり射精できるように、じゅぶじゅぶっ！　おちんぽから……ぢゅるる\nっ、吸い出して、あげる……ぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「お口の中で、おちんぽが暴れてる……んっ、んんっ！　隊長さんの腰も、浮\nいちゃって……ンッ、かわいい、反応……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「んんっ、また……カウパーが溢れてきた……んちゅるっ、ちゅるちゅるぅ…\n…っ！　んっ、んん……ぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「美味しいよ……隊長さん……。じゅるっ、じゅるるぅ……っ！　んふっ、ど\nんどん、カウパーが溢れてきてるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0103214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「なに？　正義の味方がそんなエロ顔でフェラしていいのかって？　んー、い\nいでしょ。気持ちいいことは正義だよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0103215" ]},
		{"command":[ "SETIMAGE", "0", "still_00007601_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「だから、隊長さんも思いっきり気持ちよくなっちゃえって。んじゅるるっ、\nじゅぶじゅぶっ、じゅちゅちゅぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0103216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「んふぅっ、もう限界が来そうだね……おちんぽのびくんびくんがだんだん大\nきくなってきた……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0103217" ]},
		{"command":[ "SETIMAGE", "0", "still_00007601_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「おちんぽぱんぱーん♪　じゅっぷ、じゅっぷじゅっぷじゅっぷっ！　んふふ\nぅ……ほらほらぁ……だしてだしてぇ～……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0103218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「じゅるるるっ！　んっ、んっ、んっ、んじゅるるぅっ！　んふふぅ……じゅ\nぶじゅぶっ、じゅぢゅぢゅぢゅぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「んっ、んっ、んん……っ、んふぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「んっ、んっ、んんぅうううぅぅぅっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0103301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00007601_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「んぐぅうっ！　また口いっぱいに、隊長の精液ぃ……んっ、んんぅ……っ！\n　んぐ……んぐぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「今度は、こぼさない、ように……んくっ、んくぅ……。全部飲んじゃうね…\n…んっ、ん……んく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0103303" ]},
		{"command":[ "SETIMAGE", "0", "still_00007601_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「すっごい……二度目なのに、こんなに濃いのを出すなんて……。んぐっ、の\nどに、絡みついてくるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0103304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「んくっ、んく……じゅるる……っ！　ほらぁ……おちんぽの中の、残りも…\n…じゅるじゅるぅ……んっ、んんぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0103305" ]},
		{"command":[ "SETIMAGE", "0", "still_00007601_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「んふぅ……はぁ……。全部飲み干しちゃった……。ふふ、すっごく美味しい\n精液だったよ、隊長さん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0103306" ]},
		{"command":[ "SETIMAGE", "0", "still_00007601_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「あれあれ？　やっぱり私がこんな反応したことが納得いかない？　だって、\n私はクロスホワイトの妹だよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0103307" ]},
		{"command":[ "SETIMAGE", "0", "still_00007601_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「んふふつ、普段使ってる剣だけじゃなくて、男の人についてるソッチの剣の\n扱いだって心得ているんだから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0103308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「地方防衛部隊は、まあ、娯楽が少ないからねー。必然的にエッチしかやるこ\nとなくなっちゃうから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「だから隊長さん、今度は私のおまんこ、使ってみて欲しいな……なーんて、\nふふ、気が向いたらね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「んんぅううっ！　た、隊長さんっ、いきなり……ぃ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0103401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00007601_01_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「んぁっ、ああっ、あはぁ……っ！　顔に、どぴゅどぴゅって、精液がかけら\nれてるぅ……つ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「んっ、すっごい匂い……っ！　はぁ、はぁ……べっとべとで、こびりついて\n……離れない……みたいな……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0103403" ]},
		{"command":[ "SETIMAGE", "0", "still_00007601_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「んんっ、まだまだ射精してる！　びゅっくんびゅっくん精液でちゃってる～\nっ！　あっ、ああ……すっごぉ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0103404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「口の中じゃなくて、こんなにかけるなんて……。白く濁ったドロドロで、私\nの方がクロスホワイトになっちゃうよー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0103405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「それにしても、こんなに射精しちゃうくらい気持ちよかったんだね。ふふ、\n頑張ってフェラしてよかったよー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0103406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「んっ、ぺろぺろ……。こんなにねばっこいの、口や顔だけじゃなくてもっと\n別なところでも感じたいかも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0103407" ]},
		{"command":[ "SETIMAGE", "0", "still_00007601_01_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「え？　それってどこかって、そりゃあおまんこに決まってるでしょ！　もう\n、察しが悪いなぁ、隊長さんったら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0103408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「お仕事頑張ったら、今度はエッチもしてくれるって？　ふーん、そういう条\n件なら、私も頑張っちゃおうかなー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0103409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「私はこの剣に。隊長さんはそのおちんぽに誓って、約束だよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0103410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
