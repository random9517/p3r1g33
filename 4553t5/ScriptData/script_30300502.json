		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んぁっ、ふっ……オマ〇コの方も、一突きするごとに……お腹に力を込めて\n……キュンと……オチ〇ポを絞り込んで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0504130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あくっ……今のが気持ちいいですか……？　はい、今の調子で続けさせて頂\nきますね……あっ、あぁっ、はっ、あぁうんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0504131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
