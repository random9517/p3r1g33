		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「こうして足を開くと……オ、オマ〇コが全部見えてしまいますね……あぁ…\n…貴方のオチ〇ポも、もうこんなに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0504107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「すぐに入れる訳ではないのですか……？　最初は、擦り付けるだけ……は、\nはい……んっ、ふっ、こう……でしょうか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0504108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んっ、あぁ……熱いのが入り口をなぞっています……貴方も、こんなに興奮\nされていたんですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0504109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「私も……そうですね、あっ……こうしてみると、とても期待していたのかも\nしれません……あっ、でも……こんなに焦らされたら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0504110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はい……んっ、母乳が出てしまいます……あぁっ……切ないです……おっぱ\nいもその気になってしまいました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0504111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「お願いします……どうか、オチ〇ポを入れることをお許し下さい……潤み切\nったオマ〇コに……ハメさせて下さいませぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0504112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あぁ……ありがとうございます。それでは……失礼致します……んくぅぅぅ\n……あっ、はぁぁぁぁぁぁぁんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0504113" ]},
		{"command":[ "SETIMAGE", "0", "still_00003005_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はぁっ、んっ……！　あぁ……入り、ました……あふぁっ……あっという間\nに奥まで届いて……母乳も……あっ、出ますぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0504114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んく……熱いです……こんな外で、しっかりと性器を繋げてしまうなんて…\n…胸がどうにかなってしまいそうです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0504115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んふっ……私から動かしてよろしいですか？　それでは、腰を使わせていた\nだきますね……あっ、ひっ、はっ、んくぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0504116" ]},
		{"command":[ "SETIMAGE", "0", "still_00003005_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あぉっ……あぁっ、長いオチ〇ポが……子宮口近くまで届いてしまいます…\n…はぁぁっ、中の襞が……伸ばされて参ります……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0504117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「このまま、伸びた襞を擦り上げて……動かして……あひっ、あっ……！　あ\nぁっ、何だか……これっ……あっ、あぉぉっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0504118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あぁ……いつもより、ずっと……感覚が鋭敏になっている気がいたします…\n…これがお祭りの影響なのでしょうか……は、んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0504119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んぁっ、腰を浮かせただけで……くちゅんと……はしたない音がして……お\n汁が後から後から湧き上がって参ります……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0504120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んはぁ……あぁ、いけません……ちゃんとオマ〇コを締め付けて……オチ〇\nポにご奉仕しませんと……んぁっ、くふっ、あ、はぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0504121" ]},
		{"command":[ "SETIMAGE", "0", "still_00003005_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あぁっ……身体が揺れてっ、あっ、あぁっ、母乳が……飛び散ってしまいま\nすっ……はぁんっ、申し訳……あっ、あぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0504122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
