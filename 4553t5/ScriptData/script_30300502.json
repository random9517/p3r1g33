		{"command":[ "PLAYVOICE", "v2_030_0504304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んんっ……！　はい……奥に打ち付けられる感触……堪らないです……あふ\nぅ……これが特別な日のセックスなのですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0504305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はぁ、んっ、あぁ……オチ〇ポ……やっと落ち着きました……はい……お腹\nが新鮮な精液でたぷんとしています……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0504306" ]},
		{"command":[ "SETIMAGE", "0", "still_00003005_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「ええ……いつもしている以上に気持ちよくて……やはり、特別な時だからな\nのでしょうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0504307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
