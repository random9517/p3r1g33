		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あぁっ、はい、ゆったりと……ですが、大きな動きで……あんっ、はぁっ…\n…かき回し、ますぅっ……んくぁぁっ！」", "NORMAL" ]},
