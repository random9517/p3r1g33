		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「……確かに、今の私は……何とも気持ちが高ぶっているような……そんな感\n覚がございます……では、このまま上に跨がれば……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0504105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んっ……前を失礼致します……はい……下着は、言われた通り身につけてお\nりません。それが着付けの習わしなのですよね？」", "NORMAL" ]},
