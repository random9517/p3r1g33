		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「ええと……それで……はい、この木陰で……お祭りの続きを二人で行う……\nこちらでは、そのような習慣があるのですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0504104" ]},
