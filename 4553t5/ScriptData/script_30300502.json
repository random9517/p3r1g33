		{"command":[ "SETIMAGE", "0", "still_00003005_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「もっといやらしくおっぱいを揺らして……あぁっ、こ、こうでしょうかっ？\n　んっ、あっ、あぁ、母乳が飛ぶの……はしたないっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0504209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あぁっ、でも……喜んで頂けるのでしたら、恥ずかしくても……もっと動き\nますわっ……あんっ、はっ、あっ、あぁんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0504210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あっ……んむっ、申し訳ありません……どうしても声が高くなってしまいま\nして……まだどなたかいらっしゃるかも知れませんのに……」", "NORMAL" ]},
