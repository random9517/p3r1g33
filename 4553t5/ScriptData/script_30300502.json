		{"command":[ "PLAYVOICE", "v2_030_0504207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「は、はい……身体が自然に浮き上がるように……出し入れ……どんどん速く\nなって……参りますっ、おぉっ、おひぃっ！」", "NORMAL" ]},
