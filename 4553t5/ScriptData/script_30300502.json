		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「人のいない場所ですか……？　そうですね、この神社でしたら、こちらの方\nは一般の方は立ち入りされないと思います」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0504102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
