		{"command":[ "PLAYVOICE", "v2_030_0504124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「うんっ、何もしなくても……ひくひくと……襞が……震えてしまいますっ、\nあっ、んはぁっ、く……んんっ、ふぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0504125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
