		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「恐らく、また……イッてしまいます……んっ、あふっ……貴方は……いかが\nですか？　あぁ……んっ、イキそうですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0504216" ]},
		{"command":[ "SETIMAGE", "0", "still_00003005_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はい、可能でしたら……一緒にイキたいですっ……貴方と共に、最高の瞬間\nに達したい……あっ、くふっ、んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0504217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んぅんっ！　その……突き上げぇっ！　あっ、オチ〇ポがっ……オマ〇コに\n響いてっ…あぁっ、も、もうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0504218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はいっ、後少しだけっ……はぁっ、ですがっ……待ち切れませんっ……！　\nうぁうっ、もうっ、オマ〇コっ……イキますからっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0504219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「おっぱいも……出ますっ……！　はぁぁぁんっ、母乳を出しながらっ……オ\nマ〇コっ……イクっ……イキっ……ますぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0504220" ]},
