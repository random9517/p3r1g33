		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はぁぁぁ……元気な子種が……どんどんオマ〇コの中を浸して参ります……\nんくぅぅ……これが欲しかったものです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0504302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あぁっ……母乳掛かってしまいますね……申し訳ありません……美味しい…\n…ですか……？　そ、そうですか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0504303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
