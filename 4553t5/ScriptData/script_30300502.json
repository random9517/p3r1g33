		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「内側から……心地いい感覚が広がっていくのが……とても素敵です……んん\nっ……もっとオチ〇ポを感じていたいです……あっ……」", "NORMAL" ]},
