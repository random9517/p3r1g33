		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んっ……あっ、ふっ……まだオチ〇ポ……元気ですね。後少しだけ、お待ち\nいただけますか……？」", "NORMAL" ]},
