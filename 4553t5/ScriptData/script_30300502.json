		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んくぅぅぅんっ！　あぁっ、新しい……精液っ……奥にっ……びゅくびゅく\nっ……流れて来ますぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0504301" ]},
