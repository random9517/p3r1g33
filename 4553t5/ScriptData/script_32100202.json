{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021002_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「隊長さん、ちょっといいですか……巡回が終わってすぐで申し訳ないのです\nが……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0204101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「隊長さんと一緒にいると身体が熱くなって……ふうっ、うっ、この熱を静め\nたいんです……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0204102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「認識阻害フィールドを張りましたから……んんっ、お願い、お願いします隊\n長さん、私の身体を静めてください……っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0204103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「おっぱいもぱんぱんになってて……あんっ、隊長さん、吸っちゃ……吸っち\nゃだめ、あんっ、興奮して母乳が出ちゃう……あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0204104" ]},
		{"command":[ "SETIMAGE", "0", "still_00021002_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「あんっ、あっ、そんな赤ちゃんみたいにちゅうちゅう音を立てて……んっ、\nふっ、もう、隊長さんはしょうがない赤ちゃんですね……んうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0204105" ]},
		{"command":[ "SETIMAGE", "0", "still_00021002_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ふうっ、ふっ、んっ、ママのミルクを欲しがる赤ちゃん……んんっ、赤ちゃ\nんならママのオマンコに入りましょうね……あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0204106" ]},
		{"command":[ "SETIMAGE", "0", "still_00021002_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「あっ……ふっ、うっ、これ、思ったよりも……いいっ、あんっ、隊長さん…\n…赤ちゃんの脚、私の中をぐりぐりって……あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0204107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「隊長さんをバイブみたいにするの……んっ、気持ちいい！！　もっと、もっ\nと奥を脚でごりごりってして……あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0204108" ]},
		{"command":[ "SETIMAGE", "0", "still_00021002_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ふああっ、母乳もびゅっびゅって出てきてる！！　んんっ、隊長さんはママ\nのオマンコどう？　気持ちいい？　んんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0204109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ふふっ、隊長さんのおちんぽ、ママのオマンコの中で気持ちよさそうに震え\nてる……下半身全部、締め付けてあげる……あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0204110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「うっ、んっ、隊長さんがいけないんですよ……私の母乳を、あんなふうに吸\nうから……私がママになっちゃったじゃないですか……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0204111" ]},
		{"command":[ "SETIMAGE", "0", "still_00021002_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ふうっ、うっ、ママのオマンコをこうして締め付ければ……んんっ、隊長さ\nんの下半身がきゅっきゅって絞られてるでしょう？　ふあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0204112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「あんっ、隊長さんの下半身がオマンコの中で暴れてる……あんっ、そんな、\nオマンコ蹴っちゃだめ、あんっ、ああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0204113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「んふうっ、うっ、オマンコの中でバタ足しちゃだめっ！！　あん、マン肉は\nプールじゃないのっ、あうっ、んっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0204114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「んんっ、隊長さんの脚がマン肉を震わせて……あんっ、いやらしい赤ちゃん\nですね隊長さん……やっ、あっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0204115" ]},
		{"command":[ "SETIMAGE", "0", "still_00021002_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「あうっ、ああっ、凄い、隊長さんの下半身から振動が伝わって……オマンコ\nの中、ぐっちゅぐちゅにされてるっ、あああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0204116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ふうっ、ふうううっ、ママのオマンコをかき混ぜる隊長さん肉バイブ、いい\nっ、もっと、もっと暴れてっ、んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0204117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「はっ、あっ、んっ、もっと、もっと奥の方もぐりぐりって、ほら、隊長さん\n、ママのあっついオマンコ、静めて、ねっ、んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0204118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ふうっ、うううっ、ずぼずぼするのに合わせて脚が……あんっ、うっ、締め\n付けちゃう、ママのオマンコで隊長さん締め付けちゃう、ふあっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0204119" ]},
		{"command":[ "SETIMAGE", "0", "still_00021002_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「んんっ、あっ、また母乳が……あんっ、びゅるびゅるって出て溢れてる……\nふあああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0204120" ]},
		{"command":[ "SETIMAGE", "0", "still_00021002_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「あっ、ああっ、あんっ、凄い、隊長さんの身体がママのオマンコかき混ぜて\n……んんっ、音が、じゅぷじゅぷって……ふああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0204121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「んっ、んんっ、はっ、あっ、ママも隊長さんを気持ちよくしてあげるから…\n…んっ、あんっ、これで……んううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0204122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「あっ、きゅってしたら隊長さんのおちんぽも引っかかって……ふううっ、う\nっ、あっ、んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0204123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「んんっ、ママも、隊長さんも、どっちも気持ちいい！！　あんっ、両足、両\n足でオマンコ蹴らないでっ、ひああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0204124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ああんっ、脚曲げるのも、だめっ、引っかかって、マン肉に引っかかってご\nりゅごりゅって！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0204125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ママの、オマンコ、頭の中、おかしくなっちゃう！！　隊長さんの身体で、\nおかしくなっちゃう！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0204126" ]},
		{"command":[ "SETIMAGE", "0", "still_00021002_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「おっぱいも熱くなって、ミルクいっぱい出て、ふああっ、あっ、バカになっ\nちゃう、私、戦士なのに！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0204127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「おっぱいミルクとオマンコ、おちんぽで頭バカになっちゃう！！　隊長さん\nとのセックスで、バカになっちゃう！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0204128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ふうっ、ああああっ、オマンコの奥ガンガン蹴られて、隊長さんを肉バイブ\nにして、ふあああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0204129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「あっ、イく、イくイくイく！！　隊長さんをオマンコにズボズボ入れて、マ\nマイっちゃう！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0204130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ふあっ、あああっ、ああああっ、オマンコきっつきつに締めるからっ、隊長\nさんもイって！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0204131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「一緒に、ママと一緒に、イきましょう！！　ふあっ、ああああっ、んんんん\nっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0204132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「イく、イく、イっくうううううううう！！　ひあああああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0204133" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021002_02_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「んんっ、隊長さんのおちんぽから、ママの中にいっぱい出てる……んっ、脚\nでかき混ぜないで……やんっ、あっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0204134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ふうっ、ううううっ、あっ、凄い、ママのマン肉が震えるたびに、隊長さん\nのおちんぽもミルク出してる……んうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0204135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「はっ、はあっ、あっ……んっ、凄かった……気持ちよかった……隊長さん、\nありがとうございます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0204136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「お腹の奥の疼きは治まったけど、身体全体はむしろ火照ってきたかも……ふ\nふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0204137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「んっ、余韻でまた隊長さんの身体締め付けちゃう……あんっ、隊長さんも動\nいちゃうんですね……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0204138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「気持ちいい……頭の中、トロトロに蕩けちゃったかも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0204139" ]},
		{"command":[ "SETIMAGE", "0", "still_00021002_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「私は戦士ですけれど、こういう時間があってもいいですよね……隊長さん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0204140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「あんっ、もう一回したいんですか？　いいですよ、ほしがりさんの隊長さん\n……あっ、ふああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0204201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「んんっ、さっきのおちんぽミルクでさらにぐちょぐちょになったオマンコで\n……隊長さんの身体を、んっ、ふあっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0204202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ふっ、あっ、おっぱいからも、下からも、もう飛沫みたいにいっぱい飛び散\nって、んんっ、隊長さんの身体もぐちょぐちょになって……んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0204203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ああっ、凄い、ぬるぬるの身体でズボズボするとさっきとはまた違って……\nんうっ、ふうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0204204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ほっかほかのマママンコで隊長さんのおちんぽ、またしごいてあげる……あ\nっ、んっ、うっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0204205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「んうううっ、にゅるにゅぐって、しごきながら隊長さんの脚がばたばた暴れ\nて……ふあっ、あああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0204206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「あんっ、隊長さんもママのマンコほじるのうまくなって……ふああっ、つま\n先でカリカリしたら……んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0204207" ]},
		{"command":[ "SETIMAGE", "0", "still_00021002_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ふううっ、うっ、そんな悪い子にはおしおき……お腹に力を入れて……んん\nっ、ほら、ぎゅうぎゅうに絞って……あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0204208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ふふっ、さっきよりも隊長さんの形がわかる……鍛えられた脚も、腰も、お\nちんぽも……んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0204209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ママのオマンコが熱くなってるけど、隊長さんの身体もほっかほかになって\nますね……あんっ、やっ、膝でごりごりしたら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0204210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「んんんっ、ほら、さらに締め付けちゃうじゃないですか……やっ、あっ、中\nで腰ひねらないでっ、おちんぽがこすってくる……ふああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0204211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ああっ、うっ、隊長さんの身体でマン肉がごりごりされて……ふううっ、マ\nマとのセックス、そんなにいいのね……ふああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0204212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「あっ、ああっ、また、また来た……気持ちいいの、来た、んっ、イく、イく\n！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0204213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「隊長さんも、イって！！　ママのオマンコで、思いっきりイって！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0204214" ]},
		{"command":[ "SETIMAGE", "0", "still_00021002_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ほら、締め付けてあげるから……あんんんっ！！　最後の最後に、そんな奥\nをカリカリしちゃ、ふあああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0204215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「あひっ、あっ、ああっ、ママのオマンコ、そんなに責められたら、ああっ、\nあっ、もう、もうだめっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0204216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「んぐうううっ！！　手加減できないっ！！　隊長さんの身体、キッツキツの\nマママンコで思いっきり締め付けちゃう！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0204217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ふあっ、あああっ、イっく、隊長さんを肉バイブにして、またイっちゃうう\nうう！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0204218" ]},
		{"command":[ "SETIMAGE", "0", "still_00021002_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「全身ほっかほかになって、頭の中バカになって、何も考えられなくなって、\nひあああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0204219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「イっくうううううううううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0204220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「あふうっ、ああっ、あっ、隊長さんのおちんぽミルク、また来たああああっ\n！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0204301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021002_02_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「どくどくって、どくどくって言ってママのオマンコに隊長さんのミルク注が\nれてる……ふああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0204302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「熱い……アッツアツのマンコ以上に熱くて……おちんぽミルクでやけどしち\nゃう……んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0204303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ふうっ、ああっ、二回目なのに凄く出てる……んっ、あっ、そんなにこすり\nつけなくても、全部受け止めますから……ふあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0204304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「あふうっ、お腹いっぱい……気持ちいい……セックス、凄く気持ちいい……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0204305" ]},
		{"command":[ "SETIMAGE", "0", "still_00021002_02_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「好きな人とセックスするって、こんなに幸せなことなんですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0204306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「全身がべたべたになっても、全然気にならない……ふふ、興奮すると母乳が\n出る体質なんて、少しコンプレックスでしたけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0204307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「隊長さんが喜ぶなら、この体質も嬉しくなります。ありがとうございます、\n隊長さん。私のおっぱいミルクを飲んでくれて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0204308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ふふ、今回は冗談でママって言いましたけど、隊長さんが望むなら、私は本\n当にママになってもいいですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0204309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「だから……また今度、中にいっぱいいっぱい出してくださいね。あなた」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0204310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「あっ！？　ああっ、やっ、あっ、隊長さん、なんでママのオマンコから出て\nいくの、やっ、だめえっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0204401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021002_02_16" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ふあっ、あっ、顔の前で、あっ、ああっ、隊長さんのおちんぽから、ミルク\nが……ふあああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0204402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ああんっ、私の眼鏡、大切な眼鏡におちんぽミルクを……そんな、そんなこ\nとされたら……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0204403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「興奮して、おっぱいミルク吹き出しちゃうううううんんんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0204404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「オマンコからも一杯潮が……ふああっ、上からも下からも、一杯一杯出ちゃ\nう、んんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0204405" ]},
		{"command":[ "SETIMAGE", "0", "still_00021002_02_17" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ふうっ、んっ、ああっ、隊長さんのおちんぽミルク……おいし、んんっ、ん\nくっ、ふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0204406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「あふうっ……んっ……おっぱいミルクとおちんぽミルク、オマンコからの潮\nで凄いことに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0204407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「隊長さんも気持ちよかったんですね……顔で分かります。そんな顔をされる\nと、私も幸せになっちゃう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0204408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「顔にかけられていると、自分が隊長さんのものになったって自覚がとてもし\nてきますから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0204409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「だから……いつでも私が隊長さんのものだって、確認してくださいね……ふ\nふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0204410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}