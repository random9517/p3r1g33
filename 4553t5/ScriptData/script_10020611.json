{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0147" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "グルメコンテストは、校庭に用意された特設ステージで行われる。", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんだ？　コンテストの参加者って３チームだけなのか」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「そうみたいですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130113660001" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「それじゃあ、グルメコンテスト審査部門をはじめますよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_050113660001" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「進行はウチです。そして審査員は学園長」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_050113660002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「よろしくお願いします」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020113660001" ]},
		{"command":[ "SETCHARA", "0", "char_00002602_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「ＥＤＯ本部から冴島長官」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_050113660003" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「よろしくたのむ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010113660001" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「そして、特別ゲストにエファさん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_050113660004" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「特別ゲストということで、お腹を空かしてきました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060113660001" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "学園長はともかく、あとの二人はグルメとはほど遠い印象だな。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「それじゃあ、トップバッターはエジプト文化研究会です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_050113660005" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「我々が用意したのはとっておきの魚を使った寿司である」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_020113660001" ]},
		{"command":[ "SETCHARA", "0", "char_00002002_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「お寿司ですか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020113660002" ]},
		{"command":[ "SETCHARA", "0", "char_00002602_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「なんというか、皿が真っ白いな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010113660002" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「川魚は白身なのである」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_020113660002" ]},
		{"command":[ "SETCHARA", "0", "char_00002002_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「個人的に屋台へお邪魔したときに食べたものと同じかしら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060113660002" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "さっそく実食審査が始まる。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「はむ……。これは……なんてやわらかい身。口の中でとろけるような。シャ\nリの握り加減も絶妙ですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020113660003" ]},
		{"command":[ "SETCHARA", "0", "char_00002602_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「美味しいです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010113660003" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「ん～、美味しいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060113660003" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "後ろ二人のコメントが雑だなぁ……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「勝てるでしょうか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130113660002" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、可能性はあるかもしれない」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "いくらとっておきの食材を使っても、食べる相手がそれに通じるほどのグルメ\nでなければ意味がない。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "遥架の用意した魚がなにかは知らないが、きっと長官もエファも普通の白身魚\nと区別ができていないのではないか。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「それでは、次の料理です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_050113660006" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「魔術研究会のとっておきカレー、です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_020113660001" ]},
		{"command":[ "SETCHARA", "0", "char_00001802_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「カレーですって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130113660003" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「くっ、やはりカレーか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "さっきの理論だと、カレーはまずい。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "なぜなら、カレーという身近な食べ物なら普段食べているカレーと比較して味\nが評価されてしまう。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「カレーね。いただきます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060113660004" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "さっそくエファがカレーを口に入れた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「はむ……んっ、んんぅ……っ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060113660005" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「んふぅううううぅぅぅぅうっ！！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060113660006" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "な、なんだあの反応は！？", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「ああっ、なんて美味しいの！　こんなカレー初めてだわっ！　んぅっ、あは\nぁあんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060113660007" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "5", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「口の中がっ、辛みとうま味に支配されちゃうっ！　んんっ、手が止まらない\nわっ、ああっ、美味しいぃいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060113660008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「どれどれ、私も……あむ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010113660004" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "長官も食べた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「こ……これは……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010113660005" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "sbg_0137" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「うーーー！　まーーー！　いーーー！　ぞーーー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010113660006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "うおおおっ！？　口からビームを出した！？　いくら美味しいからってオーバ\nーリアクションすぎる！", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0147" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁっ、美味しいっ、美味しいわっ！　ああっ、んぁっ、ほれぼれ\nするくらい美味しいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060113660009" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おいおい、おかしいだろ。グレーテル、あのカレーになにを入れたんだ！？\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「別に、変なものは入ってないよ？　魔術にも使うようなハーブばかり」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_020113660002" ]},
		{"command":[ "SETCHARA", "0", "char_00001802_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いやいや、十分に変なものじゃねーか！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おい、兎子！　いったん審査を止めさせろ！　というかこれを学園長まで食\nべたら……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「そ、そうですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_050113660007" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「心配いりませんよ、カツマ先生。私はいたって平常です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020113660005" ]},
		{"command":[ "SETCHARA", "0", "char_00002602_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「牛は草食ですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_020113660002" ]},
		{"command":[ "SETCHARA", "0", "char_00003002_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ああ、このふたりの場合、本当に影響がないのかもうわからねえ……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……おかわりは、ないのかしら……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060113660010" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「え……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_020113660003" ]},
		{"command":[ "SETCHARA", "0", "char_00001802_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「おかわりだ……おかわりを要求する……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010113660008" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "一方、食べ終わったらしいエファと長官がギラついた瞳でグレーテルのことを\n見つめている。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「お、おかわりなんてないよ。審査員の人数分しか作ってないし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_020113660004" ]},
		{"command":[ "SETCHARA", "0", "char_00001802_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「なら作って！　今すぐ作って！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060113660011" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「そうだ！　そうだぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010113660009" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「む、無理だよ。どのハーブをどう調合したのか覚えてない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_020113660005" ]},
		{"command":[ "SETCHARA", "0", "char_00001802_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「なんですって！　思い出しなさい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060113660012" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「思い出すんだっ！　むしろ作り方を教えろっ、吐けっ、吐くんだっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010113660010" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「ひぃいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_020113660006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「エファも長官も、落ち着いてくださいって！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「やらやらやらぁっ！　カレー！　カレー！　カレー！　カレーがいいのぉっ\n！　食べたいのぉっ！」", "NORMAL" ]},
