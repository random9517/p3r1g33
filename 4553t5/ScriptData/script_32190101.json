		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「奉仕？　キミに？　ふーん……わざわざ呼び出しなんてして……そういうこ\nとだったの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0103101" ]},
		{"command":[ "SETCHARA", "0", "char_00021901_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「べつに驚かないよ。そういう話は聞いてたから……まあ私が指名されるとは\n思ってなかったけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0103102" ]},
		{"command":[ "SETCHARA", "0", "char_00021901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「胸？　そ、そう……？　大きい方かなとは思うけど……もっと大きい人いっ\nぱいいるから……待って、イヤとは言ってないけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0103103" ]},
		{"command":[ "SETCHARA", "0", "char_00021901_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「だって、キミがわざわざ私を選んだってことでしょ？　私も一応女だから…\n…ちょっと嬉しい、ていうか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0103104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「そんなノリノリってほどじゃないよ？　そこは勘違いしないでね。キミがし\nて欲しいっていうから……だから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0103105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「もう、あんまりからかわないで。奉仕……するから……胸で、して欲しいん\nだよね？　じゃあ……するね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0103106" ]},
		{"command":[ "SETCHARA", "0", "char_00021901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「服くらい自分で脱いで欲しいんだけど……ダメ？　これも奉仕……か……そ\nう言われると仕方ないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0103107" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00021901_01_02" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「他の人にも……こういうこと、させてるの？　嫉妬とかじゃなくて、単純に\n気になっただけ。ホントよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0103108" ]},
		{"command":[ "SETIMAGE", "0", "still_00021901_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「そうね、確かに野暮かも……ごめんなさい。ズボン、脱がせるからこっちき\nて……そう……ちょっとジッとしててね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「……きゃっ！？　もう、こんなに大きくなってる……そう、なんだ……服の\n上からでも胸、見たら……こうなっちゃうんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0103110" ]},
		{"command":[ "SETIMAGE", "0", "still_00021901_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「見ただけじゃなくて、私のご奉仕に期待してるから……？　あまりハードル\n上げないで欲しいけど……とにかく始めるね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0103111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「はぁ、ふぅ……大きい……挟んだら、より大きく感じる……んっ、んっ……\n立派ね、これ……ええ、とっても立派よ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0103112" ]},
		{"command":[ "SETIMAGE", "0", "still_00021901_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「だ、大丈夫よ……これくらい、できる……から……胸で、ご奉仕するから…\n…ジッとしてて……ンっ、くふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「本当に大きい……硬いし、熱いし……血管が浮かび上がってて、ビクビクし\nてる……凶悪な、チンポね……はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「それに、匂いもすごい……男っぽくて、むせちゃいそう……んっ、ふぅう…\n…イヤってほどじゃないよ……大丈夫、うん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0103115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「はっ……あんっ……んふっ……力加減は、どう？　もっと強く挟んだ方がい\nい……？　窮屈すぎない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「わかった、グイグイ押しつける……ね……ふぅっ……んっ……これ、くらい\n？　あっ、あふ……んんっ……はぁはぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0103117" ]},
		{"command":[ "SETIMAGE", "0", "still_00021901_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「大きくて、ちょっとやりづらいけど……せっかく私を選んでくれたんだから\n、楽しんでもらいたいし……頑張る、ね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「ふぅ、はぁあ、ふうっ……なんか、先っぽ濡れてきた……気持ちよくなって\nくれてるのね……んっ……あ、あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「だって、キミのチンポ……立派すぎて……ちょっと大変なんだから、声くら\nい……出ちゃう……はぁ、あぁ……あふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「これも仕事のひとつだと、思ってるので……しっかり、やるからね……んん\nっ、ヌルヌルしてきた……滑りがよくなってるね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「この調子で続けるね……おっぱいで、チンポ……ずりずりって、して……は\n、あふっ……どう？　気持ちいい……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0103122" ]},
		{"command":[ "SETIMAGE", "0", "still_00021901_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「もっと擦り、つけていいのね……わかった……ふぅ、うっ……はぁ、あっふ\nっ……もっと揺らして、あげるから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁあっ……おっぱいの中で、どんどん……大きくなってる……カリ\nも膨らんで、ゴツゴツしてきた……すごい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0103124" ]},
		{"command":[ "SETIMAGE", "0", "still_00021901_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「なかなか、上手い？　悦んでもらえてよかった……はぁ……はふっ、んっふ\nぅ……気持ちいい、でしょう？　チンポがそう、言ってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「ねえ……もしかして、もう出そうなの？　我慢しなくていいんだから……出\nそうになったら、出しちゃって……ほら、ほらぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「これくらい、私だってできるよ……ふふっ、キミのチンポ……さっきから、\n嬉しそうにビクビク震えてる……やっぱもうイキそうなんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「んんっ……もっと強く挟んで、扱いてあげるから……出して……びゅっびゅ\nって……精液を……んっ、はぁ、はぁぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「あぁ、すごい……まだ硬くなってる……やっぱり、若いから……かな……じ\nゃあ、一回射精したくらいじゃ……足りないよね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「安心して、ちゃんと満足するまでご奉仕するから……この、胸で……気持ち\nよくするから、一回射精して……んんぅっ……ふぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「あっ、んっ……胸が、滑っちゃう……はんっ、んんんっ……もっと押しつけ\nて、むにむにって……擦って……は、はんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「いいよ、出して……おっぱいで、受け止めるよ……キミの精液、いっぱい…\n…出して……んっ、はぁあっ、ああっ……あふぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0103132" ]},
		{"command":[ "SETIMAGE", "0", "still_00021901_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「もう少しですか？　んんぅっ……わかっています……しっかり胸で受け止め\nますから……あっ、あふうっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「は、はぁっ……んっ、くふっ……出して……！　だ、出して……！　はぁ、\nああっ……この胸に、キミの……ぶちまけてぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「んっ！　はっ、あぁっ！　んっはぁぁぁっ……あっ、あぁっ、あんっ、あぁ\nぁぁぁぁぁぁぁっ～～～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0103135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021901_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「あ、あくぅっ、んふぅっ……で、出てる……あぁ、胸の中に……ドクドクっ\nて、出てっ……はっ、はあっ、あふぅっ……！　んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0103136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「わ、私の胸が気持ちよすぎるから……？　あっ、あぁ……止まらない、です\nか……んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0103137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「はぁはぁ……た、たくさん出たね……私の胸、気持ちよかった……みたいで\n、安心した……ふぅ……んっ……あぁ、すごい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「こんなに出したのに……チンポ大きくなったままね。若いんだから、一回出\nしたくらいじゃ満足しないよね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0103139" ]},
		{"command":[ "SETIMAGE", "0", "still_00021901_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「ふふっ……安心して。さっき言ったけど、ちゃんと面倒見てあげるから……\nこのおっぱいで、好きなだけ気持ちよくなって、ね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0103140" ]},
		{"command":[ "SETIMAGE", "0", "still_00021901_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「んっ、さっきより大きくなってる気がする……射精、して……すぐなのに…\n…若いんだね、ホント……はふぅ、すごい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0103201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「こんなに勃起しっぱなしで、ツラくない……？　おっぱい、で……挟まれて\nるから感じちゃう？　そう、ならこのまま楽しんで」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「はぁ、はっ……んっ、んくっ、ふうっ……精液で、ヌルヌルして……なんか\n、滑っちゃうね……でも、こういうのもいいでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0103203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「だって、さっきから……キミのチンポ、嬉しそうにヒクついてるから……わ\nかりやすいし……んんっ、ふうっ……はぁあっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0103204" ]},
		{"command":[ "SETIMAGE", "0", "still_00021901_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「もっと、強くおっぱいで扱いてあげるね……ほら、こんな感じで……んっ…\n…精液、塗り込んで……むにむにって……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「だって、こんな熱くて硬いチンポ、挟んでたら……私だって、興奮してきち\nゃうよ。すっごく、エッチな匂いしてるし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「なにって、精液の匂いよ……んぅ、ふぅうっ……キミがいっぱい出してくれ\nたおかげで、ここまで匂ってくるの。濃い男くさい匂いがね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「はぁ、はっ……んんんっ……ふう、ふうっ……この匂いかぎながら、熱いチ\nンポおっぱいで擦ってたら、あ、あんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「あぁあっ、あふっ……さっきから、身体中が火照ってて、はぁ、はぁ……ん\nっ、くっ……このチンポのことしか考えられなくなってる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「早く出して欲しいな……またさっきみたいにどぴゅどぴゅって、キミの精液\nを……私の胸に、たくさん出してね……ん、んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0103210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「こうやって、おっぱい両方抱えて、ブルンブルンって……弾ませて、谷間に\n挟んだチンポをシコシコ～って、するの。いいでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0103211" ]},
		{"command":[ "SETIMAGE", "0", "still_00021901_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「チンポ、が……また熱くなって、ますよ……おっぱいと擦ってるから？　そ\nれもそうだけど、気持ちいいって言ってるのよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「はふっ、んっ、んふっ……はっ、はぁ、おっぱい、揺らし続けるのって、結\n構大変だから……はぁあっ、あんっ……声、出ちゃう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「今度は、こうやって……おっぱいを交互に擦り合わせて、ごしごしって……\n挟んで扱いて……どう、かな……？　どっちがいい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0103214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「んふっ、ンンぅぅっ！　ど、どっちも？　欲張りだね、キミは……でも正直\nに言ってくれて、嬉しいよ……ふう、んっ……はぅんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0103215" ]},
		{"command":[ "SETIMAGE", "0", "still_00021901_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「だから、お望み通り……このおっぱいで、いっぱい気持ちよくしてあげるか\nら、遠慮せず……んんっ、出してね……んっ、んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0103216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「はあっ……んっはぁっ！　チンポ、ビクビクっていってるよ？　また出そう\nなんじゃない？　ねえ……ほらぁ……あっ、あふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「おっぱい、少し緩めてあげるから……これで、気持ちよく射精できるよね？\n　んっ、はぁぁっ……きて、いっぱい出してっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0103218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「さっきみたいに、んっ、ふうっ……精液……ザーメン……キミの濃くって、\nくさいザーメン、私の胸にぶちまけてぇ……あっ、ああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「は、んんっ！　はっ、はぁ……あふっ、うぅっ！　心配しなくても、全部受\nけ止めるから……ふう、ふっ……うぅんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「あっ、ああっ……！　んっ……んんっ、あっあっ……はぁぁぁぁぁぁぁ～～\n～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0103301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021901_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「ひううっ……あっ、あふっ！　す、ごいっ……んんぅっ！　ひゃうっ……ん\nっ、んんっ……あぁっ……また、いっぱいぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0103302" ]},
		{"command":[ "SETIMAGE", "0", "still_00021901_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「熱い、布越しでも……ザーメンの熱が、伝わってくる……んっはぁっ……！\n　二回目なのに……匂いも、濃い……あぁ、むせちゃいそう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0103303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「くっ……はっ、あぁ……ひうっ！　んっ！　あっ、あぁっ……すごい勢いで\n、飛んできて……おっぱい、ドロドロになってく……んんぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0103304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「さっきより、量、多い……かも……あっ、あんっ、んふぅ……シャワーみた\nい……これ……あったかい……はぁぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0103305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「ふぅ、んっ……はぁ、はぁ……すごかったね……連続で射精したのに、全然\n勢い変わらないし……おっぱいがザーメンまみれよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0103306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「どうだった……って、聞かなくてもわかるけど……でも、やっぱり直接聞き\nたいから、聞くね。私のおっぱい、気持ちよかった？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0103307" ]},
		{"command":[ "SETIMAGE", "0", "still_00021901_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「そっか……そんなに気持ちよかったんだ。うん……そうだよね、こんなに射\n精してくれたんだもんね……ふふ、嬉しい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0103308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「なに？　また胸でご奉仕して欲しいの？　もう、エッチなんだから……でも\n、いいよ。またいつでもしてあげる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「そのかわり……恥ずかしいから、このことは二人の秘密ね？　約束してくれ\nたら、またいっぱいおっぱいで搾ってあげるから……ね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「んっ、はっ……あっ、あっ！　ひゃうっ！　きゃんっ……ひゃあぁぁぁぁぁ\nっ～～～！　ああぁっ……顔、かかって……んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0103401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021901_01_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「きゃんっ！　あ、あぁっ……！　勢い、よすぎて……顔まで、飛んで……ん\nっ、ひぃうっ……！　あぁあっ、あぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0103402" ]},
		{"command":[ "SETIMAGE", "0", "still_00021901_01_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「ひゃうっ、あっ……あんっ……すごい……さっきより、量も、多いっ……ひ\nゃあっ！　あっ……あっ……ん～～っ……あ、熱いぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0103403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「おっぱいで受け止める……って、言ったのに……あぁ……んんぅ……顔にか\nけちゃうなんて……あぁ、ドロドロになっちゃうぅ……んふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0103404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「ひゃ、あっ……あふっ……ねえ、まだ……出るの……はっ、んっ……あぁ、\nあ、熱いし……匂いが、んんっ……鼻が、おかしくなりそう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0103405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「はぁあ……んっ、たくさん出たね……そんなに私のおっぱい、気持ちよかっ\nた？　それにしても……ちょっと出しすぎ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0103406" ]},
		{"command":[ "SETIMAGE", "0", "still_00021901_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「こんなにぶっかけられたら、匂いが取れなくなっちゃいそう……キミとエッ\nチなことしてたのが、バレちゃう……あぁん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0103407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「あぁ、もぅ……こんなに汚しておいて、チンポはまだ不満げだけど……もっ\nと、して欲しいの？　そんなに私のおっぱい気に入った？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0103408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「ふふっ……そこまで言われると、ちょっと恥ずかしい……嬉しいけどね、う\nん……だから、もうちょっとサービスしてあげようかな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0103409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "怪人・ハチ乙女" ]},
		{"command":[ "SETTEXT", "「今日だけじゃなくて、これからずっと？　毎日のようにおっぱいで、奉仕…\n…？　キミがして欲しいなら、いいよ。してあげる……ふふっ」", "NORMAL" ]},
