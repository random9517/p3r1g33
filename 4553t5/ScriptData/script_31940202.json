{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0041" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「今日は……任務が早く終わったのか？　呼び出しに応じてくれたこと、感謝\nする。……察しの良い貴方のことだ、今日ワタクシに呼び出された理由」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0204101" ]},
		{"command":[ "SETCHARA", "0", "char_00019402_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「うすうすわかっているのだろう……。ああ、遠回しに言っても仕方がない。\n率直に言わせてもらうぞ。最近、ワタクシと貴方が良い雰囲気になると……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0204102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「きまってアトロポスやラケシスの邪魔が入る。それどころか、他の女達まで\n……！　ゆえに、ワタクシは欲求不満が爆発しかけている……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0204103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「色々と手段を駆使したが、もうラチがあかん。おとなしく次の機会を待つの\nはやめた。だから……人目のない場所に呼んだのだ。来い」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0204104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「貴方には、どれほどワタクシが貴方を欲していたのかをしかと見てもらう。\nいいか……？　んッ……目をこらしてよーく見届けろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0204105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、はぁ……っ。ひ……一目でわかるだろう。ワタクシの肉体のあ\nらゆる部位が……貴方を待ちわびて、愛欲の蜜を垂れ流していることが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0204106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00019402_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「ワタクシが……こんな風になるまで放っておくなんて、貴方はなんと罪な男\nだろうか……。ま、股……を広げて誘惑するまで気づかないなど……くぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0204107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「屈辱だが……ケダモノのようにワタクシに襲いかかり、食らいつくというの\nなら許してやっても良いぞ……。……ん？　どうした？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0204108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「なぜ、本性を剥き出しにして襲ってこないのだ？　な、なぜ？　ワタクシが\nここまでしているのにっ……？　えっ？　えっ、な、なぜ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0204109" ]},
		{"command":[ "SETIMAGE", "0", "still_00019402_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「放置プレイ……？　なんだそれは。おいっ、いつ人が来るかもわからない路\n地裏でそんな小細工はいらない、早く……。……どうして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0204110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「っぅ……。し、しないのなら見るな……！　恥ずかしいだろうっ……。あ、\nあ……！　隠しては駄目なのか？　服を着ることも？　そんな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0204111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「ぁ……。本当に……しないのか……？　なあ……こんな……誰にも見せたこ\nとのないふしだらな、淫らな姿を晒しているのだぞ？　貴方だけに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0204112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「それなのに、さんざんおあずけしたあげく……触れてもくれないなどと……\n。はぁっ、はぁ……。あ……、なぜだ、少し気持ち良くなってきた……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0204113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「ンッ！？　んんっ……！　あっ……！　母乳……母乳が出てきてしまった…\n…！　こ、これは！　違うんだ！　貴方を喜ばせようと思って……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0204114" ]},
		{"command":[ "SETIMAGE", "0", "still_00019402_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「妹から、アトロポスから分けてもらったボニューデマクールという薬の効果\nで……。何？　知っている？　この薬は興奮すると母乳が出る？　あぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0204115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「ワタクシは……ワタクシは、放置プレイで感じてなんか……！　愛液が溢れ\nている？　い、いやぁ……。見るなと言っているのに……はぁ、はぁはぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0204116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「な、あ……こんなに飢えているのに、意地悪をするのはやめろっ。ほら……\nすぐそこに、すぐに挿入できる都合のいいダークエルフおまんこがあるのだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0204117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「ズブッと太いペニスをねじり込むだけではないか……！　無視、するな……\n。あ……あ、ワタクシが腰をよじって物欲しそうにしている、だと？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0204118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「仕方無いだろう……！　本当に欲しいんだから、身体が火照って言うことを\nきかないんだ。なあ……し、したい。して……。……何？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0204119" ]},
		{"command":[ "SETIMAGE", "0", "still_00019402_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「ワタクシにはしたないおねだりをしてみせろと？　う……。普段なら……絶\n対にしない。だが……今の私は……。あ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0204120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「お……お願い、します……。いやらしい熟女ダークエルフのワタクシは……\n貴方のオチンポをオマンコに挿入してもらえないと困るの、だ……。んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0204121" ]},
		{"command":[ "SETIMAGE", "0", "still_00019402_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「セックスを想像してぐちょぐちょにオマンコを濡らした、恥知らずの淫乱マ\nンコに貴方のその、美味しそうな太くて硬いオチンポを入れ……ああッ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0204122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「っぅっ！？　入って……ああっ！　おねだりの途中ぅうう……！　言い終わ\nる前に挿入……ッ、チンポが、太いチンポが入ってきて……あひぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0204123" ]},
		{"command":[ "SETIMAGE", "0", "still_00019402_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「イクぅっ……イクイクイクっ、ぶっ壊れるぅっ！　あッあっあっあああああ\nあぁ！　ひぃいいっううぅ……！　挿入の快感だけで……ああああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0204124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「ワタクシが簡単にイかされるだなんて……！　あっ！　あっ、心の準備が出\n来ていなかったから、混乱っ……混乱して……あっ！　あっ！　あっぁっ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019402_02_06" ]},
		{"command":[ "PLAYVOICE", "v2_194_0204125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「今突くな……ぁ！　あっ！　ち、違う！　チンポは抜くな、突かれるとイっ\nてしまうんだ！　あっ！　やだっ！　突き上げるなぁ、すぐイクぅうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0204126" ]},
		{"command":[ "SETIMAGE", "0", "still_00019402_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「あ～～～～っ♪　あっあっあ～～～～～♪　イク、イク、ずっとイッている\nのにぃいい……！　あッ♪　あああああっ……おっ♪　おおおおぉっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0204127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「あっあっ！　びゅるびゅると母乳が噴き出して……ああっ！　力をこめても\n止まらない……！　あっ！　あったかい……、気持ちいい……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0204128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「っえっ？　舐めるのか？　母乳を……？　あッ♪　おっ♪　濡れた舌の感触\nぅう……らめっ！　らめぇっ、達するっ、達するぅう果てるぅう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0204129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「んぁぅう……！　おっ、おぉっ♪　ベロベロと舐め回されて……乳首ぃ、噛\nまれて……ああっ！　おかしくなる、おかしくなる……うぁああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0204130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「おかしくなると母乳が溢れて……甘い匂いが路地裏に充満する、頭がバカに\nなってきたぁ……あっ！　あっ！　オマンコ勝手に締めつけて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0204131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「オチンポに全力ですがりついてしまってる……！　っぇっ？　な、なんだ…\n…イキすぎていて良く聞こえない……。は？　中出し……っ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0204132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「中出ししたいのか！？　それはダメだっ……こんな状態で中に出されたら、\n妊娠してしまう……！　子宮の準備が出来てしまっているから……。あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0204133" ]},
		{"command":[ "SETIMAGE", "0", "still_00019402_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「受精っ……受精してしまうから待ってくれ……！　っぅっ……♪　そう言わ\nれるとますます膣奥に射精したくなるだと……？　う、うぁあああ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0204134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「し、知らないからな！　デキてしまってもぉ♪　あっ♪　あっ、それなら…\n…出してくれぇ、ガンガン子宮をチンポでノックして、開かせて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0204135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「それから思いっきり、睾丸が空になるまで精液を子宮に注入してくれぇ……\n！　あっ、あっ、デキるぅ、人間との子を孕むぅうう！　あ～～～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0204136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「おぅっ♪　あぁふっ……！　出ているっ……出ている子種が……！　ああっ\n！　うれし、い……。あぁああっ！　イク……っ、イクぅう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0204137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019402_02_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「あっううぅううう～～～～～っ♪　チンポっ、チンポの先から大量の子種が\n発射されて……子宮口に突入してくるっ……熱い子種が……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0204138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「あっああああああっ♪　あああああっ……！　ああああ～～～～っ♪　んぉ\nぁああああ……♪　中出、し……中出し、気持ちいいぃ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0204139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「気持ち……。……はっ！？　い、今絶頂と共に軽く気を失いかけてしまって\nいた……。あっ……！　ワタクシの理性がなくなるほどの膣内射精……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0204140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「やはり、貴方はヒトの中でも最も優れた男……オスだ……。はぁっ……♪　\nはぁ、はぁ……。ん？　精子を注がれた感想か？　決まっているだろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0204201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「最高、だった……♪　ありがとう、これで欲求不満も解消され、ワタクシは\n満足し……。んっ？　な、なんだ。一体何をするつもりだ？　あっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0204202" ]},
		{"command":[ "SETIMAGE", "0", "still_00019402_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「やっ……！？　えっ、あっ……！　膣内の精液をチンポでかき混ぜている、\nのか……？　あっ♪　やめろ……ワタクシはもう満足して……あぁんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0204203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「や、ぁ、あ、あ……あぁ♪　な……なんということだ、精液で満たされたオ\nマンコ、を……チンポで激しく掻き回されたら……ああぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0204204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「また……したくなってきてしまったではないかぁ……！　は、ぁ、うっ♪　\nうぅ……♪　あふっ♪　ぬ、抜かなくていい……もっとするぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0204205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「もっとしたいから……、あっ♪　続けてくれ……。んっ、そうだ、確かにワ\nタクシは満足したのだが……こんな風にされて耐えられるものかぁ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0204206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「ワタクシも腰を振って、オマンコを締めて興奮させるから……貴方を気持ち\n良くさせてみせるから、どうか……どうか続けて、あんっ、もっと！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0204207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「ッあぁああ……！　あっぁっあっぁっ……♪　外でするセックスは、交尾は\nエルフの大好物なん、だ……開放的で、……あぁんっ、心地いいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0204208" ]},
		{"command":[ "SETIMAGE", "0", "still_00019402_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「だが……だがここまでの興奮は、昂りは異常だ……！　なぜ、なぜ貴方のチ\nンポをハメられると性欲が、肉欲が止められなくなってしまうのか……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0204209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「あっあっワタクシは、ワタクシは貴方の肉棒の魔力にとりつかれているっ、\nそれくらい気持ちがいい……！　太すぎるし硬くて……はぁううっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0204210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「一番いいところに当たるんだっ……！　あふぁああっ♪　またイかされた♪\n　あっあっ、間髪入れずにぃ……またイって……あぁあああんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0204211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「母乳っ……母乳また出るぅ……！　あああ、もう……ワタクシの知性が、高\n貴さが、力が全て母乳になって乳首から溢れ出していくみたいだぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0204212" ]},
		{"command":[ "SETIMAGE", "0", "still_00019402_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「わけがわからないぃ……っ。オチンポ、チンポでワタクシはダメダークエル\nフに成り下がってしまう、堕落して……セックス狂いになってしまうぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0204213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「あーっ♪　あぁああっ……♪　チンポ……、チンポがすごすぎるのがいけな\nいんだぁ……っ♪　チンポ……あっ、チンポいいっ、気持ちいい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0204214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「あひっ、あひぃっ……ひぃんっ……♪　チンポ奥に入れてっ……抜いて……\nまた入れて……っ♪　激しく出し入れしながら腰を、打ちつけて……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0204215" ]},
		{"command":[ "SETIMAGE", "0", "still_00019402_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「はぁああ♪　なんとみっともない格好を、外でしているんだワタクシは……\nぁっ。でもそれが、それが……！　あんっ、子宮に響くのだぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0204216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「あぁあぁ……外でイク、オマンコ路地裏で犯されながらイクぅ、達し続けて\n……貴方専用のダークエルフオナホールになってるっ、はぁああぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0204217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「あっ！？　い……今近くにヒトが通って……！　あぁ♪　だめだ、それだけ\nで……ヒトの気配だけでイってしまいそうだ……、どうかしているぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0204218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「あぁ、見知らぬ大衆よ……！　ワタクシが突かれてイクところを、膣内を征\n服されているところを見てくれぇ、見て欲しいぃい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0204219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「マゾダークエルフだとでも、淫乱熟女だとでも好きに呼ぶがいい！　ワタク\nシは……この男のチンポでイクぞ！　ああっ、見て、見てぇえ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0204220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「んぉおおおっ♪　おおぉっ♪　おほぉっ、おぉおおっ……♪　おおおおっ…\n…♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0204301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019402_02_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「し……知っているぞ、この状態、を……ヒトはアクメというのだろうっ？　\nワタクシは……今アクメをキメている、貴方の精液で……あ～～～っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0204302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「子宮、に確実に溜まっていく貴方の種汁……♪　あっぁっおっ♪　おぉ……\n♪　さっき……一度目に注がれた種よりもっと重い……濃いぃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0204303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「ワタクシの膣内全てが歓喜して、チンポから精子を吸い上げている……飲み\n干していく……♪　はぁああっ……これだ、これが欲しかったのだ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0204304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「あっあっ♪　まさか……まさかヒトの中に、ワタクシを孕ませることが……\n孕みたいと思わせるオスがいたとは……最高の誤算だった……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0204305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「は、ンン……♪　ど……どうだ？　一滴も残さず絞り上げてやったぞ……♪\n　こんなこと……ワタクシ以外に出来ようはずもない。感動しただろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0204306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「はぁ……♪　あぁあ……♪　精液を注がれ過ぎて、下腹がもう妊婦のように\n膨らんでしまっているみたいだ……。フフッ……さすがに出し過ぎだが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0204307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「ワタクシほどのダークエルフを支配し、孕ませようというのならば……これ\nくらいは当然か。実に素晴らしかったぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0204308" ]},
		{"command":[ "SETIMAGE", "0", "still_00019402_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「完全なる我が膣内へのマーキング、この私をあれだけ喘がせ、乱れさせる胆\n力……。貴方はもはや、ヒトを超えた何か……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0204309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「そうだな、後にダークエルフの国の王になるべき男なのかもしれない。そう\nなってくれれば、ワタクシ達三姉妹は喜んで貴方を迎えるぞ……きっとな♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0204310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「んっおふっ♪　おっ……♪　あっ♪　身体が熱い……っ！　んっ！？　か、\n身体……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0204401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019402_02_17" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「んぷっ、うぷっ……！　お、溺れてしまう……！　とめどないザーメンシャ\nワー……あぁ気持ちいい、気持ちいい……が……。なぜ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0204402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「なぜ膣内ではなく外に……ぃ！　あっ、そうなのか……？　誰かにワタクシ\nの痴態を見せつけるのであれば……出来るだけ無様な格好が良いと？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0204403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「こうしてっ……！　んぷぅっ、くふっ……あうぅっ♪　ザー汁まみれにされ\nて、しかも……膣口からも精液を溢れさせている姿を見せたいと？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0204404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「す……凄まじい外道の発想……！　それなのに、その考えに陶酔してしまう\n……。いいぞ、かけてくれ……ワタクシを汚してくれ、貶めるのだぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0204405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「あ……♪　とんでもない姿にされてしまったぁ……♪　路地裏で、卑猥な衣\n服を身にまとい……精液まみれで中出しされたダークエルフ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0204406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「こんなもの、一目で何をされていたかわかる……わかってしまう……♪　あ\nぁ、ワタクシが貴方に蹂躙されていたことが……。はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0204407" ]},
		{"command":[ "SETIMAGE", "0", "still_00019402_02_16" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「……ワタクシが今日一番興奮しているように見える？　そうかもしれないな\n……。この服を、譲ってもらって本当に良かった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0204408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「ワタクシは、こういうプレイにひどく昂りをおぼえるのだな。それを知った\nからには……ククク、これからが楽しみだと思わないか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0204409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「ワタクシはこれから、貴方にどこまで淫らに開発されてしまうのだろうな…\n…♪　期待で今から、この胸が張り裂けてしまいそうだ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0204410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
