{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024802_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「あっ、あのっ……！　カツマ先輩……！　ノゾミのお尻の穴……ちゃんと奥\nまで見えてますかっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0204101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「ほ、本当はオマンコの処女をあげたいんですけど……今日は接続用プラグの\n調子が悪いみたいで……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0204102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「ですので……変わりと言っては何ですが……！　ひ、ノゾミのお尻の処女を\nもらってくださいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0204103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「ちゃんと新品のプラグにしてありますし、感触とかも人のお尻と同じように\nできてます……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0204104" ]},
		{"command":[ "SETIMAGE", "0", "still_00024802_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「ノゾミのことが好きなら……こ、応えて欲しいですっ……！　カツマ先輩の\nオチンポ……アナルに挿れて、いっぱいズポズポしてくださいっ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0204105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「ひっ、あっ……！？　お、お尻に硬いのが入ってきてますっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0204106" ]},
		{"command":[ "SETIMAGE", "0", "still_00024802_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「これがカツマ先輩のオチンポの感触っ……！　太くて、大きいっ……！　ん\nっ、あっ、ぐっ……！　あああぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0204107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「ノゾミのお尻の穴が、どんどん押し広げられてっ……！　んんっ……！　た\n、たまりませんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0204108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「肛門がムズムズして、勝手にアナルが締まっちゃうっ……！　カツマ先輩の\n挿入中のオチンポ、キツく締め付けちゃうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0204109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「あっ！　あっ！　奥まで……きてるっ……！　アナルの接続プラグにオチン\nポがずっぽり入って……んはあぁぁぁぁぁっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0204110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「はぁ……！　んっ、あっ、うぐっ……！　ど、どうですか……！　ノゾミの\nお尻……気持ちいいですかっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0204111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「ノゾミは……凄く気持ちいいですっ……！　異物感はありますけど、それ以\n上にカツマ先輩と一つになれたのが嬉しくて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0204112" ]},
		{"command":[ "SETIMAGE", "0", "still_00024802_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「挿れたままじゃなくて、いっぱい動いて欲しいですっ……！　パンパンって\n腰を打ち付けて、お尻の中をえぐってくださいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0204113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「あっ！　んひっ！？　あひぃぃっ！？　カツマ先輩のオチンポが、お尻の中\nでズルズル動いてますぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0204114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「カリのでこぼこしたところが、プラグのヒダを擦ってきてますっ……！　肛\n門が引っ張り出されちゃう感じがするぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0204115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「んっ！　おっ、おほぉぉぉっ！？　勢いよく突かれると、奥から気持ちいい\nのがこみ上げてくるぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0204116" ]},
		{"command":[ "SETIMAGE", "0", "still_00024802_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「ズリズリされるたびに、勝手にお尻が反応しちゃいますっ！　さっきよりも\n強く肛門が締まっちゃいますぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0204117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「んひぃぃぃぃぃっ！？　そんなっ、浅いところをズポズポするのダメですっ\n！　人間でいう排泄感覚がずっと続いて……んはぁぁぁっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0204118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「おっ、おっ！？　んおぉぉぉっ！？　ノゾミ、出しちゃいけない声出してる\nっ！　エッチな喘ぎ声、止まらなくなってますぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0204119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「ひぎぃっ！？　がっ、ああぁっ……！？　こ、今度は一気に奥にオチンポが\n突き刺さってますぅ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0204120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「腸の奥の方にオチンポが届くような感覚がしてますっ……！　こ、これが人\n間のアナルセックスの快感なんですねっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0204121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「ひっ！？　おっ、あっ！？　んぎぃっ！？　お尻からエッチなオイルが溢れ\nてきてるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0204122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「オチンポでズンズンされるたびに、ぐちゅぐちゅいやらしい音が鳴って……\n！　こんなの、エッチすぎますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0204123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「あはああぁぁぁんっ！？　カツマ先輩のオチンポからも、エッチな汁がにじ\nみ出てますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0204124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「ノゾミのお尻の汁と混ざって、さらに卑猥な音になってっ……！　あっ！　\nんっ！　滑りもどんどんよくなっていってるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0204125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「こんなに気持ちよくされたら、オマンコの接続プラグも疼いちゃいますっ！\n　調子が悪いはずなのに、オマンコでも感じてっ……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0204126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「あぅ、ひっ、あひぃ！？　お尻とオマンコ、どっちも感じますぅ！　オチン\nポで２つの穴を同時にズポズポされてる感じがしますぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0204127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「はぁ、んっ！　あっ！　も、もっと激しく突いてくださいっ！　カツマ先輩\nのオチンポ、根本までお尻に挿し込んでくださいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0204128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「ちゃんと全部受け止めますからっ！　だから遠慮せずに、もっと奥までっ…\n…！　あひぃぃぃぃぃんっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0204129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「おっ、おっ……！？　腸の奥の奥まで、オチンポが突き刺さってますぅ……\n！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0204130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「あああっ！　そこ、気持ちいいですっ！　奥の方をグリグリされると、オマ\nンコがさらに疼いちゃいますぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0204131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「それ、もっとしてくださいっ！　円を描くようにオチンポをズリズリしなが\nら、ズポズポ出し挿れしてぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0204132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「あっ！　んっ、おっ、おほっ！？　んんっ、ぐっ、ひぐっ……！　あっ、ん\nおっ！　おぉぉぉっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0204133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「か、カツマ先輩っ！　ノゾミ、感じすぎてイッちゃいますっ！　アナルセッ\nクスでイッちゃうぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0204134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「カツマ先輩もイッてくださいっ！　一緒に感じて、一緒にイッてぇ！　あっ\n！　あっ！　来るっ！　凄いの来るっ……あはぁぁぁんっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0204135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「んほぉぉぉぉぉっ！？　アナルにびゅーびゅー精子出てますぅっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0204136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024802_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「カツマ先輩の濃厚な精子、腸の方に流し込まれてるっ……！　熱くてドロド\nロの液体がお尻に満ち溢れて……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0204137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「んぎっ、がっ、あっ……！　ま、まだ出てますっ……！　ノゾミのお尻の中\n、精液でいっぱいになるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0204138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「で、でも……カツマ先輩の色に染められてるみたいで、凄く嬉しいですっ…\n…！　もっとノゾミのお尻に精子出してくださいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0204139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「ノゾミのアナル、カツマ先輩の濃厚精子でぐちゃどろにしてくださいっ……\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0204140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「んっ……あふっ……！　カツマ先輩のオチンポ、素敵でした……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0204201" ]},
		{"command":[ "SETIMAGE", "0", "still_00024802_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「お尻の隙間から溢れてきて……んっ、はぁ……！　このドロっとした感覚だ\nけで、またイッちゃいそうです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0204202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「えへへっ……カツマ先輩のオチンポ、まだ硬いままですね……もっとノゾミ\nとしたいんですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0204203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「はい……もっとしてください……！　ノゾミのアナル、いっぱい味わってく\nださいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0204204" ]},
		{"command":[ "SETIMAGE", "0", "still_00024802_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「んっ……！　あっ……！　オチンポで肛門のお肉が引っ張られてますっ……\n！　あっ、あっ……！　あはぁぁぁぁぁっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0204205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「あっ！　んひっ！？　おっ、おほぉ！？　またお尻の穴をズポズポされてま\nすぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0204206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「精子のおかげで滑りもよくなってるから、さっきよりも肛門がえぐれてる感\nじがっ……！　ひっ、あっ！　うぐっ、んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0204207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「それに奥の方にも亀頭が届いてますっ……！　オチンポの先端が、子宮の裏\n側の方に当たってるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0204208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「これ、お尻の方からオマンコを犯されてるみたいで、凄く感じますっ！　ノ\nゾミの子宮、腸越しにトントンされてますぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0204209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「ひぎっ！？　んっ、おっ、んふっ！　あっ、ひああぁ！？　んっ、くっ、あ\nっ……ひぐっ、んふぅぅぅっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0204210" ]},
		{"command":[ "SETIMAGE", "0", "still_00024802_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「カツマ先輩っ……！　もっと激しくズポズポしてくださいっ……！　ノゾミ\nのアナルとオマンコ、いっぱい気持ちよくしてくださいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0204211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「あああぁぁぁんっ！　それ、いいですっ！　オチンポを激しく打ち付けられ\nるの、たまりませんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0204212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「肛門がズリズリめくれる快感と、お尻の奥をズンズン突かれる快感が合わさ\nって、身体の奥が熱くなってきますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0204213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「ああぁんっ！　カリ首がまた腸のヒダに絡まってますっ！　ゴリゴリってえ\nぐられる感覚がたまりませんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0204214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「ひぐっ、んっ！　あひぃ！？　お尻の奥でオチンポがビクビク跳ねて、暴れ\nまわってますぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0204215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「このオチンポがヒクつく感じっ……！　カツマ先輩、またイキそうなんです\nねっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0204216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「は、はいっ……！　またノゾミにいっぱい出してくださいっ！　遠慮せずに\n、精液びゅーびゅーしてくださいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0204217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「ノゾミは大好きなカツマ先輩のためなら、何回だって精液を受け止めますっ\n！　どこに出してもらっても構いませんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0204218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「だからノゾミのこと、もっと犯してくださいっ！　精液まみれにして、カツ\nマ先輩のモノにしてくださいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0204219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「あっ！　あっ！　来るっ！　ザーメンくるぅ！　出してっ！　カツマ先輩の\n出したいところに、精子どぴゅどぴゅしてくださいーーーっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0204220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「あああぁぁぁんっ！　またお尻の奥に精液びゅーびゅー出されてますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0204301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024802_02_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「熱くてドロドロの濃いザーメンがノゾミのお尻の奥に届いてっ……！　ひぐ\nっ！　がっ、あっ！　あはぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0204302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「アナル越しに子宮のにびちゃびちゃ精子が当たってるの感じますっ！　ノゾ\nミのこと、孕ませようとしてるんですねっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0204303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「妊娠させたいって思ってくれるほど、強く射精してくれるなんてっ……！　\nすっごく嬉しいですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0204304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ！　もっと、もっと出してくださいっ！　ノゾミのアナルにカツ\nマ先輩の精液、たっぷり染み込ませてくださいっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0204305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「んっ……くっ、あふっ……！　ようやく、射精が落ち着いてきたみたいです\nね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0204306" ]},
		{"command":[ "SETIMAGE", "0", "still_00024802_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「えへへっ……ノゾミのアナル、どうでしたか……？　気持ちよかったですか\n……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0204307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「悦んでくれたなら嬉しいです……ノゾミも、すっごく感じちゃいました……\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0204308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「あの……今日はお尻の穴でしたが、オマンコの接続プラグが直ったら、今度\nはオマンコでセックスしてもらってもいいですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0204309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「ノゾミのためにも、オマンコでもセックスしたい……？　あ、ありがとうご\nざいます！　ノゾミ、すっごく嬉しいですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0204310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「あひぃぃぃっ！？　おっ、お尻の穴からオチンポがズルズル抜けていってま\nすぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0204401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024802_02_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「それにお尻の中じゃなくて、外に熱いのがかかってっ……！　あっ、ひぎっ\n！？　これ、カツマ先輩の精液ですかっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0204402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「そんなっ……！　中じゃなくて外に出されるなんてっ……！　あぁんっ！　\nでも、カツマ先輩の精液なら嬉しいですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0204403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「お尻だけじゃなくて、オマンコやおっぱいにも精液が染み込んできてますっ\n！　ノゾミの身体、ザーメンの臭いでいっぱいになっちゃうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0204404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「臭いが染みついたら、もう外を歩けませんっ！　カツマ先輩っ！　責任取っ\nてくださいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0204405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「あっ、んっ……全身ドロドロですっ……ボディの隙間にも、精液が染み込ん\nできてますっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0204406" ]},
		{"command":[ "SETIMAGE", "0", "still_00024802_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「中も外も精液の臭いでいっぱいですっ……！　これ、洗車しても臭いが落ち\nそうにないですね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0204407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「ちゃんと責任を取るって……ま、まさか……！　さっきノゾミが言ったこと\n、本気にしてくれたんですか……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0204408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「う、嬉しいですっ……！　これでカツマ先輩と私は……その、こ、ここ……\n恋人ということになるんですね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0204409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「えっ……？　責任を取って、ちゃんと自分の手で洗車するから安心して欲し\nい……？　せ、責任って、そういう意味ですかぁ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0204410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}