{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「隊長ー。琴吹ですー。いやー、今日のビーチも最高でしたねー。右も左も水\n着美女に水着男子……って、隊長？　お元気じゃない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0203101" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00006402_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「ははーん、さては武器のメンテナンスをして欲しくて私のことを呼んだんで\nすねー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0203102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「そういうことだったら、水着姿のままですがご奉仕して差し上げましょう。\n隊長には、お世話になってますからねー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0203103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「よ……っと……。なんだ、おちんぽは勃起しちゃってるじゃないですか。ビ\nンビンに膨らませちゃってー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0203104" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00006402_01_02" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「じゃあ、さっそくおっぱいで挟んでー……っと。んぁあっ、隊長のおちんぽ\n、めっちゃ熱い……。谷間がヤケドしそうですよー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0203105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「それじゃあ、パイズリする前に……れろぉ……っと、よだれを垂らして滑り\nをよくしてーっと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0203106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「しっかり押さえてー……褐色おっぱいで、隊長のお疲れ勃起おちんぽをマッ\nサージしてあげますよー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0203107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「んしょ、んしょ……。よいしょ……んふっ、んっ、んっ、どうですかー？　\nんっ、おっぱい、感じますかー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0203108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「柔らかーいおっぱいを上下に動かして、おちんぽ、ずーりずーり、やさしー\nくしごいてるんですよー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0203109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「あんっ、相変わらずの立派な武器ですねぇ、隊長のおちんぽ……。挟みがい\nがあるっていうかー、パイズリしていて楽しいですよー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0203110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「こーやってー、ちょーっと意地悪に刺激するだけで、おっぱいのなかでビク\nビクーってしちゃうんですからー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0203111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「ほらー、じっとしていてくださいよー。隊長が、私におっぱいでして欲しい\nーって泣きついてきたんですからー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0203112" ]},
		{"command":[ "SETIMAGE", "0", "still_00006402_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「え？　泣きついたりなんかしてない？　まま、細かいことは気にせずにー。\nほらほらー、パイズリですよー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0203113" ]},
		{"command":[ "SETIMAGE", "0", "still_00006402_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「んっ、ああ……っ。んふぅ……。おっぱいの間で、隊長のおちんぽが暴れて\nます……んっ、んんぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0203114" ]},
		{"command":[ "SETIMAGE", "0", "still_00006402_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「アツアツの勃起おちんぽこすれて……ぇ……。はぁ、はぁ……。ンッ！　隊\n長、腰が動いてますよー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0203115" ]},
		{"command":[ "SETIMAGE", "0", "still_00006402_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「ぎゅっと押しつけられたおっぱいに、くいっ、くいっと腰を浮かせて、おち\nんぽこすりつけてくるみたいにー……んっ、ああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0203116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「ちょ、ちょっとなんですかー？　隊長、私の……おまんこいきなり触るなん\nてー……ひゃんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0203117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「股のところが湿っているからって？　んっ、んぁっ！　ちょっと、そんなに\n指で……ひゃふっ！　だめですってぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0203118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「あうー……。んっ、ンンッ！　隊長に、パイズリしながら濡らしちゃったお\nまんこ、めちゃくちゃ見られてる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0203119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……。だってぇ……。こんな立派な武器を前にしたら、欲情した\nってしかたないじゃないですかー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0203120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「こんな……ガッチガチで……男くっさぁいおちんぽ……。はぁ……はぁ……\nたまりませんってー……。んふ……んふふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0203121" ]},
		{"command":[ "SETIMAGE", "0", "still_00006402_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「ひゃんっ、た、隊長！？　ますますおまんこから汁が出てきたって？　ああ\nん、そういうこと言わないでくださいってー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0203122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「あっ、んあっ、ああっ！　隊長の指が、ンッ！　おまんこ、かりかりって…\n…くすぐるみたいに刺激してきて……ひゃうぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0203123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「だ、だめですってー……。パイズリに、集中できなくなっちゃいますってー\n……。はぁ、はぁ……。んっ、あんっ、あぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0203124" ]},
		{"command":[ "SETIMAGE", "0", "still_00006402_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「隊長のおちんぽ、なんだかさっきよりもおっきくなっていませんか？　んっ\n、興奮してる……？　私のおまんこいじりながらですかー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0203125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「ひゃんぅ、そんな、エッチな声出ちゃっていますか？　そりゃ、興奮のあま\nり変な声を出すことはたびたびありますが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0203126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「それとは違う？　いやらしい声で興奮するって……？　や、やだ……そんな\n恥ずかしいこと言わないでくださいよー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0203127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「い、意識しちゃうじゃないですか……。ンッ！　あっ、ああっ！　ちょっと\n隊長……っ！　指、さっきよりも激しく……あひゃんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0203128" ]},
		{"command":[ "SETIMAGE", "0", "still_00006402_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「ええい、それなら私だって、隊長に情けない声を出させちゃうんですからね\n！　んっ、んっ、んんっ！　はぁ、はぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0203129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「こうして、おっぱいで勃起おちんぽ思いっきりしごいて……っ！　あははっ\n、隊長、おちんぽ限界っぽいじゃないですかー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0203130" ]},
		{"command":[ "SETIMAGE", "0", "still_00006402_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「おちんぽ、ビクンビクンしてイキそうになっちゃってます。んふーっ、これ\nはもうどぴゅっちゃいそうですねー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0203131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「えいっ、えいえいっ！　イかせちゃいますよっ！　ほら、ほらほらー！　隊\n長、隊長、どぴゅっちゃえー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0203132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「んふふー、私のパイズリが気持ちよすぎて、指の動きが止まってますよ。こ\nのままとどめですーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0203133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「んんんぅぅぅっ！　ああっ、ビクビクって、おちんぽ跳ねてます！　んっ、\nあっ、ああんっ！　あはぁああ～～～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0203134" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00006402_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「んっふふー。ずいぶんたっくさん出しましたねー。隊長、さては私に手マン\nしながら射精を耐えてましたね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0203135" ]},
		{"command":[ "SETIMAGE", "0", "still_00006402_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「だめですよー。我慢はほどほどにしないとー。少なくとも、私のパイズリの\nときは情けなくどびゅーっとしちゃってくださいよー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0203136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「そのために呼んだんでしょー？　んふふー、本当に、やーらしい匂いの精液\nですよねー、隊長のはー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0203137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「はいはい、わかってますよー。もっと射精したいんですよね？　こんなにガ\nチガチのままですからー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0203138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「……ん？　私のおまんこもイかせたいって？　隊長の指でイかせられますか\nねー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0203139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「ためしてやる？　ほほう、隊長ってばいつになくやる気。じゃあ、受けて立\nちますよ。たまには、隊長にいじってもらうのもいいですからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0203140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「んふふー、相変わらず、こんなにガッチガチのままそそり立って……。本当\nに立派なおちんぽですよねー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0203201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「真っ赤に充血したさきっぽもなんだか可愛くて、もう、見ているだけでドキ\nドキしてきちゃいますよー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0203202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「じゃ、隊長。褐色おっぱい、堪能しちゃってくださいねー。ンッ、すっごく\nヌルヌルになってる……んっ、んっ……んふふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0203203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「ああ……。隊長の指が、動き始めて……ンッ、ンッ、いいですねー……。は\nぁ、はぁ……アンッ！　んん……んぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0203204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「ますますおまんこが、ヌルヌルになっているって……？　あんっ、だって…\n…隊長がすっごくやらしい精液だすからー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0203205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……。隊長が、おまんこひろげてる……。ああん、エッチな視線\n……おまんこに向けられてますよー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0203206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「アンッ！　またおちんぽが硬く……。おまんこ見ただけで大喜びだなんて、\n隊長はぴゅあっぴゅあですねー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0203207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「そんなかわいい反応をされたら、ちょっと……私の母性がくすぐられちゃう\nじゃないですかー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0203208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「母性なんてあったのかって？　もう、失敬な。私だって女の子なんですよー\n？　武器が大好きってだけですー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0203209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、隊長、アンッ！　おちんぽ……んふぅ、いっぱいいっぱい気持\nちよくしてあげますよー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0203210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「ガチガチ勃起ー……。んふぅ……。はぁ、はぁ……。褐色おっぱいで、こね\nこねー、ずりずりー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0203211" ]},
		{"command":[ "SETIMAGE", "0", "still_00006402_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……。ぬるぬるおっぱいが、熱いおちんぽにすっごく密着しち\nゃって……気持ちいい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0203212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「んっ、腰を動かすなって……。無理ですよー……。だって、隊長にエッチな\nことしてあげてるんですからー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0203213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、んっ、ん……っ！　おっぱいを動かすたびに、胸の中で精液が\nかき混ぜられて、いやらしい匂いが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0203214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「こんなの嗅いでいたら、もう……我慢できなくなって……。はぁ……はぁ…\n…もっと欲しくなっちゃいます……んっ、ああ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0203215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「隊長……？　ほら、ほらー……。このまま、また、びゅーっとしちゃってく\nださいよー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0203216" ]},
		{"command":[ "SETIMAGE", "0", "still_00006402_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「隊長にパイズリしながら、おまんこ濡らして、おっぱい発情させちゃってる\nドスケベ隊員に……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0203217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「びゅーっ、びゅーっと、隊長のおちんぽに溜まっている濃厚なやつー。お願\nいしますー……。ねー……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0203218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「んっ、んんっ。はぁ、はぁ……ああ……っ。隊長、隊長……っ。精液、ぴゅ\nっぴゅー、ぴゅっぴゅー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0203219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「射精……射精して……して……！　んっ、んっ、んっ、んっ！　はぁ、はぁ\nはぁ……ああ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0203220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「んんんっ！　あっ、ああぁっ！　あああぁぁぁああぁぁ～～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0203301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00006402_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「また、勢いよくでましたね。ンッ！　すっごい、またまた濃いやつ、濃厚ね\nっとり汁……。ああ……さすがですー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0203302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「やっぱり隊長のおちんぽすごい……。こんなにいっぱいだしちゃうんですか\nらー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0203303" ]},
		{"command":[ "SETIMAGE", "0", "still_00006402_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「射精と一緒に、私のおまんこもイッてました？　あははー、バレちゃいまし\nたか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0203304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「隊長にいっぱい射精されながら、おまんこヒクヒクさせていたら、そりゃあ\nバレますよねー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0203305" ]},
		{"command":[ "SETIMAGE", "0", "still_00006402_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「だって、素敵なおちんぽからでる精液ですよ？　こんなの受け止めたら、ア\nクメ必須にきまってるじゃないですかー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0203306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「えへへ、精液受け止めてイッちゃうエロまんこを見せるのは、隊長だけです\nよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0203307" ]},
		{"command":[ "SETIMAGE", "0", "still_00006402_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「特等席で、私のおまんこがイクところを見せちゃいましたね……。な、なん\nだかいまになって猛烈に恥ずかしく……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0203308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「ちょ、ちょっと隊長！？　そんな腰を押さえつけて、あの、もう終わりでい\nいんですよね！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0203309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「イッたあとのおまんこをもっとよく見せろって？　ああっ、ちょっと、いま\nは勘弁してくださいーっ！！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0203310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「ひゃああっ！　おちんぽがにゅるんて飛び出して……っ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0203401" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「んひゃああっ！　ああっ、おちんぽが暴れて、精液がいっぱい……っ！　ん\nんっ、んんーっ！　びゅびゅーってーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0203402" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00006402_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁっ、すっごい……すっごい匂い……。粘り気も……こんなに…\n…ねっとりしてる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0203403" ]},
		{"command":[ "SETIMAGE", "0", "still_00006402_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「隊長、容赦なくぶっかけましたねー。んふふ、まあ、隊長の精液だからいい\nですけどねー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0203404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「でも……でもこの、隊長の濃い匂いは……。すぅー……はぁー……。や、や\nばいですー……んっ、んん……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0203405" ]},
		{"command":[ "SETIMAGE", "0", "still_00006402_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「あ……っ、ああ……っ！　ビクッと、身体が……。んふふ……隊長のお察し\nの通り、イッてしまいました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0203406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「隊長のおちんぽは、本当にエッチで、強いですねー。まさか精液の匂いだけ\nでイかされてしまうなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0203407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「え？　それは私が変態なだけだろうって？　もう、失礼しちゃいますね。私\nが誰彼かまわず欲情する痴女なわけないでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0203408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「こんなにメロメロになってしまうのは、隊長のごりっぱな武器の前だけです\nー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0203409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「んふふ、よく頑張りましたね、隊長のおちんぽさん。いいこいいこ、ですよ\nー……」", "NORMAL" ]},
