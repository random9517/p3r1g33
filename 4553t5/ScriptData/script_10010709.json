		{"command":[ "PLAYVOICE", "v2_001_010107090008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「宇宙の別の星に飛ばされたかと思えば……ほ……ほほほ北海道だと！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010107090009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「猿の惑星なんてものはなく……。私たちはただ、ロケット打ち上げに失敗し\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090107090004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「北海道に不時着していただけだったのか……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090107090005" ]},
