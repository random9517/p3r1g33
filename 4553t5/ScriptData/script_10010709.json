	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "PLAYBGM", "BGM_006" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "結局、寒さに負けたうえに多勢に無勢で……。", "NORMAL" ]},
	{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "俺達は猿の大群に捕まってしまった。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「踏んだり蹴ったりだぞ、これは……」", "NORMAL" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「下僕……。貴様が役に立たないから……！　うううう……寒い……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010107090001" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "1", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「い、今はそんなことで争っている場合ではないだろう……ぶるるるるる……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090107090001" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "唸り、震える俺達を猿は神輿のように担ぎ上げ……吹雪の中をえっほえっほと\n運んでいく。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "逃げ出すにしても、両手両足を縛られてしまって……。それになにより！", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「もう抵抗する気力も体力もねえ……」", "NORMAL" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "猿１" ]},
		{"command":[ "SETTEXT", "「キッキ！　キッキ！　キッキッキ！」", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "猿２" ]},
		{"command":[ "SETTEXT", "「ウキーキッキッキ！　キキー！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「うわー！　揺さぶるな、上下に揺らすなぁあ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010107090001" ]},
	{"command":[ "SETCHARA", "0", "char_00000401_01", "3", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「もう少し優しく運べないのー！？　　いやん！　へんなとこつかまないでー\nっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010107090001" ]},
	{"command":[ "SETCHARA", "0", "char_00000601_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……あいつらは無駄に元気だな。しかし……どこに向かってるんだ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「わかりません……猿たちのすみかでしょうか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010107090001" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「も、もしかして、猿たちの神様かなんかの、生贄にされちゃうんじゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010107090001" ]},
	{"command":[ "SETCHARA", "0", "char_00001201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「い……生贄……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ひっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010107090002" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "長い棒にくくりつけられ、焚火の上でぐるぐる回転させられる図が頭に浮かぶ\n。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うぁああああー！　やめてくれ！　俺たちは美味くねえし栄養もねえぞー！\n」", "NORMAL" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そ、そうだ！　栄養はなくカロリーだけだ！　食っても体に悪いだけだぞー\nっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010107090003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ルナテミスがいくら身体を揺らしても、尻がぷりぷり左右に動くだけだ。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ああああ！　猿のくせに！　猿のくせに、どうしてこんなに縛り方が上手い\nのだっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010107090004" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ですね。猿にしては、ずいぶん知能が高いです。もしかして彼らにも彼らの\n文化があるのかも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010107090001" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「呑気に感心している場合かぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010107090005" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「落ち着け、ルナテミス。無駄に体力を消耗するな。暴れるのはヤツらの目的\n地に着いてからでいい。それまでは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090107090002" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「縛られたまま回復などするかぁ！　んぐっ！　だから揺らすなっ！　猿ーッ\n！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010107090006" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "猿３" ]},
		{"command":[ "SETTEXT", "「キキャー！！」", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "猿４" ]},
		{"command":[ "SETTEXT", "「キャキャキャキャキャキャキャー！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああもう！　猿とルナテミスの鳴き声がうるっせーーーー！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "bg_0133" ]},
		{"command":[ "DISPIMAGE","0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "……そんなこんなで１０分後。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "猿１" ]},
		{"command":[ "SETTEXT", "「ウキウキウキ！　キャッキャッ！！」", "NORMAL" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "どうやら、ヤツらの目的地についたらしく、俺たちはどさっ！　と地面に投げ\n落とされた。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "猿たち" ]},
