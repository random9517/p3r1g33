		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "DISPIMAGE","0", "true" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ここは北海道だったんだーっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "みんな" ]},
