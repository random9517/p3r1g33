	{"command":[ "SETCHARA", "0", "char_00000601_01", "1", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ですが、猿たちの信仰する神とはいったい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010107090002" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},


		{"command":[ "FADEIN", "NORMAL" ]},
