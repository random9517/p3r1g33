		{"command":[ "SETIMAGE", "0", "bg_0135" ]},
		{"command":[ "DISPIMAGE","0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ですが、札幌にしては人間の姿が見えません。これはいったい……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010107090004" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "3", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「……わからん」", "NORMAL" ]},
