{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000118_01_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ふふ……さあ、捕まえたぞ……もう離さないからな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1803101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「全く……ここまで、さんざん私のことを焦らしてくれたからな……しっかり\nと反撃はさせてもらうぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1803102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ふふっ、別にそんなに緊張することはない。私がするのは、夫に対してのご\n奉仕……それだけだからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1803103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「さあ観念したか？　そうだ、無駄な抵抗はせずに、素直に身を任せているが\nいい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1803104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「それにしても……しっかり大きくさせているじゃないか。ほら、このオチン\nポはどういうことだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1803105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「よっぽど私のご奉仕を待ち遠しく思っていたと見えるな。こうして、軽く扱\nいてやるだけで……あっ……ピクっとして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1803106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ふふ……手袋の感触が気持ちいいか？　当然だ、これは最高級の絹で編まれ\nたサテンの手袋だからな……滑らかさが段違いだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1803107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「皮の部分を……優しく包み込んで……ゆっくり上下してやれば……ほら……\nどうだ、気持ちいいんじゃないか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1803108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ふふっ、それは何よりだ。これも花嫁修業と思って、ずっと練習は欠かさな\nかったぞ。お陰で、ここ最近の朝食はずっとバナナだった位だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1803109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「だが、このオチンポはバナナよりはずっと丈夫だからな……もう少しギュッ\nとしても……あっ、跳ねて来るっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1803110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ……まるで駄々っ子のようだな。ふふ、いい子にしてろと言っても、こ\nのオチンポには難しそうだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1803111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そうだな、いつまでも焦らしたままというのも可哀想だ。そろそろ……んっ\n、ちゅっ……んっ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1803112" ]},
		{"command":[ "SETIMAGE", "0", "still_00000118_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁ……先端に軽くキスをしただけで、私も……その、いやらしい気分にな\nって来てしまう……んっ、あぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1803113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ダメだ……我慢できない……オチンポ……舐めてしまうぞ？　舐めてしまう\nからな……ちゅぷ……ちゅぱ……ぴちゃ……んちゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1803114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁっ、んむっ、れろっ、えろ……ちゅぷ……んちゅぷっ、ぴちゃ……ちゅ\nぱ……れろ……えろ……れろぉっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1803115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁぁ……んちゅぷ……不思議な感じだ……ちゅぱっ、むわっとする匂いが\nして……味も汗のような感じで……んっ、れろ、クセが強いのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1803116" ]},
		{"command":[ "SETIMAGE", "0", "still_00000118_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ちゅ、んちゅぷっ……すごく……美味しく感じて……愛おしくて、仕方ない\n……ぴちゃ……んっ、オチンポが……大好きになってしまってるんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1803117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「れろっ、んっ、えろぉ……んふっ、見えているか？　私の舌が……何度も何\n度も……あなたのオチンポを舐めているところ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1803118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁ……私は、どれだけいやらしい顔をしているんだろうな……ちゅぱっ、\nさぞ……だらしない顔で……オチンポを見てるに違いない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1803119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ、ぴちゃ、れろ……でも、止められない……んりゅっ、あなたの気\n持ちよさそうな顔と……この震えるオチンポと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1803120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「それを見比べながら……れろっ、んっ、唾液を塗り込めていく作業が……ち\nゅぷっ、楽しくて仕方ないんだ……れろ、んっ、オチンポ美味しい……りゅぷ\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1803121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んぁぁ……ちゅぱっ、あぁ……そろそろ、本格的にしてしまおう……りゅぱ\nっ、くぽっ、んくぷぅぅぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1803122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んふぁぷ……根本まで……咥えて……ひまっひゃ……くぽっ、んっ、ふむっ\n、んぶっ、じゅぽっ、くぽっ、りゅぷっ、んじゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1803123" ]},
		{"command":[ "SETIMAGE", "0", "still_00000118_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んふぅぅ……あぁ、太いな……んくぽっ、上手くやらないと……頬がいっぱ\nいになっへ……むずかひい……んりゅ、ちゅぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1803124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んふっ、大丈夫ら……無理してる訳じゃない……このオチンポの世話をする\nのは……じゅぽっ、妻としての大切な役目だしな、じゅぽっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1803125" ]},
		{"command":[ "SETIMAGE", "0", "still_00000118_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「れろ……んんっ、えろ……れろ……このまま射精するまで……しっかり、オ\nチンポにご奉仕するぞ……ちゅぱっ、んちゅっ、ぷちゅぅぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1803126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んふふっ……唇の感触がいいのか？　あぁ……ここの力加減は、一番気をつ\nけているところだからな……もっと褒めてくれてもいいんだぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1803127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ぴちゃ……んちゅぱっ、あ……んむっ、んぱっ、ちゅぱっ……はぁんむ……\nあむっ、くぽっ、かぷっ、はむぅ……んくぷぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1803128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ、本当に繊細な場所なんだな……ちゅぷっ、ちょっと血管の浮いている\n所をついばむだけで……身体が震えるのがよく分かる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1803129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁ……ちゅぷっ、我慢汁も……滲んで来た……りゅぱっ、ふふ……もう射\n精したくなったのか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1803130" ]},
		{"command":[ "SETIMAGE", "0", "still_00000118_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ、れろ……えろぉっ、れろっ、れろんっ、いいぞ……もちろん、精液は\n全部飲ませて貰うから……ちゅるっ、くぽっ……んちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1803131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ここからは、本気のピストンと……バキュームを味わってもらう……んっ、\nふっ、くぽっ、じゅぷっ、んじゅっ、じゅぷっ、んじゅるるるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1803132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んふぅっ、あぁ……先っぽがビクビク来てるっ……じゅるっ、んじゅぅぅっ\n、オチンポが脈打って……出したがってるのが分かる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1803133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「じゅぽっ、んふっ、深く咥えるからな……んりゅぷっ、全部頬張ったところ\nれ……たっぷりらひてくれ……んくぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1803134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ふぉらっ、吸うぞっ……じゅるっ、んじゅぅっ、じゅるっ、んじゅるるるる\nるるるぅぅーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1803135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んんんんっー！　んふっ、れたっ……んっ、んぐっ、んむぅっ、んっ……ん\nっふぅぅぅぅぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1803136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000118_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「こくっ、んんっ、あぁ……中れ……跳ねてる……んっく、新鮮な……ザーメ\nン……飲んでるぅ……こくっ、んくっ、んく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1803137" ]},
		{"command":[ "SETIMAGE", "0", "still_00000118_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ、んくんっ、んっ、んはぁっ……はふっ……はぁ……ふぅぅ……どうだ\n、気持ち……よかったか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1803138" ]},
		{"command":[ "SETIMAGE", "0", "still_00000118_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ふふっ……表情が全て物語っているようだな。私も、れろっ……旦那様の濃\n厚な精液を味わえて、とても充実している」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1803139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「愛する夫へのご奉仕だ。一生懸命にもなるさ……あぁ……愛おしいオチンポ\n……ちゅぷっ、いっぱい出してくれてありがとう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1803140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ちゅぷ……んっ、む……後始末と思ったが……れろ……ぺろ……やっぱり一\n回位じゃ、全然足りないって感じだな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1803201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んちゅぷ……ごまかしたってダメだ。目の前のオチンポが、勃起したままこ\nんなにビクビク震えて……どういうことだろうな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1803202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ふふ……何も言えないみたいだな。じゃあ、私が代わりに教えてやろう……\nほら……またオチンポをさすっていけば……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1803203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「このサラサラの感触……たまらないだろう？　とっても繊細な生地だから、\nヌルヌルの精液がすぐに染み込んで来るのだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1803204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そうすると、また少し感触が変わって……指をしっかり感じるようになる…\n…こんな風に……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1803205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ふふ……また、分かりやすく震えてる……んちゅっ、ちゅぷっ……ちゅ……\nちゅぷ……れろぉ……れる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1803206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ、精液の味……まだまだいっぱい残ってる……あれだけ私に出しておい\nて、もっとして欲しいなんて……いやらしいオチンポだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1803207" ]},
		{"command":[ "SETIMAGE", "0", "still_00000118_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ちゅぷっ、そして……んふっ、そんなオチンポを美味しそうにおしゃぶりす\nる私も、どうしようもなく淫乱な妻なんだろうな……ちゅぱ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1803208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「こんな淫らな妻は嫌いか？　オチンポに目がない……舌を下品に伸ばして、\nれろれろと舐めしゃぶるメスは……はぁ……んちゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1803209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ふふ……よかった。あなたなら、きっとそう言ってくれると思っていた……\nだから、私も、もっともっと淫らに……夫を悦ばせたいと思うんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1803210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「れろ……んっ、んりゅぅ……れろ……れろぉんっ……舌がよーく見えるよう\nに動かして……尿道口を何度もついばんで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1803211" ]},
		{"command":[ "SETIMAGE", "0", "still_00000118_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んちゅぅぅ……よだれをいっぱい垂らして……あぁ……また、思いっきり…\n…咥えるぅぅ……んちゅぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1803212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んくぽっ、はむぅ……んっ、りゅぷっ……はぁん……口いっぱいに頬張って\nるぅ……んりゅっ、れろ……もごっ、んくぷぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1803213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「じゅるっ、優しく……竿を咥えてぇ……りゅぷっ、扱く……ずりゅずりゅっ\n……擦るっ……んぷっ、くぽっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1803214" ]},
		{"command":[ "SETIMAGE", "0", "still_00000118_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あはぁ……んっ、じゅぷっ、わらひ……いやらしい顔してるっ……けど、止\nまらないっ……オチンポご奉仕……したいからぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1803215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ、くぷっ、オチンポ……おいひぃっ、オチンポ……好きっ……ちゅぱぁ\nっ、あなたも……オチンポも、愛してるぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1803216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ぷぁっ……あぁっ……オチンポ……ビクビクしてるっ、射精……また……し\nたがってるっ、じゅぷっ、じゅるるるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1803217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んふぅっ……いいぞ……今度は、あなたの……好きなようにして……欲しい\n……ちゅぱっ……りゅぱっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1803218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「また……飲ませてもっ、じゅるっ……顔に掛けてもっ……じゅぷっ、どんな\n風にでも……してっ……ひてぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1803219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「さあ……んりゅぷっ、どうするんだっ……？　オチンポ……もう限界だろう\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1803220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「まら……口にっ……んんっ、いいぞっ……また咥えるからっ……のまへてっ\n……ん、じゅるるるるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1803301" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んふぅっ！　むぐっ、んむっ、んっ……んくっ……んっ、んふぅぅぅんっ…\n…！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1803302" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000118_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁ……んっ、こくんっ……喉に……絡む……んんっ、すごい……さっきよ\nり、もっと……味が……濃くなって……んふぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1803303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ちゅぷっ……うまくしないと……ちゃんと飲みきれない……んっくっ、こく\nっ、んくっ、んくんっ……あぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1803304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んはぁっ……はぁ、はぁ……はぁ……どうだ、何とか……飲めたぞ……ふふ\nっ、勢いに……負けるかと思ったがな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1803305" ]},
		{"command":[ "SETIMAGE", "0", "still_00000118_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あ……そ、そんなに頭を撫でなくても……これは、妻の務めなのだから、当\n然のことなんだからな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1803306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ちょっと待っていてくれ、最後まで後始末をしなくてはならないからな……\nちゅぷっ……オチンポを清めるのも、大切な妻の役目だ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1803307" ]},
		{"command":[ "SETIMAGE", "0", "still_00000118_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「れろ……ぴちゃ……うむ、よし……これで、すっかり綺麗になったぞ。オチ\nンポ……本当に、頑張ってくれたな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1803308" ]},
		{"command":[ "SETIMAGE", "0", "still_00000118_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ふふ……満足そうな顔をする。それでこそ、ご奉仕のしがいもあったという\nものだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1803309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そうだな、必要な時にはいつでも言ってくれ。何と言っても私はあなたの奥\nさんなんだからな……ふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1803310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「顔に……掛けたいのかっ？　あぁ……もちろん好きにしていいっ……出して\nくれっ、顔に……いっぱい浴びせてぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1803401" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あぅんっ！　んぁぁぁっ……あぁっ……出てるっ……また、いっぱいっ……\n精液っ……出てるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1803402" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000118_01_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んふぁ……粘っこいのがどんどん溢れて……あぁ……まだ出る……どれだけ\n出すつもりなんだ……んはぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1803403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、やっと……落ち着いたか……んちゅぷっ、こぼれてしまう…\n…れろ……せっかくの精液が勿体ない……ちゅぱ……ぴちゃ……ちゅぷん……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1803404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「れろ、ちゅぱ……んちゅ……えろ……んりゅ……れろ……うん、これで……\n何とか舐め取れたみたいだな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1803405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「どうせなら、このまま掃除までしてしまおうか。もう少し大人しくしていて\nくれ……れろ……ちゅぷ……んっ、ぴちゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1803406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「うむ、これでいい。ちゃんとオチンポも綺麗になった。本当によく出してく\nれたな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1803407" ]},
		{"command":[ "SETIMAGE", "0", "still_00000118_01_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「それだけ、奉仕のレベルが高かったと？　ふふっ、そうだろう、そうだろう\n。私が心を込めて尽くしたのだからな……当然のことだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1803408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「でも、よかった……ちゃんと喜んでもらえるかは心配だったからな……上手\nく出来て、ホッとしているところもある……だが、今日で自信もついた」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1803409" ]},
		{"command":[ "SETIMAGE", "0", "still_00000118_01_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「だから、またムラムラしたらいつでも言ってくれ。今度はもっとすごいご奉\n仕をするぞ。何と言っても私はあなたの奥さんなんだからな……ふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1803410" ]},
