{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000212_01_02" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「Dr.サイレーンから新しいプラグを試して欲しいって言われたの。その…\n…『ご奉仕プラグ』って言うんだけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1203101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あなたも知っていると思うけど、このスーツは挿入されたプラグによって私\nの能力をアップさせるの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1203102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「だから、このプラグを使えば、私のご奉仕能力がアップするってことなんだ\nけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1203103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「え？　ただちにそうにゅうしたまえ？　そ、そう……。そこまで言うなら、\nこのプラグを使ってみるね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1203104" ]},
		{"command":[ "SETIMAGE", "0", "still_00000212_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「お尻の穴に、プラグを挿れて……ンッ、んぅ……いつものプラグより、ちょ\nっと大きい……？　んっ、はぅう……っ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1203105" ]},
		{"command":[ "SETIMAGE", "0", "still_00000212_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ああっ、頭に、ンッ、すっごくエッチな内容が、流れ込んできて……っ！　\nはぁっ、はぁっ、なに……これ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1203106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「う、うん……平気……。大丈夫だから、ね……あなたのオチンチンに、ご奉\n仕させて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1203107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……。オチンチン……。ん……んちゅ……ちゅぅ……。んふぅ\n……ちゅぱ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1203108" ]},
		{"command":[ "SETIMAGE", "0", "still_00000212_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「勃起して……ガチガチになってる……んちゅっ、これ……どうやったら気持\nちよくできるのか、わかっちゃって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1203109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「舌が、勝手に……んちゅるっ、ちゅぱっ。オチンチン、ペロペロって……ん\nっ、ちゅちゅっ、んれろっ、れろぉっ、んちゅるるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1203110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「オチンチン、おいしい……。んれろ、れろぉ……。いっぱい舐めちゃう……\nんちゅっ、れろれろれろっ、れろぉ……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1203111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「オチンチンの根元から……先っぽまで……。よだれたっぷりの舌で、べろぉ\n～んって、舐め上げて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1203112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「裏筋のところ……れろれろれろって、舌先でくすぐるの、気持ちいいでしょ\n……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1203113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あなたのこと……んちゅっ、いっぱい気持ちよく、できてるかな……？　ん\nれろっ、れろれろっ、ンッ、ちゅばっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1203114" ]},
		{"command":[ "SETIMAGE", "0", "still_00000212_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んちゅっ、ちゅぶっ、ん、んちゅ、ちゅ……。んふ……。ちゅ、ちゅぱっ、\nんちゅぅ……ちゅぱっ、んっ、んんぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1203115" ]},
		{"command":[ "SETIMAGE", "0", "still_00000212_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「オチンチンが、どんどんおっきくなってる……。ふふっ、確かにプラグの効\n果はあるみたい……んっ、ちゅぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1203116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んっ、ちゅ、ちゅぱっ。んん……ちゅ、ちゅ……ちゅるっ、んふぅ……れろ\n、れろぉ……んちゅるっ、べろぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1203117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「もっと、先っぽ……んれろっ、れろれろっ、いっぱい舐めちゃうね……。ふ\nふっ、よだれでぬるぬるにしちゃうから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1203118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んれろ、れろれろれろっ。先っぽ、舐めまわして……んれろっ。先走り？　\n溢れてきちゃってるね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1203119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「じゃあ、今度は咥えるね。んぁ……む……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1203120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んっ、んんぅ……！？　口の中、オチンチンが入った途端に、なんだか気持\nちよくて……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1203121" ]},
		{"command":[ "SETIMAGE", "0", "still_00000212_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んふっ、ちゅるっ、ちゅるっ、ちゅるるっ！　んっ、動くね……んじゅるる\nっ、じゅぶっ、じゅぶっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1203122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「硬くて、熱い……おっきなオチンチンで……。んじゅるっ、口の中……ちゅ\nぶっ、いっぱいに……なって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1203123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ちょっと苦しいけど……ンッ、身体の、奥……というか、お尻が……んちゅ\nるっ、疼いて、きて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1203124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んっ、んっ、ちゅぶっ、ちゅるるっ！　んふっ、ちゅぶっ、ちゅぶっ、ちゅ\nるるっ、んっ、ちゅばっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1203125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「オチンチンに、ご奉仕しながら……んちゅっ、手が……んっ、お尻、いじっ\nちゃう……んっ、じゅるるっ、んふぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1203126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んんっ、じゅぶっ、じゅぶっ、んふぅ……。じゅるるっ、んっ、んっ、じゅ\nぶっ、じゅぶっ、んぅうっ、んふぅうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1203127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「こんな……オチンチン舐めながら、オナニーしちゃうなんて……んじゅるっ\n、恥ずかしい……のにぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1203128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「でも……んっ、じゅばっ。あなたが興奮して……オチンチンが気持ちよくな\nってくれるなら……んっ、じゅるるっ、じゅぶっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1203129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「どんどん、エッチになっちゃう……！　んじゅるっ、じゅぶっ、あなたもも\nっと、私のお口……感じてぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1203130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んふっ、じゅぶっ、じゅぶっ、じゅるるっ！　んんっ、んふっ、じゅぶっ、\nじゅぶっ、じゅるっ、じゅぶっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1203131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んっ、んんっ、口の中……先走りの味でいっぱい……んじゅるっ、エッチな\n味……じゅぶっ、私も興奮しちゃう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1203132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「先走りだけじゃなく……んちゅっ、精液も、出していいんだからね……じゅ\nぶっ、じゅぶっ、じゅるるるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1203133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ね、出して……。じゅぶっ、じゅぶっ、精液……んっ、私の口に……出して\n……んじゅるっ、じゅちゅちゅぅうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1203134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んっ、んんんっ！　んふぅうううっ！　んっ、んぁっ、出て……出てる……\nんっ、んんぅ……精液ぃ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1203135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000212_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ん……すごい……。口いっぱいに……んぁっ、あなたの……ドロドロしたミ\nルクが……いっぱぁい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1203136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んっ、んくっ……ごく……っ。すごく濃いね……喉にひっかかっちゃうくら\nいで……んっ、それにぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1203137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「飲みこむと、ますます身体が熱くなって……。はぁ……はぁ……。お尻の穴\nも、ジンジンしちゃってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1203138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あなたのオチンチン……まだ、おっきいままだね……。んっ、プラグが、も\nっとご奉仕しろって、命令を……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1203139" ]},
		{"command":[ "SETIMAGE", "0", "still_00000212_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あなたもまだ、満足してないみたいだもんね。もっと、ご奉仕するから……\nいっぱい気持ちよくなって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1203140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んっ、じゅぶっ、じゅぶっ、じゅるるぅっ！　さっきあんなに射精したのに\n、ぜんぜん萎えてない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1203201" ]},
		{"command":[ "SETIMAGE", "0", "still_00000212_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「一回射精したくらいじゃ満足できないよね……んじゅぱっ、大丈夫、満足す\nるまでしてあげるから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1203202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んっ、んふっ、じゅるるっ、んっ、じゅぶっ、じゅぶっ。口の中が、じゅる\nっ、エッチな味で、いっぱい……じゅるるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1203203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「オチンチン、美味しくて……んっ、私もどんどん……じゅるるっ、よだれが\n、溢れてきちゃってる……んじゅるるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1203204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「も、もっと強く吸う？　んっ、じゅるるっ、わかった……んっ、じゅるっ、\nじゅるる……んっ、じゅぶっ、じゅぶっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1203205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「じゅぷっ、じゅぷっ、んんっ、じゅるるるっ！　んふぅっ、じゅぶっ、じゅ\nじゅじゅっ！　んじゅるるるっ！　じゅぼじゅぼじゅぼっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1203206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ふふっ、すごく気持ちよさそうな顔してる……。んっ、あなたのそんな顔見\nたら、私また……手が……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1203207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「お尻のプラグを、いじっちゃう……んっ、じゅるっ！　プラグでお尻の中、\nぐりぐりって……じゅるるっ、んっ、んんぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1203208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「と、止まらないの……んじゅるっ、あなたにご奉仕するの、すごく気持ちよ\nくって……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1203209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「オマンコからも、お尻からも……んっ、じゅるるっ、イヤらしいお汁が溢れ\nてきちゃって……んっ、んじゅるっ、じゅぱっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1203210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「奉仕しないといけないのに、ンッ、指で……んはっ、気持ちよくなっちゃう\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1203211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「い、いいの？　このままオナニーし続けたほうが興奮する？　じゃあ、その\n代わり……私の口を好きに使って……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1203212" ]},
		{"command":[ "SETIMAGE", "0", "still_00000212_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「お口、しっかりすぼめて……オチンチンに吸い付いて……んちゅっ、ご奉仕\nするから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1203213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んんっ、んじゅっ、じゅるるっ！　んっ、激しく……んふっ、じゅるるるっ\n！　オチンチン、いきなりぃ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1203214" ]},
		{"command":[ "SETIMAGE", "0", "still_00000212_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「こうやって、んじゅぶっ、口の中で舌を動かして……じゅろろろっ！　出し\n入れされるオチンチン、気持ちよくするね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1203215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んじゅっ、じゅぶっ、じゅぶっ、んじゅるるっ！　んっ、んっ、オチンチン\n深い……んじゅぶっ、じゅぼっ、じゅぼっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1203216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「オチンチンで口の中、んじゅるるっ、かき混ぜられて……ンッ、先っぽ、喉\nまで届いちゃってる……んっ、じゅぷっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1203217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ビクンビクン暴れてっ、んじゅるるっ！　我慢できなくなってる……？　ん\nっ、いいよ、射精して、いいから……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1203218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「好きなときに、んっ、じゅぶじゅぶっ！　好きなように射精しちゃっていい\nからね、んぶっ、んぶっ、んぶっ、んぶっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1203219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「私も……じゅぶっ、あなたの精液……欲しい……欲しいの……んっ、んっ、\nじゅるるっ、じゅぶっ、じゅるるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1203220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んんっ、んんぅぅうううっ！　んっ、むぐっ、んっ、んんぅぅうううっ！！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1203301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000212_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んっ、んじゅっ、じゅるる……っ、ちゅぶぅ……。口の中に……んぅ……精\n液が……出てるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1203302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「まだまだこんなに出るなんて……。ンッ、全部、飲まなくちゃもったいない\nね……んくっ、じゅるるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1203303" ]},
		{"command":[ "SETIMAGE", "0", "still_00000212_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「じゅる、じゅる、じゅるる……っ！　んっ、最後の一滴まで……んっ、オチ\nンチンから……吸い上げて……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1203304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んじゅじゅじゅ……じゅるる、んっ、じゅるる……っ！　んくっ、んっ、ん\nん……ちゅっぽん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1203305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「とっても美味しい精液……ごちそうさまでした……。ふふっ、ご奉仕プラグ\nのおかげかな？　いっぱい射精したね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1203306" ]},
		{"command":[ "SETIMAGE", "0", "still_00000212_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「でも……あなたがこういうご奉仕が好きなら、プラグなしでも私がんばって\n覚えるからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1203307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「だって、あなたのオチンチンだったら、こんな道具に頼らなくったって気持\nちよくしてあげたいし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1203308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「わっ。またおっきくなった。もしかして、もっとしてほしいの？　ふふっ、\n本当にスケベなんだから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1203309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「じゃあ、もっとしてあげる。今度はプラグを抜いてね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1203310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んっ、ああっ、ああぁああっ！　精液っ、んっ、顔に……かかって……はぁ\nっ、はぁあああぁぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1203401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000212_01_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「熱いのが、いっぱい……っ！　あっ、ああっ！　これだめっ、イッちゃう…\n…イッちゃうの……んっ、ああぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1203402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んはぁ……はぁ……ああ……。あなたの精液……ドロドロで……すっごい臭\nい……んはぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1203403" ]},
		{"command":[ "SETIMAGE", "0", "still_00000212_01_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「たくさん浴びながら……お尻で……お尻のプラグで……イッちゃった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1203404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ご奉仕プラグ……どうだったかな……？　えっと……あなたに満足してもら\nたら、いいんだけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1203405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「……わっ、ちょっと、まだまだこんなに大きい！　えっ、私のご奉仕、全然\n足りなかった？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1203406" ]},
		{"command":[ "SETIMAGE", "0", "still_00000212_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「それとも、もっともっとご奉仕して欲しいってこと……？　ふふっ、そうい\nうことなら、うん、もっとしてあげるよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1203407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「このプラグも、あなたが満足してくれるまで止まらないと思うから……んち\nゅっ、だから、もっとしよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1203408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「せっかく強化された私のご奉仕、もっともっと、あなたには味わってほしい\nから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1203409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ふふっ、私のご奉仕口マンコ、いっぱい使ってね」", "NORMAL" ]},
