		{"command":[ "PLAYVOICE", "099_0104101" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「あれあれあれ～？　隊長さん？　そんなに興奮して、どうしたのかなぁ～？\n」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0104102" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「え？　この状況を見ればわかるだろうって？　わかんないなぁ～？　隊長さ\nんの口からぁ、あーしと何したいのか、説明してみて～？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0104103" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「ちゃんと説明してくれないと～？　入れてあげないよぉ～？　えへへへへ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0104104" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「ほうほう？　あーしのアソコに、ギンギンになったチンポを挿入したい？　\nそうですかそうですか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0104105" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「じゃあ、キチンとお願いしないとねー？　隊長さん？　何て言ったらいいと\n思う～？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0104106" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「なになに～？　『醜く膨れ上がった哀れなチンポを、かわいいシャラク様の\nアソコに入れさせてください』だって～？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0104107" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「あはははははは！　しょうがないなあ！　みっともないなあ！　チンポの先\nから涙流してお願いなんて！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0104108" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「仕方ないなあ。かわいそうだから入れさせてあげちゃおっかな～？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0104109" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「ふふふふ……いいよ？　入れさせてあげる～。もう、濡れてるから自分で入\nってこられ――ふぁあああっ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0104110" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「あ、ああああっ！？　いきなり！？　もう！　スケベなんだからぁ……ああ\nあああっ！　あっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009901_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0104111" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「はぁあ～……いきなりだけど、気持ち……いいっ……！　あ、あ、あ、ああ\nああっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0104112" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「はぁああ～……隊長さん、動いて。ゆっくり動いて……あ、ああん！　そ、\nそう、そんな感じで……んっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0104113" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「ん、ん、んんんっ！　ふぁあ……ううっ、あっ、あ、はぁああん！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0104114" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「そう、そうだよ～隊長さん。あーし、なんだか気持ちよくなってきちゃった\n……んんっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0104115" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「ね、隊長さん？　あーしの中、さっきよりヌルヌルしてきてない？　あ、や\nっぱり～？　そうだと思ったんだ～」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009901_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0104116" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「だって、隊長さんのチンポがあーしの中でゆっくり動いて、中にこすれて、\nとっても気持ちいいから……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0104117" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「だから、だんだん濡れてきちゃうんだよぉ～？　んんんっ！　あ、あ、ああ\nあん！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0104118" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「ね、ねえ？　隊長さん？　隊長さんも気持ちいい？　気持ちいいでしょ？　\nそうだよね～？　だって、あーしとしてるんだもんねぇ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0104119" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「いいんだよ～？　隊長さん。もっと激しく動いても～？　ちゃんと、お願い\nしてくれたらね～？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0104120" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「おっとっと、速攻でお願い～？　『シャラク様の中をこの粗チンで、もっと\n激しくこすらせてください』って～？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0104121" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「うふふふふ、しょうがないなあ～？　隊長さんは、ホントに欲望に正直って\n言うか、そのことしか考えてないんだね～？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0104122" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「いいよ～？　好きなだけガンガン動いて……おぉおおっ！？　んはぁっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009901_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0104123" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「な、何よ～。許可したとたんに、おサルさんみたいに腰振って――はぁああ\nあん！　ああんっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0104124" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「あ、あ、あ、あ、すごい！　隊長さんの動きが……予想以上っ！　はぁああ\nあん！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0104125" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「あ、あ、あ、あ、あ、いいっ！　あああん！　奥まで届いたぁ！　はああっ\n！　ふぁっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009901_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0104126" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「んんんん……すごいっ！　激しいっ！　隊長さん、がんばってるねぇ～？　\nあーしも気持ちいいよぉ……ああん！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0104127" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「あんっ！　あっ、あっ！　はぁあああ～ん！　イエス！　オーイェッ！　そ\nこっ！　そこ、こすってっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0104128" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「あああああ……っ！　隊長さんの、さっきよりもっと硬くなってる！　気持\nちいいの？　気持ちいいんでしょっ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0104129" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「あぅっ！　あっ！　あっ！　あああっ！　はぁああん！　動きもどんどん激\nしくなって――はぁああん！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0104130" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「あ、あはははは……なぁに？　隊長さん。もうイカせてほしいの？　シャラ\nクの中に、精液いっぱい出させてほしいの？　んっ……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009901_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0104131" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「いいよ……！　あーしも、気持ちよくなってきたし……このまま、ズンズン\n動いて、こすって、イカかせてくれたら……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0104132" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「あああああっ！？　さっそく！？　そう！　そんな感じで！　奥までズボズ\nボ……はぁあああん！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0104133" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「ああああっ！　んんん！　！　はあああ――あ、あ、あ、あ、来る！　来そ\nう！　イキそう……オーイェッ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0104134" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「あ、あ、あ、あ、あ、あ、あああああああああーっ！」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009901_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0104135" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「んあぁあああああっ！？　隊長さんも！？　隊長さんもイッたのっ！？　ふ\nあぁああっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0104136" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「あ、あ、あ、ああああん！　出てるぅ！　あーしの中に、熱くてヌルヌルの\nが出てるぅ！　わかる！　わかっちゃうぅ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0104137" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「ああああ……はぁ……いい……あーしの中で、隊長さんのがじんわり広がっ\nてきて、あったかくて……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0104138" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「えへへへ、隊長さん。なかなかやるじゃないの……とっても気持ちよかった\nよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0104139" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「うん、隊長さんとシャラク、けっこう体の相性いいのかもね。今度また、エ\nッチしてもいいよ？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009901_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0104140" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「隊長さんが、きちんとお願いしてくれたらね！　あははははははっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0104201" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「え？　え？　えええっ！？　もうしたくなっちゃったの！？　さっき出した\nばっかりなのに！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0104202" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「しょうがないなあ……もう。それじゃ、来て」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009901_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0104203" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「お願い？　別にいいよ……免除してあげる。そのかわり、二回目は最初から\n激しく来て？　ね？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0104204" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「んああああんっ！　来たぁっ！　二回目のガチガチチンポぉ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009901_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0104205" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「ね？　あーしの中、ヌルヌルで熱いでしょ？　動きやすいでしょ？　はぁあ\nあん！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009901_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0104206" ]},
		{"command":[ "SETNAME", "シャラク" ]},
