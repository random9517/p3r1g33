		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0104207" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「あ、あ、あ、ああああっ！　隊長さん？　いいんだよぉ？　二回目は特別に\n、好きに動かせてあげる～♪　えへへへ……ああん！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0104208" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「ああっ！　はっ！　あああん！　そう！　そうやって……あああん！」", "NORMAL" ]},
