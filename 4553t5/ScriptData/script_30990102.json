		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「ああああああっ！　あ、あっ！　隊長さん……！　余裕、なくなってきたで\nしょ……！？　はぁあん！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
