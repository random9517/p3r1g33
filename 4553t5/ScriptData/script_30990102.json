		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0104209" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「あああ……気持ちいい。隊長さんの硬いチンポが、あーしの中の気持ちいい\nとこをぐりぐりこすって……はぁああん！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0104210" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「んっ、んん、んんんっ！　あ、動いちゃう。あーしも、腰動いちゃうっ！　\nはぁああああ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0104211" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「あ……隊長さんのチンポ、今、ピクッてしたぁ……あーしの動きが、気持ち\nよかったのかなぁ？　えへへへへ……」", "NORMAL" ]},
