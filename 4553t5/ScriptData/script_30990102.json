		{"command":[ "PLAYVOICE", "099_0104212" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「えい、えい、えい、えいっ！　えへへへへ。隊長さん、反応がかわいいなあ\n……はぁああん！」", "NORMAL" ]},
