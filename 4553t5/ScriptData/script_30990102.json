		{"command":[ "SETTEXT", "「ああああ……おなかのなか、あったかくて……中に出されるのって、やっぱ\nり気持ちいい……はぁ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0104304" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「二発目でもこんなに出てくる隊長さんって、やっぱりすごく元気だね……え\nへへへへ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009901_02_12" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0104305" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「ふぁああ……隊長さんの、まだじわじわ出てくる感じだし、あーしの中もピ\nクピク動いて、隊長さんのを搾り取ってるぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0104306" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「あ、でもさぁ～？　中にこんなに出されちゃうと、あーし、妊娠しちゃうか\nもしれないねえ？　今気づいたんだけど～」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009901_02_10" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0104307" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「あーしに子供ができたら、お姉ちゃんたちは三人とも伯母ちゃんだねえ？　\nえへへへへへ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0104308" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「ねえ、隊長さん？　できちゃったら責任取ってくれるんだよねえ？　パパに\nなってくれるんでしょぉ～？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0104309" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「なってくれるんだったら、またいっぱい中に出させてあげる～。えへへへへ\nへへへ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009901_02_12" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0104310" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「いいの？　パパになってくれるんだね？　うんうん。それならまた中出しし\nていいから……近いうちに、またセックスしようね～♪」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009901_02_10" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},
		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "PLAYVOICE", "099_0104401" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「あにゃああああ？　な、なんで抜いちゃうのぉお～！？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009901_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0104402" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「あ、あ、あ、ああああっ！　はああああん！　　かかってるぅ～！　隊長さ\nんの精液がぁ、あーしにかかってるぅ！」　", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009901_02_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0104403" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「ふぁああ……なんで外に出しちゃうのぉ～？　もったいないよぉ～！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0104404" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「『これはこれで気持ちよくないか？』ってぇ？　う～ん……そう言われてみ\nれば、そんな気もする……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009901_02_13" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0104405" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「っていうかぁ、そうかも知れないねぇ～。あーしも、だんだんそんな気がし\nてきたよぉ～？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0104406" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「隊長さんのベトベトネバネバと、くっさい臭いがあーしの体にしみこんでく\n……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0104407" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「えへへへ、あーし、今、隊長さんの精液でできてるようなものかもねぇ～？\n」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009901_02_15" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0104408" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「あれ？　ってことは――もしかしてシャラクって今、隊長さんの子供みたい\nなものってこと～？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009901_02_13" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0104409" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「えへへへ～。シャラク、隊長さんの娘だぁ～。それじゃ、パパにおねだりし\nてもいいんだよねえ～？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "099_0104410" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「ねえ、パパ～？　シャラクの中に、またその太いのぶちこんでねぇ～？　あ\nーしの、お・ね・が・い♪」", "NORMAL" ]},
