{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010007_01_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……どうだ、私のおっぱいと乳首の感触は……柔らかい中にコリ\nコリした感触が混じって、気持ちいいだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0703101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふふっ……そう怖がらなくていい。これはおまえへの感謝の印みたいなもの\nだからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0703102" ]},
		{"command":[ "SETIMAGE", "0", "still_00010007_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「おまえはただ、快楽に身を任せておけばいい。こうやって手でシコシコされ\nながら、ペニスで感じていろ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0703103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あっ、くっ、あふっ……！　亀頭のあたりを撫でると、ペニスが凄く反応し\nてくるぞ……このあたりが感じるのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0703104" ]},
		{"command":[ "SETIMAGE", "0", "still_00010007_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んんっ……はぁ、あぐっ、んっ……！　小刻みにビクビク動くたびに、ペニ\nスの先端が乳首に擦れてくるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0703105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んっ？　もっと根本の方までシコシコして欲しいのか……？　ああ、いいぞ\n……して欲しいことがあったら、遠慮せずに言うといい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0703106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「おまえが望むままにズリズリシゴいてやるし……なんなら、手じゃなくて口\nやアソコを使わせてやってもいいぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0703107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「……好きなところを使わせてくれるなら、このままおっぱいに挿入したい？\n　ほう……それはまた妙なプレイを思いついたものだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0703108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ニプルファック、というのか……なるほど。乳首を女性器に見立て、ペニス\nを挿入すると……ふふっ。いいだろう。私も興味が沸いてきたぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0703109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「普通は乳首の中にペニスなど入らないだろうが……ダークビキニンジャ・マ\nスターとなった私に不可能はない……！　んっ、くっ……あぐぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0703110" ]},
		{"command":[ "SETIMAGE", "0", "still_00010007_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んほっ……おぐっ、んおぉぉぉ……！？　乳首の穴が亀頭で広げられている\nっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0703111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「はぁ、んっ……ひっ、あぅ……！　ふふっ……！　どうだ……ちゃんと入っ\nているだろう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0703112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「だが、まだ先っぽだけだ……！　しっかりと奥まで突き入れるといい……！\n　あっ、うっ……！　んひっ、あっ、ひあぁぁぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0703113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「おっ、おおおぉぉぉ……！　いいぞ……！　亀頭が乳首の中に入り込んでき\nている……！　これは……かなり変な感じがするな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0703114" ]},
		{"command":[ "SETIMAGE", "0", "still_00010007_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「別に気持ち悪いわけではない……むしろ乳首を内側からズリズリされる感じ\nがして、かなり気持ちいいぞ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0703115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「はぁ……あっ、あはぁ……！　ちゃんと奥の方まで入ったぞ……ふふっ。ま\nさか本当に入るなんて思ってなかったといわんばかりの顔だな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0703116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ダークビキニンジャ・マスターである私に不可能はないと言っただろう。そ\nれとも、私の言葉を信じていなかったのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0703117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「自分からこんな変態じみたことをしたいと言い出したクセに……まったく。\n随分と馬鹿にされたものだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0703118" ]},
		{"command":[ "SETIMAGE", "0", "still_00010007_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふんっ……！　このニプルファックとやらはご褒美だが、私を信じられなか\nったのは万死に値する愚行だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0703119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「バツとしてこのままペニスを思いっきりシゴきまくってやる。すぐに射精し\nないよう、気合を入れておくんだな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0703120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あっ、あっ！　んひっ、あっ、うぐっ、あああぁっ！　乳首の中でカリが擦\nれまくってくるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0703121" ]},
		{"command":[ "SETIMAGE", "0", "still_00010007_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「おっぱいを前後に動かすと、気持ちいいところが強く刺激されて……！　あ\nっ、あっ！　声が自然と出てしまうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0703122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「穴をホジられているのに、アソコとは違うこの感覚っ……！　実にいいぞっ\n！　これは最高のプレイだっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0703123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふふっ……！　おまえも自分から動きたくてたまらないといった様子だな…\n…！　そんなに腰を前後させて、私の乳首の中を犯したいのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0703124" ]},
		{"command":[ "SETIMAGE", "0", "still_00010007_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「別に犯す分には構わないが……犯したいなら、相応の言い方というものがあ\nるだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0703125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「しっかりと口に出して言え！　情けなく腰をヘコヘコ振って、乳首をズポズ\nポしたいです！　乳首の中でびゅるびゅる射精したいです、となっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0703126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「……あははははっ！　たかがピストンのためだけに、そんな切なそうな声で\n懇願するとはな！　いいだろう！　自分から動くことを許可してやる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0703127" ]},
		{"command":[ "SETIMAGE", "0", "still_00010007_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「せいぜい情けなく腰を振り乱して、おっぱいからパンパンと卑猥な音を響か\nせてみろっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0703128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふっ、おっ……おおっ、んふっ、うぐぅ！　中々器用に腰を振るじゃないか\n……！　乳首の内側がカリに引っかかって、かなり気持ちいいぞ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0703129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「はぁ、んっ、あっ！　あっ！　あああっ！　激しすぎて、乳首が裏返ってし\nまいそうだ……！　その調子で、もっとピストンを繰り返せ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0703130" ]},
		{"command":[ "SETIMAGE", "0", "still_00010007_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あんっ、あっ、んんっ！　ひぐっ、うっ、んっ！　必死に動くおまえにサー\nビスだ。少し乳圧を強めてやろう……んっ、ぐっ……！　んふぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0703131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「おほおぉぉぉ……！？　おっぱいに力を入れると、ペニスの形がより強く伝\nわってくるぅ……！　それにさっきよりも強く震えて……あはあぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0703132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「こんなに震えるということは……そろそろイキそうなんだな……！　いいぞ\n……！　このまま乳首の中に出すがいい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0703133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「アソコやアナルでは絶対に味わえない、乳首内射精だっ！　普段と違う快楽\nに包まれながら、情けなく射精しろっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0703134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あっ！　あっ！　んっ、あっ！　そうだ……！　イケッ……！　おまえの無\n駄打ちザーメンを、思い切り乳首に吐き出してしまえっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0703135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んくううぅ……！　あっ、熱いのがこんなに……！　うぐっ、おおぉ……本\n当に乳首の中に出されているっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0703136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010007_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},	
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ペニスが跳ねるたびに、ドロドロの精子が乳首いっぱいに広がって……！　\nあああっ！　まるで乳首を弄られているようだ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0703137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んんっ！　あっ、あっ！　これは私もイッてしまうっ……！　乳首に精子出\nされながら、イッ……イクッ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0703138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あっ、ひっ、あぐっ！　あああぁっ！　まだびゅーびゅー出て……！　ぐっ\n、んひっ……！　あっ、本当にイクッ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0703139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふっ、んひっ！？　おっ、おぉぉぉ……！　イクッ……！　イクイクッ……\n！　イクぅぅぅっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0703140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、あはあぁ……！　これがニプルファックか……普段やらない\nプレイなせいか、いつも以上に感じてしまったな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0703201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふふっ……アソコや口で味わう精液もいいが、乳首で直接味わう精液も中々\n乙なものだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0703202" ]},
		{"command":[ "SETIMAGE", "0", "still_00010007_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あんんっ……！　乳首の中でペニスが膨らんでいるぞ……！　あんなに出し\nたのに、まだシたいというのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0703203" ]},
		{"command":[ "SETIMAGE", "0", "still_00010007_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「私の乳首でこんなに興奮するとは、おまえは本当に変態だな……だが、悪い\n気はしない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0703204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふっ……いいだろう。せっかくペニスが乳首に入ったままだし、もう一度シ\nゴいて射精させてやろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0703205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「うぐっ、おっ、んほぉ！？　あっ、おぐっ、んふうぅぅぅ！？　軽くおっぱ\nいを動かしただけなのに、亀頭がさっきよりも強く擦れてくるぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0703206" ]},
		{"command":[ "SETIMAGE", "0", "still_00010007_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「はぁ、んっ、あっ、あひっ！？　そ、そうか……！　先ほどの射精で、より\nいっそう滑りがよくなったせいだな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0703207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふふっ……！　これはシゴき甲斐があるというものだ……！　乳首を思い切\nり締め付けて、亀頭を刺激しまくってやる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0703208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ああっ！　んっ、あひっ！？　乳首気持ちいいっ……！　こんなに硬く勃起\nしてるのに、まだ乳首が大きくなってくるほどだ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0703209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「はぁ、あぐっ、あはぁ……！　おまえも動けっ……！　私の乳首を押しつぶ\nすように、ズポズポしまくるんだ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0703210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ああっ！　あっ、あはあぁっ！　いいっ！　いいぞっ！　その調子だっ！　\n思い切り腰を突き出して、ペニスをおっぱいに沈めていけっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0703211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「おまえがペニスを押し付けるタイミングに合わせて、私ももっとおっぱいに\n圧をかけてやる……！　んふっ、ふぐっ……！　んぐぅぅぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0703212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「はひっ、ぐっ、あっ……！　あはあぁぁぁっ！　乳首からずちゅ、ぐちゅっ\nて、いやらしい音がするな……！　それに臭いも濃いぞ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0703213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「真っ白な液体をまき散らしながらズポズポされてたら、まるで母乳を噴き出\nているように感じてしまうじゃないか……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0703214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んひっ！？　あっ、んはあぁ！？　な、なんだ……！？　急にペニスが大き\nく膨らんできたぞ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0703215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「私が妊娠して、ボテ腹になりながら母乳をまき散らす姿を想像して興奮した\nだと……！？　ふふっ……！　おまえは本当に変態だな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0703216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「想像で興奮するような変態にはお仕置きだ……！　激しくシコシコしまくっ\nて、さっき見たいに思いっきり射精させてやる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0703217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んんっ！　うぐっ、あっ、ふっ、あっ！　くっ、おおおぉ……！？　私の乳\n首の形が変わるくらい、圧迫しまくってやるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0703218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あっ、んっ！　あああっ！　乳首の中でペニスが暴れまくっているっ……！\n　射精したいと疼いているぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0703219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ほらっ！　出すがいい、変態っ！　乳首でズリズリされながら、絶対に孕む\nことのない場所に向かって、無様に精子を吐き出すがいい！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0703220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あはぁぁぁんっ！　また乳首の中に精子が出ているっ！　熱くて臭い汁が、\nびゅーびゅー出ているぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0703301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010007_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ、あひっ……！　乳首の奥まで精子がしみ込んでくるっ……！　\n気持ちのいいところに、勢いよく汁が飛んでくるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0703302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「こんなに感じさせられたら、またイクッ！　おっぱいに出されながら、イク\nぅぅぅ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0703303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あっ！　あっ！　イッてるのに、精子が次々に飛び出てきて……！　気持ち\nいいのが止まらないっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0703304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ぐっ、おっ！　おほぉぉぉ！？　またイクッ！　乳首イキするぅ！　あっ、\nあっあっ！　んはあぁぁぁあああぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0703305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んっ……あふっ……中々激しい射精だったな……乳首の中にペニスを挿れた\nだけなのに、ここまでイクとは思ってなかったぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0703306" ]},
		{"command":[ "SETIMAGE", "0", "still_00010007_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「それにしても、ニプルファックか……この気持ちよさは、クセになってしま\nいそうだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0703307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ビキニ姿だと挿れるのも容易いし、今後も定期的に取り入れたいエッチだな\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0703308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「……ん？　今後も、ということは、また近いうちにニプルファックをさせて\nくれるのかだと？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0703309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふふっ……そうだな。おまえがしっかりと私のために働き、頑張ったなら…\n…ご褒美としてまたさせてやらなくもないぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0703310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「えっ！？　あっ！？　乳首からペニスが抜けてっ……！　ひゃうううぅぅぅ\nっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0703401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010007_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「かっ、顔に精子がかかって……！　おっ、おいっ！　おまえ……！　出せと\nは言ったが、誰が顔に出していいと……んぶうぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0703402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あっ、うぐっ！　ま、まだ出るのかっ！？　いい加減射精を止めろ……！　\nくっ、あっ！　鼻や口に精子が入ってくるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0703403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「こんなのを味わわされたら、子宮が疼いてしまう……！　んっ、あっ……！\n　切ない感じが強くなってきて……あんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0703404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「くうぅ……！　あっ、んっ……！　あふっ、ぐっ、んふっ……！　いい加減\nにしろ……！　この変態がっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0703405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、はあぁ……！　勢いよくペニスを握ったら、ようやく射精が\n収まったな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0703406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「まったく……この私に向かって好き放題するとはいい度胸だな。よほど命が\n惜しくないと見える」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0703407" ]},
		{"command":[ "SETIMAGE", "0", "still_00010007_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふんっ。今更謝ったところで、許すわけがないだろう。おまえには再びバツ\nを受けてもらうぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0703408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「おまえは私のモノだということをしっかりと教え込んで、二度と好き勝手に\n射精しないよう調教してやる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0703409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「痛い思いもするかもしれないが、すぐにそれも快楽に代わるだろう。だから\n安心して、身をゆだねるといい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0703410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}