		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「この辺に、騒動の主がいるってことかい……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010021800001" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「どうなんでしょう……でも、イルルちゃんには確信があるようです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010021800001" ]},
		{"command":[ "SETCHARA", "0", "char_00001101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「うん、近くにいる……おとーさんのことも、何となく……分かる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021800001" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「しかし、果たしてどの辺りに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021800001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「はん、随分待たせてくれたじゃん！　てっきり、このままコイツを見捨てて\n、おウチでガタガタ震えてんのかと思ったし！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010021800001" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うっ……くっ……くそっ、離せっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「暴れてもムダだしー。アンタのへなちょこパワーじゃ、ヤムのコーソクは解\nけないよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010021800002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「おとーさんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021800002" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「なーにが、おとーさんよ。こんな人間ごときにべたべた甘えて……ドラゴン\nとして恥ずかしくないの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010021800003" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021800003" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ま、ヤムのことを見つけられるってことは？　多少は、力もマシになったっ\nてこと？　これで少し位は遊べるのかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010021800004" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「イルルは、あそびたくない。おとーさんとかえる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021800004" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「アンタに、ケッテー権なんてないし。それとも、ちょっとくらいコイツ痛め\nつけた方が本気になれたりするう？　んーっ……えろっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010021800005" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「こ、こらっ、頬を舐めるなっ、んひゃっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「おとーさんをはなして！　イルル……怒ってるんだから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021800005" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「怒ってる？　アンタが？　あはははっ、そんなぽやぽや顔で言われたって、\nなーんにも怖くないし！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010021800006" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「……今ならゆるしたげる。おとーさんを……はなして」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021800006" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「あん？　今……許すとか言った？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010021800007" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「おとーさんを連れてったこと……今だけ、ゆるしたげる……だから、おとー\nさんをはなして！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021800007" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ナニ、アンタがヤムにえらそーにメーレーしてんの？　ちょっとムカついた\nし……泣かせちゃう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010021800008" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「っ……！　こいつは……ヤバい気配だよっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010021800002" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「はっ、はひっ！　何となくですけどっ、危ない感じがするのはっ……わ、分\nかりますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010021800002" ]},
		{"command":[ "SETCHARA", "0", "char_00001101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「と、とにかく……一度、安全な所に避難を……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021800002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「バカ！　イルルを放って逃げてどうするんだよっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010021800003" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「だいじょうぶ、おかーさん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021800008" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「……イルル？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010021800004" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「ちゃんと、イルル……本気出す。おとーさんをたすけるために……イルルに\nねむってるチカラ、めざめて！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021800009" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「きゃあっ！　ひ、光がっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010021800003" ]},
		{"command":[ "SETCHARA", "0", "char_00001101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「この光はっ……くっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010021800005" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「来てっ、ヴィキニドラグーンっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021800010" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

