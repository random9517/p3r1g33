		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「いや、無茶を言わんで下さい。あんな勢いで突っ込まれたら、ワタクシなど\nひとたまりもありませんて」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021800010" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「てて……くそ、確かにそうだが……あ、そ、そうだっ……イルルはっ！？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「あの通りでございまして……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021800011" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021800012" ]},
		{"command":[ "SETCHARA", "0", "char_00016402_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「イルルっ！？　な、何だ、あの格好はっ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「本来の力を開放させた姿のようです。二人揃って、ヴィキニ対決という感じ\nですな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021800012" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「のんきなことを言ってる場合かいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010021800010" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「とは言いましても……とてもじゃありませんが、あそこに介入出来る雰囲気\nではありませんぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021800013" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「た、確かに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010021800009" ]},
		{"command":[ "SETCHARA", "0", "char_00001101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「さーて、見せてもらおうじゃないの、アンタのホンキってのをさっ！　はぁ\nぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010021800015" ]},
		{"command":[ "SETCHARA", "0", "char_00017501_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「イルル……ほんきでやっつけるっ！　えーいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021800013" ]},
		{"command":[ "SETCHARA", "0", "char_00016402_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「おおっとぉっ、へっ、当たらないよーっだ。今度はヤムの番っ……せりゃぁ\nぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010021800016" ]},
		{"command":[ "SETCHARA", "0", "char_00017501_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「ぜんぜんっ……あたらないっ！　せやーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021800014" ]},
		{"command":[ "SETCHARA", "0", "char_00016402_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「ひぁぁぁぁっ！　な、何かっ……空の周りで……すごい雷が鳴ってますっ！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010021800010" ]},
		{"command":[ "SETCHARA", "0", "char_00001101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「全く……まるで天変地異じゃないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010021800011" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「加勢しようにも、あんな場所でやり合われたら、我々は見てる位しか出来ま\nせんぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021800014" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「悔しいが、今のあたし達じゃ邪魔にしかならないか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010021800012" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「イルル……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「へぇ……全くヘナチョコだと思ってたけどっ、少しはやるじゃないのっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010021800017" ]},
		{"command":[ "SETCHARA", "0", "char_00017501_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「おとーさんに……あやまってっ！　そしたらっ、イルルっ……もうゆるした\nげるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021800015" ]},
		{"command":[ "SETCHARA", "0", "char_00016402_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「そーいうっ……いい子ちゃんなトコっ……イラッとするんですけど！？　ふ\nんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010021800018" ]},
		{"command":[ "SETCHARA", "0", "char_00017501_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「いーこにしてない子はっ……きらわれちゃうんだからっ！　えいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021800016" ]},
		{"command":[ "SETCHARA", "0", "char_00016402_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「アンタなんかにキラわれたって、何でもないしっ！　っりゃーーーーー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010021800019" ]},
		{"command":[ "SETCHARA", "0", "char_00017501_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「何か……戦ってるのは分かるんだが……気のせいか、じゃれ合ってるように\n見えなくもないな……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「争いは同じレベルでしか発生しないというやつですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021800015" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「それは、低いレベルの奴らの話だろ……あんな天上界の戦いで言ってもな…\n…」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「確かに、迂闊に巻き込まれたらメチャクチャにされそうですな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021800016" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「くそ……とにかく、無茶はするんじゃねーぞ、イルル……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}