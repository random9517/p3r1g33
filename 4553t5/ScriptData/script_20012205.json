		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_007" ]},
		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021800011" ]},
		{"command":[ "SETCHARA", "0", "char_00016402_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「は……あわわわ……あ、あれは……ビ、ビビ、ビキニ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010021800004" ]},
		{"command":[ "SETCHARA", "0", "char_00001101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ちちち、翔生子どの、イルル殿の発音によれば、ヴィキニドラグーンですぞ\n。ヴィ、です、ヴィ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021800003" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「ヴィ……ですか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010021800005" ]},
		{"command":[ "SETCHARA", "0", "char_00001101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ちょ、ちょっと待て！　そういうこっちゃないだろ！　イルルがあんな姿に\nなるなんて聞いてないぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010021800006" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ワタクシも、初めて知りました。何というか、かなりギリギリの所を攻めて\nらっしゃる感じですな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021800004" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ギリギリって言うか……アウトじゃないのかい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010021800007" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ふむ、まぁお母さんとしては、何かと心配なのはよく分かりますぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021800005" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「だれがお母さんじゃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010021800008" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「とは言え、際どいところで倫理規定は守っているようですから、はい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021800006" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「古文書には力の開放と書かれていましたけど……まさか、服まで開放してし\nまうなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010021800006" ]},
		{"command":[ "SETCHARA", "0", "char_00001101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「おお、なかなか上手いことを仰いますな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021800007" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「え？　あ、ありがとうございます……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010021800007" ]},
		{"command":[ "SETCHARA", "0", "char_00001101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「あははははっ、やーっとやる気になって来たじゃん！　そいつが、アンタの\nヤバいヤツってことね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010021800009" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「いいじゃん、いいじゃん、アガって来たわ！　いーわ、ヤムとヤッて、勝っ\nたらこいつは離してあげる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010021800010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ケド、アンタなんかが勝てるワケないから！　それを教えたげるっ、はぁぁ\nぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010021800011" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「きゃあっ！　ま、またすごい光がっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010021800008" ]},
		{"command":[ "SETCHARA", "0", "char_00001101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「くっ……この力の気配っ……かなりヤバいよっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010021800009" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「はぁぁぁぁあーーーーーーーーーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010021800012" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

