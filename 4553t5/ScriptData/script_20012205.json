		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「これで……ヤムの方も、エンリョなくパワー出しまくれるし♪　メチャクチ\nャ暴れちゃおっかなー♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010021800013" ]},
		{"command":[ "SETCHARA", "0", "char_00017501_01", "8", "CENTER", "0" ]},
