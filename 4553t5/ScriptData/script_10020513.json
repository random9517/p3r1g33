		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「えっ、だから俺だけじゃ決められないんだってば！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "投票はもちろん俺も参加するが、観客の投票があったうえでのこと。そう何度\nも説明しているじゃないか！", "NORMAL" ]},
