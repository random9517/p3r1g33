		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はぁ！？　たった１票なら無効だろ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「そんなことない。カツマ先生の１票なら１兆票くらいの価値があるから」", "NORMAL" ]},
