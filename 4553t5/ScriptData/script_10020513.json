		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「桁が増えてるんだが！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "なんとかごまかしたいところだが、流々那も今回ばかりは頼れそうにない。", "NORMAL" ]},
