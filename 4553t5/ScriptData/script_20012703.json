{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0022" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「……ううう、お腹、空いた…………これ、ヤバくない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021890001" ]},
		{"command":[ "SETCHARA", "0", "char_00010301_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "一蹴である。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "モチベーションが最低とはいえそれなりに戦闘経験を積んだ三人であったが、\n現れた二人にはまるで敵わなかった。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「うん、ヤバい……これ、負けイベントな気がする……お姉ちゃん、代表して\n『参りました』っていう役、お願いできる？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_010021890001" ]},
		{"command":[ "SETCHARA", "0", "char_00010201_01", "4", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ううう……ま、まだまだぁ……これからが、本番です……っ！　古人いわく\n……はー……はー……えーっと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021890001" ]},
		{"command":[ "SETCHARA", "0", "char_00010101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「うう、故事成語が思いつかない……考えておくから、ちょっと時間稼ぎして\nおくですよ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021890002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「えええ～～……故事成語のために、わざわざ時間使うとか……はぁ……ええ\nっと、使ってるスマホの機種、なんですか～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_010021890002" ]},
		{"command":[ "SETCHARA", "0", "char_00010201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "相変わらずわちゃわちゃとした三人を呆れたような目で見ながら、二人は剣を\n収める。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "敵意はなさそうだが、その目には諦めと悲しみに彩られていた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「……やれやれ、我が末裔とはいえ、情けないでござる……武家の娘ともあろ\nう者が、このように育ってしまうとは……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_104_010021890001" ]},
		{"command":[ "SETCHARA", "0", "char_00010401_01", "5", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「まあ、階級社会だった頃は遠い昔のことですし……それより、話が進まない\nから、こっちから勝手に自己紹介をしましょう」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00010501_01", "0", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_105_010021890001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「お聞きください、サムライテールのお三方。こちらのかたをどなたと心得ま\nすか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_010021890002" ]},
		{"command":[ "SETCHARA", "0", "char_00010501_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「……先祖様……なの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021890002" ]},
		{"command":[ "SETCHARA", "0", "char_00010301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「おおおー！　慧眼！　言わずとも伝わるとは……これぞ武家の血の為せる技\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_104_010021890002" ]},
		{"command":[ "SETCHARA", "0", "char_00010401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「……いや、自分で言ってたじゃん。『我が末裔とはいえ、情けない。でもと\nても綺麗に可愛くキュートに育ったね♪』って」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_010021890003" ]},
		{"command":[ "SETCHARA", "0", "char_00010201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "虎之丞" ]},
		{"command":[ "SETTEXT", "「ぐぬぬぬぬぬ……後半はまったく記憶にないが～～……まあよいでござる！\n　拙者、若苗虎之丞と申す！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_104_010021890003" ]},
		{"command":[ "SETCHARA", "0", "char_00010401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "虎之丞" ]},
		{"command":[ "SETTEXT", "「かの己亥（つちのとい）で悪霊と戦い、倒れ……魂となってさまよっておっ\nた。だが、この度、お亥さまの導きでまた地表へと蘇ったでござる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_104_010021890004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「……なるほど、そーいうことね。で、そっちの露出狂は？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_010021890004" ]},
		{"command":[ "SETCHARA", "0", "char_00010201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「南出愛奈（みなみで　あいな）よ。でも露出狂はひどいなぁ……まあ、そう\n思われても仕方ないんだけどさ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_010021890003" ]},
		{"command":[ "SETCHARA", "0", "char_00010501_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「ふ～ん……じゃあ、ご先祖様じゃないってこと？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021890003" ]},
		{"command":[ "SETCHARA", "0", "char_00010301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「そう。虎之丞さんのサポートとして雇われただけ──って、虎之丞さん？　\nどうしてスマホなんか取り出して……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_010021890004" ]},
		{"command":[ "SETCHARA", "0", "char_00010501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "虎之丞" ]},
		{"command":[ "SETTEXT", "「……この『すまほ』なる物、機種は何であったかなと思って……どこをたっ\nぷすればよいでござるか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_104_010021890005" ]},
		{"command":[ "SETCHARA", "0", "char_00010401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「ああ、まず、『設定』を開かないと……。えーっと、画面にアイコンがあり\nませんね。スワイプして、画面を動かさなきゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_010021890005" ]},
		{"command":[ "SETCHARA", "0", "char_00010501_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "虎之丞" ]},
		{"command":[ "SETTEXT", "「あいこん……すわいぷ…………ふむぅ、面妖な……便利ではあるが、いささ\nか拙者には扱いきれんでござる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_104_010021890006" ]},
		{"command":[ "SETCHARA", "0", "char_00010401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「……これ、逃げるチャンスじゃない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_010021890005" ]},
		{"command":[ "SETCHARA", "0", "char_00010201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「逃げる理由、あんまりなさそうだけどねー。それよりむしろ、不意打ちして\n倒しちゃうってのはどうかなー……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021890004" ]},
		{"command":[ "SETCHARA", "0", "char_00010301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「倒す理由の方が行方不明だってば！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_010021890006" ]},
		{"command":[ "SETCHARA", "0", "char_00010201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「……オホン。内緒話を堂々とするの、止めてちょうだい。それよりも、こっ\nちは用事があって来たんですから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_010021890006" ]},
		{"command":[ "SETCHARA", "0", "char_00010501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "虎之丞" ]},
		{"command":[ "SETTEXT", "「然り。お亥様より、直接頼まれたでござる。腑抜けきったサムライテールを\n、拙者の手で鍛え直すべし、と」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_104_010021890007" ]},
		{"command":[ "SETCHARA", "0", "char_00010401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「私はお手伝いです。やりたくてやってるわけじゃありませんからね。その点\nご理解ください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_010021890007" ]},
		{"command":[ "SETCHARA", "0", "char_00010501_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「…………思いついた！　古人いわく『親が死んでも暑気払い』！　たとえ、\n大変なことがあって、身体の負担になるようなことは──」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021890003" ]},
		{"command":[ "SETCHARA", "0", "char_00010101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「あれ？　何？　私が一生懸命頭脳労働をしている間に、話が展開してるです\nか？　そんな……私、長女なのに！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021890004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "虎之丞" ]},
		{"command":[ "SETTEXT", "「はぁ……これが長女なのだから、三姉妹の実力は推して知るべしであるな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_104_010021890008" ]},
		{"command":[ "SETCHARA", "0", "char_00010401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ぐっ……た、たしかに……最近だらけてるとは思うけど、妹たちと私の侮辱\nは許せないです！　いくらご先祖様であってもです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021890005" ]},
		{"command":[ "SETCHARA", "0", "char_00010101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「そーだそーだ！　そんな乳をして！　恥ずかしくないのか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_010021890007" ]},
		{"command":[ "SETCHARA", "0", "char_00010201_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「ほんとだよぉ……そのエロい人がご先祖様ならさ、遺伝でボクもびっくりお\nっぱいになったかもしれないのなぁー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021890005" ]},
		{"command":[ "SETCHARA", "0", "char_00010301_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「……なんだか、私に被害が飛び火してるんですが……あの、虎之丞さん、と\nっとと済ませて帰りましょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_010021890008" ]},
		{"command":[ "SETCHARA", "0", "char_00010501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "虎之丞" ]},
		{"command":[ "SETTEXT", "「承知した。聞けぃ！　我が裔（すえ）ども！　古来より若苗家は武家として\n名高い一族でござる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_104_010021890009" ]},
		{"command":[ "SETCHARA", "0", "char_00010401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "虎之丞" ]},
		{"command":[ "SETTEXT", "「時は移ろい、世情は変われど、気高き武家の誇りは永久不変！　勤倹にして\n好学尚武の精神こそ、若苗家の家風！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_104_010021890010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「……うう、なんだか、かっこいい感じ……でも、そんなこと言われてもさぁ\n……一応やることはやってるわけだし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_010021890008" ]},
		{"command":[ "SETCHARA", "0", "char_00010201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「ということで、虎之丞さんの言葉をまとめて『若苗家諸法度』を作成いたし\nました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_010021890009" ]},
		{"command":[ "SETCHARA", "0", "char_00010501_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「何？　ショハットって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021890006" ]},
		{"command":[ "SETCHARA", "0", "char_00010301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「……わかんない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021890006" ]},
		{"command":[ "SETCHARA", "0", "char_00010101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「ハット……だから、帽子、かな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_010021890009" ]},
		{"command":[ "SETCHARA", "0", "char_00010201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「……バツグンのバカどもですね。諸法度とは、『やっちゃ駄目なことを明文\n化したもの』です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_010021890010" ]},
		{"command":[ "SETCHARA", "0", "char_00010501_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "虎之丞" ]},
		{"command":[ "SETTEXT", "「……ふむ、そういう意味であったでござるか。なるほど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_104_010021890011" ]},
		{"command":[ "SETCHARA", "0", "char_00010401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「……虎之丞さん？　どうしたました？　何かブツブツ言ってますけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_010021890011" ]},
		{"command":[ "SETCHARA", "0", "char_00010501_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "虎之丞" ]},
		{"command":[ "SETTEXT", "「お気にめさるな、アイナ殿……さて、それでは、これより『若苗家諸法度』\nを唱和するでござる。後に続くように」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_104_010021890012" ]},
		{"command":[ "SETCHARA", "0", "char_00010401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「えー……そんなブラック企業の朝礼みたいなの、やだなー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021890007" ]},
		{"command":[ "SETCHARA", "0", "char_00010301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "虎之丞" ]},
		{"command":[ "SETTEXT", "「早速、第一条に反してるでござるな……まあいい。さあ、始めるでござる！\n　一つ！　先達に背くことあるまじき！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_104_010021890013" ]},
		{"command":[ "SETCHARA", "0", "char_00010401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「ひっ、ひとつ、せんだつにそむくことあるまじき！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021890008" ]},
		{"command":[ "SETCHARA", "0", "char_00010301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "虎之丞" ]},
		{"command":[ "SETTEXT", "「一つ、みだりに若苗家の名誉を貶めることあるまじき！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_104_010021890014" ]},
		{"command":[ "SETCHARA", "0", "char_00010401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「はいはい……ひとつ、みだりにもにゃもにゃモゴモゴあるまじきー……って\n、こういう体育会系、苦手なんだけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_010021890010" ]},
		{"command":[ "SETCHARA", "0", "char_00010201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "虎之丞" ]},
		{"command":[ "SETTEXT", "「一つ、戦いで不当な報酬を得ることあるまじき！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_104_010021890015" ]},
		{"command":[ "SETCHARA", "0", "char_00010401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「あ、あの……ちょっと待ってくれる？　いつまでこんなことやればいいです\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021890007" ]},
		{"command":[ "SETCHARA", "0", "char_00010101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "虎之丞" ]},
		{"command":[ "SETTEXT", "「何か不服があるでござるか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_104_010021890016" ]},
		{"command":[ "SETCHARA", "0", "char_00010401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「そんなにいっぱい言われても憶えられないです！　ってか、妹たちが嫌がっ\nているのにこれ以上続けることあるまじき、です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021890008" ]},
		{"command":[ "SETCHARA", "0", "char_00010101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「う～ん、あんたが１２０年前か１８０年前か２４０年前の人なのか知らない\nけどさぁ、令和の女学生の間では、そーいう体育会系、流行んないんだよね～\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_010021890011" ]},
		{"command":[ "SETCHARA", "0", "char_00010201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "虎之丞" ]},
		{"command":[ "SETTEXT", "「……やはり第一条に反するつもりでござるか？　ではお亥さまのお願い通り\n、綱紀粛正に努めさせていただくでござる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_104_010021890017" ]},
		{"command":[ "SETCHARA", "0", "char_00010401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「……そんな勝手な決め事だなんて、お断りです！　力で押し通るですよ！！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021890009" ]},
		{"command":[ "SETCHARA", "0", "char_00010101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021890010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「それで……その『若苗家諸法度』って、全部で何項目あるですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021890011" ]},
		{"command":[ "SETCHARA", "0", "char_00010101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「８８個です。そのうち７割ぐらいが内容が重複してますね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_010021890012" ]},
		{"command":[ "SETCHARA", "0", "char_00010501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「はぁ……やっぱ付き合いきれないです！！　いくですよ、破、急！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021890012" ]},
		{"command":[ "SETCHARA", "0", "char_00010101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「さっすが姉さん！　イマドキの若苗家のサムライスタイル、見せつけてやり\nましょ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_010021890012" ]},
		{"command":[ "SETCHARA", "0", "char_00010201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「もう帰りたいから、とっとと殺っちゃおうよー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021890009" ]},
		{"command":[ "SETCHARA", "0", "char_00010301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「よーし、行くですよー！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021890013" ]},
		{"command":[ "SETCHARA", "0", "char_00010101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "虎之丞" ]},
		{"command":[ "SETTEXT", "「……結構なことでござる！　力でねじ伏せるも、また士道の一つ！　さあ、\nまいるでござる！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_104_010021890018" ]},
		{"command":[ "SETCHARA", "0", "char_00010401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "三人" ]},
		{"command":[ "SETTEXT", "「不言行殺！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021890014" ]},
