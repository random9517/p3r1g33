{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0138" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「はーいみなさん、席に着いてくださーい！　ホームルーム始めまーす！　ち\nゃんと聞いてくださーい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020113560001" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「聞いておりますわ。しかしながら、どうして教室に先生たちまでも集まって\nおりますの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113560001" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「球技大会の説明について、教師陣も教室に集まれとの話でしたので」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_060113560001" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「早くはじめてもらえますか？　ウチにはこの後も仕事があるのです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_060113560002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「え、えっと！　訓練も兼ねて各自の親交を深める目的で……今度、球技大会\nが行われる事になりまして」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020113560002" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「なんだ？　要するにバトルか？　よし、今すぐ始めようぜ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040113560001" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「教師のくせに学生に混じろうとしてるんじゃねーですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_060113560003" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「あー、その球技大会だが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020113560001" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ん？　どうしたんだ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「地球防衛科は、ほかのクラスとの対戦はありません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020113560002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "生徒たち" ]},
		{"command":[ "SETTEXT", "「ええぇーーっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113560002" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "3", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "1", "char_00002402_01", "3", "CENTER", "0" ]},
		{"command":[ "SETCHARA", "2", "char_00001502_01", "3", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "DISPCHARA", "2", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "酷いブーイングが起きる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「当たり前でしょう！　自分たちが先週なにをしでかしたのか、思い出してみ\nなさい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020113560003" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "DISPCHARA", "2", "FALSE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「なにかあったっけ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040113560002" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「授業をしていた教師が忘れますか。犬なのに鳥頭なんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_060113560004" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「なにおぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040113560003" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "俺も思い出した。あの時……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0153" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SETTEXT", "時はさかのぼり、この間の体育の時間。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんで俺が審判をさせられてんだ……」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「いいだろー。私が試合に出ていたら誰が生徒をみるんだよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040113560004" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「それに、審判だって必要だしな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040113560005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "仕事中のところをセレインに捕まっていた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "現在、普通科のクラスとバスケで対戦している。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「今のどこがルールに違反したと言いますの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113560003" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "みんと" ]},
		{"command":[ "SETTEXT", "「あたりまえです！　ボールを持って４歩も歩きましたよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_020113560002" ]},
		{"command":[ "SETCHARA", "0", "char_00001502_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「あなたが私の邪魔をするから動いてしまっただけです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113560004" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「わっ、ケンカねっ。勝った方がルールブックになる流れね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020113560002" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「いや、そんなわけないでしょ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020113560001" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ただ、ここでの戦闘はまずいぞ。なんせ、普通科の生徒もいるわけだし……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「私がルールブックよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113560005" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "みんと" ]},
		{"command":[ "SETTEXT", "「そんな無茶苦茶な理屈通しません！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_020113560003" ]},
		{"command":[ "SETCHARA", "0", "char_00001502_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "お前ら～っ！　まてまてまてまて！　だからこんなところで……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「おおっ、楽しそう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040113560006" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「教師のお前まで混ざろうとするんじゃねえっ！　というか、教師なら止めろ\nぉっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ああもう、いつもながらホントーっに、言葉で殴り合うよりこぶしで語り合い\nたがる奴らだなぁっ！", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}