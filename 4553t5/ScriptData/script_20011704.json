	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「とっても綺麗で、広くて泳ぎやすい海だったね～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021540013" ]},
		{"command":[ "SETCHARA", "0", "char_00010303_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「このビーチに慣れると、地元の海水浴場やプールに行きたくなくなっちゃう\nかも」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_010021540012" ]},
		{"command":[ "SETCHARA", "0", "char_00010203_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「気持ちはわかるけど、これはあくまで旅行です。今だけの特別な時間だと思\nっておかないと、帰ったときにつらくなるですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021540016" ]},
		{"command":[ "SETCHARA", "0", "char_00010103_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「そんなこと言ってる割に、姉さんも随分とはしゃいでましたよね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_010021540013" ]},
		{"command":[ "SETCHARA", "0", "char_00010203_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「最初はあんなに渋ってたのに、海に入ったら一番泳いでるし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021540014" ]},
		{"command":[ "SETCHARA", "0", "char_00010303_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「それは……！　だって……こういう場所で泳ぐなんて、めったにないことで\nすし……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021540017" ]},
		{"command":[ "SETCHARA", "0", "char_00010103_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「姉さん、即落ちね。ふっ、チョロいんだから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_010021540014" ]},
		{"command":[ "SETCHARA", "0", "char_00010203_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「そ、即堕ちって……！　ああ、もう！　私のことはいいです！　次にやるこ\nとを決めましょう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021540018" ]},
		{"command":[ "SETCHARA", "0", "char_00010103_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「そうだね……さすがに泳ぎ疲れたし、違うことしたいかな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021540015" ]},
		{"command":[ "SETCHARA", "0", "char_00010303_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「ホテルに戻るにしてもまだ早いし、どうしましょうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_010021540015" ]},
		{"command":[ "SETCHARA", "0", "char_00010203_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「ん……？　なんだろう、このチラシ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021540016" ]},
		{"command":[ "SETCHARA", "0", "char_00010303_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「豪華賞品がもらえる、渚のマーメイドコンテスト……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021540019" ]},
		{"command":[ "SETCHARA", "0", "char_00010103_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「豪華賞品か……これは気になるねー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_010021540016" ]},
		{"command":[ "SETCHARA", "0", "char_00010203_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「水着審査やいろんな競技があるんだって……ねぇ、これに出てみない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021540017" ]},
		{"command":[ "SETCHARA", "0", "char_00010303_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「別にいいですけど、優勝は難しいかもしれないですよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021540020" ]},
		{"command":[ "SETCHARA", "0", "char_00010103_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「ボクのナイスバディを披露すれば、会場の人たちはメロメロになること間違\nいなし……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021540018" ]},
		{"command":[ "SETCHARA", "0", "char_00010303_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「急が参加するなら、あたしも参加してもいいよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_010021540017" ]},
		{"command":[ "SETCHARA", "0", "char_00010203_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「わかったですよ。それじゃあ、コンテストに出るとしましょうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021540021" ]},
		{"command":[ "SETCHARA", "0", "char_00010103_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
