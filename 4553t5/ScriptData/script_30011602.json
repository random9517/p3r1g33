{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000116_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「ほら……ここなら誰も来ないわ。扉も、内鍵で閉められるから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1604101" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「そんなに待ちきれないのかって……当然でしょっ……貴方に、どれだけ……\n身体を弄くり回されたと思ってるのよっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1604102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「やっと二人きりになったんだし……この持て余した身体……しっかり責任取\nってもらうから……分かった！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1604103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「んっ、ふぅ……それならいいのよ……んっ、おほん……それでね、やり方な\nんだけど……ほら、この前……ちょっとしたこと、あったじゃない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1604104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「だから、アレ……アレよっ、その……この前やった奴……！　ほらっ、貴方\nが人質を使って、私を脅すような感じにして……わ、分かった？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1604105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「その、確かイメージプレイっていうの？　もう一人の自分を見つけるような\n感じで……わ、悪くなかったから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1604106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「ほらっ、何となく怪人は慣れてるようなもんでしょっ、いい感じにやってみ\nて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1604107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「ひぁんっ！　あっ……ま、待ちなさいっ……一体、何をするつもりで……あ\nぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1604108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「逆らったら、どうなるか……うくっ……わ、分かったわ……ちゃんと、言う\nことを聞くから……乱暴な真似は……あんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1604109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「あぁっ、そんな……そこっ、あっ、くぅぅ……んっ、ぬ、濡れてなんか……\nあぁっ……ダメよ……待って、そこは……あっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1604110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「んっ、あぁ……指が入ってくる……んんっ、オマンコ……濡れてるの……気\nづかれちゃった……もう、準備できちゃってるの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1604111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「い、いいわ……覚悟は出来ているもの……私には何をしてもいいから……人\n質には手を出さないで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1604112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「そうよ、ちゃんと……オ、オマンコを差し出すわ……ほら、ここよ……その\nまま、入れて……あ、くっ、んぅぅぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1604113" ]},
		{"command":[ "SETIMAGE", "0", "still_00000116_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「あぁっ……入ってくる……敵の怪人に……私、オマンコ……許しちゃってる\n……んっ、ふぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1604114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「く……ふっ、大きい……あぁ……オチンポがいっぱいに埋め込まれて……オ\nマンコ、広がって来ちゃってるの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1604115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「んっ、くぅぅ……好きにしなさい……けど、身体は好きに出来ても、心まで\n好きに出来るなんて思わないで……あっ、はぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1604116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「くうんっ、はっ、んぁっ、あぁっ……かき混ぜられるぅ……くぅんっ、よ、\n弱い所を……グリグリ擦ってきて……こ、腰に力が入らなくなるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1604117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「はぁっ、んふっ、んくんっ……なんて大きさなの……んくぅっ、オマンコに\nみっちり埋め込まれて……あ、ひぃっ、身体……おかしくなるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1604118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「き、気持ちよくなんか……これは、んっ、人質の為に……仕方なくよ……そ\nうじゃなきゃ、貴方のオチンポなんて……こんな、あひっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1604119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「違う……あっ、い、今のは……ちょっと弱い所が擦れただけで……あっ、こ\nれくらいのこと全然……もう一回されても、別に……んひんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1604120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「あっ、そんな……も、もう一回って言ったのに……そんな、二回もっ、三回\nもなんてっ、あひっ、あっ、あぁっ、弱いのにっ、んひんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1604121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「待って……あぁっ、そこっ、そこぉっ！　感じるっ、オマンコグリグリされ\nるとぉっ、あっ、声が……出ちゃうからぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1604122" ]},
		{"command":[ "SETIMAGE", "0", "still_00000116_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「はひっ、お汁も出ちゃうっ！　じゅわって溢れてっ……ヌルってするのがっ\n、いっぱい……来てぇっ、あっ、んぁぁぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1604123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「あぁっ、そうよっ……レイジョーピンクはっ……んくっ、怪人に……オマン\nコされてっ、今……感じてるのっ、はひぁっ、あぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1604124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「太いオチンポが……出たり入ったりしてっ、はぁっ、どんどん頭の中までっ\n、ピンクになっていってるのっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1604125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「くうっ……ダメ……こんなっ、人質の人も見てるのにっ……怪人に犯されて\n蕩け顔になってるのっ……はしたないのにっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1604126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「あぁっ、でも……逆らえないっ！　このオチンポの前にっ……私っ、どうす\nることも出来ないのぉっ、はひんっ、気持ちいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1604127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「あぁっ、そうよっ……気持ちいいのっ……オチンポ気持ちいいっ、認めるわ\nっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1604128" ]},
		{"command":[ "SETIMAGE", "0", "still_00000116_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「レイジョーピンクはっ、怪人にオマンコされてっ！　どんどん、気持ちよく\nなってるっ……いやらしいヒロインなのぉっ、あ、はぁぁぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1604129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「あぁっ、サカられてるっ！　鼻息が首筋に掛かって……ゾクゾクするっ！　\nあぁっ、オマンコっ、そこっ、蕩けるっ、おかしくなるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1604130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「はひぁっ、あぁんっ、ダメっ……こんなっ、私っ……もうイッちゃうっ、敵\nのオチンポでっ、オマンコイカされちゃうのっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1604131" ]},
		{"command":[ "SETIMAGE", "0", "still_00000116_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「あひぉぉぉっ！　も、もうイクっ、んくぅぅぅんっ！　いやぁぁぁんっ、オ\nマンコッ……イクぅぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1604132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「はぁっ、あっ、あぁぁぁ……イ、イカされちゃった……あぁ……まだ、オチ\nンポ……激しく突きこまれてるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1604133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ、この激しいのっ……あぁっ、で、出るのねっ……？　射精……\nされちゃうのねっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1604134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「中はダメよっ……このまま中出ししたらっ、許さないんだからっ、あぁっ、\nダメっ……中に来てっ……あひっ、来てぇぇぇぇぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1604135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「んぁぁぁぁぁぁぁぁぁーっ！　あぁっ、出てるっ……中に……出されてる…\n…ダメって……言ったのに……んはぁぁぁ……気持ちいい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1604136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000116_02_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「はぁぁ……あふっ、びゅくびゅく……オチンポが震えてる……んっ、どんど\nん流し込まれてるの……オマンコいっぱいになっちゃうぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1604137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「はぁっ、あぁ……あふっ……終わったの……？　んっ、射精……出し切っち\nゃったのね……あぁ……はふぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1604138" ]},
		{"command":[ "SETIMAGE", "0", "still_00000116_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「ふぅぅ……わ、私……これ……クセになりそうかも……こんなドキドキして\n、気持ちいいこと……あぅぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1604139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「もう……本当になんてことしてくれたのよ。本格的に責任取ってもらわない\nと……いけないかもね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1604140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「んっ……ふっ、それで……まだオチンポ……ちゃんと硬いままでいるわよね\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1604201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「当たり前よ、まだ一回して満足させてハイ終わりなんて、そんなコトは許さ\nないからね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1604202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「そうよ……本番はここからよ……怪人らしく、ピンクのこと……も、もっと\n激しく犯しなさいっ……あっ、あぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1604203" ]},
		{"command":[ "SETIMAGE", "0", "still_00000116_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「あくっ、んふっ……ど、どういうつもりっ……！？　もう終わったんじゃな\nかったの？　な、何よその呆れた目はっ……もっと、やる気出しなさい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1604204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「こういうのは……しっかりなり切らないと興ざめなんだからっ……あぁっ！\n　んっ、そうっ、あぁっ、くっ、は、離しなさいっ、ダメよ……そこはっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1604205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「あんっ、あぁっ！　もっと感じる場所を……探していくなんてっ、そんな、\nことぉっ、あっ、これ以上……どこをするっていうのっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1604206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「んんっ！　もっと奥っ！？　そこはっ、あっ、子宮の……入り口のとこっ…\n…んっ、ひぃんっ！　あっ、そんなとこっ、あっ、ダメェっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1604207" ]},
		{"command":[ "SETIMAGE", "0", "still_00000116_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「はぁぁっ、当たるっ……オチンポの先っぽがっ……コツコツして来てっ！　\nくひぃっ、あぁっ、よ、良すぎるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1604208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「はんっ、あんっ、あっ、あぁんっ、あひっ、あぁっ、そんなっ、さっきより\nっ……もっとっ、感じてっ……激しいっ……音、するぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1604209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「んらめっ、オチンポッ……強いのっ！　あぁっ、で、でもっ、すごくいいっ\n！　ダメっ……敵に負けちゃうっ、オチンポに勝てないっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1604210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「反撃っ……？　そ、そうだわ……んっ、そっちのオチンポに……もっと強い\n刺激を与えてあげれば……んっ、くぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1604211" ]},
		{"command":[ "SETIMAGE", "0", "still_00000116_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「ほ、ほらっ……どうっ？　んっ、ふっ……この締め付けっ……貴方は弱い筈\nよっ……んっ、あっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1604212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「ふふっ、やっぱり顔色が変わったわね……オチンポの先端が……ムズムズし\nてたまらないんでしょう？　あっ、ふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1604213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「んぁっ！　あぁ……でも、これ……私にも気持ちいいのが……跳ね返って…\n…はぁんっ、あっ、あぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1604214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「ダメっ……ダメよっ……あぁっ、やっぱり気持ちいいっ……オチンポっ、さ\nっきより、ずっと良くなっちゃうのっ、オマンコっ……溶けるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1604215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「あっ、んはぁぁっ、あぁっ、こんなっ……何度もズボズボされてっ……やっ\nぱり、オチンポに降参させられちゃうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1604216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「んぁっ、あぁっ……オチンポ……また、ビクビクしてるのっ……はぁんっ、\n出るのねっ……また、射精しちゃうのねっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1604217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「もうっ、何でもいいのっ、どうにでもしてっ！　オマンコ……グチュグチュ\nにかき回してっ、いっぱいイカせてっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1604218" ]},
		{"command":[ "SETIMAGE", "0", "still_00000116_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「ギンギンオチンポッ……強く押し込んでっ……あぁっ、思いっきり射精して\nっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1604219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「どこでもいいわっ、レイジョーピンクの身体っ……どこでもいいからぁっ、\n全部っ……全部出しきってぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1604220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「はぁんっ、またっ……中に出すのねっ？　あぁっ、精液っ……中出しされち\nゃうのっ……んくぅっ、あっ、んぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1604301" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「くぅぅぅぅぅんっ……！　あぁっ……中に来てる……また、熱いの……流し\n込まれてるぅっ……はひぃっ、イクぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1604302" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000116_02_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「あぁ……んっ、オマンコ……ヒクヒク動いてる……勝手にオチンポ……吸い\n上げようとしちゃってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1604303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「んっふ、あぁ……いっぱいになっちゃったのに……まだ、オチンポ動き続け\nてるわ……後もう少し出すの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1604304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「んっ……こうなったら、どうにでもして……ちゃんと、全部……出し切っち\nゃって……精液……オマンコにぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1604305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「はぁ、んっ、あぁっ……また、出た……んっ、ビュクって精液……入って来\nてる……んぁふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1604306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「あぁ……終わった……んっ、はぁぁ……はぁ、はぁ……それでも、ヒロイン\nは……負けないんだから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1604307" ]},
		{"command":[ "SETIMAGE", "0", "still_00000116_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「はふ……うん、お疲れ様……その、少し……のめり込み過ぎちゃったかも知\nれないわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1604308" ]},
		{"command":[ "SETIMAGE", "0", "still_00000116_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「でも、貴方も結局ノリノリだったわね。まだオチンポ……大きいままだもの\n……ふふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1604309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「とりあえず、ちょっと一休みして……そしたら、またもうちょっと続き……\nしましょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1604310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「んぁぁっ、身体にっ、掛ける気なのっ？　あぁっ、精液で……私を……汚す\nのねっ！？　んぁぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1604401" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「はぁぁんっ……あぁぁ……かかってるっ、熱い精液……ぶっ掛けられてるぅ\nっ……んぁぁぁっ、イクぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1604402" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000116_02_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ、じゅぷっ……んんっ、あぁ……どれだけ出してるの……ねっとり\nしたのが、んっ、顔に……へばりついて……匂いも凄い……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1604403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「んんっ！　あぁっ、また……飛んできた……あぷっ、顔にっ、んちゅぷっ、\nドロッとしてる……こくっ、んくんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1604404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「あぁ……塗りこめられてる……精液……頬に染み込ませて……オチンポでね\nとねとにされちゃってるのぉ……はぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1604405" ]},
		{"command":[ "SETIMAGE", "0", "still_00000116_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「んふっ……あぁ……やっと、出し切ったの……？　はぁ……あぁ……私、汚\nされちゃった……ドロドロにされちゃった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1604406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「それでも……心は負けて……ないんだから……はぁ、はぁ……んっ……ふぅ\nぅ……よっこい……せっと！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1604407" ]},
		{"command":[ "SETIMAGE", "0", "still_00000116_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「はぁ、ついつい夢中になっちゃったわ……やっぱり、私……ハマっちゃった\nのかも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1604408" ]},
