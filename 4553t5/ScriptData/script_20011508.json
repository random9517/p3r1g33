{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0081" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「会場の準備が整ったようなので、次の競技に行ってみましょう！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「水着と言えばこれが定番！　水中騎馬戦ーーーーー！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "観客たち" ]},
		{"command":[ "SETTEXT", "「うおおおおおぉーーーーー！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「騎馬戦で水着といえば、当然ポロリ！　これは期待が持てるぞ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ポロリはコンテストの趣旨ではないですぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021520054" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「ルールは簡単！　四人一組で騎馬を組み、騎手であるキャプテンが倒れたら\n負けというもの！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「また、キャプテンの水着にはハチマキが結んでありますので、これを奪い取\nっても勝利です！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「ですが水着にハチマキがある関係上、ハチマキを取られると水着も取れてし\nまうかもしれません！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「素直に倒れるか、ポロリするか……二つに一つです！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「悪趣味な騎馬戦だわ。でも、合法的にアナザーと戦えるいい機会ね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070021520011" ]},
		{"command":[ "SETCHARA", "0", "char_00000107_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「それはこちらのセリフだ。貴様の実力、見せてもらうぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090021520013" ]},
		{"command":[ "SETCHARA", "0", "char_00000111_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「はじまる前から両キャプテンの間で、火花が散っております！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「そんなキャプテンたちを支える、騎馬となる選手を紹介しましょう！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「まずは紅組！　月影輝夜さん、エファ・グラナーダさん、ピースムーンさん\n！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「き、騎馬なら……あんまり人に見られない……かな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_050021520011" ]},
		{"command":[ "SETCHARA", "0", "char_00000205_01", "2", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「前に居た方が注目されそうだし、私がフロントをやるわね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021520009" ]},
		{"command":[ "SETCHARA", "0", "char_00000306_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピースムーン" ]},
		{"command":[ "SETTEXT", "「お嬢様は必ずお守りしますので、安心してください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_040021520011" ]},
		{"command":[ "SETCHARA", "0", "char_00000811_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「続いて白組！　セレイン・チャンさん、朧兎子さん、ディアナ・アーマーン\nさん！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「騎馬は機動力が命！　ってことで、私がフロントをやらせてもらうぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040021520008" ]},
		{"command":[ "SETCHARA", "0", "char_00000404_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「ディアナちゃんか弱いから、箸より重たいモノって持てないのよね～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_050021520008" ]},
		{"command":[ "SETCHARA", "0", "char_00000605_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「ウチが騎馬だなんて……水に浸かりたくないので、騎手がよかったです……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_060021520009" ]},
		{"command":[ "SETCHARA", "0", "char_00000506_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「アナザーの騎馬は、セレイン頼りになりそうだな」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ですがルルーナ殿の騎馬は、輝夜殿という爆弾を抱えています。これは見も\nのですぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021520055" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「騎馬の準備もできたようですので、はじめて行きましょう！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYBGM", "BGM_002" ]},
		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「それでは皆さん！　水中騎馬ファイト！　レディーーー！　ゴーーーーー！\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「アナザーに掴まれたら勝ち目はないわ！　まずは動き回って、かく乱するわ\nよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070021520012" ]},
		{"command":[ "SETCHARA", "0", "char_00000107_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「わかったわ。しっかり掴まってて頂戴ね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021520010" ]},
		{"command":[ "SETCHARA", "0", "char_00000306_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「紅組は真っすぐ相手に向かうんじゃなくて、回り込む作戦みたいだな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「そのままルルーナの方に向かえ！　直線的な機動力なら、セレインに勝てる\nヤツは居ない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090021520014" ]},
		{"command":[ "SETCHARA", "0", "char_00000111_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「任せとけって！　行くぞおおおおおぉーーーーー！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040021520009" ]},
		{"command":[ "SETCHARA", "0", "char_00000404_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「白組は力こそパワーといった感じですな。真正面から突っ込んでおりますぞ\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021520056" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「ちょ、ちょっとセレインさん！　ウチらのことも考えてください！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_060021520010" ]},
		{"command":[ "SETCHARA", "0", "char_00000506_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「そんなに速く走ったら、ディアナちゃん壊れちゃうぅ～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_050021520009" ]},
		{"command":[ "SETCHARA", "0", "char_00000605_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「なんとセレイン選手、一人で騎馬を動かしています！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「兎子選手とディアナ選手は必死にセレイン選手にしがみ付き、水中で引きず\nられている状態だぁーーー！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「もう全部、セレインだけでいいんじゃないか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「兎子殿とディアナ殿が倒れても、セレイン殿が居れば持ち直せるでしょうな\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021520057" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「くっ……！　セレインさんの速度は厄介ですが、策はあります！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070021520013" ]},
		{"command":[ "SETCHARA", "0", "char_00000107_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「輝夜、ピースムーンさん！　館長の動きに合わせて移動しながら、大きく水\n飛沫を上げてください！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070021520014" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「セレインのことだから、私たちを見失えば何処に突っ込んでいいのかわから\nなくなるはずよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070021520015" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピースムーン" ]},
		{"command":[ "SETTEXT", "「わかりました。輝夜様、準備はよろしいですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_040021520012" ]},
		{"command":[ "SETCHARA", "0", "char_00000811_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「は、ははは……はい……！　それでは……！　い、行きます……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_050021520012" ]},
		{"command":[ "SETCHARA", "0", "char_00000205_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「な、なんと！　人間技とは思えない、すごい水飛沫だーーーーー！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「まるで津波のようなビッグウェーブ！　これでは相手が何処にいるのかわか\nらなくなるどころか、波に呑まれて騎馬が崩壊しそうです！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「前が見えねぇ！　これじゃ、ルル様が何処にいるかわかんなくなっちまう！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040021520010" ]},
		{"command":[ "SETCHARA", "0", "char_00000404_01", "4", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「安心しろセレイン。この程度の波、私がなんとかしてやる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090021520015" ]},
		{"command":[ "SETCHARA", "0", "char_00000111_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「必っっっ殺！　月風！　正拳突きぃぃぃぃぃーーーーー！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090021520016" ]},
		{"command":[ "SETCHARA", "0", "char_00000111_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「な、なんだアレ！？　波が綺麗に割れたぞ！？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「さすがはアナザー殿。モーセが海を割ったように、真っ二つになっておりま\nすな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021520058" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「えっ……なんですかこれは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_060021520011" ]},
		{"command":[ "SETCHARA", "0", "char_00000506_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「ちょっとすごすぎて、理解が追い付かないんだけど～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_050021520010" ]},
		{"command":[ "SETCHARA", "0", "char_00000605_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「驚いてないで、今のうちに距離を詰めろ！　近づけばなんとでもなる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090021520017" ]},
		{"command":[ "SETCHARA", "0", "char_00000111_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「よっしゃあああぁ！　ルル様、覚悟おおおおおぉーーーーー！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040021520011" ]},
		{"command":[ "SETCHARA", "0", "char_00000404_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「一気にルルーナ選手との距離を詰める、セレイン選手！　そしてついに、紅\n組と白組が組み合ったーーーーー！！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「掴まえたぞルルーナ！　大人しく倒れれば、ハチマキは奪わないでおいてや\nるぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090021520018" ]},
		{"command":[ "SETCHARA", "0", "char_00000111_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「くっ……あぐっ……！　やっぱり、腕力だとアナザーに勝てないわね……！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070021520016" ]},
		{"command":[ "SETCHARA", "0", "char_00000107_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「お、おお……お嬢様……！　だ、大丈夫ですか……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_050021520013" ]},
		{"command":[ "SETCHARA", "0", "char_00000205_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「月影さん！　今はとにかく動いて、アナザーさんから離れましょう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021520011" ]},
		{"command":[ "SETCHARA", "0", "char_00000306_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピースムーン" ]},
		{"command":[ "SETTEXT", "「ですが私たちがどれだけ動いても、お嬢様がこの状態では……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_040021520013" ]},
		{"command":[ "SETCHARA", "0", "char_00000811_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「組み合っている両キャプテンに対し、紅組の騎馬は必死に動こうとあがいて\nいる！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「もう少しよ、アナザーちゃん！　頑張って～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_050021520011" ]},
		{"command":[ "SETCHARA", "0", "char_00000605_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「もういっそのこと、ハチマキを取ってください！　多少のポロリは許容範囲\nです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_060021520012" ]},
		{"command":[ "SETCHARA", "0", "char_00000506_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「それでは筋肉で勝ったことにならないだろう！　力でねじ伏せてこそ、強者\nというものだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090021520019" ]},
		{"command":[ "SETCHARA", "0", "char_00000111_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「あぐっ、ううぅ……！　この腕さえ振りほどければ、ハチマキが取れるのに\n……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070021520017" ]},
		{"command":[ "SETCHARA", "0", "char_00000107_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「責めるアナザー選手に対し、防戦一方のルルーナ選手！　だが騎馬は諦めて\nいないのか、なんとかして動こうとしているーーー！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「絡み合うごとに、両チームの胸が揺れていく！　ポロリはないがこれは眼福\n！　その調子でもっと揺らしていってください！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いいぞーーー！　その調子で動けーーー！　揺らせーーー！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「む、胸って……！？　わ、私……揺れるとこ……み、見られて……！　ひっ\n、やあぁ……！　は、恥ずかしい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_050021520014" ]},
		{"command":[ "SETCHARA", "0", "char_00000205_01", "9", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「やっ……あっ……！　だ、ダメ……！　もう、限界……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_050021520015" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「こ、コロス……！　見た者は、みんなコロスゥゥゥゥゥーーーーーッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_050021520016" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「な、ななな……なんと！　騎馬である輝夜選手が大暴れし始めたーーーーー\n！？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「ちょ、ちょっと輝夜！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070021520018" ]},
		{"command":[ "SETCHARA", "0", "char_00000107_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピースムーン" ]},
		{"command":[ "SETTEXT", "「輝夜様、落ち着いてください！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_040021520014" ]},
		{"command":[ "SETCHARA", "0", "char_00000811_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「ムダよ！　こうなった月影さんは、誰にも止められないわ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021520012" ]},
		{"command":[ "SETCHARA", "0", "char_00000306_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「コロス！　コロス、コロス、コロス！　コロしてやるうううううぅーーーー\nー！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_050021520017" ]},
		{"command":[ "SETCHARA", "0", "char_00000205_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「わわっ！？　ば、バカ！　こっちくんな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040021520012" ]},
		{"command":[ "SETCHARA", "0", "char_00000404_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「きゃあああぁ！？　せ、セレインさん！　バランスを崩さないでください！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_060021520013" ]},
		{"command":[ "SETCHARA", "0", "char_00000506_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「いやあぁ～ん！　ディアナちゃんの水着が脱げちゃうぅ～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_050021520012" ]},
		{"command":[ "SETCHARA", "0", "char_00000605_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「お前たち、そんなに動くな！　わっ、わわわっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090021520020" ]},
		{"command":[ "SETCHARA", "0", "char_00000111_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「騎手だけでなく、騎馬同士も絡み合いの大混戦！　水着もいろんな意味でき\nわどくなってきたぞーーー！？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「今だわ！　アナザー、覚悟しなさい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070021520019" ]},
		{"command":[ "SETCHARA", "0", "char_00000107_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「くっ……！　負けるかあああぁーーーーー！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090021520021" ]},
		{"command":[ "SETCHARA", "0", "char_00000111_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「両者一歩も譲らず、体勢を崩しながらもハチマキに手をかけたあああああぁ\n！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ポ・ロ・リ！　ポ・ロ・リ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「ここで両チーム、ともに転倒ーーーーー！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「果たしてどちらのチームが勝ったのか、ＶＴＲを見返してみましょう！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「このコンテスト、撮影されていたんですか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021520059" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「さあ、ご覧ください！　ルルーナ選手とアナザー選手が、互いに水着につけ\nられたハチマキに手をかけ……！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「あーーーーーっと！　ハチマキを取ると同時に、両者どころか多くの女性の\n水着がズレてポロリしているーーーーー！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「ですが大事な部分が水飛沫で隠れて、まったく見えなーーーーーい！　誰一\n人として、カメラにポロリが映っていません！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんだよそれ！　なんのためのＶＴＲだ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「ハチマキが取れるのも同時、騎手が倒れたのも同時……よってこれはドロー\n！　両チームとも、ポイント獲得ならず！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……酷い目にあったわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070021520020" ]},
		{"command":[ "SETCHARA", "0", "char_00000107_01", "4", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「まったくだ。だが、悪くない勝負だったぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090021520022" ]},
		{"command":[ "SETCHARA", "0", "char_00000111_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「ええ、そうね。でも次は絶対に白黒つけてあげるわ。覚悟しなさい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070021520021" ]},
		{"command":[ "SETCHARA", "0", "char_00000107_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「ふふっ。それはこっちのセリフだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090021520023" ]},
		{"command":[ "SETCHARA", "0", "char_00000111_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「ここで水着を整えた両チームのキャプテンが、がっちりと握手を交わしてお\nります！　いやー、実にいい勝負でした！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「それでは、ここで一旦休憩となります！　競技再開まで、今しばらくお待ち\nください！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}