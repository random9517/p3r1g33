{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0101" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_011" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ピースムーン" ]},
		{"command":[ "SETTEXT", "「エファナティカ様、本日の準備、滞りなく完了いたしましたっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_010022450001" ]},
		{"command":[ "SETCHARA", "0", "char_00000803_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ああ、ご苦労さん。また時間になったら、お茶汲みを頼むからそのつもりで\nいとくれ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022450001" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピースムーン" ]},
		{"command":[ "SETTEXT", "「はっ！　了解でありますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_010022450002" ]},
		{"command":[ "SETCHARA", "0", "char_00000803_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「さて……部屋の方の準備はよしと……それにしても、あのバカが遅いね……\nどこで油を売ってるんだい……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022450002" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うぃーす」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「遅いよっ！　何をグズグズしてたんだいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022450003" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「えっ、まだ集合予定時間じゃねぇだろ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「幹部たるもの、予定の３０分前には来るのなんて常識だろっ！　何を偉くな\nった気になってるんだい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022450004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そう言われても、俺の方も色々と……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「言い訳するんじゃないよっ、どうせあんたの用事なんて大したこと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022450005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「あっ、おかーさーんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010022450001" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「イルル？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022450006" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「わーいっ、おかーさんだっ、えへへーっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010022450002" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「っととっ……なかなか腰の入ったタックルだね。っていうか、お母さんじゃ\nないっ。全く、結婚だってしてないってのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022450007" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「でも、おかーさんは、おかーさんだもんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010022450003" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あぁもう……まぁいいや。それで、どうしてここに？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022450008" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや……エファナティカがいるって聞いたら、絶対付いて行くって聞かなく\nてな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「付いて行くって……これから何をするか分かってんのかい？　遊びに行くん\nじゃないんだよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022450009" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「分かってるよ。新しく派遣されて来る新怪人の面談だろ？　何か、怪人派遣\n協会から紹介されてきたってやつの……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「そうだよ。結構な腕利きが来るって話だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022450010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「腕利きねぇ……どれ程のもんなんだか……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「そいつを見極めるんだよ。陛下自らのご指名で、あたしとあんたで話をする\nんだからね。そこにイルルを連れてきてどうするんだい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022450011" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、流石に面談の場には同席させねぇよ！　ただ、あれで頑固でなぁ……\nイルルも」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「フン……要するに、駄々こねられて結局折れちまったと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022450012" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、ほら……面談の時間自体はまだ先だろ？　だったら、まあ少し位は相\n手してやれなくもないし……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ったく、甘やかしぃだねぇ。まぁ、まだ時間はあるけどさ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022450013" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「おかーさんっ、えへへぇっ、あのねっ、イルルねっ、昨日もおとーさんにい\nっぱい遊んでもらったの！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010022450004" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「遊んでもらったのかい、そいつは良かった……と言いたいとこだけど、ちゃ\nんと勉強はしてるのかい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022450014" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「おべんきょー？　んっと……うー、えっと……んーと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010022450005" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「遊んでばっかりじゃ、立派な大人にはなれないよ？　カツマみたいなうだつ\nの上がらない奴になったら、後々苦労するからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022450015" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「何で、俺が引き合いに出されてるんだよ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「ん……うん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010022450006" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「イルルも何となく困ってる！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ふん、慕われてるもんだからって、どうしてもビシッと出来ないようだね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022450016" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「面談までは、まだもうちょっとあるか……よし、それなら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022450017" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「おかーさん？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010022450007" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「そんなにお母さんがお望みってんなら、ちょっと気合を入れてあげようかね\n！　はぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022450018" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0101" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おぁっ……！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「おかーさんっ……光ってるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010022450008" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "9", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「……ふむ……こんなものかね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022450019" ]},
		{"command":[ "SETCHARA", "0", "char_00000312_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「…………はわぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010022450009" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「普段、めったに見せる姿じゃないんだが……ピースムーン達の新人研修の時\n以来だったかねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022450020" ]},
		{"command":[ "SETCHARA", "0", "char_00000312_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「う……何か、色々思い出した気がする……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「くくっ、トラウマを呼び覚ましちまったかい？　狂魔元帥の姿より、効くや\nつには効くんだよねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022450021" ]},
		{"command":[ "SETCHARA", "0", "char_00000312_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「おかーさん…………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010022450010" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「かっこいーーーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010022450011" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んぁっ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022450022" ]},
		{"command":[ "SETCHARA", "0", "char_00000312_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「見たことないかっこっ！　おかーさんっ、ぴしっとしててっ……ねっ、ねっ\n、これってメガネ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010022450012" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あ、あぁ、そうだね。メガネが珍しいのかい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022450023" ]},
		{"command":[ "SETCHARA", "0", "char_00000312_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「んっと、見たことあるけど……おかーさんがしてるの、はじめて見たから！\n　かっこいー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010022450013" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「そ、そうかい。けどね、あたしがこの姿になったからには、遊んでばっかり\nではいさせないよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022450024" ]},
		{"command":[ "SETCHARA", "0", "char_00000312_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「今日のあたしは教育ママだ。しっかり勉強を見てやるから、そのつもりでい\nるんだね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022450025" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「おかーさん、べんきょーおしえてくれるの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010022450014" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ん……？　何だい、勉強がイヤって訳じゃないのかい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022450026" ]},
		{"command":[ "SETCHARA", "0", "char_00000312_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「んーと、ずっと分かんないおはなしは眠くなるけど……おかーさんといっし\nょならがんばる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010022450015" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「へぇ……いい心がけじゃないか。それなら、ビシビシいくけどいいんだね？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022450027" ]},
		{"command":[ "SETCHARA", "0", "char_00000312_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「はいっ、おかーさんせんせー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010022450016" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おぉ……俺が言っても、あんまりその気にならなかったイルルが一瞬で……\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ふん、ちょうどいいね。カツマ……あんたも、色々と事務仕事が溜まってる\nんじゃないのかい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022450028" ]},
		{"command":[ "SETCHARA", "0", "char_00000312_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うぇっ！？　い、いや、俺は……別に、そんな……でも？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「へぇ、ということは新しい仕事を振っても、すぐに対応出来るって訳だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022450029" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「い、いや、それとこれとは別だろ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022450030" ]},
		{"command":[ "SETCHARA", "0", "char_00000312_01", "0", "CENTER", "0" ]},
