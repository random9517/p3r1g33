		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んぁぁぁぁーっ！　あっ……オチンチン抜けてっ……あっ、掛かってるっ、\nおっぱい……お尻にもっ……精液……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1104401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000211_02_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「はぁぁんっ、外からも……私のこと……精液まみれにさせて……完全に染み\n込ませちゃうつもりなのね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1104402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あぁ……んっ……あぁ……オチンチンの先がドロドロになってる……勿体な\nいから、ちゃんと全部塗りつけて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1104403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「はふっ……そう、あぁ……ヌルヌルの先っぽがお尻のとこくすぐってる……\nドレスにも染み込んじゃうの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1104404" ]},
		{"command":[ "SETIMAGE", "0", "still_00000211_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んふ……でも、精液まみれの花嫁って……なんだか、とっても背徳的……し\nょうがないもの、私はあなたのモノなんだから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1104405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「隅々まで塗り込めて……んっ、はぁ……からだ……ジンジンしてる……私も\n、ずっとイッたままになってるみたい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1104406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あふっ、もう少しで出し切るの……？　うん、最後まで出し切ってね……あ\nっ、んっ……！」", "NORMAL" ]},
