		{"command":[ "PLAYVOICE", "v2_002_1104123" ]},
		{"command":[ "SETIMAGE", "0", "still_00000211_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「はんっ、あんっ、ぱんぱんって……音してるっ……お尻と……太ももが……\n当たってぇっ……あぁっ、ケダモノみたいな……セックスぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1104124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「こんな、素敵なドレスを……はしたなく着崩してっ……スケベな場所……何\nもかも晒して……考えるだけで……どうにかなりそうなのに……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んんっ！　くぅぅんっ！　お、奥っ……突きこまれたらっ……何もっ、あっ\n、分からなくなるぅっ……んふぅんっ、オマンコいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「はぁぁっ、やっぱりこのオチンチンっ……私をダメにしちゃうのっ、あぁっ\n、好きな所……全部バレてるからっ、思うままにされてっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1104127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「恥ずかしい声出してっ……お汁……どんどん漏らしてっ……なのにっ、あぁ\nっ、イヤじゃないっ……全部……見せてあげたくなっちゃうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「はんっ、あぁっ、こんないやらしい花嫁でもいいの？　スケベな妻でっ……\n大丈夫なのっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1104129" ]},
		{"command":[ "SETIMAGE", "0", "still_00000211_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「嬉しいっ……！　あぁっ、あなたの為ならっ、もっともっと、いやらしくっ\n……オチンチンに尽くすからぁっ、そこっ、あっ、してぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「はひっ、あぁっ、今の……すごいっ！　亀頭がグリグリしてくるのっ、ひっ\n、腰が……抜けちゃいそうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「はんっ、あんっ、あぁっ……うんっ、支えててっ……あぁっ、お尻掴んで…\n…私のことっ……離さないでっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んんっ、しっかり捕まえてくれたらっ……ホッとするからっ……あぁっ、い\nいのっ、私も……オマンコっ……キュウってするぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んっ……あっ、いいのっ？　出したくなってるのっ？　うんっ……もちろん\n中に……来てっ！　熱いの全部……子宮に届けてぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「はぁんっ、激しいっ……ズボズボ来るのっ、あぁっ、イクッ……私もっ……\nあぁんっ、オチンチンズボズボされてっ、オマンコイッちゃうぅぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1104135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
