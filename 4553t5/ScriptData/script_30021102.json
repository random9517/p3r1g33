		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「うぅっ……やっぱり、この格好……恥ずかしい……！　特別なドレスなのに\n……思いっきり……足を開いて……お尻……高く上げて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「はぁぁ……大切な場所……オ、オマンコ……全部見せちゃってる……あぁ…\n…恥ずかしい場所……あなたの目の前に突き出しちゃってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1104103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んっ……ふっ……でも、あなたに興奮して欲しいから……夜の営み……子作\nり……種付け……して欲しいから……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1104104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「だから……あぁ、恥ずかしいけど……見て……！　すっかり発情して……ト\nロトロになってるオマンコ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1104105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あなたの……旦那様のオチンチンが欲しくて、今日は朝からずっとウズウズ\nしていたの……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1104106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「任務の間も、自然に濡れて……湧き上がる感覚……止められなくて……もう\n、ぐちゅっとしてるの……分かる、でしょう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1104107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あっ……オチンチン……！　おへそまで反り返って……本気になってくれて\nる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1104108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「うんっ……欲しい……欲しいの……それ、あなたのギンギンに漲った……ぶ\nっとくて、硬い……熱いオチンチンっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1104109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「その太いのを……この発情して……ずっとお汁を垂らしてる……いやらしい\nオマンコに突っ込んでっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1104110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「新鮮で元気な精液が欲しくて、ひくひくさせてるオマンコぉっ……あなたの\nオチンチンでっ……貫いてぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1104111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んぁぁぁぁんっ！　あっ、はぁぁぁんっ……来てくれたっ……オチンチンっ\n……ずぶって届いて来るぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1104112" ]},
		{"command":[ "SETIMAGE", "0", "still_00000211_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あっ、あぁっ、めり込んで来てるっ……オマンコ……こじ開けられてぇっ…\n…あひんっ、中っ……広がる……んぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1104113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あっ、はぁぁ……うんっ、分かるぅ……すごく深いところまで届いちゃった\n……あぁ……子宮のすぐ手前まで……オチンチンいっぱい……」", "NORMAL" ]},
