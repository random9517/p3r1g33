		{"command":[ "PLAYVOICE", "v2_002_1104136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000211_02_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あぁっ、流れ込んでくる感じすごい……あぁ……精液がオマンコの中……洪\n水みたいに溢れて……イッてる感じ……ずっと続いてるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1104137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んんっ、あぁぁ……はぁぁんっ……あ……終わってきた……オチンチン……\nやっと、落ち着いたの……？　んっふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「うん、オマンコ……いっぱいにされたわ……子種、たっぷり中にしてくれた\nの……嬉しい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1104139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んふ……これで、妊娠してくれるかな……ふふ……楽しみ……ね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1104140" ]},
		{"command":[ "SETIMAGE", "0", "still_00000211_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「でも、まだまだ、もっと念入りに子作りはしないと……オチンチン、続き…\n…出来るよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1104201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「うん、私のオマンコも……まだ、オチンチンのこと……離したくない。もっ\nと深く繋がって……んっ、ケダモノセックス……続けたい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あんっ！　あぁっ……うんっ、そうっ、後ろからのしかかられてっ……その\nまま、パンパンって……突いてもらうのっ……いいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1104203" ]},
		{"command":[ "SETIMAGE", "0", "still_00000211_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「はっ、ひぁっ、あんっ、は、はいっ、もっと……足を広げてっ、オマンコ…\n…入りやすくっ、しますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1104204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あんっ、グリグリしてぇっ……バックハメっ……オチンチン好きなように暴\nれさせてっ、んんっ、オマンコっ……締めつけるからぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1104205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「はぁぁぁっ、ジンジンするぅ……種付けされたオマンコが……ぐちゅぐちゅ\nって……かき混ぜられて……ミルクがドロドロになっていくの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1104206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あぁ……いやらしい格好で……浅ましくオチンチンを欲しがってぇ……こん\nな所……他の誰にも見せられない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1104207" ]},
		{"command":[ "SETIMAGE", "0", "still_00000211_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「でも、あぁっ、あなたには……全部知られちゃってる……私の本性もっ、ス\nケベでオチンチンが大好きなこともっ、何もかもっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「だからっ、あぁっ、もっと見てっ！　私の恥ずかしい四つん這いポーズっ、\nんっ、お尻も振ってっ、ピシャって打ってぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1104209" ]},
		{"command":[ "SETIMAGE", "0", "still_00000211_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あんっ！　あぁんっ！　またずぶってぇっ！　目の前に……火花が散るっ！\n　好きっ……これ好きぃっ！　も、もう一回してっ、あひぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1104210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あぁんっ！　勝手にオマンコヒクヒクするぅっ！　キュンってっ、動いてっ\n……あぉぉっ、こんなっ、感じ過ぎちゃうのっ、んひぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1104211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あぁっ、イクっ……先にイッちゃうっ！　ごめんなさいっ、私っ……我慢で\nきないっ、もうっ、待ちきれないでっ……オマンコッ、イクぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1104212" ]},
		{"command":[ "SETIMAGE", "0", "still_00000211_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んっ、はぁぁぁぁぁっ……あぁっ……すごい……いっぱいイッた……あぁ…\n…んんっ、中……ヒクヒクして……止まらない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1104213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「えと……大丈夫……んっ、あなたも……まだ出そうでしょ？　遠慮しないで\n……オチンチン続けて……オマンコで気持ちよくなって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1104214" ]},
		{"command":[ "SETIMAGE", "0", "still_00000211_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ、んくぅっ……ぎゅってしてあげる……オマンコにぐっと力を入\nれて……オチンチン蕩けさせてあげるの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1104215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ふふっ、息が荒くなって来た……んっ、これ、いいでしょ……んっ、ピスト\nンに合わせて……リズムよく……締め付けて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1104216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あっ、あぁっ！　また……激しくっ……あっ、これ……ラストスパートっ…\n…！？　んんっ、旦那さまの……本気のピストンっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1104217" ]},
		{"command":[ "SETIMAGE", "0", "still_00000211_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「はんっ、あひっ、あぁっ、あひぁっ！　オチンチンが暴れてるっ……中……\n震えてっ、また出したがりになってっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1104218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「いいよっ、どこでもっ……また赤ちゃんの部屋に出してもっ……ドレスごと\nっ、私のからだっ……マーキングしてもっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1104219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「なんでもっ……受け入れるからっ、あぁっ、好きにしてっ、はんっ、オチン\nチンミルクっ……私にいっぱいぶちまけてぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1104220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んぁぁぁぁーっ！　あっ……またっ……中に出て……るっ……！　んくっ、\nまた……熱い精液っ……どぷって……射精されてるぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1104301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000211_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「はぁぁんっ……あぁ……中ぁ……子宮に届いてぇ……はぁぁんっ、またイク\nっ……あひっ、イクっ、イクぅぅぅぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あぁぁ……はぁぁ、子作りセックス……良すぎるぅ……あぁ、もうオチンチ\nン……ずっとこのままでいたい位……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1104303" ]},
		{"command":[ "SETIMAGE", "0", "still_00000211_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ、全部出しきってね……中で受け止めるから……オマンコ……ん\nっ、ちょっと垂れて来そうだけど……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1104304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あぁ……うんっ、しばらく栓をしていて……太いオチンチン……みっちり埋\nまったままの状態で……感じていたいの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1104305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「このまま、んっ……しっかり着床するまで……あんっ！　ま、まだ出るの…\n…？　わ、分かったわ……動いててもいいから……あ、ひっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1104306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「本当……まだ出てきた……すごい……本当にオチンチン……元気なんだから\n……はぁ、んふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1104307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、あぁ……射精……終わった？　うん、ありがとう……お疲れ\n様……いっぱい出してくれたから、きっとあなたの赤ちゃん身ごもったわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1104308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「うん、小さい頃からの夢が叶って……とっても嬉しい。私……きっといいお\n母さんになるから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「少しだけ休憩しましょう……それから、また続き……だって、夜はまだこれ\nからなんだから……ね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1104310" ]},
