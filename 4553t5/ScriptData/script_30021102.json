		{"command":[ "SETIMAGE", "0", "still_00000211_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「はぁ……んんっ、生の……コチコチのオチンチンの感触……はあぁぁ……す\nごく好き……ドキドキして、オマンコがすぐ喜んじゃう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1104115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ね……もう、準備出来てるから……オマンコいっぱい突いて……このオマン\nコは……あなたのものだから……好きなようにしていいから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1104116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ううんっ、私がもう待てないの……お願いだから、オチンチンかき回してっ\n、たくさんオマンコしてっ、あなたのオチンチンで征服してぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1104117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「はぁぁんっ！　あっ、あぁっ、ズボズボっ……来たっ、あっ、あぁんっ、オ\nチンチンのピストンッ……始まってるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1104118" ]},
		{"command":[ "SETIMAGE", "0", "still_00000211_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「はんっ、あんっ、あぁっ、いいっ、んくぅんっ、熱いオチンチンっ……いっ\nぱいオマンコに擦れてるっ、カリ首がっ、気持ちいいとこほじってるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あんっ、あぁっ、腰っ……回してぇっ、あぁっ、奥っ……そこぉっ、あぁん\nっ、気持ちいいーっ、オマンコっ……すごく気持ちいいのぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1104120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あぁっ、あんっ、だってっ……あなたに開発されちゃったからっ！　私っ…\n…もう、このオチンチンなしじゃいられない……淫乱妻だからぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1104121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「だからっ、スケベな奥さんのオマンコっ……もっとほじってっ！　あぉぉっ\n、中っ……色んな所っ……全部っ、全部かき回してぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
