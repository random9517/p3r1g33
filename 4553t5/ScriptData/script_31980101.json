		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「んぷぁっ！？　あぁっ……ややわぁ！　いけずいけずぅ……！　んぁっ……\nあああん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0103401" ]},
