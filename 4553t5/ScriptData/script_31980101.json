		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「うちのおしゃぶり棒取り上げて……あっ！　なんやの！？　顔っ……顔にめ\nがけて……♪　あっ……やぁあ♪　無理やって、無理ぃ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「あんっ♪　あんっ、あぁんん♪　これ……顔射ってやつとちゃうのぉ……！\n？　あっ……♪　こんなん、こんなん初めてぇ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0103403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「んん……あああ♪　うちの顔に充満する、子種の臭い……♪　こないに贅沢\nにいただいてもうて、ええのん……？　はぁっ、はぁ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0103404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「もっとかけてぇ♪　まだ足りへん……♪　んぁ♪　んぷぁっ……♪　そう、\nそうやぁ……♪　嬉しいわぁ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0103405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「見てぇ……♪　うちの顔、隊長さぁんの精子まみれやぁ……はぁああ……♪\n　口の中にもらえんかったのは残念やけど……んん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0103406" ]},
		{"command":[ "SETIMAGE", "0", "still_00019801_01_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「これはこれで、格別やね……♪　ふぅうう……永遠に浸っていたいわぁ。…\n…でも、精液が垂れて落ちてしまうから……ふふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0103407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「時間制限ありなのが惜しいわぁ……。でも、一滴も無駄にしたりせえへんよ\n？　もらったもんは、ぜーんぶうちのもんやもの……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0103408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「手でぬぐいとって……♪　味と香りを楽しみながら、じーっくりぺろぺろさ\nせてもらうわぁ……♪　おちんぽと、その中身と……んふふふ♪」", "NORMAL" ]},
