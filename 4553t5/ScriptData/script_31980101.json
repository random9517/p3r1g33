		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「あむ♪　あむ……んぁんん♪　じゅっぷっ、じゅっぷっ、じゅっぷっじゅぷ\n……♪　あぁ……めっちゃ大きくなってきた……これがええのんよぉ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0103215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「んー……ぐちゅっ！　ぐっぽっぐっぽっぐっぽっ♪　ぐ……ちゅっ♪　ぐぽ\nっ♪　ぐぽっ、くぽっ……♪　んっ♪　んっ、んっんっんっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0103216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「吸いつきすぎれひっこにゅかれそぉ……？　あは……♪　そうなん♪　うち\n、スッポンの生まれ変わりなんかもね……んぢゅるっ！　ぢゅるるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0103217" ]},
		{"command":[ "SETIMAGE", "0", "still_00019801_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「ぐっちゅっぐっちゅっぐちゅっ！　……えぇ？　またこみあげてきとるん…\n…？　ごめんねぇ、うちがおしゃぶり好きなせいで……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0103218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「もひろん、責任とらせてもらうえ……♪　好きなところに出ひてくれてええ\nからね……♪　んふ……どこに出してくれはるんやろぉ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「想像するらけれ、疼いてきひゃう……♪　ん、どーこぉ？　どこにくれるん\n……？　いくえ、……ぐちゅっ！　ぢゅるるっ、ぢゅるるる……！」", "NORMAL" ]},
