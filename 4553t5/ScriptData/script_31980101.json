		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「あっ♪　あ、あ、もっと奥ぅ……喉の奥の奥にまでおひんぽ突っ込んれ、そ\nこでドプドプ射精ひてくらはい……んっ！　もっろ、もっろ奥ぅう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「ん～～～～～♪　ごくっ……！　ごくっ、ごくっ……♪　ああああ、なんて\n美味なんやろぉお……♪　おいひぃ……おいひぃわぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0103303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「んふ……ごきゅっ……ごきゅっ、ごきゅっ……んぁああ……♪　喉に絡みつ\nいて、ベロをべとべとにしてまう強い精子ぃ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0103304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「んっあっ、あ、あぁ……♪　さすがですわぁ♪　隊長さぁん……♪　隊長さ\nんの精液、二度目になっても濃ゆくて濃ゆくて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0103305" ]},
		{"command":[ "SETIMAGE", "0", "still_00019801_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「良質なお抹茶みたいな味わいやったわあ……。ああ……♪　けふっ……♪　\nあら、ややわぁ……まだ、ちょろっと残ってますやないの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0103306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「うちがきっちり吸い出したらんと……。……ぢゅ♪　ぢゅる……♪　ぢゅ…\n…あぁあん♪　ええわぁ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0103307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「おしゃぶりみたいに、いつまでも吸ってたい……♪　うち、あんさんのおち\nんぽの虜やぁ……だってほんまにおいしいんやもん……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0103308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「ちゅるちゅる啜ってると、孕んでしまいそうなええ匂いするし……。はぁ…\n…♪　一生舐めとりたいわぁ……あかん？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0103309" ]},
		{"command":[ "SETIMAGE", "0", "still_00019801_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「おちんぽふやけてまうまで、むしゃぶりついとるうちを……笑わんでねぇ？\n　自分でも、ひいてまうくらいフェラチオが好きみたいやの……♪」", "NORMAL" ]},
