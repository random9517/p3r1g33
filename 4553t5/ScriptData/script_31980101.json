	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「あらぁ……この香り……。狭い部屋の中を充満しているこの匂い……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0103101" ]},
		{"command":[ "SETCHARA", "0", "char_00019801_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「隊長さぁん？　うちをここに呼んだ理由……。大体想像がつきましたえ？　\nラブラブで、いちゃいちゃで……ねちゃねちゃなことをご所望どすなぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0103102" ]},
		{"command":[ "SETCHARA", "0", "char_00019801_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「……えぇ？　嫌やありまへんよ。うちもあんさんと、そないなことをしたい\nと思っとったところどす……。ふん、ふん……この匂いで言えば……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0103103" ]},
		{"command":[ "SETCHARA", "0", "char_00019801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「『一人寝で寂しい夜に、ラストノートに濃厚なフェラチオを……』『口淫を\nお願いしたい』といったところでしょうか。うふ、ホントにどすけべはん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0103104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「ええんですよぉ？　フェラチオでもイラマチオでもその先でも……♪　でも\n、今日はお口の気分でしたら……どうやろか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0103105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「フェラチオよりも、もーっと過激でぇ♪　二人が一緒に楽しめて、気持ち良\nくなれる……。そんな遊びがあるんですけど、せえへん……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0103106" ]},
		{"command":[ "SETCHARA", "0", "char_00019801_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「んっ……あは♪　どうです……この眺め♪　そう♪　うちがあんさんにお口\nでご奉仕するだけやなくて……。あぁん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0103107" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00019801_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「あんさんもうちのおまんこをペロペロ出来る体勢……。いわゆるシックスナ\nインで遊ぼうと思て♪　なんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「感想は、口で聞かんでも匂いでよーくわかりますえ……♪　はぁっ……はぁ\n、はぁ……なんですのん？　このチンポのいやらしい臭い……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0103109" ]},
		{"command":[ "SETIMAGE", "0", "still_00019801_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「うちのお口おまんこを味わいたくてたまらへんって感じやわ……。凝縮され\nたオスのニオイ……。悪臭すれすれの、すえた香り……たまらへん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「これを堪能させてもらうかわりに……。あんさんも、うちのアソコをぎょう\nさん可愛がってやってくださいねぇ？　能力がなくてもわかりますやろ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0103111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「うちのおまんこ♪　蕩けた桃のお汁みたいに、愛液にまみれたいやらしーい\nアソコ……♪　メスの匂いがぷんぷんで、男を誘っていますやろ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「……と、言葉で煽っていてもしょうがありまへん。さっそくいただきますえ\n……♪　まずは味見から……んっ……。だめ、興奮するわぁ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「れろ……ぺちょっ、ぺちょ、ぴちゃ……♪　あぁん……やっぱり♪　汗とチ\nンポそのものの、エッロい匂いと味が伝わってくるぅ……♪　ん、ぴちゃっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0103114" ]},
		{"command":[ "SETIMAGE", "0", "still_00019801_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「最高やぁ……♪　あん、舐めてるだけで感じてまうぅ……♪　ぴちゃっ……\n、ぺちょ、ぷちゅ、ちゅぷ……れろっ、れろっ、れろれろ……んん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0103115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「あーん……♪　はむん♪　ぴちゃっ……ぴちゃっ、ぴちゃ♪　ぺろ……ぺろ\n、ぺろ……れろ……♪　あっあっあっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「おいしぃい……♪　おいしいのぉ♪　うち、うち、おちんちん好きぃ……♪\n　あんさんのおちんぽ舐めしゃぶるの好き、もっと、もっとさせてぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「ぴちゃっ……ぴちゃ、ぴちゃ……はぁあん♪　あぁんっ……！　ちゅぷ、ぺ\nちょ……ぺちょ、ちゅぱっ♪　ちゅぱ、れろ、れろ、れろ……れろぉおお♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「っああああ♪　この芳醇な味と香りぃ……♪　おかしくなってまいそぉ♪　\n腰を自然に振ってまう、あっ、あっ……あんさんも、あんさんもはよぉ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「うちのヌルヌルおまんこにキスしておくれやすぅ♪　まんことチンポのディ\nープキス……んっんっ♪　お願いします、どうかお口で……ぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「あっ♪　あ、あああああ～っ、ああああ……！　そうっ、そう、そうどすぅ\nうう！　おまんこ、おまんこぺちゃぺちゃ舐めて、舐めて、舐めてぇえ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0103121" ]},
		{"command":[ "SETIMAGE", "0", "still_00019801_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「うちも、うちもおちんぽにご奉仕しますから♪　二人同時に気持ち良くなり\nたいんどすぅう♪　はぁああっ……あああ、ああ、すごい、すごいぃ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「隊長さぁんのクンニゾクゾクするえぇ♪　うちも……うちもおちんぽレロレ\nロせな……。んんむ♪　ぴちゃ、ぴちゃ、ぴちゃ……ちゅぱ、れっろっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「あん♪　あんっ、あぁんん♪　気持ち……ええ♪　気持ちええ♪　シックス\nナイン、頭おかしくなってまいそぉやぁ……すっごい気持ちええのぉお♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「れろっ……れろっ、れろぉ……！　ぺろ、ぺろ、ぺろ……！　ンン……♪　\nこっちも……ぺろっ、おちんぽ、おちんぽの全部の角度舐めつくして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「うちの唾液まみれにするのん……♪　ん、ぺちゃ、ぺちょっ、ぺちゃ……あ\nああ……♪　見てぇ♪　唾にまみれた亀頭がツヤツヤ綺麗やぁ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「ん……んん……おいひぃ……♪　あんさんの味ってこないな風やねんねぇ…\n…。すっごくジュンとくるわぁ……。あぁ♪　あ、あ、あ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「大きすぎて口に入りきらん……♪　れろ……んん♪　それに、このどっしり\nとした太さ……。逞しくって、血管が浮き上がってて男らしい……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「はぁあ……♪　好き♪　好きや……♪　おしゃぶりするのが止まらへん……\n♪　ぴちゃっ、ぴちゃ、ぴちゃ……んん……♪　んん、んー……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「ねーえ♪　根元まで舐めてええかしら？　れろ……♪　あぁ……♪　こっち\nはますます味が濃いわぁ……。クラクラするくらい香りも強いし……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0103130" ]},
		{"command":[ "SETIMAGE", "0", "still_00019801_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「ぺろ、ぺろ、ぺろ……れろ♪　んんぅ♪　んん、んん……♪　もぉお♪　め\nっちゃもどかしい……ベロだと一度に全部舐められへん……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0103131" ]},
		{"command":[ "SETIMAGE", "0", "still_00019801_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「ぷっくり膨らんで可愛い先っちょも、硬くてゴツゴツしたおちんぽ竿も……\nあぁん♪　陰毛かきわけて舐める根元も、タマタマすらおいしいのにぃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「うちのベロが短すぎるんやろかぁ……♪　ううん、やっぱちゃうわぁ、あん\nさんのがおっきすぎるのぉ……♪　ぺちゃっ……ぺちゃっ、ぺちゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「んん♪　幸せ♪　大好きな人におまんこねぶられながら……はぁんん♪　お\nちんぽペロペロできて幸せ♪　おいしい、おいしい、おいひぃの……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「えぇ？　淫らな顔しすぎてるぅ？　やぁ……見んとってぇ♪　おちんぽに集\n中してやぁ、恥ずかしい……。でも、あんさんも相当なもんやでぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0103135" ]},
		{"command":[ "SETIMAGE", "0", "still_00019801_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「おちんぽバッキバキ……♪　あは、あは……♪　出ちゃいそう？　ええよ…\n…一回出して楽になっとこか……。うち、本気だして吸ったげる♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0103136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「ん、ぺちゃ……ぺちゃ、ちゅうぅう♪　ちゅ、ちゅ、ちゅぅ……ぢゅるっ、\nれろ、れろ……れろ♪　ん、んん♪　ぴちゃっ……ぴちゃっ、ちゅぷ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0103137" ]},
		{"command":[ "SETIMAGE", "0", "still_00019801_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「ぺちゃっ、ぺちゃっ、ぺちゃ……れろれろぉ……♪　んぁ♪　おツユ垂れて\nきたぁ……飲んじゃうぅ♪　ぢゅる……ごくん、ちゅる、れろ、れろれろ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「ん？　んん？　あぁ……めっちゃ太くなってきたぁ……♪　ええよ、うちも\n欲しい……♪　一番くっさい精液欲ひぃ……欲しいのん……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0103139" ]},
		{"command":[ "SETIMAGE", "0", "still_00019801_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「れろ、れろ、れろ……出ひて♪　出ひて出ひてぇ♪　れろ、れろ、れろ、れ\nるれるれる♪　ちゅぱ……ぺろ、ぺろ♪　ぺろぺろぺろ……今やぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0103140" ]},
		{"command":[ "SETIMAGE", "0", "still_00019801_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「んん、んんーっ……んぶっ♪　ぢゅるっ……ぢゅるっ、ぢゅるるるっ……！\n　ぢゅー、ぢゅー……ぢゅるっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0103201" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019801_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「ごくっ……♪　ごくっ、ごく……ぷぁああ……♪　あああ、ウソやろぉ……\n♪　酔ってまいそーなくらい濃いぃやん……素敵すぎるわぁ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「あんまりはっきり射精の匂いするもんやから、うち、とっさに尿道口に吸い\nついてもうたけど……そこから噴水みたいにびゅーっ、びゅーってな♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0103203" ]},
		{"command":[ "SETIMAGE", "0", "still_00019801_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「うちのお口の中に精子がたっぷり注がれていくの……♪　何度も何度も、び\nゅるーっ、びゅるーって……まるで精液の出るホースみたいやった♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0103204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「それを、頬いっぱいにほおばりながら……飲み干す時の恍惚といったらあら\nへん……♪　ぶわぁって鼻腔に精液の香りが広がって……んー……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「こんなん、やみつきやわ♪　ねーえー……♪　うち、もっと精液欲しい♪　\n胃の中だけやなくて、うちの喉も、口も舌も強烈な臭いに包まれるような」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0103206" ]},
		{"command":[ "SETIMAGE", "0", "still_00019801_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「特濃の射精、何度でもして欲しいんよ……♪　やから……。あむっ♪　もっ\nぺんおちんぽご馳走になるわ♪　んんー♪　ちゅむ♪　ちゅむ、ちゅむ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「あんさんも、うちのおまんこで楽しんでぇ♪　……ふふ、舐めてるとわかる\nやろぉ？　さっきの射精でうちが軽く達してしもたこと……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「イったばっかでやーらかくなったトロトロおまんこをご賞味あれ♪　うちも\n……♪　はぁ、はぁ、うちもおちんぽ舐め舐めさせてもらうわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「ぢゅる……♪　ぢゅ、ぢゅ、ぢゅ……♪　くちゅっ！　ちゅっぷっ、ちゅぷ\n……んうううう♪　まだ精子の味残ってる♪　残ってるぅ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0103210" ]},
		{"command":[ "SETIMAGE", "0", "still_00019801_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「これ、ぜーんぶうちのやぁ……♪　うちのもんやぁ♪　ん、ぐちゅ♪　ぐち\nゅっぐちゅっ……ぢゅるっ♪　ごくんっ……ぢゅるっ、ぢゅるるるっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「ん、あっ♪　おまんこからぁ……隊長さぁんのベロの感触がヌメヌメして…\n…うちはうちで、おちんぽむしゃぶりついて咥えて、すすって……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「至福、至福やぁ……んぐちゅっ！　ちゅむっ、ちゅむっ、ちゅむ……んぁん\nん♪　もっろ……♪　もっろ奥まで……おひんぽ全部咥えらい……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「ん、む……！　ぐちゅうぅうう♪　ぐちゅっ、じゅっぷっじゅぷっ……れろ\nれろれろれろ♪　はぁー♪　はぁー♪　ぐちゅ、れろれろれろれろぉぉ♪」", "NORMAL" ]},
