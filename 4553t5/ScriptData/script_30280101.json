{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「エッチなことをしたことがあるのかって……？　な、なんでそんなこと、あ\nんたに教える必要があるの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0103101" ]},
		{"command":[ "SETCHARA", "0", "char_00002801_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「そんなセクハラをするようなヤツは、この大桃切で叩き斬ってやる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0103102" ]},
		{"command":[ "SETCHARA", "0", "char_00002801_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「なに？　今更命乞い？　……はぁ？　もっとあたしのことを理解したかった\nから、こんな質問をしたの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0103103" ]},
		{"command":[ "SETCHARA", "0", "char_00002801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「理由はわかったけど、セクハラに変わりないわよ！　反省しろっ！　この変\n態っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0103104" ]},
		{"command":[ "SETCHARA", "0", "char_00002801_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「まったく……こんなセクハラ受けたら、あの日のこと、思い出してきちゃう\nじゃない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0103105" ]},
		{"command":[ "SETCHARA", "0", "char_00002801_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「ね、ねえ……本当にこれを舐めるの？　なんか、カタくて、大きくて……変\nなニオイがするんだけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0103106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00002801_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「べ、別にイヤとは言ってないでしょ！　それにこれは、ブラックメルヘンの\nヤツらを倒すため……原典を守るためよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0103107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「あんたのオチンチンを舐めて射精させれば、今よりもっと強くなれるからっ\nて……そういう約束だったでしょ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「強くなれるとか、本気で信じてるわけじゃないけど……まあ、あんたのオチ\nンチンだし、イヤじゃないかなって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「と、とにかく、これはあたしのためってことを忘れないで！　さっさと始め\nるわよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「ぐぷっ……ちゅ、んちゅ……じゅるっ、ちゅちゅ……んっ、んむっ……これ\nが、オチンチンの味なのね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0103111" ]},
		{"command":[ "SETIMAGE", "0", "still_00002801_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「咥えてるだけで……熱いのが、舌から伝わってくる……んっ、じゅぐっ……\nちゅぱっ、ぢゅちゅ……んっ、んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「あぷっ……はぁ、はあぁ……大きいから、ずっと咥えてると息苦しくなって\nくるわね……あむっ……んっ、ちゅぱっ、じゅるるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「にちゅるっ、ちゅぐっ……ぐぽっ、じゅずっ……何処を舐められると、気持\nちがいいとか……あったりする？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0103114" ]},
		{"command":[ "SETIMAGE", "0", "still_00002801_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「だって……あんたを気持ちよくした方が、早く精液を出して貰えるでしょ…\n…ちゅ、んちゅ……ぐぷぷっ、くじゅ、ちゅるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0103115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「ふーん……この亀頭っていう、デコボコしたところがいいのね……なら、こ\nこを重点的に舐めてあげるわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「あ、あと……はじめて舐めるし、痛かったりしたら遠慮なく言ってくれてい\nいから。あんたも痛いより、気持ちいい方がいいでしょ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「ぢゅぱっ……れろっ、ちゅちゅ……ぷちゅ、ぴちゃっ……んっ、あんっ……\nにちゅ、ぐちゅ……ずぞっ、ぬりゅうぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0103118" ]},
		{"command":[ "SETIMAGE", "0", "still_00002801_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「んっ……あふっ……！　オチンチンがビクビクし始めたわね……そんなにあ\nたしの口が気持ちいいの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「ちゅくっ、じゅるっ……ちゅぱっ……！　んっ、はあぁ……もっと奥まで咥\nえて、吸って欲しいのね……わかったわ……あむっ、くちゅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「んっ、んんっ……！　ぐぽっ、ぢゅぷっ……！　ちゅ、れろっ……じゅるっ\n、ちゅぱっ……ちゅぱっ、ちゅぷぷっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「ずっ、じゅるっ……！　ぐちゅ、じゅぞぞっ……！　けほっ、けほっ……！\n　オチンチンの先端から、汁が出てきたわよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0103122" ]},
		{"command":[ "SETIMAGE", "0", "still_00002801_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「ネバネバしてて、変な味がするけど……これ、飲み込んでも大丈夫なの……\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「害がないなら別にいいわ……それに、あんたのオチンチンから出た汁だった\nら……イヤじゃないから……ぐちゅ、ちゅぷっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ、じゅるっ……！　ぐぽっ、じゅぞぞっ……！　ちゅ、ちゅるっ…\n…！　にちゅ、ちゅぷぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「うぐっ……あむっ、うむぅ……！　舐めれば舐めるほど、次から次に汁が溢\nれてくるわね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0103126" ]},
		{"command":[ "SETIMAGE", "0", "still_00002801_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「さすがに全部飲んでると、お腹が苦しくなるわ……あむっ、くちゅ、じゅち\nゅ……ぷちゅ、ちゅぱっ……じゅぞっ、ぢゅじゅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「それにこの汁……舌で味わってると、どんどんエッチな気持ちになってくる\nっ……！　触ってないのに、オマンコが疼いてくるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「じゅるっ、ちゅるるっ……ずぽっ、ぐぷっ……！　はぁ……はあぁ……！　\nね、ねえ……まだ射精しないの……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「オチンチンしゃぶって、吸ってるだけなのに……あたしそろそろ限界で……\nんっ、あふっ……！　ちゅ、ちゅちゅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「もう少しでイキそうだから、激しく吸い付いつけばいいのね……！　あむっ\n……ぐぷっ、じゅぞっ……！　ちゅぱっ、にちゅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「んふっ……あっ、あぷっ……！　ちゅぱっ、じゅるっ……！　んっ、んんっ\n……！　オチンチンが、口の中で暴れてるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0103132" ]},
		{"command":[ "SETIMAGE", "0", "still_00002801_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「そんなにビクビク動かされたら……オチンチンの味と感触が、口いっぱいに\n広がって……んんっ、か、感じちゃうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「ずちゅ……！　ちゅ、くちゅ……！　はぁ、ああっ……！　イッ、イキそう\nなの……！？　いっ、いいわ……全部、出して……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「あたしの口であんたの精液、全部受け止めてあげるから……！　遠慮しない\nで、口をいっぱい汚してっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0103135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「あぶっ……！　んっ、ぐちゅ……！　ちゅぱっ、じゅるっ……！　これが、\n精液っ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0103136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002801_01_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「さっきオチンチンから出てた汁よりドロドロで……んっ、ごくっ……ごくん\nっ……！　うぶっ……！　の、喉に絡むぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0103137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「あっ……はああぁ……！　ちゅぱっ、ちゅぱっ……！　あっ、あっ……！　\nこれ、飲んでるだけで……オマンコが変になってくるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「はぁ、あああっ……！　イクッ……！　イッちゃうぅ……！　精液で気持ち\nよくなって……イッ、イクッ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「ずちゅ、ぐりゅ……！　ちゅぱっ、じゅるっ……！　あっ、あっあっあっ…\n…！　イクッ、イクぅぅぅ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「ずちゅ……ちゅ、じゅるっ……はあ、はああぁ……オチンチン咥えたまま、\nイッちゃったわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0103201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「んちゅ……ぷはっ……あれだけ出したのに、オチンチン大きいままじゃない\n……男の人って、一回射精したら小さくなるんじゃないの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0103202" ]},
		{"command":[ "SETIMAGE", "0", "still_00002801_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「あたしのフェラが気持ちよかったから、勃起したままになってる……？　ふ\n、ふーん……そうなのね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0103203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「ねえ……もっと出したいんでしょ……？　あ、あたしももっと強くなりたい\nし……その……手伝ってあげなくもないけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0103204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「んっ……あんたがそこまで言うなら、もう一回シてあげるわ……はむっ……\nくちゅ、じゅ……ちゅぱっ、ちゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「ずぷっ……ちゅぽっ、ぐぽっ……！　はああぁ……オチンチンの中に、精液\nが残ってるわよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0103206" ]},
		{"command":[ "SETIMAGE", "0", "still_00002801_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「これ、吸い出した方がいいのよね……ずっ、じゅるっ……！　ちゅ、ちゅぷ\nっ……ちゅぱ、にちゅ、ぐちゅるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「んっ……こくっ、ごくっ……んんっ……！　はあぁ……変な味だけど、あん\nたの精液なら……もっと飲みたいわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「は、はあ！？　別に精液が気に入ったとかじゃなくて……！　そ、そう！　\nあんたを射精させれば、強くなれるから……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0103209" ]},
		{"command":[ "SETIMAGE", "0", "still_00002801_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「精液はその副産物っていうか……！　とにかく、あんたはあたしの口で気持\nちよくなってればいいのよ……！　ちゅ、ちゅるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0103210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「っていうか、あたしにそんな口をきいていいのかしら？　あんたのオチンチ\nンの弱点、とっくにわかってるのよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「ぐちゅっ、ちゅるっ……ぷちゃ、れろれろっ……！　ぴちゅ、ちゅちゅ……\n！　やっぱり……亀頭の裏側が弱いみたいね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「舌先でグリグリほじるだけで……ぐちゅ、じゅっ……ちゅぱっ、にちゅ……\nビクビクって暴れまくってるわよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0103213" ]},
		{"command":[ "SETIMAGE", "0", "still_00002801_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「それに、このエッチな汁が出て来るところ……オチンチンの先端も、弱点な\nんでしょ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0103214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「ふふっ……あんたの切なそうな顔を見てれば、すぐにわかるわよ……桃太郎\nの末裔である、あたしの観察眼を舐めないでよね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0103215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「ぐぷっ……ちゅ、じゅるっ……！　ちゅぱっ、じゅるっ……！　はああぁ…\n…また、エッチな汁が口いっぱいになってくるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0103216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「んっ、んじゅるっ……！　ダメっ……！　鼻の奥に、オチンチンのニオイが\n染みわたってきて……んんっ！　また、イっちゃうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「ああっ、んっ……！　にちゅ、ぐちゅ……！　じゅぱっ、ぢゅぷぷっ……！\n　あ、あんたのオチンチンも暴れ出してるわね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0103218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「イキたいなら、イッていいわよ……！　あたしも限界だから……！　にちゅ\n、じゅ……ちゅ、くちゅ、ずちゅるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「あっ、あっ！　んちゅ、ぷぢゅ、じゅるぅ……！　イクッ……イクッ……！\n　ふあぁ、あっ……んくううぅ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「うぶっ……！　ぐっ、あぶぅ……！　また、いっぱい口の中に出して……じ\nゅるっ、ぷちゅうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0103301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002801_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「あっ、あふっ……！　なによこれ……！　さっきよりも量が多いじゃない…\n…！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「こんなに出されたら、飲み込めない……んぐっ、ごくんっ……！　あふっ、\nじゅるるっ……！　ちゅぱ、にちゅるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0103303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「げほっ、けほっ……！　くっ、苦しっ……！　あふっ……！　じゅるるっ…\n…！　ちゅぱ、んっ、んっ……ちゅうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0103304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「やっ、あふっ……！　ま、まだ出るの……！？　あんた、少しは遠慮っても\nんを……！　んんんっ！　ちゅぱっ、じゅぞおおぉ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0103305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「ふーっ……ふーっ……んっ、ちゅうぅ……こくっ、こくっ……ごくんっ……\n！　さすがに、飲みすぎたわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0103306" ]},
		{"command":[ "SETIMAGE", "0", "still_00002801_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「お腹の中、精液でいっぱいになってる……今日はもう、ご飯が入りそうにな\nいわね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0103307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「まったく……こんなに出すなんて、さすがに予想してなかったわ……んっ、\nちゅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0103308" ]},
		{"command":[ "SETIMAGE", "0", "still_00002801_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「でも、気持ちよかったみたいね……満足してくれたみたいで、よかったわ…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「あ、あたしも気持ちよかったし……んっ……前より強くなれた気がするわ…\n…だから、その……あ、ありがと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「きゃっ……！？　お、オチンチンが抜けて……！　えっ、なに！？　顔の前\nに両手を出して、精液を受け止めろって……きゃあああぁ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0103401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002801_01_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「あぶっ、んぶううぅ……！？　あっ、熱っ……！？　ちょっと、顔に出すな\nんて聞いてない……あっ、ふあああぁ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「やっ、ああっ！？　ちょっと、止めて……！　こんなに熱いの、全部受け止\nめられないから……！　あっ、あっあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0103403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「んんんっ！　精液のニオイ、いっぱい感じちゃうっ……！　ダメっ……！　\nこのニオイと熱さで、イッ……イクッ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0103404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「あっ……あっ！　イクッ……イグッ……！　ふあっ、あんっ！　あっ、イク\nッ……！　んんん～～～～～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0103405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「はぁ……あっ、はあああぁ……ちょっと。あたしの顔……精液まみれなんだ\nけど……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0103406" ]},
		{"command":[ "SETIMAGE", "0", "still_00002801_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「出していいとは言ったけど、顔にかけていいなんて一言も言ってないし……\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0103407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「それに、手で精液を受け止めさせるだなんて……こんな、エッチな恰好させ\nて……んっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0103408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「精液を受け止めて欲しかったって……まったく。あんたって、本当に救いよ\nうのない変態ね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0103409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「別に怒ってないわ……でも、次はちゃんと出す前に、何処に出すか言ってよ\nね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0103410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
