		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「遊びに行くわけじゃないんですってば……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020116190002" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「あれ？　あんたたち、ＥＤＯの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_010116190001" ]},
		{"command":[ "SETCHARA", "0", "char_00022601_01", "3", "CENTER", "0" ]},		
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「っ！？　あんたたちは！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020116190002" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「襲来者（インベーダー）じゃない！　さてはあなたたちがスケバンサンダー\nを隠してるのね！？　さあ、出しなさい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020116190002" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「な、なんの話！　っていうか、今日は侵略活動じゃないから！　きょうは休\n日で遊びに来ただけだから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_010116190001" ]},
		{"command":[ "SETCHARA", "0", "char_00022701_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「そうそう！　たまたま知り合いのあんたたちを見かけたから、声をかけただ\nけ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_010116190001" ]},
		{"command":[ "SETCHARA", "0", "char_00022801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「なーんだ、つまんないの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020116190003" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「つまんないとか、そういう問題じゃないと思いますけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020116190003" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「まあ、勤務中じゃないんならどっちでもいいか。あんたたち、宇宙から来た\nスケバンを見なかった？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020116190003" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「ああ、スケバンサンダーとかいうヤツ？　そういえば今朝会ったけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_010116190002" ]},
		{"command":[ "SETCHARA", "0", "char_00022601_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「今朝？　どこで会ったか教えて！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020116190004" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「えーと、あれはね……あ、いや、ちょっと待って？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_010116190003" ]},
		{"command":[ "SETCHARA", "0", "char_00022601_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「どうかしましたか？」", "NORMAL" ]},
