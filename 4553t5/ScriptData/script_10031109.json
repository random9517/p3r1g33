		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「いいじゃない、あっちこっち探しましょ！　カラオケボックスとか、ボウリ\nング場とか、遊園地とか、それからそれから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020116190001" ]},
