		{"command":[ "SETCHARA", "0", "char_00001702_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「せっかくだし、ここでバトルしとかない？　人数的にもちょうどいいし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_010116190004" ]},
		{"command":[ "SETCHARA", "0", "char_00022601_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「そだね！　バトルで勝てたら、教えてあげる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_010116190002" ]},
		{"command":[ "SETCHARA", "0", "char_00022701_01", "6", "CENTER", "0" ]},
