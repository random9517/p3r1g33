{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0147" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「インクレディブル・スクワッドの新メンバーＭ．Ａ．Ｍ．Ａは、超高性能Ａ\nＩを備えたハイパースクールバスだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_999_010114060001" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「下僕っ、買い物に行くわよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070114060001" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああ、はいはい。で、どこまで？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「隣の県まで！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070114060002" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はぁ！？　そんな遠くまで行くのか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「あら、お出かけかしら～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114060001" ]},
		{"command":[ "SETCHARA", "0", "char_00021201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「隣の県まで乗せていきなさい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070114060003" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「いいわよ～。さ、ママに乗りなさ～い」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114060002" ]},
		{"command":[ "SETCHARA", "0", "char_00021201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「できれば開店に間に合いたいわ。急いで」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070114060004" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おいおい、無茶言うなよ。いまから隣の県まで行くのにどれだけかかると思\nってるんだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「ふふっ、隊長さん、心配しないで」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114060003" ]},
		{"command":[ "SETCHARA", "0", "char_00021201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「私にまかせて。ちゃんと目的地に送り届けてあげるわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114060004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「だって、私に乗った子はみんな、私のファミリーだもの～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114060005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0155" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「別のある日」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_999_010114060002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まさか、教師陣の旅行にまで使われるとは。これ、スクールバスなんだよな\n？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「細かいこと気にするなって。スクールバスなんだからさ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_030114060001" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「ＥＤＯから提供されたものですから。ありがたく使わせていただきます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_050114060001" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「あぁん。シートがふっかふかで座り心地も最高だわ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040114060001" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「みんなに喜んでもらえて、ママもうれしいわ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114060006" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0147" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「さらに別の日」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_999_010114060003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「今日も生徒たちの送り迎えをしてくれて助かったぜ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「ありがとう、隊長さん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114060007" ]},
		{"command":[ "SETCHARA", "0", "char_00021201_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「だけど、わざわざお礼なんていいのよ。だって、これがママのお仕事だもの\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114060008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「でも助かっているのは事実だ。専用の移動手段は、自転車や路線バスより便\n利だしな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「やだもう。隊長さんったら褒めすぎよ。エンジンが高鳴っちゃうわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114060009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「あとは隊長さんを部屋へ送るだけね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114060010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああ、そうだな。はぁ～、帰ったら溜まってるものを出さないとな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「た、隊長さん！？　……溜まってるの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114060011" ]},
		{"command":[ "SETCHARA", "0", "char_00021201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ん？　まあ、溜まってるな。なかなか出せないから」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「隊長さんって、周りに女の子がいっぱいいるから、その子たちに出してもら\nってるのかと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114060012" ]},
		{"command":[ "SETCHARA", "0", "char_00021201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いやいや、あいつらがそんなことするはずねえって。むしろ自分たちの分ま\nで俺に出させますよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「ええっ！？　あの、女の子なのに……出るの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114060013" ]},
		{"command":[ "SETCHARA", "0", "char_00021201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そりゃあ出るだろう。というか、人間生活していれば誰だって出すと思うぞ\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「そ、そうなの……！？　私、人間のことをもっともっと勉強しなくちゃいけ\nないわね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114060014" ]},
		{"command":[ "SETCHARA", "0", "char_00021201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「隊長さん、そんなに溜まっているならママに出してもいいのよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114060015" ]},
		{"command":[ "SETCHARA", "0", "char_00021201_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、Ｍ．Ａ．Ｍ．Ａに出すわけには……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「大丈夫。ママならどれだけ出されたって平気よ。さ、これを使って」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114060016" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ん？　なにか出てきて……って、オナホ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「溜まってる精液、ママが受け止めてあげる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114060017" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「溜まってるって、部屋のごみの話だからな！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「……へ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114060018" ]},
		{"command":[ "SETCHARA", "0", "char_00021201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「えええぇぇぇっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114060019" ]},
		{"command":[ "SETCHARA", "0", "char_00021201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0147" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「Ｍ．Ａ．Ｍ．Ａはすっかりインクレディブル・スクワッドに馴染んでいた」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_999_010114060004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「送ってくれてありがとうございます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130114060001" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ナイスドライブだったわ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020114060001" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「寝坊して大変だったけど、まさか車内で朝ごはん食べられるとはおもわなか\nったよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010114060001" ]},
		{"command":[ "SETCHARA", "0", "char_00001205_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「そうね。しかも走行中にスープがぜんぜんこぼれないなんて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010114060001" ]},
		{"command":[ "SETCHARA", "0", "char_00001406_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「最新の技術ってすごいね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020114060001" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「カツマちゃん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114060001" ]},
		{"command":[ "SETCHARA", "0", "char_00011101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おっ、Ｍ．Ｏ．Ｅか。どうしたんだ、そんなに急いで」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ドリフトしながら停車とは、なにかあったのでしょうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010114060001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「カツマちゃん！　その車なによ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114060002" ]},
		{"command":[ "SETCHARA", "0", "char_00011101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なにって、Ｍ．Ａ．Ｍ．Ａだが」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「ま、ママ……！？　カツマちゃんのママですって……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114060003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、ママっていうのは頭文字をとった呼称で……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「あらあら、でも私は隊長さんのママみたいな存在よ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114060020" ]},
		{"command":[ "SETCHARA", "0", "char_00021201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「なっ、なぁああっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114060004" ]},
		{"command":[ "SETCHARA", "0", "char_00011101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「わたしより後に実装されたのに！　いわばわたしの方が先輩なのに！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114060005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「貴方をママなんてよぶ筋合いはありません！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114060006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「Ｍ．Ｏ．Ｅ、一旦落ち着けって。慌ててやってきたのには理由があるんだろ\nう？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「り、理由？　あ……えっと……。さ、最近カツマちゃんがわたしに乗ってく\nれないから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114060007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「それで？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「それでって……それだけだけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114060008" ]},
		{"command":[ "SETCHARA", "0", "char_00011101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ふむふむ。……まあ、たしかに最近はＭ．Ａ．Ｍ．Ａに乗ってばかりだった\nな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「わたしはカツマちゃんの愛車なのにっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114060009" ]},
		{"command":[ "SETCHARA", "0", "char_00011101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「だけど、人数が多いときはＭ．Ａ．Ｍ．Ａの方がいいしなぁ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「荷物も沢山積めますしなぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010114060002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「それでもカツマちゃんにはわたしに乗ってほしいの！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114060010" ]},
		{"command":[ "SETCHARA", "0", "char_00011101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「他の人がそっちのバスを選んでも、カツマちゃんにはわたしを選んでほしか\nったのに！」」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114060011" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「あらあら、隊長さんを困らせちゃいけないわよ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114060021" ]},
		{"command":[ "SETCHARA", "0", "char_00021201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「貴方は黙ってて！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114060012" ]},
		{"command":[ "SETCHARA", "0", "char_00011101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まあ、適材適所っていうか、今回はＭ．Ａ．Ｍ．Ａの方が便利だったから使\nっただけでな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「そ、そんな……。カツマちゃんにとって、わたしは不便な車なの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114060013" ]},
		{"command":[ "SETCHARA", "0", "char_00011101_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、そんなことはないぞ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「カツマちゃんにとって、わたしは都合のいい車でしかなかったのね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114060014" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そこまで言ってないだろ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「もういいっ！　実家に帰らせていただきます！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114060015" ]},
		{"command":[ "SETCHARA", "0", "char_00011101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おいっ！　Ｍ．Ｏ．Ｅ！　実家ってどこだよ！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「あーあー。行ってしまいましたなぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010114060003" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "5", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「あらあら、急に暴走しちゃって、反抗期なのかしら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114060022" ]},
		{"command":[ "SETCHARA", "0", "char_00021201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ＡＩに反抗期なんてあるのか？　まったく……って、お前らなんて目で俺を\n見てるんだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ここは『ちょ、まてよ』って追いかけるところじゃない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020114060002" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「自暴自棄になっているようですし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130114060002" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「あの子のカツマさんを想う気持ちは本物だもの。ショックだったのね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010114060002" ]},
		{"command":[ "SETCHARA", "0", "char_00001406_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「ここは追いかけるべきだよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010114060002" ]},
		{"command":[ "SETCHARA", "0", "char_00001205_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうはいっても相手は車だぞ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「じゃあ、こっちも車を使えば」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020114060002" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「Ｍ．Ａ．Ｍ．Ａか。そうだな。Ｍ．Ｏ．Ｅを追いかけてもらえるか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「隊長さんの頼みを断ることなんてしないわ～。さ、みんな乗って～」", "NORMAL" ]},
