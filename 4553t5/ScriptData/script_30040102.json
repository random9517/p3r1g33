		{"command":[ "PLAYVOICE", "004_0104302" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「きゃぅうううんっ！　熱くてドロドロの子種が、オマンコの奥にっ！　きゃ\nうっ、あうぅっ！　どぴゅどぴゅっ、種付けされてるぅっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0104303" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「んぎゅうううっ！　もうオマンコいっぱいっ、せーし入らないっ！　んぎゅ\nっ！？　きゃうぅぅっ！　子宮まで、入ってきてるぅっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0104304" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「きゃうっ、きゃううんっ！　せーえきっ、そんなに入ってきちゃったら、妊\n娠しちゃうっ！　子ども孕んじゃうぅっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0104305" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「くふぅぅううんっ！　せーえき、熱いっ、気持ちいいぃっ！　またイっちゃ\nうっ、オマンコに中出しされながら、イっちゃうぅぅうううっ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0104306" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「……はへっ、はへっ、はへっ……！　またイった、イかされたぁ……オマン\nコの奥にたっぷり種付けされてぇ……んうぅ、負けちゃったぁ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0104307" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「……でも、いい……お前になら負けても……お前との勝ち負けは、ホントは\nもうどっちでもいい……ふふっ、こんな気持ち、初めてだ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0104308" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「……はうぅ、ナカから精液があふれてきてる……こんなに中出しして……本\n当に孕んじまったら、ちゃんと責任取ってもらうからな？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000401_02_10" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0104309" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「私は月狼族の長だからいっぱい子どもを産まないといけないんだぞ？　そう\nだな……１００人は産まないとな！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0104310" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「もちろん、子育ても手伝ってもらうからな？　イヤとは言わせないぞ！　ふ\nっふふ～ん、元気な子がたくさん生まれるといいな……パ・パ♪」", "NORMAL" ]},
