{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000401_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "PLAYVOICE", "004_0104101" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「あぁ……お尻に、当たってる……固くて、熱いのが……お前のチンチンが、\n私のお尻に……んふぅぅん……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0104102" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「な、なぁ……？　今日は、その、シてくれるんだろ……？　私が頑張ったご\n褒美に……いつもより、特別なマッサージってやつを……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0104103" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「す、すごく頑張ったんだからな……！　もっともっと、褒めてくれてもいい\nんだぞ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0104104" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「はうぅぅ……そんなこと言われたら、欲しくなっちゃうだろぉ……ほ、ほら\n、早くぅ……特別なマッサージってのを、早くぅ……はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0104105" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「べ、べつに、興奮なんてしてないぞ……！　私はただ、その……あっ！　あ\nっあっあっ、あぁんっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0104106" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「んあぁぁ～～……当たってる、私のアソコに、固くて、熱いのがぁ……んあ\nぁぁぁ……先っぽが入り口に当たってるぅ……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000401_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0104107" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「あっあっあっ、入り口のところっ、くぽくぽっ、あふぅぅん、固い棒の先っ\nぽが、浅くほじくってるぅ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0104108" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「それ、それを、もっと中に……奥まで、挿れてくれぇ……あうぅぅんっ、も\nっと深く、挿れてぇ……奥までマッサージしてくれよぉ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0104109" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「うぅぅ……なんでそんな、焦らすんだよぉ……んあぁぁ～～っ、あっ、あっ\n、早くぅっ、挿れてくれよぉ、奥までソレを……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0104110" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「い、いいんだ……これは、ただのマッサージだから……はぁうぅっ、Ｈなこ\nとじゃなくて、ただのマッサージだから、大丈夫っ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0104111" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「その大っきくて立派なマッサージ棒で、あっあっあっ、アソコをほぐしても\nらうだけだからっ、ごりゅごりゅって、奥まで擦ってもらうだけだからっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0104112" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「……なっ！？　ウ、ウソをつくなぁっ！　う、嬉しそうに、尻尾をフリフリ\nだなんて……そんなことしてないっ！　ほ、本当だぞっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000401_02_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0104113" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「メ、メス犬みたいとかいうなぁっ！　犬じゃなくて私は狼……あっあっあっ\n、そこっ、そこぉっ……あぁっ、ちがうっ、尻尾なんて振ってないぃ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0104114" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「い、いくらお前でもぉ、んあぁぁ、お、怒るからな……あぁんっ、入り口、\nクポクポぉ、ヤメロぉ、今、大事なことぉ……んあぁぁっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0104115" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「こ、このぉっ！　だから、私は何度も言うようにっ！　誇り高き月狼族の、\nぞくちょ……ぉほぉおおおおおおおおんっ！！？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000401_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0104116" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「オ、オチンチン、入ってきたぁっ……！　ナカを、ブリュブリュってこすり\nながらぁ……！　一気に、奥までぇっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0104117" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「んあぁぁっ！　ズンって、今、先っぽが、一番奥のところ……んぉおおおっ\n！　そこっ、押すなぁっ！　ひぃんっ！　もう入らないからぁっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0104118" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……うぅ、ひどいぞ、イキナリ挿れるなんて！　へ、変な声が、\n出ちゃったじゃないか！　バカっ！　あとで覚えてろよぉ……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000401_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0104119" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「え、あ、あ、あ……ま、待ってくれ、抜かないでぇ……！　わ、わかった！\n　何もしないからっ、だからもっと、奥まで……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0104120" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「んふぅううぅぅぅんっ！　また入ってきたぁっ……んあっ！　あっあっあっ\n、抜けてっちゃうっ……んぎゅぅぅぅっ！　奥までっ、出たり入ったりっ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000401_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0104121" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「きゃふぅぅっ……！　きゃぁあんっ！　アソコに、オチンチンが、ズポズポ\nぉっ！　あひゅううんっ！　激しすぎるぅっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0104122" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「オチンチンすごいぃっ！　ひあぁぁうっ！　固くて、太くてぇっ！　焼けた\n棒みたいに熱いのが、グリグリっ、オマンコかきまわしてるぅっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0104123" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「でっぱりがゴリゴリぃっ！　ナカをほじくってぇ！　あひっ、ひっ、ひぃん\nっ！　気持ちいいところ、いっぱい擦ってるぅぅっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0104124" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「オチンチンの先っぽで、ズンズンって、アソコの奥がぁっ！　はぁんっ、は\nぅっ、あふぅぅっ、お腹がジンジン熱くなって、おかしくなっちゃうっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0104125" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「きゃひぃいいいんっ！　すごいぃっ！　マッサージ気持ちいいっ！　ご褒美\nマッサージすごすぎるよぉっ……！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0104126" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、あっ……！　クるっ、キちゃうぅっ……！、気持ちいいのキち\nゃうっ！　もうキちゃうっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000401_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0104127" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「また負けちゃうぅっ！　マッサージされて、イかされちゃうっ！　気持ちよ\nくなっちゃうぅぅっ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0104128" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「んあぁぁっ！　キてるっ、目の前が真っ白になってぇっ……あひぃいいんっ\n、堕ちるっ、気持ちよく堕とされちゃうっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0104129" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「あっあっあっ、イく、イくっ、オチンチンでアソコ、オマンコ、ゴリゴリさ\nれてっ、マッサージされて、イっちゃうっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0104130" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「んあぁぁぁぁっ！　ダメぇっ！　大っきいのクるっ！　堕ちるっ！　イっち\nゃうっ！　イくっ！　イくイくイくっ……イっくぅうう～～～～～んっ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0104131" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「あぅうううぅぅ～～～んっ！　あぅっ、あっ、あふぅんっ……！　イくぅっ\n、イってるぅっ……！　ナカにＨなお汁出されながら、イってるぅっ！」", "NORMAL" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000401_02_08" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0104132" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「んぁぁぁ～～……っ、熱いのが、ドピュドピュッ、きゃふっ、あっあふっ！\n　奥にいっぱい、出てるぅっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0104133" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「ドロドロしたお汁が、奥の壁にっ、あひっ、あひゅっ！　ビチャビチャかか\nってるぅっ！　ナカにどんどん溜まっちゃってるよぉ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0104134" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「んあぁぁっ！？　コラぁっ！　せーえき出しながら動くなぁっ！　あふぅう\nううんっ！　また気持ちよくなっちゃうからぁっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0104135" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「んあっあっあっ、ダメっ、またイくっ、せーえき絞るのにオマンコ使われて\nっ、またイっちゃうっ、オチンチンでイっちゃうう～～～っ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0104136" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「……はっ、はっ、はっ……うぅぅ～～～っ、またイかされたぁっ……んあぁ\n、あっ、あっ……イっちゃったよぉ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000401_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0104137" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「はふぅぅ……特別なマッサージ、激しすぎるぅ……んあぁ、あ、あ……はふ\nぅ……またいっぱい気持ちよくされてしまった……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0104138" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「Ｈなマッサージ棒で、オマンコのナカをズポズポかき回されて……はぁうぅ\n……イかされたぁ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0104139" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「で、でも！　私は負けてないぞ！　せーえきを出したってことは、チンチン\nも気持ちよくなったってことだ！　だから、今回は引き分けだな！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0104140" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「いや、むしろ私よりもお前の方が少しだけイくのが早かったんじゃないか？\n　なら、この勝負は私の勝ちってことだな！　ふっふ～ん♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0104201" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「んぁぁっ……な、なぁ……なんで、腰を引くんだ……？　それに……んぅぅ\n、オチンチンがナカで、さっきよりも固くなってるような……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0104202" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「え、もしかして……ま、待ってくれ！　今、イっったばかりで、ナカがビン\nカンになってるから……さっきみたいに、勢いよく挿れたら……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0104203" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「あぉおおおおおんっ！！　おっ、おひっ……また、一気に奥までぇっ……ひ\nっ、あひぃいいぃぃっ！　そのままっ、抜き差しっ！？　あふぅううんっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000401_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0104204" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「あんっあんっあんっ！　いいっ！　オチンチン、気持ちいいぃっ！　イった\nばっかりなのに、さっきよりオチンチン固くなってるぅっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0104205" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「あっあっあっ、さっきより先っぽっ、亀頭のとこ、デコボコしてるっ！　で\nっぱりがオマンコのナカ、ほじくってるぅっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0104206" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「きゃふぅうううんっ！　すごい、気持ちいいっ！　もっとしてぇっ！　オチ\nンチンでオマンコ、ズポズポかきまわしてぇっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0104207" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「……え？　あ、あ……？　ど、どうしてやめるんだ……？　んふぅぅ……ん\nぁ、あ、あ……そんな、ゆっくりなんてぇ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000401_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0104208" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「んあぁぁ……あ、あ、ちがう、そこじゃなくてぇ……きゃうぅん……そんな\n、入り口のとこばっかりぃ……うぅぅ、ソコはヤだぁっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0104209" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「もっと、奥までしてぇっ……！　パンパン、オマンコしてくれ！　ずにゅう\nう～って、オチンチン……オチンポっ、奥まで挿れてくれぇ……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000401_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0104210" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「オチンポで奥まで、オマンコのナカをゴシゴシこすって……あふぅぅん……\nぶっといでっぱりのとこ、カリ首で、ぐちゅぐちゅかきまわしてくれよぉ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0104211" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「あぁぅ、またソコ……んぅぅ、ヤダぁ、入り口イヤぁ……！　お願いだ……\n！　こんなのもどかしくて……んふぅぅ、おかしくなっちゃうよぉ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0104212" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「うぅぅ～～……わかった、認める、認めるからぁっ……！　私の負けだ！　\nさっきのは、私がお前のオチンポに負けた！　だから、早くぅ……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000401_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0104213" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「……なっ！？　そ、そんなことまで私に言わせるのか……！？　ぐぅぅ～～\n、お前ってヤツはぁ……オニ！　アホ！　アクマ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0104214" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「あ、あ、あ……ダメだ、抜かないでくれ……！　わ、わかった！　ごめん、\nごめんなさい！　言う、言うから……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0104215" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「うぅぅ～～……お前だけだぞ！　こんなことお前にしか言わないし、させな\nいんだからな！　わかったか！？　くぅぅ～～……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0104216" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「……わ、私は……セレーナは、お前専用のＨなメス犬だ……！　お前のオチ\nンポを挿れて欲しくて、尻尾を振る、おバカなメスワンコだ……！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0104217" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「ほ、ほら、言った！　言ったぞ！　だから、奥まで…………きゃふぅううぅ\nぅ～～～～んっ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0104218" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「これぇ、これがほしかったんだ……！　んあぁっ、あっ、あっ、あぁっ！　\nいいっ、オチンポいいっ！　お前のオチンポ気持ちいいぃっ！！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000401_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0104219" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「好き、これ好きぃっ！　マッサージっ、Ｈなマッサージ、気持ちいぃっ！　\nセックス大好きっ！　気持ちいいぃぃっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0104220" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「後ろからパンパンっ、動物みたいにオチンポ挿れられて、イくっ、イっちゃ\nうっ、メス犬みたいにイくぅっ！　イっくううう～～～～～っ！！！」", "NORMAL" ]},
