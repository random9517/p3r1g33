		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0104407" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「わぁ、すごい、こんなところまで飛んできてる……んぅぅ、肌にべったりと\nはりついて、熱くて……はうぅ、ニオイもすごい……」", "NORMAL" ]},
