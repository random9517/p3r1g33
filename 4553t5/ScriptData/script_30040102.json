		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0104403" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「お尻にも、背中にもぉ……んあぁぁっ、あっ、あぁっ……熱いのが、たくさ\nん……ひぅっ！　火傷しちゃうよぉっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0104404" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「んあぁっ、あっ、あっ……また、出てるっ……！　ザーメン、たくさん……\n！　どぴゅどぴゅ、身体中にかけられちゃってるぅっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0104405" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「あっあっあっ、また、イきそう、イくっ、イっちゃうっ……！　オチンポか\nらＨなお汁をかけられて、イくっ、イっくふぅううぅぅんっ！！", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0104406" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「……はあぁぁ、あぁぁっ……イっちゃったぁ……からだじゅうに、いっぱい\n……ドロドロのせーえきをかけられて、イっちゃったぁ……」", "NORMAL" ]},
