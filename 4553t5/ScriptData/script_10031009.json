		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ぬおおおおおおおっ！　脱出ぅ～～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010116050001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
