		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「おっと……同着か。タイムは？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090116050001" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「リミット５分前！　これなら文句なしに合格だな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010116050001" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「だ、そうだぞ。ルナテミス」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090116050002" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……はぁ……そ、そうか……。ふふっ、ふふふふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010116050002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ふふふっ……ははははははっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090116050003" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あははははははっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010116050003" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「やったな、ルナテミス！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090116050004" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ああ！　勝負はつかなかったが、見事に課題はクリアした！　これなら時間\n帝国の基地をぶっ壊し、みんなを無事に連れ帰れる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010116050004" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ああ、その通りだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090116050005" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「やれやれ。ハルノブとは引き分けだったけど……まあ、時間帝国に勝てばい\nいんだよな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010116050001" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「そういうことです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110116050001" ]},
		{"command":[ "SETCHARA", "0", "char_00000511_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「やれやれ……これでやっと作戦が実行できるよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010116050002" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……はぁ……よ、よかった……俺の犠牲も、無駄じゃなかった\n……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人……何をバテておるのです、情けない。出撃前に、鍛えなおしてもら\nったほうがよろしいのでは？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010116050001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うるへー……ルナテミスたちの意地の張り合いに、巻き込まれた身にもなっ\nてみろってんだ……はぁ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0132" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SETTEXT", "そして数日後……", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「これより『ファウンデーション』攻撃作戦を開始する！　これまでの訓練の\n成果を生かし、時間帝国の基地を粉砕してもらいたい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010116050003" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「惑星『アイザモフ』までは、ダイアンサスが安全・快適にお届けしますね！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_010116050001" ]},
		{"command":[ "SETCHARA", "0", "char_00019001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ああ、よろしくお願いする」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090116050006" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「おー！　よかった、まだ出発してなかった！　喜べカグヤクン！　キミにい\nいものを持ってきたぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020116050001" ]},
		{"command":[ "SETCHARA", "0", "char_00002202_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「いいもの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010116050001" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「そうだ！　キミ専用の新装備だ！　すごいぞ！　これを使えば君のパワーは\n３０００倍に跳ね上がる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020116050002" ]},
		{"command":[ "SETCHARA", "0", "char_00002202_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ホントに……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010116050002" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「まあ、３０００倍は言い過ぎかな……だけどとにかく、パワーアップするこ\nとは間違いないぞ。これでカツマクンのピンチを救えば……ウヒヒヒヒ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020116050003" ]},
		{"command":[ "SETCHARA", "0", "char_00002202_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「……！　ありがとう……珠魚！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010116050003" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「まあまあ、お礼はいいから。使った後でレポートを提出してくれれば」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020116050004" ]},
		{"command":[ "SETCHARA", "0", "char_00002202_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「わかった。ピンチになったら使ってみる。そしてカツマを助けて、それで…\n…それで……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010116050004" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「……………！？　なに……？　これ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010116050005" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
