		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「おいっす！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021360001" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "隊員たち" ]},
		{"command":[ "SETTEXT", "「………」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00005601_01", "1", "CENTER", "-600" ]},
		{"command":[ "SETCHARA", "1", "char_00005801_01", "1", "CENTER", "-200" ]},
		{"command":[ "SETCHARA", "2", "char_00006101_01", "1", "CENTER", "200" ]},
		{"command":[ "SETCHARA", "3", "char_00006401_01", "1", "CENTER", "600" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "DISPCHARA", "2", "TRUE" ]},
		{"command":[ "DISPCHARA", "3", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「元気がないぞぉ！　もう一度！　おいっす！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021360002" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "DISPCHARA", "2", "FALSE" ]},
		{"command":[ "DISPCHARA", "3", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "隊員たち" ]},
		{"command":[ "SETTEXT", "「おーっす！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_010021360002" ]},
		{"command":[ "SETCHARA", "0", "char_00005601_01", "7", "CENTER", "-600" ]},
		{"command":[ "SETCHARA", "1", "char_00005801_01", "7", "CENTER", "-200" ]},
		{"command":[ "SETCHARA", "2", "char_00006101_01", "7", "CENTER", "200" ]},
		{"command":[ "SETCHARA", "3", "char_00006401_01", "7", "CENTER", "600" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "DISPCHARA", "2", "TRUE" ]},
		{"command":[ "DISPCHARA", "3", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「口でクソ――げふんげふん、お花を摘みに行く前に『マム』をつけろ！　わ\nかったかウジムシども！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021360003" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "DISPCHARA", "2", "FALSE" ]},
		{"command":[ "DISPCHARA", "3", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「え……なに？　急に……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_010021360003" ]},
		{"command":[ "SETCHARA", "0", "char_00006701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「ど、どうしちゃったんですか？　長官……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_010021360003" ]},
		{"command":[ "SETCHARA", "0", "char_00005601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「隊長、長官が変っス。まさか昼間っから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_010021360003" ]},
		{"command":[ "SETCHARA", "0", "char_00006101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「おそらく飲んではいない……と、思いますぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021360001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうだな。たぶん、今はな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そう、長官は今は飲んでないはずだ。飲んでいたのはあのとき。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "昨日の勤務明けだ。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "俺はあそこで、あの女に出会ってしまった……。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0116" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_019" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「あーもう、ほんっとにどうしたもんかねえ……若手連中の、最近のたるみっ\nぷりときたら！　見てらんないよ、まったくぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021360004" ]},
		{"command":[ "SETCHARA", "0", "char_00004902_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……なぜだ。なぜ俺は早めに上がれた貴重な勤務明けに、長官の愚痴を聞か\nされてるんだ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「っていうか、ほむらたん！　冷やしトマト、もっと熟したのないの！？　お\nいしいトマトの赤はもっと暗い、血の色でなきゃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021360005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……だいぶ飲んでんな、長官」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「うかつでしたなあ、ご主人。この時間帯にここへ飲みに来たら、いい感じに\nできあがった長官に出くわすに決まっておりますぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021360002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「なーにゴチャゴチャ言ってんのよ隊長～！　わかってんの？　あんたら幹部\nがたるんでっから、若い連中もゆるむんよ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021360006" ]},
		{"command":[ "SETCHARA", "0", "char_00004902_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そんなこと言われましてもねえ！？　あの女幹部連中を、いったい俺にどう\nしろと！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「なんとかしなさいよ、なんとかさぁ！　あんた隊長でしょうが！　そもそも\nねえ、あんたがあの子らを甘やかすから――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021360007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あああ……もう！　勤務明けで飲みに来てまでこれかよ……ちょっと！　ほ\nむらたん！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「あんたらな……いいかげん怒るのも飽きてきたけど、ほむら『たん』言うな\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_010021360001" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そんなことよりさぁ！　この人なんとかしてくれよ！　この店は中立地帯じ\nゃなかったのかよ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「無理言うな、ここは正義と悪の中立地帯だぞ。上司と部下の中立地帯じゃね\nえ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_010021360002" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そんな冷たいこと言わないで！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「あきらめろよ。っていうか、ふだん誰があの愚痴を聞かされてると思ってん\nだ。今日ぐらい代われ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_010021360003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「あのねえ、あんた！　若手の教育も隊長の仕事だってわかってんのぉ！？　\nったく、どーしたらいいのよ！　このままじゃあの子ら――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021360008" ]},
		{"command":[ "SETCHARA", "0", "char_00004902_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「……ん？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021360009" ]},
		{"command":[ "SETCHARA", "0", "char_00004902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「…………？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021360010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……長官？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "長官が急に黙り込んで、虚空の一点を凝視している。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「長官？　おーい、長官？　どうかしたんすか？　まさかとうとう、飲みすぎ\nて危険な領域まで――」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「なにやら、じっとテレビを見ておいでのようですが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021360003" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「テレビ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "店の壁に据え付けられたテレビでは、古い戦争映画をやっている。ちょうど、\n軍に入ったばかりの新兵たちがしごかれてるシーンだ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あ、きょうの映画これだったか！　だったらこの店に来ないで、テレビ観な\nがらウチで飲んでりゃよかったな……」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人もなかなかお目が高い。この作品は軍隊の愚かしさと不条理、そして\n戦争の無意味さを鋭く風刺した傑作ですぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021360004" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おまえは映画解説者か。まあ、たしかにあの不条理な感じがクセになるんだ\nよな。特に、ここの訓練シーンで鬼軍曹がさ――」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「これだぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021360011" ]},
		{"command":[ "SETCHARA", "0", "char_00004902_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うわっ！？　急になんスか、長官！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「そうだそうだ！　いいこと思いついたっ！　隊長、あとよろしく！　私は用\nがあるのでもう帰る！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021360012" ]},
		{"command":[ "SETCHARA", "0", "char_00004902_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「って、長官！？　帰るってどういうこと！　いいこと思いついた、ってなん\nスか！？　ちょっと待って！　せめて勘定済ませて！　長官ーっ！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「……あきらめろよ。ほれ、これ伝票」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_010021360004" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "bg_0101" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_011" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……そういや立て替えた分、まだ取り返してねえぞ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「え？　どうしたんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_010021360003" ]},
		{"command":[ "SETCHARA", "0", "char_00006301_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、なんでもねえ。それより長官のヤツ、きっと――」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「静かに！　これよりお前たちの罪状を読み上げる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021360013" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「ざ、罪状！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_065_010021360003" ]},
		{"command":[ "SETCHARA", "0", "char_00006501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「歩兵科、清水紅羽！　訓練中の誤射で施設損壊！　減給２か月！　航空科、\n古舘飛空！　無謀な着陸で滑走路に大穴をあけ、免停３か月！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021360014" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「ひっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_010021360004" ]},
		{"command":[ "SETCHARA", "0", "char_00005601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「あんまりっス～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_010021360004" ]},
		{"command":[ "SETCHARA", "0", "char_00006101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「通信科、東風雛桃！　通信中に居眠り！　武器科、琴吹天夢！　備品の特殊\n振動兵器を、その……目的外に使用！　二人とも反省文５０枚！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021360015" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「あれは残業が多すぎたせいで……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_010021360004" ]},
		{"command":[ "SETCHARA", "0", "char_00006301_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「長官こそ、あの武器早く保管庫に戻してくださいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_010021360003" ]},
		{"command":[ "SETCHARA", "0", "char_00006401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「警務科、アーネスティ！　入館証を忘れた私を追い返した！　需品科、宵待\n泉流！　頼んだ大吟醸の入荷が遅い！　腕立て３０回！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021360016" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「私は規則に従っただけです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_010021360003" ]},
		{"command":[ "SETCHARA", "0", "char_00006801_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「それ、ただのやつ当たりじゃないですかーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_065_010021360004" ]},
		{"command":[ "SETCHARA", "0", "char_00006501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「野戦特科隊、エフュサス！　および科学科、アディー！　特に失敗はないが\n愛想もないので厳重注意！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021360017" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「ちょっと待て！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_010021360003" ]},
		{"command":[ "SETCHARA", "0", "char_00005801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「ここまでくると、完全に言いがかりね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_010021360004" ]},
		{"command":[ "SETCHARA", "0", "char_00006701_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「あとカツマ隊長は、例によって例のごとく全般的にダメ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021360018" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「俺の扱い、例によって雑すぎません！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「とにかく！　このところおまえたちの勤務態度はひどすぎる！　というわけ\nでお前たちを特殊任務隊に編入し、一から鍛え直してやる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021360019" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「特殊任務隊？　野戦特科隊とは違うのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_010021360004" ]},
		{"command":[ "SETCHARA", "0", "char_00005801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「この部隊であげた成果いかんによっては、おまえたちの処分はチャラになる\n！　どうだ、悪い話ではあるまい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021360020" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「まあ、本当に免停がチャラになるんなら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_010021360005" ]},
		{"command":[ "SETCHARA", "0", "char_00006101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「嫌です、って言っても認めてくれないですよね、きっと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_065_010021360005" ]},
		{"command":[ "SETCHARA", "0", "char_00006501_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「それはまあ……そうだろうな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「と、いうわけで特殊任務隊『ＢＢ隊』へようこそ！　直ちに専用装備に着替\nえ、５分で戻ってこい！　わかったな、ダンゴムシども！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021360021" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「専用装備ねえ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「おそらく、ろくなものではないのでしょうなあ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021360005" ]},
