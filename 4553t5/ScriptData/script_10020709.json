{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0166" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "ディアナの唐突なカミングアウトに驚かされた俺たちは、場所を学食に移して\n話を聞いていた。", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……で、なんで逃げたりかばったりしたのか、今度こそはなしてもらうぞ」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「だってぇ、あのとき偶然、園子ちゃんがうろついているのを見かけちゃった\nんだもの～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040113760001" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「ほかの人に見られる前に捕まえなくちゃって思って～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040113760002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「だからって一人で動き回らなくてもいいだろ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「他の人に、ディアナちゃんの過去を知られちゃったら大変だもの～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040113760003" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「なんで知られたくなかったんですか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_050113760001" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「だって～、昔のディアナちゃんは黒歴史だし～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040113760004" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「地味で気弱で真面目な社会人だったなんて、ディアナちゃんのイメージが崩\nれちゃうでしょ～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040113760005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "確かに園子は、いまのディアナからは想像できないほど地味だ。それがどうし\nてこうなってしまったのか……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "というか、過去の自分本人に向かって「黒歴史」宣言するか、普通。よほど昔\nの自分が嫌いなんだな。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「……私だって、未来がこんなにケバい人になっているなんて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_070113760001" ]},
		{"command":[ "SETCHARA", "0", "char_00000607_01", "4", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「んなっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040113760006" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "地味で気弱という割には、なかなか切れ味の鋭い一言を漏らす園子。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「こんな風になるなら、元の場所に戻らなくてもいいかも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_070113760002" ]},
		{"command":[ "SETCHARA", "0", "char_00000607_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「園子ちゃんは元の場所に戻らないとダメでしょぉっ！　未来が変わっちゃう\nかもだしぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040113760007" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「その未来のあなたになりたくないんですけど！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_070113760003" ]},
		{"command":[ "SETCHARA", "0", "char_00000607_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「なんですってぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040113760008" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「あなたこそなんなんですか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_070113760004" ]},
		{"command":[ "SETCHARA", "0", "char_00000607_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "同じ顔のふたりが言い争うっていうのは、何度見ても奇妙な光景だ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "こっちはルナテミスとアナザーとは違う、年の離れた同一人物のケンカという\nこれまた珍妙な対戦カードだ。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「なんだか、いつもの倍やかましいですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_050113760002" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「どうなってるんだ！？、これ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040113760001" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "二人の口論を兎子とセレインは眺めているし。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「てかよ、結局あのサメはなんなんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_010113760001" ]},
		{"command":[ "SETCHARA", "0", "char_00009501_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「いま本部のデータベースをあさっている」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010113760001" ]},
		{"command":[ "SETCHARA", "0", "char_00012701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "こっちの二人は、サメのことしか考えてないのか。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「だいたいぃ、ディアナちゃんがこんななっちゃったの、園子ちゃんのせいな\nんだけど～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040113760009" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「未来の責任を過去の私になすりつけるとか最悪すぎませんっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_070113760005" ]},
		{"command":[ "SETCHARA", "0", "char_00000607_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "仲裁役がいないまま、ディアナと園子のケンカは徐々にヒートアップしている\nようだ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人、そろそろ止めたほうがいいのでは？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113760001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「やっぱ、俺がやるしかないか……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "しゃーない。ディアナ同士の不毛な争いを止めさせるべく立ち上がったが……\n。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うぉおっ！？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "sbg_0000" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "躓いてしまった。そして倒れた先に……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0143" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「ひゃぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040113760010" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「きゃぁああぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_070113760006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "極上のクッションが……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「やぁん、カツマちゃんのエッチ！　なんでおっぱいの間に挟まってくるのよ\nぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040113760011" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「や、やっぱりこの人、わざとこんなこと……！　最低です！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_070113760007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "二人とも、罵声と一緒に身体を捩ってきて、俺の頬は両サイドからおっぱいに\n揉まれている。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「天丼！　天丼ですぞご主人！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113760002" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「もごもごもごっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "顔面をおっぱいでがっちりホールドされた状態では、駄犬へのツッコミもまま\nならねえ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「おっぱいの間でしゃべらないでぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040113760012" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「生温かい息が、き、気持ち悪いぃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_070113760008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0166" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "なんとか二人は落ち着いたようだ。……俺の顔面は両頬のビンタ痕がヒリヒリ\nして落ち着かないが。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「エロハプニングの後としては、妥当なオチですな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113760003" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うるへぇ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「それで、園子さんはどうしてここに？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_050113760003" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「それは……自分でもわからないんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_070113760009" ]},
		{"command":[ "SETCHARA", "0", "char_00000607_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「あの日は、仕事で嫌なことがあって、落ち込んでて……。職場のトイレにこ\nもっていたら、穴があって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_070113760010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「……あな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040113760002" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「逃げちゃいたいと思って入ったら……いつの間にか、この学園のトイレにい\nたんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_070113760011" ]},
		{"command":[ "SETCHARA", "0", "char_00000607_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「そこからは、なるべく見つからないように隠れて過ごしていたんですけど…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_070113760012" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「でも、あのサメに狙われるようになって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_070113760013" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「なんて可哀そうなの、私ぃ～……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040113760013" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "園子の苦労話を聞いているうちに、ディアナが泣き出した。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "あの噂の正体は、学園内に迷い込んだ園子となぜか現れるようになったサメっ\nてことか。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "……結局、サメがどうして現れるようになったのかっていうのはわからないま\nまなんだが。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「穴……。過去から来たというなら、時空の穴、ということですか……ふむ…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_050113760004" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なにかわかったのか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「いえ、珍しいこともあるもんだなと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_050113760005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「時空の穴というのは、自然現象で開くものではめったにありませんからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_050113760006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「へえ、そういうもんなのか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「ええ。例えばあのサメのように……って、またですか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_050113760007" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "空間にまた裂け目ができたと思ったら、またあのサメが出てきた。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おい、またサメがでたぞ！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}