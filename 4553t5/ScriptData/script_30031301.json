{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000313_01_03" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んふふ……さて……やーっと二人きりになれたねぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1303101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「色々と邪魔も入ったけど、今度こそ一切の邪魔なしで楽しめるってもんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1303102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ふふ……なに、お主は何も心配することはない。余が、今まで味わったこと\nのない特別な快楽をもたらしてあげるからねぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1303103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「どれ……膝を貸してやろう。そこに寝て……あぁ、こんな邪魔なモノは全部\n取っちまおうねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1303104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「おやおや……なんだい、もうこんなにチ○ポをビンビンに勃起させて……ナ\nニをされるか、期待しまくっていたようだねぇ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1303105" ]},
		{"command":[ "SETIMAGE", "0", "still_00000313_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「それに余のおっぱいを、チラチラと覗き込んで……全く、不敬だなどと怒る\n気にもなれん程、正直な奴よのう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1303106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んふふっ、まぁよい。今日の余は気分がいい。いつもであれば、徹底的に奉\n仕をさせて然るべきところだが……逆にしてやろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1303107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ほら……まずは、物欲しそうにしてる口から面倒をみてやろうねぇ。いいん\nだよ、おっぱいを吸いたいんだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1303108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んっ……まるで赤ん坊だねぇ、ふふっ……いいさ、特別に吸わせてやるから\nしっかりとおっぱいを咥えてな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1303109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「あふっ……言っておくが、余をどうこうしようなんて小賢しいことは考えな\nくていいからね。お主は、ひたすら身を任せていればそれでいい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1303110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「そうら……チ○ポを握るよ。おうおう、これはまた……厚かましいまでのビ\nンビンだねぇ……ほら、どうだい……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1303111" ]},
		{"command":[ "SETIMAGE", "0", "still_00000313_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ふふっ、分かりやすく腰を浮かせて……正直すぎるチ○ポだね。どうだい、\nシコシコして欲しいのかい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1303112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「だったら、ちゃんとおねだりをしな。恥ずかしく勃起したエロチ○ポを、手\nコキして下さいってねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1303113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ふふっ、そうかいそうかい……そんなにあっさり言っちまうんだ。よっぽど\n、余に弄って欲しいんだねぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1303114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「全く仕方のないチ○ポだ……だが、そんな浅ましいチ○ポの方が余を満足さ\nせられるだろうからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1303115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ほぅら、こいつがいいんだろう？　ぎゅうっと圧迫されて……チ○ポの余裕\nがなくなるくらいの感じ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1303116" ]},
		{"command":[ "SETIMAGE", "0", "still_00000313_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「くくっ、つくづく分かりやすいねぇ。どら……ここはどうだろうね？　ぎゅ\nっと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1303117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「おっと……やっぱりキ○タマは特別弱いみたいだねぇ……ふふっ、縮こまり\nそうになっちまって……可愛いもんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1303118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「その気になれば、ぷちゅっと潰しちまうことも出来るが……おっと……今、\nチ○ポを跳ねさせたね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1303119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「普通なら、そのまま縮み上がって役立たずになっても不思議じゃないが、し\nっかりチ○ポを勃起させる……その気があるってことかねぇ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1303120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「なに、せっかくの上物……潰しちまうなんて勿体ないことはしないから安心\nしな。ちゃんと……こっちを可愛がってやるよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1303121" ]},
		{"command":[ "SETIMAGE", "0", "still_00000313_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「くくっ……そうそう、特に敏感な亀頭のところだ……ちょっと爪が食い込む\nと……ちくんってするだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1303122" ]},
		{"command":[ "SETIMAGE", "0", "still_00000313_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「このまま、更にめり込ませて……くくっ、痛いのかい？　腰が踊りたがって\nるよ、だが、離すわけにはいかないねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1303123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ふふっ……そうそう、夢中でおっぱいを吸う位がお主に出来る精一杯のこと\nだ。そっちを頑張ってればそれでいいよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1303124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ほらほら……先っぽが悶えてるねぇ……ふふっ、こうやってじわじわ来てる\n所に……ぎゅぅぅっと……竿を握ってやる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1303125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「どうだい？　気持ちいいだろう？　皮を何度も何度も捲り返して……シコシ\nコされるの……たまらないだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1303126" ]},
		{"command":[ "SETIMAGE", "0", "still_00000313_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「あぁ、チ○ポの先から、気の早いナマ汁がじわっと出てきたね……ふふっ、\nちゅぷっ……んー、流石にまだまだ薄いねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1303127" ]},
		{"command":[ "SETIMAGE", "0", "still_00000313_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「簡単に漏らすんじゃないよ？　じっくり我慢して、ドピュッと勢いよく出す\nんだ。その方が、極上の気持ちよさを味わえるからねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1303128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「シコシコ、シコシコ……グチュグチュってね……聞こえるかい？　お主のチ\n○ポが、余の手コキで悦んでる音だよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1303129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「いい大人のカッコをしてるクセに、余のおっぱいに夢中で吸い付いて……こ\nうしてチ○ポをあやされて……恥ずかしくないのかい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1303130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「っと……こいつは愚問だったね。お主のような変態は、そういう恥ずかしい\nのが大好きなんだったねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1303131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「何なら、この恥ずかしい瞬間を、他の誰かに見られたいくらいには思ってそ\nうだ。くくっ、まーたチ○ポを跳ねさせて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1303132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「つくづく分かりやすいチ○ポだね。おっと……誤魔化すように、乳首に吸い\n付くところもバレバレだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1303133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「さて……そんなチ○ポもそろそろ、出したくて仕方ないってプルプルしちま\nってるねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1303134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「後もう少しだけ我慢だよ……腰に力を入れて、ぐっと踏ん張りながら……最\n後にぎゅうっと搾り取ってやるからねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1303135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ほら、ほら、ほらぁっ……ラストスパートだよっ！　お主の欲望を、余の手\nの中に思いっきりぶちまけちまいなっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1303136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「あはははっ……！　ドプドプ出てるねっ……そうそう……ふふっ、思い切り\n出すんだよっ、ほらほら、気持ちいいだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1303137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000313_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「扱けば扱くほど、びゅくびゅく漏らして……チ○ポも悦んでるようだねぇ…\n…んふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1303138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「れろっ……んーーっ、まぁまぁの濃さだね。余の夫としては少し物足りない\n位だが……この量は悪いものじゃない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1303139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「おっと……止まっちまったね。やれやれ、呆けた顔をして……そんなに良か\nったのかい？　くくっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1303140" ]},
		{"command":[ "SETIMAGE", "0", "still_00000313_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「さて……チ○ポの具合は……ふふっ、当然一発出した程度でへなっちまうな\nんてことはないだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1303201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「いいとも……ちょっと活を入れてやろうかね。そぉらっ……ふふっ……ここ\n……効くだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1303202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「そうそう、ケツ穴だよ……前立腺。ここをほじられると……ほぉら、イヤで\nもチ○ポがその気になるだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1303203" ]},
		{"command":[ "SETIMAGE", "0", "still_00000313_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ほうら……遠慮なく、ガチ勃起させていいんだよ？　出したてのチ○ポのザ\nーメン……サオにたっぷりまぶしてやるからねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1303204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んんーっ、このヌルヌルっぷり……ふふっ、精子がたっぷり泳いでる証だね\nぇ……全くやんちゃなチ○ポだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1303205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「おっと……口の方もさみしがってるねぇ……そら、ちゃんとおっぱいを咥え\nておきな……そうそう、んっ……しっかり吸うんだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1303206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んふぅっ……その遠慮なしの吸い方……いいねぇ、余のおっぱいに魅了され\nてるってわけさね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1303207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「しかも、生意気に……舌を伸ばして来て……余を感じさせようなんて魂胆か\nい？　ふふっ……くすぐったいね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1303208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「まぁ、そう悪くはないさ。代わりに余も、このチ○ポをもっともっと可愛が\nってやろうねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1303209" ]},
		{"command":[ "SETIMAGE", "0", "still_00000313_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「どれ、また亀頭をイジめてやろうか。皮を剥きあげて……ぎゅうっと手のひ\nらで包み込む……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1303210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「そのまま強く握って……くふふっ、まだだよ……まだまだめり込ませてやる\nと……あははっ、跳ねてる跳ねてるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1303211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「どうしたい？　チ○ポが痛いかい？　けど、それ位痛いのでも、お主は悦ん\nじまうんだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1303212" ]},
		{"command":[ "SETIMAGE", "0", "still_00000313_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ちょっと責めっ気を見せる時はあっても、しっかりマゾの気も備えてるのは\nバレてるんだよ。つくづく、エロ事には節操のない男だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1303213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「何より、このチ○ポ……まぁ、嬉しそうにビクビクしまくって……よっぽど\n手コキが気に行って仕方ないみたいだねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1303214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「亀頭がいいのかい？　けど……この根元も……キ○タマも大好きそうだもん\nねぇ……ほぉら、シコシコ……シコシコ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1303215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ふふ……本当に分かりやすい悶え方をする。つくづく、お主のチ○ポは余の\n好みのオモチャじゃな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1303216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「さあ、今度は我慢しなくてもいいぞ？　情けないイキ顔を晒して、ビュクビ\nュク射精するところを余に見せてみるがいい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1303217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ほうれ……ここに来て、必死で我慢するか？　まぁ、それもよかろう。どう\nせ時間の問題でしかないし……『これ』は我慢できまいしな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1303218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「そぉら、キ○タマほぐしから、サオ扱き……とどめに、尿道押し込みのフル\nコース……くくっ、身体が痙攣しまくっておるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1303219" ]},
		{"command":[ "SETIMAGE", "0", "still_00000313_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「さあ、観念して出してしまえっ、余の思う通りに無様にイキ果てるがいいぞ\nっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1303220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ふふっ……！　おぅっ……溢れて来ておるっ……まだまだ奥に隠していたザ\nーメンがどっぷり出てきてるじゃないか……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1303301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000313_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んんっ、あっ……もうおっぱいを飲むどころじゃなのかい？　チ○ポの方に\n気が行って、それどころじゃないかも知れないねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1303302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「っと……なんてことを言ったら、また生意気に吸い付いて来る……くくっ、\nその懸命さに免じて、もっと扱いてやろうね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1303303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「そうそう……唇をしっかり合わせてチュウチュウとね……おっと、チ○ポも\nまた震えて……これは残っていた分が……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1303304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「くくっ、出てる出てる……まだ頑張って出てくるじゃないか。いずれは余を\n孕ませる為のザーメンだ。これくらい元気じゃなくちゃねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1303305" ]},
		{"command":[ "SETIMAGE", "0", "still_00000313_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「やれやれ、手が完全に汁まみれだよ。余の手をこんなに汚して……自分で味\nわってみるかい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1303306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ふふ……渋い顔をして。いらないなら、代わりに余が味わってやろうかね…\n…ちゅぷっ、ぴちゃ……れろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1303307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ふむ……まぁまぁだね。余の世継ぎを作るには、もう少し濃い方がいいだろ\nうが……まぁ、それはおいおい鍛えていけばいいさ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1303308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「まだチ○ポは勃起してるままか。ふん、まぁ、それなりに見どころはあるし\n……また、たっぷり可愛がってやろうねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1303309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「普通にしたんじゃ絶対に味わえない……特別な快楽を仕込んでやるから、楽\nしみにしているといい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1303310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んぁっ！　こいつは派手に飛ばして来るじゃないか……んっ……！　顔にま\nで……ザーメンが届いてくるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1303401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000313_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んふっ、おっぱいにもビュクビュク出して……こいつは、お行儀が悪いねぇ\n……ふふっ、まだまだ出続けてるじゃないか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1303402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「なら、とりあえず枯れちまうまで搾ってやろうかねぇ。ほぉら、ピュッピュ\nと出しちまいな……んふふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1303403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「あぁ、いいよ……一生懸命チ○ポを震わせて……たっぷりザーメンを出しち\nまおうねぇ。おっと……まだおっぱいにも執着してるとは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1303404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「つくづく、スケベな男だね……だが、それぐらいの欲望にまみれてなきゃ、\n余の相手には相応しくない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1303405" ]},
		{"command":[ "SETIMAGE", "0", "still_00000313_01_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「こうやって、余の顔を汚すほどの性欲……どれ、ちゅぱ……れろ……ぴちゃ\n……ちゅぷ、くちゅ……ふむ、まぁ悪くはないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1303406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「精子の量は申し分なし……濃さはまだ、もうちょっと濃いのがいいだろうが\n、そいつは慌てなくてもいいだろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1303407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「粘り気は……くくっ、しっかり糸を引いて上等だ。余の身体に、しっかり染\nみ込もうとして……中々の図々しさを感じるよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1303408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ふふ……堪能したかい？　こんな風に、おっぱいを吸いながら手コキされる\nなんて、他のオスには絶対させないことなんだからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1303409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「しっかりと感謝して、これからも余に尽くすといい。そうすれば、また極上\nの快楽を与えてやるからねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1303410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}