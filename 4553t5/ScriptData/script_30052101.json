{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「こんな遅い時間に、急に呼び出して……申し訳ありませんが。どうしてもウ\nチが貴方に、聞いておきたいことがあるのです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2103101" ]},
		{"command":[ "SETCHARA", "0", "char_00000521_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ウチは……昔、オボロという名前でした。それに異論はありません。でも…\n…過去の記憶が欠けている。だからそれを取り戻したいのです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2103102" ]},
		{"command":[ "SETCHARA", "0", "char_00000521_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「そのために、何かきっかけになりそうな事があれば教えてもらえませんか？\n　そうですね、昔のウチがいつもしていたことがあれば……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2103103" ]},
		{"command":[ "SETCHARA", "0", "char_00000521_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「は？　何ですか？　毎日、嬉しそうに貴方のチンポにご奉仕していた？　\nじょ、冗談を言っているのですか？　違う！？　本当のこと！？　あ、あぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2103104" ]},
		{"command":[ "SETCHARA", "0", "char_00000521_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「うぅ……。それが真実なら……。記憶を取り戻すためなら仕方ありません。\nその頃と同じことを、させてください。絶対に気持ち良くするので……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2103105" ]},
		{"command":[ "SETCHARA", "0", "char_00000521_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「……な～んて、おとなしくウチが言うとでも思っていたですか？　……何を\n驚いているのです。記憶がなくても、それくらいのことはわかります」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2103106" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_01_01" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ご奉仕なんてするわけないじゃないですか。ウチをメイドか何かと勘違いし\nているんですか？　はぁ……、まんまと見透かされているとも知らないで」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2103107" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「そんなにウチに、コレを可愛がって欲しかったのですね。まあ、今回は……\nその思惑に乗ってあげないこともありません。……どうして、って？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2103108" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「貴方の精液は……なぜか、妙に癖になる臭いですので。気まぐれです。ただ\n……ウチを騙そうとしたことの罰は受けてもらわないといけませんので」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2103109" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「１つ、ふさわしい呪いをかけてあげます。……フフフッ、気付きましたか？\n　そうです。射精できない呪いです。これでたっぷり虐めてあげましょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2103110" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「……ん、れろ……。くちゅっ、ちゅっ、ぺろっ、ぴちゃ……♪　フフフフ、\n精液を出せないと思うと急に苦しくなってきたのではないですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2103111" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「射精を禁止されたと思うだけで、逆に強く射精を意識してしまう……。これ\nは人の、正常な反応なのです。存分に堪能してください……ぴちゃっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2103112" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ん～～～……♪　れろぉっ……くちゅっ♪　んん？　どうしたのです？　ウ\nチが舌を思いっきり伸ばして、亀頭を攻めているのが辛いですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2103113" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「辛いわけがないですよね？　嬉しいと言ってください……。ぴちゃっ、ちゅ\nぷっ、ぷちゅ……。フフ、笑いがこらえきれませんね……。っちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2103114" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ウチに一方的にオチンチンをねぶられて、股間をビクビクさせているその姿\n……。とっても見ごたえがありますよ。っちゅっ、れろぉ……くっちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2103115" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んっ、んんっ……。ちゅぷっ、ちゅっぱっ、ちゅぷっ、くっちゅっ……♪　\nこのビクつきよう……。今のやつ、本来だったら射精してますね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2103116" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「出したいのに出せない……。いい気味です。もっともっとしてあげましょう\n。なにせ、毎日喜んで貴方のオチンチンに奉仕していたらしいですから♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2103117" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「……れろっ♪　こうですか？　昔のウチは、こーんな風にオチンチン舐めて\nいたんですか？　ぴちゃっ……ちゅぷっ、れろっ、れる……んんんんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2103118" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んぅ？　聞こえませんねぇ……くちゅっ、はっきり大きな声で言ってもらわ\nないと……♪　れろ……れろ、ぴちゃっ、また腰が跳ねましたよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2103119" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「これは、もっと貴方の情けない顔を見て、悦に浸らせてもらわないとです…\n…。いきますよ？　全力でご奉仕とやらをしてあげます。あーん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2103120" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ぱくっ。んっ、ぐちゅっ！　ぐっちゅっ、じゅぷぷっ……！　んむぅっ♪　\nオチンチン、硬くて熱くて……どこか懐かしい臭いがしますです……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2103121" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「この臭い……っ、はむっ、んちゅうっ……。これを嗅ぐと、いてもたっても\nいられなくなって……！　んっ、あぁ、な、なぜなのかわかりません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2103122" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_01_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「もっと嗅ぎたい……んんっ、ここです！　股間の一番深いところ……、ここ\nの臭いが、くさいのにやめられなくて……あっぁっ、ぐちゅっじゅるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2103123" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「興奮……してきました。じゅっぷっ！　じゅぷっ、ぐっちゅっ……！　んん\nむっ……！　どうせなら、強く吸って……どんどん追いつめてあげましょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2103124" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ッじゅるじゅるじゅるじゅるじゅるぅっ！　じゅっぽっ！　じゅっぽっ、ぐ\nっちゅっぐちゅっ！　ぢゅるううう……！　ぐちゅっ！　じゅっぷっじゅる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2103125" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_01_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んっ！　んん～っ、じゅるじゅるジュルジュルジュルっ……！　あはっ……\n♪　爆発しそうなくらいパンパンに膨れてきてますよ……じゅぷぷっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2103126" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んぁ……♪　これ以上大きくされたら、口に入りきりませんから……んむっ\n、温情として１回出させてやってもいいのです……ふふふっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2103127" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「さあ……ラストスパートをかけていきますよ……♪　ウチが解呪を行った後\nは、一気に大量に射精して情けない顔を晒すです……！　んぐっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2103128" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「じゅっぷっじゅぷっ！　ぐちゅっ……ぬっちゅっぐちゅっじゅっぷっ！　じ\nゅぅううっ♪　じゅるっ、じゅっぷっじゅっぷっ！　ぐっちゅっじゅるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2103129" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_01_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んっ……んっ、んんん……！　どうです？　様々な角度から……んんんっ、\nれるっ！　オチンチンを舐めしゃぶられるのは……。っじゅっぷっじゅるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2103130" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「……んんんっ？　貴方じゃなくてオチンチンの方が返事してくれましたよ。\nそうですか、嬉しいですか……。ぐっちゅっぐちゅっ、じゅぷっじゅぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2103131" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「まだです……まだ溜めこむのです……ぐちゅっ！　限界の限界、ギリギリを\n見極めて盛大に射精させますから……。んっ、んん……んんんむっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2103132" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「精子、溜めてください……じゅるっ。んむっ、じゅぷっぐっちゅっぬちゅっ\n……！　れろれろれろ……♪　あぁ、いい感じです、ねっ……じゅるるるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2103133" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「睾丸がずっしり重くなってきました……。オチンチンも最大限に膨張して…\n…ぐちゅっ。先走り汁も大量です。これなら、もういいでしょうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2103134" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_01_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「……さあっ、解呪しますよ！　ほらっ……出すのです、オチンチンから精液\nびゅるびゅる出してください！　じゅっぷっじゅぷっじゅるじゅるじゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2103135" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んむぅうううううう……っ♪　んっ、んんんんっ、ん～～～～～っ♪　来ま\nしたっ……！　ウチの口の中で、精液炸裂して……！　んぅうううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2103136" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「す、少しは慎みを持ってほしいものです……っ、が、んむ……っ！　せっか\nくです、罰の後には多少のご褒美を……。ん、ごくっ……ごくっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2103137" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ほら、大好きなウチが貴方の精液を飲み干してあげていますよ！　心の底か\nら感謝しながら……んんっ、最後の一滴まで出し尽くすのです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2103138" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_01_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ん……んっ、ん、んん……！　ひゅ、ひゅごい量でひゅね……っ。ん、ごく\nっ……！　ごくっ、ごくっ……！　ん、ぁ……粘り気が強すぎまひゅよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2103139" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_01_11" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「口の中からなかなか喉に下りてきまふぇん……っ。んんんん～……！　ごく\nっ、ごく……ごく……♪　ふふふふ……、いいザマなのです……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2103140" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「とてつもなく無様な表情を見られて、ウチも楽しくなってきました……。そ\nれにしても、いつもこんなに精液を大量に発射しているのですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2103201" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「昔から……？　そ、それとも相手がウチだったから……なんて？　どうなの\nですか。はっきり答えてほしいです。……それにしても……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2103202" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「この精液の味、そして臭い。とてもなつかしい気がしました。これはもう少\nし、調査させてもらう価値ありです。……と、いうことで」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2103203" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ふふふっ……♪　もう一度、改めて射精禁止の呪いをオチンチンにかけまし\nた。気が付かなかった？　貴方は鈍いところがありますから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2103204" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「……でもこれで、じっくりと観察し直すことができますよ。んん……、精液\nの残り汁、そして男根に付着した精子……これを舌で舐めとります」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2103205" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ぴちゃぁ……っ、ちゅっ、ちゅぷ……くちゅ……♪　うぇ、まっずいのです\n……。苦い……、んっ……んん、れろ……れろ、れろっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2103206" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「口でされるの、好きなんですね？　すぐにオチンチンの硬さが戻ってきまし\nたですよ……♪　れろ……れろ、んぅ♪　ほ～らもう元通りです……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2103207" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「丁寧に丁寧に……。んれろっ、ぴちゃっ……くちゅっ、ちゅぷっ……♪　先\n端から……んれるっ、ちゅぷ、肉竿に、肉竿から根元に……ぴちゃぴちゃっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2103208" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「緩急をつけて舐めあげることで、貴方のオチンチンを飽きさせないですよ…\n…。んちゅっ、ふふ、まったくどこを舐められるかわからないでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2103209" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「一舐めごとに貴方が動揺して、反応するのが面白くて……れろっ、もっとも\nっと攻めてやりたくなるんです。っちゅっ、くちゅっ、れろ……れろっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2103210" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「……あぁ、いいですね。今の表情……ゾクゾクします。れろっ、れろ……く\nちゅっ♪　亀頭を念入りに……。ぴっちゃっぴちゃっぴちゃ、くっちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2103211" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ここまで来たら、もう貴方も止まれないですよね……！　一気にいきますよ\n……！　んむっ！　ずちゅるちゅるちゅるっ！　じゅるっ、じゅるるるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2103212" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ふふふっ、バキュームフェラ……。貴方のお気に入りのしゃぶり方ですよ、\n……じゅるっ、じゅるるるっ！　恥ずかしがってもダメです、じゅるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2103213" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ウチには全部お見通しです……！　こうですね？　ウチの小さい口いっぱい\nにオチンチンを咥えこんで……強く精液を吸い上げてすすり取るのです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2103214" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んんんぅ～っ♪　じゅっぷっじゅっぷっじゅるっ、ぢゅるるるっ……！　ど\n、どうれひゅっ……！　腰が浮いていまひゅよ！　じゅるっ、じゅるるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2103215" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_01_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ふふっ、んふふふっ♪　せいぜい情けない表情を見せてくださいね……♪　\nちゅっ、じゅるっ、じゅるるるっ！　……じゅっぽっじゅぽっじゅぽっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2103216" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ん、ここですか？　こんなに強く吸われて気持ちいいなんて……じゅるっ、\nオチンチンに脳を支配されていますね……。っじゅるっ、じゅぽっじゅぷ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2103217" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「……精液を吐き出したいですか？　じゅるっ、呪いを解いてほしいですか？\n　……ぐちゅっ！　それならウチに永久の従属を誓うのです……じゅるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2103218" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「……なんて、さすがにそこまでは望みませんよ。再び貴方のっ……じゅるっ\n、トロけた顔を見られれば良しとしてあげます……んっ、じゅるるるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2103219" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ほら、ほらっ♪　解呪しますよ……！　オチンチンの準備はいいですねっ？\n　……解呪っ！　じゅるっ！　じゅるるるるっ、じゅるっ、ぢゅるるるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2103220" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_01_08" ]},
		{"command":[ "WAITINPUT" ]},
						
		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んぷぅ……！　んんんっ！　もがっ、お、思ったよりもオチンチンが暴れま\nすっ……！　お……おとなしくしてください！　じゅっ、じゅるるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2103301" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_01_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「貴方はウチに翻弄されて、ひたすらネバネバの精液を吐き出していればいい\nのですよ……！　っんん……んっ、吸い上げ続けますよ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2103302" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ぢゅるるるるっ……♪　ごくっ……！　ごくっ……んんん……♪　濃厚な精\n液が、たくさん口の中に……。んっ、まだ出ますでしょう？　ぢゅるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2103303" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「尿道に残った分も逃しませんから……。じゅるっ……ごくっ。ごく……ごき\nゅっ……♪　ん、う……♪　なんて粘り気ですか、飲みづらいですよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2103304" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_01_13" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ごっくっ……。飲み終わったら、オチンチンについた精子を綺麗にしゃぶり\n倒すです……。れろっ、くちゅ、ちゅっ……ちゅぅううう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2103305" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_01_12" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「……んぷっ！？　さ、最後にビュルッと飛び出しましたよ！？　ん、ぁっ…\n…！？　ふ、不意打ちで喉の奥に……！　んっんっんんっ、んぅうう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2103306" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_01_14" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「はぁああ……♪　身体の中が……貴方の臭いでいっぱいです……♪　これは\n、完全に消化し終えるまで……かなりの時間臭うはずですね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2103307" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「誰かに気付かれないようにしないといけなくて、正直めんどいですが……。\nウチが命令して、射精させたのですから甘んじて受け入れることにします」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2103308" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「べ、別に……この臭いを長く楽しみたいから飲み干したわけではありません\nよ？　本当です！　ただ……長くこの臭いに包まれていれば……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2103309" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「オボロとしての記憶が蘇るのではないかと。……そ、そうです。これは合理\n的な判断です！　たまにこうして調査させてもらうとしましょう……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あっ……！　こ、こら、勝手に動くなです！　っぅうううっ！？　オチンチ\nンからドロットとしたモノがほとばしって、ウチの顔にぃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2103401" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_01_17" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あっ♪　あっぁっ、一度出してしまったら、もう止めることなんてできませ\nんよね……っ。し、仕方ありません、このまま射精してください……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2103402" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_01_16" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「っん……ッ。熱い……♪　それに臭すぎて笑えるのですっ……。んふっ、く\nぅっ……♪　貴方のこんな汁、受け止められるのはウチだけです……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2103403" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_01_17" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「っあぁああ……っ、本当に射精している貴方の表情は最高、ですね……っ。\nお口でご奉仕したかいがありました、見ごたえがあってそそります……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2103404" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_01_16" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「はい♪　はい、見てるですよ、貴方がオチンチンから精液ビュービューして\nいるところ……っ、はぁっ、ウチが監視してます、観察してますからっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2103405" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あうっ……！　うっ、んっ、んん……ッ♪　びちゃびちゃと降りかかるこの\n精液……っ♪　ネットリしていて心地良いのですっ……♪　あっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2103406" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_01_17" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「っはぁああああ……♪　ようやく満足しましたか？　たまには呪いで射精を\n制御するのも一興でしょう。たっぷり興奮できたみたいですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2103407" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_01_16" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「記憶……はまだ、抜けているところの方が多いですが……。単純な貴方の弱\n点……。性感帯については、大体覚えることができました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2103408" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ウチがオボロだった頃のことは……。いえ、今もオボロですが……。とりあ\nえず置いておくとして、これからのことを考えると……そうですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2103409" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_01_15" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「貴方と定期的に接触するのは、イヤではない……ので。これからも協力して\nもらうことにします。記憶が戻るまで、何度でも……いいですよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2103410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}