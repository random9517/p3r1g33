{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「……どうしても、今夜は……一緒にいてほしい。他の子との約束、あった？ \n　ないなら私といてくれる？　うん……二人っきりになれる場所が、いい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0104101" ]},
		{"command":[ "SETCHARA", "0", "char_00026701_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「この部屋でなら他に邪魔は入らないよね……。あ、いつもは別にたくさんの \n人がいても楽しいし、いいんだけど。その、……困ってることがある」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0104102" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「ここのところ何日間も、ずっと身体がウズウズしておかしい。治せるのは隊 \n長さんのマッサージだけって聞いた。あってる？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0104103" ]},
		{"command":[ "SETCHARA", "0", "char_00026701_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「……そっか。服、脱ぐから一番良いマッサージをしてほしい。お金はないけ \nど、とても感謝する。それで、私はどうすればいい？　ええっと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0104104" ]},
		{"command":[ "SETCHARA", "0", "char_00026701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「……んぅ……？　なあに、この格好……？　隊長さんが、よく見えない…… \n。でも、後ろからぎゅっとされているみたいで、いい、かも……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0104105" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00026701_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「私、重たくない……？　軽い方？　そっか……それなら安心。でも、１つ気 \nになることが、ある……。コレ……なあに？　私にはついていない器官」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0104106" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「おちんちん……？　ちんちん？　聞いたことない名前。赤黒くて、プルプル \n……してる？　ん、ぅ……手が届かないから感触はわからない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0104107" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「ねえ。このちんちん……。なんで、びーんって真上をむいてるの？　誰も手 \nで支えてないのに、勝手に立ってて、奇妙……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0104108" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「……へ？　今回はちんちんでマッサージをする？　ち、ちんちんってマッサ \nージの器具、だったの……？　全然そう見えない。どうやって使うの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0104109" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「コレを私のお腹の中に……入れる？　んぇ！？　おなかの、中に？　む、む \nり……そんなの入らない。私の身体の大きさにあってないし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0104110" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「お腹の中に入れるってどうやって？　お尻の穴から？　あ、違うんだ。その \n前の穴……？　穴？　この穴ってなあに？　なんていう名前？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0104111" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「おまんこ……。隊長さんは、私のおまんこにおちんちんを入れてマッサージ \nしたいんだ。う、うぅん……。気持ちはわかった、けど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0104112" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「やっぱり大きすぎるし、ちゃんと入らないと思う。おまんこも使ったことな \nいし、こんなに太いものを入れていい場所じゃないと思う……って」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0104113" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「はう！？　やっ……♪　お、おちんちん、おまんこの中に入ってき、たぁ… \n…？　なんでなんで？　まるで、入れるのが当たり前みたいに……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0104114" ]},
		{"command":[ "SETIMAGE", "0", "still_00026701_02_03" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「んっ？　おまんこって、元々おちんちんを入れる場所、なの……？　あ、あ \n、じゃ、じゃあいいんだ、これが正しいん、だ……よかったぁ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0104115" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「う、うん。苦しくは……ないよ。だっておまんこは、おちんちんを入れると \nころだし……。でも、腰と、足に力が入らない。じーんって痺れてる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0104116" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「それに、身体の芯からガーッて燃え上がっているみたい……。あ、ぅ……♪ \n　はぅう……♪　こ、これがおちんちんマッサージ……すごいよぉお……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0104117" ]},
		{"command":[ "SETIMAGE", "0", "still_00026701_02_04" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「う……ぁ♪　ああああっ♪　ね、ねえ……っ！　私のおなか、ぼこーって膨 \nらんじゃって……あっあっ、赤ちゃん……いるみたい、妊婦みたいぃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0104118" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「こんなにはっきり、ちんちんの形……わかるんだ……。すごく大きなものが \n入ってるの、わかる……。おちんちんって、硬いんだね……。っぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0104119" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「ま、待ってぇ……？　まだおちんちんがおまんこに慣れてない、から……動 \nかしちゃだめだよ……。はぁっ♪　んんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0104120" ]},
		{"command":[ "SETIMAGE", "0", "still_00026701_02_02" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「おまんことおちんちん……。ぴったり密着してる、から……そんなに激しく \n動かさない、で……。あっ♪　ぁっ♪　身体、上下に揺らさ、ない、でっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0104121" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「ずりゅずりゅってこすれるところが……あああっ、ヌルヌルして熱い……！ \n　あぅっ、はうっ、じゅぽじゅぽっておちんちん入れたり、出したり……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0104122" ]},
		{"command":[ "SETIMAGE", "0", "still_00026701_02_03" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「隊長さん、おちんちんを動かされると、おまんこがキュンキュンって疼くよ \nぉ……！　おちんちん、硬い、し、太い、から……ひっかかるの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0104123" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「おまんこの内側にひっかかって、こすれて……！　ぁっ♪　あれぇ……？　 \nだんだん、気持ち良くなってきた……。なんで、なんでぇ……っ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0104124" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「あ、うぅ、おちんちんをズブッて突き立てられるたびに、おまんこ、すっご \nく喜んで……受け入れようとしてる。おちんちんのこと好きって言ってるぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0104125" ]},
		{"command":[ "SETIMAGE", "0", "still_00026701_02_04" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「おちんちん、にずっと入ってほしかったって言ってる……っ。あっ♪　ぁっ \n♪　身体……ぜーんぶ、おちんちんで真ん中から支えられて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0104126" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「気持ち良すぎて、自分が自分じゃなくなってくみたい……！　おちんちんマ \nッサージ、すき……♪　好きになった……。しゅき……♪　もっとしてぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0104127" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「じゅぽじゅぽ出し入れ、もっと早くして……！　いっぱいおまんこ刺激して \n、ひっかいて、かきまわして……っ♪　はぅっあうっ、あうっううっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0104128" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「あっぁっあっあっ♪　そこ……そこぉ♪　おまんこから熱いお汁がどんどん \n出てくる……っ。あっぁっ止めないで、力任せにめちゃくちゃにしてっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0104129" ]},
		{"command":[ "SETIMAGE", "0", "still_00026701_02_03" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「は……ぁああ♪　私のおまんこ、トロトロにほぐれてきたぁ……♪　マッサ \nージの効果、バツグン……♪　もっととろけたい、もっと熱くなりたい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0104130" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「んっぁっあっあっあぁ♪　マッサージ♪　マッサージ気持ちいい……♪　お \nちんちんマッサージだいしゅき……しゅきぃ♪　んぁっあっあっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0104131" ]},
		{"command":[ "SETIMAGE", "0", "still_00026701_02_04" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「お腹の形、へっこんだり、膨らんだり……♪　んふふふ、おまんこの奥まで \nおちんちんが入ってるのがよくわか、るぅ♪　はぁっ♪　あっぁっあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0104132" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「隊長さん……♪　おちんちん、私のおまんこの中でお汁まみれになっちゃっ \nてる、ね♪　んぁっ♪　あぁ、それに、出たり入ったりするたび♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0104133" ]},
		{"command":[ "SETIMAGE", "0", "still_00026701_02_03" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「どんどん硬く、大きくなってきてる……。私のおまんこ、ミチミチってひろ \nがってる……♪　それで、気持ち良さが、ぐんぐん増えてきて……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0104134" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「おまんこが、ビクビクっ、ビクビクぅって痙攣してる……っ。気持ちいいの \n証……♪　おちんちんでおまんこほじくられて、私……気持ちいいよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0104135" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「んふぁっ！？　んんん！？　な……なに？　なあにっ？　今、私の両足がガ \nクガク～って震えたのと一緒に、同時に中に熱いモノが……っ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0104136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00026701_02_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「あっ？　お汁？　おちんちんからお汁出てる？　おまんこの中に広がってく \n……っ？　んはぁぁっ？　そんな機能、あるって知らなかった……あぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0104137" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「おまんこの中、あったかいお汁で洗われてるみたい、すっごく気持ちいい… \n…♪　んふぁっ♪　びゅるっ、びゅるっていっぱい出て……あうぅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0104138" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「身体がぽかぽかしてきたぁ……♪　あぁああああ……♪　身体の内側から、 \n直接熱が伝わって……全身に広がってく、うっとりした気持ちに、なる♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0104139" ]},
		{"command":[ "SETIMAGE", "0", "still_00026701_02_06" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「ふぁあああああ……♪　この機能、しゃせいって言うの……。おちんちんの \n標準装備機能、なんだ……。おちんちんって高性能で、ひゅごい……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0104140" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「ん、ふ……♪　中に出たしゃせいのお汁……。おまんこの入口からちょっと \n溢れて、漏れてきちゃった……。いっぱい、いっぱい出してくれたから♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0104201" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「私のちっちゃいおまんこじゃ全部受け止めきれなかった……。ごめん、なひ \nゃい……♪　でも、その性能はじっくり堪能したよ……♪　最高だった♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0104202" ]},
		{"command":[ "SETIMAGE", "0", "still_00026701_02_05" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「おちんちんマッサージ、ハマりそう……。はぁ、はぁ、お汁が出るのが終わ \nっても……なんだかずっと気持ち良くて……。心も満たされた」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0104203" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「あ……♪　もしかして、おちんちんを抜こうとしてる……？　だ、め……。 \nマッサージ、もっとしてほしい……。１回だけじゃ、足りない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0104204" ]},
		{"command":[ "SETIMAGE", "0", "still_00026701_02_06" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「……むんっ！　やめたいって言ったって抜かせ、ないぃ……！　おまんこで \nぎゅーって捕まえて、無理やりにでも続けて、もらう……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0104205" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「ねぇ、マッサージ、もう一回して……。いい？　んっ……あは♪　うれしい \n……。おちんちん、また動き出したぁ……♪　あり、がと……しあわせ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0104206" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「たくさんおまんこ、ほぐして……あっ♪　ぁっ♪　んん？　なんか……！　 \nさっきよりもずっと気持ち、いい……腰がゾクゾクする……ふぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0104207" ]},
		{"command":[ "SETIMAGE", "0", "still_00026701_02_07" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「んんん……♪　おちんちんがしゃせいした時に出たお汁と、私のおまんこの \nお汁が混ざり合って、すごい音がしてる……。ぐちゅっぐっちゅって♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0104208" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「おちんちんの出し入れもしやすくなってる気がする……♪　んぁっ、で、で \nも、ぬめりですべりすぎるかな……？　絶対抜くのはだめ、だから……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0104209" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「おまんこの中に♪　入れたままにしてて……っ♪　すべって抜けないように \n……あっ♪　もっと奥に入れて……入るからっ、……ん～～～っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0104210" ]},
		{"command":[ "SETIMAGE", "0", "still_00026701_02_05" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「あは♪　あはは♪　私の身体、隊長さんの両手で自由自在に動かされ、てる \nね……っ♪　上下左右、ぐりんっぐりんって腰を回された、り……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0104211" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「色んな動きすると、い、色んな……気持ち良さがある……っ♪　あぅっ、う \nぅ、はうぅ……うぅっ♪　ズンズン突かれると、もう……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0104212" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「あっ♪　あっあっうううっ♪　おちんちん、早く動かされると爪先がビリビ \nリする、の……♪　コレはなに……？　ぜ、絶頂……？　ぜっちょう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0104213" ]},
		{"command":[ "SETIMAGE", "0", "still_00026701_02_06" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「そ、そうか……っ、私何度もおちんちんで、おまんこ絶頂してるんだ……♪ \n　んぁあっ、絶頂好き！　絶頂気持ちいい……ああああっ、んんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0104214" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「すごく感度が上がっている、って隊長さんは言うけど……。かんどって？　 \nあっ♪　ご、ごめん……っ♪　もう説明されても頭に入らない♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0104215" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「私、感度あがって、おちんちんでおまんこ絶頂するの！　１回しゃせいされ \nただけじゃ足りなくて、何度も何度も絶頂楽しんで、るぅ♪　ふぁ、あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0104216" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「ああ～っ♪　うあああっ♪　ああっ♪　あっぁっあっ♪　気持ちいぃい♪　 \nおちんちんマッサージでおまんこ気持ちいいっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0104217" ]},
		{"command":[ "SETIMAGE", "0", "still_00026701_02_07" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「隊長、ひゃん……♪　隊長さん、もう１回しゃせいしそう……？　うん♪　 \nうん、いいよ……♪　私も絶頂、しそう……一番おっきい絶頂……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0104218" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「あったかいお汁、おまんこに注入して……っ！　隊長さんのおちんちんから \n出るお汁で私のおまんこ、びちゃびちゃにして……っ！　ふぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0104219" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「ぜっちょ、う……♪　絶頂するぅっ♪　おまんこ、おまんこ絶頂するっ…… \n♪　おちんちんのお汁ちょうだい！　お汁で絶頂したいぃい！　あぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0104220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「はぅううううううんんっ♪　出たぁ♪　おちんちんからお汁出た、ぁ♪　あ \nっぁっあっ、わかるぅう……っ♪　満たされてくぅう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0104301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00026701_02_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「はぁあああ……ッ♪　しゃせいしてもらいながら絶頂するのが一番、うっと \nりする……！　感激して、涙が出るぅ……！　ありが、と……ぉっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0104302" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「はぁううっ♪　あううっ♪　うぅっ♪　ふぅううっ……♪　だめぇ、まだし \nゃせい、やめちゃだめ……！　もっとぉ、もっと、もっともっとぉ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0104303" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「私の絶頂が終わる、まで……ずっとちょうだい……！　っあぁあああっ♪　 \nふぁあああっ……！　あ～～～っ♪　あ～～～っ♪　絶頂してるぅうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0104304" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「はぅっ♪　あうっ♪　身体の震え、止まらないよぉお……♪　あ、くっ…… \n♪　くふぅっ……♪　くぅん♪　う～～～っ♪　う～っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0104305" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「私……おまんこにしゃせいしてもらうの、大好きぃ……♪　身体の細胞が、 \n全部喜んでるのがわかる、これが欲しかったんだって言ってるぅ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0104306" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「あ、あぁあああ……♪　き、気持ちよかったぁ……。あ、ありがとう……。 \n私ばっかり気持ち良くしてくれて……。……ん？　私だけ、じゃない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0104307" ]},
		{"command":[ "SETIMAGE", "0", "still_00026701_02_09" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「おちんちんも気持ち良くなってた……？　わぁ……♪　そうなんだ、おまん \nこが気持ち良くなると、おちんちんも気持ち良くなるんだね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0104308" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「だったら……どっちも良かったなら、罪悪感、なくなって気持ちもすっきり \n……。そうかぁ、おちんちんも私のおまんこでマッサージされてたんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0104309" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「私……まだまだ知らないこと、たくさんあるね……。暇な時にでも、教えて \nほしい。こんな良いこと、他の人は教えてくれない。これからもよろしくね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},
	
		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「んぁううぅうううっ♪　はうっ♪　……あ、あれ……？　しゃせいのお汁、 \nおまんこじゃなくて……私の顔に、身体にかかってる……！　あうっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0104401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00026701_02_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「ひゃっ♪　あぁんっ♪　す、すごい……飛んでくるっ♪　あッ……♪　あっ \n、やっぱりあったかい……♪　しゃせいのお汁好き、好きぃ……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0104402" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「んっ……♪　ベタベタしてる……♪　ああっ♪　こ、これがさっき……おま \nんこに注入されてたお汁……！　こんな量が入ってたんだ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0104403" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「ぅあああっ♪　あぁ……っ♪　おちんちんから出るお汁、浴びながら絶頂… \n…っ♪　んぅううううっ……♪　おまんこは少し寂しい、けど♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0104404" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「代わりに身体中がヌトヌトになって……。んッんっ……♪　この絶頂もわる \nく、ない……♪　もどかしくて、切なくて、好き……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0104405" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「ああっ、あぁあ……っ♪　出し惜しみなんてしないで……！　全部ちょうだ \nい！　もっと、もっと、私にしゃせいして！　隊長さぁん……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0104406" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「ふぅ、ふぅ、ふぅ……♪　おちんちんからしゃせいで出るお汁……。１回目 \nはおまんこの中に全部注入してもらったから、色も臭いもわからなかった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0104407" ]},
		{"command":[ "SETIMAGE", "0", "still_00026701_02_12" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「でも……身体に、顔にかけられた分は……目で見て鼻で嗅ぐことができる… \n…。へぇ……色は真っ白で、臭いは……。うぅ、ムワッとした臭い」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0104408" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「んん？　もちろん、２回目もおまんこに出してほしかったけど……。これは \nこれで、好奇心が満たされてちょっとうれしい。初めて見た、から……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0104409" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「このお汁、精液っていうんだね……。覚えておく……。これね、中で出ると \n本当に気持ちいいの……♪　私のお気に入り……また出してほしいなあ」", "NORMAL" ]},
