		{"command":[ "SETIMAGE", "0", "still_00027901_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「これで満足されましたか？　きゃっ……！？　ま、まだ……終わっていない\n……そんな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0103201" ]},
		{"command":[ "SETIMAGE", "0", "still_00027901_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「もっと口と胸を同時に使って……更に激しくしろと……どこまでも勝手なこ\nとを……でも、逆らうことは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0103202" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「分かりました……やります、から……んっ、もう一度……おっぱいを寄せて\n……オチンチンを……挟み込む……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0103203" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「あぁ……んっ、精液のにおいがまだ強く残って……すぅぅ……んっ、はぁぁ\n……あ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0103204" ]},
		{"command":[ "SETIMAGE", "0", "still_00027901_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「ち、違います……このにおいが好きなんて、そんなのじゃありません……こ\nれは、ただ、気になっただけで……んふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0103205" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「とにかく、していきますから……んんっ、くっ、はっ、んんっ……あっ、は\nぁ……んっ、おっぱいを……ぎゅっと重ねて……んくう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0103206" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「はぁ、んっ……また、舌も使って、舐めていきますから……ちゅぷ、んちゅ\nるっ、りゅぷっ、れろ、えろ……んちゅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0103207" ]},
		{"command":[ "SETIMAGE", "0", "still_00027901_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「きゃふっ……！　んっ、いや……乳首……擦れて……私……か、感じやすく\nなっている……そんな、こと……ダメなのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0103208" ]},
		{"command":[ "SETIMAGE", "0", "still_00027901_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「んぅんっ！　今のは……そんなのじゃないんです……あぁ、疼いているなん\nて……そんな、ことは……んくぅ……あっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0103209" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「そんな、こんなこと……したい訳じゃないのに……身体が熱い……どうして\n、私はそんな淫らな女神では……ひぁっ、あんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0103210" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「ちゅぷ、ぴちゃ、んっ、れろ……んりゅっ、りゅぷぅ……あぁ……んむ、ん\nっふ……はぁ、んむちゅ……んはぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0103211" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「違う……これは、うっとりしている訳じゃない……オチンチンを美味しいな\nんて思っていない……これは民の為なの……んちゅぱぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0103212" ]},
		{"command":[ "SETIMAGE", "0", "still_00027901_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「はむ、あぁんむ、ぴちゃ……んちゅるっ……でも、あぁ……舌が自然に動い\nちゃう……あぁ、んむ、ちゅぱっ、震えている場所……全部舐めて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0103213" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「あぁ……ここも、跳ねて……敏感なのね……そこに、乳首を……あひっ！　\nあぁ……また擦れてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0103214" ]},
		{"command":[ "SETIMAGE", "0", "still_00027901_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「はんっ、あんっ、あぁんっ……気持ち……いいんですね……？　い、一緒に\n感じて……そ、それは……あぁ……」", "NORMAL" ]},
