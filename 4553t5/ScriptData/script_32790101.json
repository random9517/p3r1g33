		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「し、したくてしていることではありませんっ……貴方が命令したことでしょ\nうっ……こんな、パイズリを……しろだなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0103102" ]},
		{"command":[ "SETIMAGE", "0", "still_00027901_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「逆らえばどうなるか……それ以上言う必要はありません。これも……私に課\nせられた使命……民の……為ですから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0103103" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「うぅ……でも……あ、あまり見ないで下さい……恥ずかしいです……こんな\n、破廉恥なこと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0103104" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「とにかく、こうして……挟めばいいんですよね……？　この……オ、オチン\nチンを……胸の……谷間に収めて……動かして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0103105" ]},
		{"command":[ "SETIMAGE", "0", "still_00027901_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、なんて……匂い……んんっ、すごく……むっと熱が立ち込め\nて……はぁ……生臭いのに……こんな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0103106" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「べ、別に見とれてなんかいませんっ……！　動かしていけば……いいんでし\nょう……はっ、ふっ、んっく……あぁ……んっ、あっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0103107" ]},
		{"command":[ "SETIMAGE", "0", "still_00027901_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「はっ、ふっ……あぁ……私……また、いやらしいことをしてしまっている…\n…自分の胸で……オチンチンを扱くなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0103108" ]},
		{"command":[ "SETIMAGE", "0", "still_00027901_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「はぁ、んっ、何度も……上下に動かして……んっ、くふっ……はぁっ、あぁ\nっ……皮を捲り返していくなんてことぉ……んっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0103109" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「んんっ、ふっ、んっく、あっ、うんっ……あぁ……こんな感じでいいのです\nか……？　うぅ……パイズリの素質なんて、あ、ありませんから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0103110" ]},
		{"command":[ "SETIMAGE", "0", "still_00027901_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「あ……んんっ、また膨らんで……先端がビクビク震えて……あぁ……いやら\nしい形になってしまいます……はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0103111" ]},
		{"command":[ "SETIMAGE", "0", "still_00027901_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「んっ、もっと強く押し込むように……は、はい……これで、どう……でしょ\nうか……んぁぁ……はあぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0103112" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「今度は……口で……咥えて奉仕を……わ、分かりました……その、失礼しま\nす……はぁんむっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0103113" ]},
		{"command":[ "SETIMAGE", "0", "still_00027901_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「あんむっ、ちゅぷっ、りゅぱっ、んっ、じゅぽっ……んっふ……あぁ……大\nきい……んっ、口にあふれそうな位……くぷぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0103114" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「んりゅぷっ、ちゅぱっ……んっ、ふっ……丁寧に……亀頭を舐める、ところ\nから……ちゅぷっ、ちゅぽ、りゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0103115" ]},
		{"command":[ "SETIMAGE", "0", "still_00027901_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「んちゅっ、ビクッとしてます……あぁ……んちゅっ……じゅるるっ、んちゅ\nぷぅぅ……はぁん、れる、りゅぷ……じゅぱっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0103116" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「そんな……お、美味しそうになんてしていません……こんな、しょっぱくて\n……んっ、えぐ味のあるモノ……好きで咥えているわけでは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0103117" ]},
		{"command":[ "SETIMAGE", "0", "still_00027901_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「それでも……中途半端にしていたら……終わりませんから……早く、出すな\nら……出して下さい……りゅぷっ、んちゅぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0103118" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「もっと速く……んんっ、ふぁひ……んっ、くぽっ、りゅぷ、じゅぽっ、んじ\nゅぷっ、ちゅぷっ、んくぷっ、んふぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0103119" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「胸も……お、おっぱいも同時に……分かっています……んっ、はぁ……あぁ\nっ、強く挟んで……ぎゅっと動かして……あぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0103120" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「もっとよく濡らして……滑りやすくする……はい、んっ、ちゅぱぁ……れろ\n……んっ、えろぉ……れろ……んふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0103121" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、ヌルヌルが絡んで……あふっ……さっきより、滑るようにな\nってます……これで……よろしいんですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0103122" ]},
		{"command":[ "SETIMAGE", "0", "still_00027901_01_04" ]},	
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「もっと速く……んっ、口の方も……ふぁい……んっ、あぁ、じゅぷっ、ふぶ\nっ、んりゅぷっ、くぷっ、じゅるっ、んちゅぷっ、んんんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0103123" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「あふぅ……オチンチン、んふぁ……まだ膨らんで……んんっ、じゅるっ、尿\n道口を……もっとれふか……んっ、ぐっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0103124" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「も、申し訳ありません……んっ、大丈夫でしたか？　歯が当たって、その痛\nくしてしまったのかと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0103125" ]},
		{"command":[ "SETIMAGE", "0", "still_00027901_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「敏感な場所で……それくらいがいい……はい……それでは、もっと……んふ\nぅっ、じゅぷっ、んちゅるっ、りゅぷぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0103126" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「強く吸い上げて……おっぱいを押し付けて……はぁ……んっ、震えてる場所\nを……舐め上げて……んじゅぷぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0103127" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「ち、違います……私は、淫乱なんかじゃ……これも、全て……民に危害が加\nえられないように……その為にしていることです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0103128" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「そんな、じゅぽっ、オチンチンが美味しいなんて……そんなことぉ、ありま\nせんからぁ……じゅぱ、りゅぷっ、んくぷっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0103129" ]},
		{"command":[ "SETIMAGE", "0", "still_00027901_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「んはぁ……あぁ、割れ目から……んっ、じんわり……滲んできています……\nはぁ、んちゅぷっ、先、走り……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0103130" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「れろ、んちゅぷぅ……これを、もっと……はぁんむ、するんれふよね……ふ\nぁい……んっ、くぷっ、はぁ、んちゅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0103131" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「んじゅるるっ！　また溢れて来ます……んちゅぅ……はぁ、だめ……この口\nの中に広がるこの味……ダメなのぉ……じゅぱ、ちゅぷぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0103132" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「んっ、ふぁ……んぶっ！　ふぉんんら……んっ、あぷっ！　オチンチン……\n激しくっ、んりゅぷっ……むぐぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0103133" ]},
		{"command":[ "SETIMAGE", "0", "still_00027901_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「もうすぐ……出るから……んぁぷっ、はっ、んんっ……あぁ……口の中で…\n…震えて……近いん……ですねっ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0103134" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「ころまま……んんっ、の、飲め……？　ふぉんらっ、ことっ、むぐっ、んふ\nっ、んぁっ、んむぅぅぅぅぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0103135" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「ふぶっ……！　んんんっ……！　あぁ……出て……いまふ……こんな、一度\nに……飲みきれない……んっ、むぐぅっ……ん、むっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0103136" ]},
		{"command":[ "SETIMAGE", "0", "still_00027901_01_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「ぷぁっ、んふぁぁ……後から後から、溢れ出して……こんなにドロっとした\nものが……んっ、じゅるぅぅ……くぷっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0103137" ]},
		{"command":[ "SETIMAGE", "0", "still_00027901_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「んんっ、こく、んくっ、んくんっ……んふっ、けほっ、はぁっ、はぁっ、は\nぁっ……の、飲みました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0103138" ]},
		{"command":[ "SETIMAGE", "0", "still_00027901_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「で、ですから美味しくなんて……ありません……本当にやっと、飲んだんで\nすから……はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0103139" ]},
		{"command":[ "SETIMAGE", "0", "still_00027901_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「口の横に付いている……んちゅぷっ、これで大丈夫……ですか……？　は、\nふ……」", "NORMAL" ]},
