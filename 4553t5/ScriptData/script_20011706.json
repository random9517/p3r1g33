{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0081" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「会場の皆さん、お待たせいたしました！　渚のマーメイドコンテストのメイ\nンイベント！　水着コンテストのお時間です！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "観客たち" ]},
		{"command":[ "SETTEXT", "「うおおおおおぉーーーーー！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「これから参加者の皆さんには一人ずつ、砂で出来たランウェイを歩いてもら\nいます！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「ランウェイを歩いている間、アピールなどをしていただいて構いません！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「全員の水着姿とアピールを見たあと、審査員が独断と偏見で、一番の美女を\n決めさせていただきます！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「水着コンテストか……あいつらの水着なんて何度も見たから、今更って感じ\nだな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「コンテストで見る水着姿と、普段見る水着姿とでは、また違った見え方をす\nるものですぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021540007" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そんなもんかねぇ」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「それでは、紅組の方から順番に行ってみましょう！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「まずはこの人！　紅組キャプテン、ルルーナ・フォンブラウン・ムーンラン\nドさん！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「私の美しさ、とくと味わうといいわ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070021540001" ]},
		{"command":[ "SETCHARA", "0", "char_00000107_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「とても綺麗で可憐！　まさにお嬢様といった風貌です！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「当たり前です。このスタイルを維持するために、しっかりと運動をしていま\nすから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070021540002" ]},
		{"command":[ "SETCHARA", "0", "char_00000107_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「ちなみにルルーナさんですが、身長は１６９センチ！　スリーサイズは上か\nら９２・５８・８０！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「えっ……ちょ、ちょっと！？　どうしてプロフィールを公開する必要がある\nの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070021540003" ]},
		{"command":[ "SETCHARA", "0", "char_00000107_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「最近はお腹周りが気になるようで、ダイエットと称したランニングや糖質制\n限をされているとのことです！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「誰がそんなことを教えたのよ！　ちょっとスタッフ！　個人情報がダダ漏れ\nになっていますわ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070021540004" ]},
		{"command":[ "SETCHARA", "0", "char_00000107_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「そんな努力を重ねるルルーナさんですが、残念ながら体重はごじゅ……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「イヤあああああぁーーーーー！　それ以上はやめてえええええぇーーーーー\n！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070021540005" ]},
		{"command":[ "SETCHARA", "0", "char_00000107_01", "9", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「おーーーっと！　ルルーナさん、恥ずかしさのあまり逃げ出してしまったー\nーー！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「ちなみに、これらの情報は大会スタッフが密かに確認したり、参加者の皆さ\nんからのタレコミでお送りしております！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんか水着コンテストというより、暴露大会に近いな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「近いというより、本当にただの暴露でしたな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021540008" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「お次は白組キャプテン、Ａ・ルナテミスさん！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「ふっ。別に私は暴露されて恥ずかしい情報などないし、むしろこの身体を見\nて欲しいぐらいだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090021540001" ]},
		{"command":[ "SETCHARA", "0", "char_00000111_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「筋肉を鍛えることが好きというアナザーさん！　最近はプロテインを新調し\nたそうです！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「運動後３０分以内にたんぱく質を取るのは、筋肉を鍛えるために重要なこと\nだからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090021540002" ]},
		{"command":[ "SETCHARA", "0", "char_00000111_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「そんな筋肉女子なアナザーさんですが、いろんな方から『妙にエロい声を出\nしながら筋トレしてて、業務に支障が出る』と苦情が来ております！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「ちょっと待て！　私はそんな声を出した覚えはないぞ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090021540003" ]},
		{"command":[ "SETCHARA", "0", "char_00000111_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「タレコミによると、『多分アレは、無意識のうちに出している声』とのこと\nです」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「んなっ……！？　そ、そんなバカな……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090021540004" ]},
		{"command":[ "SETCHARA", "0", "char_00000111_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「わかる……アナザーの筋トレ、なんかエロいんだよな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「声だけ聞くと、自らを慰めているのかと思ってしまうほどです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021540009" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「お次は月影輝夜さん！　張り切って、どうぞ！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「む、むむむ……無理……！　こんな……ひ、人前に出るなんて……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_050021540001" ]},
		{"command":[ "SETCHARA", "0", "char_00000205_01", "4", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「しかも、変なこと言われて……あっ、あっ……！　も、もう我慢が……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_050021540002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「はうぅぅぅぅぅーーーーーー……っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_050021540003" ]},
		{"command":[ "SETCHARA", "0", "char_00000205_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「おっと！　輝夜さん、ステージの外へ逃げ出してしまいました！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「輝夜は仕方ないな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「あの人見知りな輝夜殿が、コンテストに出ているだけでも奇跡ですからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021540010" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「えー……気を取り直して、セレイン・チャンさん！　お願いします！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「へっへー！　こりゃ、優勝はいただきかな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040021540001" ]},
		{"command":[ "SETCHARA", "0", "char_00000404_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「セレインさんは、食べることがお好きとのことです。健康的ですねぇ！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「美味しければ、甘いモノも辛いモノも、なんでも食べるぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040021540002" ]},
		{"command":[ "SETCHARA", "0", "char_00000404_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「甘いモノもお好きなようで、よかったです！　こちら、スタッフからの差し\n入れです！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「一口サイズのドーナツみたいだな。それに、すごく甘い香りがするけど……\nまあいいや。いただきまーす！　あむっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040021540003" ]},
		{"command":[ "SETCHARA", "0", "char_00000404_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「ぶふおおおおぉ！？　なっ、なんだよこれ！？　甘すぎるにもほどがあるぞ\n！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040021540004" ]},
		{"command":[ "SETCHARA", "0", "char_00000404_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「こちら、近くのビーチで売ってる、グラブ・ジャムンという食べ物です！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「簡単に言うと、小麦粉と大量の砂糖を混ぜ合わせたものをバターを使って揚\nげて、シロップに浸けたお菓子です」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「不味くはないけど、さすがにコレは甘すぎだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040021540005" ]},
		{"command":[ "SETCHARA", "0", "char_00000404_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「ちなみに、これ一個で３００キロカロリーぐらいあるので、食べすぎると\nすぐに太りますよ」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「そんなの、余計いらないよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040021540006" ]},
		{"command":[ "SETCHARA", "0", "char_00000404_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そんなに甘いのか、あれ」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「別名、世界一甘いお菓子ですぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021540011" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「お次はエファ・グラナーダさんです！　では、ランウェイへどうぞ！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「水着コンテストというより、なにかを披露したり、一発芸をする場になって\nないかしら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021540001" ]},
		{"command":[ "SETCHARA", "0", "char_00000306_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「皆さん見てください！　このエファさんの肌！　ボディ！　そして水着！　\nどこを見ても素晴らしい、絶世の美女です！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「そんなストレートに褒められると、かえって恥ずかしくなるわね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021540002" ]},
		{"command":[ "SETCHARA", "0", "char_00000306_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「そんなお美しいエファさんですが、実はかなりの年長者で、このコンテスト\nにも『ナンパされたい』という理由から出場されているようです！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「ちょ……！？　だ、誰よ！　年齢のこと言ったのは！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021540003" ]},
		{"command":[ "SETCHARA", "0", "char_00000306_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「この大胆な水着も、『若い子に負けないために選んだ』とのことですが、そ\nうなんですか？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「あ、あなた……！　死にたいのかしら！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021540004" ]},
		{"command":[ "SETCHARA", "0", "char_00000306_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「あーーーっ！　暴力はいけません、暴力は！　皆さんが見てますよ！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あの司会者、命知らずだな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「そういうご主人も、命知らずな発言が多いですけどな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021540012" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「えー……エファさんは無事、ステージ裏に連れていかれましたので、次の方\nをお呼びしましょう！　朧兎子さんです！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「あまりジロジロみないでください。不愉快です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_060021540001" ]},
		{"command":[ "SETCHARA", "0", "char_00000506_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「他の方と比べて、ちょっと……いえ、かなり胸が控え目な感じですが、心配\nいりません！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「この会場には、そういった趣味・趣向の方もたくさんおりますので、是非ア\nピールをお願いします！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「今の言葉を聞いて、どうアピールしろというんですか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_060021540002" ]},
		{"command":[ "SETCHARA", "0", "char_00000506_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「失礼ですが……タレコミによるとお風呂が苦手とのことですが、ちゃんと身\n体洗ってます？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「苦手なだけで、入らないワケじゃありません！　毎日シャワーとかで、ちゃ\nんと洗ってます！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_060021540003" ]},
		{"command":[ "SETCHARA", "0", "char_00000506_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「ちなみに、世の中にはニオイフェチな男性もいるので、少しぐらい入らなく\nても大丈夫ですよ」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "観客たち" ]},
		{"command":[ "SETTEXT", "「うおおおおおぉーーーーー！！　兎子ちゃーーーーーん！！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「なんでそこで盛り上がるんですか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_060021540004" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00000506_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんか一部のヤツらが、えらく盛り上がってるな」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「あの方々が、いわゆるニオイフェチということなのでしょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021540013" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「さて、お次はピースムーンさんです！　どうぞ！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピースムーン" ]},
		{"command":[ "SETTEXT", "「別に優勝を目指しているわけではありませんので、水着コンテストに出る意\n味はあまりないのですが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_040021540001" ]},
		{"command":[ "SETCHARA", "0", "char_00000811_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「見た目通り、中々クールな方のようです！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「さて、クールなピースムーンさんですが、どうやら上司の無茶振りに悩まさ\nれているらしいですが、本当ですか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピースムーン" ]},
		{"command":[ "SETTEXT", "「い、いえ、別にそのようなことは……！　私は言われたことを、ちゃんとや\nるだけです……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_040021540002" ]},
		{"command":[ "SETCHARA", "0", "char_00000811_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「もうこの際ですし、ぶっちゃけて楽になりましょう！　嫌いな上司は誰です\nか！？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピースムーン" ]},
		{"command":[ "SETTEXT", "「そ、そそ、そんな人はいません！　私は上司の皆さんを尊敬しておりますの\nで！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_040021540003" ]},
		{"command":[ "SETCHARA", "0", "char_00000811_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「よかったですな、ご主人。どうやらピースムーン殿から、尊敬されているよ\nうですぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021540014" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お前、それ本気で言ってる？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「続いてはこの方！　見た目にド派手な、ディアナ・アーマーンさんです！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「はぁ～い♪　ディアナちゃんよ～。みんな、よろしくねぇ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_050021540001" ]},
		{"command":[ "SETCHARA", "0", "char_00000605_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「ここまで綺麗なボディを作るのに、さぞかし苦労されたことでしょう！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「そうねぇ……確かに大変だけど、努力の賜物って感じかしら～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_050021540002" ]},
		{"command":[ "SETCHARA", "0", "char_00000605_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「それにしてもお美しい！　ずっと見ていられそう……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「……ん？　これは……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「ちょっと、どうしたの～。もっとディアナちゃんを褒めてくれていいのよ～\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_050021540003" ]},
		{"command":[ "SETCHARA", "0", "char_00000605_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「あっ、いえ……なんだか、肌にシミらしきものがあったような……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「きゃあああぁーーー！？　ディアナちゃんの綺麗なお肌に、シミなんて出来\nたら大変じゃな～い！　急いでお手入れしなきゃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_050021540004" ]},
		{"command":[ "SETCHARA", "0", "char_00000605_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「あっ、ちょっと！　ディアナさん、どちらへ……！？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「どっか行ったな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「肌の手入れをしに行ったのではないでしょうか。紫外線は肌の天敵ですから\nな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021540015" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「えー……気を取り直して、お次の方は二人同時に登場してもらいましょう！\n　十五夜つきみさんと、十五夜まりあさんです！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「人に見せるような水着じゃないけど、優勝がかかってるからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_030021540001" ]},
		{"command":[ "SETCHARA", "0", "char_00001203_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「つきみと一緒だなんて……絶対に比べられちゃう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_020021540001" ]},
		{"command":[ "SETCHARA", "0", "char_00001402_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「お二人は姉妹だそうですが、どちらがお姉さんなんですか？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「あっ……私が姉で、つきみが妹です……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_020021540002" ]},
		{"command":[ "SETCHARA", "0", "char_00001402_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「なるほど、そうだったんですね！　発育的につきみさんの方がお姉さんかと\n……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「ちょっと！　お姉ちゃんの悪口はやめてもらえる！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_030021540002" ]},
		{"command":[ "SETCHARA", "0", "char_00001203_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「い、いいのよ、つきみ……！　私の身体が貧相なのは、誰の目から見ても明\nらかだし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_020021540003" ]},
		{"command":[ "SETCHARA", "0", "char_00001402_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「私よりつきみの方が可愛いって……みんな思ってるだろうから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_020021540004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「そんなことない！　お姉ちゃんは可愛いよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_030021540003" ]},
		{"command":[ "SETCHARA", "0", "char_00001203_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「ええ、その通りです！　どんな見た目であろうと、この会場の皆さんは受け\n入れてくれます！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「そうだろう、みんなーーーーー！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "観客たち" ]},
		{"command":[ "SETTEXT", "「うおおおおおぉーーーーー！！　二人とも最高に可愛いぞおおおおおぉーー\nーーー！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「えっ、あっ……あの……あ、ありがとうございます……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_020021540005" ]},
		{"command":[ "SETCHARA", "0", "char_00001402_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「よかったね、お姉ちゃん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_030021540004" ]},
		{"command":[ "SETCHARA", "0", "char_00001203_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんか、今までで一番まともな内容だったな」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「実際、お二人とも可愛いですからな。観客の皆様が盛り上がるのもわかりま\nす」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021540016" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「お次は５人まとめての登場です！　ニンジャを目指す四姉妹！　ホクサイさ\nん、ウタマロさん、ゲンナイさん、シャラクさん！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「それと姉妹の師匠である、サチ・ハマダさんです！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「ハーイ！　みんな！　スシ食べてる？　長女のホクサイだよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010021540001" ]},
		{"command":[ "SETCHARA", "0", "char_00009602_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「オレが次女のウタマロだ！　顔と名前を間違えんじゃねぇぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_010021540001" ]},
		{"command":[ "SETCHARA", "0", "char_00009702_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「三女のゲンナイだよ。好きなものは、スシと発明。よろしくね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021540001" ]},
		{"command":[ "SETCHARA", "0", "char_00009802_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「末っ子のシャラクだよ～。あーしたち、四人合わせて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_010021540001" ]},
		{"command":[ "SETCHARA", "0", "char_00009902_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "みんな" ]},
		{"command":[ "SETTEXT", "「スクールガール・ミュータント・ニンジャ・ラビッツ！　イェーイ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010021540002" ]},
		{"command":[ "SETCHARA", "0", "char_00009602_01", "8", "CENTER", "-600" ]},
		{"command":[ "SETCHARA", "1", "char_00009702_01", "8", "CENTER", "600" ]},
		{"command":[ "SETCHARA", "2", "char_00009802_01", "6", "CENTER", "200" ]},
		{"command":[ "SETCHARA", "3", "char_00009902_01", "8", "CENTER", "-200" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "DISPCHARA", "2", "TRUE" ]},
		{"command":[ "DISPCHARA", "3", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「そして私がこやつらの師匠。サチ・ハマダだ。気軽に先生とでも呼んでくれ\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010021540001" ]},
		{"command":[ "SETCHARA", "0", "char_00010002_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "DISPCHARA", "2", "FALSE" ]},
		{"command":[ "DISPCHARA", "3", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「さすがは姉妹！　息ぴったりな自己紹介ですねぇ！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「ところで、スシというのはいったいどういうことです？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「僕たち、スシが大好きなんだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010021540003" ]},
		{"command":[ "SETCHARA", "0", "char_00009602_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「シャリと鮮魚とワサビの一体感……たまらねぇぜ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_010021540003" ]},
		{"command":[ "SETCHARA", "0", "char_00009702_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「そうそう！　一度味わったら、ヤミツキになるよね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021540003" ]},
		{"command":[ "SETCHARA", "0", "char_00009802_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「もう毎日でも食べたいぐらいだよ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_010021540003" ]},
		{"command":[ "SETCHARA", "0", "char_00009902_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「さすがに毎日スシを食べると、食費がかさむし、栄養も偏るぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010021540002" ]},
		{"command":[ "SETCHARA", "0", "char_00010002_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「皆さん、本当にスシが大好きみたいですねぇ！　ちなみに、一番好きなネタ\nはなんです？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「当然、コハダとアナゴだよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010021540004" ]},
		{"command":[ "SETCHARA", "0", "char_00009602_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「なにいってんだ！　大トロとサーモンが一番に決まってんだろ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_010021540004" ]},
		{"command":[ "SETCHARA", "0", "char_00009702_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「ホク姉もウタ姉もわかってないね。ウニとイクラこそが至高だよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021540004" ]},
		{"command":[ "SETCHARA", "0", "char_00009802_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「あーしは茶碗蒸しやプリンとかかな～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_010021540004" ]},
		{"command":[ "SETCHARA", "0", "char_00009902_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「シャラク、それはスシではないぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010021540003" ]},
		{"command":[ "SETCHARA", "0", "char_00010002_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「なんでさっきまで息ぴったりだったのに、スシネタはこうもバラバラなんで\nしょうか……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「好みは人それぞれだからな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ちなみにわたくしは、お茶と煎餅が好きですぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021540017" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「それでは、最後のお三方に登場してもらいましょう！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「こちらも姉妹での登場だ！　若苗序さん、若苗破さん、若苗急さんです！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ど、どうもこんにちはですよ！　若苗家三姉妹の長女、序です！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021540029" ]},
		{"command":[ "SETCHARA", "0", "char_00010103_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「若苗家三姉妹の次女、破です。よろしくおねがいしまーす」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_010021540023" ]},
		{"command":[ "SETCHARA", "0", "char_00010203_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「そしてボクが若苗家三姉妹の三女、急だよ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021540025" ]},
		{"command":[ "SETCHARA", "0", "char_00010303_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「随分と可愛らしい姉妹ですね！　ここには、お母さんたちと観光で来たのか\nな？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「いえ……このリゾートには、商店街の福引が当たって来ました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021540030" ]},
		{"command":[ "SETCHARA", "0", "char_00010103_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「本当はお母さんたちも来る予定だったんですけど、仕事の都合で来れなくな\nりまして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_010021540024" ]},
		{"command":[ "SETCHARA", "0", "char_00010203_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「だからボクたちだけで来たの。お母さんたちの分もリゾートを楽しんで、い\nっぱいお土産買って帰る予定なんだ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021540026" ]},
		{"command":[ "SETCHARA", "0", "char_00010303_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「くううぅ！　姉妹だけの旅行！　両親を想う、美しい家族愛！　泣かせてく\nれますねぇ！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あの司会者、随分と涙腺が緩いんだな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人は、もう少し感動するということを覚えた方がいいですぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021540018" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「さあ、以上が水着コンテストの出場者です！　審査員のお眼鏡にかなった美\n女は、果たしてどなたでしょうか！？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「結果が出ました！　今回の水着コンテンストの勝者は……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「若苗家三姉妹！　序さん、破さん、急さんだーーーーー！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「えっ、私たちが勝ったですか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021540031" ]},
		{"command":[ "SETCHARA", "0", "char_00010103_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「あたしもびっくりー。本当に勝てるだなんて思ってなかった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_010021540025" ]},
		{"command":[ "SETCHARA", "0", "char_00010203_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「やっぱり、ボクのナイスバディが決め手だったのかな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021540027" ]},
		{"command":[ "SETCHARA", "0", "char_00010303_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「いえ、お三方の水着姿というより、家族愛の方で審査員の票が集まった感じ\nです」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「じゃあ、ボクの水着姿はどうでもよかったってこと……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021540028" ]},
		{"command":[ "SETCHARA", "0", "char_00010303_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「もっとボン・キュッ・ボン！　にならないと、ナイスバディとは言えません\nよ」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「なんか納得いかない……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021540029" ]},
		{"command":[ "SETCHARA", "0", "char_00010303_01", "2", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「なんにせよ、勝ちは勝ちです！　わはは、若苗家の勝利です！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021540032" ]},
		{"command":[ "SETCHARA", "0", "char_00010103_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「そうだねー。それに三人揃っての勝利……喧嘩にならずに済んでラッキーか\nも」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_010021540026" ]},
		{"command":[ "SETCHARA", "0", "char_00010203_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「いやはや、最後まで美しい姉妹愛です！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「会場の皆さん！　若苗家三姉妹に、今一度大きな拍手をお願いします！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まさか序たちが勝つとはなぁ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「人は見た目ではなく、中身が大切ということですな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021540019" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}