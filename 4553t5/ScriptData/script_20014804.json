		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「やっと民間人を巻き込まない程度の出力を思い出したので、エネルギーが尽 \nきる前に終わらせてしまいました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010023230013" ]},
