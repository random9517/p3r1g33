{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0081" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_007" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},	
		{"command":[ "SETTEXT", "エロ改造スーツのブルーに、客席から湧きあがる大歓声。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "集まった大きなお友達も、ムスコと一緒に大喜びのようだ。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「スーツが……！　この肌の露出……！　ほ、ほとんど裸ではありませんか… \n…！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010023230001" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00005004_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「隊長……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010023230002" ]},
		{"command":[ "SETCHARA", "0", "char_00005004_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ブルー、こ、これはだな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "ブルーにギロリと睨まれ、思わずたじろいでしまう。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「ははは！　その変身アイテムは偽物だ！　どうだ、恥ずかしいだろう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_010023230001" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00019902_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「さすがのブルーも、そんな破廉恥なスーツを着てしまえば、格好がつかない \nわね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_010023230001" ]},
		{"command":[ "SETCHARA", "0", "char_00020002_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「く、くそー、すり替えられたー！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "奈羅苦が台本通りに進行してくれたので、俺も調子をあわせる。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "とにかくこれなら、ブルーが一方的にタコ乙女たちをやっつけるという流れに \nはならないはず……。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「さあさあ、勝負といこうじゃないか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_010023230002" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00019902_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "攻撃を仕掛ける奈羅苦に、ブルーが応戦する。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「こ、こんな格好で戦うなんて……！　こんな……きちんと装着されていない \n、不完全なスーツでは……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010023230003" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00005004_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「どうした！　やけに動きが鈍いじゃないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_010023230003" ]},
		{"command":[ "SETCHARA", "0", "char_00019902_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「ポロリを気にしているの？　おかげで隙だらけよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_010023230002" ]},
		{"command":[ "SETCHARA", "0", "char_00020002_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "アルスラの鞭がブルーの足首に巻き付き、転倒させた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「くぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010023230004" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00005004_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "その衝撃で、ぽろりと零れるブルーの生乳。ビーチの一部が大歓声をあげる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「そのスーツじゃ大事なところすら全然守れてないみたいだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_010023230004" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00019902_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「あなたたちこそ、暴れまわっているうちに胸がはだけていますよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010023230005" ]},
		{"command":[ "SETCHARA", "0", "char_00005004_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "ブルーの指摘通り、奈羅苦とアルスラの水着もずれて胸が露出している状態だ \nった。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「それがどうした？　むしろこっちの方が動きやすいじゃないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_010023230005" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00019902_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「そうよ。ちょっとおっぱいがはみ出ちゃったくらいで、動揺なんかしないわ \n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_010023230003" ]},
		{"command":[ "SETCHARA", "0", "char_00020002_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "奈羅苦は本当にブルーとの戦いしか頭にないようだ。アルスラも動じていない \n。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「タコ乙女様、どうします？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_010023230001" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00018201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「助っ人にまかせてもいいかもしれませんけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_010023230001" ]},
		{"command":[ "SETCHARA", "0", "char_00018301_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「私たちも、ちゃんと活躍しないと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_010023230001" ]},
		{"command":[ "SETCHARA", "0", "char_00018401_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「そ、そうだタコ！　うぅ、マスク・ザ・ブルー、覚悟するタコー！　わ、私 \nたちの相手もするトパスー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_030023230001" ]},
		{"command":[ "SETCHARA", "0", "char_00021903_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "そこへタコ乙女たちも参戦する。……語尾がブレているようだが、 大丈夫だろ\nうか。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "とにかく、改造スーツで本気をだせないブルーと、オーヴァーハング四天王の \nふたり、そして怪人派遣組合。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "エロいブルーとエロい女幹部とエロい怪人と戦闘員が、ステージで戦い始める \n。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「はぁああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_010023230006" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00019902_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「くぅっ、こんな姿でなければ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010023230006" ]},
		{"command":[ "SETCHARA", "0", "char_00005004_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「覚悟しなさいブルー。ここがあなたの墓場よ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_010023230004" ]},
		{"command":[ "SETCHARA", "0", "char_00020002_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "奈羅苦とアルスラは、ポロリなんかものともせずに大立ち回りをしている。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "一方で、ブルーは乱れたスーツが気になるのか守りに入り、決定打になるよう \nな攻撃をだせずにいるようだった。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「わ、私だって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_030023230002" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00021903_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「タコ乙女様！　胸が！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_010023230002" ]},
		{"command":[ "SETCHARA", "0", "char_00018201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「タコ……？　きゃぁあああぁぁぁっ！　み、見ないでくださいぃいいいぃぃ \nぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_030023230003" ]},
		{"command":[ "SETCHARA", "0", "char_00021903_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "あられもない姿が連発するヒーローショーに、前回とは別の意味で客席がヒー \nトアップする。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「青少年だって観客にいるというのに、こんな過激な格好をさせるなんて。誰 \nの入れ知恵ですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010023230007" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00005004_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「さぁな。アタシはただ、ブルーと戦えりゃそれでいい！　格好なんて関係な \nいね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_010023230007" ]},
		{"command":[ "SETCHARA", "0", "char_00019902_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「小さな子が、変な性癖に目覚めてしまったらどうするんですか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010023230008" ]},
		{"command":[ "SETCHARA", "0", "char_00005004_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「性癖が目覚めるきっかけになるのも、戦隊ヒーローに登場するエッチな女幹 \n部の役目よ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_010023230005" ]},
		{"command":[ "SETCHARA", "0", "char_00020002_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "いや、それはどうだろう？　そういう側面も……あるのか？", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「やはりあなた達は倒さねば……教育に悪すぎます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010023230009" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00005004_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「やってみな！　あのときみたいに、アタシに本気をぶつけてくれるんだろ？ \n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_010023230008" ]},
		{"command":[ "SETCHARA", "0", "char_00019902_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「本気……。そうですね。これは、かつてあなた方にも見せられなかった、『 \n本気』の力です……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010023230010" ]},
		{"command":[ "SETCHARA", "0", "char_00005004_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "ぶるんと胸を大きくを揺らしながらブルーがパンチを繰り出した。奈羅苦は大 \n鎌の柄で受ける。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「本気と言いながら、ただのパンチじゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_010023230009" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00019902_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "ミシ……ッ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "拳から放たれる冷気が、柄を凍り付かせ、そのままへし折った！", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「なにぃ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_010023230010" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00019902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "慌てて距離をとる奈羅苦。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「スーツが不完全なら弱体化する……。いつからそう錯覚していましたか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010023230011" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00005004_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "そう呟いたとたん、ブルーの全身から勢いよく冷気が放たれた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "そして……。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「お……おぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_010023230011" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00019902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「あ……あ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_010023230006" ]},
		{"command":[ "SETCHARA", "0", "char_00020002_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女たち" ]},
		{"command":[ "SETTEXT", "「ひぇええぇぇぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_010023230003" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "DISPCHARA", "2", "TRUE" ]},
