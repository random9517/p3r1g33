		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「おっぱいをご主人様に押しつけちゃうの。あんっ、どうかしら？　やわらか\nい私のおっぱい、全身で感じるでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0303103" ]},
		{"command":[ "SETIMAGE", "0", "still_00021203_01_01" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「ご主人様のオチンチン、硬くなっているのを感じるわ……。とっても元気ね\n……ガチガチになって、おっぱいを押しのけてくるわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0303104" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「ご主人様、ほら……口元に、私の乳首があるでしょ？　これでご主人様に授\n乳しながら、おっぱいでオチンチンも気持ちよくしてあげるわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0303105" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「あんっ、さっそくご主人様が、乳首にぃ……んっ、あぁっ、しっかり吸い付\nいて……んっ、んふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0303106" ]},
		{"command":[ "SETIMAGE", "0", "still_00021203_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「私も、おっぱいで……あんっ、ご主人様の、熱いのを……お乳でしごくわね\n……んっ、しょ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0303107" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……谷間に……んっ、こすれるの、感じるぅ……んふぅ……とっ\nても逞しいのね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0303108" ]},
		{"command":[ "SETIMAGE", "0", "still_00021203_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「んっ、ご主人様の腰も、動いちゃってるみたい……ああっ、私のおっぱいに\n、アソコが、こすりつけられてる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0303109" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「ああ、おっぱいも……吸い付いて……んっ、んふっ、乳首が引っ張られちゃ\nうくらい……あぁんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0303110" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「ご主人様、どうぞ……私のおっぱいに、いっぱい甘えてくださいね……んっ\n、んはぁ……ああ、ん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0303111" ]},
		{"command":[ "SETIMAGE", "0", "still_00021203_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「音を立てて、ちゅうちゅう吸って……んぁっ、舌で乳首……すりすりって、\nやぁっ、くすぐったいわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0303112" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「くすぐったいけど、おっぱいがジンジン疼いちゃう……はぁ、はぁ……乳首\nにいたずら、ダメよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0303113" ]},
		{"command":[ "SETIMAGE", "0", "still_00021203_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「でも、ご主人様になら、いっぱいいたずらさせてあげちゃうわ、だって、私\nのおっぱいは、ご主人様専用だもの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0303114" ]},
		{"command":[ "SETIMAGE", "0", "still_00021203_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「だから、もっと……んっ、もっと甘えて……はぁ、はぁ……乳首吸うだけじ\nゃなくて、揉んだり、オチンチンをこすりつけたりぃ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0303115" ]},
		{"command":[ "SETIMAGE", "0", "still_00021203_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁ……っ、硬いのがこすれて、んぁっ、私もおっぱいが気持ちい\nいの……んふぅ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0303116" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「私の大きなおっぱい……ご主人様に一生懸命揉まれて、んぁっ、乳首もちゅ\n～ってされて……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0303117" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「ああっ、ああぁんっ、で、でちゃうわっ、母乳が……で、でちゃうのぉ……\nっ！　あっ、あっ、ああぁああぁぁ～～～～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0303118" ]},
		{"command":[ "SETIMAGE", "0", "still_00021203_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「す、吸って、ご主人様ぁ……。ママメイドカーの母乳、いっぱい、吸ってく\nださい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0303119" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「あぁんっ、いっぱい吸われてる、ごくごくって、母乳飲まれて……んんっ、\nお乳吸われるの、気持ちいい……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0303120" ]},
		{"command":[ "SETIMAGE", "0", "still_00021203_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「ご主人様、もっと、おっぱいを押しつけて……はぁ、はぁ、飲みやすいよう\nに、しますね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0303121" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「ああ、おっぱいを吸いながら、ますます興奮しているみたい……オチンチン\nが、ますますガチガチになって……すごいわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0303122" ]},
		{"command":[ "SETIMAGE", "0", "still_00021203_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「ここもしっかり、気持ちよくしますからね……んっ、私のおっぱいで、授乳\nしながら乳コキいたしますぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0303123" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「んはぁ、機体の熱があがって、表面から冷却オイルが溢れているみたい……\nああ、おっぱいが、ヌルヌルになっちゃってるわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0303124" ]},
		{"command":[ "SETIMAGE", "0", "still_00021203_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「それだけじゃないわ……ご主人様のオチンチンが気持ちよくなって、先走り\nのお汁も溢れているからね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0303125" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、しっかりおっぱいを押しつけて……ね……。ンッ、オチンチン\n、しごくわ……あぁんっ、感じるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0303126" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「おっぱいをぎゅうてしたら、ご主人様のビクビクオチンチンを感じて……ん\nぁっ、私も、興奮の数値が、あがって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0303127" ]},
		{"command":[ "SETIMAGE", "0", "still_00021203_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「同時に、このままご主人様に気持ちよく射精してもらいたいって気持ちにな\nるわ……んっ、んふふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0303128" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「もっと、もっと強く……んっ、おっぱいで、オチンチンを挟んで……んぁっ\n、動かして、しごいて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0303129" ]},
		{"command":[ "SETIMAGE", "0", "still_00021203_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「ガチガチ、ビクビクのオチンチン……。はぁ、はぁ、いっぱい気持ちよくな\nってね……んっ、んふぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0303130" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「私も、感じちゃう……ご主人様に、おっぱい吸われて、揉まれて……んっ、\nああっ、おっぱい、おいしい……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0303131" ]},
		{"command":[ "SETIMAGE", "0", "still_00021203_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「ええ、このまま……もっともっと、おっぱいを吸っていいからね……あんっ\n、オチンチンも、いっぱい気持ちよくなって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0303132" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、腰が動いてるわ……んっ、おっぱいを、ご主人様のオチンチン\nに犯されちゃってるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0303133" ]},
		{"command":[ "SETIMAGE", "0", "still_00021203_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「とっても元気ね、あんっ、オチンチン、元気におっぱいの谷間を動いて、素\n敵よ。んっ、んん……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0303134" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「このまま、射精しちゃいそう？　いいわよ、だしていいわ、ご主人様、たっ\nくさん精液、だしていいからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0303135" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「私が、しっかり受け止めるわ。あんっ、どんどん激しくなってる……あっ、\nああっ、おっぱい犯されて……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0303136" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「乳首も吸い付いて、んっ、ちゅ～されて……あっ、ああっ、すっごく感じち\nゃう……っ！」", "NORMAL" ]},
