		{"command":[ "SETIMAGE", "0", "still_00021203_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},		
		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
