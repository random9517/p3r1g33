		{"command":[ "SETIMAGE", "0", "still_00021203_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},		
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「ご主人様のオチンチンから、アツアツの精液が、いっぱい、どぴゅどぴゅっ\nて谷間に……はぁ、はぁ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0303139" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「こんなにたくさん……いっぱい射精して、偉いわね……。うふふ、ご主人様\n……もっとこのオチンチンに、ご奉仕させて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0303140" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……射精したあとなのに、オチンチン、まだまだガチガチなのね\n……んっ、んはぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0303201" ]},
		{"command":[ "SETIMAGE", "0", "still_00021203_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「私も、さっきイッちゃったのよ……ご主人様の、ドロドロザーメンをおっぱ\nいに乳内射精されて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0303202" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「んふふ、ますます機体が火照っちゃってる……はぁ、はぁ……母乳も、とま\nらなくなっちゃっているわね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0303203" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「ふふ、いいのよ、どんどん飲んでちょうだい。私の母乳はご主人様に飲んで\nもらうためにあるんだから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0303204" ]},
		{"command":[ "SETIMAGE", "0", "still_00021203_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「んっ、ああっ、また思いっきり吸いついて……っ！　んっ、んんっ、ごくご\nくって、飲んでる……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0303205" ]},
		{"command":[ "SETIMAGE", "0", "still_00021203_01_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、いい……いいわ……。そうやって、吸ってぇ……。ああ、その\nまままた、オチンチンしごいてあげるわね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0303206" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「ああ……またこんなに、ガッチガチに勃起しているわ……。逞しいオチンチ\nン……ちゃんとお世話するわね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0303207" ]},
		{"command":[ "SETIMAGE", "0", "still_00021203_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「精液で、ヌルヌルになったおっぱいで……んっ、ぎゅうっと、オチンチンを\n押さえつけながら、ズリズリ～……って」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0303208" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「んふふ、おっぱい気持ちいい？　私のおっぱい、いっぱい感じてね。あんっ\n、オチンチンがビクンって跳ねたわ」", "NORMAL" ]},
