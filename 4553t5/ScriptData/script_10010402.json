		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「周辺に敵影なし、か。まあ、こんなもんかねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010104020001" ]},
	{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おっし、みんなお疲れ。それじゃ、本部に引き上げるとすっか」", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「ちょいと待ったらんかい、ワレェ～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_128_010104020001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「な！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "なんだ！？　どこからともなく女の子の声が――", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「まさか、まだ敵が！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010104020001" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "3", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「所属不明の人影を探知！　６時方向で――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010104020001" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「へへっ！　遅いで！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_128_010104020002" ]},
	{"command":[ "SETCHARA", "0", "char_00012801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「違う！　３時方向！　いえ、今度は１１時――速い！　どうしてこんなに動\nきが速いの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010104020002" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「見えたっ！　そこかぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010104020001" ]},
	{"command":[ "SETCHARA", "0", "char_00000401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「遅い言うとるやろがぁ！　はっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_128_010104020003" ]},
	{"command":[ "SETCHARA", "0", "char_00012801_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「なっ！？　わたしを踏み台にしたぁ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010104020002" ]},
	{"command":[ "SETCHARA", "0", "char_00000401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「アンタらに用はないねん！　用があるのは――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_128_010104020004" ]},
	{"command":[ "SETCHARA", "0", "char_00012801_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「自分らや！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_128_010104020005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「なんだと……？　私たちに何の用だ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010104020001" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「自分ら、Ｗ（ダブル）ルナテミスやろ？　へへへへ、やっと会えたで！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_128_010104020006" ]},
	{"command":[ "SETCHARA", "0", "char_00012801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「なにぃ！？　『ダブル』とはなんだ『ダブル』とは！　私だけがルナテミス\nでこいつはおまけだっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010104020002" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「……っ！？　あなたはもしや、マグナシア姫……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090104020001" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「ふふふふふふふふ、ご挨拶が遅れましたわぁ……。ごめんあそばせかんにん\nや」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_128_010104020007" ]},
	{"command":[ "SETCHARA", "0", "char_00012801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「そう、ウチが暗黒魔法王国第一王女、マグナシア・カイザー・ナックルや。\n以後、お見知りおきをやで」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_128_010104020008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「やはりそうか。初めてお目にかかる。私は――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090104020002" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「おおっと、名乗りはいらん。知っとるで。アンタは他の次元からこの世界に\n来た王女ルナテミス。通称アナザーこと『クールな一号』やな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_128_010104020009" ]},
	{"command":[ "SETCHARA", "0", "char_00012801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ク、クールな一号！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090104020003" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「そしてアンタが、元からこの世界にいた王女ルナテミス。『ツンな二号』や\nろ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_128_010104020010" ]},
	{"command":[ "SETCHARA", "0", "char_00012801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ぬぁあああああにぃいいいいい！？　誰が二号だ誰がぁ！　なぜ私が二号な\nのだ！　私こそが一号であるべきだろうがぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010104020003" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「いや、あの、『ツン』にはツッコまないの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_020104020002" ]},
	{"command":[ "SETCHARA", "0", "char_00001302_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「意外と自覚はあるのかしら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010104020003" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「まあどっちゃでもええわ。ウチが知りたいのは、アンタらがどんだけ強いか\n、ってことやからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_128_010104020011" ]},
	{"command":[ "SETCHARA", "0", "char_00012801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「なんだと？　まさか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090104020004" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「アンタらの実力、ちょいとばかし見せてもらうで！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_128_010104020012" ]},
	{"command":[ "SETCHARA", "0", "char_00012801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
	{"command":[ "EXIT" ]}
	]
}