		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「やった！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_020104020001" ]},
	{"command":[ "SETCHARA", "0", "char_00001302_01", "8", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
