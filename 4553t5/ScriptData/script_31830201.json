{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018302_01_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「はあ？　私から誘ったとか、言いがかりはやめてよね。物欲しそうな顔とか\nしてないわよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0203102" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「こうなったら射精しないと、おさまらないんでしょう？　だから仕方なく相\n手てしてるだけ……んっ……それだけ、よ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0203103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「しつこい、わね……車の中でまで勃起させてるから……気になるでしょう…\n…べつにそういう目で見てたわけじゃないわよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0203104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「んっ……はいはい、勝手に言ってなさい。あなたの好きなパイズリフェラで\n抜いてあげるから……さっさと済ませて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0203105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「誰か、来たら大変なんだから……こんなことろ見られたら……んんっ……ち\nゅ、ちろっ……れろれろっ……んれぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0203106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「興奮なんて……するわけないじゃない……そういう趣味はないの……ホテル\nが好きとか、そうじゃなくて……もうっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0203107" ]},
		{"command":[ "SETIMAGE", "0", "still_00018302_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「余計なこと言わなくていいから、大人しくしてて……気がちって、ヤリづら\nいわよ……んっ、んあっ……くちゅ、ちゅうっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0203108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「はぁ、んっ……それにしても相変わらず、大きいわね……谷間から、完全に\n先っぽが……はみ出てて……んっ、れろっれろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0203109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「惚れてなんかないわよ……呆れてるだけ……でも、もう慣れちゃったけど。\nあなたの相手ばっかしてるから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0203110" ]},
		{"command":[ "SETIMAGE", "0", "still_00018302_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「ちろっ、んぷっ……ちく、ちゅくぅ……夫の？　比べるまでもないわよ……\nあなたのより、大きいのは見たことないって言ったでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0203111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「元から、あの人のもので……というかあの人とのセックスで、満足なんかし\nてなかったわよ。あなたのチンポと、関係なくね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0203112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「でも、だからって浮気なんかするつもりなかったのに……あなたが……あな\nたが悪いのよ？　こんな凶悪なもので……ちゅる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0203113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「なによ、ここまでさせて……今さら、やめていいよなんて……無責任なこと\n言わないでよ……んっ、れろ、れろぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0203114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「悔しいけど、もう……ダメなの……あなたもわかってるんでしょ？　私が…\n…このチンポ……に取りつかれて……くっ、ふうっ、ううっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0203115" ]},
		{"command":[ "SETIMAGE", "0", "still_00018302_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「だから、ワザとズボンの上からわかるくらい勃起させて……私に見せつけて\nきて……こうなるって、わかってたんでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0203116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「はぁっ……あぁ……私が、我慢できなくなって……ふぅ、んっ……ヤらせて\n、っておねだりしてくるの……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0203117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「口ではなんだかんだ言いながら、他所の男のチンポ……胸に挟んで、しゃぶ\nって……ちゅ、ちゅぶっ……れろ、れろっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0203118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「んっ……ホント、悪い男よね……こうやって、人妻だろうとお構いなく……\n色んな女に手を出してるんでしょう？　ちゅ、ちゅぷ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0203119" ]},
		{"command":[ "SETIMAGE", "0", "still_00018302_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「あんまり、悪さ……しないように……私が、搾り取ってあげるから……んっ\n、んふぅっ……れろっ……くちゅ、ぴちゅっ、んちゅう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0203120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「他の人に……こういうことは、しないように……れろっ……しなさい……ふ\nぅっ、ンっ……ちゅ、ちゅぶっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0203121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「胸が火照ってるとか、言われても……知らないわ……擦ってるから、それで\n熱くなってるんじゃないの……ふぅ、んっふぅう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0203122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「……嫉妬？　バカなこと言わないで……なんで、私が嫉妬なんか、しないと\nいけないの……こんな凶悪なチンポに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0203123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「余計な、こと……言ってないで……早く、出して……気持ちいいんでしょ？\n　我慢汁……どんどん出てきてるわよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0203124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「れろっ、んっぷ……ちゅく……わかってるわよ、だから……こうやって……\n舌で、舐め取ってあげてるでしょ……れろ、れぉっ……んぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0203125" ]},
		{"command":[ "SETIMAGE", "0", "still_00018302_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「おっぱいも動かしてる、わよ……注文が多い、わね……んっ、んふっ！　は\nぁ、はあっ、んはっ……くはぁ……んちゅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0203126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「あぁ、もうっ……舐めても、舐めても……キリがないわね……ちゅるっ……\nんぷ……ぴちゅうっ……はあ……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0203127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「簡単に言ってくれるけど、まずいのよ……これ……自分で舐めたことある？\n　あったら、こんなもの人に舐めさせようなんて思わないわよね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0203128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……ちゅぶっ……もっと、美味いもの？　ああ、そう……んちゅ\nっ……いいわよ……れろっ……出して……んんぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0203129" ]},
		{"command":[ "SETIMAGE", "0", "still_00018302_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「わかるわよ……しゃせぇ……しそうなんでしょ？　ザーメン……美味しくな\nんか、ないけど……ンっ、ちゅうっ……れろっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0203130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「あっ、あふっ……んぶっ、ちゅむっ……口で受け止める、から……んっんん\nっ……れろっ……ちゅく、ちゅくっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0203131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「……違うわよ。車のシート、汚れちゃうでしょ……だから仕方なくよ……じ\nゃなかったら、口の中でなんて……ん、んんっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0203132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「ちょ、ちょっと……そんなに押しつけないで……！　んっ！　んぐっ……！\n　ンっ、んむっ……むっうっ……んんんんん～～～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0203133" ]},
		{"command":[ "SETIMAGE", "0", "still_00018302_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「んぶっ！？　んっ、ンうううっ……！　うーっ……んっ、ンンっ……ぐっ、\nんぶぅっ……んふぅううう～～～～っ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0203134" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018302_01_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「ンっ……はっ、はあ……はぁっ……んぐっ……コクっ……んっんっ……まだ\n、出て……んっ！　ぐっ……ぶふっ、ぶっ……ンンぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0203135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「……はーっ！　はぁー、はっ、はあっ……とんでもない、量……出すわね…\n…ホント……んっ……けほっ……喉、絡みついて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0203136" ]},
		{"command":[ "SETIMAGE", "0", "still_00018302_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「苦くて、まずくて……最悪……んっ、んぐっ……しかも匂いはキツいし……\nあー、もう……うっ、ぷっ……はぁ、あぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0203137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「全部飲んだのに……匂いが上がってくる……生ぐさくて、ヒドい……これじ\nゃ私の息までザーメンくさくなっちゃうわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0203138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「これだけ出しておいて……まだ勃起してるなんて……若いにしても、元気よ\nすぎじゃない？　そんなに溜まってたの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0203139" ]},
		{"command":[ "SETIMAGE", "0", "still_00018302_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「色んな人に相手させてるくせに……それでも足りない？　もう猿じゃない…\n…でも、いいわ……このままじゃ車、運転できないだろうし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0203140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「喜んでなんか、ないわよ……勝手なことばっかり言って……私は早く終わら\nせて欲しいの……だから、これだけしてあげてるの……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0203201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「なに？　今度はしっかり咥えて欲しいの？　わかったわよ……そのかわり変\nに我慢しないで……さっさと済ませてちょうだいよ？　いいわね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0203202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「じゃあ……根本を、胸で挟んで……固定して……んっ……この、谷間から飛\nび出してる……そう、亀頭よ……これを……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0203203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「ん～、あっ……あむっ……んっむっ……じゅぽっ……じゅっ、じゅるるっ…\n…んふぅ……おっき……んぶっ、ん、んん、んふうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0203204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「ンっんん……んぶっ……ぷ、はぁ……なに？　上手くなってきた……？　誰\nかさんに……いつもさせられてるから、よ……んぢゅ、ぢゅぶぶっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0203205" ]},
		{"command":[ "SETIMAGE", "0", "still_00018302_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「はっ、んぷっ……ぬぷっ……ずっ、ずちゅっ……はぁ、んあっ……また苦い\n汁が……いっぱい、溢れてきてる……んぢゅ……じゅるる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0203206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「んふぅ……んっ、んンっ……こうやって、先っぽ……しゃぶりながら……胸\nで……擦られるのが……いい、んれしょ……んぶっ、ンンっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0203207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「……なに？　バストサイズ？　Iカップだって……言ってるでしょ……いち\nいち、言わせなくても……んっ……いい、でしょ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0203208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「そうよ、そのIカップの……爆乳を揺らして……夫以外の男の……チンポを\n……んふっ、んぶっ……咥え込んでるの、よ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0203209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「んんっ！　罪悪感は、あるに決まってるじゃない……あふっ……んぅっ……\nでも、今さら後悔しても……どうしようもない、から……んうっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0203210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「あなたと、する時は……もう夫のことは考えないようにしてるの……んっ、\nんぶっ……はむっ、んっ……ちゅうっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0203211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「ちゅぶ、ちゅっちゅっ……ンふっ……だから、あなたも……集中して……れ\nろっ、じゅぽじゅぽっ……んっ、ぢゅるるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0203212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「はあっ、あっ、はっ……！　またイキそうなんじゃないの……？　わかるわ\nよ……こんだけ、我慢汁出して……チンポもヒクついて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0203213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「いつも、しゃぶってるんだから……もう射精しそになってること、くらい…\n…んっぷ……じゅぷ……わかるわよ……ちゅ、ぢゅううっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0203214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「はぁっ、あっあふっ……む、胸も……おっぱいも強く、挟んで……ンぅっ、\nくっ……ふっ、んぶっ……！　じゅぶっ、じゅぶっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0203215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「は、あっ……あはっ！　出る？　もう出ちゃう？　じゅぶぶっ……じゅっぽ\nっ、じゅっぷっ！　出すなら……口に……んぶぶっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0203216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「ぢゅちゅ、ずぶっ……か、顔はダメ……！　ここどこだと思ってるの……ん\nんっ、んぶっ！　シャワーなんかないのよ……んぷ、ぢゅぶっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0203217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「はあっ！　はぁ、あっ！　あふっ……じゅっぷ……んぶっ！　髪にかかった\nりしたら、大変……なの……化粧もめちゃくちゃになるし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0203218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「んっ、んぐっ！？　待って……出るの？　出る？　んっ、んんっ……ダメっ\n！　ま、待って……ちゃんと口に……んぶっ！　んっ、んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0203219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「じゅるっ……！　んぶっ、じゅぽじゅぽっ……！　れろっ、んっ……ぐちゅ\nっ……じゅぷっ、んっんぶっ！　んんっ！？　んぶぅうぅぅっ！！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0203220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「んぐっ！？　んむっ……むっ、んんぅ！！　んん～、んふっ……んっんぐう\nううううぅぅぅぅぅぅ～～～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0203301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018302_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「……むぐっ、んぶぅっ！　んっ、んふっ……ふぐっ、ぐぅっ、うっぷ……ん\nっ……ちゅ、ちゅぶっ……うぅん……んん～！　んーっ！　んぐっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0203302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「はぐっ、んぶっ、ぶぶっ……んくっ……ごく、ごくっ！　はぁ、んっ……す\nごい……出て、るっ……んっ、んんっ、んんんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0203303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「んく、んっぷっ……ずっぷ……んぶっ……また、こんなに……ごくんっ……\nちょっとは遠慮ってものを……ぶふっ、ぐっ……んっくっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0203304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「あぁ、濃い……さっきより、味……濃くなってない？　どうしてこんなに出\nるのよ……二回目よ？　んぶっ……ぶっ……んぅぐっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0203305" ]},
		{"command":[ "SETIMAGE", "0", "still_00018302_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……はーっ、はっ、はあっ……い、息も、切れるわよ……自分\nでどんだけ出したかわかってないの？　げほっ……げほっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0203306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「あぁ……んんっ！　まだ喉に残ってる……なんなのよ、もうっ……うぇ、息\nがザーメンくさい……ホント最悪……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0203307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「こんなマズいものを、たっぷり飲ませて……悪い男ね……でも一番悪いのは\n……このチンポの言いなりになってる、私よね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0203308" ]},
		{"command":[ "SETIMAGE", "0", "still_00018302_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「わかってるわよ、そんなこと……でも、もうどうしようもないの……このチ\nンポを見ると、身体がどうしようもなく疼いちゃうから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0203309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「どうせまだ満足してないんでしょう？　二回も射精したのに……こんなに勃\n起させて……お互いすっきりするまで付き合ってあげるわよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0203310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「ダ、ダメっ！　んっ、ぷはっ……！　きゃっ！　ちょ、と……!！　んっ、\nんんんんぅぅぅぅ～～～～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0203401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018302_01_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「きゃあっ！　んっ……いやっ！　まって、ちょっと！　ねえっ……んぶっ！\n　んっ……ひうっ！　はっ……あぁぁぁっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0203402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「バカっ……顔にかけないでって、言ったのに……！　なんで抜いちゃうのよ\n……んっ！　髪まで……かかって……うぶっ！　うっ、うぷっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0203403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「あー、もおっ！　嬉しそうな顔してぇ……うっ、うぶっ……！　なんなの、\nこの量は……さっきも出したでしょ……んっ……ううっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0203404" ]},
		{"command":[ "SETIMAGE", "0", "still_00018302_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……はあっ……どれだけ、ぶっかければ気が済むのよ……結局、\n車のシートも汚れちゃったじゃないの……私、しらないわよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0203405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「うっ、はぁあ……これだけ、出せば満足でしょ……顔も胸も、あなたのザー\nメンでドロドロよ……どうしてくれるのよ、これぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0203406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「くっさいし……拭いても、匂い落ちなさそう……うう、シャワーないから、\nやめろって言ったのに……うぅぅ……くさぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0203407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「……怒ってるのかって？　そんなこと聞くくらいならやらないでよね。どう\nせ怒っても仕方ないでしょ……もう諦めてるわよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0203408" ]},
		{"command":[ "SETIMAGE", "0", "still_00018302_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「ちょ、ちょ……なにまたチンポ勃起させてるのよ？　こんなに出しておいて\n……まだヤリ足りないの？　あ、ちょっと……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0203409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イチカ" ]},
		{"command":[ "SETTEXT", "「わ、わかったわよ！　やるから……ご奉仕するから、チンポ押しつけないで\n……ちゃんと、してあげるから……んっ、ちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0203410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
