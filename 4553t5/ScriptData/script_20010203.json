{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0023" ]},
        {"command":[ "DISPIMAGE", "0", "TRUE" ] },
        {"command":[ "FADEOUT", "NORMAL" ]},
        {"command":[ "PLAYBGM", "BGM_002" ]},
        {"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、はぁ……。こ、今度こそ……どうだ？　参ったか！？　ハァ、 \nハァ……」", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "PLAYVOICE", "001_010021030027" ]},
        {"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
        {"command":[ "DISPCHARA", "0", "TRUE" ]},
        {"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「ああ、まいったまいった……。と言ってやりたいところだけど……。ねぇ？ \n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "033_010021030018" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「この程度、準備運動にもならないのが現実だな。おい……大丈夫か？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "049_010021030012" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「まさか、グレート・ルナリアムの姫ともあろうお方が……疲労困憊しておら \nれるのではないだろうな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "049_010021030013" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「何！？　わ、私は疲れてなどいない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010021030028" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「そうかいそうかい。滝のように汗をかいているようだけどねえ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "033_010021030019" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「うぐぅ！　それはその……武者震いからきた脂汗のようなもので……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010021030029" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「一流の武人だからこそ出る、聖なる汗というか……強者にしか出せないもの \nなんだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010021030030" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「言っていることが支離滅裂だぞ。……まあいいだろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "049_010021030014" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「所詮、若くて世間知らずの箱入り娘……。お嬢様、いえ。お嬢ちゃまのする \nことだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "049_010021030015" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「年上の私達が譲ってやるのが筋というものだろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "049_010021030016" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「そうだね。これだけ頑張っても、私ら『本物』には遠く及ばないなんざ…… \n。可愛いモンさ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "033_010021030020" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「これなら、一日中だって遊んであげられるよ。なあに、子守りをすればいい \nだけだからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "033_010021030021" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そ、そんな……。そこまで言うことはないだろう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010021030031" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「頭が悪いだとか、世間知らずだとか、お嬢ちゃまだとか子守りだとか……！ \n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010021030032" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「やっぱり……やっぱり私はあのにっくきアナザー・ルナテミスより劣ってい \nるのか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010021030033" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「このまま、何もかも奪われて……！　いずれはヤツが私の代わりに！？　う \nうう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010021030034" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「……はぁ。泣き言を言うんじゃないよ。アンタ、女王の心得って知ってるか \nい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "033_010021030022" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「女王の心得……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010021030035" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「上に立つ者全てに通ずる、重要な心得のことだ。つまり……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "049_010021030017" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「一つ！　女王たるもの、己の心に打ち克つべし！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "033_010021030023" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「一つ！　女王たるもの、決して屈してはならない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "049_010021030018" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「一つ！　女王たるもの、部下に弱音を見せるべからず！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "033_010021030024" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「一つ！　女王たるもの、白鳥のごとく、努力を人に悟られるべからず！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "049_010021030019" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「それが女王の心得なのか……！？　素晴らしい教えじゃないか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010021030036" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「も、もう一度教えてくれ！　今度はメモを取って……。と、な、なんだ！？ \n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010021030037" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
        {"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "いつの間にか、ルナテミスの背後に忍び寄っていたお七と冴島長官。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "ぎょっとしたルナテミスの両腕を掴み、二人は彼女の服を脱がそうとする。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
        {"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「な、なにをするー！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010021030038" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「女王の心得を習得するには、ルナテミス様は形から入られるのがよろしいか \nと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "049_010021030020" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「フッ……。しつこいくらいに食らいついてくる、姫さんのど根性に期待して \n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "033_010021030025" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「この衣装はあたしらからの贈り物だよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "033_010021030026" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「これは……！　こ、これはぁ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010021030039" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
        {"command":[ "WAITMOVE" ]},		
        {"command":[ "DISPIMAGE", "0", "FALSE" ] },
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "………………", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "…………", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "……", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
        {"command":[ "WAITMOVE" ]},		
        {"command":[ "SETIMAGE", "0", "sbg_0023" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
        {"command":[ "DISPIMAGE", "0", "TRUE" ] },
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「これは……女王の心得と関係ないだろう！？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "PLAYVOICE", "001_010021030040" ]},
		{"command":[ "SETCHARA", "0", "char_00000102_01", "9", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ある。大ありだ。それとも私達の言うことが信用できないのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "049_010021030021" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そうではないが……これはいわゆる……ＳＭ衣装……。ボ、ボンデージでは \n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010021030041" ]},
		{"command":[ "SETCHARA", "0", "char_00000102_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「カツマ……。いや、下僕を鞭打つのは嫌いではないが、他の者の前では…… \nちょっと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010021030042" ]},
		{"command":[ "SETCHARA", "0", "char_00000102_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ルナテミス様。羞恥心を克服したところにしか、真の女王の心得はありませ \nん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "049_010021030022" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「その恥ずかしい格好でも、普段通り振る舞えなければ女王にあらず」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "033_010021030027" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「これが、私らが姫さんに与えられる……とっておきの試練だよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "033_010021030028" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「恥ずかしい格好って言ってるじゃないかぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010021030043" ]},
		{"command":[ "SETCHARA", "0", "char_00000102_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「……で？　やるのかい？　やらねえのかい？　派手な花火ブチあげられねぇ \nってんなら残念だけどね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "033_010021030029" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「アンタはここまでの女さ。でも……やるんだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "033_010021030030" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「む、無論だ！　私は負けるわけにはいかない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010021030044" ]},
		{"command":[ "SETCHARA", "0", "char_00000102_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ならば剣を抜け！　相手になってやるぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "049_010021030023" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「こうなったら……この格好のままやるしかない！　ゆ……ゆゆゆ、ゆくぞ！ \n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010021030045" ]},
		{"command":[ "SETCHARA", "0", "char_00000102_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}