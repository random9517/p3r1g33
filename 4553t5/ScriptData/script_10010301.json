{
	"scriptCommands" :  [
        {"command":[ "FADEIN", "NORMAL" ]},
        {"command":[ "SETIMAGE", "0", "bg_0117" ]},
        {"command":[ "DISPIMAGE", "0", "true" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
        {"command":[ "PLAYBGM", "BGM_018" ]},
        {"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はい、ＥＤＯ――あ、はい！　その件ですね。ええ、大変申し訳ありません\n二度とそのような不始末を起こさないよう担当者にですね――」", "NORMAL" ]},
        {"command":[ "DISPTEXT", "TRUE" ]},
        {"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "秘書" ]},
		{"command":[ "SETTEXT", "「隊長。こちらの書類、ご確認お願いします」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「またかよ！　それはそっちに――あ、いえいえ！　こちらの話で！　とにか\nく、壊してしまったものに関しましては――」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「隊長。午後から面接の予約があると、ライオンの仮面をかぶった女性が見え\nていますが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "050_010103010001" ]},
        {"command":[ "SETCHARA", "0", "char_00005001_01", "0", "CENTER", "0" ]},
        {"command":[ "DISPCHARA", "0", "TRUE" ]},
        {"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「わかってるわかってる！　ちょっと待っててもらってくれ！　秘書さん！　\nお客さんにお茶出してあげて！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
        {"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETNAME", "秘書" ]},
		{"command":[ "SETTEXT", "「承知いたしました。書類もよろしく」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「わかってる、わかってるって――あ、いえいえ、すみません。とにかく、そ\nれはそのように……はい、失礼いたします、はい……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
        {"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "ふぅ……なんで隊長の俺がクレーム対応なんか……って、愚痴ってる場合じゃ\nねえな。面接だ面接。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「隊長さ～ん？　ちょっとテレビのリモコン取って～。あと、そこのポテチも\n～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "099_010103010001" ]},
        {"command":[ "SETCHARA", "0", "char_00009901_01", "8", "CENTER", "0" ]},
        {"command":[ "DISPNAME", "TRUE" ]},
        {"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああ？　ほらよ……っていうかテレビばっか観てねえで、なんか仕事しろ！\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「そんなことより大丈夫～？　面接の人、待ってるんじゃな～い？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "099_010103010002" ]},
		{"command":[ "SETCHARA", "0", "char_00009901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あああ、そうだった！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「カツマ、大丈夫？　よければ面接は私が……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "002_010103010001" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そ、そうか？　それじゃ……ん？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "いや……待てよ？　極端に無口なカグヤが面接って……？", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "それ、無理があるんじゃねえのか！？", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あー……いや、いいや。やっぱり俺がいく。ありがとな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「カツマがそういうなら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "002_010103010002" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「おい、隊長。わかってんだろうねえ？　明日は大使館に、防災設備の点検が\n入る日だよ。業者が来るよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "003_010103010001" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「わかってます、わかってますって！　点検をちゃんとすませて、なおかつヤ\nバいものは見られないように、でしょ！　ちゃんとやります！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "ってことは、明日は大使館に回ってからＥＤＯ本部に出勤だな。\nそれから、えーと……。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "はぁ……さすがに厳しいなあ。そろそろ大使館の警備員のほうは、別のヤツに\n代わってもらえねえかな……ピースムーンの誰かでもいいだろうに……。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「疲れた……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人、面接は」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "009_010103010001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「わかってるよ！　行きゃいいんだろ、行きゃ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「大変だねぇ、隊長さんは」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010103010001" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うるせえ！　ソファにでーん！　と座ってひとごとみたいに言ってんじゃね\nえ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "ああ、もう、ホントに……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
        {"command":[ "WAITMOVE" ]},		
        {"command":[ "DISPIMAGE", "0", "FALSE" ] },
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETTEXT", "………………", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "…………", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "……", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
        {"command":[ "SETIMAGE", "0", "bg_0117" ]},
        {"command":[ "DISPIMAGE", "0", "true" ] },
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「えーと、今の人はとりあえず合格でいいな。今はとにかく人手が欲しいし…\n…」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「おい、下僕」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010103010001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
        {"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あー！　今度はなんすか姫様！　悪いんですけど、もうちょっと待って――\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「違う！　用事をいいつけるわけではない。ただ、その……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010103010002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「私たちは、お前が心配なだけだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_090103010001" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……は？　今、なんて？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "なんだ？　疲れてるせいか、一瞬理解が追い付かなかった。今『心配』って言\nったのか？", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "いや、それはないよな。あのルナテミスがな。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「なっ！　ち、違うっ！　わ、私は別に貴様のことを心配しているわけでは―\n―」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "001_010103010003" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「……私は心配」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "002_010103010003" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「え……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「カツマは働きすぎ。このままじゃ、カツマの体がもたない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "002_010103010004" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「そうなったら、私……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "002_010103010005" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "そ、そうか。カグヤは、俺を心配してくれているのか……。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "……って、待てよ？　それじゃさっき、アナザーは本当に『心配』って言った\nのか？", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "いや、確かに、アナザーならありうるな。こっちの世界のルナテミスと違って\n、人の心を持ってるっぽいしな。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「さ、さっきも言った通り、別に私は、お前を心配しているわけではないぞ！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010103010004" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "ええ、ええ、そうでしょうよアナタは。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ただな、このままお前一人で細かい仕事を抱え込んでいては、隊長としての\n業務がおろそかになる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010103010005" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そうなれば、インクレディブル・スクワッドの戦力はガタ落ちだ！　私は、\nそのことを心配しているのだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010103010006" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「だからだな、下僕……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010103010007" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「………………………………」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「……下僕？　聞いているのか、下僕。おい！？　下僕！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010103010008" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「カツマ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "002_010103010006" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「…………はっ！？　ね、寝てませんよ！？　大丈夫ちゃんと仕事してます！\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ば、バカモノーーーーっ！　人が話をしている時に、何を居眠りしているーっ\n！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010103010009" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「す、す、す、すみません！　いつの間にか意識がふっと……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "だって、話長ぇんだもん！", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「……やはり、相当疲れているようだな。カツマ。お前はもう少し周りを頼っ\nて、他の者に仕事を任せたほうがいい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_090103010002" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「他の者にねえ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "仕事を振ったら代わってくれるようなヤツがいれば、苦労しねえんだって……\n。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「さっきも私、そう言ったのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "002_010103010007" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "さっきのなし。仕事を代わってくれるヤツはいる。いるんだけど……。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「…………」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "そういうヤツに限って、向いてない仕事が多すぎるんだよなあ……カグヤに新\n人の面接とか、絶対無理だし……。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「カ、カツマ……そんなにじっと見ないで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "002_010103010008" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「え！？　あ、いや！　そういうわけじゃ――」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「こら下僕！　なにをこんなときにそんな不真面目な――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010103010010" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「っ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010103010011" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「緊急出動か！？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "7", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "001_090103010003" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETNAME", "秘書" ]},
		{"command":[ "SETTEXT", "「隊長。司令より出動命令です。『採石場に襲来者（インベーダー）が出現、\nただちに迎撃せよ』とのことです」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「やれやれ、この忙しいのに……しょうがねえ！　今すぐ出られるのは！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "SETTEXT", "「当然、我々グレート・ルナリアムは行ける」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_090103010004" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
