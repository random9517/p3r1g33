{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0116" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_019" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ふーん……とにかく、あいつは向こうの世界でのお尋ね者で、あんたはそれ\nを追ってきたと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020021290013" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はい。あんな姿をしてはいますが、その本性は凶悪で、危険な存在です……\n野放しには出来ません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021290016" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「そう言えば、あんた……カツマと接触した時に、ちょっと変な感じになって\nたよな？　あれは何だったんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020021290014" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あ……あれは、その……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021290017" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「言いにくいことなのか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020021290015" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「い、いえ……実は私達の世界には、ある伝承がありまして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021290018" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「伝承？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020021290016" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はい。『世界を統べる力の持ち主』と触れ合うことで契約が果たされると、\nその者と私達の間に主従関係が結ばれるのです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021290019" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「うん。それで？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020021290017" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「つまり……どうやらカツマ殿は、私達の世界を統べる力の持ち主だったよう\nで……あの方は、私の主ということになりました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021290020" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「はぁ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020021290018" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「まさか異国の地に飛んで、このような運命的な出会いを果たすなど……しか\nし、だからこそ今は危険な状態です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021290021" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「何としても我が主殿を取り戻し、しっかりとお守りしなくてはなりません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021290022" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「あいつ……マジで訳あり女が寄ってくるよな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020021290019" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「異世界なろう系ではなく、現実なってる系でございますな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021290004" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「主どのが心配です。どこに連れ去られたのか……アルマに誑かされているの\nではないか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021290023" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「転移の影響で、体調が万全でなかったことが悔やまれます……私の失態です\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021290024" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「まぁ、そう落ち込むなって。とにかく話は分かった。カツマを探さなきゃな\n。あたし達も協力するから、一緒に行動しよう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020021290020" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「それは心強いですが……よろしいのですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021290025" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「なーに、いいってことよ。困った時はお互い様だしな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020021290021" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「ほむら殿……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021290026" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「して、ほむら殿。一体、どのようにしてご主人を探すのですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021290005" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ん？　そんなもん、下っ端を片っ端からぶちのめしていきゃボスに辿り着く\nだろ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020021290022" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「……もしかして、それが作戦ですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021290006" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「おうよ、これ以上分かりやすい完璧な作戦はねーだろ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020021290023" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「いや、それは幾らなんでも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021290007" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「おお、そんな方法があるとは！　なんと素晴らしい作戦だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021290027" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「えっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021290008" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「おう、気が合うじゃねぇか！　何ていうか、あんたとは他人のような気がし\nねぇんだよな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020021290024" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「ほむら殿も、そう思いますか！　その、私も僭越ながら同じことを思ってお\nりました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021290028" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「仲良くやっていけそうじゃねぇか、これからもよろしく頼むぜ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020021290025" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はい。先程の見事な腕前、私も感服しておりました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021290029" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ははっ、そんなでもないって。よぅし、そうと決まれば早速、適当なザコを\n見つけて突っ込んで行くぜ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020021290026" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「承知しました！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021290030" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「やれやれ……まさかの脳筋がお二人になるとは……ご主人、骨は拾いますぞ\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021290009" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}