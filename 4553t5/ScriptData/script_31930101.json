{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「遅れてしまってすみません……。昨日投稿した写真が、１０万ヒットしそう\nだったので……目が離せなくて……。あ、隊長っぴも見ますです？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0103101" ]},
	{"command":[ "SETCHARA", "0", "char_00019301_01", "6", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPTEXT", "TRUE" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「今までで最高の伸び率なのです！　これは、明日には２０万いくかもしれま\nせん。１秒ごとに、更新ボタンを押す手が止められな……。……はい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0103102" ]},
	{"command":[ "SETCHARA", "0", "char_00019301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「ちょっとでいいから携帯を閉じろ？　そ、そのへんに置け？　……な、なん\nと！　それは、それは……あの……。……ええ！？　本気ですか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0103103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「むぐぅ……。隊長命令とまで言われては……仕方ない、ですね。それで、ご\n用はなんですか？　リリア、気が気じゃないので早く帰りたいのですが！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0103104" ]},
	{"command":[ "SETCHARA", "0", "char_00019301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「……戦力増強のための秘密特訓？　……軍事機密です！？　こいつはどでか\nいスクープです！？　あの、ペコスタにアップしていいですか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0103105" ]},
	{"command":[ "SETCHARA", "0", "char_00019301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「そしたら５０万バズも夢じゃな……、って、はい。ダメですよね……。え？\n　『うｐれるものならうｐってもいい』？　じゃ、じゃあやります！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0103106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「携帯の録画機能をオンにして……。いいですよ！　さ、次は何をすればバズ\nるです！？　バズるなら、リリアなんでもしちゃいま……。きゃああ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0103107" ]},
	{"command":[ "SETCHARA", "0", "char_00019301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「おっぱい！？　急におっぱい丸出しにさせられて！　んわぁあっ！？　チン\nポっ！　突然チンポをねじこまれたです！？　ちょ、ま、１８、１８禁！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0103108" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00019301_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「これじゃあネットにうｐできないです！？　あっ……！　ん、んぁあ……！\n　お宝動画って……そういう！　あ……あ……、チンポ、チンポ、とか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「裏垢でしか見たことないのに……。リアル世界で見せつけられてます。ふ、\nぅ……っ。リ、リアルチンポ、……か、解像度が高くて……うう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「なんかムニっとしてて……。嗅いだことない臭いまでします！　わ……うわ\nわ……。そっか。ネットじゃないから、温度や硬さまで……！　んん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0103111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「た……隊長っぴ……。アカウントＢＡＮ不可避な衝撃映像、ヤバいです……\n！　『そのまま胸でしごけ』？　え、エロ動画じゃないですか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「確かにキレイな海岸とか、オシャレカフェの新作パフェよりバズるの確定で\nすけど……リリア、そっち方面はやってなくて……。って、んー……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「リアルチンポ、暴れすぎではないですかぁ……！？　ピクピクって今、動き\nました！　ふぁ！？　た、隊長っぴが動かしてるです！？　し、神秘！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「女体の神秘ならぬ、男根の神秘……！　うぁあ、し、下ネタもネットでは禁\n止です！　なのに……なのに、なんで、でしょう……止められない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0103115" ]},
		{"command":[ "SETIMAGE", "0", "still_00019301_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「リアルチンポをおっぱいにねじこまれて……。プルプルされて、びっくりな\nのに逃げる気がしません。……これ、いじってもいいんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0103116" ]},
		{"command":[ "SETIMAGE", "0", "still_00019301_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「……わぁ……。すっごい色……。赤黒くて……先っちょと根元で色が違いま\nす。それに、結構太い……。硬さも、情報よりも数段上です……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0103117" ]},
		{"command":[ "SETIMAGE", "0", "still_00019301_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「これが本物のチンポなんですね。弾力があって、胸でプニ、プニって押した\nらムニって戻ってきます。変な感触……。硬いのに柔らかくて……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「あっ……！　ちょっとシゴいたら……。胸でこすったら、またピクピク……\n！　あ……あ……、これがモザイクの向こう側……無修正チンポ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「リリアが何かするとすぐ反応するの、面白い……。もっと、もっとしてみた\nいです！　ん……しょ、んんっ……！　んっ……んん……んん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「『もっと上下左右に』？　っは、はい……。んしょ……ん、こうですか……\n？　『緩急をつけて』？　つ、強く、弱く……弱く、強く……ふンン♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「あっ！　そ、そっか……！　リアルだと、おっぱいをなすりつけたら……リ\nリアも胸で感じちゃうんですね！？　そんなの想像したことなかったです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「ん、ぁ、は……ッ、はぁっ……ああ、あぁあっ……！　お胸でするエッチ…\n…！　チンポが喜んで……リリアのおっぱいも気持ち、よくて♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「一石二鳥……です、一挙両得……。ウ、ウィンウィンの関係……。んぁっ…\n…♪　なるほど、だ、だからみんなやるですね。んぅ、んんん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「ッぁ……♪　前後左右するた、び♪　チンポが胸の柔らかいところをこすっ\nて……、んっ♪　と、とろけそうな快感が……おっぱいに……んぁんん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「乳首、も……ピリピリ痺れるみたいに感じてます……！　あっ……！　た、\n隊長っぴも感じますか？　おんなじくらい……あっ！　ひゅ、ひゅごい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0103126" ]},
		{"command":[ "SETIMAGE", "0", "still_00019301_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「おっぱいでチンポごしごし♪　ごしごししながら交差させると……。んーー\n♪　たまらない快感が、あっ♪　おっぱい全体に広がって……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0103127" ]},
		{"command":[ "SETIMAGE", "0", "still_00019301_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「おっぱい、おっぱいのお肉が溶けちゃいそう……。わ、わかりますよね？　\nおチンポ敏感そうですし……私のお胸がやーらかくなってくの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「隊長っぴのおチンポと、めちゃくちゃ仲良しになってるの……感じますか？\n　あっ♪　あっ♪　リリアは感じます♪　リリアのおっぱい、おっぱいぃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「隊長っぴのチンポがお気に入り……みたい……。あっ♪　み、見てください\n……。おチンポぐにゅぐにゅ挟んで揉んで、いると……んふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「いいね連打されてるみたい、に♪　おっぱい全体がブルブル震える……です\n♪　あっ、あっ、これ……いいっ、好きっ、好きな感じっ、すごくいいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「んー、ふぅうっ……♪　ふぅう……！　ち、乳首を巻きこみながら……勢い\nよくチンポの上を駆けのぼるです、それからすぐに引きずりおろし、て♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「激しくシェイクしまくりながら……あふ♪　たっぷんたっぷん駄肉を上下に\n弾ませていると……、あぁ♪　あ、あ、あ、意識が飛びそうなくらい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「ビクビクゥ、ビクビクゥって！　電気が走るみたいに気持ち、よくて……！\nん、……これハマります、ハマ……るぅ……。いっぱいしたい、止めたくない♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「んひ……♪　ひ、ぅ♪　あふっ♪　あっぁっ♪　あっ、んっ♪　んっんっ…\n…！　なんか似てます、バズってる時と同じです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0103135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「どんどん、どんどん、気持ちいいのメーターがあがっていって……ぇ♪　も\nう、自分じゃどうしようもないくらい拡散され、て♪　イッちゃうです♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0103136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「快感♪　快感が炸裂してぇ……♪　おチンポ包みながら、無限におっぱいで\nバズっちゃいます♪　んぁふっ！　トップニュースになっちゃう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0103137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「気持ち良すぎて……！　明日のニューストピックに取り上げられちゃいそう\nです……！　ト、トレンドのっちゃう、掲載されちゃいます……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「あっ♪　あぁっ……あ！　あっ……！　ズッ♪　ズッ♪　ってチンポ♪　チ\nンポでエッチなマッサージしてるだけなのに……ああああ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「もう我慢できないです、リリアっ……おっぱいでイッちゃいますっ……あっ\n♪　おっぱいバズっちゃうっ、気持ちいいの、広がっちゃう……っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0103140" ]},
		{"command":[ "SETIMAGE", "0", "still_00019301_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「あーっ！　あーっあーっ……！　ビクビクぅうっ！　おっぱいっ、乳首ビク\nビクぅって……！　あぁっ……！　あっ……あっ……！　……ん！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0103201" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019301_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「あ、あれっ！？　た、隊長っぴ……！？　いつのまにかおチンポが一回り大\nきくなって……？　あッ！？　な、何か飛び出してきましたぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「あっんんっ！　んんんっ！？　白いのが……あっ♪　リリアのおっぱいの中\nに……！　く、くさぁい……！　それに、勢い強すぎて……あっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0103203" ]},
		{"command":[ "SETIMAGE", "0", "still_00019301_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「んぅうううー……！？　んぅー……！？　だ、出し過ぎです……！　リリア\nが刺激しすぎたからですか！？　『いつもこれくらい出る』……え！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0103204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「なんですか、そのチンポ大明神みたいな絶倫勢力……！　エッチ動画でも見\nたことない量です、それがしつこくビュルビュル、ビュルビュル……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「あぁああ……！　尋常じゃありませんん……！　む、胸の表面全部、臭いお\n汁まみれにされちゃいましたぁ……！」　", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「うわ、……見てください！　プルンッ、プルンッて……。え？　え？　精液\nってこんなに飲むゼリーみたいになるんですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0103207" ]},
		{"command":[ "SETIMAGE", "0", "still_00019301_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「あったかいあんかけのトロみみたいで……。はぁああ……♪　驚愕です、脱\n帽です……。ただ……やっぱり臭いのは臭いです、んー……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「鼻が曲がりそう……。濃いのがいっぱい出るとこうなる、ですか？　あ……\nじゃあ気持ち良かったから臭いんです？　それなら……仕方ないですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「り、リップサービスだとはわかっていますけど……。リリアも気持ち良かっ\nたので……。サービスでもう一回してあげるです……。……ん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0103210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「あは……♪　ねっちゃねっちゃします……。あっ……！　さっきより、エッ\nチい感じ……。隊長っぴの白いローションで胸がネバネバして……あぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0103211" ]},
		{"command":[ "SETIMAGE", "0", "still_00019301_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「や、は……あっ、あはっ……！　泥んこ遊びしてるみたい、です♪　やりが\nいありすぎて……楽しい♪　楽しいです、それに気持ちいい……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「ふぁああ……♪　リリア、胸でするの好きかもです……。人のを見てる時、\nは、つまらなさそうって思ってました、でも……でもしてみると♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「五感全部が刺激されて……エッチぃ気分です、あ……う、あぁ……！　おっ\nぱいなんて無料でついてるただのパーツ、なのに……んあああ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0103214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「隊長っぴのチンポを挟んで動かす、だけで♪　こんなにゾクゾク出来るんで\nす……！　あっ、あっ、無料で、いつまでも遊べちゃうんです……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0103215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「すごい、すごい、すご……いぃ♪　お得、ですし……んーっ♪　楽しい、で\nす……！　んあああっ、ああ、ああ……隊長っぴ……隊長っぴ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0103216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「リリアのおっぱい、最高ですか？　最強、ですか……ぁ？　あふ……！　お\nっきいだけで邪魔だったおっぱい♪　今は感謝です、あぁ、イイ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「そうです、おっきなおっぱいはエッチに使うと気持ちいいのです……！　っ\nんんーっ……！　ずにゅずにゅ、ずにゅっずにゅっ……むにゅぅうう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0103218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「おっぱいは、チンポを気持ち良くできて♪　チンポに気持ち良くしてもらえ\nる最高の遊び道具なのです……ぅう♪　あっ♪　あっ、あっあ……あぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「隊長っぴ……リリアまた胸でトびそう……っ、隊長っぴもトんで？　もう一\n回、リリアの胸で感じて？　出して、出して……ぇ、欲しいです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「んふー……♪　キたです、キたですぅう……♪　おっぱいの上に重ね塗り、\n真っ白なペンキぶちまけて……ドピュドピュですぅうう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0103301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019301_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「んぁーっ……あぁっ♪　また臭い……！　あぁ！　臭いのが飛び出すってこ\nとは、気持ちいいってこと……。リリアしっかり記憶しました！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「いいですよ……。出せるだけ出しちゃってください……。リリアのお胸は巨\n大ですので、どれだけ出してもこぼれちゃったりしないのです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0103303" ]},
		{"command":[ "SETIMAGE", "0", "still_00019301_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「……ん♪　んふ……ふふふ……♪　はぁ、はぁっ……♪　全部出たですか？\n　ありがとです……。隊長っぴがおっぱい星人で助かりました……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0103304" ]},
		{"command":[ "SETIMAGE", "0", "still_00019301_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「だって、初めてでテクニックもなければ、自分ばっかり気持ち良くなっちゃ\nってたリリアのおっぱいを、こんなに満喫してくれたのです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0103305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「おっぱいが大好きで大好きで愛してるのですね……♪　ふふふ……。気づい\nてましたよ、戦闘中も、待機中も……おっぱいジロジロ見てたこと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0103306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「隙あらば触ってやろう、揉みしだいてやろうって思ってたですよねぇ……？\n　いえ、別に嫌じゃないですよ。ただ……その……良かったなぁって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0103307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「リリア、リアルに自信がないので……。いつもネットでうさばらししてまし\nた。だけど……自分の長所が一つわかった気がするです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0103308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「はい。このおっぱい。夢と希望が詰まってたゆんたゆんの大きなおっぱいを\n、隊長っぴは『お気に入り』してくれたわけですし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「ちょっとリアルの自分のこと、好きになれました。だから、パワーアップし\nた……かもしれません。胸で臭い汁を絞る技能を手に入れたのです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「んふぁああっ！？　にゅるんって……にゅるんって、ウナギみたいにおチン\nポ抜かれて……！　あっ……あっああああっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0103401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019301_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「今度は胸じゃなくて……顔なのです！？　あっ……臭い……！　臭いのが、\nあっ……！　スコールみたいに顔に、顔に……ぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「んんん……！　なんでこんなことするんですか……っ？　せ、征服欲……！\n　ぁ……リリア、隊長っぴに今征服されちゃっているです……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0103403" ]},
		{"command":[ "SETIMAGE", "0", "still_00019301_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「あっ……あっ、ドプドプ出てる……。ダラダラ顔中に真っ白な臭い液垂れ流\nされて……。ぷぁ、とんでもないショッキング映像に……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0103404" ]},
		{"command":[ "SETIMAGE", "0", "still_00019301_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「絶対絶対放送禁止です……っ。というか、……んぷ……！　こんなのどこに\nもアップできないですっ……。顔にかけられてしまうなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0103405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「はぁっ……はぁ、はぁああ……。いやです……ぅ、ヌルヌルして……。それ\nに、胸に出された時よりずっと臭いがキツくって……。けほっ、けほっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0103406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「『俺の色に染めた』……？　そ、そういう考えも一理ありますけど……！　\n夢に見そうなくらい、本当に強烈です、このスメル……。こほっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0103407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「うううー……。これのどこが秘密訓練なのですー……。『精液は美容にいい\n』？　あっ、いいです！　リリアの顔に塗りたくるのはやめるのです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0103408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「お、落ちなくなっちゃったらどうするんですか……！　上質なタンパク質だ\nから？　……タンパク以前に超くっさいんですうううっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0103409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「『いずれ好きになる』？　……これをですか？　リリアはＡＶ女優ではなく\n、インフルエンサーなので！　そんな特殊能力は必要ありませんー！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0103410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}