{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0081" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「隊長！　任務おつかれさん。そろそろ交代らしいぜ？　ほらよ、差し入れに\nねぎらいのビール。俺のおごりだ、一杯やってくれ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0404101" ]},
		{"command":[ "SETCHARA", "0", "char_00003404_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「休憩中に海には行くのか？　ふぅーん……だったらさ。日焼けオイル塗って\nやるよ。あぁ？　日焼け止め？　そんな軟弱なものはいらねぇ、それっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0404102" ]},
		{"command":[ "SETCHARA", "0", "char_00003404_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「俺がたっぷりエキスを塗って……って、うぁあっ！　な、なんだよっ！　は\nぁ！？　お前が俺に塗る！？　な、なんで……いいけどよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0404103" ]},
		{"command":[ "SETCHARA", "0", "char_00003404_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「つぅかいきなり水着ズラしたり、手が早すぎるだろっ……！　そ、そんなに\n塗りたかったのか？　……俺が身体を持て余して見えた？　バッ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0404104" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00003404_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「バカ、やろぉ……！　違うとは言わねぇけどよ、ホンットムードってやつが\nねぇな！　誘うんだったらもっと……あんだろ、コラ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0404105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「んっ……！　はいはい……。隊長は俺のオッパイに夢中で話は聞いてません\nってか……。うっ♪　も、揉むのも許可なしでやりやがるしよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0404106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁ、任務中に相当溜まってたみたい、だな……。はぁっ……。う\nう、クソぉ……。妙に上手い前戯しやがって……この……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0404107" ]},
		{"command":[ "SETIMAGE", "0", "still_00003404_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「なぁっ……オイル塗りたいとか……。あっ♪　ぶっちゃけ建前だろ？　その\n……なんつぅか……。んっ、もっとしたいことがあんじゃ、ねぇの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0404108" ]},
		{"command":[ "SETIMAGE", "0", "still_00003404_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「はぁっ♪　ネチャネチャした指で俺の胸……いじくりまわしてるってことは\nさ……ヤりたいんだろ？　そうだよな、……んんっ、な、ぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0404109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「セックス……したいんだよな？　……ぅっ！　こぉらっ、乳首をクリクリす\nるな……！　オイルで敏感になってんだよっ……って、おい……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0404110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「こ、答えてくれよ。シたいんだよな？　俺と……。じ、焦らして胸ばっかイ\nジんな……！　欲求不満になるだろうがっ！　……あっ、ぁっ、うう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0404111" ]},
		{"command":[ "SETIMAGE", "0", "still_00003404_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「俺からねだれってのか……？　じょ、上等だ……。い、言うわけねぇだろ、\n俺からなんて……。いっくら胸をいじろうが、股間にチンポが当たろうが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0404112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「……って、いつのまに勃起してやがんだよ！　おいっ……これ、は……卑怯\nだろ……！　あ、あぁ、わかったよ、わかったからもう焦らすな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0404113" ]},
		{"command":[ "SETIMAGE", "0", "still_00003404_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「し、たい……！　俺が、お前としたい！　やりたいっ……その硬くなったヤ\nツ、チンポ……入れたい！　わかるだろ、こっちも濡れてんだっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0404114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「なあ……いいだろ？　俺とお前の仲じゃねえか。い、入れようぜ……。絶対\n気持ち良くしてやっから……。ん、もう我慢できねぇっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0404115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「あぁああっ……♪　ど、どうだ、勝手に入れてやったぞ……。あッ、あぁ…\n…デケぇ……！　はぁっ、お、お前もヤる気満々じゃねえか……ぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0404116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「なんで意地悪してきたんだよっ……んぉっ♪　すっげぇっ、すっげぇ……！\n　奥までミッチリ詰まって……ああっ、本気モードじゃねえかっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0404117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「うっ♪　ぁっ、あっあぁっ♪　中、拡がってやべぇ……っ！　なあ、なあ、\n動いてくれよ……俺もケツ振るから……！　なぁ、苛めるなって！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0404118" ]},
		{"command":[ "SETIMAGE", "0", "still_00003404_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「お、俺にＭっ気があるとかそういうのは黙ってろっ……！　この、腹ん中の\nスンゲェやつでめちゃくちゃに突かれたい、掻き回されたい……ぃっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0404119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「……んっ！　ああっ！　あっ、あぁッ！　んぁあああっ！　そうだっ、そう\nやって……あっ！　胸揉みながら、握りつぶすくらい強くいじめながら！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0404120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「腰っ、振ってくれ、チンポで俺のマンコを持ち上げて、限界までズコバコズ\nコバコハメまくってくれぇっ！　あーーーっ、あっあっあっすげぇぇっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0404121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「こ、こんなの即イキ不可避だろっ……！　んぁああっ、イクッ♪　んぉっ、\nおぉおっ♪　やっべ……ああっ、やっばい、全身おかしく、なるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0404122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「んぁおぉおおっ！　ぁっ……す、すまねぇ……！　興奮しすぎて腰浮かせち\nまったぁ……抜けたら一大事、だぜ……ホント……。んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0404123" ]},
		{"command":[ "SETIMAGE", "0", "still_00003404_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「これでずっぷりハマったよ、な……。あぁっ……！　ヤればヤるほど馴染ん\nでくる気がすんなっ……隊長のデカマラ……あっ♪　あっぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0404124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「中のさぁ、柔らかいとこ……ゴリュゴリュひっかいてくんだよ、カリがぁ…\n…っ！　あっ、はぁっ、それがマジでよくて……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0404125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「入口と奥とか同時に拡げられるっつぅの……っ！？　はぁっ！　ズブズブピ\nストンされてっと……くふぅっ、何か所もイイとこ当たってヤバイって！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0404126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「あ～～～、あぁっ、あぁ、あぁ～～～っ……♪　んだこれっ、頭ヘンになる\n……！　じゅっぽじゅっぽ水音たってっし、感じてるのモロバレでっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0404127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「恥ずかしいのに止める気に、なんねぇよ♪　隊長……隊長、わかるかぁ？　\n俺のアソコ、マンコがめちゃくちゃ喜んでんの……んぁぉおおお♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0404128" ]},
		{"command":[ "SETIMAGE", "0", "still_00003404_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「俺っ……見ての通り丈夫だからさっ！　もっとガンガン突き上げて平気だか\nら……！　だから力の限界まで、チンポ突っ込んでほしいんだっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0404129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「……ッああああああっ♪　それっ、それくらい強く……っ！　あっ♪　壊れ\nねぇから激しくっ、キツくしてくれぇ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0404130" ]},
		{"command":[ "SETIMAGE", "0", "still_00003404_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「っんううううっ♪　うううぅうああっ♪　チンポッ、チンポ……ああああっ\n♪　最高だぁ、隊長のチンポ、デカくて太くて……奥に当たるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0404131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「奥っ、ほじられまくってもうっ……！　どうにでもしてくれよっ、あっ、あ\nっ……マジで股間が大洪水になっちまった、びちゃびちゃだ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0404132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「隊長っ、隊長……！　隊長もちゃんと良くなれてっか？　……一度出したい\n？　ははっ、何度でもかまやしねぇよ。好きな時に出しなっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0404133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「いいぜっ、受け止めてやる……！　いいやっ、受け止めたいんだ俺がっ……\n！　俺の子宮がもう待てねぇって叫んでる……だから、注いでくれっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0404134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「隊長のっ……生のザーメンでマンコん中タップタプにしてくれよなぁぁ♪　\nあっ……こうか？　こうやって搾るとイケそうか？　ああ、出しな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0404135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「んぉおおおおっおおぉ～～～♪　出た出たっ……！　あっついのが飛び出し\nてきたぁああ♪　あっ♪　おっ♪　ブチュブチュに濃いザーメンっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0404136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003404_02_05" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「俺の大好物……！　ッあぁああああっ、もっと、もっとだ！　搾り上げてや\nる……！　んっぅううううう……！　どぴゅどぴゅ音がするぜ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0404137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「俺の中でチンポが大暴れしてやがる……！　あっ！　そこ、そこだ！　奥…\n…子宮を狙って撃てっ、撃てぇえ♪　ぉおおおっ♪　クるぅうっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0404138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「あ～～～～～♪　こっちも無理やり、強制的に絶頂食らっちまうぅううう♪\n　イクぅっ、イクイクッ……♪　隊長の生射精でイクッ、イクぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0404139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「中出しっ……やっぱ中出しが一番気持ちイイぜぇええっ♪　隊長っ、ありっ\nたけもらうぜっ……全部、全部俺のもんだぁああああ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0404140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「んっぷっ……♪　ちょ、ちょっと欲張りすぎたかぁ……？　お前もお前だ、\nしょっぱなからこんなドッパドパ出してたら身体壊すぞ……ぉ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0404201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「……とか言ってみたものの……。さっすが隊長。心配の必要はなかったみた\nいだな……♪　あんだけ出して即復活とか、カッコ良すぎるだろ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0404202" ]},
		{"command":[ "SETIMAGE", "0", "still_00003404_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「俺の締めつけがキツくて良かった？　……ふーん……。それって、隊長のが\nデカいからそう感じるだけじゃねえの？　って、締めてたか、俺も」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0404203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「……ああいうのって制御できねぇから、自然にそうなっちまうんだよ。か、\n感じたりすっと……チンポに媚びてすがりついちまうっていうか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0404204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「イッたりするとうねるらしいしな。その力が強いのかもしんねぇ……。って\n、無駄話してる場合かよ。なぁ？　『１回出す』っつったよな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0404205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「てことは、次があるってこと……だよなぁ？　まさかこのまま抜いて終わり\nじゃねぇだろぉ？　抜かずの二発目……期待していいよな？　なぁ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0404206" ]},
		{"command":[ "SETIMAGE", "0", "still_00003404_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ほらっ……♪　隊長のザーメンでタップタプのマンコでさぁ……ぐりぐり腰\nを回すと、さっきとは違う感覚になんだろ？　あっ……痺れるだろ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0404207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「今度は俺の胸がバルンバルン弾んでるのも見ながら、じっくり楽しめよ……\n。んっ……動くぜ。隊長も、俺に抵抗してどんどん腰突き上げなっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0404208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「は、ぁっ、はぁっ、ああああっ、ああ……！　や、やるじゃねぇか……っ♪\n　んぉっ♪　連続でクリティカルヒット出してきやがるぅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0404209" ]},
		{"command":[ "SETIMAGE", "0", "still_00003404_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「さすが、だぜ隊長♪　もう隊長を……隊長のチンポ知っちまったら他のこと\nなんか考えらんねぇ♪　それくらいイイぜ……っ、あっ、うぁぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0404210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「俺も限界超えて締めつけっから……ギュウッてな♪　……くぅっ……♪　ど\n、どうだ……っ？　あ、うっ♪　万力みたいにギチギチに締めたとこっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0404211" ]},
		{"command":[ "SETIMAGE", "0", "still_00003404_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ガンガン掘られるの腰にくるぜぇっ……♪　んぁああっ、どんだけ強靭なチ\nンポなんだよっ、あっ、俺のマンコより強いとか……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0404212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「あっ♪　気ぃ抜いたら気絶、しちまいそ……♪　隊長の、ゴツくてっ……す\nぐ奥に届くから……アッ♪　長くて硬くて最強だよなっ……あぁあっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0404213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「うっ♪　はぁっ、はぁっ、はぁ……♪　オイルでてらてらに濡れた胸を弾ま\nせながら、隊長の精液ねだってる時、搾ってる時が一番楽しいぜ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0404214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「なァ、俺のオッパイ揉みながらイッてくれよ♪　指の跡つくくらい、強引に\n揉んで、揉みまくって……胸とオマンコ同時に支配してくれっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0404215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ぜんっぶ♪　全部隊長のモンだってわかるようにさぁ♪　痛みが残るくらい\n握力で攻めながら……あっ♪　うぁあ♪　チンポでもイジメてくれよっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0404216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「んぁふぅっ♪　ふぅうっ♪　うぁああ♪　それ、それ、それぇ！　ズッズッ\nて中で上下して……カリでマンコっ、ぐっちょぐっちょにかき混ぜて！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0404217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「んはぁああああああ……♪　隊長のガン突き、レベル高くて感度あがりまく\nるっ♪　ひぃっ、はひっ♪　おっ♪　おっ、おっ、おぉおお♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0404218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「……くぅううう～♪　チンポ、チンポの威力どうかしてるぜ♪　ああ、止め\nずに突き上げて、くれっ、もう俺濡れまくってこらえきれねぇよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0404219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「イ……くっ♪　んぉぁああっ、イクぅっ、イク……！　はぁっ、はぁっ、隊\n長も、隊長も俺の中で、俺の胸でイッてくれぇっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0404220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「んぉぉおおぁあッ♪　コレッ、これだよ隊長ぉおお……！　あーっ、むちゃ\nくちゃほとばしってる、俺の中めがけて次々飛んでくるぅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0404301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003404_02_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「あはっ、あは……♪　すっからかんになるまで離さねぇぞ……♪　マンコ引\nき絞って、逃がさねぇ……！　出せ、出せ……！　ッはぁあああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0404302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「二発目だってのに元気いっぱいじゃねぇか……っ♪　ハハッ、出しながら更\nに突き上げてくるとか……こんなんイくだろ、ぁっ、イくっ、イクっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0404303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「うぁああああ♪　目の前真っ白になるっ……！　俺の腹ん中でドクッ、ドク\nッてチンポが痙攣して……どんどん精液送りこんでく、るぅうう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0404304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「射精強すぎてっ、あっ♪　腰が浮くぜ……♪　ダ、メだ俺は逃げたくない…\n…、隊長の精子は全部俺が飲み干すんだ……っ♪　うぅうう……ッ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0404305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「んぐっ！　うぐぅっ、ぐぅううっ……！　はーーーーー♪　終わった、か…\n…？　底無しの精力、とくと味わわせてもらったぜ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0404306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「はひぃいいい……ひぃいい……♪　は、腹破裂するかと思っただろ……！　\n出し過ぎだぁ……♪　嬉しいけどよ……当分立てそうにねぇ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0404307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「今日のセックスがスゴかったのって、もしかして……この水着のせいか？　\nだったら……うん。着たかいがあったぜ。ま、また着てみっかなぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0404308" ]},
		{"command":[ "SETIMAGE", "0", "still_00003404_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「マ、マンネリ防止にもなるだろうしさ……。こうしてヤる気になってもらえ\nんなら……安いかなって。はは、俺がこういうこと言うのおかしいか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0404309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「サイコーのセックスしてもらっちまったからさ……。お礼？　つぅの……？\n　たまに、違う服でもしよーぜ。そのために、俺、稼いでくっからさ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0404310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「た、隊長～～～～っ♪　んッ！？　コ、コラッ！　ちゃんと中に出せよっ…\n…！　あっ！　胸っ……胸にかけてぇのかっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0404401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003404_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ホンットオッパイ大好きだよな、うぁああっ♪　あっ、あっ……！　も、も\nうしょうがねぇ……出ちまったもんはっ……！　あっ♪」　", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0404402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「どうせかけるなら、ありったけ飛ばしてけ……！　んっうっ♪　ぅっ……う\nっ♪　あぁ、あっつい……！　まるでシャワー浴びてるみてぇだ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0404403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「臭いだって充満して……。ここで何してたかモロバレじゃねえかっ……。隊\n長のザーメン、臭いすっげぇし、いつまでも残るんだよ……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0404404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「うぁっ、しつこく胸に、身体にぶちまけやがるせいで……。俺の身体が、皮\n膚が隊長のザーメンに馴染んじまう……これ、これ欲しがって……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0404405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ッ……ったく♪　皮膚呼吸できなくなるくらいかけてんじゃねぇよ♪　はは\nっ、あは……っ。ドロベタで、もう日焼けオイルどころじゃねぇな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0404406" ]},
		{"command":[ "SETIMAGE", "0", "still_00003404_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「隊長のっ……体液の方が、ザー汁の方がオイルより粘りまくってて……。か\nけられた部分以外がまだらに焼けちまったらどうしてくれんだよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0404407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「っふぅうう……ふぅう……♪　ザーメンまみれにされっと……。数秒意識薄\nれるぜ……。なんも考えられなくなって……。ん……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0404408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「っぁあ……♪　なんか、包みこまれてるカンジになるんだよ……。純粋に、\n精子って……あったけぇし。隊長の体温と同じだしさ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0404409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「な、なんて乙女ちっくなこと、俺が言うのおかしいよな！　あはははっ、い\nいんだっ、いいんだ！　ま、またヤろうな……隊長♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0404410" ]},
		{"command":[ "WAITINPUT" ]},
