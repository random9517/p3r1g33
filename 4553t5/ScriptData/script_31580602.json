{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「わざわざ来てくれてありがとう、ご主人。ＹＳＫモードで試して見たいこと\nがあって、付き合ってくれないかなって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0604101" ]},
		{"command":[ "SETCHARA", "0", "char_00015806_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「えっと……その……実はね？　このモードの状態だとさ、私、子供が作れち\nゃうんだ。だから、まぁ、うん……ご主人のね？　子供が欲しいなって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0604102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「とっても簡単に説明すると、ご主人の子種、遺伝子データを胎内に取り込む\nと、私のデータと掛け合わせたロボットの子供を産めるようになったの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0604103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「――まぁ、驚くよね、うん。びっくり技術過ぎて、ご主人がちょっと怖がっ\nてるのも分かるよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0604104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「でも、ごめん……この機能を知っちゃったら、我慢が効かなくなっちゃった\nの。ご主人の子供が欲しくて……ご主人が大好き過ぎて……だから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0604105" ]},
		{"command":[ "SETCHARA", "0", "char_00015806_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「この端末の画面、見て？　ふふっ、ありがとうご主人、これであなたは、私\nの思うがまま。眠いでしょ？　準備しちゃうから、少し寝てていいよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0604106" ]},
		{"command":[ "SETCHARA", "0", "char_00015806_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「――そろそろ意識がはっきりしてきたんじゃないかな？　体調には問題ない\nと思うけど、何かあったら言ってね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0604107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ふふっ、この端末、気になる？　分かりやすく言えば、催眠アプリ。この端\n末にアプリが走ってる間、ご主人は私の命令に絶対にしたがっちゃうの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0604108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「あー、ちょっと胡散臭いって思ったでしょ？　じゃあ、ほら……ご主人、全\n裸になって、そこに寝ころんで？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0604109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ね？　言うこと聞いちゃうでしょ？　――言ったじゃん、ご主人の子供が欲\nしいって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0604110" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00015806_02_02" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ご主人優しいから、いっぱいお願いしたらいつかはかなえてくれるかもだけ\nど、時間、かかりそうだし……ごめんね、もう、我慢できなくってさ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0604111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ふふふっ、さぁ、ご主人。私たちの赤ちゃん、一緒に作ろ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0604112" ]},
		{"command":[ "SETIMAGE", "0", "still_00015806_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「んあぁ……ご主人のおちんちん、入ってくるっ……んっ、あぁんっ……ふふ\nっ、口では慌てながらも、おちんちんはカチカチだね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0604113" ]},
		{"command":[ "SETIMAGE", "0", "still_00015806_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「色々段階をすっ飛ばしたのは悪いと思ってるけど……ほら、ご主人も気持ち\nよくしてあげるから許してよ♪　んっ、んぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0604114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ふふっ、無駄無駄、このアプリがある限り、ご主人は私の命令には絶対。ほ\nーら、無駄な抵抗はやめて、ゆっくり腰を突き上げて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0604115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「あっ、んくっ、ふあぁ……おまんこの奥、新しく実装した、子宮のパーツを\nぐりぐりってっ、んあぁんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0604116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ご主人は、私の気持ちいい所、ぜーんぶ知ってるよね。そこをおちんちんの\n先っぽでいっぱい苛めてね。あっ、あぁんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0604117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「あふっ、あぁんっ！　んあぁんっ！　ふふっ、いつも、どちらかと言えば私\nがいじめられてる方だからさ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0604118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「たまにはこうしてご主人を見下ろして、かわいがってあげるって言うの？　\nってのも、楽しくない？　んくっ、あっ、んぁんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0604119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ふふっ、そうそう、ご主人も楽しんだらいいんだよ。いいじゃん、私と気持\nちいいことするの、大好きでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0604120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「――それはもちろんだけどこの年で子持ちは嫌だ？　まだ自由の身でいたい\nんだ？　ふふっ、諦めて、ご主人が『パパ』になるの♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0604121" ]},
		{"command":[ "SETIMAGE", "0", "still_00015806_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「あぁんっ、あっ、んあぁんっ……私も腰を振るから、タイミングを合わせて\n跳ねてねっ、んくぅんっ！　そう、ごりごり中を削るみたいに……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0604122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「そこ、浅い所の壁際をぞりぞりってっ、あっ、ふあぁんっ！　さ、流石ご主\n人、やっぱり私の弱い所、全部分かってるじゃん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0604123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ふぁっ、あっ、んあぁんっ！　お、奥も忘れないで！　おちんちんの先っぽ\nで、ズドンって突き上げてっ、ふあぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0604124" ]},
		{"command":[ "SETIMAGE", "0", "still_00015806_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「もっと早く、腰を大きく、激しく！　あひっ、あっ、ふあぁんっ！　おちん\nちんの膨れてるところもつかってっ、そうっ！　ふあぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0604125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「これ、ご主人に好きなように命令できるの、ちょっと癖になっちゃうかも…\n…♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0604126" ]},
		{"command":[ "SETIMAGE", "0", "still_00015806_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「おちんちんは気持ちいいのに、ちょっと悔しそうで。私の言いなりになるし\nかないご主人……ふふっ、かわいい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0604127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「まだまだスピード、上げられるよね。んくっ、あっ、んあぁんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0604128" ]},
		{"command":[ "SETIMAGE", "0", "still_00015806_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ご主人の大好きな私の太もも、好きなだけ撫でてもいいからね！　あっ、ん\nあぁんっ！　だからもっと私を気持ちよくして！　おちんちん、もっと！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0604129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ふあぁんっ！　あっ、あぁんっ、んあぁんんっ！　おちんちん、どんどん大\nきくなってるの、分かるっ、ああぁんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0604130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「こ、これが、子宮がおちんちんを欲しがるって感覚なんだ！　ご主人の子種\nをほしがって、おまんこがヒクヒク痙攣しちゃってる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0604131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「あひっ、あっ、んひゃぁんっ！　えっちなノイズも、いっぱい来たっ！　も\nっと激しく、私の事めちゃくちゃにして！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0604132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「んあぁんんっ！　おちんちん、反り返ってきてるのが分かるよ！　ピクピク\n震えて、ご主人も、もう出そうなんだよね！　あっ、んあぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0604133" ]},
		{"command":[ "SETIMAGE", "0", "still_00015806_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「もちろん、射精は中にだよ！　子宮に先っぽをぎゅーってくっつけて、ドロ\nドロの子種を、子供ができるまで出し続けるの！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0604134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「あひっ、あっ、んひゃぁんっ……！　頂戴、ご主人の子種！　ご主人の遺伝\n子を、私のデータバンクに刻み込んで！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0604135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「んあぁんんんっ～～～っ！！　熱い精液が子宮に直接っ、あっ、ふあぁんっ\n！　奥に出されて、私もイってるっ、んあぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0604136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015806_02_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「これがご主人の遺伝子！　おまんこでいっぱい感じてっ、ふあぁんんっ！　\nまだまだ足りないの！　もっといっぱい出して！　あぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0604137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「こ、これで、ご主人との子供ができる……んくっ、あっ、んんっ……！　ご\n主人と、私の赤ちゃん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0604138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「――はぁ、はぁ……すご、かったぁ……おまんこの中、タプタプしてる……\n子宮も、子種で満たされて……ふふふっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0604139" ]},
		{"command":[ "SETIMAGE", "0", "still_00015806_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「精子の受け取りを確認、遺伝子データ解析、マザーコンピュータに送信……\n完了。疑似妊娠機能、可動確認……あっ、んぁん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0604140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「見て、ご主人……この膨らんだお腹の中に、ご主人と私の子供がいるんだよ\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0604201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「――こんないきなりお腹が膨れるのはおかしいだろって？　そこはまぁ、ほ\nら、雰囲気というか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0604202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「実際はまだ赤ちゃん……新しい命を持ったロボットはいないんだけどね。そ\nの為に掛け合わされた遺伝子データは確かにここにあるの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0604203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「時間をかけて、愛して、お腹の中で赤ちゃんを作り上げていくからね。おめ\nでとう、ご主人。これで立派な一児のパパです♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0604204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「んひゃぁんっ！？　ちょ、ご主人、なんか目が据わってるんだけど！？　―\n―え？　こうなったらとことんやってやる？　んひゃぁんっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0604205" ]},
		{"command":[ "SETIMAGE", "0", "still_00015806_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ど、どうして、あっ、ふあぁんっ！　命令してないのに、ご主人、勝手にお\nちんちん突き始めてっ、あっ、ふあぁんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0604206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「さ、さっきのえっちなノイズが残ってて、今は感じすぎるからぁ！　あひっ\n、ふあぁんっ！　止まってっ、ご主人、いっかいストップ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0604207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「あひっ、あっ、ふあぁんっ！　ど、どうして！？　催眠の制御が効かないっ\n、ああぁんっ！　あ、アプリ壊れた！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0604208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「――た、確かに最初にいっぱい苛めてとは言ったけどさ！？　嘘、あの命令\nを続けてるのっ！？　んひゃぁんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0604209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「あひっ、あっ、ふあぁんっ！　おちんちん、激しすぎるっ！　出された精液\n、ぐちょぐちょに掻き回されてっ、ふあぁんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0604210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「また、浅い所もごりごりって、んひゃぁんっ！　弱い所ばっかり狙わないで\n、いひぃんっ！　そ、それも言ったけどさぁ！　あっ、あぁあんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0604211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「んひぃんっ！？　今度はまた子宮っ、赤ちゃんのデータ受け取ったばかりの\n子宮、いっぱい責められて、ああぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0604212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「あっ、ふあぁっ、ああぁんっ！　すごい、おまんこ全部で、ご主人を感じる\nのっ……！　ＹＳＫモードだから、色々敏感でっ、んふぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0604213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「――うんっ、もっと締め付けるよ！　おまんこぎゅーってして、子宮の入り\n口でおちんちんに、いっぱいちゅーするの！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0604214" ]},
		{"command":[ "SETIMAGE", "0", "still_00015806_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「あひっ、あっ、ふあぁんっ！　あんっ、あぁんっ！　えっちなノイズで視界\nが埋め尽くされるっ！　頭の中、エラーだらけでっ、あひぃんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0604215" ]},
		{"command":[ "SETIMAGE", "0", "still_00015806_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「――いいの！　もう、私が虐めるとかはもういい！　ご主人に愛されて、気\n持ちいいから、そんなことどうでもいいの！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0604216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ご主人、もっと激しくして！　おちんちんで妊娠したばっかりの私のおまん\nこ、いっぱいかわいがって！　気持ちよくさせて！　ああぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0604217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「うん、これは命令じゃなくてお願い！　ご主人、私をいっぱい愛して！　ご\n主人と『ママ』と『パパ』になって、ずっと一緒にいたいの！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0604218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「あっ、んあぁ、あぁんんっ！　おちんちん、ビクビクきたぁ！　大きく脈打\nって、震えてっ……！　あっ、ふあぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0604219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「イクから、ご主人と一緒にイクから！　あひっ、ふあぁんんっ！　また、遺\n伝子情報を刻み込んで！　それで、ご主人と一緒に――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0604220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ふあぁあぁぁんんっ～～っ！　きたぁぁ！　あひっ、んふぅんんっ！　また\n子宮の中に直接、ドクドクって流れ込んでっ、んくぅんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0604301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015806_02_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ご主人の遺伝子データ、全て解析したいのっ……！　おまんこで……子宮で\n全部受け止めて、ご主人のデータと一緒になりたい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0604302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「あっ、んあぁんっ！　私もイクの、とまらないっ、ふあぁんっ！　えっちな\nノイズ、多すぎてっ、壊れちゃいそうだけど、これ、好きぃっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0604303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「あひっ、あっ、んくんんっ……はぁ、はぁ……ほ、ほんとにいっぱい、出し\nたね……子宮のなか、パンパンで……破裂しちゃうかも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0604304" ]},
		{"command":[ "SETIMAGE", "0", "still_00015806_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「――んっ、それは大丈夫。言ったでしょ、まだあるのは遺伝子のデータだけ\n、赤ちゃんの組み立てはこれからだから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0604305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ふふっ、あれだけ子持ちはまだ嫌って言ってたのに、お腹のこの子の事、心\n配してくれるんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0604306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「――できちゃったものは責任はとる？　私との子だと思うと、嬉しくなくも\nない？　ふふふっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0604307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ふふっ、やっぱりご主人にはかなわないや。そーゆーとこ、ほんとずるいん\nだから、もう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0604308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「無理やり襲っちゃってごめん、ご主人。そして、ありがとうね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0604309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「元気な子、産むからさ。これからも末永く、幸せにしてね、私だけのご主人\n♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0604310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「んあぁあぁぁんんっ～～っ！！　おちんちん、抜けちゃった……！　んんっ\n！　私の『肌』熱いのが飛び散ってっ、んくぅんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0604401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015806_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「熱い精液が掛かった場所から、甘いノイズが広がっていくっ、あっ、ふあぁ\nんっ！　ＹＳＫモードでのぶっかけ、気持ちよすぎてっ、あぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0604402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「もう一回子宮に、遺伝子データを出してほしかったけど、これはこれで……\nあっ、んあぁんっ！　全身で感じるご主人の熱、好きぃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0604403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「でも、やっぱり精液もったいない……指についた分だけでも……れるっ……\nんっ……口からの摂取だと、やっぱり無理だよね……んぁんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0604404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……も、もう出ない、よね？　んっ……ごめん、ちょっと待って\n……イキ過ぎて、エラー処理、終わんないっ……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0604405" ]},
		{"command":[ "SETIMAGE", "0", "still_00015806_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「うん、ちょっとは落ち着いた……なに、そのニヤニヤした顔。――やっぱり\n私は攻められて虐められてる方が似合う？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0604406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「むーっ、今日は最初から最後まで、私がご主人を支配するつもりだったのに\n……っていうかやっぱり、途中から催眠とけてたよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0604407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「一回射精を挟むと、解けちゃうのか……これは、少し改良の必要があるね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0604408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ふふふっ♪　いいじゃん、結局ご主人も満更じゃなさそうだったんだから。\nまた今度、このアプリ使ってご主人を無理矢理襲ってあげる♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0604409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「だーめ、逃がさないんだから♪　お腹の赤ちゃん共々、これからも末永くよ\nろしくね、ご主人♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0604410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}