{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「……今さらこんなことを聞くのもおかしいかもしれないけど。そもそも、ハ\nロウィンとはなんなんだ？　この星独自の催しらしいことしか知らないよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0503101" ]},
		{"command":[ "SETCHARA", "0", "char_00015605_01", "2", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「ふむふむ。イタズラをされたくなければ、奉仕をするイベント……？　そう\nすれば、良いものがもらえる、と。なるほど。お互いウィンウィンの関係か」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0503102" ]},
		{"command":[ "SETCHARA", "0", "char_00015605_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「それなら両者に得があるから、流行するのもわかる気がする。……で。参考\nまでに聞いておくけど、おまえは何をしてほしいんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0503103" ]},
		{"command":[ "SETCHARA", "0", "char_00015605_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「……う、ううっ……？　乳首を使ってチンポをシゴいてほしい……！？　お\n、おかしいな。ハロウィンは子どもたちのイベントだったはずだぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0503104" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015605_01_01" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「奉仕……というのはこっち系のことだったのか！？　そ、それなら……聞か\nなかったのに。本当に、いつもいやらしいやつだ……。……ん？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0503105" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「ちゃんとご奉仕ができたら、良いものをあげる……？　い、良いものってな\nんだ。それは後でのお楽しみ？　……っくぅうう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0503106" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「こ、今度騙したら許さないからな！　……それにしても一体なんなんだ。乳\n首でチンポをシゴくって……。乳首ズリ？　名称は別に聞いてないっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0503107" ]},
		{"command":[ "SETIMAGE", "0", "still_00015605_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「こ……言葉の響きだけで卑猥なのがよくわかる……。おまえは毎度毎度、よ\nくもまあこんなに卑猥なことを思いつくな……。この星はおかしいぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0503108" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「……ん……、でも、まあ……褒美につられて、興味本位でノせられている私\nも私、か……。ど、どうせヒマだったから……付き合ってやってもいいけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0503109" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「本当にやり方は知らないから、間違っていたら教えておくれよ。乳首……で\nシゴくというからには、こうやって……乳首をチンポにあてがって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0503110" ]},
		{"command":[ "SETIMAGE", "0", "still_00015605_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「く、ぅ……♪　こ、こうか……？　んっ……。しっかりチンポを手で握って\nいないと……すべって離れてしまうな。少し、力をこめるぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0503111" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「ぎゅうっと握って……んふっ、乳首、にチンポの先っちょを押し当てて……\n。はぁ、はぁ……。乳首がぷにぷにしていて気持ちいい、だと……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0503112" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「あっ……！　そ、それはそうだろう……？　乳首は柔らかくなければ、あ、\n赤ちゃんがミルクを飲む時に大変じゃないか……。変なことを言うな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0503113" ]},
		{"command":[ "SETIMAGE", "0", "still_00015605_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「ん……ん、ん……。んん……？　チンポが濡れてきたな……？　これは……\nええと、先走りという汁だったっけ……？　この雫を絡めて……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0503114" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「手でチンポを刺激しながら……乳首でもこする……。っふぅっ、ふぅっ、ふ\nぅ……！　い、意外に難しいぞ、これぇ……！　んっ、ん、んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0503115" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「うまくこすりあわせないと……ズレて摩擦できない……。っん……！　んっ\n、ふ……。ふぅっ、ふーっ、ふー……？　な、なんだ？　ジッと見てぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0503116" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「私の乳首が……少しずつ硬く大きくなっている？　こ、これは条件反射で…\n…。んっ、い、いや……確かに気持ちいいんだけどさ……照れるよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0503117" ]},
		{"command":[ "SETIMAGE", "0", "still_00015605_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「あんまり見ないどくれ……。っふっ……♪　真面目に、ちゃんとシゴくから\nさ……。っはぁっ、は、ぁ、はぁっ、はぁ……。こ、これってさぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0503118" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「自分の手とか、指で触るのとは全然違う……。んっ……♪　隊長の反応も伝\nわってくるし……。チンポの臭いっていうの？　エロい形とか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0503119" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「私のすることに昂って、ギンッギンになってきてたり……。んっ、血管が浮\nき出てきてて……そ、そう！　すごく……やりがいがあるっていうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0503120" ]},
		{"command":[ "SETIMAGE", "0", "still_00015605_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「隊長が感じてるのが、こっちの胸にもはっきり理解できちまうだけに……。\nんぅっ、こっちも自然と熱が入っちまうんだよ……！　っぁっ、ほらぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0503121" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「一擦りするだけでチンポがピク、ピクって震えて……。んんんっ。こ、こら\n……暴れるなぁ、こっちの乳首にも快感がくる……！　っぁっ♪　あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0503122" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「先走りの量も、どんどんどんどん増えてくるし……っ。ヌルヌルしてシゴき\nにくい……っ。で、でも、ヌメっている方が、乳首は気持ち良くて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0503123" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「あ、あぁ、も、もうどうすりゃいいのかよくわかんないよぉ……！　っぁっ\n♪　隊長の要求する奉仕は、いつも私を困惑させてくるぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0503124" ]},
		{"command":[ "SETIMAGE", "0", "still_00015605_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「あんっ！　ぐいぐい下から突き上げてくるなぁっ……！　あっ♪　乳首がビ\nリビリ痺れるぅ……っ。これが、乳首ズリ……っ。乳首コキ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0503125" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「はぁっ、あぁ、あっ……んぁあっ……。……んっ？　だんだん身体が前に倒\nれてきている？　そ、れは……チンポに圧力をかけるためだしっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0503126" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「こうして胸を全部乗せてっ……、より深く乳首で刺激した方が快感も強くな\nるだろうっ？　あっ♪　ぜ、善意なんだから文句言うなぁっ……！　はぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0503127" ]},
		{"command":[ "SETIMAGE", "0", "still_00015605_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「こ、れ……。私も胸が気持ちいい……っ。乳首が熱くなる、ビンビンに尖っ\nて……あっ♪　チンポに乳房がまとわりついてぇ……っ、はぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0503128" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「ま、まずいぞ……！　乳首コキをしながら、腰をくねらせるのがやめられな\nいぃ……っ！　あっ♪　あっ、ムズムズする、胸の先がぁ……！　あっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0503129" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「ふぁっ♪　あぁ、あッ……あぁっ♪　んぁっ♪　ここか？　チンポの先っち\nょの……穴に乳首を当てて、ズリズリ動かして……あっぁっあっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0503130" ]},
		{"command":[ "SETIMAGE", "0", "still_00015605_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「はぁああっ……♪　隊長に与えている、奉仕しているつもりで……私は自分\nがすっかり気持ち良くなってしまっていて……！　っあ、ぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0503131" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「まともに立っていられないぃい……♪　膝がガクガクするぅっ……！　あっ\n！　あっ！　チンポを握りながら、見下ろしながら胸で愛撫するだけで」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0503132" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「どうしてこんなに気持ち良くぅ……！　あンッ♪　んんっ、んぅううっ、う\nう～っ……♪　ま、ますますチンポ太くなってきてるし……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0503133" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「ね、ねえ……？　もしかしてこれ、射精寸前ってこと？　このまま精液を…\n…白濁液をびゅぶびゅぶ発射したいってこと……なのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0503134" ]},
		{"command":[ "SETIMAGE", "0", "still_00015605_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「わ、わかった……！　それなら出してほしい……っ。あっ、私も共にイクっ\n……！　果てる、絶頂するから……一緒にぃいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0503135" ]},
		{"command":[ "SETIMAGE", "0", "still_00015605_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「はぅっ！？　あぁあああッ……！　あっついぃいっ……！　熱いぃっ！　ド\nロッドロの白濁液……！　ヌルヌルで粘り気の強い精液が溢れ出るぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0503136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015605_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「飛んでっ……あっ！　乳首に、胸にかかっていく……！　うぁあああ……♪\n　そうだ、この臭い……！　精液独特の、オトコの臭い……腰が疼くっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0503137" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「イッ……くぅうっ♪　あああっ、み、見ないでくれぇ……！　乳首でイクぅ\n……！　乳首と胸しか奉仕に使っていないのにぃ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0503138" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「はぁああああっ♪　全身が痙攣してっ……。膣内まで潤って、……ひんっ♪\n　愛液が太ももに垂れてきてしまった……！　情けないぃ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0503139" ]},
		{"command":[ "SETIMAGE", "0", "still_00015605_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「た、隊長のチンポがいけないんだぞ……！　こんなに男らしくて……遠慮な\nくビュービュー精液を射出し続けるからっ、男の臭いを撒き散らすからぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0503140" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「っふ……♪　や、やっと射精が止まったぁ……。いつもながらに凄まじい量\nだ……。それに、チンポもずっと硬いまま。大きいままでヒクついている」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0503201" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「……そ、その……スッキリ満足するのは難しかったか？　私が下手だったか\nら……？　ん？　違う？　私が途中から、自分が気持ち良くなってしまって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0503202" ]},
		{"command":[ "SETIMAGE", "0", "still_00015605_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「そのためにチンポをシゴいていたから……？　あっ……！　た、確かに……\nそれじゃ本当の奉仕……ではなかったな。図星だ……ご、ごめん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0503203" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「次は！　今度はちゃんとチンポのために奉仕するから！　乳首をたくさん使\nって気持ち良くするから……もう一度チャンスをくれ！　はじめるぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0503204" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「……ん……♪　ぁ、ダメだ……ダメだ、私が気持ち良くなるんじゃなくて…\n…！　乳首や胸に、精液を塗りたくりながら、指も動かして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0503205" ]},
		{"command":[ "SETIMAGE", "0", "still_00015605_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「もっと、おまえを感じさせてやりたい……♪　はぁ、はぁ……♪　あっ♪　\nダメだ、私が感じるんじゃなくて……隊長を気持ち良くしない、と……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0503206" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「っん……！　んっ……！　ンッ……♪　んっ、んっ……♪　フフフ、少しは\n上達してきたか？　手首の動かし方をもっと大胆に工夫してみるか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0503207" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「ぐりぐりぐりぐり……♪　ズリズリズリズリっ……♪　はぁっ♪　はぁ、い\nい反応だ……こういうのが好きなのか。ぐりゅっぐりゅっぐりゅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0503208" ]},
		{"command":[ "SETIMAGE", "0", "still_00015605_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「隊長の精液でニュルニュルになっているから、とってもシゴきやすくて助か\nっているぞ……♪　にゅるっ……にゅるっ、にゅる……あっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0503209" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「なんか、チンポがいやらしく輝いているぞ……？　あっ♪　ヌルヌルで……\n。んんっ♪　卑猥すぎる……。こ、こんなものを股間にぶらさげていて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0503210" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「よくマトモでいられるな……っ♪　は、ぁ♪　はぁっ、はぁ、はぁあっ……\n♪　あぁあ、シゴく手が止まらない……♪　オッパイも乗せてやるぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0503211" ]},
		{"command":[ "SETIMAGE", "0", "still_00015605_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「どうだ……？　私の胸は柔らかいか……っ？　あっ♪　ンン……♪　すぐ、\nチンポで返事するんだから……♪　そうかそうか、好きな感触かぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0503212" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「私がこんな奉仕をするのはっ♪　生涯おまえにだけだからなっ……！　堪能\nしろぉっ……！　それっ……それっ、乳首ズリ、イイだろうっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0503213" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「ん、ふふ……♪　私の敏感な乳首がコリコリになって、おまえの敏感なチン\nポを愛撫している……♪　なんて、なまめかしい光景だ……♪　はぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0503214" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「は、ぁ……♪　ま、マズいぃ……♪　また、乳首が気持ち良くなってきたぁ\n……！　あっ……こらえられない……っ、どんどん良くなってくるぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0503215" ]},
		{"command":[ "SETIMAGE", "0", "still_00015605_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「な、なあっ……！　私も、私ももう一度乳首でイッていいか……っ？　お願\nいだ、ちゃんとチンポもイかせてみせるからっ……。あっ♪　あっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0503216" ]},
		{"command":[ "SETIMAGE", "0", "still_00015605_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「……いいのかっ！？　あ、ありがとう……！　それなら、思う存分手コキの\nスピードを上げることができる……！　いくぞ、全力でシゴく……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0503217" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「んっ！　んっ、んっんんんっ……！　うぁああっ♪　気持ちいいっ、気持ち\nイイ……っ！　ああっ！　乳首イクッ、乳首ビクビク痙攣してるっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0503218" ]},
		{"command":[ "SETIMAGE", "0", "still_00015605_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「隊長ぉ……♪　おまえのチンポもすごいぞ、限界までパンパンに腫れあがっ\nてる……っ！　そろそろ出したいのか？　精液溜まってきたんだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0503219" ]},
		{"command":[ "SETIMAGE", "0", "still_00015605_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「いいぞ……♪　私も♪　私もまた乳首でイクからっ……。だから合わせて…\n…同時にイッてくれっ♪　５……、４、３、２、１……あっあああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0503220" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「あふっ♪　ンンッ……！？　熱いぃっ……！　あっぁっあっ♪　イッてる乳\n首に、容赦なくドクドク注がれる精液……最高だよ……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0503301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015605_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「あぅんっ♪　んんんっ♪　もっと♪　もっとだ、残りの汁すら枯れるくらい\nに……全部っ、全部私の乳首にかけてくれっ……！　あっぁっあっあっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0503302" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「びゅくっ♪　びゅくっ、びゅくっ……♪　フフフフッ♪　おまえの心臓の鼓\n動と同じリズムで、チンポが脈動して……次々白濁液が溢れてくる……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0503303" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「それに私も興奮するんだ……！　あっ♪　あああっ♪　乳首にぃ……♪　胸\nに精液かけられて、アソコまで……オマンコまで気持ち良くなってしまう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0503304" ]},
		{"command":[ "SETIMAGE", "0", "still_00015605_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「疼きが抑えきれない……ッ♪　あっ♪　イクイクッ♪　新鮮な精液の香りを\n嗅ぎながら……下品にアヘッてイクっ♪　あっ♪　おっ♪　おっぉっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0503305" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「乳首コキなんかで……っ♪　乳首ズリなんかでこんなにたくさん精子を出し\nて……っ♪　お前はなんて可愛いヤツなんだ……好きだぞぉおっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0503306" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「……あ……♪　す、すまない……。なんていうか……。絶頂っていうの？　\nイくと、普段抑えてたおまえへの愛しさっていうか……愛情っていうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0503307" ]},
		{"command":[ "SETIMAGE", "0", "still_00015605_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「そういうのが、どぱっと漏れ出してしまうことがあるんだ……。き、き、気\n持ち悪くなかったか……？　へ？　チンポが気持ち良かった？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0503308" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「そ、そういうんじゃなくてっ……。って、ま……。今はそれだけでもいっか\n。っていうか隊長が気にならなかったなら良かったよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0503309" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「これくらいのことだったら、ハロウィンじゃなくてもしてやるからさ。……\nうん。おまえは……特別だから。それだけは忘れてくれるなよ？　な？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0503310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},
	
		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「あぁっ、出たっ♪　飛び出たぁっ……♪　って、あっ！？　お、おいっ……\n？　飛ばしすぎだよっ、か、顔にまで飛んできてる……あっぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0503401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015605_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「わ、私の顔になんか精液かけたって何も楽しくないだろうっ……？　そ、そ\nうでもないのかい！？　あっ……うう、白濁液がドプドプと……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0503402" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「ん、ふ……！　至近距離で嗅ぐ、精液の臭いって……濃厚で、ムワッと蒸れ\nてて……強烈だ……♪　それにこの粘り気ぇ……顔にべったりはりついて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0503403" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「離れないようにってしがみついてきてるみたいだ……♪　あぁっ、いいよ、\nそんなに自分の色に……真っ白に染めたいのなら、いいよっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0503404" ]},
		{"command":[ "SETIMAGE", "0", "still_00015605_01_11" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「いくらでも浴びてやるよ……！　っふぁ……ッ♪　頭がクラクラするような\n臭いぃ……♪　ガツンと来るねぇっ……！　あっぁっ、さすがだよっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0503405" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「わぷっ♪　んぷぷっ……ひゃぁっ♪　あうぅっ……♪　まったくぅ……暴れ\nん坊にもホドがあるよっ……！　健康的で素晴らしいけどね、……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0503406" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「ふーっ♪　ふー、ふー……♪　ようやく落ち着いてきたようだね……♪　あ\n～あ、もう、私の顔から胸から、何もかもをベトベトにしてくれてぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0503407" ]},
		{"command":[ "SETIMAGE", "0", "still_00015605_01_11" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「やりたい放題の困ったちゃんだよ……。でも、ここまではっちゃけてくれる\nってことは……私に気を許してるってことだと思うからね。気分いいよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0503408" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「私には、どんな隊長だって見せておくれ。情けないところも、感じていると\nころも、こうして……暴発しちまうところも。何もかもをだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0503409" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「なんて……。独占欲が強すぎたかもしれないね。おまえに奉仕するのは好き\nだから……。色んな奉仕の仕方を教えておくれ。頑張るよ……♪」", "NORMAL" ]},
