{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「隊長さま。今日は私を呼び出してくださってありがとうございます。フフ…\n…疲れた顔。だいぶ、お仕事が溜まっていたようですね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0103101" ]},
		{"command":[ "SETCHARA", "0", "char_00011901_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「何も説明していただかなくても大丈夫ですよ。本日は、私が……隊長さまの\n日々のお疲れを癒してさしあげようと思ってきたのです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0103102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「ベッドに横になって、肩の力を抜いてください。目を閉じて、何も考えずに\n……頭が真っ白になるまで、ぼーっとして……。そう、そうです、そのまま」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0103103" ]},
		{"command":[ "SETCHARA", "0", "char_00011901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「小さな子どもに戻ったみたいに……。いいえ、生まれたばかりの、穢れを知\nらぬ赤ん坊にかえったかのように、全てを私にゆだねるのです……そう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0103104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「……え？ズボンを脱がせて何をしているのか、ですか？そうやって、すぐに\n邪念にとらわれてはいけませんよ。私は女神、人の子のための女神です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0103105" ]},
		{"command":[ "SETCHARA", "0", "char_00011901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「人の子を守るため、救うために生まれたのであれば……その役割をまっとう\nするだけ……。ゆえに、貴方の最も凝っている場所。陰の気の多い場所」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0103106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「股間をこの手で揉みほぐし、……それと同時に、この豊かな胸でぱふぱふを\nしてさしあげます。ぱふぱふ……聞いたことはあるでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0103107" ]},
		{"command":[ "SETCHARA", "0", "char_00011901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「人の世で、男性がされるととても幸せになる行為だとか。私は俗世に疎いも\nのですから、書物でじっくりと研究してきました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「ほーら、ぼくちゃん。おっぱいの先っちょをくわえてみて～？それで、ちゅ\nうちゅうって吸ってみましょうか♪んん……そうよ、上手上手、ちゅー♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0103109" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00011901_01_02" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「好きなだけぺろぺろレロレロしていいでちゅからねぇ～？んっ……舌で転が\nして……。あぁ……っ、ツボを押さえたテクニックまで……んんんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「あなたがそうして私のおっぱいに夢中になっているところに、こうして……\n少しずつ乳房を乗せて……。うん、重たいでしょう？柔らかいでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0103111" ]},
		{"command":[ "SETIMAGE", "0", "still_00011901_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「おっぱいで目隠しをしたら……あとはこっちね♪おチンチン……。肉棒を、\n私の手で、指でくにゅくにゅときほぐしてあげる。むに、むに、むに、くに」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0103112" ]},
		{"command":[ "SETIMAGE", "0", "still_00011901_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「くにゅ……くにゅ、くにゅ……くにゅ……。んん？手が冷たくて気持ちいい\n？そうねぇ……血液が人より少ないのかもしれないわね……ん、んん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「どんどん手の中で、男根が硬く……大きくなってきましたよ。あぁ……申し\n分のない太さです。人類の女であれば虜に出来る名器……フフフ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「赤ちゃんのおチンポがここまで立派だと、ママの私も照れてしまいますけど\n……。これは癒しの施術ですから。遠慮なく最大勃起してください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0103115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「てのひらをすぼめて……全部の指で、上下させるわね？くにゅっ♪くにゅっ\n……くにゅっ♪くにゅ……あぁあん♪まだ大きくなるの？すごいわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「えらくて格好いいおチンチン……♪夢中になっちゃう……。フフ♪こう？こ\nうかしら？どういう角度がいーい？……あ、これかしら♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「おててが一番強く食い込むここ……。ええ、ええ。このままたくさんシゴい\nてあげる……。あぁ、ああ、たくましい……素敵よ、んん、かっこいい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「うふふふ、シゴかれながら、おっぱいにも注目してくれるかしら？私の胸…\n…。女神の力で、母乳を出すことが出来るの。飲みたい？うんうん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「じゃあ、もう少しつよーく吸って♪チュー……ちゅぅー……そうよ、そう…\n…そうそう♪ほら、ちょっとずつ滲んできた……ちゅう、ちゅうちゅう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0103120" ]},
		{"command":[ "SETIMAGE", "0", "still_00011901_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「あっ……あああっ♪わ、わかるかしら？あまーい味が口の中に広がっていく\nでしょう？それが母乳……よ♪少し、さらさらしていて甘いでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「今日は、隊長さまだけが私の母乳を飲んでいいですからね……。たくさん召\nし上がれ？嫌なことはぜーんぶ忘れていいのよ、私が守ってあげる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「だから、おっぱい吸ってねんねして……。身体に悪い成分は、おチンチンの\n奥から先っちょにぴゅっぴゅしちゃおうか♪ん、ん……もちろんいいわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「どれだけ隊長さまが粗相をしても、女神たる私が全て受け止めてさしあげま\nす。……心と身体を静かに、じわじわと解放していきましょう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「くにゅ、くにゅ、くにゅ、くにゅ……うふふふ♪この強さじゃあ生殺し？じ\nゃあ、もーっと力を込めて……。ぐにゅっ、ぐにゅっ、ぐにゅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「隊長さまのおチンチンが大きすぎて、手で握るのが大変なのですよ。逞しく\n、生命力にあふれた源……。女神ですら見惚れる特大サイズ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「神に、いいえ、天に愛された素晴らしいおチンポですね♪それに、耐久力も\nある……。こんな男根を膣内に入れたら、女は皆狂ってしまいますね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「女のおまんこの、一番良い場所をひっかくための段差もついている……。あ\nぁ、どうしましょ……私までドキドキしてきてしまったわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0103128" ]},
		{"command":[ "SETIMAGE", "0", "still_00011901_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「母乳を吸う、あなたの舌づかいが、巧みで……。ううん、いやらしい動きを\nしているからかしら……。それとも指から想像してしまうから？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「ひ、人の子と女神の禁断の交配を……思い浮かべると、んっ、あぁ、母乳の\n勢いが強くなってしまう……。それに、手が、手が止められない……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0103130" ]},
		{"command":[ "SETIMAGE", "0", "still_00011901_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「すごいわ、魔法がかかっているみた……い♪あっ……女神の私を感じさせる\nだなんて……あっ♪数十年に……い、いえ、数百年に一人の逸材……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「ん、んんっ……もっとよ。もっと吸うのです……！私の胸に、乳房に……顔\nをうずめて！芳香をかぎながら……吸って！あぁ、舐めて……もっと！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「あっ！あっぁっあぁっ……！そうです、そう、です……んんっ！乱暴に……\nああっ！そ、う……あっ！い、いけない、達してしまいそう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0103133" ]},
		{"command":[ "SETIMAGE", "0", "still_00011901_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「私は隊長さまを癒しにきたのに……！っ……あ、ふ♪隊長さま♪まずは一度\n、溜まったものをぴゅるぴゅるいたしましょう。息を吐いて、吸って……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「心身をゆるませて、私の手に精液を引き出されてください……。ほら♪ほら\n、ほら、ほら……ぴゅっぴゅっぴゅっ♪ぴゅっぴゅっぴゅっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0103135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「っああっ♪いい子いい子！いーっぱい出ましたねぇ……♪ええ、手で受け止\nめていますよ……。でも、ここからが本番です。このドクドクが終わったら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0103136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00011901_01_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「ここからはご褒美タイム♪精液でニュルニュルになったてのひらで、何度も\n何度も出させてあげます……。ねぇ……？こうして塗りたくって……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0103137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「……ほぉーら♪ヌメヌメしてて気持ちいいでしょう～？はぁ、はぁ、私もだ\nんだん気分が上昇してきました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「おチンチンいじりをしている手が、白く染まって……んんっ、感じてしまう\n……っ。ねえ……？一緒に気持ち良くなりましょう、もっと♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「ああ、胸を吸って、吸って♪あふっ……！たぷたぷと顔で乳房を弾ませてみ\nましょうか。たっぷたっぷ♪タップタップ♪うふふふ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「大きいでしょう……？私の胸は……。人の身体で言えばＩカップだそうです\nよ……グラビア？アイドルでもそうそうみない巨乳、いいえ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0103201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「爆乳……だとか♪肌もなめらかで、どこまでも顔がしずんでいくみたいでし\nょう……？乳首の色もピンク色……うふふふ、欠点のない肉体……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「この胸は、今、隊長さまだけの胸……。本来人の触れることのできない聖域\nで、大量に射精させられるのです……。自尊心が満たされるでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0103203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「っあぁんっ！あらあら……今、おっぱいに歯形をつけましたね？独占欲の表\nれでしょうか……。乳首も噛んでみてもいいですよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0103204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「っん……♪あんっ……え、ええ……痛いというよりは……。あぁっ♪胸の先\nがピリピリするような……っああああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0103205" ]},
		{"command":[ "SETIMAGE", "0", "still_00011901_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「むずがゆくってもどかしいような気持ち……あっ！あっ！すみません、その\nままっ……噛み噛みしながら、強く吸っていただけます、か……っ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0103206" ]},
		{"command":[ "SETIMAGE", "0", "still_00011901_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「何か、何かおっぱいから……おっぱいの奥から、ドッと溢れ出してきそうで\n……ああっ！あっあっあっ、感じます、感じてしま……うっ、あああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0103207" ]},
		{"command":[ "SETIMAGE", "0", "still_00011901_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「っぁっ……！あっ……ふぁああっ♪胸が、胸が震える……ぅ……！あぁっ、\n隊長さま……隊長さま……どうしましょう、こんなこと初めてです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「これは……何？あぁっ、胸をひどくされると、なぶられると……とても身体\nがゾクゾクして……！やぁんっ、が、我慢できないぃいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「あああああっ！大量に噴射してしまうっ……あっ、あああああっ！ごめんな\nさい、お顔にたくさん、たくさん母乳が出てしま……んああああああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0103210" ]},
		{"command":[ "SETIMAGE", "0", "still_00011901_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
