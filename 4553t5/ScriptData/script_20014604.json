{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0144" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「さて、またまた会場に戻ってまいりまして、いよいよ残された予選はあと一\nつ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023120001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「カグヤ、アン＝クァー、グリムロックの３選手による勝負内容は……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110023120001" ]},
		{"command":[ "SETCHARA", "0", "char_00000514_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ズバリ、想いが重い花嫁対決！　カツマ殿の心を動かすのは誰？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023120002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ここに来て、初めてコンセプトに近い競技が行われそうですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110023120002" ]},
		{"command":[ "SETCHARA", "0", "char_00000514_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「そんな訳で、今回は参加者の皆様に、カツマ殿へ愛の告白をしていただきま\nす！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023120003" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「そして、カツマ殿につけられたセンサーで、感情の揺らぎを数値化した『ト\nゥンクポイント』を多く集めた選手が勝者となります！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023120004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010023120001" ]},
		{"command":[ "SETCHARA", "0", "char_00000214_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_010023120001" ]},
		{"command":[ "SETCHARA", "0", "char_00022101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010023120001" ]},
		{"command":[ "SETCHARA", "0", "char_00001801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「おっと……三人とも、かなり緊張の面持ち！　果たしてベストなパフォーマ\nンスを出せるのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023120005" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「誰から行くんでしょう……あっ、これはカグヤ選手が一歩前に出ましたね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110023120003" ]},
		{"command":[ "SETCHARA", "0", "char_00000514_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「おぉっ、いつも後ろからそっと寄り添うパターンのカグヤ選手にしては珍し\nい展開か？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023120006" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「えっと、カツマ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010023120002" ]},
		{"command":[ "SETCHARA", "0", "char_00000214_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お、おう」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「いろいろあったと思うけど……私、ずっと貴方の側にいて、貴方のことを見\n守ってきた……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010023120003" ]},
		{"command":[ "SETCHARA", "0", "char_00000214_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……ま、まぁ、そうだな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「貴方が私をどう思ってくれてるのか……はっきりとは分からない……けど、\n私は貴方に選んで欲しい……！　その気持ちだけ、伝えたいのっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010023120004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうか……あぁ、わ、分かった」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「おおーーっと、メーターが、一、十、百、千、万っ、一気に７万まで跳ね上\nがったーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023120007" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「一見、冷静で何でもないという雰囲気を見せていますが、内心は完全にデレ\nッデレですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110023120004" ]},
		{"command":[ "SETCHARA", "0", "char_00000514_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「いやー、あのニヤけ顔。とても地上波で流していいものではありませんな～\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023120008" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「野次がうるせぇよ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「むむ……さすが幼馴染、清楚、忍者の３属性を持つ、カグヤさんですね……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_010023120002" ]},
		{"command":[ "SETCHARA", "0", "char_00022101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「最後の一つ……関係あるかな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010023120002" ]},
		{"command":[ "SETCHARA", "0", "char_00001801_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「次はどうしますか？　グリムロックさん……よろしかったら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_010023120003" ]},
		{"command":[ "SETCHARA", "0", "char_00022101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「えっ、あっ、わ、私……？　でも、私は……やっぱり、いいかなって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010023120003" ]},
		{"command":[ "SETCHARA", "0", "char_00001801_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「えっ？　どうしてですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_010023120004" ]},
		{"command":[ "SETCHARA", "0", "char_00022101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「それは……私には、もう別にちゃんと思いを誓った人がいるから……本当の\n花嫁にはなれないし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010023120004" ]},
		{"command":[ "SETCHARA", "0", "char_00001801_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「グリムロック……そうね、貴方は……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010023120005" ]},
		{"command":[ "SETCHARA", "0", "char_00000214_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「もちろん、私だって人並みに花嫁衣装を着てみたいって気持ちはあったけど\n……でも、私なんか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010023120005" ]},
		{"command":[ "SETCHARA", "0", "char_00001801_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「そんなこと……ないですよ。グリムロックさん……とてもお綺麗です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_010023120005" ]},
		{"command":[ "SETCHARA", "0", "char_00022101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「そうですとも。それに、相手を花婿と見なさなくても勝負は挑めます。要は\nトゥンクポイントを上げればいいのです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023120009" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「トゥンクポイント……心を動かせばいいってことだよね？　フ……フフフ…\n…！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010023120006" ]},
		{"command":[ "SETCHARA", "0", "char_00001801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お、おい、グリムロック……何を笑って……ひっ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「なら、これで少しは感情が揺さぶられるんじゃないかなぁ～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010023120007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ひぃっ！？　銃を突きつけるなっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「フフ……花嫁じゃなくても、私の専属の部下にしてもいいし……私のことを\n選んでくれないと不幸になっちゃうかもよ～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010023120008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「あーっと、これはトゥンクポイントが違う形で急上昇！　４万、５万っ、６\n万８千まで伸びていったーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023120010" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「こういうパターン、アリなのかよ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「動揺するのが悪いのです。落ち着いて対処すれば問題ないかと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110023120005" ]},
		{"command":[ "SETCHARA", "0", "char_00000514_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「銃口向けられて冷静でいられるやつがあるか！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「そもそも、もう一人の男をチラつかせるとか、ブライド時空の設定はどこへ\n行ったんですかね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110023120006" ]},
		{"command":[ "SETCHARA", "0", "char_00000514_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「都合のいいところだけを抽出する。それもブライド時空の醍醐味です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023120011" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「むぅ……グリムロック、やはり強敵か……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010023120006" ]},
		{"command":[ "SETCHARA", "0", "char_00000214_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「さてさて、しかしまだ展開は分かりません。ここで、残ったのは新進気鋭の\nアン＝クァー選手！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023120012" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「一体、どんな決め台詞を用意しているのか……と、思いましたが何やら浮か\nない表情ですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110023120007" ]},
		{"command":[ "SETCHARA", "0", "char_00000514_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「わたくしも……旦那さまに、愛の告白をしたいです……でも、今のわたくし\nにその資格はありませんから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_010023120006" ]},
		{"command":[ "SETCHARA", "0", "char_00022101_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「それは、どういう……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「わたくし……花嫁衣装を持っていないんです。その、ちょうどいいサイズが\n見つけられなくて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_010023120007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「あ、あー、それはですな、その、いろいろと大人の事情と言いますか。アン\n殿は大変スタイリッシュであられますし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023120013" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「なんで、貴方がまごまごしてるんですか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110023120008" ]},
		{"command":[ "SETCHARA", "0", "char_00000514_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「この星の花嫁衣装という存在に、わたくしはすごく憧れていました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_010023120008" ]},
		{"command":[ "SETCHARA", "0", "char_00022101_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「出来ることならば、素敵な衣装を身に着けた上で……ちゃんと告白したかっ\nた……ぐすっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_010023120009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あっ……ちょ、ちょっとアンちゃん、泣かないで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010023120007" ]},
		{"command":[ "SETCHARA", "0", "char_00000214_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「そ、そうだよ。気持ちは分かるけど、資格がないなんてことは全然……今の\nドレスも十分魅力的だし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010023120009" ]},
		{"command":[ "SETCHARA", "0", "char_00001801_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうだ。何も気にすることはねぇ。花嫁衣装なんかなくたって、花嫁にはな\nれる！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「旦那さま……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_010023120010" ]},
		{"command":[ "SETCHARA", "0", "char_00022101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「大事なのは気持ちだ。それをしっかりと伝えられるかどうか……だろ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「は、はいっ……ありがとうございますっ！　わたくしっ……旦那さまのこと\nを……お慕い申し上げておりますっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_010023120011" ]},
		{"command":[ "SETCHARA", "0", "char_00022101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「例え、知り合ったのは後であっても、皆さんに負けないくらいっ……旦那さ\nまのことが大好きですわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_010023120012" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「おぉ、何だか私まで柄にもなくグッと来てしまいましたぞ。こんな企画で、\nここまで感情を揺さぶられるとは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023120014" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「それより、トゥンクポイントを見るのです。これは……ポイントが振り切れ\nている！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110023120009" ]},
		{"command":[ "SETCHARA", "0", "char_00000514_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「あーっと！　これは、すごい数字が出ている！　１万、１０万の桁も越えて\nっ……機械がオーバーヒートしたぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023120015" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「あーっと、ご主人、完全に顔が緩みきっている！　自覚があるのか、必死に\n顔を隠してますがバレバレです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023120016" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「しまった……！　女の子の涙……！　タイミングを完璧にすれば、これ以上\nの効果はない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010023120008" ]},
		{"command":[ "SETCHARA", "0", "char_00000214_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「その手があった……！　私もそっちを狙っておけば……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010023120010" ]},
		{"command":[ "SETCHARA", "0", "char_00001801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「……ぐすっ、カツマ……お願い……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010023120009" ]},
		{"command":[ "SETCHARA", "0", "char_00000214_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「くすん……カツマくん……その……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010023120011" ]},
		{"command":[ "SETCHARA", "0", "char_00001801_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……いや、今更泣き落としに入られてももう無理だからな？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「なんでっ！　幼馴染の絆はどこに行ったの、カツマ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010023120010" ]},
		{"command":[ "SETCHARA", "0", "char_00000214_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「や、やっぱり、不幸になってもらうしか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010023120012" ]},
		{"command":[ "SETCHARA", "0", "char_00001801_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「あーっと、ここでタイムアップ！　このセットでの勝者は、純粋な涙を決め\n手にしたアン＝クァー選手になりました！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023120017" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「小細工抜きの正直な思いだったからこその、メーター振り切りでしょう。お\n見事と言わざるを得ませんね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110023120010" ]},
		{"command":[ "SETCHARA", "0", "char_00000514_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あ……えっと……い、いいんでしょうか。でも……旦那さまのお側にいられ\nるなら……とても嬉しいです……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_010023120013" ]},
		{"command":[ "SETCHARA", "0", "char_00022101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「くぅーっ！　男なら一度は言われてみたいセリフですなぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023120018" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ちゃっかり腕に抱きついて、なんだかんだで、あざといですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110023120011" ]},
		{"command":[ "SETCHARA", "0", "char_00000514_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「なお、グリム殿と、アン殿の衣装については、遅れておりますが、準備を進\nめておりますのでどうぞご期待下さい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023120019" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「誰に言ってるんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110023120012" ]},
		{"command":[ "SETCHARA", "0", "char_00000514_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ともあれ、アン＝クァー殿の勝利に盛大な拍手を！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023120020" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ふふっ、旦那さま……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_010023120014" ]},
		{"command":[ "SETCHARA", "0", "char_00022101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「うぅっ……カツマぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010023120011" ]},
		{"command":[ "SETCHARA", "0", "char_00000214_01", "4", "CENTER", "0" ]},
