{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「そなたを呼び出したのはほかでもない。今から、我のメンテナンスをするの\nである」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0503101" ]},
		{"command":[ "SETCHARA", "0", "char_00002005_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「た、たしかに定期メンテナンスは済ませたであるが……それとは別に、我に\n必要なことなのである」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0503102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「さあ、服を脱ぐのである。このメンテナンスには、男は裸でなければならな\nいのである」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0503103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「そうしたら、その……我の乳首を見るのである。我の意に逆らい勃起してい\nるこの乳首に、オシオキをしてほしいのである」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0503104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「ほら、我が乳首を晒し、そなたの自由にしてよいと言っているのである。そ\nなたは言う通りにすればいいのである！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0503105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「んっくぅっ！　さっそく、乳首をつまんで……んふぅ、もっと、強くしても\nいいのである……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0503106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00002005_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「ふぅ……。そ、そうである……。はぁ、はぁ……指で、勃起乳首を転がすよ\nうに……んっ、くぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0503107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「な、なかなか上手であるな……。そなたの指……んふぅ、硬くなった乳首を\n……しごいて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0503108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「はぁっ、あっ、ああんっ！　乳首、つまみながら、引っ張られたら……っ！\n　んっ、んふぅうっ、はぁっ、くぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0503109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「胸が、ビリビリ痺れるような、アアッ、異常な信号が広がるのである……っ\n！　んくぅっ、ジンジン、疼くので、ある……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0503110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「ああっ、我のデカ乳首ぃっ！　んっ、んふぅっ、そなたに、オモチャのよう\nに弄ばれ……ああっ、んくぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0503111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「乱暴に、こねくり回されぇ……んふっ、くぅうっ、き、気持ちよくなってし\nまうのである……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0503112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁっ、快感の信号が、我の回路を駆け巡っているのである……！\n　た、耐えられない……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0503113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「限界である……乳首っ、乳首で……んひっ、イクッ、イッてしまう……ああ\n……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0503114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「乳首を、か、下等な人間の指で好き放題弄ばれ……イク……ッ！　こ、この\n我が……ああ……イッてしまう……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0503115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「んぁあああぁぁぁっ！　んはぁっ！　ああっ、ンッ、あっ、あああぁぁぁあ\nあぁぁっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0503116" ]},
		{"command":[ "SETIMAGE", "0", "still_00002005_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……。イッてしまったのである……。そなたの指……なかなか\n、よかったのである……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0503117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「それで……。そなたはどうしてチンポを勃起させているのであるか？　我に\nオシオキをしながら、興奮したとでも？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0503118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「ほう……そのチンポを使って、我の胸にオシオキをしたいと言うのであるな\n……。ふふ、いいのである」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0503119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「我を乳首だけでイかせた褒美である。我の胸を使い、パイズリすることを許\n可するのである」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0503120" ]},
		{"command":[ "SETIMAGE", "0", "still_00002005_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「んふぅっ！？　そ、そなたの狙いは、我の乳首であるか……っ！　んはぁっ\n、あっ、んんぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0503121" ]},
		{"command":[ "SETIMAGE", "0", "still_00002005_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「ぼ、勃起乳首に、チンポを擦りつけて……ああっ、熱いのである！　火傷し\nそうなのである……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0503122" ]},
		{"command":[ "SETIMAGE", "0", "still_00002005_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「ああっ、我の乳首に負けず劣らず、そなたのチンポも硬いのである……。ア\nアッ、乳首が、亀頭に弾かれる……んっくぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0503123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「ああっ、んっ、ふぅうっ……。感じてしまうのである……乳首に擦れるチン\nポで……気持ちよくなってしまうのである……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0503124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「そうやって、エラの部分でゴシゴシと乳首をこすって……んっ、はぁんっ！\n　異常な発声を、してしまうのである……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0503125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「それにしても、そなたは我の想像以上の変態であるな……。我の乳首を責め\nながら、ますますチンポを硬くしているのである……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0503126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「激しく腰を振って、ああっ、チンポで乳首を犯すように……んっ、んふぅっ\n、はぁあんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0503127" ]},
		{"command":[ "SETIMAGE", "0", "still_00002005_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「射精が近いのであるか……？　強がっても、我に備わったセンサーがそなた\nの射精が近いのを察知しているのである」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0503128" ]},
		{"command":[ "SETIMAGE", "0", "still_00002005_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「このまま射精してしまえばいいのである。射精することを許可してやるので\nある」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0503129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「我の乳首を、そなたが射精するために使うがいい。んふぅ、思いっきりザー\nメンを吐き出せばいいのである」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0503130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「んふぅっ、ああっ、もっと我の乳首っ、チンポでしごいてっ、あっ、んっく\nぅっ、はぁっ、ああぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0503131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「また、イかされてしまうのである……！　乳首っ、い、イク……ッ！　あっ\n、ああっ、んっく、はっ、はぁあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0503132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「んぁあっ！　あっ、あはぁあっ、あああぁぁぁああぁぁっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0503133" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002005_01_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「そなたのチンポも、イッてるのである……！　精液が、我の胸にびちゃびち\nゃとかかっているのである……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0503134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「は……鼻のセンサーがエラーを起こしそうなほどの、いやらしい臭いである\n……んふぅ……くぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0503135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「胸が……乳首が……ドロドロのザーメンまみれ……。んはぁ……肌が白く染\nめられるのである……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0503136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「ああ……我も、イッた……。乳首をそなたのチンポでズリズリ責められて、\nイッてしまったのである……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0503137" ]},
		{"command":[ "SETIMAGE", "0", "still_00002005_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「乳首が気持ちよすぎて……回路がショートを起こしたようである……んふぅ\n……まさかこれまでとは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0503138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「にしても、そなたのチンポは硬いままであるな？　まだまだ射精し足りない\nようなのである」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0503139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「我も、まだまだそなたによるメンテナンスが必要である。乳首は重要な器官\nであるから、じっくりと念入りに頼むのである」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0503140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「んっふぅっ！　精液にまみれた乳首を、強く引っ張りながら……はぁ、はぁ\n、またチンポを動かして……んくぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0503201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「精液で、ヌルヌルになったチンポがぁ……我の乳首を、あんっ、こすってい\nるのである……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0503202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、んふぅ……。そうやって、乳首を責められると、また身体が過\n剰に反応してしまうのである……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0503203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「はうぅ、あぅ、んふぅうっ。もっと……もっと動いて……チンポで我の乳首\nを、メンテナンス、するのである……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0503204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「はふぅっ、あぅっ、んっ、んふっ！　乳首をさらに強く、んぁっ、乳首潰れ\nるくらいっ、ぎゅっと……んぉっ、おおぉんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0503205" ]},
		{"command":[ "SETIMAGE", "0", "still_00002005_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「つまんで、ぐりぐりって……んっくぅっ！　それ、いいのである……気持ち\nいいのである……！　はぁ、はぁあんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0503206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「我の……デカ乳首……。んふぅ……いやらしい乳首である……。こんなにさ\nれて、気持ちよくなってぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0503207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「我の身体に、このような機能は必要ないはずなのに……んふぅっ、はぁ、は\nぁ……乳首ぃ……イクッ、イク……ッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0503208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「んぁあっ！　はぁっ、ああっ、あああぁぁぁっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0503209" ]},
		{"command":[ "SETIMAGE", "0", "still_00002005_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「ま、また……乳首を責められただけでイッてしまったのである……。はぁ…\n…はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0503210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「そうであるな、今度はそなたの番である。そなたがイク様を、我に見せる番\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0503211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「んぁあっ、あはぁあっ、乳首ズリ……んっ、んひぃいっ！　熱いヌルヌルチ\nンポが、我の……乳首を……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0503212" ]},
		{"command":[ "SETIMAGE", "0", "still_00002005_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「ザーメンのぬめりに任せて、チンポが乳首の間を出入りしているのである…\n…！　な、なんていやらしい光景……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0503213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「我の乳首が……そなたの性欲を処理するために使われているのである……！\n　こ、このまま、射精するのである……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0503214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「我の乳首を好き放題チンポで犯し、精液を放って我のことを汚すのである…\n…！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0503215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「んはぁあ……っ！　わ、我もまた、イキそうになっているのである……！　\n絶頂のスパンが短くなっているのである！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0503216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「そなたのチンポでまたイク……！　乳首責められて、またイッてしまうので\nある……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0503217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「んひっ、ひぃっ、乳首……イク、イク……ッ！　デカ乳首イかされる……ま\nた、イかされるのである……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0503218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「ああっ、そなたも我の乳首でっ、射精を……精液を、またいっぱい、放つの\nである……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0503219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「い、イクのである……！　今度は、我と一緒に……我の乳首と一緒に、チン\nポもイッて……イクのである……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0503220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「んはぁあっ！　ああっ、ああぁぁああぁぁぁ～～～っ！！　また精液が……\n我の、胸にぃいいぃぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0503301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002005_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「んぁああっ！　はぁああっ！　脈打って、胸に精液をびゅくびゅく放ってい\nるのである……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0503302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「イクッ、イクッ、イッてしまう……！　胸で精液を受け止めて、絶頂が……\n何度も訪れているのである……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0503303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「んはぁっ、はぁ……はぁ……んぅ……、んふぅ……くぅ……はぁ……んんぅ\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0503304" ]},
		{"command":[ "SETIMAGE", "0", "still_00002005_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「や、やっと射精も落ち着いたようであるな……。二度目だというのに、これ\nほどの量を放つなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0503305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「量だけでなく、濃さも一度目と大差なく……。我は、そなたの性欲を見誤っ\nていたようである……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0503306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「わ、我のエロ乳首が気持ちよかったのであるかっ？　くっ、どさくさにまぎ\nれて侮辱されている気がするのである」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0503307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「乳首が敏感なのは、ここが重要な器官だからに違いないのである！　でなけ\nれば、このようにイクこともないのである」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0503308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「こうなったら、今度は我がそなたにオシオキをするのである。乳首を使った\n責めで、そなたをイかせるのである」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0503309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「ふふん、なにかを期待してヒクつくそなたのチンポ……めいっぱい責めてや\nるのである」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0503310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「んふぅううっ！　ああっ、ああっ、顔に……！　んやっ、やめるのであるっ\n、精液、そんなに……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0503401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002005_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「んぁっ、ああっ、そんな……顔面に、精液を浴びて、イクなんて……んふぅ\nっ、はぁ……んぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0503402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「顔も胸も、精液でドロドロである……。はぁ……はぁ……。このようなこと\nで、快感を……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0503403" ]},
		{"command":[ "SETIMAGE", "0", "still_00002005_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「二度目だというのに、ねっとりと重たい精液をぶっかけられて……はぁ……\n快感を得てしまっているだなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0503404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「んふぅ……そなたのチンポはまだビクついて……残った精液が先端から垂れ\nているのである……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0503405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「なんてスケベな光景であるか……。はぁ……それを見て、我もなにやら、下\n半身に疼きを生じさせてしまうのである……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0503406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「まったく……このような機能、どうして我に備えられているのか理解に苦し\nむのである」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0503407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「エロいからもんだいない、であるか？　……そなた、さてはただの変態であ\nるな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0503408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「しかし、変態でもそなたのメンテナンスの腕は確かであるから、そばにおい\nてやるのである」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0503409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「これからも、我のメンテナンスをよろしく頼むのである」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0503410" ]},
		{"command":[ "WAITINPUT" ]},
