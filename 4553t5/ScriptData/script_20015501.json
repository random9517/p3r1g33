{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0101" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_011" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「まったくお前という奴は……聞いているのか、カツマ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010023580001" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はい、はい。聞いていますってば」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「聞いていないだろう……まったく、もう一度読み上げるぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010023580002" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「『話しているときに胸をガン見された』『すれ違った後に振り返るとお尻を\n見られてる』『衣装を見る目がなんかエロい』」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010023580003" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「これらのクレームはカツマ、お前に関するものだ。まだまだあるぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010023580004" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「『トレーニングしているといやらしい視線を感じる』『水着でいたらねっと\nり見られた』『私ならカツマさんに全部見られてもいいのに』む、これは違う\nな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010023580005" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「『下僕のくせに最近生意気だ』『すれ違ったと思ったら後ろ姿を見てるのを\nやめてほしい』『とにかく目がエロい』とまあこんなのが山ほどあるんだが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010023580006" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや……はははは。だって、仕方ないじゃないですか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「水着とか水着以上の露出とか、下着とか、なんならタオル１枚とかで歩いて\nる奴もいるんですよ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「男としてそこに視線が吸い寄せられるのはごく自然というか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「仕方ないわけがなかろう。昨今はコンプライアンスに厳しい。今後こういう\nことは控えろ。いいな？　罰として１ヶ月の清掃による奉仕活動を命じる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010023580007" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「えぇぇっ！！　長官だってリモートだと下はパンツ１枚とかやってるじゃな\nいですか！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「お前……減俸もされたいのか？　お前の安月給を削るのはさすがに可哀想だ\nからと私が被害者を説得してやったんだが、そうか、減俸もお望みか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010023580008" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あわわわわわっ！！　やります！！　やらせていただきます！！　反省の意\nを込めて、誠心誠意清掃活動をしますっ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「……キジも鳴かずば撃たれまいに」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023580001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うるせえっ！！　お前だって美人の尻をじっと見てるの知ってんだからな！\n！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「いやいやご主人、私は視点が低いからして、自然とそこに目線がいくのであ\nって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023580002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「奉仕活動にはジュンジローも参加するように」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010023580009" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「私もまたキジでありましたな……ご主人」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023580003" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「知的な雰囲気出してんじゃねえよ。どう考えても自業自得だろ……お互いに\nな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「言っておくが、次は本気で減俸にするからな。そうなりたくなければ、真面\n目に奉仕活動を――むっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010023580010" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「本部か！？　救援を求む！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010023580001" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「どうしたブルー！？　状況を説明しろ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010023580011" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「とにかく救援を！！　このままでは……ううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010023580002" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「おいブルーっ！！　ブルーっ！！　応答しろ！！　くそっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010023580012" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ブルーが救援要請って……今日の演目戦闘にそんなシナリオありましたっけ\n？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「……今日の戦いはデモンストレーションの演目戦闘ではなく、実利を賭けた\nガチファイトの方だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010023580013" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「え……それってつまり……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「本気の戦闘で危機に陥っているということですな。あのブルー殿が」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023580004" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「マジかよ……あいつは演目ですら相手を瞬殺するほど全力全開の本気の女な\nのに」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ともあれ、状況が分からんが救援要請には違いない。ブルーは採石場で戦っ\nているはずだ、カツマ、向かってくれ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010023580014" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「アイアイサー。ジュンジロー、行くぞ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「合点ですぞご主人」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023580005" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0022" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ここか……ブルーはどこだ？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人、あちらの方から戦闘の匂いが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023580006" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「よし、行くぞ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「ハァ……ハァ……くっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010023580003" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "4", "CENTER", "0" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_010023580001" ]},
		{"command":[ "SETCHARA", "0", "char_00027401_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「この……でやああああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010023580004" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_010023580002" ]},
		{"command":[ "SETCHARA", "0", "char_00027401_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「ぐうううっ、なぜ当たらないっ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010023580005" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あれが今日の相手か……なかなか豊満な身体……じゃねえ、なかなか強そう\nな相手だな」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00027401_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「あれほど釘を刺されたのに……ご主人が減俸されるのもそう遠くはありませ\nんな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023580007" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「それよりもブルーだ。苦戦しているみたいだが……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「苦戦というか……様子がおかしくないですかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023580008" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「はああああっ！！　くそっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010023580006" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「氷も出してないし、それに攻撃も……なんかふらふらしてるな」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "4", "CENTER", "0" ]},
		{"command":[ "MOVECHARA", "0", "CENTER", "-200", "NORMAL" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "MOVECHARA", "0", "CENTER", "200", "NORMAL" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "MOVECHARA", "0", "CENTER", "0", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「まるで徹夜残業明けのご主人のようにおぼつかない足取りですな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023580009" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お前は一言多いんだよ……あの怪人も攻撃を避けているというよりは、ブル\nーが勝手に外してるような感じだしな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「くそっ、ちょこまかと……こうなったら一気に決める、奔れ蒼氷――ざ……\nん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010023580007" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA","1"]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あっ、倒れた……と思ったら、怪人の触手で支えられてる……？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "4", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "SETCHARA", "1", "char_00027401_01", "1", "CENTER", "-1500" ]},
		{"command":[ "MOVECHARA", "0", "CENTER", "400", "NORMAL" ]},
		{"command":[ "MOVECHARA", "1", "CENTER", "0", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「触手じゃなくて蔦ですね～。私、木の怪人ですので～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_010023580003" ]},
		{"command":[ "SETCHARA", "1", "char_00027401_01", "1", "CENTER", "0" ]},
		{"command":[ "MOVECHARA", "1", "CENTER", "-400", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「どうなってんだ一体……とりあえず、そっちに行っていいか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「ええ、どうぞ～。こうなったらガチバトルもなにもありませんし～。はい、\nブルーさんをどうぞ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_010023580004" ]},
		{"command":[ "SETCHARA", "1", "char_00027401_01", "6", "CENTER", "-400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「助かる……っていうか凄い格好だなお前。いやまあ俺はそういうの大好きだ\nけど」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「お前じゃなくてフライアです～。よろしく～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_010023580005" ]},
		{"command":[ "SETCHARA", "1", "char_00027401_01", "8", "CENTER", "-400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0"]},
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「うう……私はまだ戦える……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010023580008" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "7", "CENTER", "400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや傍目から見てもふらふらだったじゃねえか……っていうか熱っ！！　お\n前これ、熱があるだろ！！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "4", "CENTER", "400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA","1"]},
		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「ちょっとおでこ失礼しますね～、あ～、これは完全に発熱ですね～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_010023580006" ]},
		{"command":[ "SETCHARA", "1", "char_00027401_01", "3", "CENTER", "-400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「らしくないバトルはこれが原因か……フライア、悪いが今回のガチバトルは\nノーコンテストでいいか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「構いませんよ～。こんな状態で勝ってもガチではありませんから～」", "NORMAL" ]},
