		{"command":[ "SETCHARA", "1", "char_00027401_01", "6", "CENTER", "-400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「助かる。再戦の日程はＥＤＯから連絡するようにしておくから。それじゃジ\nュンジロー、俺はブルーを背負うから、お前は長官に報告だ。よいしょ……っ\nと」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「あら～。隊長さんったら急に真剣な顔に～。ブルーちゃんの具合はそんなに\n悪いのかしら～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_010023580008" ]},
		{"command":[ "SETCHARA", "1", "char_00027401_01", "4", "CENTER", "-400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA","0"]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「いえ、アレは背中に当たるブルー殿の胸に全神経を集中させている顔ですな\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023580010" ]},
