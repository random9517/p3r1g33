		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「くぅぅっ……は、離せっ……一体何をするつもりだ……んくっ、あっ、うく\nっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0304101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「こ、このような……んくぅっ、拘束をして……卑怯だぞっ……恥ずかしいと\n……思わないのかっ……んっ、くっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0304102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「な……は、恥ずかしいのは……どっちだとは……ど、どういう意味だ……ん\nっ、あっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0304103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あっ、んぁっ、や、やめろっ……そんなところっ、あっ、んくぅっ、さ、触\nったら……は、ひっ、あっ、んんんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0304104" ]},
		{"command":[ "SETIMAGE", "0", "still_00016703_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「指……んひっ、あっ、あぁっ、中に入ってきてるっ……あっ、ダメだ、そん\nな場所はっ……あっ、あぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0304105" ]},
		{"command":[ "SETIMAGE", "0", "still_00016703_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「ど、どこって……んくぅっ、何を言わせようとしているっ……んんっ、あっ\n……あひっ、か、かき混ぜるなぁっ、んぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0304106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「わ、分かった……いうっ、オ、オマンコだっ……！　そんなにオマンコをか\nき回さないでっ、んくぅっ、んぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0304107" ]},
		{"command":[ "SETIMAGE", "0", "still_00016703_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「気持ちいいなんてっ、それはっ、あっ、指でっ……あっ、あぁっ、弄られた\nらっ……自然に身体がっ、反応して……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0304108" ]},
		{"command":[ "SETIMAGE", "0", "still_00016703_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あっ、あぁんっ、ダメだっ、汁が溢れるっ、んんっ、出ちゃうっ、あひっ、\n指だけでっ……んぁぁぁっ、イ、イクッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0304109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はぁ、あっ、潮がっ……ひっ、やめっ、続けて吹かせないでくれっ……あっ\n、あぁっ、ま、まだ出るっ、あっ、お潮……漏れるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0304110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あふっ……あぁ……こんなに、感じてしまうなんて……はぁ、はぁ……私は\n一体……んっ、んくっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0304111" ]},
		{"command":[ "SETIMAGE", "0", "still_00016703_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あひっ！　こ、今度はオチンポ……？　うぐっ……それが、んっ、ど、どう\nした……するんだったら、一思いにすればいいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0304112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「例え、私の身体が屈しても心までは……んっ……な、なぜだ……なぜ……入\nれない……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0304113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「じ、自分から……おねだり……な、何を言って……こんな状況で、私が、そ\nんなことをするとでもっ……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0304114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「や、やめろ……オチンポで、そんなに入り口をくすぐられたらっ……あっ、\nんんっ、はっ、んくぅっ、あっ、ひっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0304115" ]},
		{"command":[ "SETIMAGE", "0", "still_00016703_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あっ、また出る……汁が漏れちゃうっ……あひっ、あっ、んぁっ、で、出る\nぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0304116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……ぁ、ふっ……わ、分かった……分かったから……頼む……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0304117" ]},
		{"command":[ "SETIMAGE", "0", "still_00016703_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「ちゃんとおねだりするから、これ以上焦らさないでくれっ……入れて……中\nに入れてくれっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0304118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「だ、だから……私の……いやらしいオマンコに……貴様の……太くて、硬い\nっオチンポをっ……思いっきりハメてっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0304119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「ぐちゃぐちゃになってる奥深くまで突っ込んでっ、オマンコの中っ、オチン\nポでいっぱいズボズボさせてぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0304120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んぁぁぁぁんっ！　あっ、あぁぁぁっ、入ってくるぅっ……！　太いオチン\nポッ、あぉぉっ、中にっ……来てるぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0304121" ]},
		{"command":[ "SETIMAGE", "0", "still_00016703_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あっ、あぁぁぁっ！　これはダメだっ……あっ、こんなっ、あっ、一番深い\nところにっ……あっ、一気に押し込まれたらっ、ひぁっ、あぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0304122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「い、いやらしい音っ……あっ、それは……あっ、あんなに指で……かき混ぜ\nられて……そ、その気にさせられてぇっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0304123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「は……んんっ、今度は……もっと太いオチンポなんて……あっ、あぁっ、そ\nんなのっ、あっ、声が……我慢できるわけっ、ないっ、んひぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0304124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あっ、あぁっ、し、子宮にっ……当たってるっ！　亀頭が……奥にグリグリ\nっ……当たってっ！　あひっ、硬いのっ……擦れてるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0304125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んぁっ、あぁっ、も、もっと締め付けを？　そんなことを……言われてもっ\n、あ、あひんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0304126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「わ、分かったっ……するからっ、お尻を打つのはやめろっ……んぐっ、ふっ\n、んくぅぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0304127" ]},
		{"command":[ "SETIMAGE", "0", "still_00016703_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「くぅっ……あぁっ、こ、これで……どうだっ？　んんっ、あぁっ、締め付け\nると……オチンポが……あっ、めり込むぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0304128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あぁ……お、お尻……さするなぁ……お、おかしくなってしまうっ……あぁ\nっ、わけがわからなくなるっ、あひっ、あっ、んぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0304129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「まっ、またオチンポッ、深くぅっ！　んぁくぅっ……ダメッ……あっ、そこ\nも弱いからぁっ、あ、あひぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0304130" ]},
		{"command":[ "SETIMAGE", "0", "still_00016703_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あぁっ……なぜ……こんなに弱点を知り尽くしてっ……んくぅっ、い、いや\n、耐えねば……あくっ、んぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0304131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「くぅぅ……あぁっ、やめろっ……身体を揺らさないでくれっ……はぁんっ、\nあっ、胸が……揺れてっ、あ、あひぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0304132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はぁんっ、あっ、は、恥ずかしいっ……乳首が揺れてっ、あぁっ、いやらし\nい音が響いてっ、オ、オマンコッ……感じてぇっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0304133" ]},
		{"command":[ "SETIMAGE", "0", "still_00016703_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あぁっ、イクッ……イッてしまうっ！　あひっ、オチンポズボズボされてっ\n、んぁぁぁっ、イ、イクぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0304134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あぁぁぁぁっ……！　で、出てるっ……！　射精……されてるっ、ザーメン\nっ……いっぱい中出し……来てるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0304135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016703_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はぁぁ……あぁ……熱い……子宮に届いてしまう……あぁ、こんな……囚わ\nれの身で……孕んでしまうなんて……はぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0304136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あぁぁ……中がいっぱいにされていく……ドプって流れて来るの……んくぅ\nぅ……あ、あぁぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0304137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んぁっ、ま、まだ……止まらないのか……いつまで射精する気なんだ……は\nぁぁ……あっ、んふぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0304138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……はぁ……んんっ、あぁ……お、終わった……のか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0304139" ]},
		{"command":[ "SETIMAGE", "0", "still_00016703_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「イ、イッた……感想など……べ、別にないっ……こ、これ位のことで、私を\nどうにか出来たなどと思わないことだっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0304140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「まだ余裕がある……？　ど、どういうつもりだ。もう十分満足しただろう…\n…さっさと……あ、ひっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0304201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「まさか……まだする気なのか？　あっ、あぁっ……！　また、中でオチンポ\nが……大きくっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0304202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あ……あぁぁっ、入って来る……また、オマンコが……い、いっぱいになっ\nて……んくぅぅんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0304203" ]},
		{"command":[ "SETIMAGE", "0", "still_00016703_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あぁっ、身体の自由が効かないことが……こ、こんなにもおかしくさせると\nは……くぅぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0304204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んっ、ど、どうした……う、動かないのか……？　また、私を責め立てて楽\nしむつもりなんだろう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0304205" ]},
		{"command":[ "SETIMAGE", "0", "still_00016703_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「た、楽しんでいるのは……私？　ば、馬鹿なことを……んあっ……こ、ここ\nに来て焦らすつもりなのか……？　んくっ、こんな、ゆっくり……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0304206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はぁっ、んっ……あぁ……な、なぜだ……こんなに、遅いのに……あっ、あ\nひっ、オ、オマンコが敏感になって……あっ、んぁっ、あぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0304207" ]},
		{"command":[ "SETIMAGE", "0", "still_00016703_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んくう……せ、精液が……私の身体を支配している……？　そんな……馬鹿\nなことが……あっ、あくっ、んぁぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0304208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はぁぁ……だ、だが、このオチンポの感じは……んくぅ……襞が擦れる度に\n、ジンジン痺れて……うくぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0304209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「そんな、こ、こんなに敏感になるなんて……あ、あひっ、ひぃっ！　なっ…\n…こ、ここから本気で……？　ま、待て……それはっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0304210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あ、あぉぉぅっ！　また、本気オチンポッ、く、来るぅっ！　あっ、あぉっ\n、おぉっ、おほぉっ、ズボズボッ……されるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0304211" ]},
		{"command":[ "SETIMAGE", "0", "still_00016703_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はっ、んっ、あぁ……か、かき回すなぁ……あっ、ひっ、ぐちゅぐちゅっ…\n…させるなっ、んぁっ、あぁぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0304212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あひっ、あんっ、はっ、あぁぁんっ、す、好きだなんてっ、そんなことっ…\n…！　あっ、オチンポッ……止まらないっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0304213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あっ、あひぉっ、だっ、ダメっ、イクッ！　あぁっ、中をズボズボされてっ\n……ひぃんっ、オマンコイクぅぅぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0304214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あっ、あぁっ、も、もうイッてるっ！　オマンコイッてるのにっ、ま、まだ\nっ、かき混ぜられてぇっ、あひぉっ、あっ、あぁっ、おかしくなるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0304215" ]},
		{"command":[ "SETIMAGE", "0", "still_00016703_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あぁっ、そうだっ、私は負けたっ……敵に捕らえられてっ、オチンポで躾け\nられてっ、身も心も屈服してっ……全身オマンコになってしまっているっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0304216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「だ、だからっ、あひっ、もっとグリグリしてっ！　いやらしいアーマーで男\nを誘う、はしたない女騎士のオマンコを躾けてくれぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0304217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んぁっ、き、気持ちいいっ！　あぁっ、こんなっ、あぁっ、オチンポされた\nらぁっ、またイクッ……ダメになってしまうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0304218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はぁぁんっ！　オチンポも震えてっ、ま、また……射精したくなってるのか\nっ！？　あっ、あぁっ、わ、私もっ……また我慢がっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0304219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あぁっ、もう何でもいいっ！　貴様の好きなようにしてっ、どこでもいいか\nらっ、射精してくれぇぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0304220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あひぃぃぃぃぃんっ！　またっ……中にっ……あっ、出てるっ！　濃い精液\nがっ、ぶぴゅって出てるぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0304301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016703_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はぁぁ……イクッ！　またイクぅッ！　はひぃんっ、オマンコッ、ずっとイ\nッてるぅぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0304302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んぁっ……はぁ、はぁ……はぁっ……あっ、ふっ、あぁ……熱い……子宮の\n奥に、着床した子種が……中で泳いでるみたいだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0304303" ]},
		{"command":[ "SETIMAGE", "0", "still_00016703_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んふぅ……あ、ふっ……はぁ、はぁ、はぁ……主殿……そ、その、私は……\nあんな風に乱れてしまったが、決して本当に屈するつもりはないからな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0304304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「私が絶対服従しているのは主殿だけであって……だから、結局このような趣\n向の中でも、主殿にだけ恥ずかしい姿を晒したのだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0304305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「えっ……き、気持ちよかったか……そ、それは、その……確かに味わったこ\nとのない……すごい、快感だった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0304306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「自分の身体が拘束されてしまうだけで、こんなにも……その、違うとは思わ\nなかった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0304307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「え……ま、また……？　それは、その……まぁ、主殿が求めるのであれば…\n…わ、私としても……応えぬ訳にはいかぬだろうな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0304308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「うぅっ……恥ずかしい。主殿に、私の知らない淫らな一面をどんどんと開発\nされてしまっていく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0304309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「だが、それを求めてしまっている自分がいる……あぁ……主殿……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0304310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んぁぁぁぁぁぁんっ！　あぁっ、掛けられてるっ！　熱い……精液っ……あ\nぁっ、ぶっ掛けられてるぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0304401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016703_02_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んへぁぁぁ……イクッ！　あぁっ、イクぅッ！　はひぃんっ、オマンコッ、\nずっとイッてるぅぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0304402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あぁ……身体が熱い……精液にまみれて……このにおい……どうにかなって\nしまいそうだ……んふぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0304403" ]},
		{"command":[ "SETIMAGE", "0", "still_00016703_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「ま、まだ出るのか……んんっ、もうどうにでもしてくれ……全身を……ドロ\nドロにしてくれぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0304404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あぁ……気持ちいい……何も考えられない……ヌルヌルにされる感覚……た\nまらなすぎる……んふぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0304405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……あふ……終わった……？　も、もう……普通にしても大丈夫\nなのかな、主殿……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0304406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「うぅ……自分でも、ここまで乱れてしまうとは思わなかった。身体が自由に\nならないせいで、自然に力が入ってしまって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0304407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「それを主殿が巧みにするから……だ、だが、本当に敵に捕らえられたとして\nも、こんな風にはならないぞ。主殿だから……見せる姿なのだからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0304408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「ほ、本当だ。このビキニアーマーだって、主殿の求めがあったからこそ身に\nつけたもので、決して私の趣味という訳では……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0304409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「そ、それはそれとして……そろそろ下ろしてもらえると助かるのだが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0304410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}