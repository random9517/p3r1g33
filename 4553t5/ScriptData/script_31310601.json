{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00013106_01_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「こんなに勃起させて……どうしちゃったんですか？　ねえ、隊長さん……部\n下にチンポ握らせて……変態さんですねー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0603101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「扱いて欲しいって、言ったのはあなたですよ。……もっと優しく？　贅沢な\nこと言わないでください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0603102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「気持ちよくないなら、止めますけど……ねえ？　こんなにチンポ大きくして\n、ヒクヒクさせちゃって……本当にイヤなんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0603103" ]},
		{"command":[ "SETIMAGE", "0", "still_00013106_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「そうですよね～？　感じてますよね～？　こんなに血管浮かび上がらせて、\nチンポ勃起させてますもんね～？　ふふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0603104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「べつに変じゃないです。私はいつもこう……ですよ。おかしな、隊長さんで\nすね……ふふふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0603105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「じゃあ、続けますね。なにがって……チンポですよ。チンポ、シコシコって\nして、気持ちよくするんです……して欲しいですよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0603106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ふふっ……すごく熱くなってますね……ヤケドしちゃいそう。それくらい熱\nいんです。自分でさわってみますか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0603107" ]},
		{"command":[ "SETIMAGE", "0", "still_00013106_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「そうですか、残念。熱いだけじゃなくて、硬いんですよね……いつも、思う\nんですけど不思議ですよね～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0603108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「元はふにゃふにゃしてて、柔らかいのに……血が集まっただけで、こんなに\nなっちゃうんですから……男の人って、すごいですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0603109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「それに、とっても敏感なんですよね？　先っぽとか……ツンツン……♪　ど\nうしました？　鈴口を軽くさわっただけですよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0603110" ]},
		{"command":[ "SETIMAGE", "0", "still_00013106_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「じゃあ、こっちとか……どうですか？　そぉ～～～と……ふふっ、また腰、\n震えてる～……裏筋も感じますか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0603111" ]},
		{"command":[ "SETIMAGE", "0", "still_00013106_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「意地悪なんかしてないですよ。ちゃんとご奉仕するために、どこが感じるの\nか、しっかり確かめてるだけです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0603112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ほら、こうやって指先でカリを擦りながら……竿をシコシコ～って、される\nのどうですか？　感じますよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0603113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ビク、ビクって、震えてますしね……んっ、んっ……どんどん硬くなってる\n……もう鉄の棒みたいですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0603114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ほら、見えますか？　先っぽ……ヌルヌルしてきました……我慢汁が溢れて\nきてますよ？　感じてるんですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0603115" ]},
		{"command":[ "SETIMAGE", "0", "still_00013106_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「……なんですか？　睾丸もさわって欲しいんですか？　ああ、そうでした…\n…キンタマ、でしたね。じゃあこっちも……モミモミ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0603116" ]},
		{"command":[ "SETIMAGE", "0", "still_00013106_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ふふっ、腰跳ねてますよ……？　そんなに気持ちいいんですか？　シコシコ\nしながら、キンタマ揉まれて……感じてるんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0603117" ]},
		{"command":[ "SETIMAGE", "0", "still_00013106_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「さっきより、我慢汁がいっぱい……出てますよ……？　これを竿に塗ってあ\nげますね……そうすれば滑りがよくなるでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0603118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ンっ、ふぅ……ほらぁ……手が我慢汁でヌルヌルしてるから、扱きやすくな\nって……シコシコ～、シコシコ～って……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0603119" ]},
		{"command":[ "SETIMAGE", "0", "still_00013106_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「チンポを、扱きまくってあげますからね……んっ……くちゅくちゅってイヤ\nらしい音させて……ふぅ、んふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0603120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「気持ちいいのはわかりますけど、ジッとしててください。あまり腰を動かす\nと、こっちも手を動かしづらいです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0603121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「な、なんですか……急に……さわらないでください……んっ、胸……大人し\nくしてないと、ご奉仕できませんよ……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0603122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「わかってます、キンタマも揉んであげてるじゃないですか。もうちょっと優\nしく……ですか？　はあ、わかりました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0603123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「チンポは強く扱きながら、キンタマは優しく撫でる……両手を違うリズムで\n動かすのって難しいんですよ？　しかも、邪魔されてるし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0603124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ひゃ、んっ……乳首、ダメだって、言ってるのに……一生懸命、ご奉仕して\nあげてるんですから、ちゃんと感謝してくださいね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0603125" ]},
		{"command":[ "SETIMAGE", "0", "still_00013106_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ワガママな、チンポに……ご奉仕……バキバキに勃起して、反り返ってるチ\nンポはこうやって……激しく扱いてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0603126" ]},
		{"command":[ "SETIMAGE", "0", "still_00013106_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「こっちのキンタマは優しく、なでなで……と……ふふっ、なんか玉袋も硬く\nなってきましたね？　キンタマ、きゅってなってますよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0603127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「イキそうになってるんですか？　気持ちよすぎて……もう我慢できなくなっ\nてきました？　ほら、チンポがヒクついてますよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0603128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ちゃんと、キンタマも揉んであげますから……いっぱい出してくださいね…\n…んんっ、私のことはいいから……は、早く……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0603129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「んっ……我慢汁、ドバドバ出てきて……匂いが……ここまで漂ってきます…\n…スンスン……あー、くさいですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0603130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「興奮してるのは、もう十分わかりましたから……ンっ、ん……射精、してく\nださい……手で搾ってあげますから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0603131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「情けない、とか気にしなくていいから早く……部下にこんなことさせておい\nて、今さら情けないも何もないですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0603132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「チンポ、シコシコ……キンタマ、モミモミ……♪　気持ちいいですね～？　\nはい、このまま出してください……いっぱい出して……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0603133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ん、んっ……出る？　いいですよ……手にかけて……あっ、んっ……あっ、\nあぁあっ！　ひゃぁぁぁぁぁ～～～～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0603134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あっ、あっ……んんっ！　すごいっ……飛び跳ねて……ひうっ！　んっ！　\n精液が……はうっ……んっ……ああ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0603135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00013106_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ま、まだ出てる……こんなに……ひゃっ、また跳ねた……チンポ、すごい動\nいてる……生きてるみたい、ですね……うわぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0603136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「は、はい……驚きました……えっと、私……が……これ……したんですよね\n……？　隊長さんを……射精、させて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0603137" ]},
		{"command":[ "SETIMAGE", "0", "still_00013106_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「いえ、お、覚えてます。ちゃんとわかってますけど……びっくりして、頭が\n真っ白になって……えっと、えと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0603138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「射精、したんですよね？　はは、よかった、です……じゃあ、私はこれで…\n…え、ええ？　もっとですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0603139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ノリノリでって、そういうわけでは……いや、そうだった、かもしれません\nけど……あ、ううっ……わかりました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0603140" ]},
		{"command":[ "SETIMAGE", "0", "still_00013106_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あぁ、もうっ……なんで、あんなに出したのに……ちん、ちん……おちんち\nん……大きくなったままなんですか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0603201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「え？　さっきは……勢いというか……それで、うう……ちんぽ、です……は\nい、ちんぽ……大きくて、硬い……です……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0603202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ご奉仕してるじゃないですか……ほら、握って、扱いて……気持ちいいです\nよね？　んっ……んんっ……もう出そうですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0603203" ]},
		{"command":[ "SETIMAGE", "0", "still_00013106_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ま、まだ……？　え、そう、ですか……わかってます、ちゃんと扱きますけ\nど……うぅ……精液が絡みついて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0603204" ]},
		{"command":[ "SETIMAGE", "0", "still_00013106_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「変な感じじゃないですか？　自分が出した、精液で……ドロドロになって…\n…興奮するんですか？　も、もうっ……本当にスケベですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0603205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ううっ……手を動かしたら、にちゃにちゃって……音がして……確かに、滑\nりやすくなってますけど……そうじゃなくて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0603206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「これが気持ちいいんですか？　んっ……ちん、ぽ……で返事しないでくださ\nい……またヒクヒクいってる……ンンっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0603207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「はい？　キンタマの方……ですか？　えっと……こっちも……あ、う……は\nい、揉めばいいんですよね……？　優しく、ですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0603208" ]},
		{"command":[ "SETIMAGE", "0", "still_00013106_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「どうって、言われても……コリコリしてて、不思議な感触ですけど……それ\nよりあなたはどうなんですか？　気持ちいいですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0603209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「そうですか……それならよかったです……ん、んんっ……ふぅ……扱いてて\nあげますから……早く、出してくださいね……ふうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0603210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あ、あぁ……我慢汁、またいっぱい出てきてます……あふっ……精液に混ざ\nって……余計に、ぐちゅぐちゅになってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0603211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「はい、キンタマも、撫でますね……優しく、優しく……いいこいいこってす\nるみたいに……んっ……これがいいんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0603212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「はい、ちんぽ……ギンギンですね……反り返って、熱くて、カリもパンパン\nに腫れ上がってます……そんなに感じるんですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0603213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「んんっ……なんか息、上がってます？　そろそろ出そうになってきましたか\n……？　そうですよね、わかります……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0603214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「はっ、ふうっ……ンンっ……もっと強く、ですか？　いいですよ……ンっ、\nんっ……あぁ、すごい音、鳴ってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0603215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「は、恥ずかしいですよ……もうっ、私の顔は見なくていいですから、早く出\nしてください……んッ……くふぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0603216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「出して……だ、出して……ください！　んぅっ……はっ、はんっ……手でも\n、いいです……受け止めます、から……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0603217" ]},
		{"command":[ "SETIMAGE", "0", "still_00013106_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ずっとこの勢いで、扱いてるの……疲れるんですから……は、早く……んん\nっ……ふうっ、ふっ……くうっ……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0603218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
