		{"command":[ "PLAYVOICE", "v2_005_1504401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000515_02_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んふぁぁっ、ウチも……またイクっ……！　はひぁぁ……続けてイッてるの\nっ……はぁぁんっ、気持ち……いいっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1504402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「あぁ……身体……ねとねとにされてるぅ……オスのフェロモン臭……おかし\nくなるぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1504403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ、あぁ……まだ射精……してる……オチンチン……お腹にくっつ\nいて……ヌルヌル……擦り付けられてるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1504404" ]},
		{"command":[ "SETIMAGE", "0", "still_00000515_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ウチの身体……そんなに良かったですか……？　んっ、ウチも……オチンチ\nン……良かったから……一緒ですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1504405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「後もう少しだけ出ますか……はい……最後まで出して下さい……んんっ……\nあぁっ……は、ふっ……」", "NORMAL" ]},
