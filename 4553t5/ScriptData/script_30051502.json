		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「終わりましたね……？　れろっ……んっ、あぁ……濃いの……本当にいっぱ\nい出してくれましたね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1504407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「でも、そんな遠慮のなさがウチは……えっ？　な、何でもありませんっ！　\n変なことは考えてませんからっ」」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1504408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はぁ……火照った身体を元に戻すの……こんなやり方があるなんて思いませ\nんでした。さて……こういうことを教えてもらったからには……」", "NORMAL" ]},
