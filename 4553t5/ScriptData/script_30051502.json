		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んぁぁぁぁぁぁぁっ！　またっ……中っ……ビュクビュクっ……出てっ、ま\nすぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1504301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
