{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000515_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「やれやれ、次から次へと雑魚が湧いて、鬱陶しい戦いでした。ふぅ……んっ\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1504101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「別に疲れている訳じゃありません。この程度の戦い、朝飯前というところで\nす」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1504102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「息の乱れ……？　違います……これは、戦い直後の……高揚感というやつで\nす。あ……な、なんですか……急に手を引いてっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1504103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「興奮しているのは同じ……だ、だからって……何を路地裏に連れ込んでやが\nりますかっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1504104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「あっ……オ、オチンチン……何を見せつけて……んくっ、ダメです……この\nにおいは……はぁっ、んふぅぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1504105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「くぅう……戦った直後に気持ちが高ぶるのを知ってて……わざと見せびらか\nすなんて……はぁ……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1504106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ちょっ……何を器用に脱がしてますかっ……手際が良すぎっ……んっ、あぁ\nっ……だ、抱きかかえないで下さいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1504107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「うぁ……身体が密着して……んっ、はぁっ……汗のにおいが……あぁ、ダメ\nです……このにおいはダメなんですぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1504108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……ウチの身体が勝手に反応して……あぁ……オマンコ……濡れ\nて来ちゃう……んくぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1504109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「あぁ……オチンチン、擦りつけて来る……んっ、こんなところで……入れち\nゃうつもりですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1504110" ]},
		{"command":[ "SETIMAGE", "0", "still_00000515_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……ウチ次第って……ど、どういうことですか……んっ、あぁっ\n、入り口のところ……当たってる……は、入るぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1504111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んんっ……！　な、何で入れないんですか？　ここまで来て……ウチを弄ぶ\nつもりですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1504112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ちゃんとおねだり……うくぅ……人の弱みにつけこんで……んぁっ、あっ、\nあぁっ、擦れるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1504113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「うぅっ、分かりました……お願いします……入れて下さい……貴方の、オス\nフェロモンに満ち溢れた太いオチンチン……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1504114" ]},
		{"command":[ "SETIMAGE", "0", "still_00000515_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「発情して……興奮してる……ウチのオマンコの中に……奥まで……ずっぽり\n……ハメて下さい……ほらっ、言いましたからぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1504115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「あっ、あぁぁぅんっ！　あっ、あぁっ……来ましたっ……あっ、はぁぁぁん\nっ！　いっ、いきなりぃぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1504116" ]},
		{"command":[ "SETIMAGE", "0", "still_00000515_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「あぁぁ……入っちゃいました……こんな外なのに……オチンチン一番奥まで\n届いてぇ……は、くぅぅぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1504117" ]},
		{"command":[ "SETIMAGE", "0", "still_00000515_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「これだけで、軽くイカされるなんてぇ……はぁ、はぁ……んふぅ……あぁ…\n…すごい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1504118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「動くのは……ちょっとだけ待って下さい。今、すごく中が敏感になってて…\n…強すぎます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1504119" ]},
		{"command":[ "SETIMAGE", "0", "still_00000515_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「あと少ししたら落ち着きますから……はぁ、はぁ……んっ、ふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1504120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「あぁ……けど、こうして……じっとしているだけでも……中でオチンチンが\n暴れてるみたいです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1504121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「分かってます……ちゃんと、待ってて下さってるのは……でも、オマンコが\nいっぱいに広がって……身体がずっと痺れてるみたいなんです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1504122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んふぅっ……あぁ……そろそろ、大丈夫かも知れません……ゆっくり動かし\nて下さい……お願いします……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1504123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んふぁっ……！　あぁっ……ズリズリ……擦れる……あっ、くぅぅ……んっ\n、オチンチン……んっ、感じ……ますぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1504124" ]},
		{"command":[ "SETIMAGE", "0", "still_00000515_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はぁっ、んっ、こんな……抱きかかえられる格好なんて……ウチ……慣れて\nなくて……んっ、重くないですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1504125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「羽根みたいに軽い……んっ、そうですか……ご負担にならないのなら、よか\nったですけど……あっ、んぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1504126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「だからって……そんなに、激しく身体を揺すらなくてもっ……！　んぁっ、\nあぁっ、オチンチン……は、激しくぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1504127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「い、いえっ……大丈夫ですっ……この位……ちゃんと……受け入れられなく\nてはっ……ダメですからっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1504128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「もっと……オチンチンかき回してっ……オマンコっ……擦り上げて下さいっ\n……はっ、ひっ、はひっ、んひぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1504129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「あぁっ、うんっ、んんっ、し、しっかり捕まってないと……ずり落ちちゃい\nます……んぅっ、あぁ……熱い……身体……火照ってます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1504130" ]},
		{"command":[ "SETIMAGE", "0", "still_00000515_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「こんな密着したら……汗が滲んで……あぁ……また、このにおい……んんっ\n、はぁぁ……これ以上ウチを発情させないで下さい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1504131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んぁっ、ダメ……首筋を舐めるなんて……あぁっ、ずるいですっ……敏感な\nままなんですからぁっ……はっ、うんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1504132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んぁぁ……背中……指でつぅってされてる……あぁっ……腰も……パンパン\n……速くされてぇ……感じる場所……引き出すのがうますぎます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1504133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はぁっ、んっ、んぁっ、あぁっ……このままされたら……ウチ……また、イ\nッちゃいます……はぁっ、んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1504134" ]},
		{"command":[ "SETIMAGE", "0", "still_00000515_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「いいのっ、ですかっ？　貴方も……一緒にっ、あぁっ、イッて……はいっ、\n中にっ……このままオマンコに中出しして下さいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1504135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「あぁっ、出し入れっ……速すぎてっ……！　うぁぁっ、ウチもっ、イキます\nっ、我慢……出来ないっ……はぁぁぁんっ、イキっ、ますぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1504136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んはぁぁぁぁぁぁぁっ！　あっ、出てる……中っ、オマンコ……中出しされ\nてっ……ますぅぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1504137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000515_02_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「あぁ……どぷどぷって……中に流れ込んでくる……この感じぃ……熱いです\n……はぁぁぁん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1504138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「あふぁ……あぁ……気持ちいい……身体がイッたまま……ビクビクしてます\n……んふぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1504139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……はぁぁ……すごい……こんなに出るなんて思いませんでした\n……はふぅ……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1504140" ]},
		{"command":[ "SETIMAGE", "0", "still_00000515_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ふっ……あ……オチンチン……まだ抜かないで下さいね……んっ、ふっ……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1504201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「理由は分かってるでしょう……？　まだしたいんです……ウチのオマンコ…\n…もっと欲しいって……疼かせてますからぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1504202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はい……いっぱいして下さい……あっ、あぁっ、そうですっ……もっとオマ\nンコの中……かき回して欲しいんですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1504203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んぁぁっ！　あぁっ、すごいっ……んくぅっ、イッて……敏感になってるオ\nマンコにっ……オチンチンっ……効きますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1504204" ]},
		{"command":[ "SETIMAGE", "0", "still_00000515_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はぁぁっ、あくぅんっ、あっ、あぁっ、ゆさゆさっ……身体っ……揺らされ\nてっ……あひっ、オチンチン……擦れるぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1504205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んふぅっ……ウチも……んっ、ずっとされてるだけじゃありません……ぎゅ\nって……オチンチン締め付けますっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1504206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はっ、んふっ……今の、いいですか？　ふふ……いいですよ、もっと、気持\nちよくしてあげますからっ、んっ、んくっ、んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1504207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はぁっ、ヌルヌルしますか？　ウチのオマンコ……ずっと、お汁が溢れてい\nますから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1504208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「中出しされた精液と……んっ、いやらしいお汁が……かき混ぜられてっ……\nあぁっ、恥ずかしい音が……いっぱいしてますっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1504209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「あぁ……ぐちゅぐちゅっ……ずぼずぼっ……なんてスケベな音……あぁ……\nウチがさせてるんですよね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1504210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「あぁっ、うんっ、路地裏なのに……いつ、誰が来てもおかしくないのに……\nこんな、繋がってるところ……見られたらぁっ……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1504211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「あひっ、ダメです……そんな想像したら……また、オマンコ……ジンジンし\nてっ、あぁっ、溢れて来ちゃいますっ……お汁っ……止まらないっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1504212" ]},
		{"command":[ "SETIMAGE", "0", "still_00000515_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はぁっ、んっ、あっ、あぁっ……熱い……汗で蒸れてっ……貴方のにおいも\n……どんどん濃くなってます……すぅぅぅっ、んはぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1504213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「あぁっ、んむっ、あぁ……んちゅぷっ、何……勝手にキスなんてぇ……はぁ\n……んむっ、んふぁ……耳舐めもダメェ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1504214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んくぁぁ……もう何も考えられない……どこも……全部気持ちよくてぇ……\nはぁぁ……また……気持ちいいのが上がって来ますぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1504215" ]},
		{"command":[ "SETIMAGE", "0", "still_00000515_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んんっ……あっ、あぁ……オチンチンも震えて……余裕なくなってます……\n射精……そろそろですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1504216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「そんなの分かるに決まってます。だんだん速くなってるピストンのペース…\n…強くなるフェロモン……全部射精につながってます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1504217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はぁ、んんっ、出したいんですよね……？　なら……また全部出して下さい\nっ……全部……好きにしていいですからぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1504218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「中出ししても……身体に掛けてもらっても……何でもいいですっ、ウチもっ\n……もう限界ですからっ……はっ、あぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1504219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「イッて下さいっ……一緒にっ……このままっ、出してっ……！　ウチもっ…\n…あぁっ、イキっ、ますぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1504220" ]},
