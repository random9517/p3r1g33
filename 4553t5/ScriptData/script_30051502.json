		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はぁぁぁ……イクっ……イキますっ……！　オマンコっ……熱いの出されて\nっ……イッてますぅぅぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1504302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んふぁぁ……あぁっ……子宮の奥まで……精液……届けられてぇ……はぁぁ\n……ウチ……妊娠しちゃいます……こんなぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1504303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んんっ、あっ、ダメです……離しませんよ……んっ、全部出し切るまで……\nずっとしがみついてますからぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1504304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「すごい……オチンチン……ビクビクって震えてるのが分かります……んふっ\n、ウチの中に出すの……気持ちいいですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1504305" ]},
		{"command":[ "SETIMAGE", "0", "still_00000515_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んっ、しっかり締め付けて……搾り出しますから……んぐっ、んふぅぅっ…\n…あっ、ふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1504306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……はぁ……はぁ……んっ、全部出し切った……本当ですか……\n？　ウソじゃないですね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1504307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んっ、それなら……オマンコ緩めてあげます……はぁ、ふぁ……ウチも……\nもうちょっと……限界でした……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1504308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……んっ、何だか……流されるままになってしまいましたけど…\n…気持ちよかったから……よしとします……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1504309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「これからも……戦いの後は……ちゃんと発散に付き合ってもらいますから…\n…そのつもりでいて下さいね……？」", "NORMAL" ]},
