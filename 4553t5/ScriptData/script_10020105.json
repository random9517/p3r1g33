	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「貴様が悪いー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010113050001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「いいや！　貴様だ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113050001" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「なにをー！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010113050002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「やるかー！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113050002" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫とルナテミス" ]},
		{"command":[ "SETTEXT", "「うおおおおおおーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010113050003" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "1", "char_00001601_01", "7", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0000" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
		{"command":[ "SETTEXT", "と、いうわけで、まだまだ女幹部連中のバトルは続く……。こんなことになる\nんじゃないかと思ってたんだよな。最初から……。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "この際だから、事の始まりから説明しておこう。あれは、月面での戦いが終わ\nった直後……。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0101" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_011" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「わたしたちが……ブラックメルヘンの本拠地へ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010113050004" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "本部に戻った俺たちに、ブラックメルヘン首領が提案を持ちかけてきた。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "それはルナパレス２１を失い、住むところを無くした俺たちへの支援であると\n同時に、襲来者からの攻撃を受け続けているブラックメルヘンの本拠地――", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "「私立・大戸岐学園」を防衛するための、戦力増強策でもあった。つまり、お\n互いにとって利のある話、というわけだ。", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_113050001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "もちろん、こちらはありがたくその提案を受けるつもりだった。しかし――", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「戦力の増強など無用！　大戸岐学園は、われらブラックメルヘンだけで守り\n切ってみせます！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113050004" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0000" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
		{"command":[ "SETTEXT", "と、めんどくさく異を唱えてきたのが修羅姫はじめ、ブラックメルヘンの女幹\n部たちだった。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "どうもこいつら、揃いもそろって縄張り意識が強いというか、協調性に欠ける\nというか……そういった性格らしい。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そこに気づいた時点で嫌な予感はしていたんだが、そこはＧ・ルナリアムの連\n中もたいして変わらないからな……と思って、無理にスルーしていた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "それに、その場はブラックメルヘンの首領があっちの女幹部たちを説得……と\nいうか、お説教してくれて収まったからな。てなわけで――", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0138" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_016" ]},
		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「皆さん、おはようございます。今日からこの学園で、数学を教えることにな\nりました。エファ・グラナーダです。気軽に、エファ先生と呼んでね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060113050001" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "みんな" ]},
		{"command":[ "SETTEXT", "「エファ先生、よろしくお願いします！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113050001" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "6", "CENTER", "-650" ]},
		{"command":[ "SETCHARA", "1", "char_00001205_01", "6", "CENTER", "-200" ]},
		{"command":[ "SETCHARA", "3", "char_00001406_01", "6", "CENTER", "250" ]},
		{"command":[ "SETCHARA", "2", "char_00001502_01", "6", "CENTER", "600" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "DISPCHARA", "2", "TRUE" ]},
		{"command":[ "DISPCHARA", "3", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "学園を拠点とし、学園の寮に間借りする、ということで俺たちの世を忍ぶ仮の\n姿は、大使館員から学園の教職員、もしくは学生へと変わった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "DISPCHARA", "2", "FALSE" ]},
		{"command":[ "DISPCHARA", "3", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0138" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「はぁ～い、いいですかぁ～？　この鉱石はねぇ～？　地球ちゃんが、まだま\nだ若くってぇ～お盛んに火山活動をしていた時代の名残なの～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040113050001" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "bg_0147" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「よーっし！　格技の授業始めるぞー！　まずはお手本！　誰か、このバナナ\nをもって先生に殴りかかってこーいー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_030113050001" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "bg_0138" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「各班ごとに、調理実習を始めて。刃物や火をつかうので、くれぐれも安全に\nは注意……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_050113050001" ]},
		{"command":[ "SETCHARA", "0", "char_00000204_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0000" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "エファ、ディアナ、セレイン、輝夜は教師……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "bg_0148" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「学割証明書ですか。では、そこの申請書に名前、学年、クラス等々、必要事\n項を書いて提出するです。誤字脱字のないように」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_050113050001" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0000" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "兎子は学校事務……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "bg_0147" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「みなさん、ごきげんよう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113050002" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「ルルーナちゃん、おはよう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010113050002" ]},
		{"command":[ "SETCHARA", "0", "char_00001205_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「おはよう。ルルーナさん、今日も元気ね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010113050002" ]},
		{"command":[ "SETCHARA", "0", "char_00001406_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "この３人はもともと学生だし、ここでも順当に学生だ。つきみとまりあは、緊\n急時にも俺たちと行動を共にしやすいよう、こっちに転校することになった。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そして……。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「お、おはよう……ございます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130113050002" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "2", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "このおとなしそう、というか、ちょっと気弱そうな学生……誰だと思う？", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「す、すみません……私、アナザーです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130113050003" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そう。これがアナザーの「世を忍ぶ仮の姿」というわけだ。さすがに、ここま\nで性格が変わっちまうとは俺も驚いた。それに……。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "みんと" ]},
		{"command":[ "SETTEXT", "「…………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_020113050002" ]},
		{"command":[ "SETCHARA", "0", "char_00001502_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「あ、みんとちゃん！　おはよう！　ねえねえ、みんとちゃんもこっちに来な\nい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010113050003" ]},
		{"command":[ "SETCHARA", "0", "char_00001205_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "みんと" ]},
		{"command":[ "SETTEXT", "「申し訳ありませんが、私、やることがありますので」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_020113050003" ]},
		{"command":[ "SETCHARA", "0", "char_00001502_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「あ、そ、そうなんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010113050004" ]},
		{"command":[ "SETCHARA", "0", "char_00001205_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「……みんとさん？　せっかくつきみが誘ってくれたのに、そういう言いかた\nはないんじゃないかしら？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113050003" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「あああ！　いいのいいの！　みんとちゃん、ごめんね、よけいなこと言っち\nゃって！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010113050005" ]},
		{"command":[ "SETCHARA", "0", "char_00001205_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "みんと" ]},
		{"command":[ "SETTEXT", "「いえ……こちらこそ。ですが、私にはどうしてもやりたいことがありますの\nで。そのためには、わずかな時間でもコツコツ勉強しなければ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_020113050004" ]},
		{"command":[ "SETCHARA", "0", "char_00001502_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「そ、そうなんだ……すごいね、ははははは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010113050006" ]},
		{"command":[ "SETCHARA", "0", "char_00001205_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「むぅ…………！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113050004" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "みんと" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_020113050005" ]},
		{"command":[ "SETCHARA", "0", "char_00001502_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "みんと" ]},
		{"command":[ "SETTEXT", "（見てなさい……！　Ｇ・ルナリアム幹部の座は、いつか私のものに……！）", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_020113050006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「はぁ～……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010113050003" ]},
		{"command":[ "SETCHARA", "0", "char_00001406_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "みんと、という幹部見習いも、俺たちと一緒にこの学園にやってきた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "この子とは、今まであまり接点がなかったんだが、どうも他のメンバーに負け\nず劣らずめんどくさいヤツらしい……。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0000" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "そして最後に、この学園での俺の立場は、というと……。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "bg_0126" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「俺たちは住み込みの警備員と番犬、ってわけか。まあ、大使館にいたときと\n変わんねえな」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ですな。見回り範囲は広くなりましたが、やり慣れた仕事です。気楽にいこ\nうではありませんか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113050001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうだそうだ！　なんだよジュンジロー。珍しく意見が合ったな！　わはは\nははははははは！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「あ、いたいた。おーい、カツマクン！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020113050001" ]},
		{"command":[ "SETCHARA", "0", "char_00002202_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ん？　お前は、Ｄｒ．サイレーン……じゃなかった、珠魚じゃねえか。どう\nかしたのか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「どうもこうもないよ。ちょっと保健室に来てくれ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020113050002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「保健室？　別に体調は悪くねえぞ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「そうじゃない。学園長から聞いてないのか？　君には、警備員と地理の担当\n教師を兼任してもらうことになったんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020113050003" ]},
		{"command":[ "SETCHARA", "0", "char_00002202_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……は？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「君たちと同時に来てくれるはずだった、新しい地理の先生が来られなくなっ\nてしまってねえ……このままでは、授業に穴が開くんだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020113050004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「だからって俺が！？　おいおい、俺は教員免許なんか持ってねえぞ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「おやおや、ずいぶん真面目だねえ。悪の組織の幹部のくせに。大丈夫！　そ\nんなもの、悪と正義が手を組んだＥＤＯの力で裏口から……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020113050005" ]},
		{"command":[ "SETCHARA", "0", "char_00002202_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「出せるのかよ！　いいかげんなもんだな！　って、免許だけあってもしょう\nがねえだろ？　俺は、地理のことなんかぜんぜん知らねえぞ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「わかってるよ？　だから、そのために保健室に来てくれって言ってるんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020113050006" ]},
		{"command":[ "SETCHARA", "0", "char_00002202_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「話が見えねえ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「だーからー！　ボクの科学でどうにかするってことだよ！　そのための装置\nが、保健室に用意してある！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020113050007" ]},
		{"command":[ "SETCHARA", "0", "char_00002202_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おまえの……科学？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "なんか、えらい不穏な話になってきてないか。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ほほう、それは素晴らしい。隙間の多いご主人の頭に、知識を詰め込んでく\nださるということですかな？　科学の力で」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113050002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「そう！　科学の力！　科学の力を応用すれば、ベテラン教師に負けない知識\nを、３日でキミに授けてやれるぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020113050008" ]},
		{"command":[ "SETCHARA", "0", "char_00002202_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「どうやって！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「それはキミ、ボクの開発した『不眠学習装置』があればだね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020113050009" ]},
		{"command":[ "SETCHARA", "0", "char_00002202_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「学習装置……？　もしかして、寝ている間に脳をいじって、とかそういうこ\nとか……！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「ははははは！　やだなぁ！　ボクの言ったこと聞いてなかった？　『不眠学\n習装置』って言ったんだよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020113050010" ]},
		{"command":[ "SETCHARA", "0", "char_00002202_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ふみん……？　って！　それはまさか！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「そう！　３日ほど寝ないで、機械による教育を受けてもらうってことさ！　\n大丈夫！　ちょっとしたお薬や洗脳技術も使うけど、危険はない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020113050011" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「危険がないようには聞こえねえ！　嫌だ！　俺はぜったい嫌だぞ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "と、俺は珠魚に背を向け、ダッシュでその場を逃れようとしたが――", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「待ちなさい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020113050001" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「逃亡は許さんのである」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_020113050001" ]},
		{"command":[ "SETCHARA", "0", "char_00002002_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ひっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "横合いから突然現れた明日楽と遥架に、がっちりと両腕をつかまれてしまった", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "！　って、なんなんだこいつら！　すっげえ馬鹿力！", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「それじゃ、不眠学習を始めるよー。カツマ『先生』を、保健室まで連れてき\nてくれたまえー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020113050012" ]},
		{"command":[ "SETCHARA", "0", "char_00002202_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お、おい！　やめろ！　かんべんしてくれ！　ああああ、放して！　助けて\n！　おい！　ジュンジローっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人～いってらっしゃいませ～。校内の見回りは、ワタクシが引き受けま\nしたぞ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113050003" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ジュンジロー！　てめえ、あいかわらず主人をあっさり見捨てやがってー！\n　誰か！　誰か助けて！　誰かぁあああああーっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0000" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "と、いうわけで俺は警備員と地理の担当教師を兼任させられることになり……\nそればかりか「地球防衛科」クラスの副担任までやらされることになった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "bg_0148" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「…………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020113050002" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ちなみに、担任は「修羅姫」こと大江山明日楽だ。鬼の姿のときとは違い「ガ\nッチガチの堅物教師」という印象だが、おっかないことに変わりはない。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「いいですか？　世を忍ぶ仮の姿とは言え、仮にも教育者なんです。学生たち\nのためにならない行動は慎んでください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020113050003" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はい……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "「地球防衛科」というのは要するに、俺たちＧ・ルナリアムの幹部と、ブラッ\nクメルヘンに関係する学生たちを集めたクラスだ。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "もともと、ここの学生たちの中にはブラックメルヘン幹部の部下や、ヒーロー\nのバッケンローダー……つまり桃花もいたので――", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "要するに学年をまたげばひとクラス作れてしまうぐらい、ＥＤＯ関係者が大勢\nいるってわけだ！", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0000" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "そんなわけで俺たちの学園生活がはじまったのだが……。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0138" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「うおぉおおおおおおおおーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113050005" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「どりゃぁあああああーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010113050005" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "その結果がこのありさま。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はぁ……無理があるとおもったんだ、いろいろ……」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ま、そう悲観したものでもありませんぞ。まだまだ学園生活ははじまったば\nかりではありませんか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113050004" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うるせえ……どっからともなくお気楽に現れて、のん気なこと言ってんじゃ\nねえ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "とほほほ……ジュンジローに鋭くツッコんでやる気力すら沸かねえ……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}