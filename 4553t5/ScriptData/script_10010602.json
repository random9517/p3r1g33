{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0089" ]},
		{"command":[ "DISPIMAGE","0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ふむ。今日のところはこれぐらいでいいだろう。模擬戦は終了だ。撤収にか\nかれ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010106040001" ]},
	{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
	{"command":[ "DISPTEXT", "TRUE" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ふぅ……着いて早々疲れました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010106040001" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ダイヤナちゃん、早くシャワー浴びたぁ～い」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010106040001" ]},
	{"command":[ "SETCHARA", "0", "char_00000601_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「その前に、装備類を片付けなくては。みんなも手伝ってくれ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090106040001" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「うむ。いいだろう。下僕、そのようにせよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010106040001" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「結局あんた手伝う気ねえんじゃねえっすか！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「カツマ、私も手伝う」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010106040001" ]},
	{"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「あ、私も」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010106040001" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「なにやらすっかり、この流れもおなじみになってまいりましたな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010106040001" ]},
	{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「おなじみって？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010106040001" ]},
	{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「むほほほほほ。まだまだつきみどのには、男と女の微妙な機微というものが\nおわかりでないと見えますな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010106040002" ]},
	{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おい駄犬！　わけのわかんねぇこと言ってねえで、てめぇも手伝え！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「すまないな、みんな。……おや？　煙幕弾がひとつ足りないな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090106040002" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「森の中に置いてきちゃったかな？　ちょっと探してくるよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010106040002" ]},
	{"command":[ "SETCHARA", "0", "char_00001201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「いや、いい。私が行ってくる。つきみはこちらを頼む」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090106040003" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「それじゃつきみ、こっちを手伝って」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010106040002" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「うん、わかった――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010106040003" ]},
	{"command":[ "SETCHARA", "0", "char_00001201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0089" ]},
		{"command":[ "DISPIMAGE","0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_009" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「なに！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010106040004" ]},
	{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「森の中だ！　なにか爆発した！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「まさか、アナザー！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010106040002" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ルナテミスが、血相を変えて森の中へ駈け込んでいく。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「カツマ！　行ってみよう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010106040002" ]},
	{"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "俺はしばらく呆然と立ち尽くしていたが、カグヤの言葉で我に返った。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうだな！　行こう！」", "NORMAL" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "おいおいおいおい！　冗談じゃねえ、ありえねえだろ！？", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "まさかあいつが事故なんて――", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「アナザーッ！！！！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010106040003" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0089" ]},
		{"command":[ "DISPIMAGE","0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_012" ]},
		{"command":[ "SETTEXT", "森の中で倒れていたアナザーに、", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "俺たちは慌てて応急手当を施したが――", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ダメだ……死んでいる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010106040002" ]},
	{"command":[ "SETCHARA", "0", "char_00004901_01", "1", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「そんな……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010106040003" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そんなまさか……！　信じられない！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「これだけきれいな顔をしていると、嘘みたいに思えるだろうが……死んでい\nるんだ、これは」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010106040003" ]},
	{"command":[ "SETCHARA", "0", "char_00004901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「鎧である程度は受け止めたものの、衝撃が大きすぎた……ということですか\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010106040002" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「衝撃が大きすぎた、って……なんだよそれ！？　ダミーの煙幕弾だろ！？　\n花火みてえなもんだろ？　なんでそんな衝撃が――」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「たしかにそうだ。ダミーにしては爆発が大きすぎる。まわりの木も岩も、な\nぎ倒されている……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010106040004" ]},
	{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「本来、演習用の煙幕弾は、このように大きな爆発を引き起こすものではない\nはずだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010106040005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「と、いうことは……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010106040003" ]},
	{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「まさか、本物の爆弾が混じってたって言うのかい！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010106040001" ]},
	{"command":[ "SETCHARA", "0", "char_00000301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ちょっと待ってくれ！　出がけにいちおう、装備のチェックはしたろ！？　\n持ってきたのは煙幕弾だけのはずだよな！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ええ、そうです！　間違いありません！　それは、帰って武器係の記録を調\nべればわかるはずですよ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010106040004" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ウチも手伝いましたね。そのときは、確かに煙幕弾だけでした」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010106040003" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「なるほど。カツマはともかく、まりあやオボロがヘマをするとも思えないね\nえ。と、なると、だ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010106040002" ]},
	{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「と、なると？　どうなるんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010106040001" ]},
	{"command":[ "SETCHARA", "0", "char_00000401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「途中で誰かがすり替えた、とエファナティカ様はおっしゃりたいんでしょう\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010106040004" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「すり替え！？　いったい誰が！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010106040005" ]},
	{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「って！？　なんですか俺に向けるその怪しげな視線は！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「そうよ！　なぜカツマさんなの！？　私とオボロさんも手伝っていたけど、\nカツマさんがすり替えた様子はなかったわ！　そうよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010106040005" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「まあ、そうですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010106040005" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},


		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「っていうか、さっきまで装備は全部車の後ろに普通に積んであったし、誰で\nもすり替えるチャンスはあったろ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010106040003" ]},
	{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「と、なると怪しいのは動機のある者……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010106040006" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「動機……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「動機ねえ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010106040006" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「動機……アナザーを始末したいワケってことだよな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010106040002" ]},
	{"command":[ "SETCHARA", "0", "char_00000401_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "一同" ]},
		{"command":[ "SETTEXT", "「ん……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010106040004" ]},
	{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "-600" ]},
	{"command":[ "SETCHARA", "1", "char_00000401_01", "3", "CENTER", "-200" ]},
	{"command":[ "SETCHARA", "2", "char_00000601_01", "3", "CENTER", "200" ]},
	{"command":[ "SETCHARA", "3", "char_00001401_01", "3", "CENTER", "600" ]},
	{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
	{"command":[ "DISPCHARA", "2", "TRUE" ]}, 
	{"command":[ "DISPCHARA", "3", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「って！　また私を見たな！？　なぜ私を疑う！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010106040005" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
	{"command":[ "DISPCHARA", "2", "FALSE" ]}, 
	{"command":[ "DISPCHARA", "3", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「や、やあねぇ～！　ダイヤナちゃん、ルナさまを疑ってなんかいませんよ！\n？　ね～え？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010106040003" ]},
	{"command":[ "SETCHARA", "0", "char_00000601_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ただ、ちょっと、アナザーとの日頃の……ねえ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010106040008" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「いつもなんかもめてるし……ねえ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010106040004" ]},
	{"command":[ "SETCHARA", "0", "char_00000401_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「だから、動機って言われるとつい……ねえ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「『ねえ』ではない、『ねえ』では！　冗談ではないぞ！　なぜ私がアナザー\nを殺さねばならんのだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010106040006" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、誰もそこまでは言ってませんけど」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「それに、落ち着いてください。この状況はどう考えても、アナザーだけを狙\nったものとも思えません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010106040007" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「そうだよ、お前たち！　だいたいルナテミス様がアナザーを始末する気なら\n、正々堂々と決闘でもするだろうさ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010106040004" ]},
	{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「だろう！？　なのにこいつらと来たら……！　だいたい貴様ら、最近私への\nいじりが度を越してはおらんか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010106040007" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、そう言われましても……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「もういい！　もうたくさんだ！　もう、貴様らのようなボケナスビどもには\nつきあっておれん！　私は部屋に引き上げさせてもらう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010106040008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ああ！　ルナ様！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010106040005" ]},
	{"command":[ "SETCHARA", "0", "char_00000301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「待ってください、姫様！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「うるさい！　いまさら止めても無駄だ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010106040009" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、まだ部屋の鍵を渡してないんですが……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「だったら早く渡さないかボケナスビ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010106040010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「は、はあ……３９３号室です」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ふん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010106040011" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「おい！　ルナテミス様カンカンじゃないか！　どうするんだい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010106040006" ]},
	{"command":[ "SETCHARA", "0", "char_00000301_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「俺に言うなよ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「はぁ……なんでもいいが、お前たち、しばらくホテルから出ないようにな。\n私は、いったん町に戻って本部と警察に連絡してくる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010106040006" ]},
	{"command":[ "SETCHARA", "0", "char_00004901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「わざわざ降りるんですか？　電話で連絡すれば？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「電話はもう解約予定で料金を払っていない。このあたりは携帯も圏外だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010106040007" ]},
	{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「やぁあああああん！　ホントだぁ！　いまどき携帯が圏外になるとか、そん\nなホテルがあるなんて思ってなかったぁあ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010106040004" ]},
	{"command":[ "SETCHARA", "0", "char_00000601_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「だから廃業することになったんだよ。それではちょっと行ってくる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010106040008" ]},
	{"command":[ "SETCHARA", "0", "char_00004901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「アナザーはどうします？　動かさないほうがいいんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010106040008" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「そうだな……もう現場からは動かしてしまったんだし、ここに放っておくわ\nけにもいかん。部屋に安置しておいてやってくれ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010106040009" ]},
	{"command":[ "SETCHARA", "0", "char_00004901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「…………わかりました」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「では、頼んだぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010106040010" ]},
	{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「では、わたくしも長官にお供いたしますぞ。助手として」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010106040003" ]},
	{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なにさっさと逃げようとしてやがんだ。まあ、いいや。駄犬がいても役にた\nちゃしねえ」", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……ふぅ、やるか。おい、みんな。手伝ってくれ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「……おう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010106040005" ]},
	{"command":[ "SETCHARA", "0", "char_00000401_01", "1", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「……わかった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010106040007" ]},
	{"command":[ "SETCHARA", "0", "char_00001201_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ぐったりと動かないアナザーの身体を持ち上げると、なんだか急にメンバーを\n亡くしたんだという実感がわいてきた。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "こいつ、もう、泣いたり笑ったり怒ったりできないんだよな……。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「……おい、カツマ。気持ちはわかるがな、早く中に入れてやりな。変な雲が\n出てきたし、一雨きそうだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010106040007" ]},
	{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああ……そうだな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "俺たちはアナザーを屋内に運び込み、あいつが使う予定だった部屋のベッドに\n寝かせてやった。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "あいつを悼む思いで、みんなの気持ちがひとつになったような気がした。気が\nしたんだが――", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0122" ]},
		{"command":[ "DISPIMAGE","0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「だいたい、おまえがよけいなことをいうからルナ様が怒っちまったんじゃな\nいか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010106040008" ]},
	{"command":[ "SETCHARA", "0", "char_00000301_01", "0", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ウチのせいだというんですか！？　納得いきませんね！　だいたい、すりか\nえ説を持ち出したのはあなたですよ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010106040009" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「なんだってぇ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010106040009" ]},
	{"command":[ "SETCHARA", "0", "char_00000301_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「それに、ルナテミス様を疑い出したのはカツマさんやつきみさん、それにダ\nイヤナさんでしょう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010106040010" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「んだとぉ！？　俺に振るなよ俺に！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「う、疑ってない！　わたし、疑ってなんかいないよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010106040008" ]},
	{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ダイヤナちゃん悪くないもーん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010106040005" ]},
	{"command":[ "SETCHARA", "0", "char_00000601_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「うるさい！　とにかくあんたらのせいだよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010106040010" ]},
	{"command":[ "SETCHARA", "0", "char_00000301_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ちょっとやめなさいって！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010106040009" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「カツマをいじめないで！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010106040005" ]},
	{"command":[ "SETCHARA", "0", "char_00000201_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「だーっ！　ちょっと待て！　なんかもう、このまま行くとケンカに――」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "女幹部たち" ]},
		{"command":[ "SETTEXT", "「うるさいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010106040006" ]},
	{"command":[ "SETCHARA", "0", "char_00000201_01", "7", "CENTER", "-600" ]},
	{"command":[ "SETCHARA", "1", "char_00000301_01", "7", "CENTER", "-200" ]},
	{"command":[ "SETCHARA", "2", "char_00000401_01", "7", "CENTER", "200" ]},
	{"command":[ "SETCHARA", "3", "char_00000601_01", "7", "CENTER", "600" ]},
	{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
	{"command":[ "DISPCHARA", "2", "TRUE" ]}, 
	{"command":[ "DISPCHARA", "3", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "あーもうっ！　どうしてこうなるんだ！", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
	{"command":[ "EXIT" ]}
	]
}