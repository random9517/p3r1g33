		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "081_0103102" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「も、もしかして……デ、デート……のお誘い……？　い、いいよ……私、え\nと、ええと……いつでも暇で……。一人ぼっちだから……うん」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00008101_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "081_0103103" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「隊長さんが行きたいところに、い、いきたい……。隊長さんがしたいこと、\nし、したい……。だから……。デート……。……え？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00008101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "081_0103104" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「外には行かない……？　ここで、二人で……？　う、うん……い、いい、よ\n……。それで、何するの……？　うん、うん……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00008101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "081_0103105" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「ふぇら……ちお……？　パイズリしながら、お口で……？ぁ……。そ、そっ\nか……。フェラチオ……。そ、そうだよね、あは、ご、ごめんなさい」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "081_0103106" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「隊長さんと普通の女の子みたいに……い、いちゃいちゃ？　出来るかもって\n思って、よ、喜んじゃった。そうだよね、フェラチオとか、だよね」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00008101_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "081_0103107" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「……わ、私、暗いし……気持ち悪いよね。だから、そういうことでしか……\n役に立てない、よね……。えへ……えへ、えへ……へへへ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "081_0103108" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「ほ、ほんの少しだけ……悲しいけど……頑張る……。そっか……えへ、そ、\nそっか……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00008101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "081_0103109" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「えっと隊長さんの……。足の間、に行けばいいんだよね。う、うん、うん…\n…私、キ、キスも……したことないけど……パイズリフェラ、するね……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "081_0103110" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「ん……えと……。それでこ、これ……どうしたら、い、いいの？　うん……\nこの大きいのを……胸で潰して……？　あっ……！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
 		{"command":[ "SETIMAGE", "0", "still_00008101_01_01" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "081_0103111" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「ど、どうしよう、どうしよう……！　今、触ったらビクンって……！　逃げ\n、逃げちゃう……む、胸で抑え込まないと……！　あっ……ま、待って！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "081_0103112" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「つ、捕まえた……もう逃がさない……。っ……で……こ、これをこのまま…\n…ぎゅうっ、むぎゅうってする……うん……。うん、うん……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "081_0103113" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「り、理屈はわかる、けど……隊長さん、こういうことをさせたくて……私に\n優しくしてくれてた、んだね……少し見損なった……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00008101_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "081_0103114" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「せ、性欲処理に使われる、なんて……。うう……。おちんちんなんて好きじ\nゃない、のに……。ひどい……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "081_0103115" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「ここ、おしっこするところでしょ……？　隊長さんの一番汚いとこ……。こ\nこを胸でムニュムニュされたいなんて……信じられない……。え？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "081_0103116" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「もっと強く挟め？　……っ……口も使って刺激、しろ……？　うぁ……。ほ\n、本当に、こんなところを、す、するの？　怖い……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "081_0103117" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「病気になっちゃう……。それに、変な味がしたら……。ねえ……わ、私、や\nっぱり怖くて……。……や、やめちゃだめ……？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00008101_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "081_0103118" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「………………。あっ……、ち、違う、の……。ごめんなさい。ごめんなさい\n。そんな顔しないで。す、すぐに……すぐにするから……んんっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "081_0103119" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「……れ、ろ……！　うううう……　れ、ろ……ぴちゃ……。んんん……！　\nこ、れが、おちんちんの味ぃ……？　っぅ……ぴちゃ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00008101_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "081_0103120" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「うう、ううう……やだ……やだぁ……。でも……しないと、しないと嫌われ\nちゃう……。だから、やらないと……。う、うう……ぺろっ、ぺろ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "081_0103121" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「あむ……うぇ……へ、変な感触……っ……。先っちょが柔らかくて、……ん\n……棒のところは硬く、て……んん……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "081_0103122" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「め、冥界の生き物みたい……・。大ミミズみたいな……。うう、ぺちゃっ…\n…。思ったより、あ、味はしない、けど……ぺろ……ぬ、濡れて、る」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "081_0103123" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「先っちょの穴から何か滲み出して……。ぺろ……。っあぅ……、あう、ぁう\n……っ。胸で押さえると……動かすと、雫が……ぺろ、ぺろ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "081_0103124" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「こ、これ、放っておいたらいけない……よね。待ってね、今ちゃんとする、\nから……。ちゅ……ちゅ、ちゅ……ぺろ、ぺろ、ぺろ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "081_0103125" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「ん、ぺろ……ぺろ、ぺろ……ちゅ、ちゅ、ちゅ、ちゅ……。ちゅぅうう……\nぺろっ……れろっ、れろ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00008101_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "081_0103126" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「はぁっ、む、胸……を上下させながら……。おちんちんを……。んぷ……舐\nめ、……舐め、る……。ぺろ……ぺろ、ぺろ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "081_0103127" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「は、ぁ……ちゅっ……ちゅぱっ……。ちゅるっ、ちゅるるっ……！　はぁ、\nはぁ……れろっ、れろ、れろ……っ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "081_0103128" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「む、胸……苦しく、ない……？　え？　き、気持ちいい……？　嘘……。私\nの胸なんか……全然気持ちよくない、でしょ……？　ぺろっ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00008101_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "081_0103129" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「んぅ……。ん、んん……んっ、んんっ……！　くちゅ……ちゅぷ、れろっ…\n…。ちゅっぽっ……。ちゅっぽっ、ちゅぽっ、ちゅぷっ……ちゅっぷっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "081_0103130" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「んちゅ……はふ……。くちゅっ……、ちゅっ、ちゅ……。んむ……。ちゅ…\n…ちゅ、ちゅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "081_0103131" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「んぁ……、あ、あの……あの……！　隊長さん、こ、これ……おちんちん…\n…なんか変です……。ふ、震えてる……それに、太く、なって……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00008101_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "081_0103132" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「え？　え？　え……？　これっ……ぁっ、精液が出る予兆なんですか……？\n　ぁ……やだ、やだ、やだ……だ、出さないでください、あぁ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "081_0103133" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「も、もっと？　もっと強く胸を押し付けて……しゃぶれ？　ぁ……やだ、や\nだ、やだ……でも、でも……。う、うう……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "081_0103134" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「わ、かりました……。ぢゅ……！　ぢゅるっ……！　じゅるっ、じゅる、ず\nるるっ……！　ぐっちゅっ！　ぐちゅっ、ぐっちゅっ……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00008101_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "081_0103135" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「んんん……い、や……いやぁ……ああああっ……！　もぐっ……！　んぢゅ\nっ……ぢゅるっ、ぢゅるっ……！　ちゅぷぷぷ……ちゅるっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "081_0103136" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「ぁ……！　ぁ、ぁ……あああ……でちゃう、出ちゃ……う……！　ぢゅっ！\n　ぢゅっ、じゅるるっ、じゅるっ、じゅるっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "081_0103137" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「っんんんんんーーーーーー！！　いやっ、いやああああっ！　ぁ……。ぁ、\nあ……ご、ごめ……ごめ、んなさい……ごめんなさい……！」", "NORMAL" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
        {"command":[ "SETIMAGE", "0", "still_00008101_01_09" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "081_0103138" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「最後に口を離しちゃったから……！　あ、む、胸に出て……。ごめんなさい\n……ごめんなさい……っ、ゆ、ゆるしてください……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "081_0103139" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「え……？　う、うまくできなかったから……？　上手じゃなかったからもう\n一回……？　そ、そんな……あ……無理です……っ」", "NORMAL" ]},
        {"command":[ "SETIMAGE", "0", "still_00008101_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "081_0103140" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「胸っ……胸、よ、汚れちゃった、か、ら……。洗いにいかないと……。って\n、ぁ……！　……は、はい……。します……もっと頑張ります……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "081_0103201" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「ぷぢゅっ！　ぢゅぽっ、ぷぢゅるっ……！　んっ、んぅええっ……。げほっ\n、に、苦いっ……にが、い……。うぇ……ごほっ、げほっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00008101_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "081_0103202" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「あ、あ……そう、か……。精液出した後、だから……。おちんちんにもべっ\nたり味が残って、て……。んぷ……、うう、やだぁ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "081_0103203" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「ひどい、臭い……。う、うぅ……。でも、でも……舐めなきゃ……。おしゃ\nぶりしな、きゃ……。っれろ……。れろ、チュ……ちゅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "081_0103204" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「ううううっ……！　胸を動かふと……精液、溜まったのが動いて……れちゅ\n……。もう、もうめちゃくちゃ……汚い……きたないよぉ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "081_0103205" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「っふぅううっ……うう、うううー……！　れろっ、れろれろれろ、ぐちゅっ\n！　ぐちゅぷっ！　ぐちゅぽっ、ぢゅぽっ、ぢゅっぷっ」", "NORMAL" ]},
        {"command":[ "SETIMAGE", "0", "still_00008101_01_09" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "081_0103206" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「早く、早く、この味消えてぇ……っ。んれろっ……レロっ、ぴちゃ、ぴちゃ\n、ぴちゃ……うぇ……顔中が気持ち悪、い……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "081_0103207" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「ムワムワ蒸れたおちんちん、べったりこびりついた精液……。パイズリフェ\nラするなんて言わなきゃ良かった、うぅ、胸も気持ち、わるい……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "081_0103208" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「やだ、やだ、やだ……。くぷ……、ちゅるっ……んんん、ぴちゃ、れろ、く\nちゅ……！　れろ、れろ、れろ、ぐちゅっ！　ぐちゅっ！　ぐちゅっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "081_0103209" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「う、うぅ……。こ、れ……口の中の……。吐くところ、ない……。ベッドに\nはこぼせない……だから……。ん……飲むしか、なくて……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "081_0103210" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「……ごくっ……！　ぷぁああっ……！　あ……あ、飲んじゃっ……た、男の\n人の精液、飲み物みたいにごっくん、し、しちゃった、私なんかが……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "081_0103211" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「すごい……。い、淫乱の人みたい……経験豊富な人と同じ……。だったら、\nだったら……もっと、パイズリフェラ……うまくないと……だめ」", "NORMAL" ]},
        {"command":[ "SETIMAGE", "0", "still_00008101_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "081_0103212" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「んっ！　んっ、んっ、んっ……むぐっ……んぷ……じゅるっ、じゅるっぽ！\n　くちゅるっ……ぢゅるっ！　ぢゅっぷぢゅっぷぢゅっぷっ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "081_0103213" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「っは、ぁ……んれるっ……れる、ぢゅっぷっ！　んちゅぅう……じゅるっ、\nぢゅるっ……ぢゅぷっ！　はぁ、はぁ……」", "NORMAL" ]},
