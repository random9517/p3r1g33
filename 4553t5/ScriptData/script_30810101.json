		{"command":[ "PLAYVOICE", "081_0103101" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「た……隊長、さん……。私のこと……よ、呼んでたって聞いて……。あの、\nあの……ど、どうかした？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00008101_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
        {"command":[ "SPOTCHARA", "0" ] },
