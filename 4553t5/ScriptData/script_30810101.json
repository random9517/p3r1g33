		{"command":[ "PLAYVOICE", "081_0103214" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「ぁ……！　ぁ、ぁ……き、気持ち……いい……？　んぅ……わたひ……ちゃ\n、ちゃんと出来れる……？　れるっ……れるっ、んん……！」", "NORMAL" ]},
