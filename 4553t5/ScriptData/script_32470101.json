{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024701_01_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「ふふっ。カツマさんが運転してくれて、しかも洗車までしてもらえるなんて\n凄く嬉しいです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0103101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「もし操作がわからなかったりしたら、すぐに言ってくださいね。自動運転に\n切り替えますので」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0103102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「ちゃんと操縦マニュアルを読んだから大丈夫……？　わかりました。では、\nよろしくお願いしますね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0103103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「まずはゆっくりとマスター・コントローラー……いわゆるアクセルですね。\nこれを操作して、速度を上げて……そうです。いい感じですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0103104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「あっ、洗車機が見えてきましたね。このまま速度を落とした状態で、ゆっく\nりと洗車機に入ってください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0103105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「んっ……ちゃんと洗車機の中に入りましたね。あとは低速のままゆっくり進\nんで、私の車体や窓にブラシを当てていってください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0103106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「……って、あれ？　カツマさん。どうして洗車機の中で停車するんですか？\n　車の洗車と違って、私が前進し続ける必要があるんですが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0103107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「今日はいつもより汚れが目立つから、念入りに洗ってあげたいから停車して\nる……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「そ、それはダメですっ！　ただでさえ洗車は気持ちいいのに、同じところを\nずっと磨かれたりしたら……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0103109" ]},
		{"command":[ "SETIMAGE", "0", "still_00024701_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「やっ、ダメっ……！　洗車機が回り始めてますっ……！　か、カツマさんっ\n！　今すぐアクセルを入れて……きゃあああぁっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0103110" ]},
		{"command":[ "SETIMAGE", "0", "still_00024701_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「あぁんっ！　んっ、あっ、んぅ！　洗車機のブラシが、私の車体を強く当た\nってますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0103111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「普段から使ってる洗車機なのに、停車してるせいでいつもより感じて……ひ\nあぁ！？　先頭車両の汚れがどんどん落ちていってるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「汚れが落ちるのは嬉しいけど、こんなのダメですっ……！　ちゃんと前に進\nまないと……あっ、あふっ！　んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「か、カツマさんっ……！　お願いですから、アクセルを入れてくださいっ…\n…！　速度を出して、前進して……あぁぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「ぐっ、んっ……！　汚れたままの私を見たくないだなんて……！　その気持\nちは嬉しいですけど、今はそれどころじゃ……ひぐぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0103115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「あっ！　あひっ！　ライトカバーにもブラシがあたって……！　こんな力強\nくゴシゴシされるなんてぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「このままだと、おかしくなっちゃいますっ！　全身ピカピカにされる前に、\n気持ちよくてモーターがびちゃびちゃになっちゃうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「ううぅ……！　カツマさんが運転してくれるけど、もう自動運転に切り替え\nて抜け出すしか……！　んっ、ぐっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「早く自動運転に切り替えないといけないのに……！　あっ、んひっ、んぐっ\n！　ダメっ……！　気持ちよすぎて、回路がおかしくなってるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「やっ、あっ……！　前に進めないっ……！　このままじゃ、本当におかしく\n……ひっ、あっ、あはぁぁぁぁぁんっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「な、なんで急にブラシの回転が強くなるんですかぁ！？　こんなの、もっと\n気持ちよくなるに決まってますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0103121" ]},
		{"command":[ "SETIMAGE", "0", "still_00024701_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「ああぁっ！　車輪の隙間にもブラシのヒダヒダが届いて……ああっ！　ひっ\n、んふっ、うぐぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「いつもはくすぐったいだけなのに、停車してるせいで敏感なところにまで毛\n先が届いて……！　こんなの耐え切れませんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「か、カツマさんっ！　先頭車両は十分綺麗になりましたっ！　ですから、車\n体を前に進めてくださいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「んんっ！　くっ、あっ、あふっ……！　まだ窓の方が磨き終えてないだなん\nて……！　も、もういいですからっ！　窓はまた今度……ああぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0103125" ]},
		{"command":[ "SETIMAGE", "0", "still_00024701_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「だ、ダメぇ！　窓の隙間も丁寧に磨かないでください！　もうこれ以上、気\n持ちよくしないでくださいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「あっ！　んっ、あっ！　ひぐっ、んんっ！　先頭車両の隅から隅まで、どん\nどん綺麗になっていってますぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0103127" ]},
		{"command":[ "SETIMAGE", "0", "still_00024701_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「やっ、ひくっ、あぁ！　車体の震えが止まりませんっ！　性的な快感がレー\nルを通じて全身を駆け巡っていって……んんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「台車の奥から気持ちいいのがこみあげてきてるのがわかりますっ……！　こ\nのままだと、イッちゃいますっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「はぁ、んっ！　あっ、んひっ！　か、カツマさんっ！　お願いですから、前\n進してくださいっ……！　それか、この洗車機を止めて……ひぐぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「後続の車輪もどんどん磨かれて……！　んっ、ぐっ、んふっ！　あっ、あっ\n！　私のボディ、もう本当に限界なんですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「このままだと、カツマさんを運転席に乗せたままイッちゃいますっ！　私の\n恥ずかしい姿、見られちゃいますぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「あああぁ！　来るっ！　来ちゃいますぅ！　もうすぐそこまで、気持ちいい\nのが来て……んんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「もう我慢できませんっ！　車体をピカピカに磨かれながら、粗相しちゃいま\nすっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「あっ！　イクッ！　イクぅ！　カツマさんを乗せたまま、イッちゃいますぅ\nぅぅぅぅ～～～～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0103135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024701_01_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「あはあぁぁぁっ！？　気持ちよくて、ウォッシャー液がびゅるびゅる出ちゃ\nってますぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0103136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「せっかく洗車してもらってるのに、私のウォッシャー液でフロントガラスが\nびちゃびちゃになって……あはぁぁぁっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0103137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「やっ、イヤあぁぁぁっ！　カツマさん、見ないでくださいっ！　フロントガ\nラスにびゅーびゅー出てる液体、見ちゃダメですぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「ついでに窓も綺麗になるから丁度いいって……そ、そういう意味じゃありま\nせんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「ああぁっ！　もうっ！　止めたいのに止まらないなんてっ！　私の超人工知\n能、どうにかなっちゃってますぅぅぅ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、はあぁ……あ、あれ……？　いつの間にか、洗車機から抜け\n出してる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0103201" ]},
		{"command":[ "SETIMAGE", "0", "still_00024701_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「汚れが落ちたかどうか確認するために、アクセルを入れて前進させたんです\nか……？　ああっ、それはよかったです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「んんっ……もうすっかり綺麗になりましたので、あとは軽く走って、走行テ\nストをしてください……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0103203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「それで今日の整備は終わりに……って、あれ……？　か、カツマさん。なん\nで後ろに進んでるんですか……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0103204" ]},
		{"command":[ "SETIMAGE", "0", "still_00024701_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「このままバックすると、また洗車機に戻っちゃいますよ……！？　あ、あの\nっ！　今すぐブレーキを……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「あんんっ！　ま、またブラシが私のボディに絡みついてきますぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0103206" ]},
		{"command":[ "SETIMAGE", "0", "still_00024701_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「えっ……！？　誤操作してバックしたから、また洗車機に戻ったって……！\n？　で、でしたら、すぐに前進してください……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「やり方がわからないなら、私が操縦しますので……！　は、早く切り替えを\n……！　あひっ、んんっ！　やっ、ああぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「早くしないと、また洗車機が動いちゃいますっ……！　これ以上車体を磨か\nれたら、おかしくなっちゃうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「ひっ……！？　あっ、やあぁ……！？　この音……！　また洗車機の電源が\n入って……！？　きゃあああああぁぁぁっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0103210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「あはあああぁぁんっ！　また洗車機が動いて、ブラシが全身をゴシゴシ擦っ\nてますぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「さっき十分磨かれたのに、また車体や窓にきめ細かなブラシが入ってきて…\n…！　あひっ、んっ、あっ！　あっ！　あひぃんっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「あっ！　やっ、あああぁんっ！　後ろから洗車機に入ったせいか、さっきと\nは違う気持ちよさが襲ってきますぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0103213" ]},
		{"command":[ "SETIMAGE", "0", "still_00024701_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「こんなのダメですっ！　ようやく気持ちいいの落ち着いてきてたのに、また\n気持ちよくなっちゃいますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0103214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「んひっ、くっ、ああぁ！　さっきイッたばかりだから、またすぐにイキそう\nになってるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0103215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「カツマさんにまた私のはしたない姿を見られちゃう……！　そうなる前に、\n早く洗車機から出ないと……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0103216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「か、カツマさんっ！　バックしたままでいいので、アクセルを入れてくださ\nいっ！　早く私をこの洗車機から出してくださいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「じゃないと……あっ！　んっ、うぐっ！　んふぅっ！　あっ、くるっ……来\nちゃいますぅ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0103218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ！　ダメっ……！　イッ、イクッ……！　洗車機のブラシでさら\nに磨かれながら……イッ、イクッ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「あっあっあっ！　か、カツマさんっ！　お願いですから、早く動いて……あ\nああっ！　イクッ！　イッちゃいますぅぅぅ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま","LABEL1","外して","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「んんんっ～～～～～！！　わ、私またイッて……ひああぁぁぁ！？　またウ\nォッシャー液をびゅーびゅー噴き出してますぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0103301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024701_01_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「あはぁぁあぁぁっ！？　動いてって言ったのに、どうしてアクセルを入れて\nくれないんですかぁ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「気持ちよさそうだったから、もう少し洗ってあげたかっただなんて……！　\nその気持ちは嬉しいですけど、もう洗車は十分なんですぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0103303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「あああぁっ！　お願いですから、早く洗車機から出てくださいっ！　じゃな\nいと、私のウォッシャー液が空っぽになっちゃいますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0103304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「えっ、あの……！　洗車が終わったら補給するから問題ないとかじゃなくて\n、私はこの状況を何とかしてほしいんですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0103305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「んふっ、くっ、あひっ！？　ま、またイッちゃうっ！　ブラシの刺激が強す\nぎて、イクの止まらなくなってるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0103306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「こんなに連続で磨かれたら、もうこの洗車方法でしか満足できない身体にな\nっちゃいますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0103307" ]},
		{"command":[ "SETIMAGE", "0", "still_00024701_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「もしそうなったら、カツマさんが責任をもって毎日洗車してくれるんですか\n……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0103308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「毎日運転席に乗って、始発前から洗車してくれるなんて……！　そ、そんな\n……！　そんなの、幸せすぎますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「やっ、あっ！　洗車される姿を想像したら、またイッちゃうっ！　凄く嬉し\nいけど、もうイキたくありませんーーーっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「んひぃぃぃっ！？　そ、そんな速度を出して洗車機から出たら……！　ああ\nっ！　ダメっ！　イッてるのに、またイクぅぅぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0103401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024701_01_02" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「もうブラシでゴシゴシされてないのに、気持ちいい余韻が残ってますぅ！　\nあっ！　出るっ！　ウォッシャー液が噴き出ちゃうぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「やああぁ！　基本的に走行中はワイパーを動かさないのに、勝手に動いて…\n…んんっ！　自分からフロントガラス磨いちゃいますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0103403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「か、カツマさんっ！　もう洗車機から出たので、速度を落としてぇ！　ブレ\nーキ入れてぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0103404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「敏感なままで走行してたら、もっとイッちゃいますっ！　あっ！　イクッ！\n　イックぅぅぅぅぅ～～～～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0103405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、はあぁ……！　ようやく、停車してくれたんですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0103406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「綺麗にしてくれるのは嬉しいですけど……もう少し運転の仕方を覚えてくだ\nさいね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0103407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「上手く運転できるようになるために、これからも私に乗って練習したいんで\nすか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0103408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「そ、そんなっ！　イヤじゃないですっ！　むしろ、もっと運転してほしいで\nすっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0103409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「……明日も洗車しながら運転させて欲しいんですか？　えっ、いや……！　\n運転するのはいいですけど、洗車はまたの機会にしていただけると……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0103410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}