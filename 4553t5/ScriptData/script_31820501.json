{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0043" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「あら……？　どうしてあなたがここに？　あ、もしかして、今回わたしが依\n頼されたターゲットはあなただったということですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0503101" ]},
		{"command":[ "SETCHARA", "0", "char_00018205_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「こんなところで顔見知りに出会っちゃうなんて……驚きですけど。ふぅ～ん\n？　そうですか♪　今夜はあなたを籠絡してもいいってことですよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0503102" ]},
		{"command":[ "SETCHARA", "0", "char_00018205_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「それなら遠慮なく♪　さっそく籠絡させていただきま～す♪　……あっ、逃\nげられると思わないでくださいね？　こちらもプロですので♪　さてさて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0503103" ]},
		{"command":[ "SETCHARA", "0", "char_00018205_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「んんんんっ……、コレですコレコレぇ……♪　このオチンポを見たら一瞬で\n色々思い出しちゃいました。そうです、こんなにスゴいオチンポは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0503104" ]},
		{"command":[ "SETIMAGE", "0", "still_00018205_01_01" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「あなたくらいしか持っていませんから。間違いなく、ターゲットが確認でき\nちゃいましたよ。すん……すんすん、鼻を近づけただけでこの臭い……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0503105" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「あぁ……胸がドキドキしてきました。それに……あんっ、鼻息が荒すぎて、\nわたしのお股やお尻の谷間がくすぐったくってたまりません……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0503106" ]},
		{"command":[ "SETIMAGE", "0", "still_00018205_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「男の本能♪　ウズウズさせてくれてるんですね～。嬉しい……♪　えぇ？　\nいいですよ、思いっきり感じて、興奮してください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0503107" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「それがわたしのぉ、お・し・ご・とですから♪　それにぃ……こっちだって\n、ムラムラしちゃっていきなりオチンポにこんなことしちゃいますしね～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0503108" ]},
		{"command":[ "SETIMAGE", "0", "still_00018205_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「ん、はむっ……んむっ……♪　ん～～～～♪　硬ぁいぃ……♪　それに……\nんんっ、このアゴが外れそーになる太さ、ずっしり重いオチンポ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0503109" ]},
		{"command":[ "SETIMAGE", "0", "still_00018205_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「んはぁあ……♪　最高ですね、今夜のお仕事は大当たりです。……んんっ、\nそうなんです。このところ、私が満足できるターゲットがいなくって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0503110" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「早く楽しませてくれる標的さんが来ないかな～って思っていたところだった\nので……んちゅっ、まさに♪　お目当てのオチンポを引き当てたというか♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0503111" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「……んっ♪　このオチンポだったらぜーったいに楽しめるってわかるってい\nうか……♪　おしゃぶりしがいのある強いオチンポごちそうになりまぁす」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0503112" ]},
		{"command":[ "SETIMAGE", "0", "still_00018205_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「っんっ……。ん、ちゅ、ちゅっ、ちゅぅ……ふふふっ♪　すっごい♪　もう\nピクピク痙攣してる……なんてカワイイオチンポなんでしょう♪　ちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0503113" ]},
		{"command":[ "SETIMAGE", "0", "still_00018205_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「安心してくださいね～？　私のお口で堕とせなかった人はいませんから、あ\nなたも気持ち良～く籠絡されちゃってください♪　はい、プロにお任せです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0503114" ]},
		{"command":[ "SETIMAGE", "0", "still_00018205_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「舌でペロペロされている間、することがなくて暇でしたら……ふふふっ。わ\nたしのオマンコや、お尻の穴で遊んでいてもいいですよ……って」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0503115" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「あっ♪　もちろんそのつもりでした？　んっ♪　すっごく積極的にお顔を近\nづけてくるじゃないですか～♪　あっ、男らしくて素敵、ですよっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0503116" ]},
		{"command":[ "SETIMAGE", "0", "still_00018205_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「そうだ、どちらが先に相手をイかせるか勝負でもしますか？　それとも、イ\nかせた回数で？　より深くイかせた方が勝ち、でもいいですよ？　あっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0503117" ]},
		{"command":[ "SETIMAGE", "0", "still_00018205_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「……ごめんなさい♪　あなたを煽って本気にさせると、わたしが負ける可能\n性が高すぎますので……今のうちにこちらから攻めさせてもらいますね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0503118" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「んっ、くちゅっ♪　じゅぷっ、じゅぷっ、くちゅっ……♪　はぁ～い♪　ど\nんどん本気で舐め舐めしていきまーす♪　れろっ、れろ、くちゅ、ちゅぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0503119" ]},
		{"command":[ "SETIMAGE", "0", "still_00018205_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「んぁああ……♪　湯気が立ちそうなくらいあっついですねぇ……♪　逞し～\nい……♪　れろっ、れろ……夢中で舐めないと圧倒されちゃいそうです♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0503120" ]},
		{"command":[ "SETIMAGE", "0", "still_00018205_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「れろっ……んれろっ、ぴちゃっ、ぴちゃ……♪　んぅっ？　先走りのお汁が\n垂れて……すすります♪　ぢゅるっ……じゅる、んん、おいひぃ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0503121" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、あなたのオチンポ、本当にかっこよくて大好きぃ……♪　隅か\nら隅まで味わい尽くしますよぉ……。っぐちゅっ、ぐちゅっ、じゅるっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0503122" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「って……あっ！？　あなたの心にも火をっ、つけちゃいましたか……っ？　\nあっ……！　オマンコ、オマンコぴちゃぴちゃ舐められるの気持ちいいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0503123" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「あぁああっ……♪　ンッ、あぁんっ……！　だ、だめっ……♪　なんでそん\nなにクンニうまいんですかぁっ……！　わたしも負けていられませんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0503124" ]},
		{"command":[ "SETIMAGE", "0", "still_00018205_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「んむっ、ぐちゅっ！　じゅぷっ、じゅるっ……！　ぐっちゅっぐっちゅっ、\nれろれろっ……れるっ！　根元から……ぴちゃっ、先端まで丁寧に♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0503125" ]},
		{"command":[ "SETIMAGE", "0", "still_00018205_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「ぴちゃっ、ぴちゃ……くちゅっ♪　裏筋やぁ、カリ首もたーくさんチュパチ\nュパぺろぺろしちゃいますよぉ……。くちゅ、ちゅぷっ、ぴちゃっれろっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0503126" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「あっ♪　ぁっ♪　あっ、あぁんっ……！　お、オマンコだけじゃなくて、…\n…やっ♪　お尻の方までピチャピチャ舐めてますねっ……あっ♪　んぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0503127" ]},
		{"command":[ "SETIMAGE", "0", "still_00018205_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「な、なんでそんなにお口でするの上手なんですかっ？　あっ……♪　プロな\nのにこのままじゃ負けちゃいます、あっ……♪　だめです、わたしがぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0503128" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「わたしが籠絡するのであって、あなたに籠絡されたらお仕事クビになっちゃ\nいますっ……！　ん、あむっ……！　じゅるっ、ぐちゅっぐっちゅっじゅる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0503129" ]},
		{"command":[ "SETIMAGE", "0", "still_00018205_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「んぁああっ♪　本気でおしゃぶりしてるのにっ、あっ♪　クンニで気が散っ\nちゃうっ……！　あっ♪　んむっ、ぴちゃっ……イ、イキそうですっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0503130" ]},
		{"command":[ "SETIMAGE", "0", "still_00018205_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「あっ……♪　んぅううっ♪　れろぉお……じゅぷっ！　こ、こうなったらぁ\n……オチンポ丸ごと咥えこんで……ぐちゅぅうっ！　じゅるじゅるじゅるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0503131" ]},
		{"command":[ "SETIMAGE", "0", "still_00018205_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「んっ、あんっ♪　……やぁんっ♪　舌、オマンコの中に入れちゃ……あっぁ\nっあっ♪　それならわたしも、オチンポの先っちょを……れろれろれろっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0503132" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「ぴちゃっ、ぴちゃ、尿道口をちゅるるるっ……！　んふぅうっ♪　……あ♪\n　舐めるお口が止まってきてますよ？　オチンポここが感じるんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0503133" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「んんっ……♪　いいんですよっ、ぴゅっぴゅしちゃってください……っ♪　\nぐちゅっ！　わたしのお口に精液出してくだひゃい……じゅるっじゅるるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0503134" ]},
		{"command":[ "SETIMAGE", "0", "still_00018205_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「我慢なんてしなくていいん、ですっ……ぢゅるっ！　ぢゅるっ……じゅるっ\n！　さあ、射精してくださいねっ、一気に吸い上げちゃいますよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0503135" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「じゅるるるるるっ！　ぢゅるっ、じゅるるるるるっ……！　んんんんん……\n！　んぷぁあっ、い、いい勢いでひゅ……！　っじゅるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0503136" ]},
		{"command":[ "SETIMAGE", "0", "still_00018205_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「んんんぅ、あっついお汁がびゅるびゅる溢れて……！　ん、ん、ん、んん…\n…！　お口の中に……喉の奥に溜まってく……♪　ごくっ、ごくっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0503137" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「あぁん、腰を引いちゃだめです！　ぜーんぶ飲み干してあげますからね……\n♪　じゅる……じゅる、ごくっ……ごきゅっ……。ん～～～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0503138" ]},
		{"command":[ "SETIMAGE", "0", "still_00018205_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「なんて濃厚な精液……。ぷりっぷりのゼリーみたいな精液が、お口の中にい\nっぱい♪　いつもこんなに射精するんですか？　そ・れ・と・も～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0503139" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「わたしに籠絡されちゃいました～？　あははっ、まだ出し足りなかったんで\nすかね？　オチンポガチガチに硬いまま……。はぁ、はぁ、すごい臭い」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0503140" ]},
		{"command":[ "SETIMAGE", "0", "still_00018205_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「臭くて、でもクセになる……♪　あなたのオチンポも、精液も、オスの臭い\nがプンプンで……メスの本能が刺激されるのがわかります」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0503201" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「……え？　やっぱり、気持ち良すぎて１回の射精じゃ精液が出しきれてなか\nったですか？　なるほどぉ……。実はそれ、わたしもなんですよね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0503202" ]},
		{"command":[ "SETIMAGE", "0", "still_00018205_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「お仕事だから必死に耐えて、平気なフリをしてましたけど……本当は、あな\nたのクンニで軽イキしまくってたんです。ふふ、気付かなかったでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0503203" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「もうあと少しで、喘ぎながらイクってところで、慌てて射精させちゃったの\nで……。次は。２回目はもう少し、じっくり丁寧におしゃぶりしますね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0503204" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「だからあなたも……もっともっとオマンコいじってください。いじめてくだ\nさい♪　それではおかわりいただきま～す……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0503205" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「ん、んんんぅ♪　見て、くりゃはい♪　わたひのお口の中にミッチミチに詰\nまってまひゅぅ……♪　ホントにオチンポデッカすぎれひゅ♪　じゅるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0503206" ]},
		{"command":[ "SETIMAGE", "0", "still_00018205_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「ん～っ、ぐちゅっ♪　ぐちゅっ……。んふぅ♪　喉から頭のてっぺんまれ♪\n　一突きにされているみたいで興奮ひひゃいまひゅねぇ。れろれろれろっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0503207" ]},
		{"command":[ "SETIMAGE", "0", "still_00018205_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「ぐちゅっ！　……ンンッ！？　んふっ！？　あ、あなたのクンニも気持ちイ\nイれひゅよ……！　ふぐぅっ♪　んぐぅっ、愛液が垂れひゃいまひゅ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0503208" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「んっぐっ♪　んぅうっ♪　ぐちゅっ、ぬちゅっ……にちゅっ、ぴちゃっ♪　\nあははっ、胸の間でオチンポビクビク震えてきまひた……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0503209" ]},
		{"command":[ "SETIMAGE", "0", "still_00018205_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「んちゅっ……じゅぷっ！　ぐっちゅっ、ぬちゅっ……！　ふぇ……？　おっ\nぱいもお口の中もあったかくて気持ちいい、れひゅか……？　んふふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0503210" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「褒めてくれてありがとうございまひゅ……♪　お礼にぃ……！　舌全体でオ\nチンポを舐め舐め……♪　んれろっ、ぴちゃっ、れろっ、れるんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0503211" ]},
		{"command":[ "SETIMAGE", "0", "still_00018205_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「ふふっ、これ好きですかぁ？　オチンポ全部を口に含んで、亀頭をぺろぺろ\n……♪　っぴちゃっ、ぴちゃっ、くちゅ、ちゅぷ、ちゅっ、ちゅっちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0503212" ]},
		{"command":[ "SETIMAGE", "0", "still_00018205_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「唾を絡めてぇ……激しく吸い上げます♪　んっじゅるっ！　じゅっぽっ！　\nじゅぽっ、ずちゅっ！　ずちゅっ、じゅるっ、じゅっぷっ、ぐっちゅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0503213" ]},
		{"command":[ "SETIMAGE", "0", "still_00018205_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「んぁあ……♪　おっぱいにまで唾液が垂れて、オチンポがヌルヌルテカテカ\nに照り輝いてます……♪　エッチですね、……ぐちゅっ、ぐっちゅっぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0503214" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「んぁ！？　オマンコもヌルヌルになってきてる、ですか？　それはぁ……あ\nぁんっ♪　だ、だって、あなたがレロレロするから……！　あっあっあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0503215" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「あぁんっ♪　腰がくねくねしちゃう、お尻……揺らしちゃうぅっ！　はぁっ\n、あぁっ……♪　わたしも負けませんからねっ……。ん～～～～っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0503216" ]},
		{"command":[ "SETIMAGE", "0", "still_00018205_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「おっぱいでギュッとオチンポを挟んで……一気にいきますっ！　っぐちゅっ\n！　ぐっちゅっずちゅっ！　ぢゅるっ、ぢゅるるっじゅっぽっじゅぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0503217" ]},
		{"command":[ "SETIMAGE", "0", "still_00018205_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「あっあっダメっ、ダメれひゅっ！　イキまひゅっ……！　あなたのクンニで\n本気イキひひゃうぅうっ！　んぐぅうううっ♪　んぅうううう～っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0503218" ]},
		{"command":[ "SETIMAGE", "0", "still_00018205_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「ぐちゅっ！　あ、あなたもぉ！　あなたも一緒にイッてくだひゃいっ！　お\n願いぃ……！　わたしに籠絡されてぇ♪　じゅるっ、ほらっ♪　ぐっちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0503219" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「オチンポヒクヒクしてますよっ……！　思いっきり出しちゃっれくだひゃい\nぃいっ！　んっ♪　じゅるっ、精液くだひゃいっ……ぐちゅっ、ぐっちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0503220" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「んふぅううううう～っ……♪　んんんんっ！　オマンコイクぅっ！　イクッ\n……！　んんんぅっ！　精子、精子で溺れそう……！　んんぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0503301" ]},
		{"command":[ "SETIMAGE", "0", "still_00018205_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「せっかく出してくれた精液ぃっ……！　んむっ、一滴も無駄にしたくない…\n…！　全部いただきますっ……！　んっ……、ん！　んっんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0503302" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「ごくっ、ごくっ、ごくっ……！　あぁあ♪　飲んでも飲んでも次々に撃ち出\nされて……っ。んぅううっ♪　飲み干すのが間に合わないぃ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0503303" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「んっ！　んんっ……！　精液濃すぎて、喉に絡まってますよ♪　んむぅっ♪\n　舌の上にねっとり広がって……ん、ん、ごくっ……ごくっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0503304" ]},
		{"command":[ "SETIMAGE", "0", "still_00018205_01_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「あぁ……♪　なんて気持ち良さそうな顔で射精してるんですか～……♪　そ\nんなに喜んでもらえると、こっちまで嬉しくなってきちゃいます♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0503305" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「はい♪　じっくり最後までぴゅっぴゅしてください♪　んぅうっ♪　苦ぁい\n……♪　栄養たっぷりの精液、ありがとうございます……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0503306" ]},
		{"command":[ "SETIMAGE", "0", "still_00018205_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「ふぅううっ……♪　残さずキレイに出しきれましたか？　あ、オチンポにつ\nいている精液はわたしが全部舐め取りますから、そのままで～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0503307" ]},
		{"command":[ "SETIMAGE", "0", "still_00018205_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「……自分を籠絡しにきたわたしを、凄まじい射精とオチンポで逆に籠絡する\nなんて……。とんでもない性豪ですね、素直に感動しちゃいました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0503308" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「それに、意外に……クンニも上手で驚いちゃって……。仕事だって思ってい\nても、関係なく何度もイかされちゃって……ふふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0503309" ]},
		{"command":[ "SETIMAGE", "0", "still_00018205_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「たまには、こんな楽しい籠絡もあっていいですよね♪　あははっ、まぁ、わ\nたしの仕事としては……失敗なんですけど♪　すごく気持ち良かったですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0503310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「ぷぁっ！？　んぁああああっ！？　あぁあんっ、あぷぅうっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0503401" ]},
		{"command":[ "SETIMAGE", "0", "still_00018205_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「あああっ……♪　勢いすごすぎですよぉっ……！　あっ♪　顔に……わたし\nの顔にかかっちゃってますっ……！　あっ♪　んぷっ、ぷぁああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0503402" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「オチンポが跳ねて、制御不能になっちゃいましたねっ……！　あんっ♪　真\nっ白な精液が……ばちゃっ、びちゃってひっかかって……あぁんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0503403" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「だめです♪　おっぱいで抑え込んでも、逆に精子の量が増えて……噴き出し\nて……♪　あっ！　あっ、このオチンポ強すぎませんかぁっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0503404" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「あっ！？　あぁんっ、あ、暴れっぱなしで手におえませんんんっ……！　あ\nんっ♪　かかってますっ、わたしの顔がベトベトにぃっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0503405" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「ふふふ……♪　元気なオチンポにしっかりマーキング♪　されちゃいました\n……♪　この臭い、あなたの臭いがこびりついて離れないぃ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0503406" ]},
		{"command":[ "SETIMAGE", "0", "still_00018205_01_11" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「すー、はー……♪　すー、はー……♪　あ～♪　息を吸うたびに、精液の臭\nいでいっぱいに満たされちゃいます……。見てください、この量っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0503407" ]},
		{"command":[ "SETIMAGE", "0", "still_00018205_01_12" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「出しても出してもこれだけ発射できるなんて……全世界の男の人が全員嫉妬\nする絶倫ですよ。もちろん、そんなあなたのオチンポを……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0503408" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「わたしは気にいっちゃって手放せなくなってるわけで……♪　あー、もう♪\n　今日こそわたしにメロメロに籠絡させちゃうつもりだったのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0503409" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「いつもあなたに反撃されて、籠絡されちゃう……♪　プロよりすごい人なん\nて、反則です♪　会社に報告できなくなっちゃいました……♪」", "NORMAL" ]},
