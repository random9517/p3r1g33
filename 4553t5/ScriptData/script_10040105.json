{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0138" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「――と、いうわけで今日は転校生を紹介します」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020116430001" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「スバルよ。今日から地球防衛科に通うことになったわ。もう知り合いの人も\n多いけど、これからよろしく」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_020116430001" ]},
		{"command":[ "SETCHARA", "0", "char_00026802_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA",  "1" ]},
		{"command":[ "SETTEXT", "というわけで、スバルはEDO入隊と同時にこの学園にも転入することになっ\nた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "しっかりしているように見えるスバルだが、たった１人で地球に来て、なにか\nと心細いだろう。俺が副担任として、いろいろサポートを……", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "と、思っていたんだが、数日もしないうちに……", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "ハルカの部下" ]},
		{"command":[ "SETTEXT", "「スバルさん、ちょっといいですか？　宿題でわからないところがあって……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_010116430001" ]},
		{"command":[ "SETCHARA", "0", "char_00002102_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「え？　ああ、これならわかるよ。ここはね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_020116430002" ]},
		{"command":[ "SETCHARA", "0", "char_00026802_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルカの部下" ]},
		{"command":[ "SETTEXT", "「あ！　そういうことだったんですね！　やっとわかりました！　それと――\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_010116430002" ]},
		{"command":[ "SETCHARA", "0", "char_00002102_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「スバルちゃーん！　ルルーナちゃんと学食いかない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010116430001" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「いいわよ、でもちょっとだけ待って。あとこの問題を――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_020116430003" ]},
		{"command":[ "SETCHARA", "0", "char_00026802_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「スバル、例の話だけど――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020116430001" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「ああ、この前教えてもらったゲームの話ね。ちょっと触ってみて、だいたい\n操作感覚は掴めたわ。必要そうな装備もゲットしたし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_020116430004" ]},
		{"command":[ "SETCHARA", "0", "char_00026802_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「もう？　思ったより早いね。それじゃ、今日の１０時ぐらいから、みんなで\nバトルしようと思うんだけど――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020116430002" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「わかった。それぐらいにログインするわ。私のキャラはわかるでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_020116430005" ]},
		{"command":[ "SETCHARA", "0", "char_00026802_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「うん、大丈夫。それじゃ、待ってるから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020116430003" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "と、いう具合でスバルはすっかりみんなと馴染んでしまっているし、俺の出る\n幕はまったくない。そればかりか――", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「……ここ数日、誰も社会科準備室を訪ねてこなくなりましたな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020116430001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まあな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「以前はルルーナ様やつきみ殿まりあ殿、桃花殿、マーガレット殿も連日入り\n浸っておられたのに」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020116430002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あいつら、スバルと遊びに行ってるよ。まあ、あいつらが仲良くなったのは\nいいことだな。こっちも助かるし」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「本当にそう思っておられるので？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020116430003" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あいつら、この部屋を部室かなんかと勘違いしてたからな。来なくなったお\nかげで静かに仕事ができるし、いいじゃねえか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「やれやれですな。相変わらずご主人は素直でない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020116430004" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うるへーバカ犬！　さっきから何をごちゃごちゃと――」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA",  "1" ]},
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「カツマ先生」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_020116430006" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "SETCHARA", "1", "char_00026802_01", "3", "CENTER", "1500" ]},
		{"command":[ "MOVECHARA", "1", "CENTER", "400", "NORMAL" ] },
		{"command":[ "MOVECHARA", "0", "CENTER", "-400", "NORMAL" ] },
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うぉっ！　スバル！？　な、なんだ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「明日楽先生に、みんなでカツマ先生を探してくるように言われて。職員会議\nが始まるから急げって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_020116430007" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いっけねえ、忘れてた！　ちょっと職員室行ってくる！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA",  "0" ]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「はいはい、いってらっしゃいませー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020116430005" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "-400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA",  "1" ]},
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「じゃ、用事は伝えたから私はこれで――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_020116430008" ]},
		{"command":[ "SETCHARA", "1", "char_00026802_01", "6", "CENTER", "400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「……あ、でもさあ、ジュンジロー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_020116430009" ]},
		{"command":[ "SETCHARA", "1", "char_00026802_01", "3", "CENTER", "400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA",  "0" ]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「なんですかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020116430006" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "-400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA",  "1" ]},
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「カツマ隊長も、EDOと先生のダブルワークで大変だよねえ……私も、少し\n手伝ってあげたほうがいいのかな。新人としては」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_020116430010" ]},
		{"command":[ "SETCHARA", "1", "char_00026802_01", "4", "CENTER", "400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA",  "0" ]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ふむふむ……そうですな、そうしていただければ、きっとたいへん面白いこ\nとに――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020116430007" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "1", "CENTER", "-400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA",  "1" ]},
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「面白い？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_020116430011" ]},
		{"command":[ "SETCHARA", "1", "char_00026802_01", "3", "CENTER", "400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA",  "0" ]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「いえいえ！　ご主人も助かることかと思いますぞ！　ぜひぜひ、よろしくお\n願い致しますぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020116430008" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "8", "CENTER", "-400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA",  "1" ]},
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「わかった。明日から、できるだけやってみるよ。それじゃ、みんなが待って\nるから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_020116430012" ]},
		{"command":[ "SETCHARA", "1", "char_00026802_01", "6", "CENTER", "400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA",  "0" ]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「はいはい、お手数おかけしましたな。ありがとうございますぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020116430009" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "-400" ]},
		{"command":[ "MOVECHARA", "1", "CENTER", "1500", "NORMAL" ] },
		{"command":[ "MOVECHARA", "0", "CENTER", "0", "NORMAL" ] },
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "（さてさて……スバル殿がそう来るとなると……これはご主人の反応が楽しみ\nですな！）", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020116430010" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "（退屈な日常に、ちょっとした波乱が……ムホホホホホホ！）", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020116430011" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}