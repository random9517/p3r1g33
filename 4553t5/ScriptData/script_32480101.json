{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024801_01_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「あの……！　今日は本当にカツマ先輩が手洗いで洗車してくれるんですか…\n…！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0103101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「い、いえっ！　イヤだなんて思ってませんっ！　むしろ、カツマ先輩の手で\n洗ってもらえるなんて、凄く嬉しいですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0103102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「ただ、普段ノゾミが見せないところを見せてしまうので、恥ずかしいと言い\nますか……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0103103" ]},
		{"command":[ "SETIMAGE", "0", "still_00024801_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「それにあまり手洗いされたことがないので、変な声が出てしまいそうで……\n！　も、もしそうなっても、気にしないでくださいねっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0103104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「あっ、さっそくブラシで磨いてくれるんですね！　えっと、ブラシに洗剤を\n付けるときは、この専用洗剤を使ってください！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0103105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「ノゾミは普通の新幹線よりも精密にできてるので、専用洗剤じゃないと身体\nに傷がつきやすいみたいでして……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0103106" ]},
		{"command":[ "SETIMAGE", "0", "still_00024801_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「ふふっ。洗剤はたっぷり付けてくれて構いませんよ！　ヌルヌルの洗剤をブ\nラシに塗れさせて、いっぱいゴシゴシしてくださいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0103107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「ただし、精密部品のあるところや、ガラスのある個所は少し力を抜いてゴシ\nゴシしてくださいね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「あまり力強くブラッシングされると、パーツが破損したり、窓ガラスが割れ\nる恐れがあるので！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「あっ、洗剤も付け終わったみたいですね！　では、よろしくお願いしますっ\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「あんんっ……！　これがカツマ先輩のブラッシング……！　力強い腕の動き\nが、ブラシを通じて車体に響いてきますっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0103111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「普段使ってる洗車機と違って、激しくゴシゴシされる感じがたまりませんっ\n……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「それに機械みたいに規則正しい動きじゃなくて、カツマ先輩らしい不規則な\n動きが凄く素敵ですっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「こうやって好きな人の手で車体を磨いてもらえるなんて、新幹線冥利に尽き\nますっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ……！　ダメです、カツマ先輩……！　先頭車両はノゾミの敏感\nなところの一つで……んくぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0103115" ]},
		{"command":[ "SETIMAGE", "0", "still_00024801_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「できればもう少し優しく磨いてもらえると嬉しいんですが……ああっ！　ひ\nっ、あはあぁんっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「そんなっ……！　優しくって言ってるのに、さらに力強くゴシゴシされるだ\nなんてぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「こんなの、変な声が止まらなくなっちゃいますっ……！　ライトも自然に反\n応して、ピカピカ光っちゃいますぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「先頭車両は一番風があたるから、しっかり磨いておいた方がいいと思うって\n……！　そ、それはそうなんですが……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「連結してる他の車両もしっかり磨いて欲しいと言いますか……！　ひゃんっ\n！？　あっ、んっ！　あはぁっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「ブラシの動きに合わせて、ヌルヌルでふわふわの泡が、車体の隙間にどんど\nん入ってきてますっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「車輪の方にも洗剤が垂れてきてるっ……！　あっ、んふっ……！　このヌル\nヌルが滴ってくる感覚だけで、感じちゃいますっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0103122" ]},
		{"command":[ "SETIMAGE", "0", "still_00024801_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「はぁ、あっ、あぐっ……！　か、カツマ先輩っ……！　ノゾミの超人工知能\n、どんどん変になってきてますっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「もっと色んなところを強く磨いて欲しいって訴えてるみたいで……！　あ、\nあの……もっと激しくしてもらってもいいですかっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「あぁぁぁんっ！　そ、そうですっ！　そんなふうにブラシを思いっきり押し\n付けながら、グリグリしてくださいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「それで泡をいっぱい車体に塗り込んで……んっ、んんっ！　あっ、やっ、ん\nぐっ、あはあぁっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「窓ガラスに泡が染み込んできますっ！　ノゾミの車体、どんどん真っ白にな\nっていってますぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「ひあああぁぁぁ！？　換気装置の隙間にもブラシが当てられてるぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「だ、ダメですっ、カツマ先輩っ！　換気装置の近くには換気口と排気口はあ\nって……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「泡に交じって、洗剤の香りが車内に広がっちゃいますっ……！　ノゾミの車\n内がいい香りで満ち溢れちゃいますぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「あっ、でも、それってよく考えたら……車体だけじゃなくて、車内までカツ\nマ先輩の手で綺麗にされてるってことになるんじゃ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「やっ、あっ！　ひぅぅっ！？　あっ、あっ……！　そんなの、想像しただけ\nでイッちゃいそうですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「か、カツマ先輩っ！　ノゾミ、もう我慢できませんっ！　ブラッシングされ\nながら、イッちゃいますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「あっ！　あっ！　来るっ！　後尾車両から先頭車両まで、気持ちいいのが一\n気に駆け抜けてきますぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「イッ、イクッ！　イクぅ！　カツマ先輩の手で綺麗にされながら、イッちゃ\nうううぅぅぅっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0103135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024801_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「あっはああぁぁぁっ！？　気持ちいいのが溢れて、ウォッシャー液が噴き出\nしてますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0103136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「カツマ先輩の前なのに、こんなにだらしなくびゅーびゅー噴き出して……！\n　やあぁっ！　見ないでくださいぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0103137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「えっ！？　ウォッシャー液が出たから、ついでにフロントガラスを磨くんで\nすかっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「ちょ、ちょっと待ってくださいっ！　こんな状態でフロントガラスを磨かれ\nたら、さらに気持ちよくなっちゃいますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「あっ！　ダメっ！　ダメなのにぃ！　ブラシの感覚が気持ちよくて、ウォッ\nシャー液が止められません～～～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「あうぅ……ウォッシャー液と洗剤が混ざって、かなりベタベタしてます……\n！　せっかく洗ってくれたのに、汚してすみません……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0103201" ]},
		{"command":[ "SETIMAGE", "0", "still_00024801_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「ですが、おかげで車体がかなり綺麗になりましたっ！　ありがとうございま\nすっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「えっ……？　まだ車両の先端を磨いてない……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0103203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「えっ、あのっ……！　先端部分は水をかけていただくだけで大丈夫ですっ！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0103204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「だって、車両の先端はノゾミの中でも特に敏感なところで……！　あっ……\n！　か、カツマ先輩っ！　ちょっと待ってくださいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「きゃあああぁっ！？　ブラシが先端部分に当たって、力強くゴシゴシされて\nますぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「ライトカバーにも洗剤が染み込んできて……！　やっ、んぐっ……！　ヌル\nヌルの感触がさらに強くなってきてるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「はぁ、あふっ……！　んっ、あっ、ひぐうぅ……！　連結器カバーのところ\nに激しくブラシがあたって……あぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0103208" ]},
		{"command":[ "SETIMAGE", "0", "still_00024801_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「そんなにされたら、カバーが開いちゃいますっ！　ノゾミの大事なところ、\n丸見えになっちゃいますぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「カバーがくぱぁって開いたら、恥ずかしすぎて生きていけませんっ！　お願\nいですから、違うところを磨いてくださいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0103210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「あっ、そ、そうですっ！　カツマ先輩っ！　乗降口が磨きたりないみたいな\nので、そっちを磨いてくださいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「乗降口は人が出入りするところですので、念入りにブラッシングして欲しい\nんですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ！　そ、そうですっ……！　その扉のところを中心に、思いっき\nりブラシで擦って……んっ、あっ！　ふっ、くぅ、あっ、あぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「んふっ、あふっ……！　人がたくさん出入りするところだから、ここも敏感\nなところだけど……連結器カバーよりはマシかもっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0103214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「んっ、んんっ！　ひっ、あっ、うぐっ……！？　ブラシが少しずつ、先端に\n近づいてきてるっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0103215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「先端の方が尖ってるせいか、手を動かす反動でどうしても先端にブラシが向\nかうだなんて……！　そ、そんなっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0103216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「やああぁっ！　ダメっ！　ダメですっ！　カツマ先輩、お願いですから側面\nの方を重点的に磨いてくださいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0103217" ]},
		{"command":[ "SETIMAGE", "0", "still_00024801_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「それが無理なら、フロントガラスかライトカバーでいいですからっ！　お願\nいだから、先端の敏感なところは刺激しないでぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0103218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「あっ！　ダメっ！　またブラシがどんどん先端に近づいてきてるっ……！　\nダメっ！　こんなの、またイッちゃうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「んっ、んんっ！　イクッ……！　イッ、イッちゃうっ……！　あはあぁぁっ\n！　イッ、イキますぅぅぅっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま","LABEL1","外して","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「あはぁぁぁんっ！　イクのと同時に、先頭車両の先端にブラシが当たってま\nすぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0103301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024801_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「ダメって言ってるのに、敏感なところをゴシゴシされてっ……！　やあぁっ\n！　これ、凄く感じちゃいますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「こんな快感、洗車機では味わったことありませんっ！　今までで一番気持ち\nいいですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0103303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「こんなの、本当に連結器カバーが開いちゃうっ！　ノゾミの先頭車両の中、\n全部見られちゃうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0103304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「くぱぁするのだけはダメぇ！　お、お願いします、カツマ先輩っ！　早くブ\nラシを違うところに移動させてっ！　もうこれ以上擦らないでぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0103305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、あっ……や、やっとブラシが違うところに移動してますっ…\n…！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0103306" ]},
		{"command":[ "SETIMAGE", "0", "still_00024801_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「カツマ先輩っ……！　汚れが気になるのはわかりますが、先端部分だけはも\nっと慎重に磨いてくださいね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0103307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「……えっ？　表面ばかりに気を取られて、車体の下側を洗うのを忘れてた…\n…？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0103308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「ま、待ってくださいっ！　車体の下側は、洗車機でも洗わないところですよ\nっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「やっ、あっ……！　だ、ダメっ！　下側まで磨かれたら、今度こそ連結器カ\nバーが開いちゃいますからぁっ！　あっ！　あっ！　ダメぇぇぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「きゃああああぁぁぁっ！？　急に冷たい水が全身にかかって……あっ！　ん\nっ、ひぁっ、あはぁっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0103401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024801_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「これ、気持ちいいですっ！　カツマ先輩の手で磨いてたところを洗い流され\nるの、たまりませんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「こんな大量の水を一度にかけられたら……！　冷却されてるのに、車体が熱\nを持っちゃいますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0103403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「あっ！　ダメっ！　またウォッシャー液が出ちゃうっ！　気持ちいいのに反\n応して、びゅーびゅー噴き出ちゃうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0103404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「あはぁぁぁっ！　イクッ！　またイキますぅ！　ウォッシャー液をまき散ら\nしながら、何回もイッちゃいますぅぅぅ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0103405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「んっ……あふっ……やっと火照りが収まってきました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0103406" ]},
		{"command":[ "SETIMAGE", "0", "still_00024801_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「あのっ……カツマ先輩の前でこんなに粗相をするなんて……本当にごめんな\nさいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0103407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「せっかくカツマ先輩が手洗いで洗車してくれたのに……ノゾミったら、感じ\nてばかりで……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0103408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「ノゾミが綺麗になってくれて嬉しい……？　あっ、いえ、そんなっ……！　\nひ、ノゾミも綺麗にしてもらって、嬉しいですっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0103409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「も、もしよかったら、また次もカツマ先輩の手で洗車してくださいっ！　ノ\nゾミ、いつでも待ってますからっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0103410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}