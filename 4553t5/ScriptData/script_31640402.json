		{"command":[ "PLAYVOICE", "v2_164_0404210" ]},
		{"command":[ "SETIMAGE", "0", "still_00016404_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「ひゃふっ、んんっ……あっ……んむっ、おとーさんっ……キスぅ……ちゅぷ\nっ、んふっ……うんっ、んふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0404211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
