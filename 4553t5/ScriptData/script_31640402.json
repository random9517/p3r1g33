		{"command":[ "PLAYVOICE", "v2_164_0404207" ]},
		{"command":[ "SETIMAGE", "0", "still_00016404_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「んぁっ、ふぁんっ……あっ、はぁぁぁんっ！　きもちーのっ……おとーさん\nっ、もっと奥にしてっ、あんっ、そこっ、そこがいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0404208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
