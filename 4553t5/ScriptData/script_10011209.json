		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「新手ってことかよ。まあいいや、何度でも来やがれってんだ。またぶちのめ\nしてやらぁ！」", "NORMAL" ]},
