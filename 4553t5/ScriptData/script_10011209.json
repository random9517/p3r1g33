		{"command":[ "SETCHARA", "0", "char_00000601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「きゃああああああーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010112170003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「お、おい！　見ろ！　あそこ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010112170003" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "3", "CENTER", "0" ]},
