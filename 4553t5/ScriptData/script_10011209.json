		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「はああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010112170001" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「おんどりゃああああ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010112170001" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「おー！　やるじゃんか、みんな！　私も負けてらんないな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010112170001" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「だったらおしゃべりしてないで、戦ってください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010112170001" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「放て！　竜の咆哮（ドラゴンズロア）！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090112170001" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「どうだ！　これで勝負あったな！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「でしょうな。ご主人は特になにもしておりませんが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010112170001" ]},
		{"command":[ "SETCHARA", "0", "char_00000901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うるせえ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "円盤少女" ]},
		{"command":[ "SETTEXT", "「くっ……ううううっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_010112170001" ]},
		{"command":[ "SETCHARA", "0", "char_00016201_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "円盤少女" ]},
		{"command":[ "SETTEXT", "「これで勝ったと思うな……お前たちは必ず滅ぼされる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_010112170002" ]},
		{"command":[ "SETCHARA", "0", "char_00016201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「やった！　あいつ逃げてくぞ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010112170002" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「わーい！　ダイヤナちゃんたちの勝ちぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010112170001" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「やれやれだぜ……みんな、怪我はないか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「うん！　大丈夫！　っていうか――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_020112170001" ]},
		{"command":[ "SETCHARA", "0", "char_00001302_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「怪我をしてるのはカツマだけ。こっちへ来て。手当てする……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010112170001" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああ、そっか？　悪いな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「さて、怪我人の世話はカグヤに任せて、地球に引き上げる準備にかかろうか\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010112170001" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「そうですね。帰りは特に、ワームホールも必要なさそうですし――って、あ\nら？　ミス・パープルは？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010112170002" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「帰ったようですよ？　別の仕事があるとかで」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010112170002" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「そうですか。あの人もずいぶん忙しいですね。それはともかく、いったんみ\nんなを呼び集めて――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010112170003" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYBGM", "BGM_005" ]},
		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「今のは！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010112170004" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「わかりません。ですが、向こうの空でなにかが光ったような――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010112170002" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「また！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010112170003" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「いったいありゃなんだい？」", "NORMAL" ]},
