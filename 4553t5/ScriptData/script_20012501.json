		{"command":[ "SETCHARA", "0", "char_00022201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「ぐっ……はっ、あっ……クソっ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010021970012" ]},
		{"command":[ "SETCHARA", "0", "char_00012701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「通じなかった……私のこの右手が……切り札のサメ抹殺爆弾まで使ったのに\n！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010021970013" ]},
		{"command":[ "SETCHARA", "0", "char_00012701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「空を飛ぶサメを倒したチェーンソーも、トリプルヘッドのサメを倒した斧も\n、タコと合体したサメを倒した水中銃も、古代から蘇った始祖のサメすら屠っ\nてきた私の右手が……っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010021970014" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「あいつには通じなかった……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010021970015" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「この私が、逃げるしかできなかった……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010021970016" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「なんという屈辱……ぐうっ、うううううううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010021970017" ]},
		{"command":[ "SETCHARA", "0", "char_00012701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「私が……サメを殺すためだけに存在している私がサメを殺せなかった……！\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010021970018" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「強く……ならなくては」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010021970019" ]},
		{"command":[ "SETCHARA", "0", "char_00012701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「この世全てのサメを殺せるぐらいに、強く……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010021970020" ]},
		{"command":[ "SETCHARA", "0", "char_00012701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「見ていて、父さん、母さん。私はやってみせる……この右手に誓って！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010021970021" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0078" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「んん……なんか聞こえたな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_010021970001" ]},
		{"command":[ "SETCHARA", "0", "char_00009502_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「サメの嘆き、悲しみ、声ならぬ声がアタイの耳に聞こえてきたぜ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_010021970002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「ゴーストども……テメーらにも聞こえたか、サメの声が」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_010021970003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「分かってる。またぞろあのサメハンターの女が罪なきサメをいじめてんだな\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_010021970004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「平和な海を乱すサメハンター……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_010021970005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「許せねえ……天と地が許しても海のアタイが許さねえ！！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00009502_01", "7", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_095_010021970006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「この新しい力も得たところだし、目にもの見せてやる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_010021970007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「待ってろ！！　アタイがこの世全てのサメの痛みを思い知らせてやる！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_010021970008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「行くぞ野郎ども！！　テメーらの怨みを晴らすときが来た！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_010021970009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「アタイたちの怒り、今度こそあの女の身体に刻みつける！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_010021970010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「カエル……カエル……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_010021970010" ]},
		{"command":[ "SETCHARA", "0", "char_00022201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_010021970011" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0092" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「ん……予約したコテージはここね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_010021970001" ]},
		{"command":[ "SETCHARA", "0", "char_00015901_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「うん、いい感じだわ。下調べはしていたけれど、拠点としては合格点ね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_010021970002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「この近辺に眠るという『大いなる力』、その探索には長期戦が確実」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_010021970003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「少し値段は張ったけど、心身ともに充溢しなければ世界征服は成し得ないわ\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_010021970004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「ん、ちょっと空気が淀んでいるわね。それに少し汚れてもいる。シーズン初\nの予約らしいから仕方ないけれど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_010021970005" ]},
		{"command":[ "SETCHARA", "0", "char_00015901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「なら……これでどうかしら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_010021970006" ]},
		{"command":[ "SETCHARA", "0", "char_00015901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「魔導というのも憚れるような術だけれど、私の手にかかればこんなものね。\nきれいになったわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_010021970007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「さて、水回りや寝室も確認しにいきましょうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_010021970008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「カエレ……ル？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_010021970012" ]},
		{"command":[ "SETCHARA", "0", "char_00022201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「台所も風呂も思っていたよりも上質。寝室も文句なし。いいわね。全てがう\nまく回っている感じだわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_010021970009" ]},
		{"command":[ "SETCHARA", "0", "char_00015901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「そして――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_010021970010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「極めつけはこれ！！　海域探索に適したこの装備！！」", "NORMAL" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_010021970011" ]},
		{"command":[ "SETCHARA", "0", "char_00015903_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「待ってなさい、洞窟の秘宝。私が手に入れた暁には、あまねく生物全てを支\n配してみせるわ……ふふ、ふふふふふ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_010021970012" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_010021970013" ]},
		{"command":[ "SETCHARA", "0", "char_00022201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}