{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0084" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「ふぅ……浅瀬でちょっと水遊びをするだけでも、とても楽しいですね。中々\n身体を動かす機会もありませんでしたし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0603101" ]},
		{"command":[ "SETCHARA", "0", "char_00003006_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「本当に連れてきて下さって、ありがとうございました。日頃の感謝だなんて\n……それは私も日々お世話になっていますし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0603102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「私からも、せめてものお返しをしたいのですが……よろしいでしょうか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0603103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「くすっ、ありがとうございます。その、大したことはできません……ほんの\n気持ちということで……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0603104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んふ……外で……こんな風におっぱいを露出するのは……少し恥ずかしいで\nすね……でも、今は周囲に人もいませんから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0603105" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00003006_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あなたにでしたら……私の乳首も……見せていいと思っていますので……あ\nっ、ふふ……ドキドキして、もう母乳が出始めてます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0603106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あなたのオチ〇ポも、逞しく反り返ってらっしゃいます……はい、よろしけ\nれば、このまま谷間の中に入れて頂ければ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0603107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あっ……んんっ、ふっ……熱いオチ〇ポ……おっぱいの中に呑み込まれてい\nきます……んんっ……素敵ですわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0603108" ]},
		{"command":[ "SETIMAGE", "0", "still_00003006_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んふっ、一緒に遊んでいる間も、ちょっと谷間を気にされているようでした\nから……心行くまで、中を味わって下さいね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0603109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「それでは……軽く動かしていきますね……んっ、ふっ、はっ、んっ、ふっ…\n…はぁ……んっ、あ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0603110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「いかがでしょうか……なるべくお肌が密着するように……もっと寄せていき\nますね……んんっ、あっ、ふぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0603111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「気持ちいいですか？　それは何よりです。まだまだ……もっと、感じていた\nだけるようにおっぱい……シコシコ致しますね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0603112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「うんっ、んふっ、はっ、んっ……あぁ、母乳が滲んで……乳首……いやらし\nく尖ってしまいます……恥ずかしい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0603113" ]},
		{"command":[ "SETIMAGE", "0", "still_00003006_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「いつも大胆な服なのにおかしいですか？　ですが、やはり先端をお見せする\nのは……私としても恥ずかしいんですよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0603114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「ですから、今も……すごく胸が高鳴って……ドキドキしています……すぐそ\nこに素敵なオチ〇ポもありますから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0603115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あら……んっ、ふふっ、おっぱいの中でオチ〇ポがびくんって震えましたね\n。動かしたくなっちゃいましたか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0603116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「構いませんよ……どうぞ、お好きなように……私のおっぱいをあなたの太く\nて逞しいオチ〇ポで犯して下さいませ……んはぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0603117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あっ、あぁんっ……谷間の中で……あっ、オチ〇ポ……ずりゅずりゅっ、動\nいて来ますっ……んぁっ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0603118" ]},
		{"command":[ "SETIMAGE", "0", "still_00003006_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「一生懸命……腰を振って……ふふっ、とっても可愛らしいですわね……ああ\n、殿方に言うのは少し失礼だったかも知れません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0603119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「ですが、私のおっぱいに一生懸命腰を振っていただいてる姿は……とても愛\nおしくて……つい、口に出てしまいました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0603120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あんっ、あぁっ、そうですわね……もっと雄々しく、オスとしての本能の部\n分を見せて下さいませ……もっとおっぱいを犯して……あんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0603121" ]},
		{"command":[ "SETIMAGE", "0", "still_00003006_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はっ、んふっ、あっ、あぁっ……開放的な浜辺で……はしたなくおっぱいを\n丸出しにして……パイズリするなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0603122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「自分で言いだしたことですけど……んんっ、とても興奮して……あぁ……奥\nの芯が疼いてしまいますわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0603123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んふっ、私の方からも動いてよろしいですか？　はい……いっぱい気持ちよ\nくなっていただきたいですから……失礼します」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0603124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「うんっ、あふっ、下から……支えて……寄せ合わせながら、上下に……シコ\nシコ……むにむに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0603125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んっ、あぁっ、はぁんっ、重なり合う場所が熱くて……汗と母乳が……滲ん\nで……はぁぁ……ヌルヌルになっていきます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0603126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「もっと大きく動かしますね……んんっ、はふっ、んくぅっ……あっ、ふぁっ\n……あっ、んんっ……はっ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0603127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んっ……あぁ……擦れ合う音……いっぱいします……明るい陽射しの中で…\n…いやらしい音……はぁ、んっ、ふぁっ……は……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0603128" ]},
		{"command":[ "SETIMAGE", "0", "still_00003006_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「でも、もっとさせたくなってしまいます……あふっ、オチ〇ポとおっぱいで\n……んぁ……セックス……あぁんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0603129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、ぎゅうっとおっぱいで包み込んで……オチ〇ポの弱い所を集\n中的にぐにぐに……あっ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0603130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あぁ……んっ、先走りがピュッと出ましたわ……んふっ、いい匂いがしてい\nます……もうちょっと我慢できますか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0603131" ]},
		{"command":[ "SETIMAGE", "0", "still_00003006_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はい、全体を満遍なく扱き上げて……少しでも気持ちいいお射精ができるよ\nうに快感を溜めていければと……あ、んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0603132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はぁっ、んっ、あふっ……あぁっ、あなたの腰使いも……どんどん激しくな\nって……あっ、うんっ、ずりずりっ……しますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0603133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「ふぅっ、あんっ……あぁ……私のおっぱいも感じています……オチ〇ポと一\n緒に、気分が高まって……はぁぁっ……素敵です……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0603134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はぁ、んっ……あぁっ、この震え方……そろそろ限界ですか？　はい……ど\nうぞ、このまま中に出して下さい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0603135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「私のおっぱいマ〇コが……あなたの新鮮な精液を欲しがっております……ど\nうか、たっぷりとお射精なさって下さい……んっ、あぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0603136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あんっ……！　はぁぁん……あぁ……ドクドク……濃厚なオチ〇ポミルクが\n……おっぱいに流れております……あふっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0603137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003006_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はぁぁ……熱いですわ……それに、とても粘っこくて……いつ浴びても、お\nっぱいが悦んでしまいますの……んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0603138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「もっとピュッピュしましょうね……んんっ、ぎゅって寄せると……また、新\nしいお汁……搾られています……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0603139" ]},
		{"command":[ "SETIMAGE", "0", "still_00003006_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はぁ、あふっ……いっぱい出して下さいましたね……おっぱいが熱いです…\n…んふっ、気持ちいいですわ……は、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0603140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んっ……ふふ……すごいですね……おっぱいの中、ドロドロになって……ず\nっと気持ちいいままです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0603201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「でも、オチ〇ポはまだまだ硬くて……脈もすごい……一発だけじゃ出し足り\nないようですね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0603202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はい、もちろん……心行くまでおっぱいを楽しんで頂きたいですし、私もも\nっともっとご奉仕して差し上げたいですわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0603203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「このまま、また続けて下さい。発情してギチギチになったおっぱいも弄り回\nして……私のおっぱいをオチ〇ポで犯して下さい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0603204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あんっ、はっ、あふっ……ふふっ、本当にお元気なオチ〇ポです……んっ、\n精液で滑りやすくなって……もっと気持ちよくなって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0603205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「寄せて……ズリズリ扱くおっぱいにも……はぁっ……もっと力が入ってしま\nいます……んふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0603206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あっ、んんっ、あ、ふっ……あぁ、こんな明るい外でする肉の交わり……興\n奮して……また母乳が……あぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0603207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あふっ、私も……いっぱい溢れさせてしまって、恥ずかしいです……んんっ\n！　あっ、、はい、乳首……つまんで……搾って下さい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0603208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「そのまま……ぴゅって出ますわ……あっ、あぁんっ、出るっ……母乳っ……\n出てしまいますぅっ、んんぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0603209" ]},
		{"command":[ "SETIMAGE", "0", "still_00003006_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あっ、ふっ……おっぱいが出る度に、軽くイッた時と同じような感じになる\nんです……乳首がムズムズして……あんっ、そ、そこぉ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0603210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んぁっ、んふっ……この母乳をまぶしながら……パイズリ……もっと、密着\nさせていきます……んっ、くっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0603211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はぁっ、あんっ、あっ、はっ……あぁ、一生懸命腰を振って……オチ〇ポが\n熱くなって……あっ、はひぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0603212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あんっ、はっ、ぐちゅぐちゅっ……いやらしい音……あぁ、勃起乳首が……\n勃起オチ〇ポと擦れあって……ジンジンしますっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0603213" ]},
		{"command":[ "SETIMAGE", "0", "still_00003006_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あ、くっ……あぁっ……コリコリの感触、気持ちいいですか？　んふっ、皮\nの付け根がぴくんって震えて……可愛いですわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0603214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あぁ……でも、動きはとっても男らしくて……あぁっ、私のおっぱいマ〇コ\n……どんどん気持ちよくなっていきます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0603215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はっ、んんっ、オチ〇ポも、そろそろ……次の準備が整いつつありますね。\nビクビク震えて、息も乱れて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0603216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あっ、んんっ……お好きな時に射精なさって下さいませ……私のどこにでも\n……あなたの欲望をぶち撒けて欲しいんです……」", "NORMAL" ]},
