{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0177" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_005" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「と、いうことで残るは第４位……なんだけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010022880001" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 	
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ジェスタが話し終えるのが待てなかったのか、ちょこちょこ会話に混ざってき\nていた縦ロールの少女が一歩前に出た。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「あ～ら、ようやく真打の登場ですわねぇ♪　待ちくたびれましてよ。うふふ\nふっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_010022880001" ]},
		{"command":[ "SETCHARA", "0", "char_00026001_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「その目ん玉かっぽじってよーくお聞きあそばせ。私こそが遠い銀河にある、\nさる帝国の貴族にして優れた軍人でもあるアンドレッテ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_010022880002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「あ。そろそろ時間だね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010022880002" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「んんんん！？　お、お待ちなさい！　私はまだ自分の名前すらろくに紹介し\nておりませんわよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_010022880003" ]},
		{"command":[ "SETCHARA", "0", "char_00026001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「それはそれは可哀想だけど、４位が喋れるのはここまで！　お開きにしよ\nう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010022880003" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「んんんん～っ！？　なんという軽い扱いでしょう！？　このアンドレッテ・\nスプーンの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_010022880004" ]},
		{"command":[ "SETCHARA", "0", "char_00026001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ごめんごめん。でも、ここまでのやり取りで、大体キミのキャラは伝わった\nと思うから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010022880004" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「そんなぁ！　全然足りていませんわよ！　私は他の方々と違って、浅いキャ\nラ設定なんてしておりませんの！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_010022880005" ]},
		{"command":[ "SETCHARA", "0", "char_00026001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「全てをお話するには長い時間……。そう、数日はみていただかないと！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_010022880006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ふ～ん。でもダ・メ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010022880005" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「って、きゃ～！　本当にお開きにするつもりですのねぇ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_010022880007" ]},
		{"command":[ "SETCHARA", "0", "char_00026001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "露骨にオロオロしだしたアンドレッテには、既に興味はなくなったらしい。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ジェスタはブォン！　とワームホールを召喚し、そこに飛び込め、というジェ\nスチャーをしてみせた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「気にせず行っちゃって。はいはい、これでおしま～い」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010022880006" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「終わらせるものですか！　キィイ！　お聞きなさい！　私の華麗なる歴史と\nその全貌を！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_010022880008" ]},
		{"command":[ "SETCHARA", "0", "char_00026001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「う～ん。時間がおしてるからまた今度～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010022880007" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「あ～～～ん！　クソザコメンタルの私にひどいことをなさるなんてぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_010022880009" ]},
		{"command":[ "SETCHARA", "0", "char_00026001_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「今夜、枕を涙で濡らしても知りませんことよぉ！　私がぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_010022880010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お前が泣くのかよ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「ふえええ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_010022880011" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「……と、カノジョはこういう高飛車な性格をしているせいで、なかなか友達\nができないってウワサだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010022880008" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「あ～、そんな感じがいたしますなあ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022880001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「んひぅう！？　小汚い犬にまで小馬鹿にされてしまいましたわぁあ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_010022880012" ]},
		{"command":[ "SETCHARA", "0", "char_00026001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「俺はあと１人くらいなら話を聞いてもかまわないが」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「あ、貴方！　貴方は少しは見どころがありそうですわね。いいかしら？　私\nは軍の中でも准将の地位を得て……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_010022880013" ]},
		{"command":[ "SETCHARA", "0", "char_00026001_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「それじゃ、ワームホール起動するよ～。えい、ポチッとな♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010022880009" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「ですから私のお話を聞いてくださいませええええ！　ああああああ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_010022880014" ]},
		{"command":[ "SETCHARA", "0", "char_00026001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "sbg_0000" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「次にお会いした時こそ、私の話を最後まで聞いていただきますからねぇええ\nえ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_010022880015" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0149" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……ぐえっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ぐふっ！　……あ、元の部屋に戻ってこられたようですぞ。ご主人」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022880002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いつも思うが、もう少し丁寧に移動させられないのか？　呼ぶ時も雑で、帰\nす時も雑で」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いつかとんでもないケガをする気がするぞ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ど、同感ですぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022880003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……それにしてもダークエルフ三姉妹の次は、異世界からの四神衆とは……\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「１年ごとに新しい方が登場するのは、賑やかで大変よろしいですが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022880004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「これは、今後定番の流れになりそうですな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022880005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「勘弁してくれよ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "とはいえ、二度あることは三度あるかもしれない。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「４周年には気をつけよう。あやしいワームホールには絶対近づかない！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "sbg_0000" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "俺は決意を新たにし、１年後のその日を警戒したのだった……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}