		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "黒いルナテミスの周りを強大なエネルギーが覆う。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "黒いルナテミス" ]},
		{"command":[ "SETTEXT", "「ゴラド・イザヤ・ムーン、月龍の血の元に、出でよ……ドラグソード！」", "NORMAL" ]},
