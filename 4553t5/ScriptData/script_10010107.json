		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "掛け声と共にもう一匹のジュンジローは飛行形態に変形し、もう一人のルナ　\nテミスはその背に飛び乗った。", "NORMAL" ]},
