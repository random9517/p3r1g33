		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ドラゴニック・パワーとは、王家の守護神『月光龍』を己の身体に降臨させ　\n、自らを竜と化す秘儀……」", "NORMAL" ]},
