		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "変形したメカジュンジローは加速し、黒いルナテミスを乗せて上空へと飛翔し　\nていく。", "NORMAL" ]},
