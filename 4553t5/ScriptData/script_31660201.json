{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016602_01_02" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「はーい、お待たせ。ふふっ……さあ、隊長さんのだ～いすきな、おっぱいの\n時間だよ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0203101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「せっかく元の姿に戻ったんだもの……それなら、この実りあるオッパイを使\nわない手はないよねぇ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0203102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「んふふ……今から視線をギラギラ感じるよ。隊長さん、オッパイガン見し過\nぎじゃない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0203103" ]},
		{"command":[ "SETIMAGE", "0", "still_00016602_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「まぁ……変に遠慮するよりはずっといいけどね。ムッツリスケベが、チラチ\nラバレないように見ようとしてるより清々しいし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0203104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「んっ……特に乳首のとこ……すっごく見られてる……その視線だけで、ぎゅ\nって勃起しちゃいそぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0203105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「それに……オチンポの方も、すっかりその気だ。ね、おっぱいに挟まれてど\nんな気分なのかな～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0203106" ]},
		{"command":[ "SETIMAGE", "0", "still_00016602_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「あっと……だーめ、腰を引いちゃ。逃さないよ、今日はたっぷりオッパイと\n、お口で……トロトロになってもらうんだから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0203107" ]},
		{"command":[ "SETIMAGE", "0", "still_00016602_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「さて……まずはちょっと様子見程度に……んっ……んふっ、んっ、ふっ……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0203108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「ふふっ、オッパイの中で、オチンポがビクビク跳ねてる……こーら、大人し\nくしてなさい。ちゃーんと、可愛がってあげるから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0203109" ]},
		{"command":[ "SETIMAGE", "0", "still_00016602_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「本当に……本人と同じでやんちゃなオチンポさん……でも、そういう所が魅\n力的なんだよねぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0203110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「私って、それなりに恐れられたりもしてたんだけど……隊長さんってば、全\n然物怖じする感じしないし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0203111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「気持ちよければそれでいいって感じ？　んっ……それなら……もっと、しっ\nぽりサービスしてあげないとねぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0203112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ、ほら……オッパイが……しっかりオチンポとハグして……感じ\nちゃうでしょ……んく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0203113" ]},
		{"command":[ "SETIMAGE", "0", "still_00016602_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「とぼけても、ダーメ。この先っぽのトコ……プルプル震えてるのバレバレな\nんだから……えいっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0203114" ]},
		{"command":[ "SETIMAGE", "0", "still_00016602_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「ほれほれ、敏感な場所……もっとクニクニして欲しいでしょ？　切なそうな\n顔しちゃってぇ……隊長さんてば、ホントかーわいい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0203116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「そろそろぉ、舐めちゃおっか。尿道のとこ……して欲しいって言ってるしぃ\n……んっ、れろっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0203117" ]},
		{"command":[ "SETIMAGE", "0", "still_00016602_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「えろっ、んれろっ、れろぉぉぉっ、んっ、あぁ……隊長さんのオチンポの味\nぃ……少しおしっこの匂い残ってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0203118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「いつでも清潔にしておかないとって言ったのにぃ……もっとも、私はちょっ\nとカスが残ってる位は全然平気だけどぉ……んれろぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0203119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「れろっ、舐めながら……一緒にオッパイも動かしちゃう……んっ、ふっ、は\nっ、んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0203120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「隊長さん、よく見える？　私のオッパイが……ぐにゃって潰れて……隊長さ\nんのオチンポ、ぱっくりしちゃってるとこ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0203121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「んふふ……すっごく熱くなってる……ギンギンのオチンポが、早く出したい\nって駄々こね始めて来たみたい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0203122" ]},
		{"command":[ "SETIMAGE", "0", "still_00016602_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「でも、まだもうちょっと我慢だよぉ……ぐっとお腹に力を入れてぇ……そう\nそう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0203123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「溜めたら、溜めた分……ドピュって出した時に、すっごく気持ちいいからね\nぇ……ふふっ、ずりゅずりゅって……いい音してるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0203124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「れろ……んっ、えろぉ……あぁ、臭いけど……クセになる味ぃ……れろっ、\n色んな女の人……泣かせて来たんでしょぉ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0203125" ]},
		{"command":[ "SETIMAGE", "0", "still_00016602_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「そんな、いやらしいオチンポにお仕置きフェラチオぉ……んりゅっ、れるっ\n、んんんっ、んれるぅぅぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0203126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「舌が押し付けられて……腰がせり上がるでしょ……更にぃ……乳首も、こう\nしてぇっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0203127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「んっ、ほら……コリコリが擦れて……あははっ、オチンポの震え……止まら\nなくなってる。めちゃくちゃ喜んじゃってるじゃない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0203128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「カウパーも出てきた……んちゅっ、ちゅぷぅ……いつもの精液の味ぃ……も\nう始まる感じになってるしぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0203129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「どうなの？　出したいんでしょ、おねだりして見せて？　チンポから特濃ミ\nルク、ドピュドピュ出したいですーって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0203130" ]},
		{"command":[ "SETIMAGE", "0", "still_00016602_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「ほらほらぁ……このままお預けされちゃう？　オチンポは出したい～って悲\n鳴を上げてるよぉ？　んちゅ、れる、れろぉぉぉっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0203131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「ふふっ、よく言えましたぁ。じゃあ……いっぱいピュッピュって出しちゃい\nましょうねぇー、んりゅ、れるっ、れりゅ、んりゅぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0203132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「いいよぉ……私の舌に……隊長さんのオチンポミルク……いっぱい出しちゃ\nえ～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0203133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「んぁっ……！　ちゅぷっ、んんんっ！　出てっ……来たぁっ、濃いのがっ…\n…ドピュドピュ溢れてるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0203134" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016602_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「んんっ……れろっ、舌の上に……いっぱい乗ってる……んちゅぷっ、はぁ…\n…んっ、ちゃんとこぼさず飲まないと……れろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0203135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「んーーっ、相変わらずドロドロで……んっ、喉にしっかり絡み付いてくる…\n…隊長さんの精液……本当に栄養の塊って感じ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0203136" ]},
		{"command":[ "SETIMAGE", "0", "still_00016602_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「んっ、ちゅぱっ……はふっ、美味し……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0203137" ]},
		{"command":[ "SETIMAGE", "0", "still_00016602_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「ふふっ、どうだった？　オチンポ気持ちよかった？　とろーんとした顔しち\nゃってぇ……まだ、亀頭が震えてるし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0203138" ]},
		{"command":[ "SETIMAGE", "0", "still_00016602_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「そっかー、気持ちよかったんだー。うんうん、素直なオチンポで実によろし\nい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0203139" ]},
		{"command":[ "SETIMAGE", "0", "still_00016602_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「私も気持ちよかったよ、隊長さん。まだオッパイがドキドキしてる……なー\nんて、ね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0203140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「さて……いっぱい出したけど、もちろん隊長さんのオチンポが一発で終わる\nなんて、考えられないよねぇ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0203201" ]},
		{"command":[ "SETIMAGE", "0", "still_00016602_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「うんうん、分かってる。ちゃんと、満足できるまでお世話しちゃうよぉ？　\nオッパイも、まだまだこれからって張り切ってるしぃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0203202" ]},
		{"command":[ "SETIMAGE", "0", "still_00016602_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「とりあえず、周りについた精液を綺麗にしちゃってからねぇ……んっ、えろ\nっ、ぺろっ……ちゅぱっ、んちゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0203203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「ふふっ、これだけでそんなに呻いちゃってぇ……その調子じゃ、これからど\nうなっても知らないよぉ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0203204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「んっ、れろ……んりゅ……れろ、れろぉ……ふふっ、感じちゃう？　今度は\nオッパイプレスが始まるからぁ……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0203205" ]},
		{"command":[ "SETIMAGE", "0", "still_00016602_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「こうしてぇ……ぎゅってオチンポを左右から挟んでぇ……んっ、うんっ、ん\nっ、ふっ……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0203206" ]},
		{"command":[ "SETIMAGE", "0", "still_00016602_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「ここ弱いんでしょ？　指で……ぎゅぅぅーって……あはっ、身体に力入っち\nゃう？　もっと楽にしてればいいのにぃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0203207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「そんな余裕全然なさそう。んっ……えろっ、れろぉ……舌も一緒に使ってぇ\n……んじゅるっ、じゅぷっ、んちゅぅぅぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0203208" ]},
		{"command":[ "SETIMAGE", "0", "still_00016602_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「今日は……一番先っぽのトコだけ……集中的にイジメちゃう……♪　んっ、\nふっ、はっ、あんっ、んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0203209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「どうかな～？　アルマのオッパイおしくらまんじゅう～、おっされて泣くな\n～オチンポちゃーん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0203210" ]},
		{"command":[ "SETIMAGE", "0", "still_00016602_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「れる……れろっ、えろっ、れろぉっ……あれぇ？　もうビクビクが止まらな\nくなってるよぉ、隊長さん？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0203211" ]},
		{"command":[ "SETIMAGE", "0", "still_00016602_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「もうちょっと腰に力を入れて頑張らないとぉ……また、すぐお漏らししちゃ\nうよぉ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0203212" ]},
		{"command":[ "SETIMAGE", "0", "still_00016602_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ、まぁ……出したくなったら、その時にびゅびゅーって出しちゃえ\nばいいんだけどねぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0203213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「んんっ、あぁん……私も……オッパイ……ギチギチのオチンポもみくちゃに\nしてぇ……乳首……コリコリになってるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0203214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「これ……ぎゅって押し付けたらぁ……はぁぁんっ！　んっ、気持ちいい……\nあぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0203215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「んっ、えるっ、れりゅっ、じゅぷっ、ちゅぶっ……んっちゅ……はぁ……ま\nたオチンポ……出ちゃいそう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0203216" ]},
		{"command":[ "SETIMAGE", "0", "still_00016602_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「ちゅぷっ、後もうちょっとだけ我慢だよぉ……そしたら、好きなトコに出し\nていいからぁ……んりゅっ、えろっ、れろぉっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0203217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「そうそう、お腹に力を込めてぇ……ふふっ、必死だねぇ……面白い顔しちゃ\nってぇ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0203218" ]},
		{"command":[ "SETIMAGE", "0", "still_00016602_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「後は……とどめの、オッパイプレスぅ……ぎゅぎゅぅぅぅーって……ほらほ\nらぁ、いよいよ限界かなー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0203219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「さあ、どうしたいの？　隊長さんのチンポミルク……どんな風にしたいのか\nなぁ？」", "NORMAL" ]},
