		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「んふっ……オッパイの中に出したいの……？　んんっ、いいよぉ……出して\n……このまま、オッパイマンコに中出しぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0203301" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
