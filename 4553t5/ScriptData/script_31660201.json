		{"command":[ "PLAYVOICE", "v2_166_0203304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「んはぁ……はぁ……はぁっ、すご……んっ、パイズリだけで……めちゃ、気\n持ちよくなっちゃったぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0203305" ]},
		{"command":[ "SETIMAGE", "0", "still_00016602_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
