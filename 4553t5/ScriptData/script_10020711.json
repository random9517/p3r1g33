{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0166" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_020" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「危ないところだったね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_020113780001" ]},
		{"command":[ "SETCHARA", "0", "char_00001802_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああ、おかげで助かったよ。ありがとう」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「エヘヘ……って、あれ？　ディアナ先生が二人……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_020113780002" ]},
		{"command":[ "SETCHARA", "0", "char_00001802_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「これって、ドッペルゲンガーっていうやつ？　出会ったら死んじゃうってい\nう……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_020113780003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「違う違う。そんな物騒なもんじゃない」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "あとからやってきたグレーテルにも説明しておかないとな。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「こっちは園子。昔のディアナなんだ。顔が似ていて当然だろう？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000607_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「なるほどね……。幽霊じゃ、なかったんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_020113780004" ]},
		{"command":[ "SETCHARA", "0", "char_00001802_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "納得した様子のグレーテルだが、相手が幽霊ではないことに少々残念そうにし\nていた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「それにしても、なんであのサメは標的を隊長に変えたんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010113780001" ]},
		{"command":[ "SETCHARA", "0", "char_00012701_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「きっとカツマの方が美味しそうに見えたんだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040113780001" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「そんなわけねぇだろ！　サメにとって男は前菜で女はメインディッシュなん\nだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_010113780001" ]},
		{"command":[ "SETCHARA", "0", "char_00009501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「単純に守りが薄くなっていた隊長を狙ったという可能性もあるか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010113780002" ]},
		{"command":[ "SETCHARA", "0", "char_00012701_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「あり得ますね。ですが、それでも時空を超えてきたわけでもないカツマさん\nを襲いますか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_050113780001" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「お腹が空いて、もう誰でもいいやってなったとか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040113780002" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「んなわけねーです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_050113780002" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "デッドシャークは神出鬼没すぎて、スーザンの本部にも詳しい生態がまとめら\nれていない始末だった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "結局、どうして俺まで襲われたのかはわからずじまいだ。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「だが、隊長も狙われるっていうのなら、あの作戦がつかえるかもしれねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_010113780002" ]},
		{"command":[ "SETCHARA", "0", "char_00009501_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「ほほう、聞きましょうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_050113780003" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「待てよ。俺が狙われたから使える作戦って、なにをするつもりなんだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「なに、悪いようにはしねえって。アタイはサメだぜ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_010113780003" ]},
		{"command":[ "SETCHARA", "0", "char_00009501_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「どういう理屈だよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「サメの考えはサメが一番よくわかる。悔しいがその通りだからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010113780003" ]},
		{"command":[ "SETCHARA", "0", "char_00012701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "俺の意見は相変わらず聞き入れられなかった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「あの……私はなにをしたらいいんでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_070113780001" ]},
		{"command":[ "SETCHARA", "0", "char_00000607_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうだな。お前はやっぱり過去に戻った方がいい」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「それは……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_070113780002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「カツマちゃんの鬼！　園子ちゃんに、またあの惨めな日々に戻れっていうの\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040113780001" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「い、いやでも、いつまでもこの時代にいるわけにはいかないだろう？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「大丈夫よ！　私と一緒に住めばいいんだから！　過去に居場所がなくても、\n未来のここなら居場所があるもの！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040113780002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「……ディアナさん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_070113780003" ]},
		{"command":[ "SETCHARA", "0", "char_00000607_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「でも、つらくても自分の世界があるなら、ちゃんと帰った方がいい」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「自分の世界もなくなって、帰れないやつだっているんだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「あ……うぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040113780003" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「…………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_070113780004" ]},
		{"command":[ "SETCHARA", "0", "char_00000607_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「戻るにしても、まずはサメをどうにかしてからだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010113780004" ]},
		{"command":[ "SETCHARA", "0", "char_00012701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「元の世界に戻ったところを、サメに襲われるかもしれないからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010113780005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「サメはしつこいからな。狙ったエモノは絶対に逃がさねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_010113780004" ]},
		{"command":[ "SETCHARA", "0", "char_00009501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「とにかく、園子を無事に元の世界に帰せるよう、こっちの世界でなんとかサ\nメを倒すんだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "全員" ]},
		{"command":[ "SETTEXT", "「おーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040113780003" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "7", "CENTER", "-600" ]},
		{"command":[ "SETCHARA", "1", "char_00001802_01", "7", "CENTER", "-200" ]},
		{"command":[ "SETCHARA", "2", "char_00009501_01", "7", "CENTER", "200" ]},
		{"command":[ "SETCHARA", "3", "char_00012701_01", "7", "CENTER", "600" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "DISPCHARA", "2", "TRUE" ]}, 
		{"command":[ "DISPCHARA", "3", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}