{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「こんなところに呼び出すなんて……私は忙しいんですのよ？　一体、何をし\nようというんですの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2703101" ]},
		{"command":[ "SETCHARA", "0", "char_00000127_01", "4", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「トップアイドルになる為の特訓……？　まぁ、それならそうと早く言って下\nさい。もちろん何でもやりますわ。その心構えはできていますもの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2703102" ]},
		{"command":[ "SETCHARA", "0", "char_00000127_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「それで、一体どんな特訓ですの？　えっ、きゃあっ！　な、何をズボンを下\nろしていますのっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2703103" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00000127_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「チ、チンポを咥えるのが特訓……！　ど、どうしてそうなるんですのっ、え\nっ、確かに……喉は重要ですが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2703104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「上手く咥えることで、口周りを鍛えて……声を通りやすくする……ほ、本当\nですの？　っ……確かに、何でもやるとは言いましたが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2703105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「う……ぁっ……こんなに反り返らせて……間近で見ると……本当に大きい…\n…こんなものが私の口に入るんですの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2703106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「それで……一体どうしたら……とにかく、咥える……先端にキスをしてから\n……？　や、やって、みますわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2703107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「んっ……ちゅっ……あぁ……ひくんって……んっちゅ、ちゅぷっ……はっ、\nんもっ、くぽぉっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2703108" ]},
		{"command":[ "SETIMAGE", "0", "still_00000127_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「んっふぅぅぅ……んじゅっ、りゅぷっ、んんっ、咥え……まひたわっ……ん\nっふ、おぷっ、大きい……んりゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2703109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「これで……口を大きく開ける練習……んんっ、ふぁい……もごっ、んんっ、\n確かに……そうらって……いまふわね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2703110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「ふぉれれ……んっ、これから……ろうすれば……んっ、舌の練習……んんっ\n、言う通りにふれば……いいのれふれ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2703111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「んっ、じゅぷっ、りゅぽっ、んちゅ……りゅぷっ、じゅぱっ、ちゅぷっ……\nんりゅぷっ……んっ、ふっ……ちゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2703112" ]},
		{"command":[ "SETIMAGE", "0", "still_00000127_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「口を……開けたまま……んっ……舌で……んっ、チンポの……先端を舐め回\nす……んっ、舌を鍛える……練習……れふの……ね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2703113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「れろっ、んりゅぷっ、もごっ……んっ、こんら……感じれ……いいんでふの\n……？　ちゃんと……んりゅぷっ、れきてるのかろうか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2703114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「んっ、じゅぽっ、んんっ……少し顎が疲れます……んんっ、それが……いい\nん、れふのね……んっ、くぽっ、んりゅぷっ、じゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2703115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「ふぉひたら……んっ、顔を……前後させて……んっ、じゅるっ、頬を鍛える\n……わ、分かりまひたわっ……ふっ、んぶっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2703116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「んぶっ、くぷっ、むぐっ、んんっ、じゅぷっ、じゅぽっ……んふっ、じゅる\nるっ……口の中に……んっ、唾液が溜まってしまいまふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2703117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「んんっ、上手く飲まないと……んんっ、んぐっ、口元から……こぼれひゃう\n……んっ、じゅぽっ、じゅぷっ、んくぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2703118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「垂らしてもいい……んんっ、し、しませんわっ……んっ、アイドルが……ん\nっ、そんら……みっともない真似……れきませんわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2703119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「んふっ、チンポをしゃぶるのはっ……んんっ、特訓なのれふからっ、別にい\nいんれふっ……必要な……こと、なんれひょうっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2703120" ]},
		{"command":[ "SETIMAGE", "0", "still_00000127_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「だったら……んっ、スマートに……んじゅぷっ、ふるまでですわっ……じゅ\nぷっ、んちゅぷっ、くぽっ、んちゅぷぅぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2703121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「ろうれすか……？　なかなか、上手く……できたのではありませんか……？\n　んくぷっ……今度は、組み合わせ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2703122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ、顔を動かしながら……同時に舌をチンポに押し付ける……んっ\n、どうってことありませんわ……りゅぷっ、んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2703123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「はもっ、んっ、じゅぷっ、あっ……あら……？　んっ、ふっ、りゅぷっ、こ\nれ……なかなか、んっ、難しい……れふわね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2703124" ]},
		{"command":[ "SETIMAGE", "0", "still_00000127_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「んっ、顔を……動かす……んっ、くぽっ、んふっ、りゅぷっ、んっ、んじゅ\nっ……し、舌を一緒に……んっ、れろ、んりゅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2703125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「顔が止まってる……？　んっ、いつの間に……んんっ、してる……つもりな\nんれふけど……んんっ、じゅぱっ、んちゅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2703126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「んぷぁっ……意識して顔を動かして……んっ、ふっ、あぁ……んっ、ここれ\n……舌を……んっ、れろ、えろ……難しい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2703127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「これをちゃんとできれば……もっと上を目指せる……んっ、ふっ、りゅぷっ\n……分かりましたわ……頑張りまふっ、じゅぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2703128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「んじゅっ、くぷっ、んりゅぷっ……！　はぁ、んむっ、もっと……チンポに\n集中してっ……じゅぷっ、舌にも力を入れる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2703129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「ふぐっ、むぐぅうっ、んっ、えろ……れろぉっ、んっ、あっ……今……チン\nポ……ピクって……んっふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2703130" ]},
		{"command":[ "SETIMAGE", "0", "still_00000127_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「分かりましたわ……んっ、今の感じを続けるんれふね……んちゅっ、じゅぽ\nっ、くぷっ、れろっ、えろっ、れろぉっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2703131" ]},
		{"command":[ "SETIMAGE", "0", "still_00000127_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「ふぁぁ……チンポ……また、ピクピクって……んっふ……じゅぽっ、上手く\nなってるって……こと……れひょうっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2703132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「んんんっ、はぷっ、んふっ、出すまでが……特訓……んんっ、分かりました\nわ……このまま、一気に出させて見せますわっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2703133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「じゅぽっ、んぶっ、りゅぷっ、んじゅぷっ……！　脈動が……唇に広がりま\nふっ……もごっ、身体も……震えて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2703134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「やせ我慢なんて……させませんわっ、じゅるっ、んじゅぷっ、じゅぽっ、く\nぷっ、このままっ、イくまでっ、続けまひゅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2703135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「ふぉらっ、らひなさいっ、じゅぷっ、んじゅるっ、くぽっ、むぐっ、んじゅ\nぷっ、んじゅぅぅぅぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2703136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「ふぶっ……！　んんっ、出てっ……んぐっ、んんっ、こくっ、んっくっ、ん\nくんっ……飲む……んれふ……ろれ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2703137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000127_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「こくっ、んんっ、んっ、ふぅぅ……んはっ……はふぅぅ……んっ、けほっ、\nんっ、けほっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2703138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「大丈夫れふ……ちょっとむせただけですわ……精液……ちゃんと、残さず飲\nんでますから……ん、はぁ、はぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2703139" ]},
		{"command":[ "SETIMAGE", "0", "still_00000127_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「はぁ、ふうっ、私にかかれば……この程度の特訓なんて……んっ、どうとい\nうことはありませんわ……んふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2703140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「えっ……合格点じゃない……？　ど、どうしてですのっ！？　ちゃんと射精\nまでさせたじゃありませんのっ、理不尽ですわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2703201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「チンポの状態……それは……まだ、勃起していますけど……これが、萎むく\nらいじゃないと駄目……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2703202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「……上等ですわ。要するに、もう出せなくなるまでフェラチオ特訓すればい\nいということでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2703203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「私の本気のご奉仕はこれからですわっ……覚悟なさいっ……あぶっ、ふぐっ\n、んぶっ、じゅぷっ、じゅるっ、んじゅぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2703204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ、くぷっ、ろうれふか……？　もう、ある程度のコツは掴みまし\nた……チンポの弱い所も把握しています……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2703205" ]},
		{"command":[ "SETIMAGE", "0", "still_00000127_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「りゅぷっ、くぷっ……んふっ、ふぉら、今……ピクって……ここ弱点れふわ\nね……んちゅっ、ちゅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2703206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「キスだけじゃありませんわ……んじゅるぅっ、んっちゅ……じゅぷっ、吸い\n上げて……んっ、顔も動かして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2703207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「んっふ、んふんっ、一緒にやるのも……少しずつ感覚を掴んで来ましたから\n……りゅぷっ、もごっ、んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2703208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「随分……美味しそうにしゃぶる……？　んっ、別に……美味しいなんて……\n思ってはいませんわ……じゅぽっ、んっちゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2703209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「私は……ただ、アイドルとして、より高みを目指すべく……チンポに真剣に\n向き合っているだけですわっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2703210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「ちゅぷっ、この癖のある塩味と……ちゅぷんっ、精液の……ぬめりと……喉\n越し……んっ、好きだなんて……別に……んふぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2703211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「ぴちゃっ、はぁんっ、あぷっ、じゅぷっ……唾液が溢れて止まらないのは…\n…んっ、りゅぷっ……条件反射のようなものれ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2703212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「んふっ、嬉しそうになんてなんか……んっ、してませんのっ、あぷっ、んん\nっ、じゅぽっ……あなたこそ……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2703213" ]},
		{"command":[ "SETIMAGE", "0", "still_00000127_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「私に……チンポをしゃぶられて……んんっ、あふっ、んちゅぷっ……ニヤニ\nヤしているじゃありまふぇんかっ……じゅぽっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2703214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「アイドルに……特訓だからって……んじゅぷっ、こんな風にしていいと……\n思ってるんれふかっ？　じゅぽっ、りゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2703215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「私でなければ……んじゅぷっ……しないようなことをさせてっ……あんむっ\n、あぁ……チンポ、またビクビクひてまふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2703216" ]},
		{"command":[ "SETIMAGE", "0", "still_00000127_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「汁も……んじゅぷっ……滲み出してっ……んんっ、顔も……余裕がありませ\nんわっ……りゅぷっ、チンポ……近いんでしょうっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2703217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「全部……お見通しれふわっ……んっ、ちゅぷっ、少しでも射精を遅らせよう\nと……踏ん張っても……もうっ、無駄……れふのっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2703218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「ふぉらっ……んんっ、さっさと……らひて……しまいなさいっ！　じゅぷっ\n、んじゅっ、もう出したいんれひょっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2703219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「じゅるっ……さあっ、わらひのっ……んっ、フェラで……気持ちよくなって\nっ……！　思いっきりっ……らひなさいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2703220" ]},
		{"command":[ "SETIMAGE", "0", "still_00000127_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「んんんんんっ……！　むぐっ、んふぅっ……！　あぶっ、まらっ……んんっ\n……れるっ……！　んぐっ、こくっ、んくんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2703301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000127_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「んっふ……止まらない……こくんっ……んっ、しっかり……全部……喉で…\n…味わう……んふぅぅ……こくっ、んくっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2703302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「んふぁっ、あぷっ……むぐっ、んっふっ……こんなの……一度で出す量じゃ\n……んっ、ありませんわっ……んぐっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2703303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「分かっていまふ……全部……飲まなきゃ……特訓にならないんれひょう……\n？　んっ、こくんっ、ゆっくり……飲みます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2703304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「こくっ……んっく……りゅぽっ、んふっ……じゅるるっ、んんっ、んくっ、\nは……んっ、ぷぁ……はぁ……んふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2703305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……どうですか……ちゃんと、全部飲み切りましたわ……当然で\nす。この程度のこと……できて当然ですわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2703306" ]},
		{"command":[ "SETIMAGE", "0", "still_00000127_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「どうせ、最後まで後始末をしなければ合格にはしないとか言うのでしょう…\n…？　抜かりはありませんわ……れろ、ぴちゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2703307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「んっ、ちゅぱっ……ほら、これで文句は言わせませんわ。さあ、どうなんで\nすの、判定は？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2703308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「合格……？　ふふっ、当然ですわね……私が全力でフェラチオをしたのです\n。合格でない筈がありませんわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2703309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「まだまだ、特訓の余地はある？　ふん……いつでも来いですわ。何度しても\n、あなたを極上の気分にしてさしあげますわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2703310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「ふぁんっ……！　んんっ、はぁっ……チンポっ……急に抜いてっ……んんっ\n、あぷっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2703401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000127_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「顔に出したかったんですの……？　んっ、はぁ……後から後から……溢れて\n……んふぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2703402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「ぴちゃ……んちゅぷっ……こんなドロドロで……臭くて……粘りついて……\nんっ、はぁぁ……んぁふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2703403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「あぁ……チンポ……直接頬に押し付けて……グリグリって……してくるなん\nて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2703404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……出し切りましたね……？　もう、チンポ……精液……出ませ\nんよね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2703405" ]},
		{"command":[ "SETIMAGE", "0", "still_00000127_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「今度こそ合格でいいんですわよね？　チンポの先を綺麗にしたら……ふん…\n…どうということはありませんわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2703406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「ぴちゃ……んちゅっ、ちゅぷっ……これでいいんでしょう？　合格……ふふ\nん……当たり前ですわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2703407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「これだけ舌と唇の使い方が上手くなれば、歌い方も変わってくる……ふん、\nそういう意図があることはもちろん分かっていましたけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2703408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「アイドルとして……より上を目指すのならば、この程度は難なくこなせて当\n然……どんと来いですわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2703409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「ええ、もちろん……いつ何時でも、いくらでもチンポをしゃぶってさしあげ\nますわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2703410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
