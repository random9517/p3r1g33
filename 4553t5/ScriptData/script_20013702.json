{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0177" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_005" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ふむ……なるほどねぇ。思ったよりもフットワークが軽いじゃないか。ふふ\nっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010022560001" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「何やら楽しそうですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090022560001" ]},
		{"command":[ "SETCHARA", "0", "char_00000509_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「おや、オボロ。ふふん、よく来てくれたねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010022560002" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「大至急だと人を呼びつけておいた割には随分と、のんびりした様子ではない\nですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090022560002" ]},
		{"command":[ "SETCHARA", "0", "char_00000509_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ああ、まぁそういう風に言っておけば、急いで来てくれると思ってね。その\n点、君はとても律儀で助かるよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010022560003" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「……次からは話半分以下で聞くことにします。それで……ウチに何のご用事\nですか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090022560003" ]},
		{"command":[ "SETCHARA", "0", "char_00000509_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ああ、インクレディブル・スクワッドがまた動き始めた。連中、今度は惑星\nビキニに向かったようだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010022560004" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「惑星ビキニ……なんですか、その胡散臭い名前の星は」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090022560004" ]},
		{"command":[ "SETCHARA", "0", "char_00000509_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ふふっ、胡散臭いと来たか。これが名前に違わず、実にバカンスに適した星\nらしいよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010022560005" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「……バカンスに行ったんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090022560005" ]},
		{"command":[ "SETCHARA", "0", "char_00000509_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「いや、そういう訳じゃない。そこにある遺跡の調査が目的のようでね、君に\nはその追跡をお願いしたい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010022560006" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「そういうことですか。ふん……まぁ、どうせ断れるものでもないでしょうし\n……承知しました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090022560006" ]},
		{"command":[ "SETCHARA", "0", "char_00000509_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「お気に召さなかったかな？　別に編成を考えなくもないけれど？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010022560007" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「いえ、問題ありません。承知しましたです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090022560007" ]},
		{"command":[ "SETCHARA", "0", "char_00000509_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「それは何よりだ。とは言え、ただ単身調査という訳でもない。いざとなれば\nドンパチもあるかも知れないからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010022560008" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「差し当たりの部下を貸してあげるよ。二人とも、こっちへ来てくれないか？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010022560009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「呼んだか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_030022560001" ]},
		{"command":[ "SETCHARA", "0", "char_00010003_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａウタマロ" ]},
		{"command":[ "SETTEXT", "「また新しい面倒事を持ってきたみたいだな。懲りねぇこった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_030022560001" ]},
		{"command":[ "SETCHARA", "0", "char_00009703_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「話は聞いていただろう？　君たちには、彼女と一緒に惑星ビキニに向かって\n欲しい。指示は、オボロに従ってくれ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010022560010" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090022560008" ]},
		{"command":[ "SETCHARA", "0", "char_00000509_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「自分一人でなんとでもなるって顔だね。けど、相手にしたってそれなりの手\n練が揃ってる。別にぴったり連携を取れなんて言わないよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010022560011" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「別に上下関係を強要させる気もない。二人も、それは分かってくれるだろう\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010022560012" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「分かっている。命じられた任務をこなす……それがニンジャの本分だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_030022560002" ]},
		{"command":[ "SETCHARA", "0", "char_00010003_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａウタマロ" ]},
		{"command":[ "SETTEXT", "「とにかく、敵をぶっ倒せばそれで文句ナシってことだろ？　邪魔されなきゃ\nそれでいいさ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_030022560002" ]},
		{"command":[ "SETCHARA", "0", "char_00009703_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ということで、色々と気難しいかも知れないけどね、腕は立つメンバーだか\nらよろしく頼むよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010022560013" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「分かりました。お気遣い感謝するです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090022560009" ]},
		{"command":[ "SETCHARA", "0", "char_00000509_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「転送機の準備は整ってる。好きなタイミングでいっていいよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010022560014" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「ウチの準備も問題ありません。すぐに出ます。二人は……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090022560010" ]},
		{"command":[ "SETCHARA", "0", "char_00000509_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「問題ない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_030022560003" ]},
		{"command":[ "SETCHARA", "0", "char_00010003_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａウタマロ" ]},
		{"command":[ "SETTEXT", "「いつでもいいぜ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_030022560003" ]},
		{"command":[ "SETCHARA", "0", "char_00009703_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「よさそうだね。では、健闘を祈っているよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010022560015" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「失礼します」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090022560011" ]},
		{"command":[ "SETCHARA", "0", "char_00000509_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「……ん……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090022560012" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「よう、また新しい任務のようだねぇ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100022560001" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「……貴方ですか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090022560013" ]},
		{"command":[ "SETCHARA", "0", "char_00000509_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「全く、ジェスタも人使いが荒いねぇ。お前さんも気苦労が絶えないんじゃな\nいのかい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100022560002" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「珍しいですね、貴方が人の心配をするなんて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090022560014" ]},
		{"command":[ "SETCHARA", "0", "char_00000509_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「お気遣いは感謝しますが、心配には及びません。ウチのことは、ウチ自身が\n分かっていますから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090022560015" ]},
		{"command":[ "SETCHARA", "0", "char_00000509_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「そうかい。だが、こういう時に人手はあるに越したことはない。セレーナ、\nオボロの任務……ついていってやるといい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100022560004" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「……勝手な真似をするとジェスタが黙っていないのではないですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090022560016" ]},
		{"command":[ "SETCHARA", "0", "char_00000509_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ちゃんと話はつけておくさ。それに……きっとジェスタは面白い方を選ぶ。\nお前さんが心配することはないよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100022560005" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「……分かりました。では、よろしくお願いします」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090022560017" ]},
		{"command":[ "SETCHARA", "0", "char_00000509_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「ああ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080022560002" ]},
		{"command":[ "SETCHARA", "0", "char_00000408_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ふふ……余も、いい知らせを楽しみにしているよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100022560006" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「ご期待に添えるかは分かりませんが。ウチはウチの仕事をするまでです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090022560018" ]},
		{"command":[ "SETCHARA", "0", "char_00000509_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「…………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080022560003" ]},
		{"command":[ "SETCHARA", "0", "char_00000408_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「はぁ……まったく……どいつもこいつも自分のことしか考えてやがらねぇで\nすね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090022560019" ]},
		{"command":[ "SETCHARA", "0", "char_00000509_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「白々しいと分かっていながら、もったいぶった言い方をして……ウチを見張\nりたいのなら、そうはっきり言えばいいのです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090022560020" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「色々と面倒なことになりそうですが……ふん、何者にもウチの邪魔はさせま\nせんよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090022560021" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}