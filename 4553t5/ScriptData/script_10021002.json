{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0162" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「た、助かりましたぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010114200001" ]},
		{"command":[ "SETCHARA", "0", "char_00001101_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "追ってきた襲来者を撃退すると、翔生子は安心したのか、手近な椅子に座り込\nむ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「助かった、はいいが……おまえはここの学生ではないな？　誰なんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010114200001" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「あ！　そ、そうでしたっ！　肝心なことを……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010114200002" ]},
		{"command":[ "SETCHARA", "0", "char_00001101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "修羅姫に聞かれた翔生子は慌てて立ち上がると、真剣な顔で言う。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「わたしの名前は翔生子。この学園は狙われています！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010114200003" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "人見知りの翔生子にしては珍しく、きっぱりと力強く言い切った。しかし……\n。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「この学園が……？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「狙われている、だと……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010114200002" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "翔生子の言葉に、俺たちは顔を見合わせる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「はいっ！　……って、あれ？　どうか……しましたか？　わたし、なにかお\nかしなこと……言いましたか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010114200004" ]},
		{"command":[ "SETCHARA", "0", "char_00001101_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、別におかしくはないぞ、ないんだけどな……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「大戸岐学園が襲来者（インベーダー）に狙われるのは、いつものことだから\nなぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010114200003" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「あ、そ、そうですか……そういえば、そうかも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010114200005" ]},
		{"command":[ "SETCHARA", "0", "char_00001101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「で、でも、そういう問題じゃないんです！　今回は、本当に危険かもしれな\nいんです！　おじいさまからの知らせですので！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010114200006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「なんだって！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090114200001" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0149" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
		{"command":[ "SETTEXT", "翔生子の話を詳しく聞くために、俺たちはひとまず管理人室に移動する。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ほら、お茶が入ったぞ。ひとまずこれでも飲みながら、落ち着いて話してく\nれ」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「学園の備品ですから粗茶もいいところの安物ですが、どうぞご遠慮なく」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010114200001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「あ、ありがとうございます……いただきます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010114200007" ]},
		{"command":[ "SETCHARA", "0", "char_00001101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「それで『おじいさま』というのは……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010114200004" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「とある異世界の月にある、巨大な図書館の『館長』だ。翔生子にとっては祖\n父であり、師匠でもある」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090114200002" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「そ、そうです……そのおじいさまが持たせてくれた、いろいろな『記録』を\n整理していて、とても気になる『記述』を見つけてしまって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010114200008" ]},
		{"command":[ "SETCHARA", "0", "char_00001101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんて書いてあったんだ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「そのまま、言葉にすることはできません……。幻影とか、イメージとか、漠\n然とした思念とか、そういったもののまとめなので……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010114200009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「だが司書であるおまえには、その意味が理解できたのだろう？　だから、慌\nてて知らせに来たんだな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090114200003" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「は、はい。その『記述』は……いわば予言でした。それも、かなり具体的な\n内容の……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010114200010" ]},
		{"command":[ "SETCHARA", "0", "char_00001101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「どういう内容だったんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010114200005" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そう言って翔生子は小さく体を震わせ、絞り出すように告げる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETCHARA", "0", "char_00001101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「襲来者（インベーダー）が、これまでになく大規模な攻勢をかけ……大戸岐\n学園と、にいさまたちを壊滅させようとしている、と……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010114200011" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なにぃ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「そしてその影には、襲来者（インベーダー）たちよりずっと強力で、巨大な\n組織の思惑が働いているようだ、と……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010114200012" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「組織……だと？　その組織というのは、いったいなんなんだ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010114200006" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「ひっ！　わ、わかりません！　ですから、わたしもおじいさまに連絡したん\nです！　でも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010114200013" ]},
		{"command":[ "SETCHARA", "0", "char_00001101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「でも、なんなんだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010114200007" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「修羅姫！　落ち着け！　翔生子が怯えてる！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「ああ……すまない。つい興奮してしまった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010114200008" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「い、いえ、いいんです……それに……すみません。『組織』については、今\nはまだ言えません……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010114200014" ]},
		{"command":[ "SETCHARA", "0", "char_00001101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「『今は』というと？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090114200004" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「おじいさまにも、まだ確信が持てないと……間違ったことを伝えては、かえ\nって姫様たちを危険にさらしてしまうと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010114200015" ]},
		{"command":[ "SETCHARA", "0", "char_00001101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「…………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090114200005" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「だから、わたしの目で確かめて間違いないとわかるまでは、姫様や、にいさ\nまにも組織の正体は知らせるなと。そして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010114200016" ]},
		{"command":[ "SETCHARA", "0", "char_00001101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「そのときが来たら、この箱を開けろと言われました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010114200017" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そう言って翔生子は、銀色の小箱を取り出して見せる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「この箱は？　……って、それもまだ言えないわけだな？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「ご、ごめんなさい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010114200018" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、いいんだ。だけど学園に本当に危機が迫ってる、ってのは間違いない\nようだな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「うむ……学園長にも伝えて、明日から警戒を強めなければ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010114200009" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「やれやれだ。襲来者（インベーダー）のヤツら、毎回手間をかけさせてくれ\nるぜ……」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}
