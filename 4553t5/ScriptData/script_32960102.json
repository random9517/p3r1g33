		{"command":[ "SETNAME", "あなた" ]},
		{"command":[ "SETTEXT", "「それにしても、今日はすごく調子良かったな」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00029601_01", "0", "CENTER", "0" ]},
