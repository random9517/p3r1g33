		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "理事長のところに行く途中で、何気なくそんなことを言った。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "別に深い意味はなかったんだけど、俺の隣を歩いていた小春が急に肩を縮こま\nらせる。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "小春" ]},
		{"command":[ "SETTEXT", "「だって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_296_0104101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "あなた" ]},
		{"command":[ "SETTEXT", "「うん？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "小春" ]},
		{"command":[ "SETTEXT", "「可愛がってもらったから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_296_0104102" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "あなた" ]},
		{"command":[ "SETTEXT", "「え、それ関係あんの？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "小春" ]},
		{"command":[ "SETTEXT", "「あるよ。重要だよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_296_0104103" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "力強い口調で言われてしまう。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "小春" ]},
		{"command":[ "SETTEXT", "「あれで元気をもらったんだから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_296_0104104" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "あなた" ]},
		{"command":[ "SETTEXT", "「そうか。だったら良かった」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "お互いに笑顔を交わす。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "なんの話をしているのかといえば、今日の見回り中の出来事だ。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "たまたま小春と２人だったから、なんとなくいい雰囲気になってしまって、空\nき教室に連れ込んでしまったのだ。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETTEXT", "そして、何をしたのかといえば――", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0000" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "小春を教室の窓に押し付けて、俺は後ろから尻を掴んだ。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "見回りの最中だっていうのはわかってるけど、こういう雰囲気になってしまっ\nたのだ。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "PLAYBGM", "WAR_BGM7" ]},
		{"command":[ "SETNAME", "小春" ]},
		{"command":[ "SETTEXT", "「もう……誰もいないからって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_296_0104105" ]},
		{"command":[ "SETIMAGE", "0", "still_00029601_02_01" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "あなた" ]},
		{"command":[ "SETTEXT", "「小春がふざけて腕を組んでくるからだぞ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "小春" ]},
		{"command":[ "SETTEXT", "「それは……ううっ、ごめんなさい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_296_0104106" ]},
		{"command":[ "SETIMAGE", "0", "still_00029601_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "あなた" ]},
		{"command":[ "SETTEXT", "「それに今日はいい匂いがした」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "小春" ]},
		{"command":[ "SETTEXT", "「あ、シャンプー変えたからかな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_296_0104107" ]},
		{"command":[ "SETIMAGE", "0", "still_00029601_02_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "あなた" ]},
		{"command":[ "SETTEXT", "「とにかく、そういうわけだから責任取ってもらわないとな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "小春" ]},
		{"command":[ "SETTEXT", "「んああぁぁっ…………！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_296_0104108" ]},
		{"command":[ "SETIMAGE", "0", "still_00029601_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "腰を前に進ませて、小春の中にイチモツを押し込む。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "柔らかな感触が伝わってきて、俺の全身が大きく震えた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "小春" ]},
		{"command":[ "SETTEXT", "「ふ、あっ……はいっ、て、くるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_296_0104109" ]},
		{"command":[ "SETIMAGE", "0", "still_00029601_02_05" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "あなた" ]},
		{"command":[ "SETTEXT", "「小春も……すごく、締め付けて、くるぞ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "小春" ]},
		{"command":[ "SETTEXT", "「は、ふ……んふぁ、はっ……ひ、はあぁんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_296_0104110" ]},
		{"command":[ "SETIMAGE", "0", "still_00029601_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "小春" ]},
		{"command":[ "SETTEXT", "「一番、深いところ……まで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_296_0104111" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "あなた" ]},
		{"command":[ "SETTEXT", "「あと、もう少し……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "さらに腰を強く突き出す。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "イチモツは根元まで入って、子宮をグリグリと押し上げた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "小春" ]},
		{"command":[ "SETTEXT", "「んんっ、あっ……今日は、すごく大きく……感じる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_296_0104112" ]},
		{"command":[ "SETIMAGE", "0", "still_00029601_02_07" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "あなた" ]},
		{"command":[ "SETTEXT", "「小春のも……今日は締め付けが強い気がする」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "小春" ]},
		{"command":[ "SETTEXT", "「だって、こんなところでしたら……　もしも、誰かが来たら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_296_0104113" ]},
		{"command":[ "SETIMAGE", "0", "still_00029601_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "あなた" ]},
		{"command":[ "SETTEXT", "「声を出さなきゃ大丈夫じゃないか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "小春" ]},
		{"command":[ "SETTEXT", "「そんなの無理だよ。だって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_296_0104114" ]},
		{"command":[ "SETIMAGE", "0", "still_00029601_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "小春" ]},
		{"command":[ "SETTEXT", "「んひゃっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_296_0104115" ]},
		{"command":[ "SETIMAGE", "0", "still_00029601_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "まだ小春が話してる途中なのに、腰を前後に動かし始める。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "小春" ]},
		{"command":[ "SETTEXT", "「あ、あぁっ、これぇっ……　すごく、気持ちいい、ん、だからぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_296_0104116" ]},
		{"command":[ "SETIMAGE", "0", "still_00029601_02_05" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "あなた" ]},
		{"command":[ "SETTEXT", "「ん、くっ……ふうっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "小春" ]},
		{"command":[ "SETTEXT", "「そん、な……動いちゃ……あ、ああぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_296_0104117" ]},
		{"command":[ "SETIMAGE", "0", "still_00029601_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "あなた" ]},
		{"command":[ "SETTEXT", "「最初から、すごく……締め付けてくるな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "小春" ]},
		{"command":[ "SETTEXT", "「それは……んんぅっ、体が……勝手に……ひゃんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_296_0104118" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "小春" ]},
		{"command":[ "SETTEXT", "「あ、ああっ、熱くて、硬いのが、ぁ、あぁんっ……　いっぱい、動いて……\nんっふ、ううぅぅんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_296_0104119" ]},
		{"command":[ "SETIMAGE", "0", "still_00029601_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "小春の中は、すぐに濡れてきた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "しっとりとした感触がイチモツ全体に広がって、優しく包み込んでくる。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "腰を動かすたびに湿った音が鳴って、抽送を滑らかなものにしてくれた", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "小春" ]},
		{"command":[ "SETTEXT", "「ふぁっ、ああぁんっ、ひ、んあっ、う、く、あ、はっ……！　ひ、あぁ、ん\nふぁ、ん、はあっ、はああぁんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_296_0104120" ]},
		{"command":[ "SETIMAGE", "0", "still_00029601_02_06" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "あなた" ]},
		{"command":[ "SETTEXT", "「小春の中、どんどん濡れてくるから、動きやすいな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "小春" ]},
		{"command":[ "SETTEXT", "「や、あ、恥ずかしいこと、言わないで……ひあぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_296_0104121" ]},
		{"command":[ "SETIMAGE", "0", "still_00029601_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "あなた" ]},
		{"command":[ "SETTEXT", "「でも、本当のことだし……んんっ、ぬるぬるしてる」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "小春" ]},
		{"command":[ "SETTEXT", "「だって、気持ち、よくて、んあっ、か、体が、あ、あっ、　勝手にそうなっ\nちゃうんだもん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_296_0104122" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "小春" ]},
		{"command":[ "SETTEXT", "「おち○ちんが、んんぅっ、擦れて、　く、ふっ、おま○こ、濡れ、ちゃう…\n…ひああぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_296_0104123" ]},
		{"command":[ "SETIMAGE", "0", "still_00029601_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "腰の動きを加速させていくと、小春の声が大きくなっていく。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "膣内はうねるような動きを伝えていて、まるでイチモツ全体が揉まれてるみた\nいな感触だった。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "あなた" ]},
		{"command":[ "SETTEXT", "「今日も……めちゃくちゃ気持ち良い！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "小春" ]},
		{"command":[ "SETTEXT", "「私も……あ、あっ、おち○ちん、んんぅっ、いいよ、ぉ、　ふあっ、おま○\nこの、き、気持ちいい、ところに、んんっ、　おち○ちん、擦れてるよぉっ！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_296_0104124" ]},
		{"command":[ "SETIMAGE", "0", "still_00029601_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "小春" ]},
		{"command":[ "SETTEXT", "「そのまま、して、あ、んんっ、おま○こ、突いて、ひあっ、　いっぱい突い\nて、気持ち良くしてぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_296_0104125" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "あなた" ]},
		{"command":[ "SETTEXT", "「小春もだいぶ積極的になったよな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "小春" ]},
		{"command":[ "SETTEXT", "「だって、これ好き、ぃ、ひんっ、おち○ちんで、されるの、　ん、あっ、可\n愛がって、もらうの、大好きだからぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_296_0104126" ]},
		{"command":[ "SETIMAGE", "0", "still_00029601_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "あなた" ]},
		{"command":[ "SETTEXT", "「ああ、俺のチ○ポで、小春のオマ○コなでなでしてやるぞ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "小春" ]},
		{"command":[ "SETTEXT", "「ふああぁっ、してっ、おち○ぽ、で、んあぁっ、　おち○ぽで、私のおま○\nこ、なでなでしてぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_296_0104127" ]},
		{"command":[ "SETIMAGE", "0", "still_00029601_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "イチモツで責め続けていると、小春のテンションも上がってきた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "以前はこんなに恥ずかしいことは言わなかったけど、最近はあえて口にしたほ\nうが興奮できるらしい。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "オマ○コの締め付けもどんどん強くなっていて、だんだん射精の瞬間が近づい\nてきていた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "あなた" ]},
		{"command":[ "SETTEXT", "「なんか、こういう場所でしたほうが、　締め付けが強くなってないか？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "小春" ]},
		{"command":[ "SETTEXT", "「そんなこと、ないよ、ぉ、んあっ、今日は、ま、窓際で、　あ、あああっ、\nすごく、き、緊張してるから……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_296_0104128" ]},
		{"command":[ "SETIMAGE", "0", "still_00029601_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "小春" ]},
		{"command":[ "SETTEXT", "「こんなところ、んく、あっ、誰かに、み、見られたら、　ひ、あぁんっ、は\n、恥ずかしくて、死んじゃう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_296_0104129" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "あなた" ]},
		{"command":[ "SETTEXT", "「確かにその気持ちは、わからなくはないな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "この教室からは学園の裏側の通路が見えるから、誰かがそこを通っても不思議\nじゃない。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "外からは小春の顔くらいしか見えないはずだけど、緊張するのは当然だ。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "あなた" ]},
		{"command":[ "SETTEXT", "「でも、だからこんなに気持ち良いんだよな」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "小春" ]},
		{"command":[ "SETTEXT", "「んんぅっ、か、勝手に、締め付けが、強くなって、　あ、くあっ、おち○ち\nんの、動き方も、んんっ、　激しくなって……あああぁっ、感じすぎちゃうよ\nぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_296_0104130" ]},
		{"command":[ "SETIMAGE", "0", "still_00029601_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "あなた" ]},
		{"command":[ "SETTEXT", "「んっ……んっ……んっ……んっ……んっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "小春" ]},
		{"command":[ "SETTEXT", "「んふぁっ！　ひあっ、ん、く、ふああぁ、んっ、ひんっ！　ん、んうっ、く\n、ふっ、んあっ、ふあ、ぅ、はぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_296_0104131" ]},
		{"command":[ "SETIMAGE", "0", "still_00029601_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "イチモツの動きをさらに加速させて、ラストスパートに入る。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "結合部からは透明な愛液が染み出していて、腰を振るたびにグチュグチュと卑\n猥な音が鳴った。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "でも、それが俺の体をさらに興奮させてくれて、イチモツを石のように硬く勃\n起させる。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "先端はゴツゴツと子宮を突き続けていて、下腹部の奥から熱いものが込み上げ\nてくるのが感じられた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
