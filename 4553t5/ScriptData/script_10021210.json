		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「では皆のもの、出撃だー！　敵兵が出てくればとことんぶちのめし、輝くお\n宝あれば無理やりいただく！　勝利は我らのためにあーる！」", "NORMAL" ]},
