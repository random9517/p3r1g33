		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「どうやら、宇宙船からの電波でまた暴走させられちゃったみたいね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114160001" ]},
		{"command":[ "SETCHARA", "0", "char_00021201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「なにのんきなこと言ってるの！　このままじゃ、崖に突っ込んじゃうでしょ\nうが！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114160002" ]},
		{"command":[ "SETCHARA", "0", "char_00011101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「心配ないわ。Ｍ．Ｏ．Ｅちゃん、アレを使うわよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114160002" ]},
		{"command":[ "SETCHARA", "0", "char_00021201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「アレ？　アレってなんのこと！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114160003" ]},
		{"command":[ "SETCHARA", "0", "char_00011101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「んもぅ、Ｍ．Ｏ．Ｅちゃんったら。そこは『よくってよ、お母様』でしょ！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114160003" ]},
		{"command":[ "SETCHARA", "0", "char_00021201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「だから、貴方をお母様なんて呼ぶ筋合いは……って、もうだめっ、落ちる！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114160004" ]},
