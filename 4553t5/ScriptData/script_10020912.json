		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「車になっているならちょうどいい、暴走電波を浴びせてくれるわ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010114160002" ]},
