		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「ちょ、ちょっと！　ブレーキが利かなくなっちゃってるんだけど！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114160001" ]},
		{"command":[ "SETCHARA", "0", "char_00011101_01", "3", "CENTER", "0" ]},
