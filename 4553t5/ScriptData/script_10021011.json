{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0159" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "変身した学生をＤｒ．サイレーンたちに任せて、俺たちは対策を話し合う。", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「やっぱり時間が戻されてるのかよ……それじゃ、俺たちどうすればいいんだ\n？　何回襲来者をやっつけても、戦闘前に戻されちまうんだろ！？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「そういうことになるな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090114290001" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「あの機械が悪いわけ～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_010114290001" ]},
		{"command":[ "SETCHARA", "0", "char_00001501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あれはあくまでもガス発生機だろう。時間逆行の原因は、おそらくほかにあ\nる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090114290002" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「じゃ、いったいどうすればいいんだ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114290001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「…………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010114290001" ]},
		{"command":[ "SETCHARA", "0", "char_00001101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「時間の逆行を止める必要があるが、そもそも逆行の原因がわからないことに\nは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090114290003" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああ……まためんどくせえことになったなぁ……。とにかく、みんなをいっ\nたんここに集めて……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「やっぱり、そうだったのかも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010114290002" ]},
		{"command":[ "SETCHARA", "0", "char_00001101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "俺が通信機のスイッチを入れようとしたとき、翔生子が急にそんなことを言い\n出した。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「え？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「やっぱり、おじいさまの考えは正しかったのだと思います……！　と、いう\nことは……今こそ、この箱を開けるとき……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010114290003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おい、翔生子！？　急に走り出して、どこへ行くんだ！？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「校門の方へ向かっているようですぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010114290001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いったいなんなんだ？　とにかくみんな！　校門前へ急げ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0173" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "Ｇ・ルナリアムの連中を引き連れて校門に向かうと、翔生子はそこで待ってい\nた。", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00001101_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「みんな……来てくれたのですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010114290004" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああ。でも翔生子、いったいどうしたんだ？　もしかしてなにか、思いつい\nたことでもあるのか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「思いついた、というか……やるべきことがあるんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010114290005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そう言って翔生子は、銀色の小箱を取り出す。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「その箱は、さっきの？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090114290004" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「おじいさま、それにみんな……力を貸してください……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010114290006" ]},
		{"command":[ "SETCHARA", "0", "char_00001101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「ああっ！　翔生子ちゃんの体から光が……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010114290001" ]},
		{"command":[ "SETCHARA", "0", "char_00001205_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0173" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "翔生子の体が、俺たちの前でまばゆい光に包まれたと思うと――", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「翔生子ちゃんの姿が……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010114290001" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「覚醒……したのか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090114290005" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「おじいさま、みんな、ありがとう。この力があれば……道を作れます……！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010114290007" ]},
		{"command":[ "SETCHARA", "0", "char_00001102_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そう言って翔生子は空に向かって両手をかざす。すると――", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「量子変動が急激に増大！？　これはまさか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010114290001" ]},
		{"command":[ "SETCHARA", "0", "char_00001406_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ワームホールですか……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010114290001" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "おいおいおい、まじか！？　翔生子のヤツ、学園の真上にでっかいワームホー\nルを開いちまったってのか！？", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「こ、これ、いったいどこに通じてるんだ……？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "と、思わず俺がつぶやいたとたん――", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "sbg_0158" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「こ、これはっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010114290001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「エファナティカにセレーナ！？　なんだ！？　これはなんなんだ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114290002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「え！？　ええっ！　し、知らない！　わたし、全然知らないぞ！？　ってい\nうか、わたし、ちゃんとここにいるじゃん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010114290001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0173" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "と、セレーナが慌てている目の前で、二人の姿はワームホールのかなたに消え\nていく。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「いったい、あれはどういうことだい……？　はっ！　まさか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010114290001" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「そうだ。あれは間違いなくエファナティカにセレーナ……。しかし、いまこ\nこにいるお前たちではない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090114290006" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「私と同じように、異世界の存在……つまり、おまえたちのアナザーだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090114290007" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}
