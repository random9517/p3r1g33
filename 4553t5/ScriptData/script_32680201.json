{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「パワーアップをするための特訓に興味はあるかって？　もちろん、あるに決\nまってるわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0203101" ]},
		{"command":[ "SETCHARA", "0", "char_00026802_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「もしかして、今日はそのために私をここに呼び出したの？　だったら、早く\nその特訓とやらを始めましょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0203102" ]},
		{"command":[ "SETCHARA", "0", "char_00026802_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「私は強くなるためなら、何だってするわ。どんなに厳しい内容だったとして\nも、絶対に耐えてみせるから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0203103" ]},
		{"command":[ "SETCHARA", "0", "char_00026802_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「え、えっと……服を脱いで脇を見せろと言われたけど、これでいいの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0203104" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00026802_01_01" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「別に疑っているわけじゃないんだけど……これ本当に、強くなるための特訓\nなのよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0203105" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「素肌や脇を晒して、羞恥に耐えるのも強くなるためには必要なことって……\nそんなの、聞いたことないのだけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0203106" ]},
		{"command":[ "SETIMAGE", "0", "still_00026802_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「スーツ姿ならまだしも、裸だなんて……絶対こんなので、強化できるワケが\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0203107" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「きゃあぁっ！？　ちょ、ちょっと、何を擦りつけて……んっ、ひゃんっ！　\nく、くすぐったいじゃない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0203108" ]},
		{"command":[ "SETIMAGE", "0", "still_00026802_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「カタくて熱いモノが、脇のところを擦ってきて……って、こ、これ、オチン\nポじゃない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0203109" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「どうしてオチンポを脇に擦りつける必要があるの！？　えっ……君のオチン\nポから、心身を鍛える汁が出て来るの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0203110" ]},
		{"command":[ "SETIMAGE", "0", "still_00026802_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「それを身体に塗れば、強くなると……な、なるほど。そうなのね……男の人\nのオチンポから出る汁に、そんな効果があるなんて、知らなかったわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0203111" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「騒いだりして、悪かったわね。君の指示に従うから、どうすればいいか言っ\nてちょうだい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0203112" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「ふむふむ……まずは隊長のオチンポを気持ちよくすればいいのね。だったら\n、手で擦ったりした方が、いい気がするのだけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0203113" ]},
		{"command":[ "SETIMAGE", "0", "still_00026802_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「手より脇の方が興奮できるからって……そ、そう。隊長がそれでいいなら、\n別にいいのだけど……んぅ、はっ、んくぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0203114" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「ふっ、んふっ……はっ、あっ……スリスリされると、ヘンな気持ちになって\nくるっ……あんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0203115" ]},
		{"command":[ "SETIMAGE", "0", "still_00026802_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「あっ、あっ……ヌルヌルした汁が出て来たわね……これを塗りつければ、強\nくなれると……んふっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0203116" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「はぁ……くっ、んくぅっ……ね、ねえ。いっぱい汁を塗りたくられているの\nに、あまり強くなってる気がしないんだけど？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0203117" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「これは先走り汁っていう違う汁で、セーエキっていう白い液体が出ないと、\nパワーアップしない？　そ、そうなのね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0203118" ]},
		{"command":[ "SETIMAGE", "0", "still_00026802_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「それならそうと、先に言っておいて欲しかったわ……騙されたのかと思った\nじゃない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0203119" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「とりあえず、そのセーエキっていうのを、早く出してちょうだい。何かして\n欲しいなら、遠慮なく言って……あっ、あんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0203120" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「はぁ……あっ、くっ、んくぅ！　ふっ、あふっ……はふっ、んんっ！　ヌル\nヌルの感触が、脇全体に拡がってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0203121" ]},
		{"command":[ "SETIMAGE", "0", "still_00026802_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「くちゅくちゅって、ヘンな音がして……やっ、あっ！　この音を聞いている\nだけで、オマンコが疼いてくるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0203122" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「ち、ちがっ！　別に、感じたりしてないわ！　ただ、ちょっとオチンポに意\n識が向いてしまうだけで……あふぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0203123" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「はぁ……あっ、え、なに？　もっと脇を締めて欲しい？　分かったわ……な\nら、腕を降ろして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0203124" ]},
		{"command":[ "SETIMAGE", "0", "still_00026802_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「腕は上げたまま、オチンポをギュっとしてくれって……難しいこと言ってく\nれるわね。えっと……こう、かしら……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0203125" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「あっ、んっ……はふっ、あぐっ！　ふっ、んむっ……くっ、あっあっ！　ふ\nっ、あっ……きゃ、んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0203126" ]},
		{"command":[ "SETIMAGE", "0", "still_00026802_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「オチンポのデコボコしたところが、脇に挟まって……あはぁぁっ……さっき\nより、オマンコ感じてっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0203127" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「ひっ、うぐっ！　きゃ、あっ！　スリスリする速度が上がってる……ヌルヌ\nルした汁も、もっと拡げられてっ……あぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0203128" ]},
		{"command":[ "SETIMAGE", "0", "still_00026802_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁぁっ……あっあっ、あっ、んふぅっ！　お、おっぱいにも刺激が\nっ……あひぃっ！　触ってないのに、乳首が大きくなるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0203129" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「こんな変態みたいなことで……か、感じるなんてっ……でも、これもパワー\nアップのため……が、我慢しないとぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0203130" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「あっ、ひっあっ、んっ、はぁぁっ！　オチンポを擦る速度が、もっと上がっ\nてるっ……それに、なんだかヒクヒクしてて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0203131" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「脇の奥に押し込まれるたびに、ビクンビクンって、跳ねまくってるぅ……な\n、なにがどうなってるの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0203132" ]},
		{"command":[ "SETIMAGE", "0", "still_00026802_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「も、もしかして、さっき言ってたセーエキっていうのが出るの？　オチンポ\nから、白い液体が出るってこと！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0203133" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「そろそろ出るから、脇にチカラを入れてくれって……わ、わかったわ！　思\nいっきり、ぎゅーってしてあげる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0203134" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「ふんっ！　んっ、くぅぅっ！　あっ、あっ！　ふぎゅ、んっくぅっ！　はぁ\n、あっ、あっ！　ひぎっ、あっあっ！　あっはぁぁぁっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0203135" ]},
		{"command":[ "SETIMAGE", "0", "still_00026802_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「あっ、熱いぃっ！　すごい勢いで、ドロドロした液体が出てきてるぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0203136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00026802_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「これがセーエキ……ひゃぐっ！？　す、すごいにおいだわ！　何ていうか…\n…く、くさいぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0203137" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「でも、これを身体に塗らないと、パワーアップできないのよね……私に構わ\nないで、いっぱい塗りたくってちょうだい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0203138" ]},
		{"command":[ "SETIMAGE", "0", "still_00026802_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「脇の隅から隅まで、念入りに……んっ、ふぐっ！　はぁっ、あっ、くふっ！\n　ふっ、はぁっ、んふっ！　んぐぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0203139" ]},
		{"command":[ "SETIMAGE", "0", "still_00026802_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「まだセーエキ出てるっ……こんなの、脇が火傷しちゃうぅ……はぁっ、あっ\n！　ひゃ、あっ！　んっ、あっあっ！　んんんっ～～～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0203140" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「はぁ……ふっ……んふぅ……セーエキもだいぶ落ち着いたみたいね……ふぅ\n。これでパワーアップできたのかしら？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0203201" ]},
		{"command":[ "SETIMAGE", "0", "still_00026802_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「具体的にどういう効果があるのか、確認しないと……悪いけど、オチンポを\n離してもらっていい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0203202" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「なに？　一回だけだと効果が薄い？　まだセーエキは出るから、もっと脇で\nスリスリさせて欲しいの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0203203" ]},
		{"command":[ "SETIMAGE", "0", "still_00026802_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「そういうことなら、もっとセーエキを出してもらわないと……えっと、さっ\nきみたいに、脇でオチンポを気持ちよくすればいいのね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0203204" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「んっ……においが気になるけど、大丈夫よ。これも強くなるためだもの……\nそれじゃあ、また脇を締めるわね……んっ、んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0203205" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「はぁ、くっ、はふっ！　ひゃ、あっ！　くっ、あっ……あふっ、んんっ！　\nはぁ、あぁっ……あっ、きゃ、あっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0203206" ]},
		{"command":[ "SETIMAGE", "0", "still_00026802_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「セーエキのおかげで、さっきよりも滑りがよくなってるみたいね……ズリズ\nリってされる感じが、より伝わってくるわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0203207" ]},
		{"command":[ "SETIMAGE", "0", "still_00026802_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「もっとオチンポを肌に押し付けていいから……出来る限り、満遍なく塗り込\nんでちょうだい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0203208" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「ひぐっ、はっ……ひゃ、んきゅっ！　あぁぁっ！　カタいのが、激しく押し\n込まれて……んんっ！　奥まで、きてるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0203209" ]},
		{"command":[ "SETIMAGE", "0", "still_00026802_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「あぁぁっ！　関節のところに、デコボコしたのがすっぽりハマってるっ！　\nやっ、そんなとこ、グリグリされたらぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0203210" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「はぐっ！　んっ、くふぅっ！？　く、くすぐったいのと、気持ちいいのが、\n同時に……やっ、あっ！　な、なにこれぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0203211" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「こんな感覚、知らない！　脇にオチンポを押し付けられて、快感を覚えるだ\nなんて……そんなこと、今までなくて……あぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0203212" ]},
		{"command":[ "SETIMAGE", "0", "still_00026802_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「幸せな気持ちが、どんどん溢れて来るっ！　ヘソの下あたりが、ズキズキっ\nて痛むように疼いて……んっ、くっ！　あっ、んひぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0203213" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁっ！　も、もしかして、これがパワーアップしてるって感覚なの\nかしら……だとしたら、この気持ちも納得だわ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0203214" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「んっ、んくぅっ！　もっと強く、脇にオチンポを押し込んで！　擦りながら\n、トントンって叩いて刺激してちょうだい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0203215" ]},
		{"command":[ "SETIMAGE", "0", "still_00026802_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「私ももっと、脇をぎゅーってするから……んんっ！　ふっ、んふっ！　はぁ\n、くっ、あっ、あひっ！　はぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0203216" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「あぁぁぁっ！　オチンポで脇が撫でまわされてるっ！　ズンズンって突かれ\nながら、セーエキ塗り込まれてるのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0203217" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「やだっ、なにこれ……ヘンなのが、オマンコの奥からきてっ……ひっ、あっ\n！？　足や腰が勝手に震えてっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0203218" ]},
		{"command":[ "SETIMAGE", "0", "still_00026802_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「ふひぃっ！？　隊長のオチンポも、さっきみたいにビクビクってしてるっ！\n　ま、また出るのね！　セーエキ、出ちゃうのね！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0203219" ]},
		{"command":[ "SETIMAGE", "0", "still_00026802_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「私に構わず、いっぱい出して！　さっきの熱くてドロドロした白い液体を、\n思いっきりびゅーびゅーしてぇっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0203220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「あはぁぁぁぁんっ！　ま、また脇にいっぱい出てるぅ！　白くて熱いの、ど\nぴゅどぴゅされてるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0203301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00026802_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「脇の奥のところに、流し込まれて……んふっ！　くっ、はぅ！　んんっ、あ\nっ、あひぃんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0203302" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「出してる最中も、脇を締めて欲しいのね！？　わ、わかったわ！　力の限り\n、挟み込んであげる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0203303" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「んぐぐっ！　ふんぐっ！　ふっ、おふっ！　おっ、んひぃっ！　はぁ、あっ\n、うぐぐっ！　んっ、ふっ！　はふぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0203304" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「あっ、あっ！　まだ出てるっ！　私の脇が、真っ白いのでいっぱいにされて\nっ……あっ、あっ！　あぁぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0203305" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、はふぅ……すごかったわ……隊長の熱いセーエキが、こんな\nにいっぱい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0203306" ]},
		{"command":[ "SETIMAGE", "0", "still_00026802_01_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「これだけ出されれば、絶対にパワーアップしたに違いないわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0203307" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「本当なら、今すぐチカラを試したいけど……さすがに、体力を消耗しすぎた\nわね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0203308" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「それに、このにおいを放置していたら、脇に染みついちゃいそうだわ……ん\nっ、はぁぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0203309" ]},
		{"command":[ "SETIMAGE", "0", "still_00026802_01_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「え？　このにおいもパワーアップする要素だから、しばらくこのままで居て\n欲しいの？　わかったわ……隊長がそう言うなら、そうさせてもらうわね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0203310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「きゃあぁぁぁっ！？　ちょ、なにが起こって……あひっ！？　あ、熱いぃ！\n　顔に何かかけられてるぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0203401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00026802_01_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「も、もしかして、セーエキを顔にかけてるの！？　どうして……さっきは脇\nに出してたのにっ！　あっ、んふっ！　あっ、はぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0203402" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「ちょ、ちょっと……一旦、セーエキを止めて……あはぁぁっ！　クチや鼻に\n、いっぱい降りかかってくるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0203403" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「ダ、ダメ……このキツいにおいが充満して……嗅いでると、ヘソの下から何\nかが溢れてきてっ……あっ、あっ！？　やっ、なにこれ……あんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0203404" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「くるっ……オマンコから、出てきちゃうぅ！　セーエキ浴びせられながら、\nヘンなの出ちゃうのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0203405" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「ふーっ……んふぅー……いったい、何が起こったの……もう、わけが分から\nないわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0203406" ]},
		{"command":[ "SETIMAGE", "0", "still_00026802_01_13" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「え？　気持ちよかったかって……そ、それは、その……気持ちよかったけど\n……このドロドロした感じは、正直、不快だわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0203407" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「そもそも、セーエキを顔にかける必要はあるの？　さっきみたいに、脇に出\nせばよかったじゃない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0203408" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「身体に塗ればいいから、脇でも顔でもどこでもいいの？　それなら、手とか\nお腹とかでもよかったじゃない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0203409" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「ああ、もう……においが身体に染みついちゃう。早くシャワーを浴びないと\n……えっ、シャワーもダメなの！？　そんなの聞いてないわよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0203410" ]},
		{"command":[ "SETIMAGE", "0", "still_00026802_01_12" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
