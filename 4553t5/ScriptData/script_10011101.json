{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0111" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_005" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "襲来者リーダー" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010111010001" ]},
		{"command":[ "SETCHARA", "0", "char_00090101_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "謎の声" ]},
		{"command":[ "SETTEXT", "「……報告は見せてもらった」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者リーダー" ]},
		{"command":[ "SETTEXT", "「はっ！　そ、それでですね、作戦の進捗に関しましては……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010111010002" ]},
		{"command":[ "SETCHARA", "0", "char_00090101_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "謎の声" ]},
		{"command":[ "SETTEXT", "「君には失望した。たかが辺境の次元ひとつ、制圧するのにどれだけの時間と\n費用をかけているのか」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者リーダー" ]},
		{"command":[ "SETTEXT", "「そ……それは、ですね！　どうやら他の多くの次元から、この次元に協力者\nが集まっているようでありまして、でありますからその――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010111010003" ]},
		{"command":[ "SETCHARA", "0", "char_00090101_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "謎の声" ]},
		{"command":[ "SETTEXT", "「言い訳は不要だ」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者リーダー" ]},
		{"command":[ "SETTEXT", "「言い訳などと、そのような！　ただ、ワタクシはご質問にお答えしようと―\n―」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010111010004" ]},
		{"command":[ "SETCHARA", "0", "char_00090101_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "謎の声" ]},
		{"command":[ "SETTEXT", "「つまるところ、この次元の制圧は君の手に余る。そういうことだな？　よろ\nしい。代わりの指揮官を送る」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者リーダー" ]},
		{"command":[ "SETTEXT", "「え？　は！？　ええっ！？　いえいえいえ！　決してそのようなことは！　\nただ、いま少し時間と予算がですね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010111010005" ]},
		{"command":[ "SETCHARA", "0", "char_00090101_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "謎の声" ]},
		{"command":[ "SETTEXT", "「言い訳は無意味だと知りたまえ。代わりの指揮官は、すでにそちらに向かっ\nている」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者リーダー" ]},
		{"command":[ "SETTEXT", "「いや、あの、お待ちくださいっ！　どうか、どうかもう一度だけチャンスを\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010111010006" ]},
		{"command":[ "SETCHARA", "0", "char_00090101_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "謎の声" ]},
		{"command":[ "SETTEXT", "「チャンスか。最後のチャンスをくれということか」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者リーダー" ]},
		{"command":[ "SETTEXT", "「はいっ！　ぜひとも！　ぜひともぉ～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010111010007" ]},
		{"command":[ "SETCHARA", "0", "char_00090101_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "謎の声" ]},
		{"command":[ "SETTEXT", "「ならば、新しい指揮官のもとで手柄を立てて見せたまえ。結果によっては、\n処分を免れることもありうる」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者リーダー" ]},
		{"command":[ "SETTEXT", "「しょ、処分っ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010111010008" ]},
		{"command":[ "SETCHARA", "0", "char_00090101_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "謎の声" ]},
		{"command":[ "SETTEXT", "「逃れられるかどうかは、君次第だ。通信を終わる」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者リーダー" ]},
		{"command":[ "SETTEXT", "「くっ……！　おのれ、インクレディブル・スクワッド……！　奴らのせいで\nこのような屈辱を……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010111010009" ]},
		{"command":[ "SETCHARA", "0", "char_00090101_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者リーダー" ]},
		{"command":[ "SETTEXT", "「この怒りを、奴らに必ず……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010111010010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0117" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ふぁあああ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ふぁ～～……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010111010001" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「…………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010111010001" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ヒマだ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「……そだね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010111010001" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テレビの音声" ]},
		{"command":[ "SETTEXT", "「はい！　というわけでこの特大ハンバーグ、九重市内では昔から人気のお店\nで……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「はぁ……うまそう。いますぐ食べにいきたい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010111010001" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「この前、ウチを無理やり連れて行ったじゃないですか。そして行列にうんざ\nりして帰ってきたじゃないですか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010111010001" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「大丈夫！　大丈夫だって！　今回はちゃんと並ぶから！　今から行こうぜ！\n　なぁ～！　行こうよぉ～！　ダイヤナも行こうぜ～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010111010002" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ええ～？ダイヤナちゃん、ダイエット中だし～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010111010001" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「いいかげんにしてください！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010111010002" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「え？　な、なんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010111010003" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「いつまでもテレビを見ていたり、ダラダラサボってばかりで！　そんなこと\nより、戦闘に備えて自主訓練でもしたらどうなんですか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010111010003" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「ええ～？　だってなあ。襲来者（インベーダー）のヤツら、ここ最近全然現\nれないじゃん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010111010004" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「そうよねー？　もう襲来者（インベーダー）ちゃんたち、あきらめておうち\nに帰ったんじゃないのー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010111010002" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「おいおい、なにをのん気なことを言っているんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010111010001" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あ、長官」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010111010002" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「こうしている間にも、ヤツらは次の作戦を進めているかも知れないんだぞ？\n　だいたいお前たちは――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010111010002" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テレビの音声" ]},
		{"command":[ "SETTEXT", "「では、次の話題なんですが、この写真、見てください。空に小さく、光る円\n盤のようなものが浮かんでいますね。最近、全国でこのような――」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ん……？　空に円盤……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010111010003" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「長官、これはもしかして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010111010004" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ああ……間違いないな。これは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010111010004" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「ええ。私もそう思います。きっと襲来者（インベーダー）が――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010111010005" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「空飛ぶ円盤！　ＵＦＯ（ユーフォー）じゃないか！　懐かしいなぁ！　昔テ\nレビで流行ったよなあ、こういうの！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010111010005" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「は！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010111010006" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ああ、あれだね？　あたしも地球からの電波を傍受してよく見てたよ。なん\nとかスペシャル、とかいってさ。『４ｍの宇宙人発見！』とか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010111010001" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「そうそう！　『宇宙人解体ショー』とか言ってな！　大げさな音楽で！　デ\nィレクターのうさんくさい解説がまた最高でな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010111010006" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あったねえ！　懐かしいねえ！　あんたたちも観たことあるだろ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010111010002" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「え……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010111010003" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「なんすか？　それ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010111010005" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「わたしは……観たことないなあ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010111010002" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「エファナティカや長官が若いころの話だから……私たちが知らないのも当然\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010111010002" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ちょっと待ちな！　あたしはまだまだ若いよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010111010003" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「今、検索してみたけど……かなり前に流行った番組のようね。『毎週スペシ\nャル　円盤特集シリーズ』……ですよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010111010001" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「円盤特集ねえ……聞いたことないですねえ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ぐっ……！　こ、これがジェネレーションギャップ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010111010007" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「……って！　隊長はともかく長官まで一緒になって脱線しないでください！\n　まともに仕事してくださいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010111010007" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「いや、しかしな。そうは言ってもな。こうもヒマではなぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010111010008" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「っ！？　なんだ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010111010009" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "秘書" ]},
		{"command":[ "SETTEXT", "「長官！　隊長！　ルナパレス２１より、緊急通信です！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ルナパレス！？　母上様か！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010111010001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「月から！？　なにかあったのでしょうか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010111010008" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「わからん……。とにかく、つないでくれ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010111010010" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "秘書" ]},
		{"command":[ "SETTEXT", "「了解しました！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「皆の者、久しいの。余じゃ。ルナルバースじゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010111010001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「母上様！　いったいどうなさったのですか！？　緊急通信などと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010111010002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「まさか、月に異変が！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010111010009" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「異変……といえば、異変かもしれん。そうでないといえば、そうでないかも\nしれん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010111010002" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「どういうことです？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010111010002" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「うむ……実はの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010111010003" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「……実は？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090111010001" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYBGM", "BGM_018" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「余の部屋を思い切って改装してみたんじゃよ～！　みんなの感想を聞きたい\nんで、ちょっとルナパレスまで遊びに来んかね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010111010004" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "一同" ]},
		{"command":[ "SETTEXT", "「だあああああーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010111010003" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "3", "CENTER", "-600" ]},
		{"command":[ "SETCHARA", "1", "char_00000101_01", "3", "CENTER", "-200" ]},
		{"command":[ "SETCHARA", "2", "char_00001401_01", "3", "CENTER", "200" ]},
		{"command":[ "SETCHARA", "3", "char_00001201_01", "3", "CENTER", "600" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "DISPCHARA", "2", "TRUE" ]}, 
		{"command":[ "DISPCHARA", "3", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "DISPCHARA", "2", "FALSE" ]}, 
		{"command":[ "DISPCHARA", "3", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0002" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「やー！　皆の者、よう来たの！　ま、適当にそのへん座って！　くつろぐが\nよいぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010111010005" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「はあ、恐縮です。しかしですねぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010111010012" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「いきなり緊急回線で通信してくるから、何事かと思いました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010111010004" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「あー、すまんすまん。たったいま部屋の改装が済んだんじゃが、皆にも早く\n見せてやりたくての」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010111010006" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「言われてみればおとといから、玉座の間にピースムーンたちを呼んで何かや\nってたわよねぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010111010003" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ウチも気づきましたが……しかし、どこも改装されているようには見えませ\nんが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010111010004" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「なにを言っとるか。ここじゃよ、ほれ、ここー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010111010007" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「ここって？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010111010004" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「だからここ！　ここじゃって！　ほれ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010111010008" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ここ、とは……はっ！？　玉座のひじ掛けにボタンが！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010111010005" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「そうそう！　これじゃよ、これ！　地球の立ち飲み屋にヒントを得てな。何\nか用があるときは、侍女たちやピースムーンをこれで――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010111010009" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……つまり、呼び出しボタンっすか。玉座に、呼び出しボタンを取り付けた\n。それが陛下の自慢の改装」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010111010003" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ま、まあ、そうじゃけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010111010010" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「つまり、呼び出しボタンを見せるために私たちは呼び出された、と」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010111010006" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「誰がうまいこと言えと言いましたか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010111010005" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「こんなことなら、マスク・ザ・ブルーたちと本部でお留守番していたほうが\nよかったような……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010111010004" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「ま、まあ、姉ちゃんそう言わないで……ははははは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010111010005" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「なんじゃおまえら！　反応悪いのう！　このボタンをなめるでないぞ！　よ\nいか？　実はこのボタン、呼び出し機能のほかに――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010111010011" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「うわっ！？　なにこの音っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010111010006" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「母上様！？　いくらなんでも、こんなに大きな音にしなくても！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010111010006" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「違う！　これは違うぞ！？　この音は――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010111010012" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピースムーン" ]},
		{"command":[ "SETTEXT", "「陛下っ！　警報です！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_030111010001" ]},
		{"command":[ "SETCHARA", "0", "char_00000809_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ほら見ろ！　やはり違ったではないか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010111010013" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「んなこと言ってる場合ですか！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「わかっとるわい！　それよりこの音は、侵入警報じゃな！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010111010014" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピースムーン" ]},
		{"command":[ "SETTEXT", "「はっ！　警戒衛星が、怪しい影を捕らえました。すでに第一次警戒ラインの\n内側に入っているようで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_030111010002" ]},
		{"command":[ "SETCHARA", "0", "char_00000809_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「なんじゃと？　それまで発見できなかったというのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010111010015" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピースムーン" ]},
		{"command":[ "SETTEXT", "「はい。申し訳ございません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_030111010003" ]},
		{"command":[ "SETCHARA", "0", "char_00000809_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「とにかく、正体を見極めねばならんな。迎撃部隊を発進させよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010111010016" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピースムーン" ]},
		{"command":[ "SETTEXT", "「はっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_030111010004" ]},
		{"command":[ "SETCHARA", "0", "char_00000809_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「……陛下、失礼いたします。様子を見てまいります」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010111010004" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「どうした？　気になることでもあるのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010111010017" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ええ、少しばかり……。それでは」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010111010005" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ウチも、防御魔法を点検してきます。セレーナさん、手伝ってください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010111010006" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「ん？　ああ、わかった！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010111010007" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ダ、ダイヤナちゃんもちょっと……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010111010004" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「どうしたというのだ、皆そんなに慌てて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010111010007" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「グレート・ルナリアムの誇る警戒衛星網を、知らぬ間に突破されたのじゃ。\n神経質にもなろうて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010111010018" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「警戒網を……知らぬ間に……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090111010002" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……おい、どうしたんだアナザー。顔色が悪いぞ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「いや、なんでもない。そうだな……まさか、こちらでまでそのようなことは\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090111010003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「っ！！！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090111010004" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「な、なんだ！？　この音！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピースムーン" ]},
		{"command":[ "SETTEXT", "「陛下っ！　申し上げます！　緊急事態でございます！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_030111010005" ]},
		{"command":[ "SETCHARA", "0", "char_00000809_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「今の爆発か！？　何事じゃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010111010019" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピースムーン" ]},
		{"command":[ "SETTEXT", "「襲来者（インベーダー）の大部隊がルナパレス２１付近に突如現れました！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_030111010006" ]},
		{"command":[ "SETCHARA", "0", "char_00000809_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「なんだとぉ！？　ルナパレス周辺は、エネルギーシールドで守られているは\nずではないのか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010111010008" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピースムーン" ]},
		{"command":[ "SETTEXT", "「それが、シールドの一部が突然消滅し、そこから敵が現れたとのことで……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_030111010007" ]},
		{"command":[ "SETCHARA", "0", "char_00000809_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「どうして急に……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010111010007" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「状況は？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010111010004" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピースムーン" ]},
		{"command":[ "SETTEXT", "「現在、王宮警備隊が襲来者（インベーダー）たちと交戦中です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_030111010008" ]},
		{"command":[ "SETCHARA", "0", "char_00000809_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「とにかく、このままにはしておけんな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010111010020" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「陛下、相手が襲来者（インベーダー）となれば、我々も見過ごすわけにはい\nきません。ルナパレス防衛に協力しましょう。いいな？　隊長」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010111010013" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「このまま帰るわけにもいきませんからね。そういうわけで、ちょっとあんた\n頼まれてくれないか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピースムーン" ]},
		{"command":[ "SETTEXT", "「は！　なんなりと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_030111010009" ]},
		{"command":[ "SETCHARA", "0", "char_00000809_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「通信でエファナティカとオボロと、それから……まあいいや、ジュンジロー\n、お前も行って、さっきどっかに出かけた連中を呼び集めてくれ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「俺たちゃ先に襲来者（インベーダー）退治に出る！　急いで合流するように\n伝えるんだ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「承知しましたぞ。では、まいりましょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010111010001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピースムーン" ]},
		{"command":[ "SETTEXT", "「はっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_030111010010" ]},
		{"command":[ "SETCHARA", "0", "char_00000809_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「さて！　こっちも行くぜ、みんな！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「シールド消失……突然現れた襲来者（インベーダー）……か」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090111010005" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「……どうした？　アナザー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010111010009" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「……っ！　いや、なんでもない。わかった、出撃だな？　よし、行こう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090111010006" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
