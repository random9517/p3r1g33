		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「ふぅ……やっぱり、たまのリラックスは必要だよなー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1204101" ]},
		{"command":[ "SETCHARA", "0", "char_00000412_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「じっくり骨休めが出来て、気持ちもリフレッシュできて……後は……一つだ\nけ、満たされてないものがあるな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1204102" ]},
		{"command":[ "SETCHARA", "0", "char_00000412_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「……なんだよ、何となく分かるだろ？　意味ありげにニヤニヤしやがって…\n…だからぁっ……こ、こういうことだよっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1204103" ]},
		{"command":[ "SETCHARA", "0", "char_00000412_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「んっ……はぁっ……はぁ……ずっと、分かってたクセに勿体つけやがって…\n…結局、オレが押し倒してるじゃんか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1204104" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00000412_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「これも、全部お前がオレをそういう風にしたのが悪いんだからな……？　そ\nこんところ……しっかり落とし前つけてくれよな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1204105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「ビキニ……邪魔……ぅぅ……こんな露出してるのに……いちばん大事なトコ\n……取っちゃわないと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1204106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「これでいいよな……ほら見ろ……お前のチンチン、もう完全にその気になっ\nてるじゃんか……いやらしい奴だ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1204107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「こんな上向きに勃起させて……ちょっと擦るだけで、ビクンって震えてるぜ\n……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1204108" ]},
		{"command":[ "SETIMAGE", "0", "still_00000412_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「んんっ、あぁ……オレのも濡れてる……んっ、そんなの分かってるよ……だ\nって、したくてしたくて……仕方ないんだからぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1204109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「もう、入れるぞ？　チンチン……入れちゃうからな……？　オマンコに……\nチンチン……ずっぷり……ハメるぅ……んぅぅぅぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1204110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「んくぁぁぁぁ……はぁぁぁ……んっ、入ったぁ……チンチン……ずっぷり…\n…埋まっていくぅぅぅ……んっ、くぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1204111" ]},
		{"command":[ "SETIMAGE", "0", "still_00000412_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「そうだよ……ずっと欲しかったんだからな……お前が、このチンチンの味を\n教えたから……こんな風になったんだぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1204112" ]},
		{"command":[ "SETIMAGE", "0", "still_00000412_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「んくぁ……ぶっすり突き刺さってるまま……腰、動かしていくぅ……はぁっ\n、んっ、くぅっ、んふぁっ、あっ、んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1204113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「うぁぁ……おっきぃ……思ってたより……もっと、オマンコ……ぐぱって…\n…広がってるぅっ……んくぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1204114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「あっ……な、何して……こら……勝手におっぱい……も、揉むな……あ、ひ\nぁっ、あっ、んぁぁんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1204115" ]},
		{"command":[ "SETIMAGE", "0", "still_00000412_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「物欲しそうにしてたからって……そ、それは……あぁっ、んっ、そんな、こ\nとは……あひっ、はっ、んくぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1204116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「くそ……気持ちいい……かも……うくぅっ、乳首……あっ、むくむく育って\n来てる……あっ、爪が食い込むぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1204117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「んんっ……そっちがその気なら……オレだって……んっ、ふっ、はぁっ、あ\nっ、んくっ、ど、どうだ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1204118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「んふぅ……なっ、チンチン、いい感じになってきてるだろ……？　上下に動\nきながら……キュって……締め付けてやってるんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1204119" ]},
		{"command":[ "SETIMAGE", "0", "still_00000412_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「オマンコの肉が……むちって……チンチンにへばりついて……じゅくじゅく\nって汁をなすりつけていく……んふぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1204120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「あぁ……効くぅぅ……オマンコ……感じるぅ……ほらぁ……お前も、もっと\n……あっ、動かしてみろぉ……あっ、あひぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1204121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「そ、それぇっ……あっ、あぉっ、下からっ……ぐいぐいっ、あっ、来てるっ\n……んふぁっ、あっ、はぁぁぁぁんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1204122" ]},
		{"command":[ "SETIMAGE", "0", "still_00000412_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「あっ、あぁっ……ヤバい……声、出ちゃうっ……はぁっ、こ、こんなに出し\nたらっ……あ、あぁっ、誰かに聞かれちゃう……かもっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1204123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「み、見せつけてやればいいって……あぁっ、そ、それはやだっ……あっ、恥\nずかしいっ……こんなトコ見せるなんて……ダメだからぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1204124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「オレが……あっ、こんなトコ……見せるのはっ、お前だけなんだからなっ…\n…それっ、分かってるのかっ、あっ、ひぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1204125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「やだ……お前がヘンなこと言うからっ、オマンコ……どんどん濡れて……は\nぁっ、溢れて……来るぅっ……ひゃ、ひぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1204126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「あぁっ……待てっ、今っ……乳首っ……弱いからっ、んぁっ、はっ、あぁん\nっ、あっ、あぁぁぁっ……カリカリしちゃらめっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1204127" ]},
		{"command":[ "SETIMAGE", "0", "still_00000412_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「は、あぁぁっ……らめらっ、止まらないっ……あぁぁ……どんどん、気持ち\nよくなるぅっ……腰が……動いてくぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1204128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「あっ、くぁぁんっ、分かったっ……認めるっ、認めるからぁっ……オレはっ\n……発情したエロ犬でっ……チンチンが大好きでぇっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1204129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「だからっ、あっ、今みたいにっ……下からっ……オマンコっ、ズンズンされ\nるの好きだからぁっ、してっ、もっとしてくれぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1204130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「ひゃひぃぃっ……んぁぉっ、おぉぉぉぉんっ！　チンチンすごいっ、ズンズ\nン来るっ……太くてっ、おっきいのっ……グリグリされるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1204131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「あぁっ、おっぱいもっ……ぎゅうってされてぇっ……オレっ、カラダ……全\n部っ、感じるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1204132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「いいっ、もっと……乱暴にしていいからっ……おっぱい、揉みくちゃにして\nぇっ……あひっ、乳首っ……つねられてるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1204133" ]},
		{"command":[ "SETIMAGE", "0", "still_00000412_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「やらっ、カラダっ……ピリピリするっ……はぁっ、んっ、オレ……あっ、ひ\nぁっ、イキそうにっ……なってるぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1204134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「お前もっ……イクのかっ？　あっ、あぁっ、もうっ、何でもいいからっ……\n来てっ……あひぁっ、だ、出してぇっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1204135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「あぅぅぅぅぅぅぅぅぅんっ……！　オマンコっ……熱いのっ……びゅくびゅ\nくっ……してるぅぅぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1204136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000412_02_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「やらっ、あぁっ、また……この気持ちいいのっ……力っ……抜けてっ……が\n、我慢っ……出来ない……は、ひぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1204137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「あぁぁぁ……も、漏れるぅ……また……オレ……イッて……も、漏らしてる\nぅぅ……あぁ……か、掛かってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1204138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「ご、ごめん……あぁ……止められなくて……あぁぁ……おしっこ……出して\nるの……はぁぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1204139" ]},
		{"command":[ "SETIMAGE", "0", "still_00000412_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「ふぁ……はぁ、はぁはぁ……しちゃった……んぅ……あぁ……気持ちいいの\n……出しちゃった……んふぁぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1204140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「その……悪かったな……また、おしっこ……掛けちゃって……そんなつもり\nじゃなかったんだけど……で、出ちゃって……あっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1204201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「んんっ……別に気にしないって……？　それより……もっと続き……こ、こ\nのスケベ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1204202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「けど……んっ、オレも……まだして欲しいって感じ……かも……あっ、チン\nチン……抜かないで、続きしようぜ……く……んふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1204203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「そう……あっ、はぁっ、イッた後だから……まだ、オマンコ……ジンジンし\nてる……動かすの、もう少しだけ後で……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1204204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「あっ、うん……そうだな……その間……おっぱい好きにして、いいから……\nはふぁ……あっ、んくぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1204205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「最初は……ホント、遠慮しねぇーなーって思ってたけど……それ位の方が…\n…オレには合ってるのかも……マジ、気持ちいい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1204206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「乳首……んくぅっ、何回も転がされて……ムズムズして……はぅ……んっ、\nヤバ……あふっ……力……抜けるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1204207" ]},
		{"command":[ "SETIMAGE", "0", "still_00000412_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「うん……そろそろ、動いていい……感じ……また、オマンコ……続きしよう\n……あっ、あぅっ、んくっ、ふっ、あっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1204208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「うぁぁ……やっぱ、あぁっ、響くぅっ……チンチンの先がっ……子宮のトコ\nまでぐぐって当たってっ……は、ひぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1204209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「もっと、腰を振るっ……あぁっ、俺の……方もっ、チンチンっ、感じさせて\nいくからっ、うんっ、あぁっ、はぁうんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1204210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「んぁぁっ……！　グイグイ来てる……おっぱい……揉みまくられながら……\nズリズリされるのっ……あぁっ、いいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1204211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「あっ、はんっ、あっ、あぁっ……うんっ、いいっ、チンチン感じるっ、オマ\nンコ……突き回されてっ、喜んでるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1204212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「はぁっ……んぁっ、やらしすぎる……こんな明るいトコですることじゃない\nのにっ……もうっ、止まらないっ……もっと欲しいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1204213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「くふぅぅんっ！　あぁっ、オレの……緩んでる顔……見られてぇっ……ぷる\nぷるっ、おっぱい揺らしてぇっ……オマンコ広がってぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1204214" ]},
		{"command":[ "SETIMAGE", "0", "still_00000412_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「はぁぁっ、またイキたくなってるっ、オマンコイッちゃうっ！　あぁっ、い\nいのかっ？　うんっ、イキ顔っ……見せちまうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1204215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「らめっ、もっ、イクっ……！　あひぃぃぃっ、チンチン突きまくられてっ！\n　オマンコっ……またっ、イックっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1204216" ]},
		{"command":[ "SETIMAGE", "0", "still_00000412_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「んんんんんんんんんっ……！　あっ、あぁぁぁぁぁぁぁ……イ、イッてる…\n…！　またっ、オレのイキ顔……見せてるぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1204217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「あぁぁ……ま、待ってっ！　イッてる時にっ、まだっ、激しくっ！　そんな\nっ、あっ、ズンズンされたらぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1204218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「お、お前もっ……！？　それはっ、あっ、でもっ……今……されたらっ、ま\n、またっ、で、出ちゃうかもっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1204219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「気にしないってっ……オレは気にするのにっ！　ダメっ、あぁっ、も、もう\nらめっ！　あっ、出るっ……また出ちゃうっ、はひぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1204220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「んぁぁぁぁぁーっ！　またっ、おしっこっ……出てるっ……中出しされてっ\n……も、漏れてるぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1204301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000412_02_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「はぁぁ……ごめん、オレ……止められ……ない……汚いの……掛けちゃって\nる……あぁ……ごめん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1204302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「いいのか……？　んっ、うんっ……あぁ……お互い様って……バカ……精液\nとおしっこじゃ……全然意味違うだろ……んふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1204303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「でも、ありがとな……少しだけ、気持ち……楽になったかも……んぅ……は\nぁぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1204304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「うん……全部、出た……お前は……まだ、少し出る……？　んっ、なら……\nこのまま、出しちゃって……んふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1204305" ]},
		{"command":[ "SETIMAGE", "0", "still_00000412_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「はぁっ……はぁ、んっ、今度こそ……終わりだな？　うん……オマンコ……\nいっぱいになったから……あふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1204306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「あ……まだ、抜くのはもうちょっと待ってくれ。腰に力入らなくて……ガク\nガクだからさ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1204307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「はぁ、でも……めっちゃサカッちまった……オレとしたことが……流石に恥\nずかしすぎるぜ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1204308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「と、とりあえず……シャワー浴びないとな……オレが汚しちゃったし……そ\nの、ちゃんと責任とって洗うから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1204309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「あ、あんまりヘンなこと期待すんなよ！？　これ以上はマジで色々限界だか\nらっ！　わ、分かったな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1204310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「ふぁぁぁっ……カラダっ……あっ、掛かってっ……！　オレもっ……また…\n…あっ、も、漏れてるぅぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1204401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000412_02_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「あぁぁ……出し合ってるって……バ、バカぁ……そういうのじゃ……ないの\nにっ……は、恥ずかしいだろっ……んぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1204402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「気にせず出せば……うぅ……気にするってぇ……けど……止められない……\nあぁ……おしっこぉ……はふぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1204403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「んっ……あふっ、止まった……あぁ……お前は……もうちょっと……？　う\nん……掛けて……お尻にも……びゅくってぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1204404" ]},
		{"command":[ "SETIMAGE", "0", "still_00000412_02_16" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「はふぁ……終わった……？　そっか……うん……ねとねとだ……いっぱい出\nしたな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1204405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「はぁ……めちゃくちゃ大胆なコトしちまったな……幾らなんでも開放的にな\nりすぎたかも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1204406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「いい乱れっぷり……バ、バカ……だから言うんじゃねぇっての！　本気で恥\nずかしいんだからな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1204407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「まぁ、気持ちよかったし……お前も、いっぱい出したんなら……そのよかっ\nたけどさ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1204408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「と、とりあえず……シャワー浴びないとな……オレが汚しちゃったし……そ\nの、ちゃんと責任とって洗うから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1204409" ]},
		{"command":[ "WAITINPUT" ]},

