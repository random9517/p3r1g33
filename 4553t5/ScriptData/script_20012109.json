{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0156" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お、お前は……！」", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "闇より出でし謎の人物……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "マイクロバスの運転手は、深くかぶっていた帽子を投げ捨てると高らかに笑い\n出す。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "？？" ]},
		{"command":[ "SETTEXT", "「ハハハハッ、アハハハハッ！　愚鈍なる地球人ども！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "？？" ]},
		{"command":[ "SETTEXT", "「どうだ？　まんまと我々の罠にかかった気分は！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「あの～……でも作戦失敗してますよね。コレも罠……ってわけじゃなさそう\nですが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_030021740001" ]},
		{"command":[ "SETCHARA", "0", "char_00007903_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "？？" ]},
		{"command":[ "SETTEXT", "「ぐぅっ！　そ、それはだな！　まずはこちらの話を聞け！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「はぁ……。いいですけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_030021740002" ]},
		{"command":[ "SETCHARA", "0", "char_00007903_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "？？" ]},
		{"command":[ "SETTEXT", "「我々の崇高なる作戦の全貌はこうだ。諜報員が貴様らの休暇を調べ上げ！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "？？" ]},
		{"command":[ "SETTEXT", "「そこを狙って慰安旅行のチラシをこれでもかと撒き、邪魔なＥＤＯとΩ組を\nなんとか一緒の旅行に行かせ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "？？" ]},
		{"command":[ "SETTEXT", "「その場を怪人が襲撃することで、思う存分体力、気力を削いだ後……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "？？" ]},
		{"command":[ "SETTEXT", "「弱った貴様らを潰し合わせて一挙両得！　どちらも滅ぼしてやる予定だった\n。のだが……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "？？" ]},
		{"command":[ "SETTEXT", "「だが、その作戦には一つだけ盲点があった！　怪人派遣組合が、予想以上に\n！　強烈に！　信じられないほど！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "？？" ]},
		{"command":[ "SETTEXT", "「……弱かったのだ！　一矢報いるどころじゃなく、まさに最弱！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハチ乙女" ]},
		{"command":[ "SETTEXT", "「す、すみませぇぇえええん……。がんばったんですけどぉおおお～～～～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_010021740001" ]},
		{"command":[ "SETCHARA", "0", "char_00021901_01", "4", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「今度はもっとがんばります～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_010021740001" ]},
		{"command":[ "SETCHARA", "0", "char_00018201_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「パート気分ですみませんでしたぁあ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_010021740001" ]},
		{"command":[ "SETCHARA", "0", "char_00018301_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「子どもが～、昨日夜泣きしてあんまり眠れてなくて～！　ごめんなさぁああ\nいい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_010021740001" ]},
		{"command":[ "SETCHARA", "0", "char_00018401_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "？？" ]},
		{"command":[ "SETTEXT", "「……貴様らの家庭事情は知らん」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「そ、そうですよねぇえええ。私たちぃ、社会を甘く見てましたぁあ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_010021740002" ]},
		{"command":[ "SETCHARA", "0", "char_00018401_01", "4", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "？？" ]},
		{"command":[ "SETTEXT", "「と、とにかくっ！　やはりこの星の組織なぞ、信用するに値（あたい）せん\nということだ！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "？？" ]},
		{"command":[ "SETTEXT", "「よって！　我々自身が打って出ることにしたのだ！　ククク……！　我々を\n、バイトの人妻どもと同じに思うなよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "？？" ]},
		{"command":[ "SETTEXT", "「こちらの軍勢は純粋なるエリート軍団！　もはや貴様らに逃げ場などない！\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "？？" ]},
		{"command":[ "SETTEXT", "「怖いか？　恐ろしいか？　泣け！　わめけ！　叫べ！　逃げまどえ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "？？" ]},
		{"command":[ "SETTEXT", "「そして思い知るがいい、我ら襲来者を敵に回した自分達の迂闊さを、浅はか\nさを……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「それで話は終わりかよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_040021740001" ]},
		{"command":[ "SETCHARA", "0", "char_00003404_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "？？" ]},
		{"command":[ "SETTEXT", "「む？　何を言っている。まだこれからだ。いかにして我々がこのスパを包囲\nしたか」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "？？" ]},
		{"command":[ "SETTEXT", "「そしてどれだけの軍勢が今！　貴様らを取り囲んでいるかみっちり説明させ\nてもらう！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「いえ。結構です。それには及びません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_030021740001" ]},
		{"command":[ "SETCHARA", "0", "char_00005003_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "？？" ]},
		{"command":[ "SETTEXT", "「何ぃ！？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「は～～～。ありきたりにも程がある作戦を、ダラダラダラダラ語りやがって\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_040021740002" ]},
		{"command":[ "SETCHARA", "0", "char_00003404_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「自分達で直接襲ってくればいいものの……。ネチネチネチネチ遠回しに……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_030021740002" ]},
		{"command":[ "SETCHARA", "0", "char_00005003_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「まわりくどいんだよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_040021740003" ]},
		{"command":[ "SETCHARA", "0", "char_00003404_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「まわりくどいんですよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_030021740003" ]},
		{"command":[ "SETCHARA", "0", "char_00005003_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ようやく、長ったらしい黒幕の話が終わり、戦闘開始かと思われたその瞬間。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "二人" ]},
		{"command":[ "SETTEXT", "「お前はもう喋るなっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_040021740004" ]},
		{"command":[ "SETCHARA", "0", "char_00003404_01", "7", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "1", "char_00005003_01", "7", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "息のあった二人の同時攻撃で、マイクロバスの運ちゃん……もとい、襲来者は\n吹き飛ばされた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「あらららら。これじゃ、僕達の出番はなさそう……ですかね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_030021740003" ]},
		{"command":[ "SETCHARA", "0", "char_00007903_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「いや。そうでもなさそうだぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_040021740001" ]},
		{"command":[ "SETCHARA", "0", "char_00004904_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「ふふふふ……。黒幕さんがおっしゃってた通り……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_030021740001" ]},
		{"command":[ "SETCHARA", "0", "char_00003303_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「さっきから、ここにもあそこにもそこかしこから……残党さんの気配がプン\nプンしとります」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_030021740002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「ああ。稚拙な作戦ではあったが、嘘はついていなかったようだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_040021740002" ]},
		{"command":[ "SETCHARA", "0", "char_00004904_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「襲来者さんたちが私達を倒す……。ふふふ、随分趣向を凝らしてくださった\nみたいですけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_030021740003" ]},
		{"command":[ "SETCHARA", "0", "char_00003303_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「それならさっさと出てこんかい！　ぐうたらしとると奥歯ガタガタ言わせた\nるからな！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_030021740004" ]},
		{"command":[ "SETCHARA", "0", "char_00003303_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「そ……そう！　そうです！　僕も気づいていましたとも！　それそれ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_030021740004" ]},
		{"command":[ "SETCHARA", "0", "char_00007903_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「敵は水の中に潜み、僕達が油断したところを一網打尽にするつもりだったと\nいうわけです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_030021740005" ]},
		{"command":[ "SETCHARA", "0", "char_00007903_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ビシッ、とプールの中を指さす名探偵。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "しかし、敵はわらわらと……鳳雛の後方、リゾート入り口から普通に入ってき\nた。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「……あっ、あれぇ？　きょ、今日は少し調子悪かったかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_030021740006" ]},
		{"command":[ "SETCHARA", "0", "char_00007903_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いっそお前らしいよ名探偵！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人！　きゃつらが襲ってきますぞ！」　", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020021740001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「よ、よし！　いくぞ、決戦だ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "俺の掛け声を耳にするなり、待ってましたとばかりに女達が襲来者に攻撃をし\nかける。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「おーっしゃあ！　祭りだ祭りだ！　大暴れしてやるよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_040021740005" ]},
		{"command":[ "SETCHARA", "0", "char_00003404_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「Ω組の意地、見せるべき時が来たようですねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_030021740005" ]},
		{"command":[ "SETCHARA", "0", "char_00003303_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「ＥＤＯの本気を見せつけるぞ、行けるな！？　氷華！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_040021740003" ]},
		{"command":[ "SETCHARA", "0", "char_00004904_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「もちろんです。汚物を一掃してみせましょう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_030021740005" ]},
		{"command":[ "SETCHARA", "0", "char_00005003_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}