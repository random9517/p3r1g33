		{"command":[ "SETNAME", "Ａジュンジロー" ]},
		{"command":[ "SETTEXT", "「警備担当区域に到着。指示を待つ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_040104060001" ]},
	{"command":[ "SETCHARA", "0", "char_00000904_01", "0", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はいよ。……しかしこのメカ犬、どっかの駄犬よりよっぽど優秀だよなあ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「ふだん無口だから目立たないけどね。この惑星に来るまで、ワームホールを\nナビしてくれたし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010104060001" ]},
	{"command":[ "SETCHARA", "0", "char_00001201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ふん！　そのようなまがいもの、いくら高性能でもいずれ飽きます。やはり\nジュンジローはわたくし一匹。本家にしか出せぬ味が――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010104060001" ]},
	{"command":[ "SETCHARA", "0", "char_00000901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「……あの、皆さん？　お話の途中ですが、あれを……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010104060001" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "観客" ]},
		{"command":[ "SETTEXT", "「ブヒッ！　ブヒヒヒッ！　ボクちんの嫁たちを！　プリンセスを見せないと\nはどういうことでしゅか！　ブヒヒヒヒヒィ～！」", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "観客" ]},
		{"command":[ "SETTEXT", "「ちょっとだけ！　ちょっとだけプリンセスたちの靴をなめさせろぉおおお！\n　いや、せめて匂いだけでもぉおおおおおお！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "観客" ]},
		{"command":[ "SETTEXT", "「うぉおおおお～～～！　プリンセスを見せろ！　ローアングルで撮らせろぉ\n～～～～～！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「な、なんだいありゃ……すごい数だね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010104060001" ]},
	{"command":[ "SETCHARA", "0", "char_00000301_01", "3", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「入れなかった観客たちでしょう。どうやら、中に入れろと騒いでいるようで\n――あ！　バリケードが！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010104060001" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａジュンジロー" ]},
		{"command":[ "SETTEXT", "「ピピピピッ！　大会本部よりの指令を受信！　観客を阻止せよ！　もしくは\n、特別料金を徴収せよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_040104060002" ]},
	{"command":[ "SETCHARA", "0", "char_00000904_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「阻止ぃ！？　あんだけの数を、どうしろってんだ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａジュンジロー" ]},
		{"command":[ "SETTEXT", "「武器の使用を許可する！　繰り返す！　武器の使用を許可！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_040104060003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんじゃそりゃ！　やることがメチャクチャじゃねえか！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「メチャクチャはお互い様だ！　あいつらも体を張って試合を見ようとしてる\nんだ。だったら、こっちもガチで答えなきゃな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010104060001" ]},
	{"command":[ "SETCHARA", "0", "char_00000401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あああああ！　もう、どうなっても知らねえぞ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
	{"command":[ "EXIT" ]}
	]
