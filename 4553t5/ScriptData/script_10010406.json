		{"command":[ "SETNAME", "実況" ]},
		{"command":[ "SETTEXT", "「プリンセストーナメント第一次予選！　さきほどゴールしたシロクマ姫に続\nいて入ってきたのは――」", "NORMAL" ]},
	{"command":[ "DISPTEXT", "TRUE" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "実況" ]},
		{"command":[ "SETTEXT", "「ルナテミスとＡルナテミスの、Ｗルナテミスだぁーっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「だから！　Ｗ（ダブル）ルナテミスと呼ぶなー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010104060001" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
	{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「まあ、いいじゃないか。決勝で当たるまで、我々はＷ（ダブル）ルナテミス\nということにしておこう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090104060001" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「まったく……！　お前はどうしてそう無頓着なんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010104060002" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「今はそんなことより、予選を勝ち抜くことだ。それだけを考えよう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090104060002" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「せやで。あんたらに勝ち抜いてきてもらわんと、こっちゃ退屈でかなわんか\nらな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_128_010104060001" ]},
	{"command":[ "SETCHARA", "0", "char_00012801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「マグナシア！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010104060003" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「第一次予選突破、まずはおめでとさん、ってとこやな。その調子で、本戦ま\nで勝ち抜いてきてや」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_128_010104060002" ]},
	{"command":[ "SETCHARA", "0", "char_00012801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「本戦の試合で、ウチがあんたらをボッコボコに負かしたるから！　楽しみに\nしといてや！　ははははは！　あーっはっはっはぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_128_010104060003" ]},
	{"command":[ "SETCHARA", "0", "char_00012801_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「くっ……！　言わせておけば！　マグナシア！　貴様こそ今の言葉を後悔す\nるなよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010104060004" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「本戦で、大観衆の目の前で、貴様をリングに這いつくばらせてやる！　いい\nか！　必ずだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010104060005" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「ふっ……ふふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_128_010104060004" ]},
	{"command":[ "SETCHARA", "0", "char_00012801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そのときになって、ほえ面かくなよ！　マグナシアーーーーーッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010104060006" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「はははははは！　はーっはっはっはっは！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_128_010104060005" ]},
	{"command":[ "SETCHARA", "0", "char_00012801_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

