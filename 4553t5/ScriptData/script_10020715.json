{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0168" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "サメが消えたところに空間の裂け目が残された。", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「これが、園子さんのいた時間につながる穴かな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_020113820001" ]},
		{"command":[ "SETCHARA", "0", "char_00001802_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「多分、そうだと思います」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_070113820001" ]},
		{"command":[ "SETCHARA", "0", "char_00000607_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "俺には本当にそうなのかわからないが、入ってきた本人が言うのなら間違いな\nいだろう。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「短い間でしたが、ありがとうございました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_070113820002" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「園子ちゃん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040113820001" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「……未来でこんな素敵な仲間たちに出会えるのなら、ケバくなるのも悪くな\nいかなって思いました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_070113820003" ]},
		{"command":[ "SETCHARA", "0", "char_00000607_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「け、ケバくないわよぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040113820002" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「とくに、サメをおびき出すエサになってくれたカツマさん。ありがとうござ\nいます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_070113820004" ]},
		{"command":[ "SETCHARA", "0", "char_00000607_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いいっていいって。それに、ああいう役は俺じゃないと務まらないからな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「やはりご主人は根っからの苦労体質ですなぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113820001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うるせぇ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「別れを惜しむところ悪いのですけど、早くしないと時空の裂け目が閉じてし\nまいますよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_050113820001" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「そ、それじゃあ。皆さん、お元気で」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_070113820005" ]},
		{"command":[ "SETCHARA", "0", "char_00000607_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「あっ、待って園子ちゃん！　あのねっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040113820003" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "何か言おうとしたディアナの口を、園子の指がふさぐ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETCHARA", "0", "char_00000607_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「ディアナさん。未来が変わってしまうかもしれないので、言わないでくださ\nい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_070113820006" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「……うん、わかった。園子ちゃんがこれからいっぱい頑張るのは、未来の私\nが一番よく知ってるから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040113820004" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「だから……諦めないで」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040113820005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「はい、ありがとうございます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_070113820007" ]},
		{"command":[ "SETCHARA", "0", "char_00000607_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "園子は閉じかけている時空の裂け目に入って、過去へと戻っていく。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「行ってしまわれましたなぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113820002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああ、そうだな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ちょっと、寂しくなりますなぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113820003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "空間の裂け目は、閉じてしまえばそこには何も残らない。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "しかし俺たちには、一夜の出会いと別れ、サメとの激闘が記憶されている。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……頑張れよ、園子」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "俺はぽつりとつぶやいた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040113820006" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "5", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……どうした、ディアナ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「な、なんでもないのよっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040113820007" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "な、なに？　カツマちゃんにドキッとしちゃうなんて！", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040113820008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "もしかして、変なところでディアナちゃんの過去が変わっちゃったのかしら\n……？", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040113820009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0169" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_070113820008" ]},
		{"command":[ "SETCHARA", "0", "char_00000607_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "戻ってきた。あのときの、私の時代のトイレ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "sbg_0145" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「戻ってきたんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_070113820009" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "未来に行って、サメに襲われて、未来の私と、その仲間たちに助けてもらって\n……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「夢みたいな出来事だったわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_070113820010" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そう思って手を見ると、私の指に濃い色のリップがついていた。未来の私がつ\nけていた色だ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「今度のお給料で、新しい化粧品を買ってみようかな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_070113820011" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "もう少しだけ、このお仕事を頑張ろうと思った。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "STOPBGM" ]},
