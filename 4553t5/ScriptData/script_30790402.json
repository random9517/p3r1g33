		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「そうっ、またイクのっ、あひっ、オマンコイクからっ！　君のチン突き、す\nごすぎてっ……うくぅっ、まらイグっ……おぉぉっ、イグっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0404216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「はっ、あぁっ、はへぁっ……んんっ……！　でも、ただじゃイカないからっ\n♪　君のチンポ締め付けてっ……道連れぇっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0404217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「ほらっ、君の小鼻もぷっくり膨らんでっ……余裕……なくなってる……いい\nよっ、出してっ、いっぱいっ、ぴゅっぴゅしようっ、ねっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0404218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「あっ、あぁっ、そうっ、ラストスパートっ……♪　オマンコの中っ、めちゃ\nくちゃにされながらっ、射精のお手伝いしていくからっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0404219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「んぐっ……！　どこでもいいよっ！　君の好きなように……出してっ……僕\nもまたイクからっ、あっ、あぉぉっ、続けてっ、イクゥっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0404220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「んんんんんんんーーっ！　あぁっ……またっ、あふぁっ……な、なかぁ……\n２発目ぇぇっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0404301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00007904_02_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「あぉぉ……どぷどぷってぇ……君の白濁で満たされてるぅ……もう……止ま\nらない……あひぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0404302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「ふぁ……あぁ、もういっぱいになっちゃった……あふれる……んっ、お湯の\n中に混ざっちゃうよ……はふぅ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0404303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「んんっ……あぁ、まだ少し出続けてる……本当にすごいな、君は……呆れる\n位の煩悩の持ち主だ……でも、それがいい……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0404304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「あ……やっと、腰が落ち着いてきたね……はぁ……んふっ、うん……満足ぅ\n♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0404305" ]},
		{"command":[ "SETIMAGE", "0", "still_00007904_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「ありがとう、心も身体も……隅々まで君のお陰で満たされたよ……はふ……\n♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0404306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「あぁ、でも、もうちょっと離れるのは待ってくれないかな。こうして繋がっ\nたまま、深い余韻に浸っていたいんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0404307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「ふふ……その間に、またムラムラ来るのは勘弁してくれよ？　さしもの僕で\nも、ほんの少しは休まないと、腰がガクガクだからね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0404308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「えっ……少し休んだ後ならいいのかって……？　ふふっ、そうだねぇ……そ\nれは、君の方が僕をその気にさせるかどうか、かな♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0404309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「一回冷たい水を飲んでさっぱりして……そしたら、また燃え盛る展開……そ\nれは悪くないかもしれないね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0404310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},


		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「ひぁぁぁぁんっ！　あぁっ……チンポ……抜けてっ、あっ、顔に……おっぱ\nいにもっ……２発目……出てるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0404401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00007904_02_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「んぁ……はぷっ、内側だけじゃなく……外側まで……全部……君の色に染め\nられてる……あふぁ……全部……気持ちいい……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0404402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ……あぁ……この味だ……んっ、れろ……今日も健康そのものの、\n新鮮な精液……直接味わっちゃってるよ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0404403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「おっぱいにも……んっ、いいよ……どんどん出して……んふ……谷間にヌル\nヌルが混じって気持ちいい……湯船にちょっと残ってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0404404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「ふふ……そうだね、お湯は後でちゃんと綺麗にしておかないと怒られちゃう\nね……でも、今日はまだ貸し切りみたいなものだからさ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0404405" ]},
		{"command":[ "SETIMAGE", "0", "still_00007904_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「だから、もう遠慮しないで出し切っちゃおう♪　ほら……残ってる分……全\n部、ぶっ掛けて……あっ、ふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0404406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「んっ……はぁ、はぁ……はぁ……うん、終わったかな……？　僕のためにい\nっぱい動いてくれてありがとう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0404407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「とりあえず、一回上がろうか……もうお湯の中で派手に動いて……のぼせち\nゃいそうだよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0404408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「シャワーでさっぱりして、一休みして……さて、その後はどうしようか……\nふふっ、案外君もまだその気だったりするのかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0404409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「さて、どうしようかな……うん、夜はまだ長いしね……この火種がくすぶっ\nてるうちは、もうひとサカり……悪くないかもしれないね♪」", "NORMAL" ]},
