		{"command":[ "SETTEXT", "「やぁ、のんびりしている所に失礼するよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0404101" ]},
		{"command":[ "SETCHARA", "0", "char_00007904_01", "6", "CENTER", "0" ]},
