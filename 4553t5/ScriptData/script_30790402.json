		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「おっと、そこまで驚かせるつもりはなかったんだが、やはり美しい裸体を見\nてしまうと君も冷静ではいられないのかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0404102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「大丈夫、ちゃんと淑女の嗜みとして帽子は被っているからね。まあ、そう緊\n張しないでくれたまえよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0404103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「ふふ……そんな訳で正面にお邪魔するよ。まぁ、お邪魔したのは……ちゃん\nと理由があってね……聞いてくれるかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0404104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「まぁ、とは言っても……大体のところは君も見当がついているんじゃないの\nかな？　ここのところ……どうしても身体が疼いてしまってね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0404105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「だから、君の風呂の時間にかこつけて……せっかくだから……楽しい時間を\n過ごせたらと思ってね……という訳で……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0404106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「んっ……どうかな、見えるかい……？　僕の大切な場所……オマンコが綻ん\nでいるのが分かるんじゃないのかな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0404107" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00007904_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「どうかな……ふふっ、ここに思いっきり君のペニスを突っ込んでみたいって\n……そんな風に思わないかな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0404108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「ほら……もう勃起してきてるじゃないか。これは、僕の裸体に興奮して発情\nしている証だろう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0404109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「んっ……そうそう……そこが入り口だよ……そのままぐぐっと……中に……\nんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0404110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「っとと……上滑りしちゃったかな……？　もうちょっと下で、そのまま奥に\n……そこっ……んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0404111" ]},
		{"command":[ "SETIMAGE", "0", "still_00007904_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「お、おいおい……どうしたのさ。らしくないよ、こんな……んっ、続けて入\nれそびれるなんて……というか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0404112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「そうか……君は僕を焦らしてる訳だ……けど、このまま生殺しにするつもり\nじゃないだろうね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0404113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「つまり、その気にさせるようなおねだりをしろと……んぅっ……そういうこ\nとなんだね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0404114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「これだけ、勃起しておきながら、僕にいやらしいことを言わせたい一心で焦\nらすなんて……分かったよ、お願いだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0404115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「ほら……ここを見てよ……君の開発のお陰で、すっかりとスケベなことが好\nきになってしまった発情オ、マンコ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0404116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「ペニス……じゃない、チンポを……ずっと咥え込みたくて、ウズウズしてい\nるんだ……だから、早く……ハメて欲しい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0404117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「君の太くて固くて……ギチギチに勃起した、そのチンポで……ヌルヌル、ぐ\nちゅぐちゅの……恥ずかしいオマンコをめちゃくちゃにしてっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0404118" ]},
		{"command":[ "SETIMAGE", "0", "still_00007904_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「いっぱい奥を突いてっ……オマンコの中を、かき回してっ……そのまま、中\n出しっ……膣内射精して欲しいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0404119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「あっ、あぁぁぁぁんっ……♪　くぅぅっ……あっ、来て……くれたぁっ……\nあ、ひぃんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0404120" ]},
		{"command":[ "SETIMAGE", "0", "still_00007904_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「んくぅっ……ふぅぅっ、んっ……あぁっ、まずいよ、これは……あっ、思っ\nてた以上に……あっ、ひっ……きもちが……いいっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0404121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「あくぅっ……あぁぁ……嬉しい……んっ、あっ、あぉぉっ♪　太いっ……チ\nンポぉっ……オマンコっ、あっ、悦ぶぅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0404122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「はぁっ、湯船の中でっ……お湯がっ……一緒に入ってきてっ……あったかい\n中っ……硬いのっ、かき回されてぇっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0404123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「あっ、もっ、イクっ！　おふぅっ……すぐに達してしまう♪　おぉっ、おふ\nぁっ、オマンコっ……と、とろけるぅぅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0404124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「んぁっ、ふっ……もう達した……絶頂してしまったっ……あぁ、君の前では\n、何の小細工も通用しないっ……メスにさせられるぅ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0404125" ]},
		{"command":[ "SETIMAGE", "0", "still_00007904_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「けど、それが心地いい……♪　あぁぁ……もっとして欲しいっ、いやらしい\nチンポっ……中を、もっとぐりぐり動かしてぇっ、あっ、それぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0404126" ]},
		{"command":[ "SETIMAGE", "0", "still_00007904_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「はひっ、あひんっ、あぁっ、浅ましいメス声が漏れてしまうっ♪　こんな、\n足を広げた……淫乱ポーズを晒してっ、はしたないのにっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0404127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「けどっ、おぉっ♪　この、一突きがっ……あぉぉっ、どうしようもなく幸せ\nでっ、求めてしまうっ、そこぉっ、チンポもっとして欲しいっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0404128" ]},
		{"command":[ "SETIMAGE", "0", "still_00007904_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「んっ、ひっ、あっ、ひっ、だんだんっ、速くなってきてるっ♪　おぉっ、ぐ\nちゅぐちゅって……中の愛液っ、マ、マン汁っ、かき回されてぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0404129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「僕の奥から……こんこんと湧き上がって止まらないっ♪　あぁっ、逞しいチ\nンポをおもてなししたくてっ、オマンコの涎っ……止まらないっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0404130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「んくぅっ……いいよっ、もっと好きなように動いてくれて構わないっ。君の\n突き込みはっ……どこをされてもっ、感じるからぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0404131" ]},
		{"command":[ "SETIMAGE", "0", "still_00007904_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「あっ、あぉぉっ……そ、そうっ、特にっ……そこはっ、効くぅっ！　膣壁の\n中でもっ……一際、痺れる場所ぉっ、身体……跳ねるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0404132" ]},
		{"command":[ "SETIMAGE", "0", "still_00007904_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「あぁっ、揺れるっ……おっぱい揺らしてっ、メスアピールしてしまうっ♪　\nこんなの僕らしくないっ……けどっ、そんなことはどうでもいいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0404133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「今は……この、チンポピストンでっ……どこまでも堕ちてっ……君に浅まし\nいアクメを晒してしまうっ、はひぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0404134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「あぁっ、またっ、あぉっ、またもっと激しくぅっ！　射精に向けたチンポス\nパートっ……あぉぉっ、効くぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0404135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「あぁっ、このままだよっ……中に欲しいっ、熱い精液っ……直接っ……オマ\nンコに流し込んでっ……あっ、あぁぉっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0404136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「はひっ！　来たっ……出て来たぁっ♪　熱いのっ……びゅくびゅくっ♪　い\nっぱいっ、いっぱいっ……入って来るぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0404137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00007904_02_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「そうっ……これだぁっ……これを待っていたんだぁ……♪　はぁっ、絶頂オ\nマンコに染み込む子種汁ぅ……すごい……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0404138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「あふっ、はぁっ、あぁ……どくどくって……脈打ちながらぁ……いっぱい出\nてくるの……止まらない……んっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0404139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……あぁ……すごい感覚だった……風呂セックスは危ない……ハ\nマったら抜けられなくなりそうだ……あふぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0404140" ]},
		{"command":[ "SETIMAGE", "0", "still_00007904_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「んんっ……あぁ……まだ、オマンコの中で……君のチンポがみっちりと詰ま\nっているよ……んぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0404201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「これ……まだ終わる気はないって……そういう解釈でいいのかな……？　ん\nふっ……もちろん、僕に異論はないよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0404202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「もっともっと蕩け落ちさせて欲しい……♪　うん……僕のオマンコを徹底的\nに躾け直して欲しい……♪　あっ、はっ、んぁぁぁんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0404203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「あぁっ……これで、休憩はおしまいなんだね……んっ、ふっ、んくぅっ……\n抜かずの２回戦っ……始まりだぁっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0404204" ]},
		{"command":[ "SETIMAGE", "0", "still_00007904_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「あぉっ、ふっ、んんっ……もう……中出し済みだから……動く度に、ぐちゅ\nぐちゅって……いやらしい音が凄すぎるぅっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0404205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「いやらしい性器同士を擦れ合わせてっ、ケダモノ同然にサカる……このまぐ\nわいっ……あぁっ、理性なんかもういらないって……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0404206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「はぁっ、んんっ、自分でもらしくないことを口にしてしまうなんて……あっ\n、あぉっ、そこっ、今のとこっ……うんっ、ぐりぐりがいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0404207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「あひっ、あぁっ、ちょっとするだけでっ……もう、僕のオマンコの感じる所\nっ……全部知られちゃってるっ、くぅっ、腰がよじれるっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0404208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「あぁっ……逃げられないっ、んんっ、あふっ……どこまで行っても……チン\nポが追いかけて来てぇ……あ……んむっ、ちゅぷぅ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0404209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「んふぁ……こんら時に……キスまでするなんてぇ……君ってやつはぁ……ん\nっ、あぁっ、おっぱいも触られてるぅ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0404210" ]},
		{"command":[ "SETIMAGE", "0", "still_00007904_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「りゅぷっ、んんっ、ちゅぷっ、れるっ……欲しいとこ……全部してくれてる\nぅ……どこも気持ちよすぎてぇ……んはぁ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0404211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「んっ、あふっ、もう、なんでもいいっ……僕のことっ……好きなようにして\nいいからぁっ……もっと、もっと気持ちよくしてぇっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0404212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「んひぁっ、あっ、あぁっ……あぁんっ♪　肉壷が蠢くぅっ♪　君のチンポを\n求めて……勝手にオマンコがヒクヒクしてっ、あひっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0404213" ]},
		{"command":[ "SETIMAGE", "0", "still_00007904_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「何度も何度もっ……弱い所っ……突きまくられてぇっ、あひぁっ、ダメにな\nるっ、完全に君のチンポに屈服するぅっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0404214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「あぁっ、はぁぁっ……見てっ……僕が浅ましくよがってっ……はしたなくお\nっぱいを揺らしてっ、上り詰めていくところぉっ」", "NORMAL" ]},
