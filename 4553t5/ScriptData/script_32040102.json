		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「はァァアアア～？　今夜はまだ仕事が残ってる、だぁ？　バッカな事を言っ\nてんじゃないよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0104101" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「おまえが毎日毎日毎日！　あたしの身体をからかって……触って、いじりま\nわすもんだから……あたしは鬱憤溜まって発情中なんだよっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「とっととチンポを出しておっ勃たてなっての！　あン？　こーんな美女が抜\nいてやるって言ってるのに、断るなんてしないだろう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0104103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「ほらっ……♪　ほら、ほら、ほら♪　お尻フリフリ～♪　熟れた肉尻に、ト\nロットロに潤んだ極上のオマンコだよ……これが欲しいだろお？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0104104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「今すぐにチンポ突っ込んで、気持ちよくなりたいよねぇ？　男なら……あた\nしにむしゃぶりついてヘコヘコ腰を振りたいだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0104105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「……え？　ここまでさせて何もしないっていうのかい？　……ね、ねえ……\n。あたしが誘惑してあげてるんだよ？　見えるだろ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0104106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「充血して濡れそぼったオマンコさらしてさぁ、ウサギみたいにケツ振って誘\nってるのに……ほったらかし？　ど……どういうつもりだい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0104107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「……まさか本当に、このままってことはないよねぇ？　……ねえ……。した\nいんだよ。もう我慢できない……。交尾しようよぉ、隊長～……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0104108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「あたしのムッチリしたデカケツが好きだろお？　これっ……自由にしていい\nよ。ね？　乱暴にしてもいいから……チンポ入れてって。ねえ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0104109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「あ……♪　なーに？　その手は……。早くズボン下ろして、チンポ出してっ\nてぇ～♪　あたしの方なんか触んなくていいから……って、きゃあ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0104110" ]},
		{"command":[ "SETIMAGE", "0", "still_00020401_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「ひいいい！！　な、な、な、なんでスパンキング！？　ひ、人の尻を許可な\nくいきなり叩くだなんて……正気かい！？　ねえ！　ねえねえねえっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0104111" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00020401_02_04" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「っあっ！？　ああああぁんっ！？　なに……！？　なんだいっ！　この感覚\n……！　ああっ、ああ！　よしとくれよお尻が熱いぃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0104112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「あひっ！？　ひぃっ、ひィィっ……！　ひぃん！　ケツをぶたれてヨガるシ\nュミなんてあたしには無いって……。んん！？　あひっ！　ひぃいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0104113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「パンパンパンパン叩くなって言ってんだ、よぉ……！　あっ♪　あたしのケ\nツは……！　あひぃんんっ！　フツーの男じゃ手に出来ない上モノぉっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0104114" ]},
		{"command":[ "SETIMAGE", "0", "still_00020401_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「アッ！？　そ、それを……！　最上の美尻をやったらめったらバチバチ平手\n打ちするなんて……宝の持ち腐れ……！　あっ！？　あっあっあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0104115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「ひぃんんっ！　ひぃんっ！　いや、いやだよ……！　なんで、なんでオチン\nポ入れずにこんな、こと……あっ！　あっ、あたしはＭじゃないぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0104116" ]},
		{"command":[ "SETIMAGE", "0", "still_00020401_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「ドＳの女王様……。あっ！？　いやぁっ♪　いやっ、いやぁあ♪　ひぃいい\nっ♪　尻が、尻が燃える……燃えちゃうよ、いやっ、いやぁあ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0104117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「あ！　あ！　あ！　……な、なんだって？　ケツ叩かれて、あたしがマンコ\nから汁垂らしてるって？　じょ、冗談だろうっ……嘘だよね！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0104118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「感じるもんか、おまえのスパンキングなんかで……。んあッ！？　やめっ…\n…やめろぉっ、やめ……！　あっあっアッ！　いやああぁ♪♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「ご……ごめんなさい♪　わかりました！　わかりました……っ！　そ、そう\nです……あたし、お尻を叩かれて感じてます、感じてるからぁ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0104120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「ねえ……お願い、お願いぃ……！　ちゃんとオチンチン入れてぇ♪　もう準\n備出来てるの、おまんこが濡れて切ないよぉ……入れて、入れてぇえ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0104121" ]},
		{"command":[ "SETIMAGE", "0", "still_00020401_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「ンッ！？　はぁっ、うっ♪　んあああああああ♪　チンポぉおおお♪　チン\nポッ、チンポきたぁあああ♪　きたきたきた、チンポぉおおお♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0104122" ]},
		{"command":[ "SETIMAGE", "0", "still_00020401_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「あ～～～♪　あ～～～～、あ～～～～♪　キっくぅうう……♪　うん、うん\nっ、わかってるっ、これはチンポでの躾なんだろう？　わかるよっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0104123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「性の濁流で相手を無理やり屈服させて……！　はぁんん♪　チンポの力でエ\nロ奴隷に仕立てる最低の行為♪　でも、でも、これが気持ちいい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0104124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「あ～～っ♪　あぁああんっ♪　ぶっとくて、ゴリッゴリのカリ高チンポ……\n♪　こんなの食らって、マトモでいられる女はいないぃ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「あはっ♪　あはっ、も、もう……いいですぅ♪　あたしがＭで、ドマゾでい\nいです♪　だから……だからもっと味わわせて、チンポの味教えてっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0104126" ]},
		{"command":[ "SETIMAGE", "0", "still_00020401_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「突いて、突いて、突きまくって躾してぇ♪　あたしは悪くて、しつけのなっ\nてないバカ女王様♪　だからおまえのチンポで屈服させてぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0104127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「んっ……あっ、ああっ……ああ……♪　すっご……！　ンンンッ……おまえ\nのチンポって……デカイだけじゃなくてエッグい形、してる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0104128" ]},
		{"command":[ "SETIMAGE", "0", "still_00020401_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「それにむちゃくちゃ長くって……。はぁんんっ♪　少し突くだけで行き止ま\nり……子宮に突き刺さる……最高のオチンポだよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「あっ♪　あっ、あっ、あっ……も、もどかしいよ……！　狂ったみたいに腰\nっ、振りたいのに……チンポがデカすぎてうまく動けない……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「んん……ンッ、んん……！　あッ……♪　愛液、で……すべらせて……。あ\nああっ！　そうっ、そうっ、おまえが腰を揺らしてくれたら……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「ッああああああ♪　あああああっ♪　おぁあああ♪　あああああっ♪　す、\nごぉい……スゴぉい♪　これっ……たまんない、感じすぎるぅう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「あっ♪　あはぁっ♪　あぁッ♪　あっ……あぁんっ、あはぁんんっ♪　敏感\nな粘膜、一度にぜーんぶこすりあげてくるぅ……このデカマラぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「おまえの度を超したデカすぎチンポ、気持ち良すぎてどうかしてるよ……！\n　ッあぁああう……♪　あたしをチンポ狂いにする気だねっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「あっ、はぁっ♪　はぁっ、はぁあん……！　んん？　や、だ……。なんか、\n更にデカくなってきて……あっ、ちょっと！　もしかして……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0104135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「んっ！？　んっぐぅううううっ！？　ふぅうううう……ッ！？　な、生中出\nしィ……！　予告抜きでの傲慢種付けェ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0104136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00020401_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「んぉっ……！　ほぉおっ……♪　あっつッ……、熱いぃ……♪　あぁ……♪\n　もう、尻もオマンコも熱くってわけがわかんなくなってきた……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0104137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「ビュル、ビュルって腹ン中……オマンコの中に精液溜まってく感覚って何よ\nり強い快感だよ……！　あっ♪　あっ、まだ出てる……長い射精ぃ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「フフ、ウフフフ、ンフフフ……♪　めちゃくちゃたくさん出しまくってくれ\nたじゃないか……最強の子種……容赦なくドクドク～ってぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0104139" ]},
		{"command":[ "SETIMAGE", "0", "still_00020401_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「気持ちよさそうにありったけ注いでくれちゃってさぁ……。え？　い、イヤ\nじゃないよ。軽くアクメっただけ。ま、待って！　やめないで！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「ねえ……もう一度しておくれよ！　今度は尻を叩きながらさぁ！　あ、あた\nしのこと……オトナのオモチャみたいに扱って、雑に犯してほしいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0104201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「あんたのためになら……Ｍ女にでも奴隷にでもなんでもなるから……！　も\nう一回……！　あ、精子は拭かないで、このまま抜かないでもう一発」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「激しいのをナカにちょうだい……。ん……♪　んん♪　抜こうとしたって無\n駄だよ……。締めつけて離さない、意地でも勃起させてやる……ぅ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「あぁ……♪　ヌプッ、ヌプッ、ヌプッて……はじめはゆっくり……。だんだ\nんスピードをあげて……腰をくねらせて……。あ♪　あっあっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0104204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「やった……！　また大きくなってきたよ！　このまま続けていいよね……っ\n♪　ねえぶって♪　お尻ぶって、そしたらもっと締めつける♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0104205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「たくさんイッて、イキまくってさぁ♪　ヌルヌルの愛液とキッツいオマンコ\nで気持ち良くしてあげるから……。っあああああああんんっ！　あん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0104206" ]},
		{"command":[ "SETIMAGE", "0", "still_00020401_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「これっ、これだよぉおおっ！　バシン、バシン、バシンって……！　骨にま\nで響くスパンキングぅううっ！　お仕置き、お仕置き身に染みるぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「尻からアソコに、オマンコにも振動が伝わって気持ちいいいい……！　あぁ\n！　もっと！　もっと叩いて……たくさん犯してぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「ッあっ！　あひぃいっ、ひぃっ！　あひぃんんっ♪　あひっ、ぶひっ、ぶひ\nぃいっ♪　あふっ♪　イイっ、イイ、イイ、イイっ、イきそうぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「あぁんっ……！　イッく……イクぅっ、イクぅ……！　なんなのっ、なんな\nのよぉコレぇ……！　こんなの、こんなの初めて……っ、あぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0104210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「ぶたれ、ながら……スパンキングされながら挿入されて、ピストンされまく\nるのがこんなにイイなんて知らなかった……！　感じちゃうぅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0104211" ]},
		{"command":[ "SETIMAGE", "0", "still_00020401_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「あひ……！　ひィんっ！　ぶって♪　ぶってぶってぇ♪　そうなの、あたし\n悪い女王様なのぉ……！　お仕置きされるのがすごく好きなのぉっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0104212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「……あっ♪　アッ♪　あっ、あぁ……！　んひんッ！？　あぁ～～♪　はひ\nぃっ！　ひぃんっ、ひぃ……！スゴい、スゴぉいい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0104213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「下半身全部っ、隊長に支配されちゃってる……！　でもそれがいいのっ、赤\nく腫れあがった尻も……オマンコも、もうあたしのモノじゃなくなってっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0104214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「隊長……隊長のモノになってると思うと興奮する……！　んぁあっ……おま\nんこずっと気持ちいい♪　初めての快感……こんなのアリぃ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0104215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「あはぁんんっ……！　あぁ……隊長の腰が早くなってきた、準備してるんだ\nねっ……あたしのマン肉の奥に射精する準備……あっあっあっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0104216" ]},
		{"command":[ "SETIMAGE", "0", "still_00020401_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「も……もう一度射精したくなってきたんだろう？　も、もちろんいいよ……\n♪　だっておまえは、おまえはあたしのご主人様だからぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0104217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「ご主人様の出したい時に種付け♪　してください♪　あたしは……あたしは\n、精液を入れるための穴だから、ただの肉穴ですからぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0104218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「精液流し込むためだけのミルクポッドですぅう♪　ぶひぃいっ！　じょ、女\n王様のフリしてっ、最悪のドＭです、ドＭ嬢ですううう！　ひぃいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0104219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「おまんこで！　一滴残らず搾り取って飲み干します！　ちゅ、忠誠を誓いま\nすぅうう……！　出して、出して、注いで……お願いですっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0104220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「おふぅぁあああああぁああ♪　んふぁあああああ♪　おおおおぉっ♪　んぉ\nおおお～～～～ッ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0104301" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「あ、あ、ありがたき幸せぇ……♪　ドＭ女王に躾の精液注入ぅうう……！　\nあ、ありがとうございます、ありがとうございますご主人さまぁああ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0104302" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00020401_02_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「卑しきあたしに、……ああ♪　こんなにも熱くて新鮮なミルク♪　注いでく\nださってェエ♪　どぴゅ、どぴゅしてくださって感謝しますぅう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0104303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「あ、ああああ……子宮に何重にも精液が溜まっていくのがわかるゥ……♪　\nはぁあああ……♪　これ以上ない至福の時だよぉ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0104304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「んはぁああ♪　なんてことだよっ、まだ……まだ出てる……！　確実にあた\nしを孕ませにきてるっ、……最強のオチンポ様……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0104305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「はい！　はいっ、わかりました……孕みますぅ、孕みます……♪　極上チン\nポに屈服アクメキメて、じっくり受精させていただきます……ん～～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0104306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「ッあ……♪　はぁっ、はぁ、はぁ、はぁ……スゴ……かった、スゴかったぁ\nああ～～～♪　おまえ、調教師の免許でももってるってのかい！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0104307" ]},
		{"command":[ "SETIMAGE", "0", "still_00020401_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「あたしみたいな猛獣を、たった一度の交尾でおとなしくしつけてくれちゃっ\nてさぁ……天才だろっ、完全に……惚れた！　もうおまえしかいない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0104308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「ンフ、ンフフフ……♪　こりゃもう、次のおねだりは決まったようなもんだ\nよ♪　おまえの子種で受精着床は確実なんだ……。だから、ねぇ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「これからなんでもするからさぁ♪　あたしを隊長のオンナにして……♪　専\n用種付けペットにしておくれよね♪　待ってるよぉ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「……んはぁっ！？　な、なぜ……ッ、なぜ一番大事な瞬間にオチンポを抜い\nて……。あっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0104401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00020401_02_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「んぶっ！　んんん！？　何を……んん！？　め、眼鏡ェ……！？　うぷ……\n！　むせかえるようなオスの臭い、精液の香りぃい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0104402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「んはぁああ……、おまえが孕ませたかったのは、あたしよりもあたしの眼鏡\nだったってことか……。はぁ、はぁ、それはわかんなかったよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0104403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「はぁっ……♪　すっごい……♪　ご主人さまの精液がたらーって眼鏡にかか\nってる……♪　あっ、レンズがくもってる……あっつい精液だから♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0104404" ]},
		{"command":[ "SETIMAGE", "0", "still_00020401_02_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「ほかほかだよ……。ンフッ……♪　ホンットーにいやらしくて最高のご主人\n様だよね、隊長は……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0104405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「……見て？　隊長に抱かれた後のあたし……。まだ、ビクビク痙攣がおさま\nんなくて……全然動けない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0104406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「その上、大事な大事な眼鏡も、ドスケベマーキングされちゃってドロッドロ\nにされちゃった……。ンフフフ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0104407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「無敵の女王と呼ばれたあたしを、ここまでいいようにあしらえるんだから…\n…。隊長は性豪どころか、交尾の王様ね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0104408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「ううん、もしかしたらもーっとスゴいかも……♪　この星の神？　アハッ…\n…そのテクでオチない女なんてどこにもいないかも」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0104409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｏトーチャー" ]},
		{"command":[ "SETTEXT", "「そんな天才的な男に抱かれて幸せ……。だから、これっきりにはしないでね\n？　いつでも、準備して待ってるから……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0104410" ]},
