{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0147" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「喰らえぇい！！　『廬山失恋覇（ろざん　しつれん　は）』！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113870001" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「ぐわああああー！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113870001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あー……一瞬、良い勝負かな、と思ったんだが」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「逆転からの瞬殺、でしたなあ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113870001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ふ……あたしたちがこれまで流した涙の滝、あんたには昇ることさえできは\nしなかったな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113870002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「く……婚活に失敗し続けた恨みや無念が、ここまで強いものとは……がくっ\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113870002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "意味わからん。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0147" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ショルダーアーマーを身に纏いながら、なんて口ほどにもない。さて――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113870003" ]},
		{"command":[ "SETCHARA", "0", "char_00000311_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「それでは戦利品として、男は貰っていく」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113870004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "って、え？", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人。どうやら退路を断たれておりますぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113870002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「の、ようだな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "仲間なのか？　未だによくわからんが、あいつのチームメイトに取り囲まれて\nしまった……。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「っておい！？　触るな、持ち上げるなっ！？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「どうしてわたくしまで一緒に？　確かにこれでもオスのつもりでおりますが\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113870003" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "9", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「自分だけ逃げようとするんじゃねえ駄犬！　って、うわぁぁぁー……っ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「しっかり捕まえたね？　それじゃ、あばよ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113870005" ]},
		{"command":[ "SETCHARA", "0", "char_00000311_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0147" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「くっ……みすみす、目の前で、あいつを攫われてしまうとは……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113870003" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「いやー、でも考えようによっては、カツマくん一人の犠牲で丸く収まった感\nじ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020113870001" ]},
		{"command":[ "SETCHARA", "0", "char_00002202_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「であるな。闖入者は揃って立ち去った。球技大会に平穏が戻ったのである」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_020113870001" ]},
		{"command":[ "SETCHARA", "0", "char_00002002_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「い……いいの、かな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_020113870001" ]},
		{"command":[ "SETCHARA", "0", "char_00001802_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「攫ったのはエファナティカですし。特に心配する必要はないのです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_050113870001" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「あ、それもそっか。よくわかんねえ格好してたけど、エファはエファだもん\nな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_030113870001" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「攫われたのが学生で、相手が見知らぬ暴走集団だったら、ちょーっと責任問\n題が発生しちゃったりかもだけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020113870002" ]},
		{"command":[ "SETCHARA", "0", "char_00002202_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「特に問題はないのである。よって、この件は仕舞いである」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_020113870002" ]},
		{"command":[ "SETCHARA", "0", "char_00002002_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「く……貴様たち、追うつもりはないのか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113870004" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「だって暑いし～。ディアナちゃん、これ以上汗かくのはごめんよぉ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040113870001" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「カツマくん、不幸だ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_020113870002" ]},
		{"command":[ "SETCHARA", "0", "char_00001802_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「ずいぶんと楽しそうですね、あなたたち……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020113870001" ]},
		{"command":[ "SETCHARA", "0", "char_00002602_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "みんな" ]},
		{"command":[ "SETTEXT", "「ひいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_030113870002" ]},
		{"command":[ "SETCHARA", "2", "char_00000403_01", "3", "CENTER", "-600" ]},
		{"command":[ "SETCHARA", "1", "char_00002002_01", "3", "CENTER", "-200" ]},
		{"command":[ "SETCHARA", "0", "char_00002202_01", "3", "CENTER", "200" ]},
		{"command":[ "SETCHARA", "3", "char_00000505_01", "3", "CENTER", "600" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "DISPCHARA", "2", "TRUE" ]}, 
		{"command":[ "DISPCHARA", "3", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「この寒気……この威圧感……ばっちゃと同じか、それ以上の気だ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_030113870003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「学園長、本気でお怒りモードのようですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_050113870003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「球技大会を滅茶苦茶にされ、仲間を攫われるという醜態まで晒した……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020113870002" ]},
		{"command":[ "SETCHARA", "0", "char_00002602_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "DISPCHARA", "2", "FALSE" ]}, 
		{"command":[ "DISPCHARA", "3", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「居並ぶ観客、市民の皆様に、どう説明するつもりですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020113870003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「学園長も、ちょっと、煽ってたけどね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_020113870003" ]},
		{"command":[ "SETCHARA", "0", "char_00001802_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}