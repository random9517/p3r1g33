{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0101" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_011" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "そして、いろんな意味で辛く苦しい訓練の日々がようやく終わりを告げ、≪Ｂ\nＢ隊≫が任務につくことになった。その出発前……。", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「…………うん。いいな……！　皆、いい顔になった……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021400001" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "長官が隊員たちを整列させ、全員の顔を見回す。", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00005602_01", "7", "CENTER", "-600" ]},
		{"command":[ "SETCHARA", "1", "char_00005802_01", "7", "CENTER", "-200" ]},
		{"command":[ "SETCHARA", "2", "char_00006102_01", "7", "CENTER", "200" ]},
		{"command":[ "SETCHARA", "3", "char_00006402_01", "7", "CENTER", "600" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "DISPCHARA", "2", "TRUE" ]},
		{"command":[ "DISPCHARA", "3", "TRUE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「さすが、私の訓練を乗り越えた者たちだ！　面構えが違う！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021400002" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "DISPCHARA", "2", "FALSE" ]},
		{"command":[ "DISPCHARA", "3", "FALSE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そう言って長官は満足げにうなずき――", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「本日をもって貴様らは、ウジムシを卒業する！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021400003" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "隊員たち" ]},
		{"command":[ "SETTEXT", "「ありがとうございます、長官！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_010021400001" ]},
		{"command":[ "SETCHARA", "0", "char_00005602_01", "8", "CENTER", "-600" ]},
		{"command":[ "SETCHARA", "1", "char_00005802_01", "8", "CENTER", "-200" ]},
		{"command":[ "SETCHARA", "2", "char_00006102_01", "8", "CENTER", "200" ]},
		{"command":[ "SETCHARA", "3", "char_00006402_01", "8", "CENTER", "600" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "DISPCHARA", "2", "TRUE" ]},
		{"command":[ "DISPCHARA", "3", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うぉおお！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "な、なんだ！？　なんだ！？", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "全員、妙に力が入りまくってるぞ！？", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「本日から貴様らはビキニバズーカ隊員である。貴様らのくたばるその日まで\n、どこにいようと、ビキニバズーカ隊員は貴様らの姉妹だ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021400004" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "DISPCHARA", "2", "FALSE" ]},
		{"command":[ "DISPCHARA", "3", "FALSE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「これより我々は危険な任務へ向かう。ある者は二度と戻らないかもしれない\n。だが肝に銘じておけ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021400005" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ビキニバズーカ隊員は死ぬ。死ぬときは死ぬ。それはもう死ぬ。死ぬったら\n死ぬ。死ぬために我々は存在する」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021400006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「それでもビキニバズーカ隊は永遠である。つまり―――貴様らは永遠にビキ\nニバズーカ隊のお嬢さん、略して『ＢＢ嬢』である！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021400007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "その呼び方、なんかいかがわしいから却下！　とツッコミを入れそうになった\nが、他の隊員たちが、俺より早く反応した。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「長官……！　感動しましたっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_010021400002" ]},
		{"command":[ "SETCHARA", "0", "char_00005602_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ふぇええっ！？　感動！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「厳しくも暖かい長官のお言葉、決して忘れないっス！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_010021400002" ]},
		{"command":[ "SETCHARA", "0", "char_00006102_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「長官！　やります！　私たち、やりますよぉ～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_010021400002" ]},
		{"command":[ "SETCHARA", "0", "char_00006402_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「ふっ……安心しな、姉妹たち。あたしがいるかぎり、あんたらを死なせやし\nないよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_010021400002" ]},
		{"command":[ "SETCHARA", "0", "char_00005802_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「って、なにを盛り上がっちゃってんの！？　この人たち！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「では諸君、出撃だ！　ゴー！　ＢＢ嬢！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021400008" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "隊員たち" ]},
		{"command":[ "SETTEXT", "「ゴー！　ＢＢ嬢！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_010021400003" ]},
		{"command":[ "SETCHARA", "0", "char_00005602_01", "7", "CENTER", "-600" ]},
		{"command":[ "SETCHARA", "1", "char_00005802_01", "7", "CENTER", "-200" ]},
		{"command":[ "SETCHARA", "2", "char_00006102_01", "7", "CENTER", "200" ]},
		{"command":[ "SETCHARA", "3", "char_00006402_01", "7", "CENTER", "600" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "DISPCHARA", "2", "TRUE" ]},
		{"command":[ "DISPCHARA", "3", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "な、なんてこった……！　全員、いつの間にか洗脳されてる……あんなアホみ\nたいな訓練で――", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ゴー！　ＢＢ嬢！　ですぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021400001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "DISPCHARA", "2", "FALSE" ]},
		{"command":[ "DISPCHARA", "3", "FALSE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「って、おまえもかよ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「長いものには巻かれろ、偉い人にはゴマをすれ、人気クリエーターの新作と\n覇権アニメはほめちぎれ。それがわたくしの処世術です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021400002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「その処世術はわかるけどよ……でもこれ、本当に乗っかっても大丈夫な奴か\n！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "不安だ……限りなく不安だ……！", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}