{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0194" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「ハァ……ハァ……ううううう～～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_010023080001" ]},
		{"command":[ "SETCHARA", "0", "char_00026301_01", "4", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「暴れて少しは気が晴れましたか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023080001" ]},
		{"command":[ "SETCHARA", "0", "char_00000812_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「心なしか足下の雨雲が薄れてきたな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「ヴァルナ、いい子だからいいかげん機嫌を直してくれ。な？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_010023080001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「ううう～うるさいうるさいうるさいのです！！　私はまだお姉を許していな\nいのです！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_010023080002" ]},
		{"command":[ "SETCHARA", "0", "char_00026301_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「これは根が深いよなあ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「まあ、あんなことを言われれば無理もないですけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023080002" ]},
		{"command":[ "SETCHARA", "0", "char_00000812_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「だからごめんってば。今度ヴァルナの好きなエナドリ奢るからさ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_010023080002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「……足りないのです。私の心を癒やすには、エナドリとお菓子と最新ＰＣが\n必要なのです！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_010023080003" ]},
		{"command":[ "SETCHARA", "0", "char_00026301_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「え、えー……さすがにそれはお金が……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_010023080003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「どうでもいいけど、女神もエナドリ飲んだり金で買うんだな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「地上に来たら郷に従う感じじゃないですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023080003" ]},
		{"command":[ "SETCHARA", "0", "char_00000812_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「買ってくれないならお姉を許さないのですっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_010023080004" ]},
		{"command":[ "SETCHARA", "0", "char_00026301_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「その望み、ボクが叶えちゃいますよ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010023080001" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ジェスタ！？　なんでここに！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「今日はヴァルナちゃんの勧誘だよ～。ねえ、ヴァルナちゃん、時間帝国なら\nキミの望みを全部叶えられるよ～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010023080002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「全部……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_010023080005" ]},
		{"command":[ "SETCHARA", "0", "char_00026301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「うん。冷蔵庫には各種のエナドリは常備。お菓子も大体揃ってるし～、ない\nものも経費で注文可能！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010023080003" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「もちろん24時間いつでも食べ放題飲み放題で～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010023080004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「俺も行きたくなってきた」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「隊長が言うとシャレにならないからやめてください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023080004" ]},
		{"command":[ "SETCHARA", "0", "char_00000812_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「食べ放題……飲み放題……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_010023080006" ]},
		{"command":[ "SETCHARA", "0", "char_00026301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「しかも個室にはエアコン完備で、最新のゲーミングＰＣもあったり～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010023080005" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「行く！！　行くのです！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_010023080007" ]},
		{"command":[ "SETCHARA", "0", "char_00026301_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「はい一名様ご案内～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010023080006" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「ヴァルナ、待って！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_010023080004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「さすがに看過できねえ、ソレイユ、行くぞ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「隊長……それが、もうアグニさんに授けられた力の限界が……くあっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023080005" ]},
		{"command":[ "SETCHARA", "0", "char_00000812_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ふふ、さっきの戦闘でずいぶん体力を使ってたみたいだけど、今のキミたち\nにボクを倒せるかな～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010023080007" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ぐあっ！！　くそっ、待て、ヴァルナ、本当にそれでいいのか？　ＥＤＯに\nはアグニもいるんだぞ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「ＥＤＯは飲み放題食べ放題、最新ＰＣが揃ってるのですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_010023080008" ]},
		{"command":[ "SETCHARA", "0", "char_00026301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「そこで黙っちゃだめですよ隊長！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023080006" ]},
		{"command":[ "SETCHARA", "0", "char_00000812_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、だって」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「だってじゃないです！！　ああ、二人が行ってしまいます！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023080007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ふふふ、ボクからすればカツマくん、キミも勧誘したいところだけど、今日\nはヴァルナちゃんだけね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010023080008" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「それじゃあ、ごきげんよう。またね～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010023080009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「ヴァルナ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_010023080005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「お姉、じゃあね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_010023080009" ]},
		{"command":[ "SETCHARA", "0", "char_00026301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「ああ、行ってしまった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023080008" ]},
		{"command":[ "SETCHARA", "0", "char_00000812_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「さすがに分が悪い……しかたない、雨雲自体は晴れたんだ、帰還しよう」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0101" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「というわけで、今日から仲間に加わったアグニだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010023080001" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「アグニだ！！　カツマ、ソレイユ、改めてよろしく！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_010023080006" ]},
		{"command":[ "SETCHARA", "0", "char_00026401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まあそんな気はしていた」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「アグニさんはヴァルナさんを取り戻すためにですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023080009" ]},
		{"command":[ "SETCHARA", "0", "char_00000812_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「まあそうだな。あの子はあれで可愛い私の妹分だ。間違った道に進むのなら\n引き戻してやらなければ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_010023080007" ]},
		{"command":[ "SETCHARA", "0", "char_00026401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あいつがあっちに行ったの、わりと本気でアグニのせいな気もするが」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「ま、まあジェスタの勧誘が的確だったのもあるでしょう。あの環境を用意さ\nれれば……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023080010" ]},
		{"command":[ "SETCHARA", "0", "char_00000812_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まあ、逆らえないよな。正直、俺も心が揺らいだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ゴホン。ともかく、これからうまくやるように。そして早速だが任務だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010023080002" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ええ、長雨を終わらせてきた俺たちに休みもなくですか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「その長雨のせいでな……ＥＤＯ本部のあちこちが軋んで吹き飛びそうになっ\nたんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010023080003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「えー……そんなにヤバかったのか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「ヴァルナも神だからな。正直最後の豪雨があと少し続いていたら本気で崩壊\nしていたもしれない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_010023080008" ]},
		{"command":[ "SETCHARA", "0", "char_00026401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「それをやらせたのはアグニさんの一言ですけどね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023080011" ]},
		{"command":[ "SETCHARA", "0", "char_00000812_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「そんなわけだから、建物の補修を命じる。もちろん、三人共だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010023080004" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うへえ。やっぱり待遇はあっちの方がいいよなあ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「個室とエアコン完備は憧れますね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023080012" ]},
		{"command":[ "SETCHARA", "0", "char_00000812_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ええい、さっさと行かんか！！　減俸処分にするぞ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010023080005" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「やぶ蛇だった！！　しゃあない、ソレイユ、アグニ、行くぞ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「しょうがないですね、さっさと終わらせて休みましょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023080013" ]},
		{"command":[ "SETCHARA", "0", "char_00000812_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「二人とも、私とヴァルナのせいですまない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_010023080009" ]},
		{"command":[ "SETCHARA", "0", "char_00026401_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「んー。まあしゃあねえよ。ＥＤＯはこういうところだからな。やれることは\n皆でやるしかない」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「それにまあ、お前はソレイユを産みだしてくれてもいるし……ヴァルナのこ\nとは残念だったが、気に病むな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「ん……そうか。カツマ、君はそういう人か。ふふ、うん。わかった。ありが\nとう！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_010023080010" ]},
		{"command":[ "SETCHARA", "0", "char_00026401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「うーん、また隊長の毒牙にかかった人が一人」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023080014" ]},
		{"command":[ "SETCHARA", "0", "char_00000812_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
