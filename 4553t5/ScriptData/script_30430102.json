{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004301_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "PLAYVOICE", "043_0104101" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「っあぁ……。どうして今夜もまた……、私ではなく他の者を呼んで……。は\nぁ、はぁ、はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0104102" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「隊長さん、隊長さんは私の従僕であり新しい一族の一員のはず……。それ、\nなのに……最後の一線を超えてはくれない……。っ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0104103" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「なぜ……？　私の気持ちを試しているの？　それ、とも……私のことなどど\nうでも良くなってしまったのかしら……。ああ、寂しい、さび、しい……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0104104" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「あっ……！　あっ、ぁっあっ……。だめ……いけないとわかっているのに、\n品位が落ちる、のに……我慢できません……っ、あっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0104105" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「一人になる、と……隊長さんのことを考えて……。ああ……！　胸をいじっ\nたり、目を閉じ、て……あそこに触れてしまった、り……んんんっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0104106" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「あっ！　隊長、さん……隊長さん……っ！　抱いて、抱いて欲しいのです…\n…私を、抱き潰すくらい……めちゃくちゃに犯してぇ……あああっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004301_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0104107" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「はぁっ、あっ、あっあっ！　あっ……！　ああ……この指が隊長さんのもの\nなら、どんなにか……っ。あぁ、あぁ、ああ……す、好き、好き、好き……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0104108" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「指なんかじゃ足りない……っ！　ねえっ……ここ、この穴っ……貴方を想っ\nて濡れそぼったこの狭い肉穴に、もっと大きなものをちょうだいぃ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0104109" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「っ……んッ……んっ、ひっ、ひっぁっ、あっあっあっ……！　気持ちいい、\n気持ちいいのに……満たされなくて、あっ、辛い、辛いのです……っ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0104110" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「私の不器用な手では……あっ！　貴方のぬくもりには敵わない……。どれだ\nけ必死にクリッ、クリトリス、クリトリスを刺激して……もっ、んーっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0104111" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「溢れてくる愛液を、ゆ、指に塗りたくって肉穴に挿入……ぅうしても……ぉ\nっ、あっ！　処女膜の手前で、どうしても止めてしまうぅ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0104112" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「だって、だってだって……ぇえっ、私はじめては……破瓜はどうしても隊長\nさんがいいのっ、隊長さんの男性自身で、ここ、ここを破ってほしいっ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004301_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0104113" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「それで……それで、気を失うくらい愛してほしいっ、私のこと、押さえつけ\nて、圧倒的な体格差で……拒むことすらできないくら、い……ぃっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0104114" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「ガンガンに突きまくって、下剋上して欲しい……！　はぁ、はぁ、はぁ、隊\n長さん……隊長さん、切ないの……もういやぁ、イヤぁ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0104115" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「私のおまんこに隊長さんの逞しいおちんちんをくださいっ、入れて、入れて\n入れて……っ、あああっ、ずっと待っているのにぃ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0104116" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「……！　あっ……！？　えっ、えっ！？　た、隊長さん！？　う、嘘……！\n？　い、いつからそこにいたのですか！？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004301_02_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0104117" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「や、やだ……！　てっきり今夜は別の方と……！　えっ？　かなり前から…\n…。私がおまんこに指を差し入れる前から、ずっといた……のですか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0104118" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「あッ……！　あっ、こ、これっ……これ、は……。ああああ、ち、違うので\nす、少し寂しくて……！　で、ですから、あっ……あ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0104119" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「決して貴方を想ってオナニーなんて……。ああああ、うううう……。えっ！\n？　ど、どうして近づいてくるのです！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0104120" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「やっ……だ、だめっ、ダメッ！　今、下着をつけていないからっ……それに\n、あッ、あそこがっ、おまんこがぐちゅぐちゅで……って、んんんっ！？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004301_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0104121" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「どうしておちんちんを出すのですか！？　あッ……い、入れる、のですか…\n…？　まだキスもしていないのに、い、いきなり挿入を！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0104122" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「っ……や、ぁ……ああああ、だめ、だめ、だめ……！　したかったですけれ\nどっ、こんなムードのないレイプはダ、ダメ……あああああーっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0104123" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「やっ……あッ！　ああああっ！　はいっ……入っちゃいましたわ、ずぶって\n……！　あ、あ、簡単に……ぬるぅって……いやあああ……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004301_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0104124" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「は、初めて、初めてなのにこんな……！　自慰の最中に襲われて、なんて…\n…。高貴な私にふさわしくない初夜、ですのに……なのに……ぃい」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0104125" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「ど、どうしてこんなに気持ちがいいのぉおおっ……！　あーっ！　嘘っ、ウ\nソウソぉおお……！　おまんこ勝手に蠢いて、波打って……あーっ♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0104126" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「隊長さんの、隊長さんのおちんちん包みこんでますっ……！　自分からっ…\n…ぎゅーっぎゅーって絞りにいっちゃって……はしたないぃい……♪」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004301_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0104127" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「あッ♪　いやっっ♪　こんなはしたないＨおまんこ、私のおまんこではあり\nませんんっ……！　あっ、レイプ、レイプされているのに……ぃいっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0104128" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「あっんんんっ！　おちんちん入れられた、だけで……あっ！　ずっと軽くイ\nッちゃって……ぇえっ♪　なんて、なんて淫乱なダメおまんこなのっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0104129" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「はしたない、はしたなさすぎます……！　あっ！　いや……！　腰、が、勝\n手に動いちゃうぅ……勝手にお尻、揺らしておねだりしちゃうぅっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0104130" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「隊長、さ……隊長さん、隊長さん……あああっ！　し、したかったのですわ\n、私、貴方とＨ、したかったのです……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0104131" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「どうか、どうかお願いします……！　このまま、遠慮なくおまんこをズポズ\nポしてくださいまし……っ、も、もう、意識がずっとトんだままで……っ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0104132" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「その巨大なおちんぽで、私の濡れ濡れちびおまんこをほじくりまくって、種\n付けしてくださいっ！　早くっ、早く、早く……ううううっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0104133" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「えっ？　キツい？　すぐに一発目が出そう……？　ええ、ええ、いいのです\n、何度でも射精してください、このおまんこは隊長さんのもの、ですわ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004301_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0104134" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「だから……出してくださいっ、何度でも出してっ……、射精して私をイかせ\nて、もっと強く、深くイキたいの、隊長さんの精液でイキたいのぉっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0104135" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「んぁっ、あっおっおっあっあっあっ♪　しょ、初手からスパート、かけられ\n、て……ガン突きされて、射精、射精待ってますっ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004301_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0104136" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「私の赤ちゃんホールっ、隊長さんの特濃精子待ってますっ……、ああ、ああ\n出して、最初の一撃食らわせて、ぶちまけて……あーっ！　あーっあっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0104137" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「やっ、やだああああああ♪♪　本当に出しましたわねぇえっ♪　ああああっ\n！　ああっ！　おっ、おっあっ♪　あっあっ♪」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004301_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0104138" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「こ、これが膣内射精ぃいい……っ！　あーっ！　すっごいっ、すっごいぃっ\n……全部、一滴残らず私のオマンコに注入されて……ぇえ♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0104139" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「あーっ！　あっ、ああああ……！　美味しい♪　美味しいのですっ、もっと\n！　もっとくださいまし、私のお腹の中で、精子混ぜて、かき混ぜてっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0104140" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「一回出しただけでは満足しませんわよ……さあっ！　もっと突きなさい、犯\nしなさいぃい……このミルラを、孕ませるのですぅうう……っ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004301_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0104201" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「あーっ！　あーっあーっ！　ひゅ、ひゅごいぃい……！　お腹の、にゃか…\n…おまんこホールの奥、で……ムクムクムクって起ち上がって……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0104202" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「一度射精したのに、こんなにすぐ元気になるなんて……。さすがは私の選ん\nだ従僕っ……。わ、わたひの一族を継ぐにふさわしいっ、優れた男っ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0104203" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「なんて素敵な、強靭なおちんぽなのでしょう……。で、でも……少し、私の\nおまんこのサイズよりも大きすぎるような……気のせいでしょうか？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004301_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0104204" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「最初に挿入した時より、一度出してからの方が大きくなったような……。ア\nッ！？　これっ、これ、勘違いではありませんわよ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0104205" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「おっきっ……！　ほらっ！　私のお腹がポコッて膨らん、で……内側からゴ\nリュゴリュ亀頭が、肉竿が、私の膣粘膜を拡張、して……ひああああ♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0104206" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「あぁんっ！　あんっ、んっああ……どうしましょう、呼吸すら苦しくなって\n……っ、でも、これで、これでようやく……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0104207" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「本気の貴方に抱いていただけるのですわよね、あっ、情けなどいりません…\n…全力、で……犯して、犯して、犯してぇ……っ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0104208" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「あんっ！　壊れてしまってもいいの、私のっ……私のおまんこ、貴方の形に\nしてください、お、お願い、いたします……わ……んんんっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0104209" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「ああーっ！　あっ、あああーっ！　ひゅごい、ひゅごい、ひゅごいぃいい…\n…！　身体、アッ！　浮かされて……んああああっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004301_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0104210" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「一直線に貫かれ、てぇ……あああんっ！　腰がっ、腰がガクガク……っああ\nあああっ♪　ああああっ♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0104211" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「隊長ひゃんっ、隊長ひゃんんっ……！　わたくひ……私、し、幸せですわっ\n、しあわへ……あーっ！　あっあっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0104212" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「す、ごい、しゅごいぃ……！　おまんこがうねうね止まりませんのぉお……\n！　隊長さんにしがみ、ついて……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0104213" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「あっ！　ヌポヌポいってますっ、ヌチョヌチョ中で……膣内でこすれ、て…\n…ああああ、どうしましょう、どうしましょう気持ちいぃいい……ッ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004301_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0104214" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「あっああっ！　隊長さん、隊長ひゃん……わたくひの、わたくひの穴が、ぽ\nっかり空いてた穴が……隊長ひゃんで埋まって……嬉しいっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0104215" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「気持ちいいっ、気持ちいひっ……！　どうか、どうかこのままぁ……このま\nま精液をなすりつけてくだひゃい、わたくひのおまんこに……あんっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0104216" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「わたくひの赤ちゃんホールで気持ち良くなって、くだひゃい、一族っ……新\nしい一族っ、作って……つくって、つくってえええっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0104217" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「あっ！　あぁああ……もうダメ！　もうダメ！　イッちゃいますっ、私の指\nでは届かない深い場所を、隊長ひゃまがズンズン突き上げて……っ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0104218" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「あっ！　イッ……イキましゅっ、イキまひゅ、イキまひゅぅううっ！　あー\nっ！　頭の中で、おまんこでお星さまがキラキラ、キラキラ……っ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004301_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0104219" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「イッちゃいましゅうううっ……！　あーっ！　イッ……！　イくぅううっ！\n　イくっ、イくぅううっ！　あああああっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0104220" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「くぅ、ぅうう～～～っ！　おまんこ、おまんこ気持ちいいっ、おまんこ幸せ\nぇえええ～～～～っ！　隊長ひゃまぁああ～～！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},
		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "PLAYVOICE", "043_0104301" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「おっ！？　んぐっ……んんんっ！？　あっ……！？　ま、また、またおまん\nこの中に……一番奥に出てる、出てる、出てまひゅぅうう～～～っ！」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004301_02_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0104302" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「あっ……い、いやぁ……これ以上入れられてひまったらぁ……。お腹、お腹\nがぽっこり膨らんじゃいますわ……お下品です……ぅっ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004301_02_11" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0104303" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「あっ！　隊長ひゃん、しゅごい……。わ、かります、奥で……ビュルッ、ビ\nュルッと樹液が注がれていくのが……あっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0104304" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「これが命のほとばしり……。隊長さんの精液……遺伝子なのですわね……。\nあたたかい……満たされていきます……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0104305" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「……ん！　んんんんっ……！　私のちいちゃな子宮口を通り、過ぎていく…\n…。こじあけて子宮に飛び込んでいく、元気な子種……ぇ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0104306" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁ、はぁ、はぁ……。そうです……私はこれをずっと求めていた\nのです……。隊長さんからしか、受け取れないもの……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004301_02_10" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0104307" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「……ごちそうさまでしたわ。くすくす、そうです。真の姫たるもの、お礼は\nきちんとしておきませんと♪　それとも……そうですわね？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0104308" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「射精出来たのですから、隊長さんも気持ちが良かったのだとしたら……お互\nいに、互いを貪り、食らいあってお互いさまなのかもしれませんけれど」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0104309" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「それでも……ふふふ、やっぱり感謝を告げてしまいますわね。こうして膣内\n射精していただけたことで、私、実感していますもの」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0104310" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「……私はこの時のために……。貴方に抱いていただくために、ここにいて。\nそのために生まれたのだと……。本当に、ありがとうございます……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},
		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "PLAYVOICE", "043_0104401" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「あっ、あううううう～～っ、ああああっ！？　えっ！？　熱いっ……お股が\n……あっ、身体に熱い雫が……んんんっ！？」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004301_02_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0104402" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「あっ！　あっあっ！　お、驚かさないでくださいましっ！　わ、私……もし\nや絶頂と共におもらしをしてしまったのではないかと焦りましたわ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0104403" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「あ、貴方の……。隊長さんの精液だったのですね。でしたら問題は……。っ\nて、ああああああ～～～っ！！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004301_02_13" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0104404" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「な、何を勝手に、私に断りもなく外に出しているのですっ！　なんて愚かな\n従僕なのでしょうっ、し、し、信じられませんわっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004301_02_14" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0104405" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「せっかく新しい一族を……、あ、貴方の種で孕もうとしていましたのに！　\nんもうっ、もう、もうっ……！　また初めからやり直しですっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0104406" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「……ん？　もう既に一度放っているから許してほしい……ですってええっ！\n？　一見合理的な言い訳ですわね、……でもっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0104407" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「一度より二度！　膣内射精の回数が増せば増すほど、妊娠の確率もあがるの\nではなくて！？　それくらい、私にもわかりますっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0104408" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「ぷ～～～～～……。せっかく……せっかく、私のちぃちゃな子宮口を開いて\n、貴方を最奥へ……子宮へ誘ってさしあげていましたのに……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0104409" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「こ、この屈辱は……次回にはらしていただきますわよ。よくって！？　んも\nうっ、もうっもうっ！　ぷんぷんぷん！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0104410" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「……は、肌で精液を感じるのも……嫌いではありませんけれど……。でも…\n…。ううう、次は上手におやりなさい！　いいですわねっ！？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004301_02_13" ]},
