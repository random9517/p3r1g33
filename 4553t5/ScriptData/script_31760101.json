{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「我が盟友よ！　我を呼び出すとは、いったいどのような用件があるというの\nだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0103101" ]},
		{"command":[ "SETCHARA", "0", "char_00017601_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「ジェルスタン王国の王女ではあるが、我と汝の仲であるからな、なんでも申\nしてみるがよい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0103102" ]},
		{"command":[ "SETCHARA", "0", "char_00017601_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「……んぇっ！？　我に奉仕をして欲しいと！？　ほほほう、たしかになんで\nもとは言ったが大きくでたな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0103103" ]},
		{"command":[ "SETCHARA", "0", "char_00017601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「奉仕することでパワーアップも見込める？　なんだか都合のいい話だが……\nまあ、いいだろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0103104" ]},
		{"command":[ "SETCHARA", "0", "char_00017601_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「そ、それで……胸を？　んっ、こう……か……？　しっているぞ？　原住民\nは胸を使ってパイズリという奉仕をすると」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0103105" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00017601_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「え？　パイズリではない？　我にしかできない奉仕をしてもらう？　んぅっ\n！？　な、汝の魔槍（おちんぽ）が、我の蒼真珠（ちくび）に……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0103106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「んぅっ、そんなに蒼真珠（ちくび）に魔槍（おちんぽ）の切っ先（さきっぽ\n）をつきたてて……っ、あぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0103107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「んんっ、な、なにを……ぁんっ！　そんな、執拗に……んんっ、つんつんと\n切っ先（さきっぽ）で……ぁあんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「感じるのかって……んっ、当然、だろう……。盟友の、魔槍（おちんぽ）の\n放つ熱気を……すごく、感じている……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「んんっ、それで、いったいこれから……って、お、おい盟友！？　魔槍（お\nちんぽ）を蒼真珠（ちくび）に突き立てて、なにを……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「んくぅううっ！？　我の、蒼海を封じる宝珠（おっぱい）が、汝の魔槍（お\nちんぽ）に貫かれているぅっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0103111" ]},
		{"command":[ "SETIMAGE", "0", "still_00017601_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「お、おい、原住民はこんなむちゃくちゃなことをするのか！？　ああっ、本\n当に中に入ってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「み、見えるだろう……。汝の禍々しき魔槍（たくましいおちんぽ）が、中で\n暴れている……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「んぁっ、ああっ、あんまりビクビクとあばれさせるなっ！　ああっ、こんな\nことをされるのは……初めてで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「というか、盟友もおどろいているのではないのか？　本当に魔槍（おちんぽ\n）がここに入ってしまって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0103115" ]},
		{"command":[ "SETIMAGE", "0", "still_00017601_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「我の肉体は流水がごとく自在なのだから、これくらい当然だ。それにしても\n……妙な感じ、だ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「我が蒼海（おっぱいのなか）が魔槍（おちんぽ）によってぐりぐりとかき混\nぜられている……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「そのように波打たせ……んっ、ああっ！　身体の芯が、お、おかしくなりそ\nう……だ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「んっ、んっ、んく……ぅ……っ！　腰を振って、気持ちいいのか、この中と\nいうのは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「中……んっ、ああっ、ぬるぬるしている、か……。んんっ！　それはそうだ\nろう、我が粘液の中なのだから……んぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0103120" ]},
		{"command":[ "SETIMAGE", "0", "still_00017601_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「にしても……どうして……。んっ、ああ……こうして胸を好きにされている\nのに、身体が……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「全身の粘液が、ぞわぞわとしている……。ぞくぞくと、身体の中で粘液が反\n応してしまって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「魔槍（おちんぽ）に蒼海（おっぱいの中）をかき混ぜられて……んっ、ああ\n……感じて……る……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「はあ……はぁ……。こんな、熱くて……身体が蒸発しそうな熱を感じて……\nんっ、ああっ、ああ……つ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「わ、我が粘液の……身体は……んっ、ああっ！　ジェルスタンの、宝である\nはず……なのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「このように……んっ、くぅっ！　猛々しい魔槍（おちんぽ）を……受け入れ\nてしまって……んん……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「んなっ！？　わ、我の宝珠（おっぱい）が、深層（おまんこ）のようだって\n！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0103127" ]},
		{"command":[ "SETIMAGE", "0", "still_00017601_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「うぅっ、こんなことをしておきながら、そんな感想を……。そう思うのもむ\nりはないが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「だが、我が蒼海を封じる宝珠（おっぱい）は、そのような浅ましい器官など\nでは……んっ、ああぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「そ、そんな……奥……っ！　奥にまで、魔槍（おちんぽ）を突きたてて……\nんっ、腰……振って……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0103130" ]},
		{"command":[ "SETIMAGE", "0", "still_00017601_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「ああっ、ああっ！　胸っ、んっ、激しく……んぁっ、ああっ！　犯され……\nんひぃいいっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「魔槍（おちんぽ）の鼓動（びくびく）が、全身に伝播していく……っ！　ん\nくっ、んふぅっ！　はぁっ、はぁあんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「なんだ、このまま、我の中に子種を放とうというのか！？　んっ、ああっ！\n　そんな……正気か……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「ここは、本来精を放つべきところではないのに……っ！　ああっ、ああっ！\n　こらっ、話を……っ！　んっ、んんぅううううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「ああぁっ！　あああぁぁぁっ！　すごい……脈打って、精液が……っ！　お\nっぱいの中に流れ込んできてる……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0103135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017601_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「こ、こんなに……。はぁ……はぁ……。身体の中に放たれたものが、漂って\nいるのが、見えてしまっている……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0103136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……。これで満足か……？　というか、どうだったんだ、こん\nなところを犯して……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0103137" ]},
		{"command":[ "SETIMAGE", "0", "still_00017601_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「気持ちよかった……？　うぅ、意外な反応。盟友は変わっているな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「ま、まあ。ジェルスタン王国の王女だからな、我は。当然この身体の中も気\n持ちいいに決まっている！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「ふふん、どうした？　まだまだいきり勃ったままの魔槍（おちんぽ）が丸見\nえのままだぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「ああっ、んっ、んくぅっ！　また、我の宝珠（おっぱい）の中をかき回すよ\nうに……ンッ！　魔槍（おちんぽ）を動かして……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0103201" ]},
		{"command":[ "SETIMAGE", "0", "still_00017601_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「すごく……感じるぞ……っ！　ンッ！　ああんっ！　汝の。魔槍（おちんぽ\n）の猛りを……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「んん？　なんだ？　熱を感じているのかって、さっきからそう言っているで\nはないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0103203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「我々ジェルスタンの民は、自在に身体をかえることができるのだからな……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0103204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「……って、全身オマンコだと！？　ど、どうしてそういう破廉恥な発想にな\nる！　痴れ者っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0103205" ]},
		{"command":[ "SETIMAGE", "0", "still_00017601_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「ま、まあ……たしかに……。このようなところで魔槍（おちんぽ）を受け入\nれながら、昂ぶりを抑えきれずにいるが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「……んんぅっ！？　お、おいっ、急に腰を奥まで……っ！　ひゃぁあんっ！\n　ああっ、ああ……んぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0103207" ]},
		{"command":[ "SETIMAGE", "0", "still_00017601_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「宝珠（おっぱい）を激しくっ！　んぅううっ！　波打たせるように腰を打ち\nつけて……っ！　あっ、あっ、ああぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「ま、マンコおっぱいなら奥が感じるはずだ、だって！？　そ、そんなわけ…\n…んぅうっ！　あ、あるか……ぁ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「ああっ、ああっ！　んっ、んっ、んぅううっ！　んくっ、んふぅっ！　はぁ\nんっ！　ひゃっ、ひゃぁああぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0103210" ]},
		{"command":[ "SETIMAGE", "0", "still_00017601_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「魔槍（おちんぽ）の切っ先（さきっぽ）がっ！　アンッ！　我の、し、芯核\nの……近くに、まで……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「んぁあっ、ああっ、ああぁ……っ！　全身にっ、ンッ、魔槍（おちんぽ）か\nら発せられる魔の気（いやらしいの）が広がる……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0103212" ]},
		{"command":[ "SETIMAGE", "0", "still_00017601_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「あんっ、そんなに奥にっ、芯核の近くにまで……っ！　んっ、んんぅっ！　\nか、感じて、しまうから……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「ああっ、汝の魔槍（おちんぽ）に芯核が反応してっ！　んっ、全身に、甘き\n大波（エッチなきもち）が広がっていく……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0103214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「宝珠（おっぱい）の中っ、うねらせて……んぅっ！　汝の魔槍（おちんぽ）\nに奉仕してしまって……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0103215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「ああっ、我慢できない……っ！　我の身体が……爆ぜてしまいそうになって\nいる……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0103216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「汝も、また……辛そうであるな……？　んっ、射精を、しそうになっている\n……のだな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0103217" ]},
		{"command":[ "SETIMAGE", "0", "still_00017601_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「汝の放つ、子種汁を……わ、我の……宝珠（おっぱい）に向かって……っ！\n　ああっ、んっ、んっ、いいぞ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0103218" ]},
