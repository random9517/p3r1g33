		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「んぁあああぁぁぁっ！　ああっ、ああ……ああ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0103301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017601_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「また大量に、子種が我の体内に……っ！　んぅっ、んんんぅっ！　ビチビチ\nと、宝珠の大海（おっぱいのなか）を泳いでいる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「はぁああぁぁっ。身体の奥にまで、入ってくるのを感じる……ぅ……っ！　\nんんぅ……っ！　イクッ、イッくぅうううぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0103303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「んぅ……くぅ……。ふぅ……はぁ……ふぅ……。汝の魔槍（おちんぽ）から\nの子種……すっかり、体内に溶けてしまったぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0103304" ]},
		{"command":[ "SETIMAGE", "0", "still_00017601_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「こんなにたくさん……我の身体に取り込ませて……。んっ、なんだか変な気\n分だ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0103305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「ああ……もう……。汝ので……感じて……気持ちよくなってしまったではな\nいか……。はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0103306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「こんな感触、はじめてだ……。原住民は、こうやって性欲を発散し合うのだ\nな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0103307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「……え？　こんなことをするのは我にだけ？　ま、まあそうであろうなぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0103308" ]},
		{"command":[ "SETIMAGE", "0", "still_00017601_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「宝珠（おっぱい）の中に魔槍（おちんぽ）をつっこみたいなどと言うのは、\n汝だけだろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「ふふっ、ここが気に入ったのなら、また入れさせてやってもよいぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「んぅうっ！？　な、なんだっ、すごい勢いで……っ！　あっ、ああ……ああ\nぁぁっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0103401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017601_01_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「なっ、汝の精液が、勢いよく噴き上がって、我のこと、どろどろに……っ！\n　こんなに、こんなに勢いよく……っ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「原住民の射精というのは、こうもむちゃくちゃなものなのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0103403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「……えっ、そんなことはない？　気持ちよかったから、勢いよく射精してし\nまったと？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0103404" ]},
		{"command":[ "SETIMAGE", "0", "still_00017601_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「ほ、ほほう……。まあ、そうなってしまうのもむりはないな。なんせ、王女\nの宝珠（おっぱい）なのだからな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0103405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「汝も我慢できず、濃厚な子種汁をぶちまけてしまったのもうなずける。うん\nうん。苦しゅうないぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0103406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「ふふっ、どうやら汝は我の身体の虜になりかけているようだな。我が魅惑の\n粘液に囚われるがよい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0103407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「んんぅっ！　こ、こらっ、中で魔槍（おちんぽ）をあばれさせるなっ！　ん\nっ、ああんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0103408" ]},
		{"command":[ "SETIMAGE", "0", "still_00017601_01_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
