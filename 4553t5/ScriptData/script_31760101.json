		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「ああっ、ああっ、んっ、んっ、んんぅっ！　はぁっ、はぁっ、はぁ……っ！\n　こ、こい……こい……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_176_0103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スラヱ" ]},
		{"command":[ "SETTEXT", "「わ、我の胸に……いっぱい、いっぱい……射精して……っ！」", "NORMAL" ]},
