{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「や、やっと見つけたぞ……。お前はいつもフラフラと、どこにいるかわから\nぬのだから……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0104101" ]},
		{"command":[ "SETCHARA", "0", "char_00025801_01", "2", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「何か用事か、だと？　くっ……そ、それが……。我にも初めてのことでよく\nわからない、のだが。お前に開発させられてから身体が妙におかしいのだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「体温が上がったまま、興奮するとそれがいつまでもおさまらぬ。それどころ\nかどんどんひどくなってくる！　頭が朦朧として、息苦しくてかなわん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0104103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「……だが、こういったことはここでは珍しくないらしいではないか。開発後\nの発情状態……それを治療できるのはお前だけだと聞いて探していた！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0104104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「頼む。このままでは満足に戦うこともできん。なんとかできるのなら今すぐ\nやってくれ。……うむ。服を脱ぐのだな、それからどうすればいい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0104105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「う、くぅうっ……？　こ、この体勢は？　お前に背を向けて、尻を見せつけ\nて……。本当にこれが治療なのか？　とてもそうとは思えんが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0104106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00025801_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「っひぃっ！？　うひぃっ……つ、冷たい……！　お、おい、何をしている。\nまさか、我の尻の穴に何か塗っているのか？　答えろ！　っううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0104107" ]},
		{"command":[ "SETIMAGE", "0", "still_00025801_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「何？　不浄の穴である尻の穴にローションを塗りたくって、丁寧にマッサー\nジすることで身体全体が清められていく？　そんな話は聞いたことがない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0104108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「だが……。っふぅっ……んん……、確かに少し、火照りがやわらいできてい\nるような……。っううっ！　少しくすぐったい……。くぅっ、うう、うう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0104109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「んぁあっ♪　尻穴にローションを垂らすだけでなく、尻の肉まで揉んでいく\nのか。っひぅ……！　変な、気持ちだ、おかしな声が漏れてしまう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0104110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「っぁ……！　ああっ、くっ、くふぅうっ……！　んんんっ、ムチムチと臀部\nを揉みながら、親指と人差し指でネチネチ尻穴に雫を塗りこんで……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0104111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「ああっ♪　腸内にローションが注ぎ込まれていく……。そして、ジュワジュ\nワと熱くなってきた。我の身体の中の熱を発散させているのか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0104112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「はぁっ♪　あぁ、や、やめろ……！　ううっ♪　そんなところ……！　尻穴\nの粘膜なんてものをそんな風にいじられたことなどないのだ……ぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0104113" ]},
		{"command":[ "SETIMAGE", "0", "still_00025801_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「んひっ！　せめて優しくしてくれ、……うっ♪　指を入れるな……！　んぁ\nあっ！　ヌチヌチ指を出したり入れたり……だめだ、背筋が震えるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0104114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「んぁ～っああっ、あぁっ、ああああ……！　こ、これだけ尻の穴をもてあそ\nべば充分だろうっ、ムズムズする！　お前にここを触られると！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0104115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「ま、まるで尻の穴で感じているみたいではないか！　……あッ♪　な、なん\nだ？　チンポなんて出して。今度は身体の中からほぐしていく？　待て！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0104116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「あぁあああっ！？　くぅうう！？　くふぅううっ！？　う、嘘だろうっ！？\n　あぁッ！？　し、尻の穴にチンポを、チンポを入れてしまったのかぁ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0104117" ]},
		{"command":[ "SETIMAGE", "0", "still_00025801_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「む……無理だ！　無理っ、無理だああっ！　こんなに太いモノが尻の穴に全\nて入りきるわけがないだろうっ！？　あぁあ！　硬い、重い、熱いぃいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0104118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「あっ……うぁあああ……！　あぁっ、ロ、ローションのぬめりを利用して…\n…！　く、ぅ、ううう……！　長いチンポが腸内にもぐりこんでくるぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「あひっ……ひいいっ、んあっああああっ……！　い、いやだぁああ……！　\n尻の穴にチンポが入ってしまったぁあ……！　抜いてくれ、抜いてぇえ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0104120" ]},
		{"command":[ "SETIMAGE", "0", "still_00025801_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「尻の穴はチンポを入れる場所じゃないぃ……！　こんなことをしていたら我\nは変態になってしまうではないか！　あっ、なぜ、なぜやめぬぅう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0104121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「はぁうううっ、む、むしろ更に奥へと掘り進めてくるだと……！？　んくぅ\nうう……！　さ、さすがは我が見込んだ男……しかし、こればっかりは！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「んああっ！　腰を揺らすなぁ！　はぁっ♪　わ、我が感じているように見え\nる、だと！？　そんなはずは……！　はぅうっ、んううっ、うう！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0104123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「やめ……やめよ！　はぅああっ！　尻の穴、は弱いのだ！　自分が自分でな\nくなるっ、身体がバラバラになってしまう、チンポ止めてくれ、止めっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0104124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「うううううううっ！　激しく前後に抜き差しするなああああっ！　あぅああ\nあっ！　だめだ、このまま突かれていたら、我は……我はぁああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0104125" ]},
		{"command":[ "SETIMAGE", "0", "still_00025801_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「あうううううっ♪　……ち、ちがうぅっ、イッてなどいない！　尻の穴でイ\nクわけがないだろうっ……！　ああっ！　だから動かすなとぉおっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「あああああっ！　ああああああ～っ！　快楽が制御できない、なぜっ、なぜ\n我は尻の穴なんかでめちゃくちゃに……！　あうぁああああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0104127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「イッていないぃっ！　イッてなどいるものかあっ！　あぁっ！　んふぅっ！\n　我の尻の穴が、絶頂するたびに収縮している？　か、勘違い、だろうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0104128" ]},
		{"command":[ "SETIMAGE", "0", "still_00025801_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「悪魔筆頭騎士の弱点、が、尻の穴のわけがあるまいぃいっ！　あひぃっ♪　\nひぃいっ！　効かぬからっ、だからもう抜いてくれっ……あううっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「イクぅっ……！　悪魔なのに、尻の穴を突き上げられてイクぅううっ♪　あ\nうううっ、ロ、ローションのせい、だ、でなければ間違っているっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「尻の穴は交尾に使うものではないと言っただろう！　それなのにこんなに感\nじるのはおか、しい！　ローションが悪いのだ、我のせいではないぃいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「ああっ！　ああああっ！　どちゅどちゅ腸内を突かないでくれぇええ……！\n　くふぅうっ、汗が止まらない、オマンコから愛液も溢れ出してきているっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0104132" ]},
		{"command":[ "SETIMAGE", "0", "still_00025801_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「ああああっ！　尻の穴を孕ませようとするのは、やめ、るのだあああ！　あ\nあっ！　ああっ、勝手に尻の穴がヒクつく、チンポにまとわりついていく」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「我の尻は壊れてしまったのか！？　ああっ、ああっ、硬く大きなチンポでほ\nじくりまわされて……もう無理だ、イク……！　イキっぱなしになるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「んくぅうう！！　頼む、もう解放してくれぇ！　精液、精液出してチンポ、\nチンポ休ませてくれ……！　でないと尻の穴でするのが好きになる！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0104135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「お前の望むように！　尻の穴を締めるから、尻でチンポを締めつけるから…\n…出してくれ！　射精して、チンポ小さくしてくれぇえっ、早くぅうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0104136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「はぅううううううう……ッ！！　えぇ……！？　ああああっ、な、なんとい\nうことだ……！　尻の中で出されると精液が熱い、沸騰しているみたいだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0104137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00025801_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「あうううっ、ううううっ！　ドクドク、ドクドクと奥に……！　腸内に精液\nが広がってゆく……！　あああっ、熱い、それにべったり粘っていて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「我の、尻の穴が性器にされてしまっているぅ……！　んっ、そんなに大量に\n出されたら……ああああっ、我は何度でも絶頂して……！　ん～～～～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0104139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「ああっ、ああああっ！　尻の穴が言うことを聞かない！　勝手に精液を吸い\n上げて……！　っう……！　見ないで、見ないでくれぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「……ふーっ♪　ふーっ、ふぅうう……♪　よ、ようやく射精が終わったか…\n…。も、もう治療なんてどうでもいい、チンポが小さくなったら抜いてくれ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0104201" ]},
		{"command":[ "SETIMAGE", "0", "still_00025801_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「尻の穴にチンポを入れられるとあんな風にイキっぱなしになるだなんて知ら\nなかったんだ！　だからもうしない、まだ、まだ小さくならんのか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「……なんだ？　むしろ尻の中で、チンポが力を増しているような……？　へ\n？　ローションに精液が加わって、潤滑油が多くなって良い？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「ふ……ふざけるな！　お前が我の身を案じ、尻穴マッサージをしてくれてい\nるのはわかっている、だが！　……はぁ！？　今、なんと言ったのだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0104204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「これはマッサージではなくケツ穴アナルセックスだと！？　あっ……！　し\n、尻の穴で交尾させられていた？　最強の我が？　……こら！　ダメだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0104205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「尻の穴で子作りするのは、……あうっ！　よ、良くない！　……あうっ！　\n我の弱点を見つけた、だと？　だから徹底的に攻める？　……くううっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0104206" ]},
		{"command":[ "SETIMAGE", "0", "still_00025801_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「ひ、卑劣、らぞ……！　弱点と知りながらぁあ……っ、尻の穴をチンポで再\nびえぐる、とはぁ……っ♪　戦士の風上にもおけにゅ……！　くふぅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「せ、戦士じゃないから問題ないぃ……！？　ば、馬鹿者ぉおお……！　あッ\n♪　おっ♪　おほっ♪　おぉっ♪　尻の穴を掘るな、許可していにゃいぞぉ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「あぅううっ……♪　ううううっ、うう～～っ♪　うううう……ッ♪　これは\n尻の穴でするセックス……！　し、知らなかった、騙されていたぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「悔しいはず、なのに……っ、あっ！　あっ♪　果てしなく気持ちがいい……\nっ！　尻の穴を犯されて感じるなど、我は変態になってしまった……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0104210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「……おっ♪　な、なあ……っ！　お前、も気持ちいいのか……？　女の……\n悪魔筆頭騎士の尻の穴にチンポを入れると、どんな感じなのだ……っ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0104211" ]},
		{"command":[ "SETIMAGE", "0", "still_00025801_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「んんっ、入口、が……すぼまってチンポの根元にまとわりついて？　中はぬ\nらぬらとあやしくうごめいていて？　んぉっ♪　こうして突き上げると？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0104212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「我、が喘いで……見ていて楽しい……！？　あっ、ずっと中が痙攣していて\n……チンポがもぐりこんでくるのを歓迎してくれる……っ、そ、そんな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0104213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「我の尻の穴はチンポを入れられて悦んでいるのか！？　そんっ、な……あふ\nっ♪　あっ♪　我が自分から尻を股間に寄せている？　あああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0104214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「言わないでくれぇっ……！　ああっ、気持ち、いい……気持ちいいのだ、尻\nの穴を精液まみれのお前のチンポで突かれるのが気持ちいいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0104215" ]},
		{"command":[ "SETIMAGE", "0", "still_00025801_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「んぉおおおっ♪　おぉおっ♪　おほっ、おっおっ♪　んぉおおお……ッ♪　\nおぉおおっ！　もっと！　もっとくれぇ、尻の穴を犯してくれぇっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0104216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「はぁっ、あああっ……！　んあっ、ああああっ！　気持ちいい……ッ、ズボ\nズボ奥を突かれて……あぁっ！　もう、もう限界だ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0104217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「今度、は一番大きくイキそう……だ！　ああああっ、お前もぉ……お前も一\n緒に！　一緒にきてくれっ、もう、抵抗したりしないから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0104218" ]},
		{"command":[ "SETIMAGE", "0", "still_00025801_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「もう一度我の尻の穴に！　あの熱くてネバネバした精液を注入してほしい、\nどうなってもいい！　欲しいぃいっ、尻に、尻の穴に精液欲しいぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0104219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「はぁぁああっ♪　イクっ……イクぅううっ！　だ、め、だ完全に尻の穴でイ\nクようになってしまった！　責任を取ってお前もイケぇえええっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0104220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「うあああっああっ♪　ああああああッ！　精液で濡れた尻の穴に、また精液\nが……ッ♪　くふぅううっ♪　禁断の快感に、おぼれ、るぅうっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0104301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00025801_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「んあはぁッ♪　んあっ♪　んあぁっ♪　熱いチンポから、熱い精液が放たれ\nて……我の腸内がお前の精液で染まっていく、支配されていくぅうっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「こんなところにどれだけ出してもっ……♪　あぁっ、子を孕むことなどない\nというのに……！　完全に快楽のためだけに出す、なんて……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0104303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「んっ……♪　敏感になった腸内でチンポが震えて……♪　はぁっ、ああああ\n……♪　いいぞ、尻の穴で飲み干してやる……出るだけよこせぇえっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0104304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「ああっ、尻の入口を締めて……根こそぎチンポから精液を絞り出して……！\n　んんんぅっ、こんないやらしいことまで出来るようにされてしまった！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0104305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「悪魔筆頭騎士としては終わっている！　だが、それでも欲しいのだっ！　お\n前の精液で尻の穴が満たされていく、逆流しないように力をこめるぞぉっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0104306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「っんぷ……♪　す、少しでもみじろぎすれば尻の穴から精液が漏れ出してし\nまいそうだ……。腹がパンパンになっている……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0104307" ]},
		{"command":[ "SETIMAGE", "0", "still_00025801_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「何も食べていないのに、二回の射精を飲み干して満腹だぁ……♪　はぁ、は\nぁ……身体の火照りはまだおさまらない、が……♪　んんんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0104308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「嫌な感じはしない……。心まで満たされて、しまった。……あぁ♪　悪魔筆\n頭騎士のこの我が、尻の穴でイカされ続けて射精されて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「情けなくて恥ずかしいはずなのに、身体がどうしようもなく認めてしまって\nいる。はぁっ、尻の穴でするのは気持ちいい。どうしてくれるんだぁ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「おっ♪　おぉッ♪　あおおおっ、おぉ♪　イク、イク、尻の穴でイクぅうう\nっ……！　んんんっ、んふぅうっ♪　んん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0104401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00025801_02_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「……あぅっ！？　な、なぜ我の尻の穴がぽっかりと空いて空洞に……！　あ\nあっ、だめだ、一度目に射精された分がこぼれてしまう、いやだぁあっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0104402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「んひぃいい……♪　んううっ！　し、尻の肉と背中……。我の身体に精液を\n垂れ流して一体どうするつもりなのだぁああ……♪　あああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0104403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「腸内への中出しっ、尻の穴への直接注入を楽しみにしていたのに、ひどいぞ\n……！　あぅっ！　背中も、腰も熱い精液が流れて熱いぃいい……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0104404" ]},
		{"command":[ "SETIMAGE", "0", "still_00025801_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「わ……我の尻の穴の中でガチガチになっていた巨大なチンポが……次々に白\n濁とした精液を撃ちつけてくるぅ……♪　そんなに良かったのかぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0104405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「んぁっ！　お前が喜んでくれたなら嬉しいぞお！　だが……だが！　本当は\n腸内にもう一度出して欲しかった！　ドロドロを粘膜で感じたかったぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0104406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「ん……♪　んぁあああ……♪　尻の穴でするセックスなんて、ほんの少し前\nまで想像すらしたことがなかった我を、さんざんもてあそんでくれよって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0104407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「こ、このせいで我の尻の穴がガバガバになってしまったらどうするのだっ…\n…！　尻の穴でセックスする用の下品な穴になってしまったら……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0104408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「……それなら何度でも出来るから嬉しい？　そ……そういうものか。いいの\nだな？　我の尻の穴がお前のチンポを求めるように変わってしまっても？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0104409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「……うう……♪　いつまでも尻の中に快感の余韻が残って、何もかもうまく\n考えられない……。とんでもない身体にしてくれたものだ、まったく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_0104410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}