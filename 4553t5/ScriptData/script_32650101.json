{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「ああぁっ、たっ、隊長様！　お、お忙しいところ、お越しいただき、あっ、\nありがとうございまひゅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0103101" ]},
		{"command":[ "SETCHARA", "0", "char_00026501_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「お、落ち着けですか？　そうですね、ひぃ……ひぃ……ふぅ……。うぅ……\nすみません、今まではこんなことなかったんですけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0103102" ]},
		{"command":[ "SETCHARA", "0", "char_00026501_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「ここ最近、隊長様を見ていると胸が苦しくなってしまって……。こ、こうし\nて近くにいるだけで、今も……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0103103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「いえ、体調が悪いわけではないんです！　ただ……シャナはこの苦しさとい\nうか、せつなさがいったいなんなのか知りたくて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0103104" ]},
		{"command":[ "SETCHARA", "0", "char_00026501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「それに、これは本当に隊長様にしか相談できないのですが、最近シャナのお\nちんちんも、様子がおかしくて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0103105" ]},
		{"command":[ "SETCHARA", "0", "char_00026501_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「隊長様のことを想って、ドキドキしていると、おしっことは違う透明なもの\nが溢れてくるんです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0103106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「隊長様は、シャナと同じようになったことってありませんか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0103107" ]},
		{"command":[ "SETCHARA", "0", "char_00026501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「ある……んですか？　そんなとき、いったいどうしているのか、シャナにも\n教えてください！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「ふぇ……発散……？　お、おちんちんを触りながら、そのような気持ちを発\n散するといいんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「やり方を教えるから、服を脱げ……って、服を脱ぐのですか！？　わ、わか\nりました。恥ずかしいですが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0103110" ]},
		{"command":[ "SETCHARA", "0", "char_00026501_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「こう……でしょうか……？　股間を突きだして、おちんちんを、隊長様によ\nく見えるように……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0103111" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00026501_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「うぅ……。いま、シャナのおちんちんはおかしくなっています……。こんな\nに、硬くなってしまって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「それが普通、なのですか？　隊長様がそういうのなら……って、隊長様！？\n　隊長様まで裸にならずとも……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「オナニー……？　発散する方法のことをオナニーというのですね。それを、\nシャナに教えてくれると……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「あぅ……。あれが、隊長様のおちんちん……。シャナのと、大きさが全然違\nいます……ね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0103115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「でも、シャナと一緒で硬くなってます……。えっと……それから、おちんち\nんを握る……んですね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「んんぅっ！　か、硬くなっているおちんちんを握った瞬間に、腰に、ズキン\nとした刺激が……きて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……。それから、握った手を動かす……。おちんちんの根元か\nら、先っぽにむかって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「んんっ、あっ、んふぅ……っ！　はぁ、ふぅ……ンッ、あぅ……んふぅ……\nっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0103119" ]},
		{"command":[ "SETIMAGE", "0", "still_00026501_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「た、隊長様……っ！　シャナ、変な感じ……です……！　おちんちんが、と\nても……せつないと、いうかぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「そういうもの、なのですか……？　んぅ、ああ……っ！　おちんちんが、熱\nくなって……手が、汗ばんできて、ます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「隊長様は……？　すごい……おちんちんが、さっきよりも大きくなってます\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0103122" ]},
		{"command":[ "SETIMAGE", "0", "still_00026501_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「手の速度や、握る力加減をかえながら、おちんちんを刺激してやるといいの\nですか？　や、やって、みます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「んふぅっ、んっ、んんっ、あうっ、んっ、んく……ぅう……っ！　こうやっ\nて、おちんちんを……刺激、して……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁっ、隊長様……シャナのおちんちんも、だんだん膨らんできま\nした……んっ、あうぅ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「膨らむほど、どんどん……お、おちんちんの根元がくるしく……んくぅ、ふ\nぅ、ふぅ……はぁ……ああ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「この調子で、おちんちんをしごいてやれ……？　はい、わかりました。シャ\nナ……おちんちん、しごいて……みます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「んぅっ、くぅっ、ふぅ……っ！　はぁっ、はぁ……っ、んっ、くぅ……っ！\n　隊長様、み、見て……ください……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「この、お汁です……。シャナが……隊長を想って、せつなくなるとでてきて\nしまう、ぬるぬるとした、透明な……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「これ、おしっこではありませんよね？　さ、先走り……？　そういう、名前\nなのですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「ああ……隊長様のおちんちんからも、先走り、でてますね……。ああっ、こ\nのまま、もっともっと、手を……動かす……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「んひっ、いっ、いいっ、なんだか……へんな……っ！　おおっ、おちんちん\n……ビクビクして……んっ、くぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「ああっ、隊長様の手が、あんなに激しく……。シャナも、同じようにしてみ\nます……っ！　んぁあっ、ああぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「おっ、おちんちんがっ、痺れて……っ！　腰まで、跳ねてしまいますっ、ん\nぁっ、ああっ、隊長様っ、なにか……キそうで……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0103134" ]},
		{"command":[ "SETIMAGE", "0", "still_00026501_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「イク……イクという、感覚なのですね……！　はい、隊長様、シャナはイキ\nそうになってます……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0103135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「こみあげてくるの、へんな感じで……！　怖いのに、でも、手がとまらない\n……！　おちんちんが、い、イキたがってる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0103136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「た、隊長様……！　隊長様も、一緒、にぃ……！　はい……シャナも、シャ\nナもイキますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0103137" ]},
		{"command":[ "SETIMAGE", "0", "still_00026501_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「隊長様っ、イクッ、イクッ！　シャナも……シャナもおちんちんっ、いっ、\nいっ、イッくぅうううぅぅぅ～～～～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「あああぁぁぁ～～～～っ！　いっ、いいっ、いっぱい……！　この、熱いの\nが精液……！　隊長様の精液も、身体に、いっぱい……かけられてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0103139" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00026501_01_04" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……。シャナ……こんな気持ち、初めてです……。でも……ま\nだおちんちんが……。発散が足りないのでしょうか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0103140" ]},
		{"command":[ "SETIMAGE", "0", "still_00026501_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「そういうときは、もう一度するのですか？　なるほど、今度はシャナ、ひと\nりでやってみます……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0103201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「んっ、んん……あぁ……ふぅ……こうでしょうか……ンッ、くぅ……あふぅ\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0103202" ]},
		{"command":[ "SETIMAGE", "0", "still_00026501_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「おちんちん……精液で、ヌルヌルになって……んふぅっ、ああっ、先っぽに\nふれると、ジンジンします……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0103203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「んくっ、ふぅっ、隊長様も……おちんちんをしごいてるんですね……はぁ、\nはぁ、隊長様のも、まだまだ大きいまま……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0103204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「おちんちん……んんっ！　ここ、このでっぱったところも、指でこするとビ\nリビリって、します……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「こんな感覚はじめて……！　き、気持ちいい……？　たしかに、びっくりし\nましたけど、イヤな感じじゃない、です……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「おちんちん、気持ちいい……！　ああ、隊長様っ、おちんちん気持ちいいっ\nて思うと、もっともっと気持ちいいです……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「んんっ、ああっ、おちんちん、おちんちん……！　気持ちいい、とまらない\nっ、気持ちいいのが、どんどんおちんちんからきて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「頭の中が、いっぱいになりますっ！　おちんちんと、きもちいいことで、頭\nの中……破裂しちゃいそうです……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「んぁあっ、あっ、ああっ、もっと……ぬるぬるのおちんちん、激しく……し\nごく……んぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0103210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁっ、なんだかまた、おちんちんの奥がむずむずしてきちゃいま\nした……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「また、射精しそうになっている……そうかもしれません。射精って、そんな\nに何回もできるものなんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0103212" ]},
		{"command":[ "SETIMAGE", "0", "still_00026501_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「おちんちんをこうやっていじるの、すっきりするまでやった方がいい……。\n隊長様がそういうのなら、シャナ、もっと射精します……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁっ、んんぅっ！　んっ、んっ、んくっ！　あふぅっ、はぁっ、\nああっ、んっ、んはぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0103214" ]},
		{"command":[ "SETIMAGE", "0", "still_00026501_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「ぬるぬるの、おちんちんしごくぅ……っ！　ああっ、おちんちんがジンジン\n熱くてっ、頭の中もおかしくなりそう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0103215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「隊長様もっ、ますます手を激しく動かして、シャナと一緒で、隊長様も射精\nしそうになっているのですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0103216" ]},
		{"command":[ "SETIMAGE", "0", "still_00026501_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「はいっ、シャナも、隊長様が射精ときに、一緒に……！　お供しますっ、シ\nャナも隊長様と一緒に……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0103217" ]},
		{"command":[ "SETIMAGE", "0", "still_00026501_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「おちんちんから、いっぱい、精液をだしながらイキます……！　はぁっ、は\nぁっ、おちんちん……しごいてぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0103218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「ああっ、シャナまたっ、イキそう……さっきのような感覚が、またこみあげ\nてきて……はぁっ、はぁっ、隊長様ぁ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「隊長様っ、イクッ、イキます……！　隊長様も射精っ、シャナにむかって、\n隊長様の精液……くださいぃ……っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「ああぁあっ！　あはぁあああぁぁぁっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0103301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00026501_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「ああっ、ああ……っ！　また、いっぱい……シャナのおちんちんからも、隊\n長様のおちんちんからも……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「ドロドロの……精液が……。はぁ……はぁ……。身体に、たっくさんかかっ\nて……ます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0103303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「おちんちんがせつなくなったら、こうやって発散すればいいのですね……は\nふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0103304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「ああ、でも……なんだか……。うう、今になって考えてみると、隊長様にこ\nんな姿を見せたことが、急に恥ずかしく……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0103305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「ふぇ、よくあること、なんですか？　射精をすると、急に頭の中がすっきり\nして冷静になってしまう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0103306" ]},
		{"command":[ "SETIMAGE", "0", "still_00026501_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「たしかに、いまのシャナは隊長様のいう通りの状態だと思います。さすが隊\n長様。やはり隊長様に相談してよかったです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0103307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「これからは、ひとりでも隊長様のおちんちんを思い出しながら、自分のおち\nんちんをすっきりさせられると思います！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0103308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「え？　それはやめてほしいって、どういうことですか？　シャナは隊長様の\n手さばきをしっかり覚えましたので！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「これからも困ったことがおきたら相談させてくださいね、隊長様」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「あああぁぁぁ～～～～っ！！　ひやっ、せ、精液がぁっ！　んんっ、んぶっ\n、ううぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0103401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00026501_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁ……っ！　おちんちんからまた、すごい勢いで精液がでてくる\nなんて……。んぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「シャナの顔、自分の精液と隊長様の精液でドロドロになってしまいました…\n…はぁ……はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0103403" ]},
		{"command":[ "SETIMAGE", "0", "still_00026501_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「熱くて……ドロドロにされたのにぃ……。なんだか、ますます身体が火照る\nような感じ、です……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0103404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「はぁ……。こんなに……隊長様の精液の匂い……。すごく濃い……頭の中が\n真っ白になりそうです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0103405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「うぅ……。隊長様、シャナのおちんちん、まだまだ収まりません……。もっ\nともっと、発散しないといけないでしょうか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0103406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「隊長様の精液をかけられて、ますますおちんちんが硬くなったように感じま\nす……。シャナのおちんちん、どうなってるんでしょう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0103407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「気にせずこのまま、発散すればいい……ですか？　わかりました。またおち\nんちんを弄って、精液をだしてみます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0103408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「隊長様……その、シャナが収まるまで見ていてくれませんか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0103409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「シャナが上手に発散できるようになるまで、隊長様に、そばにいて欲しいで\nす……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0103410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
