		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0103302" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「や、やるじゃぁ……ないか！　二回目で、こんなに重い一撃くれやがって…\n…っ！　おっ♪　キクぅ……キクキクぅう……♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0103303" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「見てごらん……ッ、血桜お七の胸に、全力で中出しキメてくれて……。こん\nな度胸ある男は久方ぶりだ、大したタマだよ、隊長さんっ……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003301_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0103304" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「あぁ……、あぁああ……。こいつぁ、まだドプドプと、私の胸を汚してくれ\nてんのかい……？　最高だねぇ……いいよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0103305" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「玉の野郎が二、三日カラッカラに干上がるまでゆっくり出しな！　慌てるこ\nとはないよ……穴に染み込むくらいたっぷり出すんだよ……っ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003301_01_09" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0103306" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「はぁっ……はぁ、はぁ、はぁ……隊長さんの精子の匂いが……この肌に、入\nれ墨にまで塗り広げられるまで……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0103307" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「……好きなだけ……。ふふ、オスの傲慢な射精は好きさ。自分がオンナだっ\nてことを、孕まされるメスだってことを自覚させてくれる……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003301_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0103308" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「……私を弱い女だって、一瞬錯覚させてくれる。乙女だった頃に、生娘だっ\nたころに……連れ戻してくれる……。ふふ、ふふふ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0103309" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「………。隊長さん。隊長さんは、自分で思ってるよりずっと豪気で運の強い\nひとですよ。私にはわかります」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0103310" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「私に射精出来たくらいですから……もっと自信を持って、親玉の道ってのを\n、ひたすらひた走ってくださいねぇ……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},  
		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "PLAYVOICE", "033_0103401" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「んっ、ぁ……♪　あらあら……ぁ、も一度にひっかけるって寸法ですかぁ…\n…」", "NORMAL" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003301_01_11" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0103402" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「んーっ……♪　んんんっ♪　んー……♪　ああ……ザーメンシャワー……降\nり注ぐ白濁汁……健康で若くて、性欲の強い男の精液……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0103403" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「そいつをたっぷり顔に浴びると……自分まで若返ったような気分になってア\nガりますねぇ。あは、はは……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0103404" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「あ、あぁ……あああー……あぁ……。二回目とは思えないこの、滝のような\n射精といったら……。まさに男の中の男、惚れちまいそうだよ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0103405" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、はぁ、はぁ……。どうでした？　Ω組の組長の顔に……泥塗る\nどころかザーメンぬったくって……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0103406" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「組員に知られたら、指の一本二本じゃぁ済みませんよ？　もちろん、私を怒\nらせたのなら……腕や足じゃぁ終わらせません」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003301_01_10" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0103407" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「ですが……んぷ……。顔が重くなるようなこの精子の量、とんでもなくキツ\nい臭い……。黄ばんだベトッベトの白濁液……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003301_01_11" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0103408" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「こいつを気にいっちまったんで、無罪放免……気持ちよくお開きといきやし\nょうや。今日のことは隊長さんと私だけの秘密……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0103409" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「ふふ……うふふ……私の名にかけて、隊長さんとの秘密はお守りします。そ\nれなら安心でしょう……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0103410" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「酒の代わりに、精液で杯（さかずき）を交わしたとでも思っておきやしょう\n……それでいいですね？」", "NORMAL" ]},
