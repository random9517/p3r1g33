		{"command":[ "PLAYVOICE", "033_0103101" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「……この部屋には、どうにも嫌な気といいますか……。良くない空気がまと\nわりついているじゃあありませんか……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "2", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0103102" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「私も極道の女です……。ここに呼ばれた理由は察しているつもりですが……\n夜のお相手ということで、間違いありやせんね……？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0103103" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「……目が怖い？　これが素ですんで……。睨むな？　……真剣に向き合って\nいるつもりでいますが……？　なんですって……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0103104" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「『果し合いをしようってぇハラじゃない』……？　どういうことです、隊長\nさんは私をモノにしたい、あわよくば情婦（イロ）にしたいのでは？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0103105" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「……『ここで性交渉を行うことで、戦士としての力量が上がる仕組み』……\nへぇ……そいつぁ初耳です。……が……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0103106" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「隊長さんが悪意じゃぁない、私を見下してもいない、尊重するとお言葉だけ\nでもおっしゃっているうちは……殺し合いはやめておきやしょうか」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0103107" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「……それで。私に何をさせたいのです？　若い男の性欲\nの発散方法なんて、とんと想像がつきませんけど……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0103108" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「……胸での奉仕……。ああ、こういうことですか……貴方さまの猛る肉幹を\n……私の乳房で愛撫し、射精に導く……ええと……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0103109" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「今のハイカラな呼び方をすれば、パイズリ、というものですね。承知しまし\nた。それでは……始めましょう」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0103110" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「ふふふ……。これが、隊長さんのマラ肉ですか……。可愛い顔をなさって、\nかなりの逸物を股間に隠していらっしゃったご様子……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003301_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0103111" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「私の胸で挟みきれますやら……？　なんて……大丈夫なことは知っています\n。昔から、この胸だけは自慢でして……ほら」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0103112" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「これで何人もの男を泣かせてきたんですよ。……こう、やって……強引にた\nたみかけ……おマラ様をずっぽり胸の内に入れ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0103113" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「はぁっ……はぁ、驚く暇も与えずにっ……乳肉で暴力的に、一方的に、相手\nになすすべも与えずに……強姦のつもりでズるんです」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0103114" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「ずり、ずり、ずり、ずり……フフフ、他の女とは一味も二味も違うでしょう\n……？　サイズも、肉の厚みも、しとやかさも」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0103115" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「このなめらかでしっとりとした肌は……素人さんにはなかなかおりませんか\nら。さて、隊長さんはどれほどもつやら……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0103116" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「はっ、はっ、はっ、はぁっ……そぉら……いい子だ……私の胸に潰されて、\n可愛い悲鳴をあげておくれ……！　はぁっ、はぁ、はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0103117" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「男なんて、皆コレが好きで好きでたまらないんでしょう……？　このだらし\nない大きな胸……年増の女の艶っぽい胸が……フフ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0103118" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「こうして左右からぎゅーっと圧迫されて……それでズリッ……。ずりっ、ず\nりっ……おや？　もう、息が荒いのでは？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0103119" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「始めたばかりですよ……音を上げても、離れてなんてあげられませんね……\n。ずりっ……ズリッ、ズリッ、ズリッ……フフフフフ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0103120" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「そう……その顔ですよ。私に弱点を包まれて……はぁっ、情けなく喘ぐ男の\n顔……嗜虐心にメラメラ火がつきます……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003301_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0103121" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「もっと……もっと呻きなさい。もっと、悶えなさい。もっと……蕩けなさい\n。私に夜伽をまかせたことこそ運の尽き……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0103122" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「絶え間なく押し寄せる肉の快楽に……腰を抜かして抜け殻になるまで……。\nもう、止まりませんから……パイズリ。ふふふふ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0103123" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「ズリッ……♪　ズリッ、ズリッずりっ……♪　フフフ……ずりっ♪　ずりっ\n、ずりずりずりっ……♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0103124" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「あらあら。腰が上がってきましたよ？　おマラもビクビクと痙攣して……で\nも絶頂なんてそうそうさせません。ズリ、ズリ、ズリ……♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0103125" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「こうやって、強く根元を抑えられていると……イキたいのにイけなくてもど\nかしいですよね……？　私を穢して自由にするつもりで……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0103126" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「熟女のデカパイに操られているんだから不思議なものですよねぇ……？　ほ\nぉら、ずり、ずり、ずり、ずり……たぷんたぷん……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0103127" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「私の胸で、弄ばれて骨抜きになりたかったんでしょう……願いが叶って嬉し\nいですよねぇ……？　ほら。ほら、ほら、ほら……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0103128" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「ふふふふ……なんて可愛らしい声で鳴くんです。私をパワーアップ、させて\nくださるってお話でしたけど……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0103129" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「この程度で精液出しかけている隊長さんに……私に与える力なんて残ってい\nるんでしょうかねぇ……ずりっ♪　ずりっ♪　ずりっ♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0103130" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「あぁ、そうだ。どうせ射精出来なくしているんです。サービスして、口でも\n可愛がってさしあげましょう」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003301_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0103131" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「……ん、ぺろっ……ぺろっ、ぺろ……ちゅっ……ちゅっ……チロ……チロチ\nロチロ……チロチロチロ……っ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0103132" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「もっとしっかり咥えてほしい……？　極道の女のおしゃぶりが見たい……？\n　ご冗談を。これは焦らし、ですよ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003301_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0103133" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「ギリギリのギリギリ、際（きわ）の際まで相手を追い込んで、泣かせて楽し\nむ上級技です……ぺろっ……れろ、れろ、れる……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0103134" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「あぁ……いいですねぇ……これですよ。己の身体一つで、男を屈服させるこ\nの……この瞬間に一番興奮するんです。チロッ……♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0103135" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「チンコの先っちょペロペロされたくらいで、にっちもさっちもいかなくなっ\nて……気持ちいいでしょう？　ペロ、レロ、チロ、チロチロ……♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0103136" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「ふふ、うふふ……ふふふ……さぁて……まずは一回、出させてあげましょう\nか。当然、二回戦もいけるクチでしょう？　ぺろ、ぺろ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0103137" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「……隊長さんの射精のタイミングは私が決めます。流行の射精管理というや\nつですね……ふふ、さあ。一度目を出しなさい……。出すの、命令よ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0103138" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「一旦解放してあげ……って、あら……あらあら。壊れた蛇口みたいにびゅー\nびゅー……放物線を描いて、またびゅー……」", "NORMAL" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003301_01_04" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0103139" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "あらいやだ……どれだけ興奮なさっているんです。真っ白のゼリー状……とん\nでもない量が出てますよ。でも……まずはここで打ち止め」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0103140" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「本番はここからですよ……私のしつこさを、たーっぷり堪能して……誘った\nことを後悔なさるんですね。……再開です。ズリッ♪　ズリッ……♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0103201" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「ああ、いいですねぇ……。若いとすぐに回復して……柔らかいのは一瞬です\n。すぐに胸の中で硬度を取り、戻して……大きく」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003301_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0103202" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「どんどん育って……硬く太く……限界なんて知らないみたいに、簡単に膨れ\n上がって、反り返って……。金玉も精を作り始める」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0103203" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「上に立つお人っていうのはこうじゃぁなくちゃあ……さあさ\n、とっとと精液を補充しな。でないと追いつかないよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0103204" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「空打ちなんざしたくないだろう？　だったら精子……生成するんだよっ！　\nこの血桜お七が、自らパイズッてやってんだからねぇ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0103205" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「そらっ……そらっ！　そらっ……そらっ……！　隊長さんの生ぬるい精液で\n、私の胸もヌメりが良くなった……そら、わかるだろう？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0103206" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「滑りが良くなれば……快感は二倍にも、三倍にも乗算されてとどまるところ\nを知らなくなる……後は頭がおかしくなるまでズるまでよ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0103207" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「ズリッ……ずりっ、ずりっ……ズリッ！　ずりっ、ずりっ、ずりっズリっ…\n…あは……私は地獄行の急行列車に乗るのが好きでねぇ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0103208" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「生死の境を彷徨ってる時が一番……はぁっ、感じるんだ。乳房の毛穴が全部\n開いて、気持ちいいことしか考えられなくなって……んっ、んっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0103209" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「頭も手足も感覚なくして、チンポとマンコだけになる瞬間が最高なんだ。…\n…今の隊長さんなら嫌というほどわかるだろう？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0103210" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「私の胸マンコでチンポズられて天国と地獄を往復だ……。そーら、ズリっ、\nずりっ、ずりっ、ずりっ……目を白黒させて耐え抜きな……っ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0103211" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「その分最後は……天下一カッ飛んだ快楽に叩き落としてあげようじゃぁない\nですか……二度と戻れない、閻魔行きのパイズリさぁ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0103212" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「泡ぁ吹くまでカチコんであげやしょう……それ……っ！　それっ、隊長の好\nきな、だーい好きな胸ですよ……それっ、それぇ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0103213" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「獄門七重の顔中に、遺伝子ぶっかけておいて高飛びは無しですよ……。逃が\nすようなパイズリなんていたしませんのでねぇ……ほらっ、ほらっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0103214" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「あはは、はははは……イキたいかい？　イキたいねぇ……我慢しな……そし\nて感覚を研ぎ澄ますんだよっ、はははは……っ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0103215" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「このデカくて臭いだけのバカチンポにはもったいない極上の爆乳は……柔ら\nかいだろう？　まとわりついてくるだろう？　絡みついて……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0103216" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「蛇のように執拗に、獲物をカラッカラになるまで絞り切る……。ほら……ほ\nら、ほら……ほら……！　たっぷんたっぷんたっぷんたっぷんっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0103217" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「デカチチの頂点で、大きな乳首が踊ってるよっ……上下左右、隊長さんに欲\n情して……ぷっくり膨らんで訴えてるよ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0103218" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「隊長さんの元気な射精を見せて欲しいって……この私を、お七を凌駕し感嘆\nさせるほどの……粘っこくて重い精液が欲しいってさ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0103219" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「さあ、決めな。私のどこに出したいんだい？　もう一度顔か。この胸の穴か\n。顔に出すなら窒息させてみな。胸に出すなら膣内射精キメるつもりで……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003301_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0103220" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「命がけで精液ぶっぱなすんだよ！　いいねっ……！　迷ってる暇はないよ…\n…イキな！　覚悟見せなっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},
		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "PLAYVOICE", "033_0103301" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「んっおっおっおっ♪　おぉっ……おっ♪　おぉおおお♪」", "NORMAL" ]},
