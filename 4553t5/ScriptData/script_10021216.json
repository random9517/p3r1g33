{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0043" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「あら、ベルガマスクさん。いらっしゃ～い」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114620001" ]},
		{"command":[ "SETCHARA", "0", "char_00021202_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「……なんなんだこの店。なんでバスがスナックのママをやってるんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_020114620001" ]},
		{"command":[ "SETCHARA", "0", "char_00000702_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「だって私（わたくし）はみんなのＭ．Ａ．Ｍ．Ａだもの～。ここは『スナッ\nク停留所』。疲れた女幹部やヒーローの集まる場所よ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114620002" ]},
		{"command":[ "SETCHARA", "0", "char_00021202_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「疲れた女幹部かぁ……まぁ、たしかになぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_020114620002" ]},
		{"command":[ "SETCHARA", "0", "char_00000702_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「あら。どうかしたの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114620003" ]},
		{"command":[ "SETCHARA", "0", "char_00021202_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「なんというか最近、この格好でいると疲れてしまってな……たまには――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_020114620003" ]},
		{"command":[ "SETCHARA", "0", "char_00000702_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0043" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「こうして元の姿に戻らんと、腰のあたりがベキベキ言い出してあかんのじゃ\nよー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_040114620001" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「あらあらあら！　まあまあまあ！　ベルガマスクさんの正体は、ルナルバー\nス陛下でしたのね～！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114620004" ]},
		{"command":[ "SETCHARA", "0", "char_00021202_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「……無理に合わせてくれんでもいいぞ。どうせおぬしもわかっとったんじゃ\nろうが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_040114620002" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「……バレました？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114620005" ]},
		{"command":[ "SETCHARA", "0", "char_00021202_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「バレるに決まっとるわ。余の変装なみにバレバレじゃ。あの変装で気づかん\n者なぞ、ウチのアホ娘ぐらいじゃぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_040114620003" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「あー……そういえばルナちゃん、気づいてませんでしたねえ。でも、意外と\n他の子たちも気づいてなかったような……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114620006" ]},
		{"command":[ "SETCHARA", "0", "char_00021202_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「……類友ってヤツじゃな。まあええわ。Ｍ．Ａ．Ｍ．Ａ、焼酎お湯割り。梅\n干しも入れてくれんかの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_040114620004" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「は～い～。でもねえ、陛下。陛下はそう言うけど、ルナちゃん最近頑張って\nると思うわよ～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114620007" ]},
		{"command":[ "SETCHARA", "0", "char_00021202_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「そうかぁ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_040114620005" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「そうよぉ！　だってほら、今回の終盤なんか、こんな感じで！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114620008" ]},
		{"command":[ "SETCHARA", "0", "char_00021202_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ああ……確かにのう。あの子が、こんなに立派に覚醒してくれるとはのう…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_040114620006" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「でしょ～？　親の見てないところで、ルナちゃんだって成長してるのよ。こ\nの学園に来てから、いろいろあったし！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114620009" ]},
		{"command":[ "SETCHARA", "0", "char_00021202_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「そうじゃのう。この１年で、あの子なりにいろいろと学ぶところもあったの\nじゃろうなぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_040114620007" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「そうねえ……例えば勉強が嫌すぎて逃げ出して、夜の校舎で窓ガラス壊した\nり……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114620010" ]},
		{"command":[ "SETCHARA", "0", "char_00021202_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「カードゲームや戦車シミュレーションだの、おかしな遊びにうつつを抜かし\nたりのう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_040114620008" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「そうそう！　それから、球技大会で夜叉ちゃんに大迷惑をかけたり！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114620011" ]},
		{"command":[ "SETCHARA", "0", "char_00021202_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「学園祭では、演劇で校庭を破壊したりグルメコンテストでとんでもないカレ\nーをつくったり……って、あれ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_040114620009" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「あ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114620012" ]},
		{"command":[ "SETCHARA", "0", "char_00021202_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「なんということじゃ……まるで成長しておらぬ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_040114620010" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「……この話、やめましょうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114620013" ]},
		{"command":[ "SETCHARA", "0", "char_00021202_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「そうじゃな……っていうか、なんでおぬしがそんなにルナのやらかしに詳し\nいんじゃ！？　おぬしの初登場は９話じゃろうが！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_040114620011" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「まあまあ、細かいことはいいじゃない。はいこれ、サービスの柿ピーよ～？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114620014" ]},
		{"command":[ "SETCHARA", "0", "char_00021202_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「まったく……調子がええのう、おぬしは」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_040114620012" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「うふふ。だって私はみんなのＭ．Ａ．Ｍ．Ａですもの～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114620015" ]},
		{"command":[ "SETCHARA", "0", "char_00021202_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「Ｍ．Ａ．Ｍ．Ａは関係なかろう。しかしルナのヤツ……この先大丈夫かのう\n、先が思いやられるわい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_040114620013" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「そうねえ～。シーズン２も終盤に来て、時間帝国に刻の女王、そしてアナザ\nーなみなさんって、急展開だったものねえ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114620016" ]},
		{"command":[ "SETCHARA", "0", "char_00021202_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「メタ発言にためらいがなくなってきたな、おぬし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_040114620014" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「だって～。気になるんですもの～？　『悪の女幹部ペリジーニュームーン』\n、次のシーズンはどうなっちゃうのか～って！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114620017" ]},
		{"command":[ "SETCHARA", "0", "char_00021202_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「そうじゃのう。それはのう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_040114620015" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「それは……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114620018" ]},
		{"command":[ "SETCHARA", "0", "char_00021202_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「それは……プレイしてのお楽しみじゃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_040114620016" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}