{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010003_01_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ようやく目が覚めたか？　まったく……ここまで刺激してあげてるのに、随\n分と寝坊助だな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0303101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「なにをしているのかって……見ての通り、パイズリだよ。私のおっぱいで、\nおまえのペニスをシゴいてあげてるんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0303102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「逃げようとしてもムダだ。私のニンジュツで、動けないようにしてある」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0303103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「それにこれは、日頃の感謝を込めた私からのご褒美なんだ。素直に受け取っ\nても、バチは当たらないと思うぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0303104" ]},
		{"command":[ "SETIMAGE", "0", "still_00010003_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ご褒美をもらうようなことをしていない？　ふふっ。謙遜はいいことだが、\nやりすぎると卑屈と捉えられるぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0303105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「それとも……おまえはこうやって、ペニスをシゴかれるのは好きではないと\nでも？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0303106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「狼狽えた顔をしても、ペニスは正直だな。先端からエッチな汁を吹き出して\n……もっとシコシコして欲しいと訴えておる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0303107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「それにニオイも濃くなってきて……はあぁ……！　私も我慢できなくなって\nきてしまった……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0303108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ん？　どうした？　私が積極的にエッチなことをするのが、そんなに珍しい\nか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0303109" ]},
		{"command":[ "SETIMAGE", "0", "still_00010003_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふふっ。性欲をはじめとした、己の欲求に対し素直に従う……それが本来、\n人としてあるべき姿だ。理性なんてものは足枷にすぎん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0303110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「まあ、私は人であり猫でもあるせいか、普通の人間よりも性欲が強く、理性\nという足枷も簡単に外れてしまうみたいでな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0303111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「だからこうして、自分なりの楽しみを見出すことに、一切の疑問を持ってい\nない……気持ちいいことは、素晴らしいことだからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0303112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あまり長々と話ばかりしても、ペニスが苦しいだけだろう？　今はそのまま\n、快楽に身を任せろ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0303113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「私のおっぱいでこの勃起したペニスをいっぱい弄って、擦って、気持ちよく\nしてやる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0303114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふふっ。おまえは私の責めで快楽を感じ、だらしない顔を晒すといい。ほら\n、はじめるぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0303115" ]},
		{"command":[ "SETIMAGE", "0", "still_00010003_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あははっ！　軽く擦っただけなのに、我慢汁がたくさん溢れてくるぞ！　そ\nんなに私のおっぱいが気持ちいいのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0303116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「おっと、いくら気持ちいいからといって、勝手に動くことは許さないからな\n。おまえはあくまでも、私に責められる側だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0303117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「このペニスをいつ射精させるか……どれぐらい気持ちよくさせるかも、全て\n私次第だ。どうだ、嬉しいだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0303118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「そんなにペニスをビクビクさせてもムダだ。シゴく強さも速度も、私に決定\n権がある。ほら、じっくり感じさせてやるぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0303119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んっ……あっ、はああぁ……！　こうしてペニスの先端から出た汁を、いっ\nぱい塗りたくって……ゆっくりシゴけば……んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0303120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「カリの部分を、柔らかい胸でねっとりと刺激されるのは、たまらないだろう\n？　オトコはみな、快楽に弱い生き物だからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0303121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「亀頭だけでなく、竿も刺激して欲しいのか？　おまえも随分と欲求に対し、\n素直になってきたな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0303122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あっ、あぐっ、んんっ……あっ、あっ、はああぁ……！　オトコのニオイが\n、どんどん濃くなっていく……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0303123" ]},
		{"command":[ "SETIMAGE", "0", "still_00010003_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「メスを欲情させる、いやらしい香りだ……ほら、さっきよりも強くシコシコ\nしてやるから、もっと濃いニオイをペニスから漂わせろ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0303124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んっ……ふっ、ぐっ、んふっ……！　さらに大きく……熱くなっていってい\nるぞ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0303125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「シゴくたびにペニスだけでなく、口からもだらしない声を漏らしよって……\nいいオトコが台無しだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0303126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ほらっ、ほらっ！　そんなに気持ちいいなら、もっと声を出してヨガれ！　\nお前のだらしない顔を、もっと見せてみろ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0303127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ああぁ……！　その顔、その声……！　人の欲望と快楽が入り混じっていて\n、とても心地いいぞ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0303128" ]},
		{"command":[ "SETIMAGE", "0", "still_00010003_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「おまえのペニスがゾクゾクしているように、私の背筋もゾクゾクしている…\n…！　興奮でアソコが濡れてくるぞ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0303129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「もっと緩急をつけて、ペニスをシゴいてやる……！　安心しろ、痛くしたり\nはしない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0303130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「はっ、あっ、ふぐっ……！　あふっ、んっ……はぁ、あはぁ……！　いい、\nいいぞ……！　もっと乱れろ……！　欲望を解放しろ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0303131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「おっと、ペニスがビクビクしてきたな……！　表情から察するに、イキたく\nてたまらないみたいだな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0303132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「イキたいのなら、言うことがあるだろう？　今のおまえなら、私が説明せず\nとも理解できるだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0303133" ]},
		{"command":[ "SETIMAGE", "0", "still_00010003_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふふっ。先生、イかせてください、か……少し物足りない言葉だが、よしと\nしよう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0303134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ほら、イケ……！　イケ……！　おまえを気持ちよくしてくれているおっぱ\nいに、精液をぶっかけろ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0303135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んくうううぅ……！　あ、熱いのがこんなに……！　はぁ、ああぁ……！　\n欲望の塊がどんどん出て来る……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0303136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010003_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「情けなく射精し、精液を振りまく姿……！　くっ、あふっ、んんっ……！　\nた、たまらないな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0303137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ほら、まだ出せるだろう……！　ペニスの奥に残っているのも、全部吐き出\nすといい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0303138" ]},
		{"command":[ "SETIMAGE", "0", "still_00010003_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「一度出したのだから、遠慮なんていらないぞ。ペニスの赴くまま、欲望のま\nまに射精しろ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0303139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふぐっ、んはっ……あっ、ああぁ……！　またいっぱい、胸に出されて……\nんああああぁ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0303140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「随分と気持ちよさそうな顔をしているな……そんなに私のおっぱいが気持ち\nよかったのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0303201" ]},
		{"command":[ "SETIMAGE", "0", "still_00010003_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふふっ。そんなに首を縦に振って……その情けない姿を見ているだけで、私\nも心が満たされてるよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0303202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「だが、おまえの方はまだ満たされてないみたいだな。ペニスはガチガチに勃\n起したままで、まだ出したいと言っているみたいだぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0303203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「なに、遠慮することはない。おっぱいでシゴいて欲しいなら、好きなだけシ\nゴいてやる。欲望は吐き出してこそだからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0303204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「では、おまえのお望み通り、たっぷりと可愛がってやる。また私を満足させ\nてくれよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0303205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んっ、ふくっ……！　はぁ、あっ……あっ、あっ！　はああぁん……！　さ\nっき出したばかりの精子が、胸にこびりついて……んぐっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0303206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ぐちゅぐちゅと谷間でいやらしい音が鳴っているな……！　それに、擦るた\nびにエッチなニオイも立ち込めてくる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0303207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「我慢汁とは違った、精液特有の濃いニオイ……！　まるでマタタビを味わっ\nているみたいに、本能が拒むことを拒否してくるな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0303208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「だが、私は自分の欲求には素直なタイプでな……！　おまえにはつらいかも\n知れんが、もっとこの香りを吐き出してもらうぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0303209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふああぁ、あっ！　んひっ、くはあぁん……！　強く挟めば挟むほど、ペニ\nスの先端から新鮮な精液のニオイが……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0303210" ]},
		{"command":[ "SETIMAGE", "0", "still_00010003_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「はぁ、あああぁ……！　いい、いいぞ……！　もっと出せ……！　私が満足\nするまで、エッチなニオイを充満させろ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0303211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あははっ！　気持ちよすぎてつらそうだな！　だがここでやめてやる義理な\nどない！　おまえがどうなろうと、知ったことか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0303212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「気持ちよくしてもらえてるだけ、ありがたいと思え！　ほら、もっと強く挟\nんで、いやらしくおっぱいを動かしてやる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0303213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「全体にシゴきながら、おっぱいをぐにぐに動かすと、よりペニスが反応する\nな。この変則的な動きがいいということか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0303214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ならばこの気持ちよさを、極限まで味わうといい！　そして、エッチなニオ\nイを吐き出しまくれ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0303215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んむっ、んっ、はぁ、あああぁ……！　すうぅ……んっ、はああぁ……！　\n頭がクラクラするこの感じ……本当に素敵だ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0303216" ]},
		{"command":[ "SETIMAGE", "0", "still_00010003_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふふっ。おまえのペニスも、クラクラしてきてるみたいだな……！　射精さ\nせてくれと言わんばかりに、おっぱいの中で暴れているぞ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0303217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ここまで楽しませてくれたご褒美だ……！　おっぱいと顔、好きな方に出さ\nせてやる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0303218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
