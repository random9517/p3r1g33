{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0136" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「門番は思ったよりも大した相手ではなかったな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022610001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「あははっ、フルパのあたし達なら余裕余裕ーってね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_010022610001" ]},
		{"command":[ "SETCHARA", "0", "char_00017002_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「うぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_010022610001" ]},
		{"command":[ "SETCHARA", "0", "char_00016902_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「姉ちゃん、まだ慣れないの？　そこまで普段のカッコと変わんないし、結構\n、動きやすいと思うんだけどなー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_010022610002" ]},
		{"command":[ "SETCHARA", "0", "char_00017002_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「貴方はいいかも知れないけど、私のは激しく動くと……ず、ずれそうになる\nんですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_010022610002" ]},
		{"command":[ "SETCHARA", "0", "char_00016902_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「あー、まぁ確かに。でもちょっと位見えても仕方なく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_010022610003" ]},
		{"command":[ "SETCHARA", "0", "char_00017002_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「仕方なくありませんからっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_010022610003" ]},
		{"command":[ "SETCHARA", "0", "char_00016902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「しっ……ちょっと静かにしてくれ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010022610001" ]},
		{"command":[ "SETCHARA", "0", "char_00016703_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……ん……？　イグニス、どうしたんだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「前方に良からぬ気配がある。主殿も気をつけてくれ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010022610002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「前方に……気配……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「ほう……しっかりと殺気は断ったつもりでしたが、よくお気づきになりまし\nたね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090022610001" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「むぅっ、何者だ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022610002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「いずれ遺跡のどこかで相まみえると思っていましたが、予想していたよりは\n早かったですよ。くく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090022610002" ]},
		{"command":[ "SETCHARA", "0", "char_00000510_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「お前はっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022610003" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「オ……オボロっ……！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「おや、ウチの名前を知っているとは……くくっ、思わぬ所で有名になってし\nまいましたか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090022610003" ]},
		{"command":[ "SETCHARA", "0", "char_00000510_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「何だ、その変態みたいな格好は！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「はぁぁぁっ！？　あなた方にだけは言われたくないですが！？　特に、そこ\nの裸にマスクのあなただけにはっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090022610004" ]},
		{"command":[ "SETCHARA", "0", "char_00000510_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あ……い、いや、これはっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「確かにご主人が一番の変態仮面でしたな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022610001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「他の面々も揃いも揃って、はしたない格好をしてっ。どう考えてもそっちの\n方が変態でしょうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090022610005" ]},
		{"command":[ "SETCHARA", "0", "char_00000510_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「はぅっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_010022610004" ]},
		{"command":[ "SETCHARA", "0", "char_00016902_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「失礼なっ、私のどこが変態だというのだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022610004" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「まぁ、どっちもどっちって感じがするけどなー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_010022610004" ]},
		{"command":[ "SETCHARA", "0", "char_00017002_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「一緒にするなと言ってるですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090022610006" ]},
		{"command":[ "SETCHARA", "0", "char_00000510_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「やれやれ、何とも賑やかなことだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_030022610001" ]},
		{"command":[ "SETCHARA", "0", "char_00010007_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａウタマロ" ]},
		{"command":[ "SETTEXT", "「役者が揃って、少しは盛り上がって来たんじゃねーか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_030022610001" ]},
		{"command":[ "SETCHARA", "0", "char_00009704_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「うわっ、また新しい痴女二人！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_010022610005" ]},
		{"command":[ "SETCHARA", "0", "char_00017002_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ビキニを着ているだけで随分な言い草じゃないか。私達のこれは、この場に\n相応しい正装なんだがね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_030022610002" ]},
		{"command":[ "SETCHARA", "0", "char_00010007_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａウタマロ" ]},
		{"command":[ "SETTEXT", "「いい素材で出来た、特注品だぜ？　着こなしもバッチリだろ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_030022610002" ]},
		{"command":[ "SETCHARA", "0", "char_00009704_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「確かに。この中に入ることが出来るということは、正統なビキニアーマーと\nいうことだろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010022610003" ]},
		{"command":[ "SETCHARA", "0", "char_00016703_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「全員この状態だと、もう何が正しいのか分かったもんじゃねぇな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「とにかくっ……こんなビキニのことはどうだっていいのですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090022610007" ]},
		{"command":[ "SETCHARA", "0", "char_00000510_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「あなた方は、伝統の鎧とやらを探しているようですが、そうは行きません。\nウチたちがそれを頂きます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090022610008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「何だと……貴様、どこでそれをっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022610005" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「せいぜいそこで遊んでいるといいです。ニャンコ先生、ウタマロ、足止めを\nお願いします」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090022610009" ]},
		{"command":[ "SETCHARA", "0", "char_00000510_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふん、そろそろ一暴れしておきたい所だったからな。了解した」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_030022610003" ]},
		{"command":[ "SETCHARA", "0", "char_00010007_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａウタマロ" ]},
		{"command":[ "SETTEXT", "「それなりに楽しませてくれるといいけどねぇ？　雑魚だったら承知しないよ\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_030022610003" ]},
		{"command":[ "SETCHARA", "0", "char_00009704_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「上等っ！　ここはあたしと姉ちゃんに任せて、みんなは先に行って！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_010022610006" ]},
		{"command":[ "SETCHARA", "0", "char_00017002_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「うぅっ……こうなったらヤケですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_010022610005" ]},
		{"command":[ "SETCHARA", "0", "char_00016902_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「分かったっ、頼んだぞ、二人ともっ！　いきましょう、主殿っ、ルナテミス\n殿も一緒に！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010022610004" ]},
		{"command":[ "SETCHARA", "0", "char_00016703_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お、おぉっ、頑張れよミラ、ルシオラ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａウタマロ" ]},
		{"command":[ "SETTEXT", "「さて……おっぱじめようか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_030022610004" ]},
		{"command":[ "SETCHARA", "0", "char_00009704_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「見た限り、肉弾戦主体と、魔導を纏った二刀流使いか。なかなか面白そうな\n組み合わせだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_030022610004" ]},
		{"command":[ "SETCHARA", "0", "char_00010007_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「ふん、ニンジャってのは速さがウリなんだっけ？　しっかり捕まえてやんな\nいとね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_010022610007" ]},
		{"command":[ "SETCHARA", "0", "char_00017002_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａウタマロ" ]},
		{"command":[ "SETTEXT", "「ちちち……ニンジャじゃない。私たちは、ダークビキニンジャだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_030022610005" ]},
		{"command":[ "SETCHARA", "0", "char_00009704_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「ダ、ダーク……ビキニンジャ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_010022610006" ]},
		{"command":[ "SETCHARA", "0", "char_00016902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「主君の為に影に生きるのがニンジャの定め……だが、自らの欲望にも忠実な\nのが我々ダークビキニンジャだ。ふんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_030022610005" ]},
		{"command":[ "SETCHARA", "0", "char_00010007_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「きゃっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_010022610007" ]},
		{"command":[ "SETCHARA", "0", "char_00016902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａウタマロ" ]},
		{"command":[ "SETTEXT", "「私達を足止めするなんて大口叩いたからにゃあ、楽しませてくれよ！　うり\nゃぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_030022610006" ]},
		{"command":[ "SETCHARA", "0", "char_00009704_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「くぅっ……！　やっぱり……速いっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_010022610008" ]},
		{"command":[ "SETCHARA", "0", "char_00017002_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「ミラっ！　連携ですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_010022610008" ]},
		{"command":[ "SETCHARA", "0", "char_00016902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「おっけー！　はいやーーーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_010022610009" ]},
		{"command":[ "SETCHARA", "0", "char_00017002_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａウタマロ" ]},
		{"command":[ "SETTEXT", "「おっと……！　いい蹴りを出すじゃないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_030022610007" ]},
		{"command":[ "SETCHARA", "0", "char_00009704_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「まだまだっ……！　連撃っ……スターラッシュキーック！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_010022610010" ]},
		{"command":[ "SETCHARA", "0", "char_00017002_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「鋭い蹴りに、魔法弾が入り乱れて……なるほどこいつは面白いっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_030022610006" ]},
		{"command":[ "SETCHARA", "0", "char_00010007_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「はぁぁぁっ！　スティア・ディザイダー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_010022610009" ]},
		{"command":[ "SETCHARA", "0", "char_00016902_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａウタマロ" ]},
		{"command":[ "SETTEXT", "「うわぁっと、あぶなっ……！　やってくれるじゃんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_030022610008" ]},
		{"command":[ "SETCHARA", "0", "char_00009704_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「足止めなどと、甘えたことは言いません。この場であなた方を倒しますっ！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_010022610010" ]},
		{"command":[ "SETCHARA", "0", "char_00016902_01", "7", "CENTER", "0" ]},
