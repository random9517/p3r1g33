{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0101" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_011" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "そのころ、地球では……。", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「と、いうわけで。シャムちゃんとフィルちゃんは、無事ルナテミスさんと合\n流しました！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_010114470001" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「海賊団のみなさんは、時間城への強行突破を図るみたいです。ダイアンサス\nも作戦通り、海賊艦隊の支援にまわりまーす！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_010114470001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「わかった。よろしく頼む」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010114470001" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「カツマ隊長と翔生子さんは一緒にいないようで、そこが気がかりなんですが\n……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00019101_01", "0", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_191_010114470001" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「そちらにも、スクールガール・ミュータント・ニンジャラビッツたちを向か\nわせた。間もなく報告が入ると思う」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010114470002" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「そうですか。では、こちらも作戦に戻ります。以上、宇宙軍よりの報告でし\nた」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_010114470001" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ふう……どうやら宇宙組は、なんとかやっているようだな。それに引き換え\n、こちらは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010114470003" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「それが、まだ揉めていまして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_010114470001" ]},
		{"command":[ "SETCHARA", "0", "char_00006801_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「だから！　彼女たちは捕虜としてＥＤＯで尋問するべきでしょう！？　\nさっさとこちらへ引き渡しなさい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_020114470001" ]},
		{"command":[ "SETCHARA", "0", "char_00005002_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者リーダー" ]},
		{"command":[ "SETTEXT", "「ひいいいいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010114470001" ]},
		{"command":[ "SETCHARA", "0", "char_00015601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「ご、拷問とか研究とか、痛いことしないで～～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_010114470001" ]},
		{"command":[ "SETCHARA", "0", "char_00090201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「いーや！　こいつらはあたしに助けを求めた！　つまり、中立地帯の居酒屋\n・正義（まさよし）に助けを求めたんだ！　あたしが預かる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020114470001" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「あなたは今、正義（まさよし）の勤務時間外でしょう！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_020114470002" ]},
		{"command":[ "SETCHARA", "0", "char_00005002_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「そういう問題じゃねえ！　これは信義の問題ってヤツだ！　お七姐さんに言\nわせりゃ、仁義の問題でもある！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020114470002" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「た、助けてくださぁ～いっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_010114470001" ]},
		{"command":[ "SETCHARA", "0", "char_00090301_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「青い人も赤い人も怖いですぅ～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_010114470001" ]},
		{"command":[ "SETCHARA", "0", "char_00090401_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「この調子で、まるで決着が着きそうにありません……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_010114470002" ]},
		{"command":[ "SETCHARA", "0", "char_00006801_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「あーもう！　こいつらと来たら……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010114470005" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「ちょ、長官さん！　あなた、ここの責任者ですね！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_010114470002" ]},
		{"command":[ "SETCHARA", "0", "char_00090401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「お、お願いです！　助けてください！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_010114470002" ]},
		{"command":[ "SETCHARA", "0", "char_00090301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「わたしたちに痛いことしないよう、この人たちに言ってください！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_010114470002" ]},
		{"command":[ "SETCHARA", "0", "char_00090201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者リーダー" ]},
		{"command":[ "SETTEXT", "「どうか、なんとかしてください！　責任者としてーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010114470002" ]},
		{"command":[ "SETCHARA", "0", "char_00090101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「あんたらもか……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010114470006" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者リーダー" ]},
		{"command":[ "SETTEXT", "「へ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010114470003" ]},
		{"command":[ "SETCHARA", "0", "char_00015601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「あんたらも面倒なことは、ぜーんぶ私に投げりゃすむと思ってんのか！　\n私がＥＤＯの長官だからって！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010114470007" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「あ、あの？　えと？　あの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_010114470003" ]},
		{"command":[ "SETCHARA", "0", "char_00090201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「いーかげんにしろっつーのよ！　こっちだって忙しいのよ！　何でもかんで\nも、部下だの捕虜だのの尻ぬぐいできねえっつーの！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010114470008" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「ちょ、長官！　落ち着いて！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_010114470003" ]},
		{"command":[ "SETCHARA", "0", "char_00090301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「そ、そうです！　我々の世界では、ストレスはお肌によくないと言われてい\nます！　地球でもきっと――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_010114470003" ]},
		{"command":[ "SETCHARA", "0", "char_00090401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「うるせぇーっ！　肌荒れが怖くて、毎晩飲み歩いてられっか！　あー！　\nもういい！　もー、どーでもいい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010114470009" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0101" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「おーい！　酒だ酒！　誰か酒持ってこーい！　こんな仕事、素面でやってら\nんねー！　酒よこせ！　さけーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010114470010" ]},
		{"command":[ "SETCHARA", "0", "char_00004902_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「長官！　勤務中です！　気を静めてください！　長官ーーーーーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_010114470003" ]},
		{"command":[ "SETCHARA", "0", "char_00006801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者リーダー" ]},
		{"command":[ "SETTEXT", "「あ、あ、あああああああああ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010114470004" ]},
		{"command":[ "SETCHARA", "0", "char_00090101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「こ、怖いです、リーダー……！　この人、めっちゃ怖い……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_010114470004" ]},
		{"command":[ "SETCHARA", "0", "char_00090201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者リーダー" ]},
		{"command":[ "SETTEXT", "「わ、私も、こんな恐ろしい目にあったのは初めてだ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010114470005" ]},
		{"command":[ "SETCHARA", "0", "char_00090101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者たち" ]},
		{"command":[ "SETTEXT", "「地球人、めっちゃ怖ぇ～～～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010114470006" ]},
		{"command":[ "SETCHARA", "0", "char_00090101_01", "3", "CENTER", "-600" ]},
		{"command":[ "SETCHARA", "1", "char_00090201_01", "3", "CENTER", "-200" ]},
		{"command":[ "SETCHARA", "2", "char_00090301_01", "3", "CENTER", "200" ]},
		{"command":[ "SETCHARA", "3", "char_00090401_01", "3", "CENTER", "600" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "DISPCHARA", "2", "TRUE" ]}, 
		{"command":[ "DISPCHARA", "3", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「いや、こういう地球人はこの人だけですから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_010114470004" ]},
		{"command":[ "SETCHARA", "0", "char_00006801_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "DISPCHARA", "2", "FALSE" ]}, 
		{"command":[ "DISPCHARA", "3", "FALSE" ]}, 
