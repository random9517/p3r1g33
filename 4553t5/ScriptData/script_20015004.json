{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0041" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "二ヶ月後――。", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「貴梨果たちから会社の方向性が定まって、経営を立て直したから来て欲しい\nって言われたが……」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「そもそも立て直す前に、立ってすらいなかったような気がしますが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023340001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「言ってやるなよ。それで打ち上げというか、その商材が軌道に乗ったから慰\n問会みたいなのを開いてくれるんだと」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「つまりはご主人の大好きなタダ酒ですな。私としてはステーキなどあるとあ\nりがたいのですが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023340002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まあ、肉ぐらいはあるだろ……おっと、ここだ。看板は……ｓｕｃｃｕＢｉ\nのまま変わってないな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「経過報告とか聞いておられないので？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023340003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「任せきりで悪いとは思ったけど、あの後も仕事が山積みで、関われなかった\nんだよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「なるほど。まあ私も連絡できなかったので同じですが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023340004" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「じゃあ、入るぞ。お邪魔しま～す」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0195" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「いらっしゃいませ、カツマさん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_010023340001" ]},
		{"command":[ "SETCHARA", "0", "char_00026901_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「お久しぶりです……とはいっても二ヶ月ほどですが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_010023340001" ]},
		{"command":[ "SETCHARA", "0", "char_00027001_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「久しぶりだな、二人とも。会社も軌道に乗ったようでなによりだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「ええ。サキュバス派遣会社－ｓｕｃｃｕＢｉ－としてまずは順調な滑り出し\nとなりました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_010023340002" ]},
		{"command":[ "SETCHARA", "0", "char_00026901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……なんだって？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「ですから、サキュバス派遣会社です。私の力で女性を一時的にサキュバスに\n変化させ――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_010023340003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「私の力で男性の夢へとサキュバスを派遣し、日頃の溜まった鬱憤を晴らしつ\nつ、精気をいただいて健康になる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_010023340002" ]},
		{"command":[ "SETCHARA", "0", "char_00027001_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「一石二鳥の女性専用派遣会社ですわ。おかげさまで好評になっております」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_010023340004" ]},
		{"command":[ "SETCHARA", "0", "char_00026901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「それ、男の方に許可を取ってるのか……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「もちろんです。男性の方は登録だけしてもらっています。夢の中といえどサ\nキュバスの手管を味わえるとあって、こちらも好評ですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_010023340005" ]},
		{"command":[ "SETCHARA", "0", "char_00026901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「溜まっている男性も多いですからね。登録料をいただいて、お互いの欲望を\n解消する。ウィンウィンの商売です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_010023340003" ]},
		{"command":[ "SETCHARA", "0", "char_00027001_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「カツマさんが仰った、私たちのできることを商材に。つまり私の女性サキュ\nバス化と、魅白の夢への派遣能力」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_010023340006" ]},
		{"command":[ "SETCHARA", "0", "char_00026901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「その両方を最大限にシナジーさせた完璧なスキーム。それがｓｕｃｃｕＢｉ\nの業務です！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_010023340004" ]},
		{"command":[ "SETCHARA", "0", "char_00027001_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……なんか……なんかギリギリ不健全な気がする」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「いや、ばっちり不健全ではないでしょうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023340005" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「それもこれもカツマさんのおかげです。あなたの助言がなければ会社は潰れ\nていたでしょうから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_010023340007" ]},
		{"command":[ "SETCHARA", "0", "char_00026901_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「ですので、お礼として本日は夢ではなく、この現実でカツマさんにサキュバ\nスのご奉仕を味わってもらおうかと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_010023340005" ]},
		{"command":[ "SETCHARA", "0", "char_00027001_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「皆さんも、張り切って準備してくれていたんですよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_010023340008" ]},
		{"command":[ "SETCHARA", "0", "char_00026901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ん、皆さんって……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「こんにちはカツマさん～、ようこそｓｕｃｃｕＢｉへ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_020023340001" ]},
		{"command":[ "SETCHARA", "0", "char_00018204_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「ふふ……今日はたっぷりともてなしてさしあげますね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_020023340001" ]},
		{"command":[ "SETCHARA", "0", "char_00003304_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「サキュバスのご奉仕、たっぷりと味わってくださいな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020023340001" ]},
		{"command":[ "SETCHARA", "0", "char_00002605_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「こ……これは？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「なんというか、ビジュアルからもう色気が溢れだしておりますな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023340006" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「私の力で皆様をサキュバスに変化させました。うふふ、とっても魅力的でし\nょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_010023340009" ]},
		{"command":[ "SETCHARA", "0", "char_00026901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「た、確かに……いつものもいいけど、この姿もいいな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「あらカツマさんったら、お上手」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020023340002" ]},
		{"command":[ "SETCHARA", "0", "char_00002605_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「そんなこと言ってくれるなら、たっぷりサービスしてあげる～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_020023340002" ]},
		{"command":[ "SETCHARA", "0", "char_00018204_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「さあさあカツマさん、まずこちらへ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_010023340010" ]},
		{"command":[ "SETCHARA", "0", "char_00026901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「ジュンジローさんも隣へどうぞ。今日は私たち全員でおもてなししますから\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_010023340006" ]},
		{"command":[ "SETCHARA", "0", "char_00027001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「相変わらずいい身体をしてますねえ。今日は隊長さんへのお礼と私へのお礼\n、両方ですから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_020023340002" ]},
		{"command":[ "SETCHARA", "0", "char_00003304_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「とりあえず、一杯どうぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020023340003" ]},
		{"command":[ "SETCHARA", "0", "char_00002605_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お……おう。なんか、そういう店に入ったような……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「ふふ、あながち間違いじゃないですね。だから隊長さんはなにも考えず、サ\nキュバスのご奉仕を堪能してくれればいいんですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_020023340003" ]},
		{"command":[ "SETCHARA", "0", "char_00003304_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「ジュンジローさんにも、ごちそうとブラッシングを用意しておりますから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_010023340007" ]},
		{"command":[ "SETCHARA", "0", "char_00027001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「おお、これはありがたい。では遠慮なく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023340007" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「カツマさんも、今日はお仕事のことを忘れてゆっくりなさってくださいね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_010023340011" ]},
		{"command":[ "SETCHARA", "0", "char_00026901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「ｓｕｃｃｕＢｉはそのための会社ですから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_010023340008" ]},
		{"command":[ "SETCHARA", "0", "char_00027001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そ、そうか。ならそうさせてもらおうかな。これだけの美人にもてなされる\nなんてそうそうないしな！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「ええ、ええ。そうしてください。私たちとしても、精気をいただけるのはあ\nりがたいですし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_020023340004" ]},
		{"command":[ "SETCHARA", "0", "char_00003304_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……ん？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「ふふ、カツマさんの精気、一目見たときからおいしそうって思ったんですよ\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_010023340012" ]},
		{"command":[ "SETCHARA", "0", "char_00026901_01", "5", "CENTER", "0" ]},		
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「貴……貴梨果？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「実のところ、最初にカツマさんを頼ったのは、その精気がとてもいい匂いで\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_010023340013" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「サキュバスであれば誰しもが喉を鳴らすような精気を持つのがカツマさんで\nす」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_010023340009" ]},
		{"command":[ "SETCHARA", "0", "char_00027001_01", "5", "CENTER", "0" ]},	
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「魅……魅白？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「ああ、こうしてサキュバスになったからこそ二人の言うことも分かりました\n。この魅力は抗えません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_020023340005" ]},
		{"command":[ "SETCHARA", "0", "char_00003304_01", "2", "CENTER", "0" ]},	
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「ふふ、私も役目を忘れてしまいそうです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020023340004" ]},
		{"command":[ "SETCHARA", "0", "char_00002605_01", "5", "CENTER", "0" ]},	
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「ダメですよ皆さん～。まずはカツマさんを気持ちよくしてあげないと。私た\nちはそのあと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_020023340003" ]},
		{"command":[ "SETCHARA", "0", "char_00018204_01", "6", "CENTER", "0" ]},	
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「分かっていますよ……ああ、でもこの精気……たまらない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_010023340014" ]},
		{"command":[ "SETCHARA", "0", "char_00026901_01", "2", "CENTER", "0" ]},	
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「限界ギリギリまで搾り取りたくなりますね……あふうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_010023340010" ]},
		{"command":[ "SETCHARA", "0", "char_00027001_01", "2", "CENTER", "0" ]},	
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「隊長さんは何リットル出せるのか……楽しみです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_020023340006" ]},
		{"command":[ "SETCHARA", "0", "char_00003304_01", "2", "CENTER", "0" ]},	
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「男の人の限界……興味のある題材ですね。個人的にも、カツマさんの限界を\n知りたいですし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020023340005" ]},
		{"command":[ "SETCHARA", "0", "char_00002605_01", "5", "CENTER", "0" ]},	
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「ジュンジローさんも～、いっぱい気持ちよくなってくださいね～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_020023340004" ]},
		{"command":[ "SETCHARA", "0", "char_00018204_01", "2", "CENTER", "0" ]},	
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……なあ、ジュンジロー」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「なんですかな、ご主人」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023340008" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},	
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「これ、むしろ俺たちじゃなくて、貴梨果たちへのごちそうになってないか？\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「そうですな。もっと言えば我々は宴会という餌に釣られてやってきた高級魚\nのような扱いではないかと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023340009" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "6", "CENTER", "0" ]},	
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「つまり……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「今から丁寧に調理されて、おいしくいただかれますな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023340010" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},	
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「逃げるぞジュンジロー、あっ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「ふふ、まずは乾杯からですね。皆さん、お疲れ様、かんぱ～い！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_010023340015" ]},
		{"command":[ "SETCHARA", "0", "char_00026901_01", "8", "CENTER", "0" ]},	
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああ、やめろ貴梨果、腕に身体を絡めるな……おっぱいは嬉しいけど、今は\nダメだ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「ほらほら、隊長さんも食べてください。今日は特別にあ～んしてあげます、\nほら、あ～ん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_020023340007" ]},
		{"command":[ "SETCHARA", "0", "char_00003304_01", "6", "CENTER", "0" ]},	
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「膝に乗るな、また今度、また今度でいいから！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「ジュンジローさんもどうぞ～。こんがり焼いたお肉ですよ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_020023340005" ]},
		{"command":[ "SETCHARA", "0", "char_00018204_01", "6", "CENTER", "0" ]},	
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「う……逃げなければと思う心と、肉を欲する獣の本能のせめぎ合いが……！\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023340011" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "6", "CENTER", "0" ]},	
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「このブラシで毛並みも整えてあげますね。つやつやになるっていう評判のブ\nラシなんですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020023340006" ]},
		{"command":[ "SETCHARA", "0", "char_00002605_01", "6", "CENTER", "0" ]},	
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「む……無念ですご主人。役に立てない忠犬をお許しあれ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023340012" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "4", "CENTER", "0" ]},	
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あっさり陥落してんじゃねえよ！！　誰か、誰か助けてくれ～！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「ふふふ。ｓｕｃｃｕＢｉのおもてなし、たっぷりと味わってくださいね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_010023340011" ]},
		{"command":[ "SETCHARA", "0", "char_00027001_01", "5", "CENTER", "0" ]},	
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}