{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0022" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「なんだそのへっぴり腰は！　どっかに乳落としたか！　ジジイの始発ダッシ\nュのほうがまだ気合入ってるぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021390001" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "今日も今日とてＢＢ隊の訓練は続く。今日はいつもの採石場で、バズーカの射\n撃訓練だ。", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00005602_01", "7", "CENTER", "-600" ]},
		{"command":[ "SETCHARA", "1", "char_00005802_01", "7", "CENTER", "-200" ]},
		{"command":[ "SETCHARA", "2", "char_00006102_01", "7", "CENTER", "200" ]},
		{"command":[ "SETCHARA", "3", "char_00006402_01", "7", "CENTER", "600" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "DISPCHARA", "2", "TRUE" ]},
		{"command":[ "DISPCHARA", "3", "TRUE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「目ん玉開いてよーく狙え！　外したものは、泣いたりキャッキャウフフした\nりできなくしてやるぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021390002" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "DISPCHARA", "2", "FALSE" ]},
		{"command":[ "DISPCHARA", "3", "FALSE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そして今日も、冴島長官は必要以上にノリノリだ。隊員たちはもはやツッコむ\n気力もないのか、ハイライトの消えた目で標的を見つめている。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETCHARA", "0", "char_00005602_01", "7", "CENTER", "-600" ]},
		{"command":[ "SETCHARA", "1", "char_00005802_01", "7", "CENTER", "-200" ]},
		{"command":[ "SETCHARA", "2", "char_00006102_01", "7", "CENTER", "200" ]},
		{"command":[ "SETCHARA", "3", "char_00006402_01", "7", "CENTER", "600" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "DISPCHARA", "2", "TRUE" ]},
		{"command":[ "DISPCHARA", "3", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「いいか！　標的をセンターに入れて……撃てぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021390003" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "DISPCHARA", "2", "FALSE" ]},
		{"command":[ "DISPCHARA", "3", "FALSE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "長官の合図で全員が一斉にバズーカをぶっぱなした！　あたりは轟音と硝煙に\n包まれる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「いいな……朝から嗅ぐ硝煙の匂いは最高だ……！　しみついてむせる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021390004" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "などといいつつ長官は双眼鏡を取り出し――", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「……５点７点６点６点９点５点９点１０点！　全員当たりだ！　命びろいし\nたな、カメムシども！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021390005" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "隊員たちの間にほっとした空気が流れる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「それにしても東風、宵待、アディー！　おまえたちは８点以上をキープし続\nけているな！　いい調子だぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021390006" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「ほ、本当ですか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_010021390001" ]},
		{"command":[ "SETCHARA", "0", "char_00006302_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ああ、私は嘘は言わん！　おまえたちにはバズーカ射撃の才能がある！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021390007" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「バズーカなんて撃ったことなかったけど、なんでもやってみるものね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_010021390001" ]},
		{"command":[ "SETCHARA", "0", "char_00006702_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「実にいい、気に入った！　おまえたち褒美に、ウチにきて３人で百合百合し\nていいぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021390008" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「ありがとうございます！　ご褒美は辞退します！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_065_010021390001" ]},
		{"command":[ "SETCHARA", "0", "char_00006502_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「やるじゃないか、３人とも！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_010021390001" ]},
		{"command":[ "SETCHARA", "0", "char_00005802_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「ＢＢ隊の仲間として、鼻が高いです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_010021390001" ]},
		{"command":[ "SETCHARA", "0", "char_00005602_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "え？　ＢＢ隊の……仲間？　ここでいきなり仲間意識？", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「ふふふっ、私たちも負けてはいられませんね。皆さん、がんばりましょう！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_010021390001" ]},
		{"command":[ "SETCHARA", "0", "char_00006802_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「ふふふ……がんばろうね、バズ太郎きゅん。訓練のあとは、お姉さんがたっ\nぷりお世話してあげる。オイルをぬって、ピカピカに磨いて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_010021390001" ]},
		{"command":[ "SETCHARA", "0", "char_00006402_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「ＢＢ隊、がんばろー！　あははははははっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_010021390001" ]},
		{"command":[ "SETCHARA", "0", "char_00006102_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お、おい？　ジュンジロー？　みんな、様子が変じゃないか？　なんだかみ\nんな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「はい。どうやらみなさん、この状況に馴染んできてしまったようですな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021390001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「適応早ぇな！　必要以上に！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「若さゆえ、というヤツでしょうな。こうなったら我々も、合わせてみるのも\n一興かもしれませんな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021390002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「って、冗談じゃねえ～っ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}