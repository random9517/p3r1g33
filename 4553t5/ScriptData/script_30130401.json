{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「あはっ……♪　待っていましたよ？　……何を驚いているんです。先回りさ\nれて、お仕置き部屋で待たれていたのは初めてですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0403101" ]},
		{"command":[ "SETCHARA", "0", "char_00001304_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「あなた、この部屋で……パワーアップのため……なんて言いながら、女の子\nたちにエッチなことをしているらしいですね。噂で聞きました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0403102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「え？　何が目的か？　脅しなんかじゃありませんよ。私もさせてもらいに来\nたんです。パワーアップの儀式……うふふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0403103" ]},
		{"command":[ "SETCHARA", "0", "char_00001304_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「まさか嫌とは言いませんよね……。私を呼ぼうと思っていたことは、すでに\n調査済みですよ。手間が省けて良かったじゃないですか。……えいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0403104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「あはぁ……♪　いつ見てもすごい……♪　このぶっといチンポに私も何度も\n泣かされて……いえ、鳴かされてきたんですよねぇ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0403105" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00001304_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「……あら？　あらあらあら？　イニシアティブを握られて、少し私がおっぱ\nいをさらけだしたくらいで……もう勃起ですか？　だらしないチンポ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0403106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「うふ……でも……。好都合です。いつまでもフニャフニャのチンポなんかに\n興味ありませんから。ねえ？　おチンポはかたーくなくっちゃ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0403107" ]},
		{"command":[ "SETIMAGE", "0", "still_00001304_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「ほぉら。ガチガチのおチンポさん？　あなたのだーい好きなおっぱい。見せ\nてあげます。揉ませてあげます。それで……。ふぁ♪　はぁんん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0403108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「挟んであげます……♪　好きなんですよね。パ・イ・ズ・リ……あは♪　口\nで答えるまでもなく真実でしょう？　あなたはご奉仕されるのが好きで」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0403109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「その中でも、おっぱいで攻められるのが特別に好き……。違いますか？　ま\nあ、違ってもやめてなんかあげませんけど。……ん……。ほ、ら♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0403110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「よく見てください……。私のおっぱい。手で持ち上げて、チンポ挟んだりす\nるものだから……柔らかくひしゃげていやらしい形になっちゃいました♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0403111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「チンポに合わせたチンポ穴……。んぁ……あぁんんっ、はぁんん、んん……\n♪　チンポのために育ったおっぱい、気持ちいいでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0403112" ]},
		{"command":[ "SETIMAGE", "0", "still_00001304_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「すべすべの白い肌にピンクの乳頭……。あん♪　あなたの大きなおチンポを\n包みこむためだけに膨らんだプニュプニュの、魅惑の果実……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0403113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「たっぷり味わわせてさしあげます。……んッ……♪　あぁ……♪　あぁは…\n…っ、んぁんん……♪　あぁ……パイズリって気持ち、いい……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0403114" ]},
		{"command":[ "SETIMAGE", "0", "still_00001304_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「巨大なチンポをぜーんぶ楽しめちゃうんです♪　そして、教わるの。私なん\nかただの肉穴だって。私の胸はおチンポズリ穴に過ぎないんだって♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0403115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「屈辱的です……。でも、そうじゃなくっちゃ感じません。うふふっ、私……\n全身で、あなたのオナホールになりたいんです。卑猥な肉穴に♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0403116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「私の意思や人権なんてまるで無視されたい♪　ただの、メス豚として……。\nっぁっ♪　全身おまんこ娘としてチンポにご奉仕したいから♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0403117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「だか、ら……んっ、んっ。パイズリなんて望むところです、し……♪　あっ\n♪　んふ……ン、ン♪　これに生きがいを感じちゃいます。……っはぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0403118" ]},
		{"command":[ "SETIMAGE", "0", "still_00001304_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「おチンポシゴきのセックス奴隷……ぃ♪　はぁ、はぁ、いいですねぇその目\n。信じられないものを見る目♪　もっと軽蔑して、罵ってくださぁい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0403119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「今まで真面目な姉ぶってきたくせに、本当は男根のことし、か♪　考えてい\nないドスケベ女です、いつもはしかたなく濡らしなが、ら♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0403120" ]},
		{"command":[ "SETIMAGE", "0", "still_00001304_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「チンポを慕って、チンポに狂って……あぁああん♪　母乳を作る大事なおっ\nぱいですら、セックスに使ってしまうんですよ♪　ひどい女でしょう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0403121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「……んん？　もう少し強くした方がいいですか？　あっ♪　あっ♪　だめ、\nだめぇ……パイズリしてると、アソコがうずいて腰が揺れちゃうぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0403122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「あぁんっ、あぁ……あぁっあぁっ♪　おチンポぉ、私が好きなお、チンポ♪\n　チンポぉ♪　手首みたいに太くって、傲慢なまでに上を向いていてぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0403123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「女をおかしくさせる名器♪　……あああ……もう我慢できないっ！　おいし\nそう……っ。この色、このツヤ、もの欲しそうに鈴口がヒクヒクして♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0403124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「よだれ垂らして喜んでますよ……♪　あっ、カウパーにじませて……誘って\nる♪　舐めてみろって……！　ん……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0403125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「ぢゅるっ……ぢゅるるぅうっ！　ぢゅるぅ……！　へ……？　舌先じゃなく\nていきなり咥えるのか、ですか？　当然じゃあないですかぁああ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0403126" ]},
		{"command":[ "SETIMAGE", "0", "still_00001304_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「おチンポ様のご命令ですよ♪　全力でお応えするのが礼儀でしょうっ……♪\n　んぁああ……♪　ニュルニュルした味のない雫……んんん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0403127" ]},
		{"command":[ "SETIMAGE", "0", "still_00001304_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「これが苦い苦い、真っ白な精液になるまでしゃぶりつくします……！　ね、\nそれがいいですっ、それしかありえない……！　あーんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0403128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「はむっ……！　ぐちゅるっ、ん、ちゅぅうう♪　ちゅううう……♪　んふー\n♪　もひろん、パイズリだってやめまへんよ。同時ひんこうれふ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0403129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「ぴちゃっ……れろれろっ……！　ぢゅるっ……ぢゅるっ、ぢゅる……！　は\nぁ、んん……あぁん……！　ぐちゅっ……！　ぐちゅっ、ぢゅる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0403130" ]},
		{"command":[ "SETIMAGE", "0", "still_00001304_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「ぐちゅっ……あむ……。ンン……おいひぃ……♪　やっぱりぃ、あなひゃの\nチンポが一番んん……っ♪　あむっ♪　ぢゅっぽっぢゅぽっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0403131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「あは……♪　しつこいバキュームフェラ、いいれひゅか？　ん、む……っ。\nだってわたひ、おチンポがひゅき、なんれひゅものぉお……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0403132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「どこまでもしつこく追い詰めてあげまひゅよぉ♪　んーっ……♪　チンポは\n根元からぁ、先っひょまでおいひい……。れろれろれろ、れるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0403133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「じゅぷっ！　ぐちゅっぷっ、ぢゅるっ、ぢゅるぅ……ぢゅる♪　れろれろ…\n…ぢゅっ♪　ぐちゅるっ、ぢゅるっ、ぢゅーっ、ぢゅる……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0403134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「あん♪　カウパーの量がぁ増してきまひたよぉ♪　チンポもビクビク震え出\nひて……イキそうなんれひゅね。まだ本気なんて出ひてないのにぃ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0403135" ]},
		{"command":[ "SETIMAGE", "0", "still_00001304_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「わたひがちょーっとおひゃぶりひたら出しちゃうんれふねぇ……♪　んふふ\nふふっ♪　いいれひゅよぉ♪　出せばいいじゃないれひゅかぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0403136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「わたひに出すとこ見られながら……情けない声をあげてイッひゃってくだひ\nゃい♪　ねえ♪　いつまでも意地はってないれ……ほぉーらぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0403137" ]},
		{"command":[ "SETIMAGE", "0", "still_00001304_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「ぢゅるっ、ぢゅるっ、ぢゅるるるっ……♪　ん、グチュっ♪　じゅるっ……\nじゅる……はぷ♪　じゅっぽっじゅっぽっじゅぽっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0403138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「カウントダウン……必要れひゅか？　だったらお望み通り……いきまひゅよ\n？　私の声に合わせれ射精ひてくださいね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0403139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「じゅるっ、じゅるっ……ごーぉ♪　よーん……れろっ、れろぉ……♪　さん\n、に、いち……今ですよ♪　さ、出してぇ、ザーメン出してぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0403140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「んぷぅっ、んんー♪　んんんん～♪　ごきゅっ♪　ごきゅっ♪　ごきゅっ♪\n　あぁ……搾りたての生精液……おいひい♪　おいひいいい……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0403201" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001304_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「んぷ♪　出し惜しみなしで全部出してくださぁい……♪　んーっ♪　ごくっ\n……ごくっ……♪　どんどん飲んであげますからぁ……ごくっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0403202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「んぁ……♪　胸にこぼれた分もぉ、全部飲みたかったけど……まずはお口が\n潤ったので良しとしましょう……♪　ふふ、うふふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0403203" ]},
		{"command":[ "SETIMAGE", "0", "still_00001304_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「舌も喉もネロネロの粘液がこびりついて……最高です♪　あぁ……♪　この\n苦味、えぐみ……まさに一級品の濃さだったみたいですねぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0403204" ]},
		{"command":[ "SETIMAGE", "0", "still_00001304_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「おっぱいと口で搾り取られるの、たまらないでしょう？　私も男だったら…\n…ぜひ体験してみたいです、射精……♪　はぁあああ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0403205" ]},
		{"command":[ "SETIMAGE", "0", "still_00001304_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「射精直後の、ちょっとだけしゅんとした柔らかいオチンチンも風情がありま\nすねぇ……♪　チンポはどんな時だってイイ……♪　だけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0403206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「いつまでも萎えていてもらっちゃ困るんですよ。あなたともあろう人が、フ\nニャフニャチンポを私に晒し続けるわけがありませんもんねぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0403207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「協力しますよ？　だから……れろっ……♪　早いところ復活させちゃってく\nださい？　んっ……ん、ちゅぷ♪　ちろっ、ちろ……れろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0403208" ]},
		{"command":[ "SETIMAGE", "0", "still_00001304_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「ちゅぅうう♪　ちゅっ、ちゅっ、チュッ……んぁ……♪　あはは♪　硬さが\n戻ってきましたぁ……。もっと♪　もっと大きくして……れる♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0403209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「私の口からはみ出すくらい、……ん♪　太くするんです。ビキビキに隆起し\nたオチンポで、私の口と胸を蹂躙してくれなきゃいやですよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0403210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「ん、ちゅ、ちゅ、ちゅぅう♪　れろ、れろれろ……あ♪　ここに残り汁……\nごくんっ♪　丁寧に、丁寧にお掃除フェラして……って、んむぅっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0403211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「あぁああああ♪　そっちが腰、使っちゃうんですか！？　あはははっ、うふ\nふふ♪　私のおっぱいと口で交尾♪　交尾する気だなんて最低ぃ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0403212" ]},
		{"command":[ "SETIMAGE", "0", "still_00001304_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「んぷっ、ぐちゅっ、ぐちゅっ……んむぅっ♪　ぢゅっぷっぢゅぷっ♪　じゅ\nぷっ、じゅっぷっ……あは、あははは……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0403213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「そっちがその気なら私も、お相手します……！　んむ♪　胸と口をフルスピ\nードれ……動かして、ご奉仕ひて、おしゃぶり、おねぶり……んっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0403214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「んむぅううう♪　じゅっぷっじゅっぷっじゅっぷっ♪　あぁあ、むせ、返る\nようなチンポ臭……臭い股間を嗅がされながら舌を絡めて……れろぉ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0403215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「あんっ、あんっ、臭いぃ♪　くひゃい……くひゃいのぉ♪　んんー……れろ\nれろれろっ♪　ぢゅるーーーじゅるじゅるじゅる♪　ん、ん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0403216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「喉の奥まで突き入れひゃってくださいぃ……♪　んぁおぉ♪　ぢゅううう♪\n　ぢゅるっ、じゅっ、じゅうう♪　れろっれろっ、れろれるぅ、れるっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0403217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「んふ♪　いい、です、素敵です……！　んむっ！　ぐちゅっ、ぐちゅ……！\n　あああ……♪　どんどん腰が速くなって……あっ♪　あっ、じゅるっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0403218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「二度目も盛っ大にまき散らしちゃってくださいねぇ……精子♪　ん、あぁ…\n…あぁ♪　れろっ、れろっ、れろ……ぢゅぅ♪　ぐっちゅっぐちゅ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0403219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「精液ぃ♪　精液欲しい♪　欲しい、欲しいのぉ♪　ザーメン恵んでぇ♪　は\nやく、はやく、はやくちょうだい、出ひて、出すんですぅう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0403220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「ぐ、ぷ♪　んんん♪　ごくっ……ごくっ、ごくっごくっ♪　ぢゅー――――\n♪　ごくっ♪　ごくっ、ごく……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0403301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001304_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「あああ、出たぁーーーーー♪　んむっ♪　あは……まだありますか？　じゃ\nあ、口の中に……胸の谷間にどぉーぞぉ……♪　あんっ、あんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0403302" ]},
		{"command":[ "SETIMAGE", "0", "still_00001304_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「口内粘膜の中を跳ねまわるザーメン……♪　やんちゃすぎでしょぉ♪　あっ\n♪　あっ♪　お口の中に射精されると……熱くて頭がぽぉっとして♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0403303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「脳内真っ白に染め上げられちゃいますぅう……♪　最高ぉ♪　さいこおぉ♪\n　んーっ♪　タマタマの中身からっぽになるまで出して……んぁああ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0403304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「あ、あ、あ……♪　出し終わり……ましたかぁ？　そしたら、お口の中れぇ\n……♪　ザーメンくちゅくちゅ唾液と混ぜ、てぇ……♪　っくちゅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0403305" ]},
		{"command":[ "SETIMAGE", "0", "still_00001304_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「後は美味しくいただきまぁすぅうう……♪　……ごくんっ……♪　ごきゅ…\n…♪　ふぁあああ……！　後を引く、この臭み……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0403306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「ぷはぁああ……♪　やだ、息が精液臭くなってしまいました♪　ううん、き\nっと口だけじゃない……。胃も、身体の至る場所も全部……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0403307" ]},
		{"command":[ "SETIMAGE", "0", "still_00001304_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「あなたのザーメンの臭いに染まって……。ああああ、ゾクゾクするぅうう♪\n　二発分のザーメン♪　ご馳走さまでした……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0403308" ]},
		{"command":[ "SETIMAGE", "0", "still_00001304_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「本当は毎日飲ませて欲しいくらいです♪　あ……♪　チンポにこびりついた\nぶんを、舐め回して胸でそぎとって……お掃除しますね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0403309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「ぺろ……れろっ、ちゅぱ♪　ちゅぱ♪　ちゅぱ……♪　あとは胸で……。ん\n……んん♪　どうです、綺麗になったでしょう……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0403310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「きゃぁ～～♪　ぶっかけですか！？　ぶっかけ、ぶっかけぇえ♪　あは……\n♪　あはっ、あはっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0403401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001304_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「ひゃん！　胸に……、えっ？　顔ですかぁ♪　スケベぇ……！　あっ♪　あ\nっ♪　熱い濁流がほとばしって……。くっさぁいい……♪♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0403402" ]},
		{"command":[ "SETIMAGE", "0", "still_00001304_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「芸術的な生臭さですよ……あぁん♪　信じられなぁいぃ♪　女の子の顔に…\n…あっ、シルバスターの顔面にザーメン直に生発射するなんてぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0403403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「外道～～～♪　あ♪　あ～～～～～♪　こんなドロドロしたシャワー初めて\n……♪　だめぇ♪　髪にも精子ついちゃってるじゃないですか～～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0403404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「はぁああ……♪　ぷぁ……はぁ♪　はぁああ～～～～♪　息をして、大きく\n吸いこむだけで……生臭いザーメン臭を好きなだけ肺に送りこめるぅ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0403405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「それに……。ん、ちゅる……れろ……ちゅる……♪　口元に流れてきた分は\n、栄養補給に舐めて飲めますし……ぃ……♪　ん、れろ……れろ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0403406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「顔に出されるのも、意外と悪くないです……ね♪　そりゃあ、口やオマンコ\n……粘膜の中に直接供給されるのが最強ですけど……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0403407" ]},
		{"command":[ "SETIMAGE", "0", "still_00001304_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「私の顔に、胸にザーメンかかった淫らな姿をあなたが見たいっていうのなら\n、多少はお譲りしますよ……。うふふ、いい気分でしょう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0403408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「本来なら敵同士だったはずのシルバスターを、悪堕ちさせてザーメン漬けに\nして……快楽のことしか考えられなくして♪　すごい背徳感ですよね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0403409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「そういうので……感じちゃうのわかりますよ♪　だって……私も同じなんで\nすから♪　ふふふふ……二人でもっと堕ちていきましょうね……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0403410" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
