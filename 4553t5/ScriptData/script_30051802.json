{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0187" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「この時が来るのを、ずっと待ち遠しく思っていました……ウチと旦那様との\n結婚初夜……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1804101" ]},
		{"command":[ "SETCHARA", "0", "char_00000518_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「もう準備も整っています……さあ、こちらのベッドに寝そべって下さい。ウ\nチが上に乗りますから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1804102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んっ、しょっ……あぁ……勃起しきったオチンチン……今から、これがウチ\nの中に入るんですね……立派で、美しいです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1804103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ウチの持てる全ての技巧を駆使して、たっぷり気持ちよくしますから……子\n作りを楽しみましょうです……旦那様♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1804104" ]},
		{"command":[ "SETCHARA", "0", "char_00000518_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ほら……ウチのオマンコ……どうなっていますか？　こんなに涎を垂らすみ\nたいに……割れ目から溢れていますでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1804105" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00000518_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「今日は、しっかり受精したと分かるまで帰しませんから……覚悟なさってく\nださいね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1804106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「おやおや……？　今ので、オチンチンが更にフル勃起してるじゃないですか\n……これは同意と見てよろしいですね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1804107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んふ……では、遠慮なく……ウチのオマンコに……この太いオチンチン……\nいただきます……はぁっ、んんんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1804108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あっ、んくぅぅぅぅぅぅぅぅぅっ！　あぁっ……入りっ……ましたっ！　は\nふぁぁぁっ……おっ、大きい……ですぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1804109" ]},
		{"command":[ "SETIMAGE", "0", "still_00000518_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「くふぁぁ……分かりますか？　オチンチン……あぁっ……大きすぎて……お\n腹が膨らんで見えちゃってます……はふぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1804110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ですが……んっ、ウチの……オマンコは……ちゃんと想定していますから…\n…んっく……このサイズ……問題ありませんです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1804111" ]},
		{"command":[ "SETIMAGE", "0", "still_00000518_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、そ、それじゃあ……動きますからね？　少し、勢いをつけま\nすから……その、ぎゅっと……手を握って離さないでくださいね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1804112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「大丈夫ですね？　では……揺らしますっ……うんっ、ふっ、はっ、あぁっ、\nんぁんっ、はっ、あぁっ、はひっ、あぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1804113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あぁ……すごく太くて……硬くて……でも、擦れ具合は……柔らかくて……\n優しくてぇ……んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1804114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「こうしてっ、ズリズリしているだけでっ……あひぅっ、発情が……進みます\nっ……は、ひっ、あひんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1804115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「旦那様は……どうですかっ？　ウチの……発情オマンコ……ちゃんと、味わ\nえてますかっ？　んっ、物足りなくないですかっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1804116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「中がとろとろで熱くて……いい感じ……ですか？　ふふっ、それは……んっ\n、何よりです……でも、まだまだこんなものじゃないですよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1804117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「今日のウチは欲張りですから……んんっ！　たっぷり、感じてもらえるよう\nに……もっと大きくピストンしますからねっ……んぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1804118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「はぁっ、んふっ、どうですか……この……腰のくねらせ具合……んぅっ……\nいやらしい動き……色っぽいんじゃないですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1804119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んんっ、あなたが……ちゃんと支えてくれれば……もっと、大きく腰を回し\nて……オチンチン……いっぱいよくしてあげられます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1804120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あふっ……はぁんっ……あぁ……降りてきた子宮に……亀頭がコリコリって\n当たってます……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1804121" ]},
		{"command":[ "SETIMAGE", "0", "still_00000518_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「オチンチンとオマンコのキス……させて貰うです……この感触……大好きで\nすからぁ……ふぁっ、んっ、あっ、あぁんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1804122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「顔が赤い……ふふんっ、そんなこと……言われるまでもなく自覚しています\nっ……それに、それはお互い様ですからっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1804123" ]},
		{"command":[ "SETIMAGE", "0", "still_00000518_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「旦那様の顔も……だらしなく緩んでますよ……？　まさか、ご自分で気づい\nていませんか？　こうして……オマンコをむにゅっと締めると……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1804124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んふふっ、ビクってなりましたね？　この可愛い反応が見たくて、今日はウ\nチが上になったんです……さあ、まだこれからですよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1804125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「はっ、んっ、あぁっ、ふっ……んふっ……切なそうな顔……はふっ、ゾクゾ\nクします……はぁんっ、あっ、んぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1804126" ]},
		{"command":[ "SETIMAGE", "0", "still_00000518_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「お汁も……新しくじゅわっと溢れて……ほらぁ……分かりますか？　結合部\nから……トロって漏れてますからぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1804127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ふぁっ、んくっ、あふぅんっ……この汁を……もっと、オチンチンにまぶし\nて……エッチな音……させますから……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1804128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「はんっ、あんっ、あぁんっ……あっ、あぁっ、気持ちいいですかっ？　ウチ\nは……ずっと……オマンコ……気持ちいいですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1804129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「もう全然……腰が止まりませんっ……はぁんっ、襞を吸い付かせてっ……何\n度も亀頭にキスをしてっ……んふぅっ、んちゅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1804130" ]},
		{"command":[ "SETIMAGE", "0", "still_00000518_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んふふっ、本当のキスまでしちゃいました……愛しあってるから……何でも\nできちゃいますっ……んっ、あっ、ふぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1804131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「このぐちゅぐちゅする音……もっと、あぁっ、もっとさせてっ……はひっ、\nああっ、ウチ……そろそろっ……イキそうですっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1804132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ほらっ……あ、足のところっ……指が……ピンってなってます……あぁっ、\nも、もう少しですっ……くぅっ、んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1804133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あなたもっ……旦那様もっ、もうすぐですよねっ？　このオチンチンの震え\n……オマンコの中でっ、しっかり伝わってますからっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1804134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「はいっ、子種はそのままっ、オマンコの中にくださいっ！　子宮は準備でき\nてますからっ……キュってオチンチン搾りますからぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1804135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あっ、あぁっ、出してくださいっ……奥にっ、はぁぅんっ、オチンチンっ…\n…びゅびゅって……してぇぇぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1804136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あぁっ……！　中っ……あっ、びゅびゅってっ……来ましたぁっ……！　精\n液っ……あふぅんっ、子宮に……届いてますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1804137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000518_02_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「はぁぁぁ……着床してますっ……赤ちゃんの……子種ぇ……届けられてます\nぅ……ふぁぁぁん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1804138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あぁ……妊娠したいです……もっと精液……しっかり満たしてください……\nはぁぁん……溢れるぅ……あふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1804139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んんっ、あぁ……たっぷり出してくれましたね……んふふぅ……嬉しいです\n……愛の結晶が宿りました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1804140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「はふ……一息つきましたが……まだまだ、愛の営みは続けられますよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1804201" ]},
		{"command":[ "SETIMAGE", "0", "still_00000518_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「いつも以上に積極的……もちろんです。元より、ウチは性欲モンスターだっ\nたんですよ。ご存知ありませんでしたか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1804202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「たっぷり出していただいた精液のにおい……いっぱい広がって……ウチの発\n情はいよいよ止まらなくなってしまいます……んふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1804203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「というわけで……また、んっ、オマンコ……ピストンさせていきますからっ\n……あっ、んぁっ、くぅっ、はふんっ、は、ひっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1804204" ]},
		{"command":[ "SETIMAGE", "0", "still_00000518_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あぁ……オチンチン……ずっと硬いままです……オマンコの中にみっちり埋\nまって……まだ、少しずつ広がってます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1804205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あふっ！　んっ、今度は……旦那様も動きたいんですか……？　もう、仕方\nありませんね……お手柔らかにお願いしますよ……はぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1804206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「はっ、んっ、あぁっ……！　最初からっ……ぐいってっ、奥へっ……突き上\nげっ……られてぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1804207" ]},
		{"command":[ "SETIMAGE", "0", "still_00000518_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あっ、あぅんっ、はひっ、くぅぅんっ！　あぁっ……ウチも……一緒に動き\nますっ……タイミング合わせてくださいっ、せーのでっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1804208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「はんっ、あんっ、あっ、あっ、あぁっ、はっ、んぁっ、あっ、声もっ……リ\nズミカルにっ、あっ、出てっ……しまう、ですっ、んふっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1804209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んふっ、ウチと……旦那様……息もピッタリですねっ……んっ、スケベな気\n持ちもっ……負けず劣らずですからっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1804210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「はぁんっ、あっ、今のとこぉっ、もっと……グリって……突いてくださいっ\n……くぅんっ……そうですっ、あっ、オチンチンそこぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1804211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「くぅっ……んんっ、あっ、ふっ……！　さすがは……旦那様っ……ウチのっ\n、気持ちいいところっ……全部知り尽くしてますっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1804212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「もっとっ、はぁんっ、あくぅっ、好きなところっ……いっぱいして欲しいで\nすっ、あぁっ、好きですっ、旦那様っ……好きぃっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1804213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「はぁぁぁぅっ……ウチもっ、あぁっ、愛していますっ……！　あぁんっ、オ\nマンコでっ、お応えしますっ、こうしてぇっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1804214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んふっ、あぁっ、オチンチンっ、暴れてますっ、はぁぅっ……子宮とキスし\nてっ、あぁっ、ぐちゅぐちゅの中……蕩けてぇっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1804215" ]},
		{"command":[ "SETIMAGE", "0", "still_00000518_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ひぃっ、んくぁっ、好きっ、好きですっ、旦那様ぁっ……あぁっ、止まらな\nいっ……！　このまま……してたらっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1804216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あっ、あぁっ……また、イキそうですっ……！　オチンチンっ……ずっとオ\nマンコの気持ちいいところ擦り続けてっ……も、もうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1804217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「イキたい……はいっ、もうイキますっ！　旦那様もっ……もうすぐですよね\nっ？　はいっ、ラストスパートですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1804218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「はふっ、あぁっ、いっぱい……腰をグリグリ回してっ！　エッチな腰振り見\nられながら……ウチもイキますっ、アクメしますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1804219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あなたもっ、出してっ……出してくださいっ！　旦那様のっ、子種っ……ま\nたっ、いっぱい欲しいですっ、あぁっ、も、もうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1804220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「はぁぁぁぁぁぅんっ！　あぁぁっ……またっ、子種っ……いただきましたぁ\nっ……はぁぁぁぁぅっ……んふぅぅぅんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1804301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000518_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あぁぁ……子宮に浴びてます……旦那様の濃厚な子種汁……はぁぁ……絶対\n着床するように……塗りつけられてますぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1804302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んふぅ……もっと締め付けますからぁ……最後の一滴まで……全部、子宮に\n届けて下さい……はぁん……もっとぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1804303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……あぁ……はぁ、はぁ……はぁ……あぁ……オチンチンが……\nやっと大人しくなりました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1804304" ]},
		{"command":[ "SETIMAGE", "0", "still_00000518_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「全く……出してる時も、まだ下から突き上げるなんて……欲望まみれのオチ\nンチンにも程があります……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1804305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ま、まぁ……ウチも精液が欲しくて、腰を振り続けてましたから……同じよ\nうなものかも知れませんが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1804306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ふふっ……最初は何もかも全く正反対で合うわけがないと思ってましたが…\n…こうしてみると、似てるところも多いのかも知れません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1804307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ということは、産まれてくる赤ちゃんもウチたちに似て……ふふっ、これは\n一筋縄ではいかない子になってしまうかも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1804308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「え……可愛いに決まってる？　全く……楽観的なところは一ミリも似ません\nね……でも、そういうところは嫌いじゃないです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1804309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ふふ……今から待ち遠しくて仕方ありません……ウチは、旦那様と赤ちゃん\nを、ずっとずっと幸せにしてみせますから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1804310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ひぁぅっ！？　あぁっ、オチンチンっ……外れてっ……あっ、んぅぅぅぅっ\n……か、身体にっ……熱いのっ……ぷぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1804401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000518_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「二発目は……外っ……んっ、最初から……そのつもりだったんですねっ……\n？　んんっ、あぷっ、ふぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1804402" ]},
		{"command":[ "SETIMAGE", "0", "still_00000518_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「いえ……精液……浴びるのも悪くないです……んっ、ふぅぅ……ウチは、旦\n那様のこのにおいが大好きですからぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1804403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「どうせなら……残らず出して……全部、ウチの身体にマーキングしてくださ\nい……直接オチンチンでなすりつけてください……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1804404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んっ、あぁ……おっぱいにも……顔にも……はぁ、んふっ、ベトベトのドロ\nドロがいっぱいです……にゅふぅ……幸せですぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1804405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ぴちゃ……んちゅぷっ、んっ……美味ですね……れろ、もう赤ちゃんの分は\n十分いただきましたし……直接味わうのも悪くないです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1804406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「出し切りましたか？　お疲れ様でした……後は、赤ちゃんを授かっていれば\n言うことなしですが、こればかりは分かりませんからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1804407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「もっとも、これからは妊娠が分かるまで毎日でも種付けしてもらいますから\n、慌てる必要もありませんね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1804408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「もちろんです。今日だけが特別な一日だとでも思ってましたか？　ウチの性\n欲を舐めてもらっては困りますよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1804409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ふふ……なんだかんだでオチンチンを硬くさせる辺り……さすがウチの旦那\n様です。これからも、末永く……よろしくお願いしますね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1804410" ]},
		{"command":[ "WAITINPUT" ]},
