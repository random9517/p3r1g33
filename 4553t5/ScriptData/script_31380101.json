{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「そんなにあたしを見つめて、どうしたんだ？　ひょっとして、あたしに興奮\nでもしたのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0103101" ]},
		{"command":[ "SETCHARA", "0", "char_00013801_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「あははっ！　冗談だよ、冗談。こんな愛嬌もねぇ女なんかに、興奮するわけ\nないもんな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0103102" ]},
		{"command":[ "SETCHARA", "0", "char_00013801_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「……え？　すごく、興奮する？　特にあたしの胸が気になる……？　ば、バ\nカ野郎！　なに言ってんだお前！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0103103" ]},
		{"command":[ "SETCHARA", "0", "char_00013801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「あー……うん。なんだ……そんなに、あたしの胸が気になるのか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0103104" ]},
		{"command":[ "SETCHARA", "0", "char_00013801_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「だったら、その……お前がよければ、その……して、あげないこともないん\nだけどさ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0103105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「ま、マジでやるのかよ……お前、少しくらい躊躇しろよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0103106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「あーもう！　わかってるよ！　こっちから言い出したことなんだし、ちゃん\nとしてやるから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0103107" ]},
		{"command":[ "SETCHARA", "0", "char_00013801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「ったく……こ、こんなことするの、初めてなんだからな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0103108" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00013801_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「ち、チンポに触れるのだって……は、初めてだし……どうすればいいのかも\n、よくわかんねぇから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「とりあえず、胸に挟んで擦ればいいんだよな……んっ、くっ……こ、こん\nな感じか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「って、これ、段々大きくなってないか！？　それに、熱くて……か、硬くて\n……ふああぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0103111" ]},
		{"command":[ "SETIMAGE", "0", "still_00013801_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「チンポの先端から変な汁まで出てやがる……！　こ、これが俗にいう精液っ\nて奴なのか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「これは先走り汁……？　気持ちよくなると出てくる……？　そ、そうか……\n気持ちいいんだな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0103113" ]},
		{"command":[ "SETIMAGE", "0", "still_00013801_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「だったら、もっと擦ってやるよ……んっ、くっ、はあぁ……ふっ、ふぐっ…\n…！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「チンポが胸の中でビクビクしてやがる……随分といい反応するじゃねぇか…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0103115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「あたしの胸で気持ちよくなってるって証拠だろ……？　へへっ。悪い気分じ\nゃないな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「でも、なんだか擦りにくいな……こう、滑りがよくないっていうか……なん\nか変に引っかかるっていうか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「チンポに唾液を垂らして、思いっきり濡らせばいいのか……？　な、なるほ\nど……そうすれば、滑りがよくなるんだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「えっと……唾液を垂らして……んっ、ぺちゃ……ぐちゅ、ちゅ、じゅるっ…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0103119" ]},
		{"command":[ "SETIMAGE", "0", "still_00013801_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「んっ……れりゅ、ちゅ、ぺちゃ……んっ、これなら、擦りやすい気がするな\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「それにしても、すごいニオイだな……お前のチンポと、あたしの唾液が混ざ\nって……なんか、クラクラする……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0103121" ]},
		{"command":[ "SETIMAGE", "0", "still_00013801_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「ちょ、お前……！　チンポがドクドクって脈打ってるし、まだ大きくなるの\nか……！？　そんなに、唾液が気持ちよかったのか……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0103122" ]},
		{"command":[ "SETIMAGE", "0", "still_00013801_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「そ、そうか……気持ちいいなら、別にいいんだ……それじゃ、続けるぞ……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「んっ、くっ、ううぅ……はぁ、あっ、ふああぁ……！　これ、擦るたびにあ\nたしの乳首がチンポで擦れて……んんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「乳首も胸の中も、熱すぎて火傷しそうだ……！　それに気持ちよすぎて、な\nんだか……へ、変な気分に……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「カリ首が柔らかい肌に擦れて気持ちいいとか、そういうこといちいち言うな\n……！　ふっ……んふっ……ん、んあっ、ぐううぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……谷間に唾液と汗と、お前の汁が混ざって……すごくエッチな\nニオイがする……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「んっ、ぐっ、あはああぁ……！　お前のチンポだけじゃなくて、あたしのア\nソコもなんだかビクビクしてきて……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「胸でチンポ擦ってるだけなのに……！　どうしてこんなにも、エッチな気分\nになるんだ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「えっ……そろそろ、出そう……？　出るって、精液が……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0103130" ]},
		{"command":[ "SETIMAGE", "0", "still_00013801_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「わ、わかった……もっと激しく擦ればいいんだな……！　だ、唾液ももっと\n垂らして……んっ、ちゅぱ、れりゅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「んっ、あっ、ぴちゃ……ぐちゅ、あはああぁ……！　ど、どうだ……？　そ\nの、精液はちゃんと出せそうか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0103132" ]},
		{"command":[ "SETIMAGE", "0", "still_00013801_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「んんっ！　ち、チンポがすごく脈打って……！？　で、出るんだな……！　\nお前の赤ちゃんのもとが……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0103133" ]},
		{"command":[ "SETIMAGE", "0", "still_00013801_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「遠慮しなくていいぞ……！　あ、あたしの胸の中に、お前の精液をたくさん\n出してくれ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「あああっ……く、来る！　お前の精液……チンポの先端から、たくさん……\nんっ、あっ、ああぁ……ふあああっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0103135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、はぁ、はああぁっ……こ、これがお前の精液……すごく粘っこ\nくて、臭くて、濃くて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0103136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00013801_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「こんなに濃厚でドロドロしてたら、もしアソコに出されたら……確実に孕ん\nでたかもな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0103137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「ま、まあ。いくらお前とあたしの仲とは言っても、さすがにそこまで許すわ\nけにはいかないからな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「それじゃ、これで終わりだ……早く綺麗にしないと、ニオイが肌に染み付き\nそうだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「お前のも拭いてやるから、早くチンポを胸からのけて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0103140" ]},
		{"command":[ "SETIMAGE", "0", "still_00013801_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「ちょ、おまっ……なんでまだ硬いままなんだよ……！　めちゃくちゃ出した\nだろ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0103201" ]},
		{"command":[ "SETIMAGE", "0", "still_00013801_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「パイズリが気持ちよすぎて、一回じゃ治まらない……？　ば、バカ野郎！　\nそんなこと言われても、嬉しくなんか……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「でも……それって、あたしの、その……胸がよかったってことだよな……？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0103203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「しょ、しょうがねぇから……あと、一回だけなら……その、付き合ってやる\nよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0103204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「それに、お前のチンポも……ガチガチのままで、苦しそうだからな……し、\n仕方なくってやつだ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「さ、さっきよりも気持ちよくしてやるから……さっさと、精液を出せ……！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「な、なんだ……もっとヌルヌルにして欲しいのか……？　しょうがないな…\n…んっ、れりゅ、れろっ……ちゅ、じゅぞっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0103207" ]},
		{"command":[ "SETIMAGE", "0", "still_00013801_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ、じゅ、れりゅううぅ……ほら、擦るぞ……んっ、くっ、はううぅ\n……あっ、ああっ、んくううぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……な、なんだこれ……さっきと同じはずなのに、谷間も乳首も\n敏感になって……ひぐううぅ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0103209" ]},
		{"command":[ "SETIMAGE", "0", "still_00013801_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「ひぐっ、あっ、熱いぃ……！　精液のせいで余計に滑りがよくなって、さっ\nきよりもチンポを感じてる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0103210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「はぁ、くっ、んんんっ！　それに、エッチなニオイもより濃くなって……ん\nぐううぅ！　こ、擦るたびに脳がトロけそうになって……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「これ、ダメだ……！　このまま続けたら、あたし戻れなくなる……！　絶対\nにこのニオイとチンポの、虜になる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「あ、アソコも……マンコもすごく濡れてきて……！　弄ってないのに、谷間\nと同じくらいぐちゃぐちゃでぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「おっぱいが精液まみれになっただけなのに……！　どうして、こうも身体が\n……マンコが反応するんだ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0103214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「もしかして、本能がお前の精液を求めてるのか……！？　子宮に……赤ちゃ\nんの部屋に、精液を欲しがってるのか……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0103215" ]},
		{"command":[ "SETIMAGE", "0", "still_00013801_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「そ、それはダメだ……！　だ、出すならおっぱいの中だ……！　ここ以外、\n認めないからな……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0103216" ]},
		{"command":[ "SETIMAGE", "0", "still_00013801_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「くっ、うぐっ、ううぅ……！　はぁ、あはあああぁ……！？　は、早く精液\nを出せ……！　じゃないと、あたしがおかしくなるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「あぐっ、くっ、ああぁ……！　これだけ激しくすれば、すぐに出るだろ……\n！　ほら、お前のチンポも限界みたいじゃないか早く……出しちまえ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0103218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……！　さっきと同じくらい、チンポがビクビクって跳ねて……\n！　は、早く出せ……！　じゃないとあたし……本当におかしくなる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「あああぁっ！　ほらっ、ほらあぁ！　出せっ！　出せっ！　お、お前のくっ\nさい精液、全部……あ、あたしにぃ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「やっ、ああああっ！　あっ、あはあああぁ！？　あ、熱いっ！　おっぱいの\n中に濃厚精子がどぴゅどぴゅ出てる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0103301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00013801_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「チンポの震えが止まらないっ！　何度もビクビクって跳ねて、次から次に精\n液吐き出してて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「こんなの、我慢できない……！　あ、あたしも、イクッ……！　触ってない\nのに、マンコイクぅ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0103303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「あっ、あっ！　イッ、イク……！　あっ、ひぐっ！　ふあああああぁ～～～\n！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0103304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……嘘、だろ……胸に精液かけられてイクなんて……あ、あた\nしの身体、本当におかしくなったのか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0103305" ]},
		{"command":[ "SETIMAGE", "0", "still_00013801_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「それに、身体に精液がべったり付いて……胸の中、もういろんな汁でぐちゃ\nどろだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0103306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「うううぅ……肌に染み付いてそうだ……このニオイだけでイキそうなのに、\n洗ってもニオイが落ちなかったら、どうすりゃいいんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0103307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「いつでも精液のニオイを感じながら、オナニーできる……？　お、おまっ…\n…！　ふざけてんのか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0103308" ]},
		{"command":[ "SETIMAGE", "0", "still_00013801_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「あ、あたしは別にお前の精液のニオイでオナニーなんて……し、しないから\nな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0103309" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「うあああっ！？　せ、精液が顔に……！　あぶっ、んっ！　ちょ、やめ……\n！　ううううぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0103401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00013801_01_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「うええぇ！　口の中に入ってきやがった……！　んっ、ぐちゅ……！　ドロ\nっとしてて、変な味が広がって……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「お、おい！　なんで胸の中に出さないんだよ！　こ、こんなことされたら、\n本当にニオイだけで……いっ、イク……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0103403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「イッ、イク！　精液の味とニオイで、イッ……イクううううぅ～～～っ！！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0103404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「はああぁ……これ以上、出すなぁ……！　精液かけられるたびに、軽くイッ\nて……んんんんっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0103405" ]},
		{"command":[ "SETIMAGE", "0", "still_00013801_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「うぐっ……ごくん……！　く、口の中の精液、飲み込んじまった……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0103406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「喉に絡みついて離れねぇ……！　身体の中まで、お前のニオイで染まっちま\nう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0103407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……も、もういいだろ……ちゃんと射精させたんだし、もう終わ\nりだ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0103408" ]},
		{"command":[ "SETIMAGE", "0", "still_00013801_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「なっ……！？　もっとおっぱいの中に出したい……！？　ふ、ふざけるな！\n　あと一回って約束だっただろ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0103409" ]},
		{"command":[ "SETIMAGE", "0", "still_00013801_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「あたしはこれから、シャワーを浴びるんだ！　もう終わりだ、終わり！　あ\nとは部屋に戻って、自分でチンポでも擦ってろ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0103410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}