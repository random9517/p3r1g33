{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0033" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "カグヤ・ダーク" ]},
		{"command":[ "SETTEXT", "「……来たか……。こんな夜更けに呼び出されて、のこのこやってくるとは…\n…お前は人が良すぎる。だが、来訪には感謝するぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1003101" ]},
		{"command":[ "SETCHARA", "0", "char_00000210_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ・ダーク" ]},
		{"command":[ "SETTEXT", "「いつも、お前は私にプレゼントを渡してくるだろう？　……あちらの世界で\nも、こちらの世界でも、私にそんなことをするのはお前だけだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1003102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ・ダーク" ]},
		{"command":[ "SETTEXT", "「よって……礼をしたく思って呼んだのだ。……暗がりに、一緒に来てもらえ\nるか？　ああ、お前は何もしなくていい。私が一方的にするだけだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1003103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ・ダーク" ]},
		{"command":[ "SETTEXT", "「そこに立ってくれ。そして……ズボンを脱がして……。こうか？　ああ、そ\nれをもっとこちらに近づけてくれ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1003104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ・ダーク" ]},
		{"command":[ "SETTEXT", "「んっ……。これが……お前のイチモツなのか……。なるほど、初めて見るが\n興味深い……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1003105" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00000210_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ・ダーク" ]},
		{"command":[ "SETTEXT", "「想像より……重くて大きいものなんだな……。それに、少々臭う。これは尿\nの残り香か？　……色には個体差があると文献で見てはいたが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1003106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ・ダーク" ]},
		{"command":[ "SETTEXT", "「これが、お前の肉棒の色……。なぜだか、観察していると心臓の鼓動が早く\nなる……。……股間からは汗の臭い、そして……んっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1003107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ・ダーク" ]},
		{"command":[ "SETTEXT", "「更に肉茎が太く硬くなった。そうか……お前は見られていると興奮するのだ\nな。……構わない。好きなだけ勃起しろ。その方が私もやりやすい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1003108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ・ダーク" ]},
		{"command":[ "SETTEXT", "「突然何をするのか、だと？　決まっているだろう。これに、出来る限りの奉\n仕をさせてもらう。……私には感情がない。何も気にしなくていい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1003109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ・ダーク" ]},
		{"command":[ "SETTEXT", "「この世界の男が喜ぶ礼の仕方を、データベースで検索し、学習し、知識とし\nて蓄積している。安心して、受け取ってくれれば問題ない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1003110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ・ダーク" ]},
		{"command":[ "SETTEXT", "「少しずつ、触れていくから……痛かったらすぐに教えてくれ。……っふ……\n。まずは、手を……肉棒に添わせて……動かす……。ん……ん、ん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1003111" ]},
		{"command":[ "SETIMAGE", "0", "still_00000210_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ・ダーク" ]},
		{"command":[ "SETTEXT", "「多少指がもたつくのは……許容してほしい。やり方がまだよく、わかってい\nない……。……こう、か？　こうシゴいていって……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1003112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ・ダーク" ]},
		{"command":[ "SETTEXT", "「肉棒が萎えないように……硬くなるように、丁寧にいじる……。はぁ、はぁ\n……とてつもなく熱い……。汗で指が湿ってきた……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1003113" ]},
		{"command":[ "SETIMAGE", "0", "still_00000210_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ・ダーク" ]},
		{"command":[ "SETTEXT", "「……それにしても……この大きさ……。私が文献で調べたモノよりもかなり\n大きいような……。お前、名器とかいうやつなのか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1003114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ・ダーク" ]},
		{"command":[ "SETTEXT", "「手で握って動かすだけで……疲れるくらい太い……。それとも、私の技が未\n熟、なのか……はぁ、はぁ、はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1003115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ・ダーク" ]},
		{"command":[ "SETTEXT", "「う……すまない。初めて目の当たりにした肉筒に、少々我を忘れかけていた\n。ここからは冷静に……淡々と礼を……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1003116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ・ダーク" ]},
		{"command":[ "SETTEXT", "「ぁ……。やめろ……男根をヒクつかせるな。わかった。もっと手でシゴくの\nか……？　ん……、こうか……？　もっと……？　ふぅ、ふぅ、ふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1003117" ]},
		{"command":[ "SETIMAGE", "0", "still_00000210_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ・ダーク" ]},
		{"command":[ "SETTEXT", "「こ、こうか……？　結構強く握ってしまっているぞ……？　ん？　玉も舐め\nて欲しい？　玉……陰嚢……？　この、股間にぶら下がった袋か？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1003118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ・ダーク" ]},
		{"command":[ "SETTEXT", "「……わかった。お前がそれを望むのならば……異論はない。少し……腰を上\nげてほしい。うん……これがお前の陰嚢というものか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1003119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ・ダーク" ]},
		{"command":[ "SETTEXT", "「率直に言うと……不思議な球体だと、思う……。ん……他の部分よりも汗の\n……お前の臭いが強いかとは思うが……。……そうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1003120" ]},
		{"command":[ "SETIMAGE", "0", "still_00000210_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ・ダーク" ]},
		{"command":[ "SETTEXT", "「ここにも、性感帯はあるのか……。勉強が足りず、ここには注目していなか\nった……。肉竿にばかり集中していたから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1003121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ・ダーク" ]},
		{"command":[ "SETTEXT", "「優しく、歯を立てずに唇と舌でしゃぶればいいんだな？　……慈しむように\n……？　言う通りにしてみよう……。ん……ふにふにしている……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1003122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ・ダーク" ]},
		{"command":[ "SETTEXT", "「では……しゃぶるぞ……。ゆえに気をつけて……しかし大胆に攻める……。\nんっ……ちゅ、ちゅ……、軽く表面に……振動を加え……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1003123" ]},
		{"command":[ "SETIMAGE", "0", "still_00000210_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ・ダーク" ]},
		{"command":[ "SETTEXT", "「そこから舌で……ぴちゃ……。ぴちゃ、ぴちゃ……ん……。皺が……。ぷち\nゅ……れる……ぴちゅ……ぴちゃっ……ぴちゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1003124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ・ダーク" ]},
		{"command":[ "SETTEXT", "「唇で……挟んだり……口の中で転がしたり……。はむ……くちゅ……くちゅ\n、ちゅぷ、ぷっちゅっ……舌全体れぇ……舐めまわひたり……れろれろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1003125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ・ダーク" ]},
		{"command":[ "SETTEXT", "「へ……変な感触だ……。れろ……れろ、くちゅ……もご……くっちゅっ、ち\nゅる……ちゅっぷっちゅぷちゅぷっちゅっぷ……んんんん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1003126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ・ダーク" ]},
		{"command":[ "SETTEXT", "「むぅ？　なんら……？　玉だけれはなく竿もねぶれ……？　わかった……。\nはぁっ……口に入りきるか……自信がないが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1003127" ]},
		{"command":[ "SETIMAGE", "0", "still_00000210_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ・ダーク" ]},
		{"command":[ "SETTEXT", "「ぐ……ちゅっ！　んむ……むぅううっ、んむぅ……。うくっ……！？　の、\n喉につかえて……上手くできな……！　もごっ、んぐぅっ、うう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1003128" ]},
		{"command":[ "SETIMAGE", "0", "still_00000210_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ・ダーク" ]},
		{"command":[ "SETTEXT", "「そ、それがキツくていい……？　う、ぁ……あっ……♪　そ、そうか……そ\nれならこのままつづけ、るぅ……。くちゅっ……んぷ、はぷ……んむぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1003129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ・ダーク" ]},
		{"command":[ "SETTEXT", "「おえっ……く……くるひい……。れも……、れも、これは、礼、だから……\nぁ。やめ、ない……絶対に……！　くぷっ……ちゅぷ、ぷっちゅっ、ちゅく」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1003130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ・ダーク" ]},
		{"command":[ "SETTEXT", "「あふ……んふぅ……！　くっちゅっ……！　れろ……ぢゅぷっ、ぐっちゅっ\n……ぬちゅっ……！　ぷちゅっ！　ぬっちゅっ、ぐっちゅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1003131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ・ダーク" ]},
		{"command":[ "SETTEXT", "「わ……わたひの息はそう長くもた、ない……。射精ぃ……ひゃへい出来るタ\nイミングがあれば、すぐに出ひてほひい……！　い、いくぞ……ぉっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1003132" ]},
		{"command":[ "SETIMAGE", "0", "still_00000210_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ・ダーク" ]},
		{"command":[ "SETTEXT", "「口内を密着ひゃへてぇえ……♪　喉を締めて、肉棒に奉仕……ほうひぃ……\nっ♪　ぐちゅっ！　ずっちゅっぐちゅっ、ぢゅるるるる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1003133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ・ダーク" ]},
		{"command":[ "SETTEXT", "「ぐちゅっ、ぐっちゅっ、ぐちゅ……！　んんん……！　はやく……ぅ、はや\nく、出へ……っ。んっ、むぅっ！　ぐちゅっ、ぐちゅッ、ぐっちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1003134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ・ダーク" ]},
		{"command":[ "SETTEXT", "「おほっ……！？　い、いいろ……いいぞぉ……！　どんどん肉棒が熱く、太\nくはりつめて……んむぁあああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1003135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ・ダーク" ]},
		{"command":[ "SETTEXT", "「んっ！？　うっ、うくぅううう……！　んむぅううううう……！　ンッ！　\nんんっ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1003136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000210_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ・ダーク" ]},
		{"command":[ "SETTEXT", "「あっ！？　ひゅ、ひゅまない……すまないぃい……っ……！　口れ……喉で\n受け止めるつもりが……！　ぁっ……勢いが強すぎて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1003137" ]},
		{"command":[ "SETIMAGE", "0", "still_00000210_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ・ダーク" ]},
		{"command":[ "SETTEXT", "「唇から外れてひまった……！　あっ……、うぅ……！　ふ、不甲斐ない……\n！　せめて、せめて詫びにたっぷり顔にかけてくれ……ああああ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1003138" ]},
		{"command":[ "SETIMAGE", "0", "still_00000210_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ・ダーク" ]},
		{"command":[ "SETTEXT", "「う……ぷぁ……。あ……、く、口に入って……。……苦い……！　あ……っ\n、ドロドロと舌の上に……。ん、ぁ……ふぅうう……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1003139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ・ダーク" ]},
		{"command":[ "SETTEXT", "「おぇっ……！　こ、これは強烈な味ら……。で、でも……お前の汁ならば…\n…耐えてみせる……。ああ、大丈夫……だ、すぐに慣れる……はず」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1003140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ・ダーク" ]},
		{"command":[ "SETTEXT", "「それより、この……蜘蛛の巣のようにべったりと張り付く粘着力に関心した\n。人の肌にこれほど密着して、顔が……私の顔が……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1003201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ・ダーク" ]},
		{"command":[ "SETTEXT", "「予想外の場所に出されてしまったのか、だと？　別に……どこに出してもい\nいが……勘違いをしてほしくない事は一つある……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1003202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ・ダーク" ]},
		{"command":[ "SETTEXT", "「……顔に射精させてしまったのは、まぎれもなく私のミスだ。忍に失敗は許\nされない……。頼む。今一度私にチャンスを。リベンジ……させてほしい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1003203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ・ダーク" ]},
		{"command":[ "SETTEXT", "「今度はきちんと礼を果たす。……つまり……口でお前の精を受け止め、喉に\n流し込み……最後の一滴まですすりとり飲み干すことを……誓う……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1003204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ・ダーク" ]},
		{"command":[ "SETTEXT", "「……いいか？　では……また陰嚢ねぶりから……始めさせてもらう……。失\n礼する……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1003205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ・ダーク" ]},
		{"command":[ "SETTEXT", "「れろぉ……。えろっ……れろ……れる……ぴっちゃっ、くちゅ……ぴっちゃ\nっ……。れろッ……れろ……れろれろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1003206" ]},
		{"command":[ "SETIMAGE", "0", "still_00000210_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ・ダーク" ]},
		{"command":[ "SETTEXT", "「はぁ……っ。飛び散ったままの精液の残滓ごと、お前の陰嚢を舐めてしゃぶ\nっているぞ……。よく見ていろ……。ぴちゃっ、ぴちゃぴちゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1003207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ・ダーク" ]},
		{"command":[ "SETTEXT", "「っぺろっ……れろっ……、んん、やはり苦い……っ。ちゅぷ……くっちゅっ\n、ぺちゃっ、ぴっちゃっ……ぴちゃ……。舌が熱い？　そうだ、な……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1003208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ・ダーク" ]},
		{"command":[ "SETTEXT", "「それが気持ちがいいのなら……もっと陰嚢に絡みつけてやる……。んれろぉ\n……れろっ、れろ……れろっ、れろぉおお……れろぉぉ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1003209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ・ダーク" ]},
		{"command":[ "SETTEXT", "「少々強めに……ぃ、吸引して……口の中れ転がすぅ……。んっ……くちゅく\nちゅくちゅ……っ。ちゅぷちゅぷちゅぷ……ぢゅるぢゅる……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1003210" ]},
		{"command":[ "SETIMAGE", "0", "still_00000210_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ・ダーク" ]},
		{"command":[ "SETTEXT", "「待、て……腰を引くな、次はこのまま……！　このまま竿だ……。覚悟する\nんだな……。あーん……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1003211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ・ダーク" ]},
		{"command":[ "SETTEXT", "「ぐっちゅっ！　んっ……！　二度目は上手く咥えられ、ら……！　いいぞ、\n最初から最高速度でしゃぶり尽くひゅ……！　ぐっぽっ！　ぐっぽっぐぽっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1003212" ]},
		{"command":[ "SETIMAGE", "0", "still_00000210_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ・ダーク" ]},
		{"command":[ "SETTEXT", "「んちゅぅううう……！　れろっ……れるぅっ……れる……！　じゅっぷっ、\nぶっちゅっぶちゅっ……ぬっちゅっ……！　ど……どう、だ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1003213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ・ダーク" ]},
		{"command":[ "SETTEXT", "「気持ちいいのか……、そうか……。ならば継続する……。あ、む……ぐちゅ\nっ！　にゅぷっ……ぷちゅ……れろれろれろ……ずっちゅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1003214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ・ダーク" ]},
		{"command":[ "SETTEXT", "「はぁっ……ずっちゅっ……！　私の唾が……お前のイチモツに馴染んで、き\nたら……冷静にバキューム……。っぢゅるるるっ、ぢゅるるるぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1003215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ・ダーク" ]},
		{"command":[ "SETTEXT", "「うっ……喉奥に刺さる……。ぢゅる……なんて……なんて長い肉棒、なんら\n……っ。ぐっちゅっ……！　ぐちゅっ、ぢゅる……ぬちゅっ、ぢゅるぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1003216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ・ダーク" ]},
		{"command":[ "SETTEXT", "「てらてらと……ぬめり輝いて……卑猥すぎる……。っぢゅーーーーーっ、ぢ\nゅるっ！　ぐちゅっぷっ、じゅるっ、ぢゅるぅ……ぢゅるうう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1003217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ・ダーク" ]},
		{"command":[ "SETTEXT", "「っふぅっ……子種が……ぢゅるっ、子種があがってきているなら……ぢゅる\n、素直に精子を吐き出ひてひまえ……。ぢゅるっ、ぢゅるるるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1003218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ・ダーク" ]},
		{"command":[ "SETTEXT", "「今回、は、苦ひくないから……。思い切り出されへも……死んらりひないか\nら……わたひの礼を受け取って、くれ……一気に吸い上げるろ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1003219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ・ダーク" ]},
		{"command":[ "SETTEXT", "「っぢゅっぽっ！　じゅぽっ、じゅっぽっじゅっぽっ！　ぢゅるるるるる、ぢ\nゅるるるる……今だ！　ありったけの子種を出すんだ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1003220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "カグヤ・ダーク" ]},
		{"command":[ "SETTEXT", "「ふぅっ！？　むぅっ……んむッ……！　んぐ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1003301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000210_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ・ダーク" ]},
		{"command":[ "SETTEXT", "「うぁ、あ……ぁ、溺れる……っ。精液の弾丸を何発も撃ち込まれているみた\nいだ……。あっ……うっ、うぅ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1003302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ・ダーク" ]},
		{"command":[ "SETTEXT", "「んんんんん……っ。……ん、ぁ……こんなに大量に……。だが、わたひはお\n前と約束、ひた……。全ての精液を口で受け止めて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1003303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ・ダーク" ]},
		{"command":[ "SETTEXT", "「最後の一滴まで飲み干すと……。……ごくんっ……。あぁ……だめだ、一度\nではまるで飲みきれない……。私の唾と混ぜて……くちゅ、くちゅ、ごくっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1003304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ・ダーク" ]},
		{"command":[ "SETTEXT", "「ん、ん……んくっ……ごくっ……ごきゅ……。……はぁぁあっ……、息が精\n子臭い……。舌がネトネトする……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1003305" ]},
		{"command":[ "SETIMAGE", "0", "still_00000210_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ・ダーク" ]},
		{"command":[ "SETTEXT", "「しかし……今度はきちんとお前の汁を無駄にせず……受け取った。いずれ、\nお前の子種は私が消化する……。……う、腹が重い……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1003306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ・ダーク" ]},
		{"command":[ "SETTEXT", "「これは……長く身体の中に残りそう、だ……。……ある意味……私は今、お\n前の子の種に……内側から、腹から支配されているのかもしれないな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1003307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ・ダーク" ]},
		{"command":[ "SETTEXT", "「……なんだ？　急にホラーな事を言うな……？　私は冗談を言ったつもり\nだったが……。何？　真顔で淡々と言うから怖かった……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1003308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ・ダーク" ]},
		{"command":[ "SETTEXT", "「けふっ……。これだけの量の精液を飲んだ後に、笑顔で話せる者などいるか\n……。うぷ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1003309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ・ダーク" ]},
		{"command":[ "SETTEXT", "「私がこんなことをするのは、お前が最初で最後だ……。慣れるまでは、こっ\nちにも余裕なんてない……。飲み方はこれから習得していく。いいな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1003310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "カグヤ・ダーク" ]},
		{"command":[ "SETTEXT", "「あっ……う、ぁ……あぁ……！　ま、また……。……あっ……、う、うぁ…\n…あ……っ、うう……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1003401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000210_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ・ダーク" ]},
		{"command":[ "SETTEXT", "「失敗してしまった……。ぁっ……また顔に……！　に……二度目はもっと、\n精液が控え目に出ると思っていたから……。……あ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1003402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ・ダーク" ]},
		{"command":[ "SETTEXT", "「こんな、に……浴びるほど出るとは……不覚……。あっ……、い、いいぞ…\n…罰の代わりに、思う存分、子の種をこの顔に……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1003403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ・ダーク" ]},
		{"command":[ "SETTEXT", "「く……ふ……、熱い……。頭にモヤがかかったような……目の前に霞がかか\nったような……不思議な気持ちだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1003404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ・ダーク" ]},
		{"command":[ "SETTEXT", "「……あ……♪　答えたくなければ……答えなくてもいいが、これは……私の\n礼に……。私に興奮したから、こんな量が出たと思っていいのか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1003405" ]},
		{"command":[ "SETIMAGE", "0", "still_00000210_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ・ダーク" ]},
		{"command":[ "SETTEXT", "「そう、か……。いや……それならば、未熟と知りながら口で奉仕をした意味\nがあった……。ああ……それにしても、シャワーのごとき濁流……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1003406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ・ダーク" ]},
		{"command":[ "SETTEXT", "「ぬめぬめとして、白く……。一体この汁にどれほどの子の種が泳いでいるの\nか……。あ……ッ、顔から垂れて……。あぁ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1003407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ・ダーク" ]},
		{"command":[ "SETTEXT", "「ゾクゾクする……。初めて触れた精液が、こんな風にぶちまけられたもので\n……。こんなにあたたかくて、臭いなんて……驚愕した……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1003408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ・ダーク" ]},
		{"command":[ "SETTEXT", "「……まだ、この汁を好きかどうかはわからない……。でも……またお前に、\nこうして礼をするのは……悪くないとも、思う」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1003409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ・ダーク" ]},
		{"command":[ "SETTEXT", "「お前。もっと……私に贈り物をしろ。そうしたら……そうだな。また礼とし\nて、今日のように……。うん、今度は成功出来るよう、精進しておくぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1003410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}