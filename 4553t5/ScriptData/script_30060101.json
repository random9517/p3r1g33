		{"command":[ "PLAYVOICE", "006_0103308" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「オチンチンはまだ固いままみたいだしぃ……まだまだ、全然出し足りないわ\nよねぇ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0103309" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「んっふふ～、あなたってホントにＨなお猿さんなんだから……ダイヤナちゃ\nんのおっぱいで興奮しすぎよぉ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0103310" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「最後の一滴まで、あたしが絞りとってあげるわ……だからもっと見せて……\nあなたの情けなくてだらしなぁい、Ｈな顔を……もっと見せてぇ……！」", "NORMAL" ]},
