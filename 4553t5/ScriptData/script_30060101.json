{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "PLAYVOICE", "006_0103101" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「こんなところに呼び出して、いったい何の用事かしらぁ？　なぁ～んて、ど\n～せまたＨなこと考えてるんでしょうけどぉ？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0103102" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ダイヤナちゃんがゴージャスで美人でカワイイから、ついついイヤらしいこ\nとシたくなっちゃうのよね、わかるわぁ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0103103" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「でも、ダ～メ。だって、ダイヤナちゃんはあなたみたいに貧相な男って、好\nみじゃないんだもん♪」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0103104" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あんまりお金も持ってなさそうだし～、ど～せなら、たっくさん宝石を贈っ\nてくれるような、ゴージャスな男の人じゃないと～」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0103105" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「顔はまぁまぁ悪くないから、もっとお金を稼げるようになったら、おっぱい\n触らせてあげるくらいは、考えてあげてもいいかしら？　なぁんて～……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0103106" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「……だ、誰が頭空っぽのホルスタイン女ですってぇ～！？　失礼しちゃうわ\n、女の子をそんなふうに言うなんて、サイテーよ！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0103107" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「無駄に大きすぎるって、昔からバカにされてばっかりで……気にしてるのに\nぃ……くすん……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0103108" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「……って、ひぃっ！？　オチンチン、すごくおっきくなってる！？　……も\nしかして、ダイヤナちゃんのおっぱいを見て、興奮しちゃったの？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0103109" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「そ、そうなの……ふ、ふ～ん……男の人はおっきなおっぱい好きって本当だ\nったのね……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0103110" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ちょ、ちょっとだけ……しょうがないから、ちょっとだけなら、してあげて\nもいいわよ？　それで、ナニをしてほしいのかしら？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0103111" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「オチンチンを両側からおっぱいで挟んで……んしょ、これでいいのかしら？\n　こんなのでホントに気持ちいいの～？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000601_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0103112" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「やんっ！　オチンチンがおっぱいの間でびくびくして……カチカチに固くっ\nて、熱くって……これって、興奮してるってことかしらん？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0103113" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あなたってホントに、おっきなおっぱいが好きなのね……んふっ、悪い気は\nしないわ……それで、この後はどうすればいいの～？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0103114" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「このままでいいの？　あなたが自分で動くから、オチンチンをぎゅぎゅ～っ\nて、挟んでいればいいのね？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0103115" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「んんっ……オチンチンがおっぱいの間から、出たり入ったり、あんっ、すご\nくイヤらしい……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000601_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0103116" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「まるでおっぱいにオチンチンを挿入されちゃってるみたい……お猿さんみた\nいに、夢中で腰を振っちゃってぇ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0103117" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「そんなにダイヤナちゃんのおっぱいが気持ちいいのぉ？　あんっ、も～、あ\nなたってホントにＨなことがだ～い好きなのね」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0103118" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「んんっ、オチンチンの先っぽから、Ｈなお汁がでてきて……やぁんっ、おっ\nぱいの中がヌルヌルになっちゃう」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0103119" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「オチンチンを、こんなにガチガチに勃起させちゃってぇ……あんっ、興奮し\nすぎ♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0103120" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あふんっ、オチンチンのデコボコがおっぱいの間をヌルヌル擦ってぇ……あ\nんっ、私まで変な気分になってきちゃう」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0103121" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「んふ……しょうがないからぁ、ダイヤナちゃんも、ちょこっとだけ、オチン\nチンが気持ちよくなるお手伝いをしてあげようかなぁ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0103122" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「オチンチンの動きにあわせてぇ、両側からおっぱいを、ぎゅむぎゅむ～って\nしたら、んん～っ……どう？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000601_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0103123" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「やんっ、だらしない顔しちゃって、オチンチン気持ちいいの？　んっふふ、\nいいわよぉ、じゃあも～っとしてあげる、え～いっ♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0103124" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あとはねぇ、おっぱいでオチンチンを挟んだままぁ、互い違いにスリスリぃ\n～って擦るのは、どぉかしら？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0103125" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「やぁんっ、これも気持ちいのね？　ただでさえ貧相なお顔が、もぉ～っとみ\nっともないお顔になっちゃってるわよぉ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0103126" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「鼻の穴をぴくぴくふくらませてぇ、すっごく情けない顔……もうダイヤナち\nゃんのおっぱいに夢中って感じね」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0103127" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「オチンチンもぉさっきより固くってぇ、あんっ、太くなっちゃってる……\nもしかして、射精しちゃいそうなのかしら？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0103128" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「んっふふ～、そうなのねぇ～？　じゃあ、もっと激しくしてあ・げ・る♪　\nえぇ～いっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0103129" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「オチンチンをおっぱいで、たぁ～くさんゴシゴシされてぇ、気持ちよくなっ\nちゃいなさい！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000601_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0103130" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「みっともない顔でぇ、オチンチンの先っぽから精液を、ぴゅっぴゅってしち\nゃいなさい？　ほらほら、イって、イきなさい……イっちゃえ～！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0103131" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「きゃああんっ！？　やんっ、あぁんっ、すごぉいっ！　おっぱいの中に、ド\nロドロの精液が出てるぅ……！」", "NORMAL" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000601_01_05" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0103132" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「オチンチンが、びくんびくんってするとぉ、先っぽから熱々のザーメンがび\nゅく、びゅくぅって……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0103133" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「やぁんっ、今のあなた、すっご～くみっともない顔してるわよ？　イヤらし\nくて、情けなぁ～いお顔♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0103134" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ダイヤナちゃんのおっぱいに射精するのが、そんなに気持ちいいの？　んっ\nふっふ～、じゃあ、もっと絞ってあげる♪」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000601_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0103135" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「射精中のオチンチンを、おっぱいでぎゅっぎゅ～って挟んで、精液を根本か\nら搾り取ってあげる」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0103136" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「だからもっと出しちゃっていいのよ？　タマタマが空っぽになるまで、残ら\nず精液をおっぱいの中に出しちゃって、ほらほら～」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0103137" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ダイヤナちゃんのおっぱいに射精サポートされてぇ、Ｈなザーメンをい～っ\nぱいコキ捨てちゃいなさぁい！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0103138" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「……あらん？　もしかして、終わりなのかしら？　ふぅん、そうなの。もう\nちょっと出るかと思ったんだけど……ガッカリね」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0103139" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「男の人って思ったよりお手軽なのね～。オチンチンをちょっと擦っただけで\n、簡単にぴゅっぴゅ～って出ちゃうんだもの」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0103140" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「……あ、それともぉ、あなただから、かしら？　そっかぁ～、やっぱりダメ\n男ちゃんはオチンチンもヘタレなのね～」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000601_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0103201" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「やぁん、怖い顔！　でもぉ、そんな顔をしたって、あなたのオチンチンが弱\n々オチンチンなのは、かわらないと思うけど～？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0103202" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「んふ～、悔しいんだったらぁ、もっとオチンチンから精液を出してみたらど\nぉ～お？　もちろん、まだ出るのなら、だけど」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0103203" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あんっ！　おっぱいの中で、オチンチンがビクビクして……あぁん、また固\nくなってきちゃった。ヤる気マンマンみたいね♪」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000601_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0103204" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ナマイキなオチンチンは、またダイアナちゃんが、このおっぱいで搾り取っ\nてあげるわ～！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000601_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0103205" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「今度こそ、タマタマの中身が空っぽになるまで、射精させちゃうから、覚悟\nしなさぁい！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0103206" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あぁん、おっぱいの間がさっき出された精液でぬちゃぬちゃして、あんっ、\nＨな音がいっぱい鳴っちゃってるぅ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0103207" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「でもぉ、ヌルヌルして滑りが良くなったから、さっきよりもも～っと激しく\n、オチンチンをシゴいてあげられそう♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0103208" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ほぉ～ら、どぉ～お？　キツキツのおっぱいにオチンポを挟まれて、ジュポ\nジュポ、出したり入れたりされるの、気持ちいいでしょ～？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0103209" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「んっ、あんっ、おっぱいの間、ヌチャヌチャで、まるでオマンコに挿れてる\nみたい……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0103210" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ね～ぇ？　ホントはこのオチンポで、ダイヤナちゃんのオマンコ、ズポズポ\nしたかったんでしょ？　正直に言ってみなさい？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000601_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0103211" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「んっふふ～、でもダ～メ。あなたみたいなダメダメ男がダイヤナちゃんのオ\nマンコをハメハメできるわけないでしょ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0103212" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ヘタレちゃんはおっぱいでオチンチンを搾り取られてぴゅっぴゅしてるのが\nお似合いよ～」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0103213" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「こんな貧相なオチンポを、おっぱいマンコでシゴいてもらえるだけ、ありが\nたいと思いなさ～い！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0103214" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「やぁああんっ、その顔……！　いいわぁ……女にバカにされて、屈辱にまみ\nれる男の顔……それが見たかったのぉ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0103215" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「もっとその顔を見せて……ダイヤナちゃんのおっぱいにオチンチンをシゴか\nれて、もっと情けない顔をいっぱいみせなさ～い！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0103216" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「んふふ～、悔しい？　でもね、あなたのオチンチンがダサダサの弱々オチン\nチンだから悪いのよ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0103217" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「おっぱいでちょっと擦られただけで、ぴゅるぴゅる～って精液をおもらしし\nちゃう、情けな～いオチンポだからなのよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0103218" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「そんなヘタレちゃんはねぇ、切なそうにオチンチンをふくらませながら、お\nっぱいに精液を絞り取られるのがお似合いよっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0103219" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ほ～ら、オチンチンがまたカチカチに固くなってきちゃった……さきっぽが\nぷっくりふくれあがって、もうイっちゃいそうなんでしょ～？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0103220" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「いいわよぉ、ダイヤナちゃんのおっぱいに挟まれて、情けなくイッちゃいな\nさい！　オチンポから白いオシッコをぴゅっぴゅしちゃいなさいっ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},
		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "PLAYVOICE", "006_0103301" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「きゃあんっ！　あんっ、あぁんっ！　おっぱいの中に、またぁ、熱い精液が\n、びゅくびゅくぅって、出てるぅ……！」", "NORMAL" ]},
