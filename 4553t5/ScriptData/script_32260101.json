		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「どういうつもりかって？　地球の男は、おっぱいが好きなんだろ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0103101" ]},
		{"command":[ "SETCHARA", "0", "char_00022601_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「おまえには結構世話になってるし、特別サービスしてやるよ。ほら、あたし\nのおっぱい……嬉しいだろ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0103102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「ほれほれー？　遠慮せず見ていいぞ。それにしても、地球の男は変わってる\nな。これで何ができるんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0103103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「……は？　見るだけじゃないのか？　じゃあ、どう……ちょ、ちょっ……！\n　なんでズボンを脱いでるんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0103104" ]},
		{"command":[ "SETCHARA", "0", "char_00022601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「お、おいっ……！　チンポをこっちに向けるな……！　しかもどうして勃起\nして……やめ……きゃあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0103105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「な、なんなんだ……これ……なにをしているんだ？　あたしの上に乗るな…\n…さっさと、どけ……んっ、んんぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0103106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00022601_01_02" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「くっうぅっ……！　チンポを、押しつけるな……！　は、はあ？　これが…\n…本当のおっぱいの使い方？　ウソだろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0103107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「こんなこと、して……なんの意味がある……んっ、んんっ！　チンポを、\n擦りつけるな……くっ、ううっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「パ、パイズリ……？　なんだそれは……地球人はみんなこれをしてるのか？\n　ウソだろ、胸で……こんな……んっあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「はあ？　怖いわけないだろ。あたしが、こんなモノにビビるか……！　おま\nえがヤリたいなら、勝手にすればいい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「あ、ああ……おまえには世話になってるって言っただろ。だから、喜ぶって\n聞いたから、おっぱい……見せてやったんだし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0103111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「それでおまえが満足するんなら、好きにしていい……あっ、んっ！　んっ、\nはぁあ……そんな激しく、するな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「好きにしていいけど……あんま強く、擦るな……ンっ、あ、熱い……チンポ\n、なんでこんなに熱いんだ……はあ、んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0103113" ]},
		{"command":[ "SETIMAGE", "0", "still_00022601_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「気持ちいい、のか？　こんなこと、して……？　本当に地球人は、よくわか\nらない……んっ……あっ……あふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「あたしには意味がわからないが……こんなに勃起してるってことは、本当に\n気もちいいんだろうな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0103115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「チンポ、反り返ってて……ガチガチに硬くなって……んっ……先端もパンパ\nンで……威圧感が、すごい……ンあっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0103116" ]},
		{"command":[ "SETIMAGE", "0", "still_00022601_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「はぁ、はっ……んんぅ……だ、だから、いちいち怖くないとか言わなくてい\nい……！　こんなモノこわくもなんともない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「お、おまえが……さっきから激しく、あまりにも強く擦りつけてくるから、\nちょっと驚いただけだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「ああ、好きに動いていいって言ってるだろ……でも加減はしろよ……？　\nんっ……んんっ、強すぎると痛いから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「はぁっ……あ、ふぅ……これくらいなら、まあ……あっ、あんっ……でも、\nやっぱりチンポが熱いから、胸も熱くなってしまう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「ンっ、んんっ……大丈夫だ、わかってる……今さらやめさせるなんて、野暮\nなことはしない、から……んっ……あふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「はあ？　なんで、あたしが気持ちよくなるんだ……？　おまえが、気持ちよ\nくなればいい……だけだ……ンふぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「はっ……ふっ……こ、声は、おまえが、チンポ擦りつけてくる……から……\nんっ、んっ……勝手に、出るだけで……はんっ、んっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「おっぱいに、意識を集中しろとか言われても……意味、わからない……あっ\n、あ、んっ……くっ、ふうっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「ねえ……そんなことより、なんか先っぽから……ンっ……出てきてる、が…\n…射精、したのか？　ヌルヌルしてる、し……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「あ、ああ……が、我慢汁ね……知ってるに決まってるだろ……は、あぁっ…\n…すごい量だし、ねばねばしてるから勘違いしただけ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「んんっ……ほら、あたしのおっぱい……谷間が、ぬるぬるになって……んっ\n、チンポからどんどん出てくるし……んぅうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「でも、これ……もうすぐ射精しそうってことだろ？　んっ、ンンっ、あんっ\n……ああ、遠慮せず……射精していいぞ……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「え？　あ、あぁ……まあ滑りもよくなってるし……さっきより強くしても、\n痛くないとは思うが……んんっ！　あっ、ふうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「そんな早く動いたら……ンぅうっ！　はっ！　あぁっ……あっ、あはぁんっ\n……！　おっぱい、熱いっ……くっうぅんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0103130" ]},
		{"command":[ "SETIMAGE", "0", "still_00022601_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「き、急に……必死に……んっあっ！　腰、振りたくって……あぁっ……これ\nが、いいのか？　んはあぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「もう、射精……する？　いいぞ……胸にっ……このまま出してっ……！　\nあっ、あっ……すごいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「くっ、はっあっ……！　はっ、ああっ！　いい、出していいから……！　\nんっあっ！　んあぁぁぁぁぁぁぁ～～～～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「あ、ああぁっ！　びゅくびゅく、いってるっ……！　なんだ、これ……すご\nいっ……！　出てる……おっぱいの中に熱いのがっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0103134" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022601_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「はぁっ、あっ……あふっ！　好きなだけ、思いっきり出して……んっあっ！\n　おっぱい中出し、して……くぅんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0103135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「あぁンっ……あ、熱いっ！　おっぱい熱くて……くっ、ううっ……まだ出る\nのか……あっあはぁ……んんぅぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0103136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「はぁ、はっ……はあっ……はーっ……はぁ、はぁぁぁぁ……ンはぁ……これ\nが射精……勢いすごすぎて、びっくりした……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0103137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「こんなに出るものなんだな……んっ、それだけあたしのおっぱいが気持ち\nよかったのか？　うん……それならよかったが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0103138" ]},
		{"command":[ "SETIMAGE", "0", "still_00022601_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「え？　あ、あぁ……確かに……おまえのチンポ……大きくなったままだな…\n…射精したら、小さくなるんじゃないのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「満足するまで射精させればいいのか？　なら、続けていいぞ。んっ……おま\nえの気が済むまでおっぱい使えばいい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「はぁあっ、んっ！　い、いきなり……ペース速くないか？　あっ……あふっ\n……んぅんっ……チンポ、擦れてるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0103201" ]},
		{"command":[ "SETIMAGE", "0", "still_00022601_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「ンっ、くっ、うぅぅっ……今、出したザーメンが、絡みついて……にちゅに\nちゅって……イヤらしい音が……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「お、おまえは……自分の精液が、チンポについてるのに……んっ……気に、\nしないのか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0103203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「確かに滑りはよくなっているが……こんな、ことも気持ちいいのか？　本当\nに不思議だな、地球の男は……あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0103204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「ンはぁっ……あんっ……だから、あたしは……べつに……んっあっ……気持\nち悪いってわけじゃないが……それだけだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「はあ？　乳首が勃ってる……？　知らんっ……気のせいだろっ……くっ、\nふぅう……そうだとしても、身体が勝手に反応してるだけだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「んぅっ、ンンっ……！　ただ……そうやって、テンポよく……ズリズリって\n、チンポで擦られて……胸は、熱いが……ンンぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「はあっ、あっあんっ……くっ、ううっ……い、意識したら、余計に胸が熱く\nなってきた気が、するぅ……んはぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「お、おい、嬉しそうな顔、して……チンポ擦りつけるな……くうっ！　はぁ\n、あっ……あっ、あんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「言うっ……正直に言うから、ちょっと待って……んんっ！　んはっあっ！　\n乳首にまで、擦りつけるなぁ……あっ、あんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0103210" ]},
		{"command":[ "SETIMAGE", "0", "still_00022601_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「さっきから、ちょっと……いいかも、って感じは……してた……んっ……\nちょっとだけだけど！　でも……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「精液も……クサくて、蒸れた匂い……鼻が変になりそうだったのに……なん\nか、頭がボーっとしてきて……あたし、おかしくなってる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0103212" ]},
		{"command":[ "SETIMAGE", "0", "still_00022601_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「はっ、あんっ……そうやって、強くおっぱい擦られると……チンポで、刺激\nされるとぉ……おっぱい疼くぅ……んうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「あんっ、はぁ……はっ……はあっ……そうやって、おっぱい……揉みながら\n、されると……はぁ、あっあっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0103214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「おっぱい、どんどん気持ちよく……なってくぅっ……！　くっ、ひっ……\nひぃあっ……あんっ！　あはぁんっ！　あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0103215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「ンぅぅっ！　はんっ、あんっ！　くはぁんっ……！　ま、また、出るのか？\n　いいっ……出していい、からっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0103216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「はっ……！　んっ！　あっはっ！　あたしのおっぱい、使って……気持ちよ\nくなってっ……射精、していいからぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「あ、熱いっ！　チンポが、谷間で暴れて……おっぱい擦れてぇ……！　んっ\nあぁぁっ！　あっ……あんっ！　はぁあんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0103218" ]},
		{"command":[ "SETIMAGE", "0", "still_00022601_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「いい、いいから……出してっ！　おっぱいにかけていいっ……あっんあっ！\n　んっ、んんっ！　はぁっ！　ああっ、んうぅぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「はっはっ……！　は、激しいっ！　はひっ！　はっあっ！　精液、出してっ\n！　出してぇぇっ！　んっ、んはぁぁぁぁぁっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「ひゃあ！　あっ、あんっ！　ひっ、ひうっ！　んっ！　んあっ！　あっあぁ\nはぁぁぁ～～～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0103301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022601_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「んんっ……ひぃンっ！　すごい出てるっ……またおっぱいの中で、チンポが\n……暴れてっ……ひぃいっ！　はっ、あぁっ、あぁんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「くっうぅ、ううっ……んはぁっ！　さっき、あれだけ出したのに……まだ\nこんなに出るのか……くうっ……んっ、ああっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0103303" ]},
		{"command":[ "SETIMAGE", "0", "still_00022601_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「はぁああ……あんっ、あぁっ……精液、熱くって……胸が……あぁんっ……\nもっと、熱くなってくっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0103304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「んあっ……！　あっ……あふうっ……はぁぁ～～～……おっぱい、ぐちょ\nぐちょ……なってる……んんぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0103305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……はぁ……ホントに遠慮なく、出してくれちゃって……んっ、\nおまえが気持ちよかったなら、いいけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0103306" ]},
		{"command":[ "SETIMAGE", "0", "still_00022601_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「わ、わかった……おまえがおっぱい好きなのは、わかったから……そんなに\n褒めるな……照れるだろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0103307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「これからもして欲しいのか？　そんなに気に入ったのか……？　どれだけ\nおっぱい好きなんだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0103308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「まあ……あたしも、おっぱい気持ちよかったし……これ、悪くはないかな\nって……思ったけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「……だから、いいよ。おまえの頼みなら……いつだって、相手してやるよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「んっああっ！　そんなに腰、突き出すなっ……！　ちか、近いっ……チンポ\n、近いっ……あっあっ！　んっあぁぁ～～～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0103401" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「ひぃああぁぁぁっ！　ひゃっ！　あっ、あふっ……！　んあっ！　急にっ…\n…！　くひぃいいっ！　ひぃいんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0103402" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022601_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「なにやってんだっ……！　おっぱいに、出すって……ひっ！　バカっ……\n顔にかかって……ひゃうっ！　んっんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0103403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「ンぶっ！　顔、ベチャベチャ……なってるっ……！　出していいって、言っ\nたけど……ぶっ、んっ……出し、すぎっ……ぷはっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0103404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「さっき、あれだけ出したのに……んうっ……どれだけ、出るんだ……ひっ、\nんっ……くふぅうっ……はぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0103405" ]},
		{"command":[ "SETIMAGE", "0", "still_00022601_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「はぁはぁ……はっ、はぁ……満足、したか？　はぁ……はぁ……まったく…\n…人の顔を、こんなに汚してくれて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0103406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「それだけあたしのおっぱいが気持ちよかった証拠なのか？　おまえが喜んで\nるなら、よかったけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0103407" ]},
		{"command":[ "SETIMAGE", "0", "still_00022601_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「あたし？　そりゃ、まあ……悪い気分じゃないっていうか……おっぱいは、\n気持ちよかったし……べつに怒ってなんかない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0103408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「ああ。おまえがしたいなら、またしていいよ。あたしのおっぱいいつでも\n使わせてやるから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0103409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「お、お礼とかいいんだよ……改まって言われると照れるだろ。まあ……それ\nだけ気に入ってもらえたら、あたしも嬉しいし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_0103410" ]},
		{"command":[ "WAITINPUT" ]},
