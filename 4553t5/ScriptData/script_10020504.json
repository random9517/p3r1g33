{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0162" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_013" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "明日楽が学園長室で監禁状態のため、帰りのホームルームは俺が担当すること\nになった。", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「それじゃあホームルームを……」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「…………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020113450001" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "始めようとしたところで、教室に明日楽が入ってきた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「だ、大丈夫か？　顔色が悪そう……というか、悪いぞ」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「ふふ、平気です……。それよりも、これを……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020113450002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「おお、これは新しい脚本」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113450001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「完成したのか！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "明日楽が持ってきた脚本を配る。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "えっと、タイトルは……？", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「令嬢戦隊ゴレイジョーＶＳアクレイジョー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113450001" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「えっと……戦隊もの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010113450001" ]},
		{"command":[ "SETCHARA", "0", "char_00001205_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「５人の令嬢ヒロインが、正義のスーツに身を包んで悪役を倒すのね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020113450001" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「その悪役って……あたしよね？　はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020113450001" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「令嬢たちを諫める王子様が白馬に乗って現場に現れる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130113450001" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「王子役はご主人ですな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113450002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そういう白馬はお前だぞ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「なんと！　それは光栄でございます。役者としての血が騒ぎますな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113450003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お前のどこに役者の血が流れているんだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "さて、新しい脚本はこれ以上トラブルが起こらないようにとクラス全員の配役\nまで決まっていた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「レイジョーピンク、ルルーナ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020113450003" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「ピンク、ヒロインらしい色ね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113450002" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「レイジョーローズ、マーガレット」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020113450004" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ローズなんて、主役らしい色じゃない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020113450002" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「レイジョーラベンダー、つきみ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020113450005" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「ラベンダーって何色？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010113450002" ]},
		{"command":[ "SETCHARA", "0", "char_00001205_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「レイジョーモモイロ、流々那」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020113450006" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「えっと、ピンクと色が被っていませんか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130113450002" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「レイジョーベビー、夜日楽」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020113450007" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「ちょ、ちょっと待ってください！　大江山先生、なんでわたしまでヒロイン\n役になってるんですか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020113450001" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「夜日楽、学園長から『学級委員がほかの４人をまとめてください』とのこと\nです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020113450008" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「わ、わかりました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020113450003" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「それにしても、変身か……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "こうしてクラスを見渡すと、全員が変身後の姿を持っているわけで……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……これって変身する意味あるか？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「もちろんあるわよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113450003" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「普段と違う姿に変身するのは重要だと思います」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130113450003" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「状況に合わせてフォームを切り替えるのってかっこいいよね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010113450003" ]},
		{"command":[ "SETCHARA", "0", "char_00001205_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「お揃いのデザインで戦隊するのって、新鮮です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020113450004" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ま、どんな姿でも私は目立っちゃうと思うけどね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020113450003" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ええ……いいのか……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そうやって台本のチェックをして、ついにラストシーンまでたどり着く。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「結構な超大作だな……」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「トイレ休憩なしで３時間はありそうですな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113450004" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ちょ、ちょっと待てよ、これは……っ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「これは、全米どころか全次元が震撼のラストですな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113450005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "相変わらず駄犬は大げさな言い方をするが、今回ばかりは俺も同意だ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「あ、悪の女幹部にやられた王子を復活させるためにキスって……大江山先生\n、どういうことですか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020113450005" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「最終的に王子様と結ばれるヒロインは、まだ決まっていないんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020113450011" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「てことは、この脚本は未完成ってことか！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「いえ、『そこだけはアドリブで、観客とカツマさんからの投票で決めましょ\nう』と学園長が……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020113450012" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "教室がざわつく。無理もないか。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「き、キスか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010113450004" ]},
		{"command":[ "SETCHARA", "0", "char_00001205_01", "5", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「か、カツマ先生と……カツマ先生とキス……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130113450004" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「キスですって……そ、そんな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113450004" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "戸惑いを隠せない三人。その一方で、", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「いくら王子役だからって、カツマ先生とキスはないわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020113450004" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「そ、そういうのは……ちょっと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020113450006" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "あからさまにいやそうな顔をするマーガレット。控えめながらも夜日楽も同様\nか。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「ええ……。これ、投票対象って登場人物全員なの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020113450002" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "桃花は気づいたようだが、王子役が選ぶのはなにもヒロインだけに限らない。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "投票によってはゴレイジョーではなくアクレイジョー役の桃花とキスすること\nもありうるわけだ。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "当然、悪役令嬢の取り巻き役や、背景の木、路傍の石役の生徒とも……って、\nなんでもありか！", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "余計に教室のざわつきが大きくなった。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「さすがにキスシーンはないんじゃないか？　学生の演劇なわけだし」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「ですが、学園長先生もイチオシの展開ですし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020113450013" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「私は、カツマ先生とキスできるなら、このままの方が……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130113450005" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「ば、バカ言わないでくださいっ。キスなんて、その……ありえませんからっ\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113450005" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「さすがに、キスシーンは恥ずかしいよね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010113450005" ]},
		{"command":[ "SETCHARA", "0", "char_00001205_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「……お困りのようですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020113450001" ]},
		{"command":[ "SETCHARA", "0", "char_00002602_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "いきなり学園長が登場した。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「うーん、王子とのキスシーンがあれば、皆さんやる気になると思ったのです\nが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020113450002" ]},
		{"command":[ "SETCHARA", "0", "char_00002602_01", "2", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「……では、こうしましょう。キスは任意とします」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020113450003" ]},
		{"command":[ "SETCHARA", "0", "char_00002602_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "任意って、キスの可能性は残すのか。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「その代わり、投票で選ばれた方には成績アップを約束しましょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020113450004" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「えっ、そんなことしていいんですか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020113450014" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「ええ。なにかご褒美があった方がいいでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020113450005" ]},
		{"command":[ "SETCHARA", "0", "char_00002602_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「成績アップね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020113450006" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「まあ、そういう特典なら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020113450004" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ほかの生徒も納得したのか、安堵の声や歓迎する声が聞こえてくる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「では、決まりですね。明日からの練習、皆さんがんばりましょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020113450006" ]},
		{"command":[ "SETCHARA", "0", "char_00002602_01", "8", "CENTER", "0" ]},
