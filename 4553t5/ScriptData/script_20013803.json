{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0045" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……と、いうわけなんだが。祭りをひらくことは可能だと思うか？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「ふむ。その程度のこと、妾にかかれば造作もない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_010022690001" ]},
		{"command":[ "SETCHARA", "0", "char_00024101_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「おぬしには色々と恩もあるしの。この神社は好きに使ってもらってかまわぬ\nぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_010022690002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「ほんとうですか……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010022690001" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "快くＯＫしてくれた稲穂姫に、イルルが目を輝かせる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「となれば、次は屋台のあてか……。これにも心当たりがあるぞ」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0140" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_014" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ってわけで、こいつらを連れてここに来たってわけだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "稲穂姫の手伝いをすると言って神社に残ったイルルを除く、ヤム、明日楽、牛\n神様と訪れたΩ組事務所。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そこでは頼れるＣＥＯこと、獄門七重が神妙な面持ちで待ち構えていた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「そうでしたか……。お力になれるかどうかはわかりませんが、まずはお話…\n…聞かせてもらいましょか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_020022690001" ]},
		{"command":[ "SETCHARA", "0", "char_00003302_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「それがね……えっと、あの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010022690001" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「慌てずに。ゆっくり話してくださってかまいませんから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_020022690002" ]},
		{"command":[ "SETCHARA", "0", "char_00003302_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「あ、ありがと……じゃあ、話すね……。まず、商店街でチラシを見つけて…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010022690002" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「……へえ。そないなことが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_020022690003" ]},
		{"command":[ "SETCHARA", "0", "char_00003302_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「大事なお友達を喜ばせたいというのは、なんとも可愛らしいお願いごとです\nね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_020022690004" ]},
		{"command":[ "SETCHARA", "0", "char_00003302_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「Ω組の力でなんとかならないか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「そうですねぇ……出来ないことはありませんねえ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_020022690005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "部下" ]},
		{"command":[ "SETTEXT", "「し、しかしいきなり祭りをやるといっても予算が……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「はぁあああ！？　予算んんん！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_020022690006" ]},
		{"command":[ "SETCHARA", "0", "char_00003302_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "部下" ]},
		{"command":[ "SETTEXT", "「ひぃっ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「小さい子の夢、素直に応援できへんなんて極道の名折れとちゃいますか！？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_020022690007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「弱き者を助けずに何が極道や！　しみったれたことを言うんやあらへん！！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_020022690008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "部下を一喝し、お七モードに変わった七重の決断力はすさまじかった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「おヤムはん。この件、私が責任を持って預からせていただきます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_020022690009" ]},
		{"command":[ "SETCHARA", "0", "char_00003302_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ま、こういうとイベントごとは居酒屋正義の稼ぎ時だからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020022690001" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ホントぉおおお！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010022690003" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ま、オレたちにまかせときな♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020022690002" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "用心棒のほむらがニヤリと笑うのを、ヤムはキラキラした瞳で見つめていた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0041" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「なんかさ？　やれそーじゃん、お祭り！　テンションあがってきたかも～！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010022690004" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "祭りが現実的になってきたことが嬉しいのか、スキップして歩くヤム。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "その後ろを、俺と明日楽はまるで保護者のように見守りつつ進んでいた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「不可能を可能にしてしまうなんて。本当に……すごい人脈ですね。感嘆しま\nす」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020022690001" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「この２年と半年、いろいろなことがあったからなぁ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "なんて、俺が感慨にふけっていると……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「後は……これ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010022690005" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "とヤムが盆踊りの絵をみせてきた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「盆踊りか……確かに夏の風物詩だしな」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「そこでね……あゆちゃんに歌ってもらう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010022690006" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あゆちゃん……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "聞きなれない謎の名前に首をひねると、ヤムがスマホを手渡してくる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「画面見て。あゆちゃん、ギャル友の間で全推しなんだ～。カワイイっしょ？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010022690007" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「この顔、どこかで見たような……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「まず、歌が超超超ウマいし？　存在自体がカリスマだし！　顔もカワイイ、\nスタイルバツグン！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010022690008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「私も話には聞いたことがありますね。おそらくどこかで、曲も何度も耳にし\nているかと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020022690002" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「街でもどこでも常に曲かかってるしね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010022690009" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そんなに有名な人だったのか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "堅物な明日楽ですらも知っている、超人気アイドルのあゆむを目を細めて見つ\nめてみる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「う～ん……？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「流石に彼女を呼ぶのは無理では……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020022690003" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "悩む明日楽の隣で俺は首をひねってしまった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「待ってくれ。今何かとんでもないことを思い出せそうなんだ」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0180" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「天野川・織姫・あゆむって……ああああ！　あのときの！？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00017801_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0041" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「……え？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010022690010" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "きょとんとするヤムに何をどう説明したものか、俺は完全に困ってしまった。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}