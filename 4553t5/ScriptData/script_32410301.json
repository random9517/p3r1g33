{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0045" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「ふむ……このような忘れられた神社に来客とは珍しい。おぬしもたいそうな\n物好きよのう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0303101" ]},
		{"command":[ "SETCHARA", "0", "char_00024103_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「しかし、よく見ればなかなかの男ぶり。妾を敬う心意気といい……気に入っ\nた。ここを訪ねたということは、妾になんぞ用事があったのじゃろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0303102" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「妾の信奉者となるならば、おぬしの望みを叶えて進ぜよう。だが、悪神とは\nいえ妾も神の一柱。貢ぎ物の一つも用意しているのであろうな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0303103" ]},
		{"command":[ "SETCHARA", "0", "char_00024103_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「ほう、手ぶらとな。酒の一つでも持ってくるのが常道なのじゃがなあ……ま\nあ、かまわん。それならそれで、捧げさせるものはある」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0303104" ]},
		{"command":[ "SETCHARA", "0", "char_00024103_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「ふむふむ、中々立派なモノをもっておるではないか。よいぞ、よいぞ。やは\nり、おぬし自身から供物をいただくことにしようかの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0303105" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024103_01_01" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「ふふ、そう怯えた顔をするでない。妾は信奉者には寛容じゃ。おぬしにも、\nたっぷりとよい思いをさせてやろうぞ。このおっぱいでの……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0303106" ]},
		{"command":[ "SETIMAGE", "0", "still_00024103_01_03" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「顔に反して、チンポはガチガチじゃのう。んふふ、少しばかり、期待してお\nったのじゃろう？　こんな寂れた神社にいる女神に対して、のう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0303107" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「よい。皆まで言うな。女として、男が妾に求めるものも理解しておる。おぬ\nしは久々の信奉者じゃ。ならばよい目を見させてやらんとの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0303108" ]},
		{"command":[ "SETIMAGE", "0", "still_00024103_01_01" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「こうして、みっちりとおっぱいでチンポを挟んで……んっ、ほれ、妾の谷間\nでおぬしのチンポがびくびくしておるぞ……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0303109" ]},
		{"command":[ "SETIMAGE", "0", "still_00024103_01_02" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「ふふ、態度は殊勝であったのに、こっちはずいぶんと暴れん坊じゃな。よい\nよい。妾は寛容じゃからして、このおっぱいで包んでやろうぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0303110" ]},
		{"command":[ "SETIMAGE", "0", "still_00024103_01_01" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「んんっ、んっ、ふうっ……なかなか、初めてやったが、気持ちいいものだな\n、これは。おぬしの快感が妾にも伝わってくる……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0303111" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「あうっ、んっ、こうしてぎゅってするのがよいのか？　それとも、こうして\n揉み込むのがいいのか？　んんっ、んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0303112" ]},
		{"command":[ "SETIMAGE", "0", "still_00024103_01_02" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「両方？　両方か。この欲張りものめ。しかし、妾は女神じゃからな、二つと\nも叶えてやろうではないか、こうして……んっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0303113" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「ほれ、ほれ。ぎゅっと抱き締めながら上下に動かして……ふふっ、気持ちよ\nさそうに腰が動いておるぞ。ふうっ、うっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0303114" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「これ、暴れるな。おっぱいからチンポが飛び出してしまうじゃろ。暴れるな\nというに、そんな悪いチンポはこうじゃ、んうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0303115" ]},
		{"command":[ "SETIMAGE", "0", "still_00024103_01_03" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「ふふ、ここまで締めつけたら、もう動けんじゃろ。妾の言うことを聞かぬチ\nンポにはおしおきじゃ……ふうっ、んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0303116" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「んう？　このまま激しく動かしてほしいじゃと？　全くおぬしは……おしお\nきじゃと言うておるに……じゃがまあ、信奉者の望みを叶えるのも神の努め」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0303117" ]},
		{"command":[ "SETIMAGE", "0", "still_00024103_01_01" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「仕方ないのう。では、お望み通り……んっ、んうっ、ふっ、ふうっ！！　ど\nうじゃ？　きつきつの谷間でごしごしされるのは？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0303118" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「んんっ、言わずともチンポと顔で分かる。おぬし、今ものすごくだらしない\n顔をしておるぞ……んふっ、んっ、んうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0303119" ]},
		{"command":[ "SETIMAGE", "0", "still_00024103_01_02" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「それに反してチンポはガッチガチじゃ。妾のおっぱいを跳ね返すような硬さ\nと火傷しそうな熱さで……雄の強さを感じるのう。んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0303120" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「妾の身体に興奮しているのが分かるぞ……それにも応えてやろうぞ。ほれ、\nほれ、こうして強く締めつけたまま……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0303121" ]},
		{"command":[ "SETIMAGE", "0", "still_00024103_01_03" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「あうっ、ふうっ、これ、チンポの形が分かって……んふうっ、悪くないのう\n……んっ、妾のおっぱいも気持ちいい……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0303122" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「ふっ、んっ、しっかりと、抱きしめたまま上下に動かして……んっ、ふっ、\nおぬしの腰が震えておるの……ふふっ、なかなか、悪くない……んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0303123" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「女神である妾が……人間の男に奉仕するのも悪くない……そんなに気持ちよ\nさそうな顔をされるとの……ふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0303124" ]},
		{"command":[ "SETIMAGE", "0", "still_00024103_01_02" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「もっと？　もっとしてほしいとな？　全く、妾が優しいからと調子に乗りお\nってからに……ま、久々の信奉者じゃ。許してやろう……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0303125" ]},
		{"command":[ "SETIMAGE", "0", "still_00024103_01_01" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「ほれ、ほれほれ。こうして欲しいんじゃろう？　おぬしの望みなど丸わかり\nじゃ……挟んで、しごいて、抱きしめて……んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0303126" ]},
		{"command":[ "SETIMAGE", "0", "still_00024103_01_02" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「チンポがビクビクと震えておるのが分かるぞ……ふっ、んっ、先端からぬる\nついたものが漏れてきておる妾の汗と混じって……んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0303127" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「おっぱいとチンポが吸いつきあっておる……んんっ、このパイズリという奉\n仕、なかなかよいの……気に入った」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0303128" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「んふっ、ふっ、おぬしも気に入っているようじゃな……そんな目で見つめら\nれたら……妾のおっぱいだけではなく、お腹も熱くなってくる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0303129" ]},
		{"command":[ "SETIMAGE", "0", "still_00024103_01_03" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「ふふ、信奉者はおろか、男にこんな風に求められたことなぞなかったからの\nう……不思議な気分じゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0303130" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「じゃが、悪くない……信心を得るのも、男に求められるのも……んんっ、お\nぬしのチンポが愛おしく思えてくる……んっ、ふうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0303131" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「はっ、ふうっ、ふっ、チンポが膨らんできた……出すのじゃな……よいぞ。\nおぬしの子種を出して、妾に捧げるのじゃ……あんっ、んっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0303132" ]},
		{"command":[ "SETIMAGE", "0", "still_00024103_01_02" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「ふうっ、ふっ、先端が熱くなって……んっ、あっ、妾の胸の中で暴れて……\nんっ、大人しくせんか、このっ、あっ、ああああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0303133" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「あふううううっ、チンポが爆発して、熱っ、んんっ、ふあっ、あああっ、ど\nろどろに、妾のおっぱいがどろどろになって……あふうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0303134" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024103_01_05" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「んんっ、んっ、おっぱいに中出しされて……んんっ、胸で孕んでしまいそう\nじゃ……んんっ、んっ、ふああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0303135" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「熱さも、匂いも……たまらん……これが……おぬしからの捧げ物……んんっ\n、素晴らしい……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0303136" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「ああ……妾の中におぬしの信心が満ちていくのが分かる……ふふ、久しぶり\nじゃ、この充足感……あふっ、んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0303137" ]},
		{"command":[ "SETIMAGE", "0", "still_00024103_01_06" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「まだ出すのか……よいぞ、満足するまで出し切るのじゃ……妾に全部、出し\n切るのじゃ……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0303138" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「んっ、んっ、こんな濃い子種、もしも腹に出されたら……そう思うだけで、\n切なくなってくるのう……んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0303139" ]},
		{"command":[ "SETIMAGE", "0", "still_00024103_01_04" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「ふふっ、おぬしも気持ちよさそうな顔で、なによりじゃ。おぬしからの捧げ\n物、しかと受け取ったぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0303140" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「それにしてもこれほど濃い子種……んっ、のう、一つ、提案があるのじゃが\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0303201" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「おぬし、妾の婿になる気はないか？　妾もな……一人きりの日々は寂しいの\nじゃ。悪神と蔑まれてからは誰も来ず……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0303202" ]},
		{"command":[ "SETIMAGE", "0", "still_00024103_01_06" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「そんなときにおぬしが来て、妾を崇めてくれて、こんなに濃い子種を捧げて\nくれた……妾は、おぬしと共に過ごしたい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0303203" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「のう、妾を妻にしてくれたら、毎日毎日こんな風に奉仕してやるぞ？　もち\nろん、胸だけではない。おぬしが望めば、下も……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0303204" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「子だって一杯孕んでみせようぞ。おぬしとの子なら、さぞかし愛い子になる\nじゃろうな。くふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0303205" ]},
		{"command":[ "SETIMAGE", "0", "still_00024103_01_05" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「ほれ、チンポはまたやる気になっておるぞ。妾のおっぱいでまた気持ちよく\nなりたいと訴えておる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0303206" ]},
		{"command":[ "SETIMAGE", "0", "still_00024103_01_04" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「少なくとも、おっぱいとチンポは相思相愛じゃなあ。ほれ、またこうしてぎ\nゅっとしながらしごけば……んっ、硬くなって、んんっ、ふうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0303207" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「子種と汗が混じってぬるぬるの谷間で、さっきよりチンポが滑らかに動いて\n……んっ、これはこれで……ふふ、気持ちよさそうじゃのう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0303208" ]},
		{"command":[ "SETIMAGE", "0", "still_00024103_01_06" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「妾と一緒になってくれれば、毎日、毎日こうして奉仕してやる……だから、\nの？　一緒になろう。夫婦の契りを交わそうぞ……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0303209" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「生活も、心配するな。悪神とはいえ、神は神。男を一人養うなぞ問題はない\n。おぬしは妾の側にいてくれればいい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0303210" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「妾が毎日、食事も、風呂も、掃除も全部世話をしよう。もちろん、こっちも\n……な？　んんっ、ほれ、チンポはもう頷いておる。あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0303211" ]},
		{"command":[ "SETIMAGE", "0", "still_00024103_01_05" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「妾のおっぱいの中で、チンポが婚姻の契りをかわそうと、びくびく震えて頷\nいておるぞ。ふふっ、おぬしの顔も、気持ちよさそうではないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0303212" ]},
		{"command":[ "SETIMAGE", "0", "still_00024103_01_04" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「ふっ、んっ、一緒になって、毎日毎日、こうして愛しあおうではないか？　\nのう、妾はこれでも尽くす女じゃからの、あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0303213" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「おぬしを毎日満足させてやれるぞ？　だから、の。一緒に、妾と一緒になろ\nう？　もう、一人は寂しくてつまらないんじゃよ……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0303214" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「ふあっ、ああっ、チンポがまた硬く……んっ、ふふっ、まずはこっちを満足\nさせてからじゃな。ほれ、ほれほれ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0303215" ]},
		{"command":[ "SETIMAGE", "0", "still_00024103_01_05" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「おぬしの好きにできるおっぱいでぎゅっぎゅって挟んで、しごいて……もち\nろん出すときは好きな場所に出してよいんじゃぞ？　あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0303216" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「顔でも、おっぱいでも、どこでも好きな場所におぬしの子種、ぶっかけてよ\nいぞ……女神にぶっかけられる男なぞ、おぬしだけじゃ。んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0303217" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「ふうっ、うっ、谷間で、また、はちきれそうに……んんっ、ぬるぬるのおっ\nぱいでもっとしごいてやろう、ふうっ、ううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0303218" ]},
		{"command":[ "SETIMAGE", "0", "still_00024103_01_06" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「はっ、ふっ、先端が膨らんできたのう。また出すんじゃな？　よいぞ、おぬ\nしの思うままに、子種を出してくれてよいぞ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0303219" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「ほれ、ほれ、遠慮せず、おぬしの妻となる女にたっぷりと、好きな場所に出\nしてくれ……んんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0303220" ]},
		{"command":[ "SETIMAGE", "0", "still_00024103_01_05" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「んふうううううっ！！　おっぱいの谷間に、また……んっ、んんっ、おっぱ\nいが溺れてしまいそうじゃのう……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0303301" ]},
		{"command":[ "SETIMAGE", "0", "still_00024103_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「ふふ、妾のおっぱいが、おぬしの子種でどろどろになって……染みついてし\nまったのう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0303302" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「んんっ、んっ、おぬしのチンポも、谷間で嬉しそうに吐き出し続けておる…\n…んっ、うっ、ふうっ……気持ちよかったろ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0303303" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「おぬしの妻として、不足のない奉仕じゃったろう？　だから、な？　妾の婿\nとなって、一緒に神社をもり立てていこうではないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0303304" ]},
		{"command":[ "SETIMAGE", "0", "still_00024103_01_09" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「え？　まだ出会ったばかりだから、もう少し時間をかけて？　そ、そういう\nのならば、次もまた来てくれるのじゃな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0303305" ]},
		{"command":[ "SETIMAGE", "0", "still_00024103_01_08" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「妾のこと、忘れずにまた来てくれるのじゃな？　ふふ、よい。ならばよい。\n信奉者のおぬしのいうことじゃ、信じてやろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0303306" ]},
		{"command":[ "SETIMAGE", "0", "still_00024103_01_07" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「くふ、くふふふふふ。次、次か。よい言葉じゃのう。信じておるからな。妾\nは、約束したからにはずっと待っておるからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0303307" ]},
		{"command":[ "SETIMAGE", "0", "still_00024103_01_08" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「もちろん、妾もただ待つだけではない……時間をおくからには、おぬしをも\nっともっと悦ばせる奉仕を学んでおこう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0303308" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「婿となるおぬしのためじゃ、学ぶことも苦ではない。むしろ、おぬしのため\nだと思うと、喜びすらわき上がってくる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0303309" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「では……また来たときには今日以上の快感になるように奉仕するからの。楽\nしみにしておいてくれ……ふふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0303310" ]},
		{"command":[ "SETIMAGE", "0", "still_00024103_01_09" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},	
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「ああっ、チンポが抜けて……んんんっ、あっ、目の前に……ふああっ、あっ\n、子種が……んんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0303401" ]},
		{"command":[ "SETIMAGE", "0", "still_00024103_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「顔、妾の顔に……ふううっ、匂いが……んっ、鼻の奥に射精されているよう\nじゃ……んんんっ、濃厚じゃのう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0303402" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「んうっ、この濃さ、匂い、まるでマーキングじゃ……妾が狐の神だからとい\nって、獣のやり方を真似せんでもよかろうに……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0303403" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「じゃが、まあ悪くない……こうしておれば、妾がおぬしのものじゃと一目で\n分かるからのう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0303404" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「のう、これはおぬしの婚姻の証と捉えてよいのじゃな？　こんな風に、おぬ\nしのしるしを顔中に浴びせるという事は、そういうことじゃろ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0303405" ]},
		{"command":[ "SETIMAGE", "0", "still_00024103_01_10" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「ん？　まだ一回しかできてない、じゃと？　ん、ふふふふふ……それは、ま\nだまだマーキングするということか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0303406" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「ということは、またここに来るということじゃな？　妾のもとに、来てくれ\nるということじゃな？　約束、約束じゃぞ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0303407" ]},
		{"command":[ "SETIMAGE", "0", "still_00024103_01_12" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「朝でも、夜でも、いつでも来てくれてよい。いつだって、妾はおぬしを迎え\nるからの。ふふ、それが妻となる女の務めじゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0303408" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「来てくれたなら、妾の顔でも、胸でも、中でも、どこでも出してよいからな\n！！　もちろん、それ以外のことだって学んでおく」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0303409" ]},
		{"command":[ "SETIMAGE", "0", "still_00024103_01_11" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「ずっと、ずっと待っておるからの。だから、忘れずにいておいてくれ……お\nぬしが来てくれれば、それだけでよい……お願いじゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0303410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}