		{"command":[ "PLAYVOICE", "v2_170_0204108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「ふんっ……所詮、この程度でしょ……んっ、くっ……全然、大したことない\n……はっ、んっ、あっ……んくっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0204109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「な、何よ……ちょっと声が出る位……どうだって言うの……？　少し位は、\nそんな風になったって……んひぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0204110" ]},
		{"command":[ "SETIMAGE", "0", "still_00017002_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「なっ……なっ、何でもないっ……！　違うわっ……い、今のは別に……そう\nいうのじゃなくてっ……きゃうんっ！　あっ、んぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0204111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「じゃ、弱点を見つけたって……何言って……そんなワケ……ないしっ、あっ\n、はっ、あぁっ、バ、バカっ……そんな同じトコばっかりぃっ、あっ、あひっ\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0204112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「あっ、あぁっ……ま、待ってっ……あっ、あぁっ、違うっ……そこはっ、あ\nっ、はひっ、あっ、あひっ、ひっ、ひぃぃぃんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0204113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「わ、分かったっ……分かったからっ！　そ、そこはっ……オ、オマンコの弱\nいトコでっ、あっ、今……続けてするのはぁっ、あぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0204114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「はっ、あぁっ、溢れて来ちゃうっ……お汁出ちゃうのっ！　あひっ、あぁん\nっ、ひぁっ、んくぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0204115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「あっ……あぁっ……はぁっ、はぁっ……なっ、ま、まだするのっ！？　い、\n今……一回イッたのにっ、つ、続けてぇっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0204116" ]},
		{"command":[ "SETIMAGE", "0", "still_00017002_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「んぁぅっ……ダメっ、そ、それ以上したらっ、あっ、来ちゃうっ……あぁっ\n、出ちゃうからっ、あっ、あぁっ、も、漏れちゃうっ！」", "NORMAL" ]},
