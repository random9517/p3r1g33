		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「んぁっ、あぁぁぁぁぁっ！　イクッ……んくぅぅぅんっ、イクぅぅぅぅっ！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0204136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017002_02_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「は……あぁぁぁん……中……熱い……オマンコ……どぷどぷ……入ってきて\nるぅ……あっ、ふぁぁぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0204137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「ダメ……こんなに出されたら……あ、赤ちゃん出来ちゃうかも知れないのに\n……まだ、精液……出たままぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0204138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「はぁ……んんっ、収まって……る……？　やっと……んふぁ……はぁ、はぁ\n……はぁ……んはぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0204139" ]},
		{"command":[ "SETIMAGE", "0", "still_00017002_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「あぁ……ま、まだ中で蠢いてる……どれだけオチンポ元気なのよぉ……んっ\n、ふっ…はぁ、はぁ……はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0204140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「も、もう……十分したでしょ……さっさとこれ……元に戻しなさいよ……ん\nっ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0204201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「な……こ、ここからが本番って……ど、どういう意味……？　もういっぱい\n出したんだから、それで……んっ、ひぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0204202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「あっ……んぁぁぁぁっ！　ま、また入ってくるっ……そんな、続けてなんて\nぇ……あっ、あひっ、んんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0204203" ]},
		{"command":[ "SETIMAGE", "0", "still_00017002_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「はんっ、んぁっ、あっ、あぁぁぁっ、ぐちゅぐちゅするっ、あぅっ、またオ\nマンコッ、か、かき混ぜられてるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0204204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「あぁっ、せ、精液を馴染ませるって……頼んでなんかっ、あっ、あぁっ、ダ\nメっ……つ、続けてはっ、ひぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0204205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「はぁっ、あっ、何これ……き、キツいのにっ……んんっ、ずっと深いところ\nに擦れてぇっ……あっ、あぁっ、気持ち……よくなってるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0204206" ]},
		{"command":[ "SETIMAGE", "0", "still_00017002_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「ち、違うっ……これはっ、そういうのじゃなくてっ……あんたのオチンポが\nいいって意味じゃっ、あっ、あひっ、そこっ、だめぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0204207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「はぁんっ、わ、分かったからっ！　一番奥にっ……届いてるオチンポっ、す\nごく気持ちいいのっ、オチンポ感じるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0204208" ]},
		{"command":[ "SETIMAGE", "0", "still_00017002_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「高く……足を上げてるからっ、普段当たらないところにっ……先っぽがグリ\nグリ来てぇっ、そ、それがっ、すごくいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0204209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「はんっ、あっ、あぁんっ、あひっ、こんな状態でポールダンスなんて……あ\nっ、出来るわけないしっ……あひっ、ひぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0204210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「お、踊り子なんてっ……そ、そんなんじゃないのにっ……！　あくぅっ、身\n体っ……勝手に跳ねちゃうっ、あぁっ、オチンポで踊らされちゃうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0204211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「くぅんっ、んぁっ、あふっ……待ってっ……こ、こんなっ、敏感なままなの\nっ、続けてたらっ……あたし、またっ……あっ、出ちゃうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0204212" ]},
		{"command":[ "SETIMAGE", "0", "still_00017002_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「だ、出していいってっ……いいワケないでしょっ！　ダメッ……こんなオチ\nンポされながらお漏らしなんてしちゃったらぁっ……あっ、んぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0204213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「はひっ、あひんっ、あぁっ、やめっ、お、おっぱいも触るなぁっ、い、今敏\n感なんだからっ、あっ、乳首浮いてるとかっ、い、言わなくていいからぁっ！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0204214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「ひぃんっ！　あっ、指ダメっ！　クニクニされたらっ、ひんっ、身体……ジ\nンジンしてぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0204215" ]},
		{"command":[ "SETIMAGE", "0", "still_00017002_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「あぁっ、こんなのっ、おかしくなるっ！　何が何だかっ……わ、分からなく\nなるぅっ、あっ、はひぁぁぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0204216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「あっ、あぁっ、んぁっ、ま、まだペース……上がるのっ！？　こんなっ、ズ\nボズボされてっ、ひぃっ、いっぱいっ……突きまくられたらぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0204217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「ダメッ……またあたしイクッ、イッちゃうからっ、あぁっ、オ、オチンポ震\nわせないでっ！　それっ、それぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0204218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「また……出したくなってるのっ！？　あぁっ、オチンポ跳ねてるっ、射精し\nたくなっちゃってるのっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0204219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「あたしもっ、もうダメっ……あぁっ、このままっ、また……オマンコッ……\nはひぃっ、ダメになるぅぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0204220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「はんっ、あぁっ、な、中にっ！？　あひっ、も、もうっ、何でもいいからっ\n！　出すならっ……早くっ……中にっ……出してぇぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0204301" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「はひぃぃぃぃぃんっ！　んぁぁぁぁっ、熱いのっ……あぁぁっ、また中にぃ\nっ、ひっ、んくぅっ、イクぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0204302" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017002_02_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「あ……あぁっ、子宮の奥に……どぷって……流れ込んでくるの……こ、こん\nなのされたら……も、ダメェ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0204303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「は……あぁぁぁ……あたし……また、漏れちゃってる……お、おひっこ……\nし、潮吹き……？　もぅ……よく分かんない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0204304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「ふぁぁ……きもひぃぃ……あぁ……足閉じられないから……入ってくるの止\nめられない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0204305" ]},
		{"command":[ "SETIMAGE", "0", "still_00017002_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「あぁ……はぁ、んっ……精液……いっぱい……あふっ、すご……すぎぃ……\nはぁ……んふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0204306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、はぁ……ね、ねぇ……ところでさ、流石にちょっと足が……疲\nれたんだけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0204307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「気持ちいいのは……そうだったけど、このポーズ……囚われ戦士設定とか言\nわれても、全然集中できないし、あたしの言うことも聞いてくれないし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0204308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「一応……エクササイズにはなった……のかな？　そこだけは、まぁ……うん\n……い、いいかな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0204309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「ま、また次も？　う、うーん……どうしようかな……まぁ、どうしてもって\n言うなら……考えても、いい、かな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0204310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「んぁっ、オ、オチンポ抜けてっ……ど、どうする気なのっ？　か、身体にっ\n……ひぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0204401" ]},

		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「きゃあぁぁぁぁんっ！　あっ……精液っ……また、いっぱい出てるっ……熱\nいのっ……ぶっ掛けられてるぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0204402" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017002_02_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「はぁぁ……んっ、こんなに……濃いの……顔にも……アーマーにも……染み\n込んで来てる……はぁぁ……ダメ……ま、またイクッ、あぁっ、イッてるぅっ\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0204403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「あふぁ……あたし、また……股間……緩んじゃってる……びゅるって何か…\n…漏れちゃってるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0204404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「んふぁ……すごい……身体中べとべとで……ボーッとして……何も考えられ\nない……んぁ……オマンコ……ジンジンしてるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0204405" ]},
		{"command":[ "SETIMAGE", "0", "still_00017002_02_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「はふ……んっ、あぁ……オチンポ……止まった……？　精液……やっと落ち\n着いたのかな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0204406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「えっと……そしたらさ、そろそろ……これ解いてくれない？　流石に、この\nポーズでずっとはキツいんだけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0204407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「や、まあ運動になったっちゃなったと思うけど……別に拘束まではしなくて\nもよかったと思うんだよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0204408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「まぁ、その、そういうシチュエーションなのは分かったし、それであんたが\n楽しかったんなら……まあ、いいけどさ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0204409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「ま、また次も？　う、うーん……どうしようかな……まぁ、どうしてもって\n言うなら……考えても、いい、かな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0204410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
