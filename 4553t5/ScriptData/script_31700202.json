		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「あっ、ひぃっ、あぁっ、んくっ……い、いつまでこの格好でさせるのよぉっ\n……あ、あぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0204133" ]},
		{"command":[ "SETIMAGE", "0", "still_00017002_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「んくんっ……はぁっ、や、やだ……あたし……こ、これ以上されたらっ、ほ\n、ホントにダメっ……！」", "NORMAL" ]},
