		{"command":[ "PLAYVOICE", "v2_170_0204125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「ま、待ってなんかないっ……ちょっと指で感じた位で……そんな勝手なコト\n……言わないでっ、あ、んぁぁぁぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0204126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、く……結局っ、これが本当の目当てだったってワケ……んっ\n、こんな……格好にして……あっ、準備までしてっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0204127" ]},
		{"command":[ "SETIMAGE", "0", "still_00017002_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「んんっ……！　くぅっ……や、やだ……足上げてると……お、奥の方まで…\n…届いて来ちゃってる……んっ、ふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0204128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「んくぅっ……あっ、うんっ、んくっ、はっ、あぁぁっ、あ、足がふらついて\n……バランスがっ……あ、あひっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0204129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「やだっ、あぁっ、ぐりって……めり込んでるっ、い、いっぱいっ……あくっ\n、オチンポッ……あぁっ、えぐれるぅっ、は、ひぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0204130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「はぁっ、あぁんっ、ダメっ……そんなっ、強くしたらっ、バランス……崩れ\nてっ、んくぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0204131" ]},
		{"command":[ "SETIMAGE", "0", "still_00017002_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「ち、違う……別に身体を支えてくれって言ってるワケじゃっ……おっぱいっ\n、も、揉むなぁっ！」", "NORMAL" ]},
