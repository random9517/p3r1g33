		{"command":[ "SETIMAGE", "0", "still_00017002_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「あっ、あぁぁっ、んぁぁぁぁぁぁぁぁぁーーーーーーーーーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0204118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「は……ぁぁ……や、やらぁ……見るなっ……あぁっ、み、見ないでっ……お\n、おしっこ……あ……あぁ……ダメェ……」", "NORMAL" ]},
