		{"command":[ "SETIMAGE", "0", "still_00017002_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「ダメって……言ったのに、はぁ……はぁ……んっ、お、お漏らしなんてぇ…\n…あぁ……あふっ、んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0204120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「うくっ……あたしを辱めてっ……気は済んだ……？　恥ずかしいところ……\n晒させて……い、いい気分なんでしょっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0204121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「ほ、本番……？　な……何、そんなにオチンポ大きくさせてんのよっ！　い\n、今おしっこしたし……き、汚いのにっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0204122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「気にしないって……あっ、あぁっ、そっちは気にしなくてもっ、あたしはっ\n……あっ、あぁっ、はっ、んぁぁぁぁぁぁぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0204123" ]},
		{"command":[ "SETIMAGE", "0", "still_00017002_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「あ……んくぅぅっ……は、入ってる……くぅっ……いやっ……熱いの……ど\nんどん奥に……届いてるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0204124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
