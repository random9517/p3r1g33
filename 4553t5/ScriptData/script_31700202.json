		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「ふん、けど……あんたの下手くそな指でされたって、別になんともないしっ\n……せいぜい無駄な時間……使ってりゃいいわっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0204107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
