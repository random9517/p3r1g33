{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0113" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_002" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「全員無事か！？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「皆さんそろっているようですな。後退がお上手になりましたな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010112050001" ]},
		{"command":[ "SETCHARA", "0", "char_00000901_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「こんなときでもひとこと多いな！　おまえは！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「だけど後退してばかりじゃ、らちがあかないよ。いまのところは、ドラグソ\nードが敵を抑えてくれてるけどね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010112050001" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「わかってるよ。どっかで反撃に出ないと、このまま押し切られる。とはいえ\n、反撃の糸口がな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「このへんで、援軍でも来てくれればねえ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_020112050001" ]},
		{"command":[ "SETCHARA", "0", "char_00001302_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「どこから来るんですか……地球から援軍を出せるわけでもあるまいし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010112050001" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "bg_0022" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_016" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「副長！　脱出船はすべて着陸したのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010112050001" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピースムーン" ]},
		{"command":[ "SETTEXT", "「さきほど最後の一隻が到着し、月からの脱出船は、すべて指定の地域に着陸\nしました。ただ――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_030112050001" ]},
		{"command":[ "SETCHARA", "0", "char_00000809_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ただ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010112050002" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピースムーン" ]},
		{"command":[ "SETTEXT", "「脱出前に受けた攻撃と、想定外の運用のため、ほとんどの船が破損し、負傷\n者も出ているようです。幸いにも重傷者はいないようですが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_030112050002" ]},
		{"command":[ "SETCHARA", "0", "char_00000809_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「そのことなら大丈夫だ。医療班が間もなく到着する。しばらくの辛抱だと、\nみんなに伝えてくれ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010112050003" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピースムーン" ]},
		{"command":[ "SETTEXT", "「了解しました。それから、長官。私たちを受け入れてくださったことに、感\n謝いたします」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_030112050003" ]},
		{"command":[ "SETCHARA", "0", "char_00000809_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「なにを言うんだ。当たり前のことじゃないか。そんなことより、今は怪我人\nの手当てと、状況の把握に全力を挙げてくれ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010112050004" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピースムーン" ]},
		{"command":[ "SETTEXT", "「了解しました！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_030112050004" ]},
		{"command":[ "SETCHARA", "0", "char_00000809_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「長官！　医療班を連れてきました！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010112050001" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「ウチの若いもんも連れてきましたよ。力仕事でしたらなんなりと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010112050001" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「これがグレート・ルナリアムの宇宙船団か……すげえなぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020112050001" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「おお、来てくれたか。すまんな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010112050005" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「いえ、任務ですから。それにしても、長官？　月から地球まで、どうやった\nらこんなに早く到着できるんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010112050002" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ああ、それは――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010112050006" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「今回は星間災害保険が適用されるケースですので、わたくしどもクリスタル\n・コンツェルンがご協力させていただきました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_072_010112050001" ]},
		{"command":[ "SETCHARA", "0", "char_00007201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「星間災害保険……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010112050003" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「ええ。ルナルバース陛下が保険に加入されていましたので、避難用の大型ワ\nームホールを臨時に開通いたしました。追加料金は一切不要です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_072_010112050002" ]},
		{"command":[ "SETCHARA", "0", "char_00007201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「なるほどね。さすがは女王陛下。抜け目がありませんねぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010112050002" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「あたしも医療保険ぐらい入っとこうかな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020112050002" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「ただ、もともと損傷していた船が急にワームホールに突入したため、ダメー\nジが拡大したようですが、その点は残念ながら適用外ということで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_072_010112050003" ]},
		{"command":[ "SETCHARA", "0", "char_00007201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「まあ、それは仕方がない。それより、隊長たちの救出作戦だが――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010112050007" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「なんだ！？　いまのは！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010112050008" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「どうやら、お客さんのようですねえ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010112050003" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「逃げ出した船はやはりここか……！　殲滅せよ！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「襲来者（インベーダー）！？　脱出船団を追ってきたのか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010112050004" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「話しは後にしよう！　まずはあいつらを片付ける！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010112050009" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「了解！　へへへ、面白くなってきたぜぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020112050003" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}