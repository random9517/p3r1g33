		{"command":[ "PLAYVOICE", "v2_157_010022410001" ]},
		{"command":[ "SETCHARA", "0", "char_00015701_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「これなら楽勝だね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022410001" ]},
		{"command":[ "SETCHARA", "0", "char_00015801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「みんな。油断しちゃダメよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010022410001" ]},
		{"command":[ "SETCHARA", "0", "char_00021202_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者" ]},
		{"command":[ "SETTEXT", "「こうなったら奥の手だ……！　出ろおおおぉぉぉーーーーー！　Ｙ.Ａ.Ｍ\n.Ｉーーーーーっ！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「またワームホールが開いてるよ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022410002" ]},
		{"command":[ "SETCHARA", "0", "char_00015801_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「Ｍ.Ｏ.Ｅちゃん！　何か出てきます！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022410002" ]},
		{"command":[ "SETCHARA", "0", "char_00015701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「あ、あれは……私っ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010022410001" ]},
		{"command":[ "SETCHARA", "0", "char_00011102_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ.Ａ.Ｍ.Ｉ" ]},
		{"command":[ "SETTEXT", "「うふふっ。貴方がＭ.Ｏ.Ｅね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_010022410001" ]},
		{"command":[ "SETCHARA", "0", "char_00022501_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「どういうこと！？　Ｍ.Ｏ.Ｅちゃんが２人いるわっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010022410002" ]},
		{"command":[ "SETCHARA", "0", "char_00021202_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者" ]},
		{"command":[ "SETTEXT", "「クククッ！　こいつは貴様の情報をコピーし、感情を消してさらなる改良を\n加え作り出した超人口知能ロボットカー……その名も、Ｙ.Ａ.Ｍ.Ｉだ！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ.Ａ.Ｍ.Ｉ" ]},
		{"command":[ "SETTEXT", "「そういうことよ。よろしくね、オリジナルさん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_010022410002" ]},
		{"command":[ "SETCHARA", "0", "char_00022501_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「そんな……！　Ｍ.Ｏ.Ｅちゃんのコピーですって……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010022410003" ]},
		{"command":[ "SETCHARA", "0", "char_00021202_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者" ]},
		{"command":[ "SETTEXT", "「驚いて貰って何よりだ。だが、私の切り札はもう一つあるぞ！　来いっ！　\nロッテっ！　クララっ！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「私たちの名前……！？　まさか……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022410003" ]},
		{"command":[ "SETCHARA", "0", "char_00015801_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふふ♪　私たちの出番のようですね～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_050022410001" ]},
		{"command":[ "SETCHARA", "0", "char_00015705_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「敵は排除する……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_050022410001" ]},
		{"command":[ "SETCHARA", "0", "char_00015805_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「私たちにそっくりの子までいますよ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022410003" ]},
		{"command":[ "SETCHARA", "0", "char_00015701_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「おかしい……中期量産の初期型のタイプは、私と姉さんだけのはず……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022410004" ]},
		{"command":[ "SETCHARA", "0", "char_00015801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者" ]},
		{"command":[ "SETTEXT", "「こいつらはＹ.Ａ.Ｍ.Ｉを強化するため、機械化帝国スペースネットのデ\nータベースをハッキングしたときに、偶然設計データを見つけてな」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者" ]},
		{"command":[ "SETTEXT", "「そのデータをコピーし、Ｙ.Ａ.Ｍ.Ｉと同じように感情を消し去って、戦\n闘用に改良させてもらったロボットだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者" ]},
		{"command":[ "SETTEXT", "「戦力増加のためと思って作ったはいいが、Ｍ.Ｏ.Ｅがこの次元に移って実\n戦投入する機会がなくてな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者" ]},
		{"command":[ "SETTEXT", "「だが、丁度オリジナルもいることだ。貴様たちに試運転の相手をしてもらお\nうか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「なるほど。だからあなたは私たちのことを知ってたんですねー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022410004" ]},
		{"command":[ "SETCHARA", "0", "char_00015701_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「データベースをハッキングするなんて、犯罪だよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022410005" ]},
		{"command":[ "SETCHARA", "0", "char_00015801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者" ]},
		{"command":[ "SETTEXT", "「クククッ！　犯罪はバレなければ犯罪ではないのだよ！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「こうして自白してる時点で、バレてると思うのだけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010022410004" ]},
		{"command":[ "SETCHARA", "0", "char_00021202_01", "9", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者" ]},
		{"command":[ "SETTEXT", "「黙れっ！　そんなの、貴様らを始末すればいいだけだ！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「初めての実戦がオリジナルの相手というのは、妙に身体が疼いてきますね～\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_050022410002" ]},
		{"command":[ "SETCHARA", "0", "char_00015705_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「相手が誰であろうと関係ない……私たちは命令に従うだけだよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_050022410002" ]},
		{"command":[ "SETCHARA", "0", "char_00015805_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ.Ａ.Ｍ.Ｉ" ]},
		{"command":[ "SETTEXT", "「貴方たちに個人的な恨みはないけど、機械である以上、命令には逆らえない\nの。残念だけどここで消えてもらうわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_010022410003" ]},
		{"command":[ "SETCHARA", "0", "char_00022501_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者" ]},
		{"command":[ "SETTEXT", "「クククッ！　さあ行け、お前たち！　こいつらを倒してしまえ！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0027" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SETNAME", "Ｙ.Ａ.Ｍ.Ｉ" ]},
		{"command":[ "SETTEXT", "「わかったわ！　変形！　フルドラーーーーーイブ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_010022410004" ]},
		{"command":[ "SETCHARA", "0", "char_00022502_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ.Ａ.Ｍ.Ｉ" ]},
		{"command":[ "SETTEXT", "「悪の心に知能を乗せて、灯せ不幸のテールランプ！　超人工知能ロボットカ\nーＹ．Ａ．Ｍ．Ｉ、道交法破って只今到着！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_010022410005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「そんなっ……！？　変形するだなんて……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010022410002" ]},
		{"command":[ "SETCHARA", "0", "char_00011102_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「まさか変形機能までコピーしているというの……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010022410005" ]},
		{"command":[ "SETCHARA", "0", "char_00021202_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ.Ａ.Ｍ.Ｉ" ]},
		{"command":[ "SETTEXT", "「貴方が変形できるのに、私ができないわけがないでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_010022410006" ]},
		{"command":[ "SETCHARA", "0", "char_00022502_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「くっ……！　どうやら、本当に自分自身と戦うしかないみたいね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010022410003" ]},
		{"command":[ "SETCHARA", "0", "char_00011102_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ.Ａ.Ｍ.Ｉ" ]},
		{"command":[ "SETTEXT", "「やる気になってくれたのは嬉しいけど、無駄な抵抗はしない方が身のためよ\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_010022410007" ]},
		{"command":[ "SETCHARA", "0", "char_00022502_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ.Ａ.Ｍ.Ｉ" ]},
		{"command":[ "SETTEXT", "「私はオリジナルである貴方より、各段に性能が強化されてるわ。勿論、ロッ\nテやクララもね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_010022410008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふふ♪　オリジナルなんかに負ける気がしませんよ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_050022410003" ]},
		{"command":[ "SETCHARA", "0", "char_00015705_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「当然……私たちはオリジナルより強いから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_050022410003" ]},
		{"command":[ "SETCHARA", "0", "char_00015805_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「貴方たちがどれだけ強化されていようと関係ないわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010022410004" ]},
		{"command":[ "SETCHARA", "0", "char_00011102_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「そうです。私たちはどんな敵が相手でも、絶対に負けませんよー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022410005" ]},
		{"command":[ "SETCHARA", "0", "char_00015701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ロボットの性能の違いが、戦力の決定的差ではないということを……教えて\nあげる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022410006" ]},
		{"command":[ "SETCHARA", "0", "char_00015801_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ.Ａ.Ｍ.Ｉ" ]},
		{"command":[ "SETTEXT", "「威勢がいいのね。なら、貴方たちがどれだけ非力か教えてあげるわ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_010022410009" ]},
		{"command":[ "SETCHARA", "0", "char_00022502_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0027" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「くうぅ……！　凄いパワーだわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010022410005" ]},
		{"command":[ "SETCHARA", "0", "char_00011102_01", "4", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「Ｍ.Ｏ.Ｅちゃん、加勢するわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010022410006" ]},
		{"command":[ "SETCHARA", "0", "char_00021202_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「ええ、お願いっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010022410006" ]},
		{"command":[ "SETCHARA", "0", "char_00011102_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふっ……！　自信満々なだけあって、かなり強いですねー……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022410006" ]},
		{"command":[ "SETCHARA", "0", "char_00015701_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「うん……正直、手ごわい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022410007" ]},
		{"command":[ "SETCHARA", "0", "char_00015801_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「さすがにＹ.Ａ.Ｍ.Ｉちゃんほどのパワーはありませんが、オリジナルを\n捻りつぶすのは簡単そうですね～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_050022410004" ]},
		{"command":[ "SETCHARA", "0", "char_00015705_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「少しは歯ごたえがあるところ、見せてよね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_050022410004" ]},
		{"command":[ "SETCHARA", "0", "char_00015805_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「言ってくれますね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022410007" ]},
		{"command":[ "SETCHARA", "0", "char_00015701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「姉さん……無理はしないで……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022410008" ]},
		{"command":[ "SETCHARA", "0", "char_00015801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
