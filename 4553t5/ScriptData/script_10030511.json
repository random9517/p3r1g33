		{"command":[ "PLAYBGM", "BGM_003" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "ハルノブのマスクが割れて覗いた顔、あれは間違いなく……。", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「お兄ちゃんあぶないですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010115330001" ]},
		{"command":[ "SETCHARA", "0", "char_00015704_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ぼーっとしてないで！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010115330001" ]},
		{"command":[ "SETCHARA", "0", "char_00015804_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああっ、すまん！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカカツマ" ]},
		{"command":[ "SETTEXT", "「さあゆけ！　みんな！　仲間を偽物のカツマの洗脳から取り戻すんだ！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "くそっ、偽物のくせに本物気取りですっかり調子に乗ってやがる！　いや、俺\nも同じ立場ならそうするかもしれん。余計に腹立つ！", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「きゃぁあああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010115330001" ]},
		{"command":[ "SETCHARA", "0", "char_00011101_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「ああぁああぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010115330001" ]},
		{"command":[ "SETCHARA", "0", "char_00021201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「Ｍ．Ｏ．Ｅ！　Ｍ．Ａ．Ｍ．Ａ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「整備士ロボは戦闘は不得手なのよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_010115330001" ]},
		{"command":[ "SETCHARA", "0", "char_00021301_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「くぅっ！　さすがに、このままでは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110115330001" ]},
		{"command":[ "SETCHARA", "0", "char_00000511_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ミヤビ……それにハルノブまで……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "女幹部たち相手では、こっちが不利だった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカカツマ" ]},
		{"command":[ "SETTEXT", "「残るはお前と、そのロボットだけのようだな」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000001_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「く……くくく……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "だが……俺にはまだ、最終兵器が残っている！ 　それを確実に当てるために、\nここで隙を作らなければ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカカツマ" ]},
		{"command":[ "SETTEXT", "「どうした？　追い詰められておかしくなったか？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はーっはっはっは！　たしかに俺は偽物さ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカカツマ" ]},
		{"command":[ "SETTEXT", "「ほう、やっと認めたか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「だが、偽物としての仕事はすでに済ませてある。俺はもう本物のカツマから\n情報を聞きだしたからな！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「なんだって！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115330001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「情報って……おいカツマ、なにを話したんだい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010115330001" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカカツマ" ]},
		{"command":[ "SETTEXT", "「え……えっと……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「俺はもうお前たちが秘密にしていることを知っている！　今から全部バラし\nてやる！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ルナテミスは家事が苦手らしいな！　特に料理は災害レベルの不味さだとい\nう！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「なにぃっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115330002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「エファナティカは蛇が苦手だったか。偉そうな顔してるくせに、蛇が苦手と\nはお笑いだな！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んなっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010115330002" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ダイヤナは昔の話が嫌いだったな。たしか園子とかいう黒歴史だっけ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ひ、ひっどーい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010115330001" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「セレーナは犬扱いされること、カグヤは目立つことが嫌いだと、本物のカツ\nマがバラしていたぞ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「おいカツマ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010115330001" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカカツマ" ]},
		{"command":[ "SETTEXT", "「お、おい、お前ら……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「どういうことだこのボケナスビ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115330003" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あたしらの秘密を、簡単に偽物に流すなんて！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010115330003" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカカツマ" ]},
		{"command":[ "SETTEXT", "「そ、それは……その……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ちなみに、俺が言ったことは、一言一句そのカツマが言ったとおりだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なぜなら俺はメカカツマ、一度聞いたことは忘れないからな！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「カツマちゃん！　どういうこと！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010115330002" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「カツマ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010115330001" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「カツマ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010115330002" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカカツマ" ]},
		{"command":[ "SETTEXT", "「お、おいお前ら、今はそんなこと言っている場合じゃないだろう！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカカツマ" ]},
		{"command":[ "SETTEXT", "「そんなことより、あの偽物を倒さないと……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「いいや、そんなことよりもまずは貴様にお仕置きをするのが先だ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115330004" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカカツマ" ]},
		{"command":[ "SETTEXT", "「なにぃっ！？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "俺の思惑通りだ。女幹部たちとの付き合いは俺の方が長い。その扱い方だって\n、俺の方が知っている。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカカツマ" ]},
		{"command":[ "SETTEXT", "「お、おい、俺を攻撃するなって！　敵はあっちだろうが！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「女の子の秘密を簡単にバラしちゃうような男は、女の敵よ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010115330003" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「そうだね。まずは一発」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010115330004" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「一人一発だ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010115330003" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカカツマ" ]},
		{"command":[ "SETTEXT", "「いい加減にしろぉっ！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「よし、いまだ！　ロッテ！　クララ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「まかせて！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010115330002" ]},
		{"command":[ "SETCHARA", "0", "char_00015704_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「兄さんの臭い……嗅がせてくる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010115330002" ]},
		{"command":[ "SETCHARA", "0", "char_00015804_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ロッテとクララが前に出て、ルナテミス達にお尻を向ける。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0195" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "ロッテ＆クララ" ]},
		{"command":[ "SETTEXT", "「超濃縮カツマ臭散布！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010115330003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカカツマ" ]},
		{"command":[ "SETTEXT", "「うわぁっ！　な、なんだ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「くっ、くっさぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010115330004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ひ、ひどい臭いだよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010115330005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ああんっ、目に染みるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010115330004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「だ、だが……この臭い……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115330005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「し、知ってる……この臭いは……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010115330002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0022" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "臭いの散布が終わった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカカツマ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……なんだったんだ……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000001_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカカツマ" ]},
		{"command":[ "SETTEXT", "「おい、みんな大丈夫か！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ああ……大丈夫だ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115330006" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカカツマ" ]},
		{"command":[ "SETTEXT", "「ルナテミス！　じゃあ、やれるか、あの偽物を！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ああ……だが偽物は……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115330007" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「お前の方だ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115330008" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ルナテミスが攻撃したのは、俺じゃなくてメカカツマの方だった。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカカツマ" ]},
		{"command":[ "SETTEXT", "「なにぃっ！？　さ、催眠が……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000001_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「思い出した。本物のカツマはあっち。あなたは本物じゃない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010115330003" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカカツマ" ]},
		{"command":[ "SETTEXT", "「ちくしょう！　こうなったら、また催眠を……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「そうはいかないんだから！」", "NORMAL" ]},
