{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「どうしたのですか？　旦那さま……なんだか今日は、にこにこしてとっても\nうれしそうですね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0304101" ]},
		{"command":[ "SETCHARA", "0", "char_00022103_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「最近、わたくしがえっちになって可愛くてしあわせ……ですか？　それは…\n…旦那さまがたくさんえっちのことをおしえてくださったからですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0304102" ]},
		{"command":[ "SETCHARA", "0", "char_00022103_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「……あの。わたくし……えっちなおくさんですので……。これから、本当の\n子作りというものをしてみたいです。……だ、旦那さまの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0304103" ]},
		{"command":[ "SETCHARA", "0", "char_00022103_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「旦那さまの笑顔をみていたら……。えっと、む、むらむらしてきちゃいまし\nた。とっても身体がうずうずしています。……いいですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0304104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「はい。今日は……わたくしが旦那さまを押し倒してしまいます。え、えーい\nっ……どんっ！　あっ……び、びくともしません……あれ？　あれ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0304105" ]},
		{"command":[ "SETCHARA", "0", "char_00022103_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「……そ、そちらから寝そべっていただけるんですか！？　よ、よかった……\n！　では、あらためて……寝ころんだ旦那さまの上に、どーんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0304106" ]},
		{"command":[ "SETCHARA", "0", "char_00022103_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「わぁ……♪　とってもいいながめです。え？　せっかくのきれいなお洋服が\nよごれてしまう……ですか？　それはだいじょうぶですよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0304107" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00022103_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「……この衣装は、決意の証……旦那さまへの愛を形に成したもの……。旦那\nさまの裸や、えっちなお汁でよごれるわけなんかないのです。ほんとうです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0304108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「……ふふふ♪　旦那さまのおちんちんさん……ぎゅーんって上をむいていま\nすね？　カチカチで、コチコチで、さわるととっても熱いです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0304109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「えへ……♪　わたくしと、赤ちゃんをつくりたくてこうなっているんですよ\nね……♪　そう思うと、すこしだけ緊張してしまいます……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0304110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「でも……せっかく、旦那さまのおかげでえっちになったわたくしを……たく\nさんかんじてほしいから……。つづけちゃいますね？　子作り……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0304111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ん……。なでなでなで……♪　おちんちんさん……♪　はやくわたくしの中\nに入ってきてください……ずーっと待っていたんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0304112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ひとつになりたくて、いっぱい中をこすってほしくて……わたくしのお股は\nヒクヒクがとまらないんですよ。せきにん……とってください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0304113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「……いじわるをして、焦らすのでしたら……こちらから……。ぁっ……おち\nんちんさんをむかえにいっちゃいます、から……♪　んんんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0304114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あっ、んぁああああっ……♪　あぁっ、は、入り、ましたぁあ……♪　えへ\nへへ、あそこがヌルヌルだったから、すぐに……あっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0304115" ]},
		{"command":[ "SETIMAGE", "0", "still_00022103_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ぬるぅうううう～って入っちゃいましたけど……。んっ、ぅ……うぅ……♪\n　すごいです、おなか……おなかがぽっこりふくらん、で……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0304116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「お腹の中からぐぐぐぅって押し上げられて、ひろげられているのがわかりま\nす……♪　何度えっちしても、毎回びっくりしちゃいます……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0304117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「……ふふ、見えますか？　わたくしの、ちぃちゃいちぃちゃいおまんこに…\n…旦那さまの太くていやらしいおちんぽさんがもぐりこんでいます♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0304118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あっ♪　この……この、あっぱくかんがすき、です……っ！　旦那さまが、\nわたくしの中に……えっちなところに入っているってわかります」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0304119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「硬くておおきいもので……貫かれて♪　ほかのだれにもさわらせたことのな\nい、赤ちゃんのお部屋のいりぐち……子宮口にキスされてぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0304120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「も、もうっ、それだけでイッちゃいそうで……す♪　あっ……！　ご、ごめ\nんなさい……っ、おちんちん入ってるだけで勝手にイきますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0304121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ッんんんん～～～～っ！　んふぅううう……！　くぅううんん♪　んんんん\n～～っ！　旦那、さまぁ……♪　旦那さまぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0304122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「旦那さまのかっこいいおちんちんで、わたくしの……アンの赤ちゃんのおへ\nや、コンコンノックしてください♪　おねがいします♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0304123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「わたくしに赤ちゃんをさずけてください……あっ♪　……わ、わたくしも…\n…がんばってうごきます！　だけど……。んぁっ、ぁっ、あっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0304124" ]},
		{"command":[ "SETIMAGE", "0", "still_00022103_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「おちん、ちん……♪　がっちりおまんこにはまってしまって……あぁっ♪　\nうごけ、ないんです……きょ、協力をおねがいします……ぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0304125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「……んんん……♪　うぅうう♪　ふ、ぅ……んんん……♪　あっ……す、す\nこし、ずつ……おまんこのヌルヌルで、すべって……んぅうう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0304126" ]},
		{"command":[ "SETIMAGE", "0", "still_00022103_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あっ♪　あぁああっ！　へんっ、へんですっ！　旦那さま……あぁっ♪　ん\nぁああっ♪　ま、まだちょっぴりこすれただけ、なのにっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0304127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「もう……ううぅ♪　イキたくて……！　きもちよすぎて失神しちゃいそうで\nす……！　あぁっ♪　えっち、えっちになっちゃいましたっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0304128" ]},
		{"command":[ "SETIMAGE", "0", "still_00022103_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「わたくし……えっちになりすぎて♪　太いおちんぽでいっぱい感じます♪　\nすぐ……すぐイッてしまうくらい♪　全身が敏感で……あぁあっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0304129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ひゅ、ひゅごい……っ、ひゅごいれすっ♪　旦那、さま……！　あぁっ！　\nおちんちんっ、おちんちんさん、動くととっても気持ちいいですぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0304130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「っあぁ……！　んぁああっ……みゃぁああっ♪　い、いいですっ、もっとつ\nよくしていいですっ！　おっきくうごいていいですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0304131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「えっちな腰の動きで、わ、わたくしのおまんこにたねづけっ……種付けして\nください……！　いつでもっ、いつでも受精できます、からっ、あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0304132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「いま、今、もう……もうっ！　イッておりますっ……！　ずぅっと……ずっ\nとイッておりますからっ！　あぁ！　あっ！　あっあっあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0304133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「たねぇ……♪　旦那さまのたねで赤ちゃん作るんですぅ……！　赤ちゃんっ\n……あっ♪　あっ♪　わたくしをママにしてくださ……いぃ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0304134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「せいえきぃ……中に……いちばん奥にびゅるびゅるしてほしいですぅう……\n♪　赤ちゃんのおへや、開いてます、待ってます、から……ふぁあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0304135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あんっ♪　あんっ、あぅううっ、ふぁああんんっ……♪　あ……っ♪　中に\n……！　中にびゅっ！　びゅっ！　って出てます……出てますぅう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0304136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022103_02_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「はい……！　はい、そうです……そうですぅっ！　わたくしは……わたくし\nは旦那さまにこうされたかったんですぅ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0304137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「えっちな子なのでっ……中出しがだいすきです♪　せいえきを……直接赤ち\nゃんのおへやにかけてもらうのがすきなんです……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0304138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「っ……くぅううんんっ♪　あうぅう……♪　うぅ……！　もっと、もっとぉ\n……！　あぁ……！　すごい……すごいんですぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0304139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「絶頂しながら、ちつないしゃせい……♪　赤ちゃんのたねをおまんこにびゅ\nっびゅされると……イキますっ！　んんん～～～～～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0304140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「っふぁあああ……♪　いっぱい出ましたぁ……♪　これで着床確実です……\n。って、だ、旦那さま……？　一体どうなさったのですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0304201" ]},
		{"command":[ "SETIMAGE", "0", "still_00022103_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あっ♪　しゃせいしたのに……まだできるのですか？　あっ♪　い、今全部\nせいえきを出したから……また作る……！？　ええええっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0304202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「す……すごいです！　かっこいいです……！　はい！　はいっ……わたくし\nもそれがいいです、何度でも、何度でも中出ししてください♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0304203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「わたくしのおまんこに、ぴゅっぴゅできるのは愛する旦那さまだけなのです\nから……。あっ♪　時間も、回数ももちろん無制限です……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0304204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「……んっ……！　わぁ……♪　か、硬いままですね……？　おちんちんさん\n、むしろさっきより元気いっぱいで……あばれんぼうで……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0304205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「すてきです……！　お願いします！　いっぱい突いてください……あっ♪　\nわたくし、うっとりして……どきどきしちゃいます……！　っあぁあ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0304206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あッ♪　んっ♪　んっ、んんッ……♪　あふ……♪　ち、力がつよくて……\nあっ！　身体が宙に浮いちゃい、ます……すごい……！　あっあぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0304207" ]},
		{"command":[ "SETIMAGE", "0", "still_00022103_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「やっぱりわたくしは……旦那さまでなければだめですっ♪　大好きな旦那さ\nまのっ、宇宙一かっこいいおちんぽで孕みたいのですっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0304208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「っあふ……♪　あぅ……♪　あうぅう……♪　えぐってくださ、い……♪　\nあぅっ♪　うぅ……♪　へいきです、わたくしはえっちです、から♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0304209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「きつく挿入っ……されてぐちゅぐちゅずぷずぷピストンされると……かんじ\nますっ、うれしいです、しあわせです……きもちいいんですっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0304210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あっ、あぁ……♪　だいすきぃ……♪　だいすき、すき……すき♪　おちん\nぽも旦那さまも宇宙一すきぃ……♪　すきぃ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0304211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「わたくしのおまんこ……気持ちいいですか？　えへへ……キツキツで、初め\nてした時と変わらない？　……嬉しいです♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0304212" ]},
		{"command":[ "SETIMAGE", "0", "still_00022103_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「その時よりも、ねっとり絡みついてきて……あぁっ♪　甘えてきてチンポに\n響く？　あは……♪　そんなに褒められると照れちゃい、ます……。んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0304213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「旦那さまのおちんちんもっ、同じです……！　さいしょのときより、ずーっ\nとずーっとコチコチで、激しくて……うんと気持ち良くしてくれます！」", "NORMAL" ]},
