		{"command":[ "PLAYVOICE", "v2_221_0304216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「わたくしのちっちゃなおまんこから溢れ出すくらいしゃせいしてください♪\n　あっ……あっ♪　ぎゅうって♪　ぎゅうって力をこめてしめつけます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0304217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「だから……♪　せいしください♪　えっちなアンにせいえき注いで、えっち\nなママにしてください♪　んっ……すき……すき、すき♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0304218" ]},
		{"command":[ "SETIMAGE", "0", "still_00022103_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
