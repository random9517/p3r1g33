		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あっんんんっ！？　おかけになるのですか！？　あっ……あったかい……♪\n　びゅるびゅるいっぱい、シャワーみたいで気持ちいいですけど……っ」", "NORMAL" ]},
