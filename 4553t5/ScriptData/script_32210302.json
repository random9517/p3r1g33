		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「わたくしのおまんこが、またヒクヒクとうずいています……。っふぅぅ……\n♪　子作り……大好きになってしまいました♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0304309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
