		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「いいですよ♪　何回でも、赤ちゃん作り……しましょう♪　たくさんわたく\nしを抱いて、えっちな妻にそだてつづけてくださいね……♪」", "NORMAL" ]},
