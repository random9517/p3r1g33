		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「赤ちゃん……！　赤ちゃんが、これではできませんよぉ……！　っあぁっ…\n…！　お外に出しちゃだめですぅう……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0304403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ひぁあんっ……あんっ、んん……！　溺れちゃいます、……あっ……♪　息\nができないくらい、かかって……ふぁああ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0304404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あぁ……。ぜんぶ、わたくしの身体に……かかってしまいましたね……。ん\nっ、い、嫌ではありません。とっても好きなにおいで、……んっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0304405" ]},
		{"command":[ "SETIMAGE", "0", "still_00022103_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「旦那さまに包まれて……うっとりしちゃいます。すぅうう……はぁあああっ\n……♪　こうして息を胸いっぱいに吸い込むだけで……とろけちゃいます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0304406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「こんなにたくさんのせいえきがお腹の中に入ったら……ぜったい妊娠してま\nした。見てください……もう真っ白で、ドロドロで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0304407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「さすがはわたくしの愛する旦那さまです……♪　男らしいしゃせい……♪　\nわたくしのすべてを埋めつくす、たくさんの赤ちゃんの種……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0304408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「中出ししなかったことを怒っているか、ですか？　……えへへ、まさか。わ\nたくしが旦那さまのご決断を否定するはずはありません」", "NORMAL" ]},
