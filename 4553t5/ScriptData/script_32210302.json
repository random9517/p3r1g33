		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ひゃんっ……あぁうっ……！？　だ、旦那さま……！　ど、どうしてわたく\nしの中からおちんぽ様を引き抜いて……ふぁああっ♪」", "NORMAL" ]},
