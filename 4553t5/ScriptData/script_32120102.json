{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021201_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「隊長さんってタイヤ交換もできるのね。こんな大変な作業を一人でするなん\nて、とっても偉いわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0104101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「でも、本当に一人で大丈夫？　私のタイヤって大型車両用だから、重たいわ\nよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「普通車で何回も交換したし、ジャッキで車体も持ち上げれてるから大丈夫…\n…？　だ、ダメよ。そんな安易な考えじゃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0104103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「交換の手順は普通車と変わらないけど、私は大型なのよ……！　万が一タイ\nヤが隊長さんの身体に倒れたりでもしたら……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0104104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「怪我は絶対にしないって言われても……心配だから、手順を説明してあげる\nわ。だから安全第一で作業をして頂戴ね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0104105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「んっ……それじゃ、タイヤを外すために、まずはホイールカバーを外しまし\nょうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0104106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「ホイールカバーには少しくぼんだ箇所があるから、そこをマイナスドライバ\nーとかで少しこじ開けて頂戴。工具がないなら、手でもいいわよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0104107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「ああっ……マイナスドライバーが、くぼみに入って……んっ、私のホイール\nカバー、外されちゃってるぅ……！　やっ、あっ……ああぁん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0104108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「だ、ダメよ、隊長さん……！　くぼんだ箇所から無理やりカバーを外そうと\nしないで……！　そんなことしたら、カバーが壊れちゃうわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0104109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「こじ開ける場所を少しずつ変えて……そ、そう……上手よ……！　カバーが\n外れたら、次はホイールナットを緩めて頂戴……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0104110" ]},
		{"command":[ "SETIMAGE", "0", "still_00021201_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「きゃあああぁ！？　そ、それ、インパクトレンチ……！？　やっ、イヤ……\n！　隊長さんっ！　いきなりそんな強力な道具を使うなんて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0104111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「まずは人力で……タイヤレンチを使って、丁寧に外して頂戴……！　じゃな\nいと、私……あっ、あっ……！　だ、ダメ……！　電源を入れないでぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0104112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「んひいいいいぃ！？　あっ、ああああんっ！　インパクトの衝撃が、足回り\nから車体に響いてくるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0104113" ]},
		{"command":[ "SETIMAGE", "0", "still_00021201_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「た、隊長さんっ！　ナットからガリガリって変な音がしてるわっ！　もしか\nしてインパクトを回す方向、間違ってない！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0104114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「ナットを緩めるとき、時計回りじゃダメよ！　緩める方向は必ず反時計回り\nっ！　ナットやボルトの大半は、左側に回すと緩まるって決まってるの！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0104115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「だ、だから一度インパクトレンチを止めて……！　んふううぅ……！　そ、\nそうよ……まずは落ち着いて、左回りに設定して頂戴……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0104116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……いい、隊長さん……ナットやネジといった固着具は、『の\n』の字に回すと締まる、その逆で緩まるって憶えておいてね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0104117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「それじゃあ、続きを……！　あっ、あああっ！？　ま、また最初から力強く\nナットが緩まって……！　あっ、やっ、フレーム当たってるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0104118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「ああああっ！　足回りが緩んでいくの感じるぅ！　私の身体、隊長さんでほ\nぐされてるのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「やっ、あっ……！　一番上のナットが緩んで……んひっ！？　あああっ！　\n工具からすごい音が響いてるぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0104120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「そんなに激しくしなくても、ナットは外れるからぁ！　だから強く押し込ま\nないでっ！　ゆっくり、少しずつ回してぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0104121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「じゃないとインパクトレンチでホイールが傷ついちゃうっ！　ハブボルトが\nなめちゃうのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「んっ、ぐううぅ……！　そ、そうよ……！　ゆっくり、優しくインパクトレ\nンチを回転させて……あああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0104123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「おっ、おおおぉ……！？　一気に足回りが軽くなってるぅ……！　タイヤが\nさらに緩んで……んぐっ、はあっ、あはああぁん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0104124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「ちゃんとナットを緩められたのね……！　なら、次は好きなところを緩めて\n……んおおおおおぉ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0104125" ]},
		{"command":[ "SETIMAGE", "0", "still_00021201_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「こ、今度は奥までインパクトレンチが入って……！？　んひいいいぃ！　振\n動すごいのぉ！　タイヤだけじゃなくて、車体もブルブル震えてるのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「あああっ！　感じるぅ！　タイヤが外されていくの、感じちゃううううぅ！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0104127" ]},
		{"command":[ "SETIMAGE", "0", "still_00021201_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……また一つナットが緩んで……！　はひいいぃ！？　これが\nあと何回続くのぉ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「ホイールナットはあと８個あるから、８回で終わりって……！　こ、こんな\n快感、あと８回も続けられるの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「だ、ダメ……！　そんなの耐えきれない……あはあああぁんっ！　い、言っ\nてる側から、またナットが緩められてるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「あっ、ああああっ！　インパクトの回転が気持ちよくなってきてるっ！　フ\nレームにあたるのも、快感になってるのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「こんなタイヤの外され方、はじめてだわっ！　今までこんなに感じたことな\nいのに……んふううぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「やっ、あっ……！　くるっ……！　来ちゃうぅ……！　奥の方から、すごい\nの来ちゃうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「ふああぁ！　もう我慢できないわっ！　あっ、あっあっあっ！　イクッ……\n！　イクイクッ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「さ、最後のナットも緩まってる……！　も、もう無理っ！　イクッ！　イグ\nうううううぅん！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0104135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「あはああああぁん！　私のフロントガラスに、ウォッシャー液が飛び出てる\nぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0104136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「今日はタイヤ交換で、フロントガラスを綺麗にする予定なんてないのに……\nああっ、ダメっ！　止まらないのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0104137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「んぐううぅ……！？　た、タイヤがゆっくりと外されて……！　あっ、あっ\n！　その触り方、感じちゃうっ……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「さっきまでインパクトレンチで激しく刺激してたのに、急に優しくタイヤに\n触れるなんて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0104139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「ああっ！　またイクッ！　イッちゃうううぅ！　ウォッシャー液、びゅるび\nゅる吹き出ちゃううううぅ～～～～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0104140" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021201_02_05" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「あっ、あんんっ……！　あ、新しいタイヤを取り付けるのね……！　なら、\nまずはハブボルトと噛み合うように、真っすぐタイヤを入れ込んで頂戴……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0104201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「んっ、ああっ……！　入って、くるぅ……！　新しいタイヤが、私の足回り\nに……んんんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「ぜ、全部奥まで入ったのね……こんなに大きくて、重たいタイヤなのに……\n隊長さんって、力持ちなのね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0104203" ]},
		{"command":[ "SETIMAGE", "0", "still_00021201_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「それじゃあ、次は手でナットを仮締めして……あああっ！　そ、そう……！\n　グリグリって、奥まで回し挿れてっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0104204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ！　隊長さんの手で、締め付けられてるっ……！　すごいっ！　\nこんなの、感じすぎちゃうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0104205" ]},
		{"command":[ "SETIMAGE", "0", "still_00021201_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「ひうううぅ！？　だ、ダメっ！　ナットの締め方が違うわっ！　ナットを締\nめるときは、必ず締めた場所から対角線上にあるナットを締めて頂戴っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0104206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「じゃないと、ホイールのセンターがズレて、事故に繋がっちゃうわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「ホイールナットを締め込むときは、１本だけにチカラが偏らないように……\nそ、そうよ……！　少しずつ、平均的に締め込んでいって……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「全部締め終えたら、タイヤレンチで本締めを……って、あああっ！？　ま、\nまたインパクトレンチを使うの……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「そんな……だ、ダメ……！　緩めるだけでもあんなに感じたのに、本締めで\nインパクトレンチなんてつかわれたら……！　あっ、あっ！　あああぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0104210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「んひいいいいぃ！？　締まってるぅ！　私のホイールナット、ぎゅうぅぅぅ\nって締め付けられてるのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0104211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「こんな振動、耐えきれないないわっ！　あああっ！　しかも、ちゃんと対角\n線上に締め付けられて……んふうううぅんっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0104212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「おっ、んほおおおぉ！？　そ、そんなに強く締めすぎないでぇ！　オーバー\nトルクしちゃうっ！　ハブボルトが折れちゃうううぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0104213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「んっ、あっ！　そんなに素早くインパクトレンチを出し入れされたら……！\n　あっ、んひっ！　またイクッ！　イッちゃうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0104214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「ダメっ、ダメぇ！　車体が震えすぎて、イクの我慢できないのぉ！　あああ\nっ！　イクッ！　イクイクッ！　イクぅ～～～～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0104215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「おほおおおぉん！？　ま、またびゅるびゅるウォッシャー液が出てるのおお\nおおぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0104216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「こんなに出したら、タンクが空になっちゃうわっ！　この前補充したばかり\nなのに、また補充しないといけなくなるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0104217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「あああっ！　インパクトの衝撃がまだ続いて……はひいいぃ！　あっ、イク\nッ！　イッてるのに、イッちゃうううぅ～～～～～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0104218" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021201_02_05" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「あはあああぁんっ！　気持ちいいっ！　タイヤ交換、すっごく気持ちいいっ\n！　新品のタイヤになるの、感じすぎるのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0104219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「んっ、はあああぁ……！　す、すごかったわ……もうこれ以上ないくらい、\n素敵な時間だったわ……って、隊長さん……どうしたの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0104220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "交換をもう一度する","LABEL1","磨いて終わらせる","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「えっ！？　タイヤを付け間違えた！？　ど、どういうことなの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0104301" ]},
		{"command":[ "SETIMAGE", "0", "still_00021201_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「スタッドレスタイヤを付けようとしてたけど、用意してたのが普通のタイヤ\nだった……？　つまり、タイヤを見間違えたのね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「そうよね……タイヤはパッと見ても、違いなんてわからないもの……間違え\nても仕方ないわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0104303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「いい、隊長さん。タイヤのサイズや種類は、側面に表示してあるの。だから\n作業する前に、ちゃんと確認してね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0104304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「あっ、ちょっと……そんなに落ち込まないで……！　私は別に怒ってないか\nら……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0104305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「でも困ったわね……このままじゃ、違うタイヤを履いたままになっちゃうし\n……どうしようかしら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0104306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「え？　とりあえず、もとのタイヤに戻しておく……？　ま、待って……！　\nそれって、またあの快感を味わうってこと……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0104307" ]},
		{"command":[ "SETIMAGE", "0", "still_00021201_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「やっ……！　あっ、ダメ……！　またホイールカバーが外れて……はあああ\nぁん！　さ、さっきより上手になってるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0104308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「こんな一瞬で綺麗に外せるなんて……！　やっ……！　また、インパクトレ\nンチがホイールナットに入って……はあああぁん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0104309" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021201_02_05" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「やっ……だ、ダメっ……！　電源を入れないで……！　これ以上されたら、\n本当にウォッシャー液がなくなっちゃうからあああぁ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「ついでだし、ホイールも磨いておくの……？　うふふっ。嬉しいわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0104401" ]},
		{"command":[ "SETIMAGE", "0", "still_00021201_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「タイヤは消耗品だから頻繁に変えるけど、ホイールはそうもいかないものね\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0104402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「ああっ……タオルの感触が心地いいわ……んっ、あんっ……！　その手つき\n、優しくて好きよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0104403" ]},
		{"command":[ "SETIMAGE", "0", "still_00021201_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「んっ、くふっ……！　そ、そう……その溝のところとか、汚れが溜まりやす\nいから……あっ、はああぁん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0104404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「丁寧にお手入れされると、ホイールだけじゃなくて車体の寿命も延びるわ…\n…だから車には、定期的なメンテナンスが必須なの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0104405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「これからもずっと私をメンテナンスしたいの……？　タイヤも交換するし、\n可能なら整備もしたいだなんて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0104406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「そ、そんなのダメよ……！　タイヤ交換はまだしも、整備するには自動車整\n備士の資格がないと……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0104407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「私のために資格をとるから、整備させてくれだなんて……！　んんっ……！\n　う、嬉しくてイッちゃうわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0104408" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021201_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……わかったわ……隊長さんが資格を取るためにも、いっぱい私\nの車体で勉強させてあげる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0104409" ]},
		{"command":[ "SETIMAGE", "0", "still_00021201_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「奥の奥まで、いっぱい見せてあげるわ……だから絶対に、資格を取って頂戴\nね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0104410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}