		{"command":[ "SETTEXT", "下校時刻はとっくに過ぎ、日もすっかり沈んでしまった。", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「カツマ先生……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020113610001" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113610001" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "sbg_0127" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「ふふ……見事だ……。その感覚、しっかりと覚えておくように……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_020113610001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ルルーナの放った渾身の一球を受け止めたベルガマスクが、校庭に膝をついた\n。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「良き闘志を見せてもらった。どうやら、私の出番はここまでのようだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_020113610002" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「お前はもう、一人で戦っていける。師を超え、心置きなく、強敵と書いてラ\nイバルと読む者たちとの血戦に挑むがいいっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_020113610003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「はい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113610002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「死合での活躍を期待しているぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_020113610004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「はいっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113610003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0150" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "悠々と校庭を去るベルガマスク。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「ありがとう……ありがとうベルガマスク……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113610004" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あいつはいったいなんなんだ……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0147" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "必殺技を編み出してからは、ルルーナの無茶な特訓は減ったようだ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「さて、当日ですな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113610001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああ。ついにこの日が来たか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ルルーナ殿は、未完成の必殺技でどこまで戦えるでしょうか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113610002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「未完成？　あの技がか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "あんな凄い球が未完成なんて、あり得ないだろう。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ええ。ドッジボールは受け止められては相手のボールになるのですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113610003" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「あのとき、ベルガマスク殿はボールを受け止め、落としませんでした」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113610004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、あのボールを受け止められる相手なんてそうそう現れないだろう」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「下僕っ、なにを話しているの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113610005" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いやなにも……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「ふん。まあいいわ。いよいよ今日は本番の試合よ。しっかり見ていなさいね\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113610006" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ドッジボールの常識の範囲内で頼みますよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「あっ、カツマ先生……ルルーナ、さん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020113610002" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お、夜日楽」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「夜日楽さん、今日はがんばりましょうね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113610007" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「え、あっ、はい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020113610003" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「どうしたの？　しっかりしなさい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113610008" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「あ、あはは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020113610004" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "なんだか夜日楽がルルーナに怯えているように見える。チームの中に不和があ\nるのは少し不安だ。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "とはいえ、見守ることしかできないか、今は……", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0147" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_007" ]},
		{"command":[ "SETTEXT", "そして、いよいよ球技大会が始まった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "一般生徒たちの試合が終わり、続いて、地球防衛科の学生によるエキシビジョ\nンマッチがはじまる。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「実況はウチとカツマ先生。解説はセレイン先生です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_060113610001" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "能力のこともあり参加できない俺は、実況席での観戦をすることになった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「あーん、解説じゃなくて試合したいーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040113610001" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "4", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「わがままいうんじゃねーです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_060113610002" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「勝った方が先生とバトルだーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040113610002" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「そんな特典、誰も欲しがりませんって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_060113610003" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "試合前のキャプテン同士の握手。", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "6", "CENTER", "-300" ]},
		{"command":[ "SETCHARA", "1", "char_00001502_01", "6", "CENTER", "300" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「負けませんよ、絶対に」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113610009" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "みんと" ]},
		{"command":[ "SETTEXT", "「こちらこそ。勝利し幹部の座を……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_020113610001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「ルルーナチーム、ファイトー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113610010" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「おーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020113600002" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナチーム" ]},
		{"command":[ "SETTEXT", "「おーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130113610001" ]},
		{"command":[ "SETCHARA", "0", "char_00000801_01", "8", "CENTER", "400" ]},
		{"command":[ "SETCHARA", "1", "char_00002402_01", "8", "CENTER", "0" ]},
		{"command":[ "SETCHARA", "2", "char_00000113_01", "8", "CENTER", "-400" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "DISPCHARA", "2", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "みんと" ]},
		{"command":[ "SETTEXT", "「……って、話を聞きなさいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_020113610002" ]},
		{"command":[ "SETCHARA", "0", "char_00001502_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "DISPCHARA", "2", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「それでは、最初はみんとチームのボールでスタートです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_060113610004" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "みんと" ]},
		{"command":[ "SETTEXT", "「はぁあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_020113610003" ]},
		{"command":[ "SETCHARA", "0", "char_00001502_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "初球は様子見かと思ったが、みんとは最初から全力の投球だった。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「一直線のボール！　まっすぐ流々那選手を狙ってる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040113610003" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「この速さのボールなら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130113610002" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "あのベルガマスクの球にくらべたら、みんとの球はずっと遅い。しかし、次の\n瞬間には、", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「ああっと！　流々那選手吹き飛ばされたーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040113610004" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "流々那の身体が宙を舞っていた。……って、なんでだ！", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「流々那さんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113610011" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "みんと" ]},
		{"command":[ "SETTEXT", "「これが、清く正しいドッジボールのルールに則った加速する魔球です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_020113610004" ]},
		{"command":[ "SETCHARA", "0", "char_00001502_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「えっと、なにが起きたんです？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_060113610005" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「着弾の寸前に速度が音速に近づき、発生した衝撃波で流々那選手を吹き飛ば\nしたんだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040113610005" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ええい、初球からドッジボールから逸脱するんじゃない！", "NORMAL" ]},
