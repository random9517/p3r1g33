{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「はぁい……お待たせしましたね……ふふっ、緊張していますか？　実は、私\nも少しだけ……そんな状態です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0203101" ]},
		{"command":[ "SETCHARA", "0", "char_00002602_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「ですが、ずっと前から決めていたことですから……貴方の最近の頑張りに対\nして、何か私なりのご褒美を差し上げたいと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0203102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「勿論、即物的な物品での伝え方もありますけど……何となく貴方のアプロー\nチもありましたし……私としても少し満更でもない所がありまして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0203103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「そんな訳で……ご希望の通り、今日は貴方のママとして……息子のオチンポ\nをパイズリさせてもらっちゃいます……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0203104" ]},
		{"command":[ "SETCHARA", "0", "char_00002602_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「と言うわけで……早速、脱いじゃいましょう……ほーら、オチンポを出して\n……そうしたら、おっぱいの間にどうぞ……んっ、ふっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0203105" ]},
		{"command":[ "SETCHARA", "0", "char_00002602_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「はーい、よく出来ましたね。いいですよ、とっても元気で立派なオチンポ…\n…ママのオッパイが食べちゃいました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0203106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00002602_01_03" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「あぁん……熱いですねぇ……すごく火照って……オッパイの中でビクビクし\nてます……ふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0203107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「待ってて下さいねぇ。今、しっかり包み込んであげますからねぇ……はぁい\n……オチンポが見えなくなっちゃいました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0203108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「ふふ、どうですか？　ママのオッパイの中……気持ちいいですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0203109" ]},
		{"command":[ "SETIMAGE", "0", "still_00002602_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「ママも、今、貴方のオチンポを食べて、オッパイの中が……ムズムズして…\n…とってもいい気持ちになってるの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0203110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「もうちょっと待ってね……今、脈打っている状態を楽しんでるの……後で、\nちゃんとシコシコしてあげるからね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0203111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「ふふ、むにゅっと包み込まれる感じ……好き？　よかった……待ってね、今\n……唾液を中に入れちゃいますねぇ……えろぉぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0203112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「ほぉら……これで、オッパイの谷間がヌルヌルになって……ちょっとオマン\nコみたいな感じになりますよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0203113" ]},
		{"command":[ "SETIMAGE", "0", "still_00002602_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「ゆっくり動かして気持ちよーくなっていきましょうねぇ……んっ、ふっ、は\nっ、あっ、あんっ……はんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0203114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「あぁん……やっぱり、立派なオチンポね。こうして、動かすのもとっても窮\n屈で、んっ、はみ出してきちゃいそう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0203115" ]},
		{"command":[ "SETIMAGE", "0", "still_00002602_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「ずっと、とくんって動いてる……しっかり感じてくれてるのね……いい子、\nいい子……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0203116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「まずは、亀頭の所からじっくり可愛がってあげましょうか。ほぉら、オッパ\nイのお肉が、オチンポの先にめり込みますよー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0203117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「ねっ？　皮がめくれて、あったかいのが重なって……びくって震えちゃうで\nしょう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0203118" ]},
		{"command":[ "SETIMAGE", "0", "still_00002602_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「見た目はすごく逞しいオチンポだけど、こうして敏感に震えてる所を見ると\n……やっぱり、とっても可愛いって……そう思えちゃいますね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0203119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「ふふっ、でも……いざという時には、ものすごく頑張っちゃうオチンポなん\nでしょうね……んっ、はぁ……んふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0203120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「ほら……もっとくっつけて……シコシコしますよぉ……はっ、あっ、んふっ\n……んっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0203121" ]},
		{"command":[ "SETIMAGE", "0", "still_00002602_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「あぁ……んっ、ずりゅずりゅって……いい音しちゃってる……どうですか？\n　私のオッパイで、ちゃんと興奮してくれてますか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0203122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「ふふっ、それは何よりです。私も、すごくドキドキして……おっぱいがずっ\nと興奮状態になってますよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0203123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「でも、貴方の乱れた呼吸を聞いていると、もっとゾクゾクして……その声、\nいっぱい聞きたくなっちゃいますね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0203124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「だから……ふふっ、やせ我慢なんかしないで……感じてる時は、遠慮なく声\nを出していいですからね……んっ、んふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0203125" ]},
		{"command":[ "SETIMAGE", "0", "still_00002602_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「あんっ、またオチンポがビクってしましたね。今度は付け根のところ……し\nてあげましょうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0203126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「うんっ、はっ、んふっ、はっ、あっ……はぁっ、あんっ……あぁ……オチン\nポ逃げないで。しっかり捕まえておかないと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0203127" ]},
		{"command":[ "SETIMAGE", "0", "still_00002602_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「これだけ密着させても……溢れてきちゃうんですから……油断も隙もない…\n…オチンポさんですね……んっ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0203128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「あぁ……でも、中で……また、ビクビクしてるのが分かります……先っぽか\nら、じわっと先走りも出てるみたいですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0203129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「この調子でこすこすしてあげたら……あっという間にイッちゃいそう……ね\n、強くしてあげましょうか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0203130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「ふふっ、こくこく一生懸命頷いちゃって……本当に、可愛い……♪　いいで\nすよぉ……ほぉら、オチンポシコシコしましょうねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0203131" ]},
		{"command":[ "SETIMAGE", "0", "still_00002602_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「はっ、あはっ、あんっ、あぁっ、皮が……よじれる……んっ、オチンポが…\n…オッパイの中でどくんどくんって……脈打ってますっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0203132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「いつでもいいですよぉ……出すのは勿論、ママのオッパイマンコの中ですか\nら。ママのオッパイ孕ませて下さいねぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0203133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「白くて元気な精液……ぴゅっぴゅって出して……ママからも母乳が出る位に\n……んっ、あふっ……いっぱいにして下さい……んっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0203134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「あはぁんっ！　出ましたっ……オッパイマンコにっ……気持ちいい汁っ……\nビュクビュク出てますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0203135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002602_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「はぁんっ……あぁっ……あったかい……元気いっぱいの精子が……オッパイ\nの中で泳いでますね……んふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0203136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「ふふ……いいお顔です。それだけ気持ちよさそうにしてくれると、私も頑張\nった甲斐があったというものです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0203137" ]},
		{"command":[ "SETIMAGE", "0", "still_00002602_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「あぁ、終わりそうですね。えらいですよ、こんなに出せるなんて、いい子で\nすねぇ……ふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0203138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「あら、顔を赤くしちゃって……照れくさかったかしら？　いいのよ、今だけ\nは存分に甘えていいんだから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0203139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「ええ……リラックス。」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0203140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「んっ、あら……あらあら……オッパイの中で……また、オチンポがビクビク\nしてきたわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0203201" ]},
		{"command":[ "SETIMAGE", "0", "still_00002602_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「そうねぇ、逞しい男の子が１回だけじゃ、どうにもならないわよねぇ……分\nかりました、ママももうひと頑張りしちゃいましょうね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0203202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「んっ……貴方がたっぷり出してくれた精液のお陰で、ママのオッパイの中…\n…本当にオマンコみたいにヌルヌルね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0203203" ]},
		{"command":[ "SETIMAGE", "0", "still_00002602_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「だから、今度は貴方も腰を振って……ママをオナホールにしちゃいましょう\n。オッパイセックス……気持ちいいわよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0203204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「あんっ！　ふふっ、そうそう……ママの谷間を、好きなように犯していいの\nよ……あぁんっ、逞しいオチンポがいっぱい擦れてるぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0203205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「うんっ、はっ、あんっ、あぁんっ、いいわっ……気持ちいいっ……ママもズ\nボズボされてっ、オッパイすごく感じるのっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0203206" ]},
		{"command":[ "SETIMAGE", "0", "still_00002602_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「くんっ、うんっ、はぁんっ……ママも……ちゃんとしてあげないとっ……う\nんっ、ふっ、んくっ、うんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0203207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「あぁっ、グリグリしてるっ……うんっ、はっ、んくっ……いいのよっ、ママ\nのオッパイマンコっ……どんどん犯してっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0203208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「はっ、ひっ、あんっ、あぁんっ、ずりゅずりゅって……激しく……オチンポ\nっ、動いて来てるわっ……ああんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0203209" ]},
		{"command":[ "SETIMAGE", "0", "still_00002602_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「んふっ……男の子は元気が一番だもの。ママにもっと逞しい所を見せてね…\n…ママも、ぎゅうってオチンポ締め付けてあげるから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0203210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「ふふ、ぐちゅぐちゅ……いやらしい音がしちゃってる……ちょっと目を閉じ\nてみて。ほら……耳とオチンポの感触だけで味わってみて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0203211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「どうかしら……んっ、さっきより臨場感があるでしょう……？　ふふっ、亀\n頭が何度も押し合いへし合いしてるの……オマンコみたいでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0203212" ]},
		{"command":[ "SETIMAGE", "0", "still_00002602_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「そのうち本番も……それは、貴方のこれからの頑張り次第かしら……でも、\n今はこのオッパイを存分に味わって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0203213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「ほぉら、んっ、んふっ、あふっ……あぁ……ママもオッパイがじわじわ感じ\nてるわ……あっ、ふっ、はふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0203214" ]},
		{"command":[ "SETIMAGE", "0", "still_00002602_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「だって、こんな元気なオチンポが出たり入ったりしてるんですもの……興奮\nするに決まってるわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0203215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「このままキンタマの方も、むにむに転がして……ふふっ、またビクって来て\nる……縦ズリでオチンポしてあげましょうね……んっ、んふっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0203216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「あぁ……いいわっ、素敵よ……息子とのオッパイセックス……気持ちいいの\nっ、貴方もいい？　んふっ、ええ、分かるわ……ビンビンになってるものっ…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0203217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「また上がって来てるのね……また出しちゃいましょう……どうする？　また\n、ママのオッパイに中出しする？　それとも、違う所がいい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0203218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「ええ、勿論貴方の好きなようにしていいのよ……一番の欲望を、思いっきり\n私にぶつけて頂戴……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0203219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「はんっ、あっ……あぁっ、ママはどんな貴方でも受け入れるわ……さあ、後\nもう少し……んっ、はぁっ、あっ、あぁっ……どうする？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0203220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「また中がいいのね……ええ、勿論いいのよ。このままズボズボして……熱い\nミルク……ママのオッパイマンコにドピュってしてっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0203301" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「あぁんっ！　あぁっ……出てきたわっ……今度もいっぱい熱いの……ドピュ\nドピュしてるぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0203302" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002602_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「んふっ、とっても元気……さっきよりもいっぱい出てきてるみたいね……は\nぁぁ……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0203303" ]},
		{"command":[ "SETIMAGE", "0", "still_00002602_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「あら……ふふっ、じっと顔を見ちゃって、どうしたの？　ええ……ママも、\n今イッたわ……おっぱい感じてイッちゃった……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0203304" ]},
		{"command":[ "SETIMAGE", "0", "still_00002602_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「だって、こんな濃いザーメンの匂い、すぐ近くで嗅いじゃったんですもの…\n…オッパイだけでもイクわ……オッパイマンコなんだから当然ね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0203305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「ふふっ、またドピュって出た……今の話で興奮しちゃったの？　いいのよ、\n残さず搾り出しちゃいましょうね……はーい、ぴゅっぴゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0203306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「んっ……終わりそう？　そうね、やっと弱くなって来たかしら……はーい、\nお疲れ様でした。いっぱい出せて偉かったわねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0203307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「では、おしまい……くすっ、どうしましたか。そんなに照れくさかったです\nか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0203308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「まぁ、男の人はずっと強い所を見せていたいっていうプライドもあるから…\n…中々、こんな風にする機会もないでしょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0203309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「でも、たまには、こうやって甘えるのも悪くないでしょう？　またして欲し\nくなったら言って下さい。ちゃんと働いた子にはご褒美をあげますから、ね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0203310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「あら……オチンポの向きが変わったわね……そう、顔に掛けたいの？　ええ\n、いいわよ……ママの顔に、たっぷりのザーメンシャワーしてっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0203401" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「きゃんっ！　んふっ、出てるっ……熱いの……顔にビュクビュクっ……され\nてるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0203402" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002602_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「ふふっ……すごい量……こんなの一度にされたら……あふっ、ちゅぷっ……\n飲むのも一苦労じゃない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0203403" ]},
		{"command":[ "SETIMAGE", "0", "still_00002602_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「あっ、ううん、いいのよ。それだけ元気があるってことなんだから……遠慮\nしないで、ママにぶっ掛けて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0203404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「ママも……んっ、はぁ……たっぷりのザーメンシャワーで……んっ、イッた\nわ……この精液の味……癖になっちゃうから……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0203405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「この際だから、全部出し切っちゃいましょう？　んちゅぷっ……精液も、マ\nマにもっと味見させて……れろ、ちゅぱ……んっ、美味しい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0203406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「ふふっ、まだオチンポがビクビクしてる……後もう少しだけ頑張りましょう\nね……はーい、ぴゅっぴゅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0203407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「んっ、全部出せたかしら……はーい、オチンポよく出来ましたー。いい子、\nいい子ねぇ、はい……おしまい。ふふっ、お疲れ様でした」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0203408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「ちょっと恥ずかしかったですか？　そうですね……あんまり、大っぴらに見\nせることではありませんからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0203409" ]},
		{"command":[ "SETIMAGE", "0", "still_00002602_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「でも、たまには、こうやって甘えるのも悪くないでしょう？　またして欲し\nくなったら言って下さい。ちゃんと働いた子にはご褒美をあげますから、ね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0203410" ]},
