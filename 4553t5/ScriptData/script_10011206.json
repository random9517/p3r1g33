{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0113" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_005" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「うわあっ！　ドラグソードが！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010112110001" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ドラグソードが……倒れた！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010112110001" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「この程度なら心配ない。立て！　ドラグソード！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090112110001" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「よかった、立ち上がった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010112110001" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「だけど、これまでのダメージが蓄積しているはずよ。どこまでもってくれる\nのか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010112110001" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうだな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「って、通信！？　こんなときに誰だ！？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「こちら、冴島だ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010112110001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「長官！？　いま、どこですか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010112110002" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「脱出船団は無事地球についた。グレート・ルナリアムからの避難者は、現在\nこちらで保護している」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010112110002" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「地球に！？　ずいぶん早いな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090112110002" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ああ、ミス・パープルが協力してくれたからな。ワームホールを通れば、月\nから地球はあっという間だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010112110003" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そうか……よかった！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010112110001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「次は、君たちを助けに行く番だ。現在、脱出船を修理して再び月に向かう準\n備を進めている」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010112110004" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「１隻だけですが、それで地球に残っていたインクレディブル・スクワッド全\n員と、ＥＤＯ精鋭部隊が月に乗り込めます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010112110001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「インクレディブル・スクワッド全員だって！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「へへへ、地球のヒーローと悪の幹部が勢ぞろいってことだぜ。なんか、そん\nな映画あったよな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020112110001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「月までは、とにかく最短の軌道で飛んでいく予定です。その軌道から計算す\nると、着陸地点はコペルニクス・クレーターになります」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010112110002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「コペルニクス・クレーターか……ここからはそう遠くないな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010112110002" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「では、そこまで移動して援軍を待ちましょう。戦力が分散してしまっては意\n味がありません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010112110002" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「それがいいだろう。着陸地点の安全を確保するという意味でもな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090112110003" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「よし、それでいこう。そうと決まれば、とにかく脱出路を開かないとな！　\nドラグソード、もう少しがんばってくれ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}