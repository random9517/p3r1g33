{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00011104_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「きゃあああああぁ！？　ちょ、ちょっとカツマちゃんっ！？　これはいった\nい、どういうことなの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0404101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「確かに今日は定期メンテナンスの日だけど……！　プラグの繋ぎ方がいつも\nと違うわっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0404102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「あひっ、んんんっ！　腕や脚だけじゃなくて、おっぱいにもプラグが絡んで\nきてっ……！　やああぁ、なにこれぇ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0404103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ……！　アソコにもプラグがあたって……んひっ、あっ……！　\nダメッ、そこは今日メンテナンスする場所なのにっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0404104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「メンテナンスだから、プラグをあてるのは間違いじゃないって……！　そっ\n、それはそうだけど……んひっ！？　あっ、あひいいいぃ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0404105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「やあああぁ！　プラグがブルブル震えてるぅ！　あっ、あっ！　アソコのビ\nンカンなところに、バイブがあたってるみたいな感じがっ……あはあぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0404106" ]},
		{"command":[ "SETIMAGE", "0", "still_00011104_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「やっ、んっ、あはあぁ！　おっぱいや乳首にも振動がきてっ……！　んひっ\n、あっ、あぐっ！　なっ、なにこれぇ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0404107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「ひぎっ、がっ、あっ！　ああああっ！　ダメっ！　ダメえぇ！　全身、感じ\nすぎちゃうっ！　ふっ、あひっ、んひいいいぃ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0404108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「これっ、本当にメンテナンスなのっ！？　エッチなことしてるんじゃなない\nのぉ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0404109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「ひぎいいいぃ……！？　やっ、やああぁ……！　まるでプラグが意思を持っ\nて動いてるみたいっ……！　こんなの、おかしいわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0404110" ]},
		{"command":[ "SETIMAGE", "0", "still_00011104_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「かっ、カツマちゃんっ！　お願いだから、メンテナンスを中止してっ……あ\nああぁっ！？　やっ、あっ！　ひぎっ、んひいいぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0404111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「アソコも乳首もジンジンするぅ！　ビンカンなとこばっかり弄られて、感じ\nすぎちゃうのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0404112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「こんなにされたら、メンテナンスなのにカツマちゃんのが欲しくなっちゃう\nっ！　ああぁ、欲しいっ！　カツマちゃんの熱いの欲しいのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0404113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「ふえっ……？　卑猥な言葉で上手におねだりできたら、アソコに挿れてメン\nテナンスしてやるだなんて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0404114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「卑猥な言葉とか言われても、そんなのわからっ……んんっ……！？　やだっ\n……Ｍ．Ａ．Ｍ．Ａ．のＡＩが卑猥な言葉を検索してるっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0404115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「そっ、そんなエッチこと言えないわっ！　カツマちゃんにいやらしくおねだ\nりだなんて……！　でも、言わないと挿れてもらえないし……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0404116" ]},
		{"command":[ "SETIMAGE", "0", "still_00011104_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「くっ……うううぅ……！　あ、あのね……カツマちゃん……！　私のアソコ\n、カツマちゃんのが欲しくてウズウズしてるのっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0404117" ]},
		{"command":[ "SETIMAGE", "0", "still_00011104_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「プラグでいっぱい弄られて、ヒクヒクしてるの……わかるでしょ……？　こ\nこに挿れたら、カツマちゃんも絶対に気持ちよくなれるわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0404118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「だから奥までカツマちゃんの挿れて、いっぱいズポズポしてっ……！　ぎゅ\nーって締め付けて、アソコの奥でたくさんシコシコしてあげるからぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0404119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「私のエッチなアソコ……カツマちゃんのたくましいのでホジホジしてっ……\n！　奥まで突き入れて、感じさせてぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0404120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「んひいいいいぃ！？　あっ……あっ……！？　そんなっ……いっ、いきなり\n挿れるだなんてぇ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0404121" ]},
		{"command":[ "SETIMAGE", "0", "still_00011104_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「私、まだ心の準備ができてないのにっ……！　ぐっ、あああぁ……！？　お\nっ、奥までカツマちゃんのが届いてるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0404122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「ああっ、あっ！　あはああぁ！　最初から激しっ……！　んんっ！　あっ、\nやああぁ！　思いっきりパンパンされてるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0404123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「エッチな音が部屋中に響いてるのぉ！　ああっ！　ダメっ！　ダメえぇ！　\n奥の方をホジホジするのダメなのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0404124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「ダメって言ってるクセに、アソコが締まってるだなんて……！　だっ、だっ\nて……！　カツマちゃんのが、気持ちよすぎるからぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0404125" ]},
		{"command":[ "SETIMAGE", "0", "still_00011104_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「アソコの接続プラグは、私の感情に合わせて自動で動くようになってるのっ\n……！　だから気持ちいいと、自然と締まって……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0404126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「あああっ！　やっ、あっ！　あっ！　あはああぁんっ！　腰の動きがまた激\nしくなってる……んんっ！　あっ、ひっ、あひいいぃ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0404127" ]},
		{"command":[ "SETIMAGE", "0", "still_00011104_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「あっあっ！　全身のプラグもまた動き出してっ……！　ひあああぁ！？　ア\nソコパンパンされながら、乳首に振動が響いてるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0404128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「クリのところにもプラグがあたってるぅ！　やっ、あひっ、んひいいぃ！　\n乳首とクリを弄られながらアソコ突かれるの、ダメええぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0404129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「これ、感じすぎちゃうっ！　全身の回路がショート寸前なのぉ！　私の身体\n、壊れちゃうからぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0404130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「ひああああぁ！？　あっ、あっ！　あはああぁ！　カリのところがズリズリ\nって擦れるの、感じすぎるぅ！　んひっ、あくううぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0404131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「これっ、ダメっ！　イクッ！　イッちゃうううぅ！　メンテナンスなのに、\nイッちゃうからぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0404132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「ひぐううぅ！？　かっ、カツマちゃんのがアソコの奥でビクビクしてっ……\n！　カツマちゃんもイクのねっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0404133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「射精するなら膣内でっ……！　このまま私の一番奥に膣内出してぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0404134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「んひっ、あはぁっ！　カツマちゃんのが膨らみながら震えてるっ！　イッ、\nイクッ……！　あはっ、んんっ！　ひああああぁ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0404135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「あはあああぁんっ！　膣内にどぴゅどぴゅ出てるぅ！　カツマちゃんの精子\n、接続プラグに注がれてるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0404136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00011104_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「あっ、んひっ、あひいいいぃぃぃ！　膣内出しで気持ちよくなるぅ！　イク\nの止まらないのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0404137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ！　イッてるのに、まだ精子出てるぅ！　プラグでメチャクチャ\nにされながら、膣内出しされるの感じすぎちゃうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0404138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「ひぎっ、ぐっ、んふううぅ！　これ、またイクッ！　何回もイッちゃうっ！\n　あっ、あっ！　気持ちいいっ！　イクッ！　イクうううぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0404139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「んひっ、あっあっあっ！　イクッ！　またイクううううううぅぅぅ～～～～\n～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0404140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……！　んっ、あふっ……！　いっぱい出たみたいね……見え\nなくても、アソコのセンサーで全部わかるわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0404201" ]},
		{"command":[ "SETIMAGE", "0", "still_00011104_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「んっ、くっ……ね、ねえ……カツマちゃん……これで、メンテナンスは終わ\nりなの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0404202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「なんでそんなこと聞くのかって……えっ、えっと……その、あのね……私の\n身体……特にアソコのところ、まだ未調整の箇所が多いと思うの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0404203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「だからもっとカツマちゃんのでたくさん突いて、メンテナンスして欲しいな\nって思って……ダメかしら……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0404204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「どういうことか、はっきり言わないとわからないの……！？　ううぅ……か\n、カツマちゃんのイジワルっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0404205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「あっ、あのね……！　私のアソコ、まだカツマちゃんのが欲しくてウズウズ\nしてるのっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0404206" ]},
		{"command":[ "SETIMAGE", "0", "still_00011104_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「１回出されたくらいじゃ、全然治まらないのっ……！　ほら……接続プラグ\nも締まって、アソコを搾り上げてきてるでしょ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0404207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「だからもっとアソコをズポズポして、いっぱいエッチなことして欲しいのっ\n……！　奥の奥まで、メンテナンスして欲しいのぉ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0404208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「ひうううぅ……！？　あっ、ひぐっ……！　カツマちゃんのが、また大きく\nなってきてるっ……！　接続プラグが押し広げられて……んひいぃ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0404209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「んはあああああぁぁぁんっ！　またカツマちゃんのが、アソコに出たり入っ\nたりしてるのぉ！　気持ちいいのが止まらないわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0404210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「あっ、あはっ、んはあぁ！　プラグがまたウネウネ動いてっ……！　あああ\nっ！　アソコ突かれながら、全身舐め回されてるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0404211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「これっ、感じすぎるぅ！　接続プラグの締まりが最大になっちゃうっ……！\n　んんっ、んっ、んくうううぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0404212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「あっあっ！　締まりすぎてるのに、カツマちゃんの精液のおかげですっごく\n滑るぅ！　アソコ、ヌルヌルになりすぎてるのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0404213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「んっ、あっあっ！　ひあああぁ！　カツマちゃんっ！　もっとメンテナンス\nしてっ！　私の身体たくさん弄ってぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0404214" ]},
		{"command":[ "SETIMAGE", "0", "still_00011104_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「カツマちゃんの手とアソコとプラグで、全身感じさせてえぇ！　あひっ、あ\nっあっ！　んくっ、あっ、うううぅ……！　あふううぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0404215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「ダメっ！　これ、またすぐイッちゃうっ！　カツマちゃんので感じすぎて、\n感情と快感が制御できないのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0404216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「あああっ！　イクッ！　イクのぉ！　またイッちゃうのぉ！　んんっ、ひぎ\nっ、あっあっ！　ひぐっ、あふううぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0404217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「んんっ！？　アソコが大きく膨らんできてるっ……！　カツマちゃんもイキ\nそうなのねっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0404218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「なら、また一緒にイキましょうっ！　好きなところに出していいから、イッ\nて頂戴っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0404219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「膣内でも膣外でも、どっちでもいいからっ！　出してっ！　カツマちゃんの\n精子、出してっ……！　あひいいいいいぃぃぃんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0404220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「あはあああぁぁぁ……！　あっ、熱いのがまた膣内にぃ……！　どぴゅどぴ\nゅって、勢いよく出てっ……んふうぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0404301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00011104_02_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「ひぎっ、んふううぅ！？　えっ、あっ……！？　なんでっ……！？　このタ\nイミングで、またプラグが動いてっ……あはああぁ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0404302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「やあああぁ！　イッてる最中に、乳首やアソコをホジホジしないでぇ！　そ\nんなことされたら、またイッちゃうからぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0404303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「んっ、あっ！　イクッ！　膣内出しされながらプラグでエッチなことされて\n、イクッ……！　イクうううううぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0404304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「あああぁっ！　イクの止められないのぉ！　ひぐっ、んぎっ、あああぁ！　\nイッくうううううぅぅぅぅぅ～～～～～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0404305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、あはぁ……！　カツマちゃんのも、プラグも……どっちもす\nごかったわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0404306" ]},
		{"command":[ "SETIMAGE", "0", "still_00011104_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「こんなメンテナンスはじめてよ……またお願いしたいくらい感じて……んっ\n、んふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0404307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「えっ……？　ならこのまま、３回目のメンテナンスをしてやるですって……\n？　ちょ、ちょっと待って……！　それはさすがに……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0404308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「違うのっ……！　遠慮してるワケじゃなくてっ……！　接続プラグの膣内が\n精子でいっぱいだから、もう入らなくて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0404309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ……！　カツマちゃんの腰が引いてるっ……！　やっ、あっ……\n！　ちょっと待ってっ……！　あはあああああぁぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0404310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「あふっ！？　んっ、くううぅ！？　えっ、そんなっ……！　わざわざ顔にか\nけるだなんてっ……ひぐうぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0404401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00011104_02_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「んくっ、あぐっ、んはあぁ！？　カツマちゃんの精子、顔や胸にどぴゅどぴ\nゅかけられるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0404402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「好きなところに出していいって言ったけど、これは予想してないというか…\n…ああああっ！　まだ出てるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0404403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「メンテナンスなのに、全身が真っ白になって……！　イッ、イクッ！　精子\nかけられながら、イクぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0404404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「あああっ！　あっ、んっ、あっ！　ダメっ！　イクイクッ！　イッ……んく\nうううぅぅぅ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0404405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「あふっ……んっ、ふううぅ……全身が真っ白になっちゃったわ……さすがに\nこれは、もう１度洗車が必要かも知れないわね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0404406" ]},
		{"command":[ "SETIMAGE", "0", "still_00011104_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「あの、えっと……カツマちゃん……？　この全身に絡んでるプラグ、ほどい\nてもらえるかしら……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0404407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「メンテナンスはまだ終わってないから、ほどくわけにはいかない……？　そ\nっ、それってどういう……んんっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0404408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「やっ、あぐっ……！？　なっ、なんで……！？　またプラグがウネウネ動き\n出してるっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0404409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「やめっ……やめてぇ！　もうこれ以上メンテナンスいらないからぁ！　お願\nいだから、プラグをほどいてえぇーーーーー！！」", "NORMAL" ]},
