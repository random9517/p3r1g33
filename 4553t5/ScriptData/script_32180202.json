{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021802_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「それでは……ご主人様……内部メンテナンスを……お願い致します……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_0204101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「既に、ご主人様にはお分かり頂けていると思いますが……原則的に、この内\n部機構については、秘匿されるべき場所として認識されています」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_0204102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「ですが、限られた特別な方に対して、然るべき機会があればと……備えて頂\nいたものです……ご主人様には、お見せ致します……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_0204103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「んっ……ここが……ちょうど、私の局部……はい、オ、オマンコに当たる部\n分……です……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021802_02_02" ]},
		{"command":[ "PLAYVOICE", "v2_218_0204104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「このようにして見せるのは……初めてですね……んくっ、私のバイオセンサ\nーも……いつも以上に……活発になっています……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_0204105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「はい……これは、羞恥と呼ばれる感覚……ご主人様に……オマンコを見せて\n……あぁ……私は恥ずかしさを感じています……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_0204106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「あ……どうぞ、指で……刺激なさって下さい……んふっ、あぁ……はい、ん\nっ、こりこりと……あ……ふっ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021802_02_01" ]},
		{"command":[ "PLAYVOICE", "v2_218_0204107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「んんっ……分泌反応……開始……んふっ、濡れて……来ました……あ、ふっ\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_0204108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「ご主人様の愛撫……お上手です……はぁっ、んっ、この力加減が……自然に\n、私の準備を整えて行きます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_0204109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「あぁ……そろそろ……限界が近くなって参りました……ご主人様……次の段\n階に進んで頂けませんか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_0204110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「はい……挿入行為です。入力ポートのセキュリティロックを解除して……ご\n主人様のオチンチンを受け入れられる体制を整えます……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021802_02_02" ]},
		{"command":[ "PLAYVOICE", "v2_218_0204111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「ロック……解除……今、この開いている所が……くぱぁ状態と呼ばれるもの\nです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_0204112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「はい、先日学習しました……私の中でも特に技術の粋を集められた……オマ\nンコ……です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_0204113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「その、逞しく勃起したご主人様のオチンチンを……どうか、深々と……オマ\nンコの奥へと挿し込んで下さい……お願い致します……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021802_02_01" ]},
		{"command":[ "PLAYVOICE", "v2_218_0204114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……くぅぅぅんっ……あっ、はぁぁぁぁぁんっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021802_02_05" ]},
		{"command":[ "PLAYVOICE", "v2_218_0204115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「あっ……申し訳ありませんっ……その、咄嗟のことで……予期せぬ冷却液が\n……漏れてしまいました……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021802_02_04" ]},
		{"command":[ "PLAYVOICE", "v2_218_0204116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「嬉ション……ですか？　嬉しいと自然に漏れてしまうおしっこ……あ……そ\nう言われると、そういうものかも知れません……少し恥ずかしい、です……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_0204117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「んっ、ですが……挿入後の状態に影響はありません……大丈夫です、このま\nま続けて頂けますか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_0204118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「あっ……はっ、んっ、あふぁっ……んんっ、はふっ、あっ、んんっ、くっ…\n…んぅんっ……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021802_02_05" ]},
		{"command":[ "PLAYVOICE", "v2_218_0204119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「本物同然……ですか……？　よかった……んんっ、自然なものではないかも\n知れませんが……ちゃんと、ご主人様を満足させることは出来そうです……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021802_02_03" ]},
		{"command":[ "PLAYVOICE", "v2_218_0204120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「オチンチンの感覚ですか……？　そうですね……んっ、予想していた衝撃や\n、負荷はそこまででもありません……粘膜部分が程よく擦れて……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021802_02_04" ]},
		{"command":[ "PLAYVOICE", "v2_218_0204121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「とても、安心すると言ったらおかしいでしょうか……。丁度いいフィット感\nが、私の側でも、感じられます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_0204122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「はい、もう少し奥まで挿し込んで頂いて大丈夫です……んくっ、あっ、あぁ\nっ……は、んっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_0204123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「あぁ……ご主人様と、これ程までに密着したのは初めてです……ご主人様の\n体温、心拍数、その他の情報が私に直接流れ込んで来ます……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021802_02_03" ]},
		{"command":[ "PLAYVOICE", "v2_218_0204124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「中でも……んんっ、オチンチンの……この、感触は……やはり、特別な感覚\nを覚えます……あ、んくぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_0204125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「不思議です……んっ、もたらされる刺激と……そこから想定される反応に、\nこんな差異が発生するとは、思いませんでした……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_0204126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「ですが、この差異は決して不快ではなく……とても、心地いいものです……\nこの快感が……生殖の悦びというものなのですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_0204127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「あぁ……もっとしてほしいと、身体が……オマンコが知らせて来ます……ご\n主人様……オチンチン、もっと大きく動かして下さいっ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021802_02_04" ]},
		{"command":[ "PLAYVOICE", "v2_218_0204128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「あっ、ひぁっ、んぅっ、くぅんっ！　あぁっ、ご主人様のっ……腰が……速\nくなって……行きますっ！　は、あぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_0204129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「あぁっ、サーモセンサー上昇っ、この感覚はっ……開発されて覚えたっ……\nあの……高揚感ですっ、あっ、んぁぁっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021802_02_05" ]},
		{"command":[ "PLAYVOICE", "v2_218_0204130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「されれば……される程っ、身体が……反応してっ、一箇所に意識が集中して\nっ……はひっ、気持ち……よくなってぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_0204131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「あっ、あぁっ！　こんなっ、震えた声が……出ますっ、止まらないっ……ん\nひぁっ、感じっ……ますぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_0204132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「ご主人様もっ……同じ……ですかっ？　あぁっ、嬉しいですっ……私のオマ\nンコで……いっぱい、気持ちよくなって下さいっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_0204133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「はっ、んんっ、射精も……近いですかっ……？　はい、もし……精液を頂け\nたら……遺伝子解析してっ……赤ちゃんが作れるように頑張りますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_0204134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「ですからっ、いっぱい出して下さいっ……中にっ、オマンコにっ……子種を\nたっぷりと注ぎ込んで下さいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_0204135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「んくぁぁぁぁっ！　出て来てますっ……ドプって……中に……あっ、精液っ\n……来てっ、ますぅっ……！」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021802_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_0204136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、凄い量が……中を満たしてっ……あぁっ、私も……今……絶\n頂を味わっています……はぁぁぁっ……んっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_0204137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「あぁ……膣内に感じる精液は……初めてです……こんなにも濃いのが……身\n体を満たしていくのですね……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021802_02_06" ]},
		{"command":[ "PLAYVOICE", "v2_218_0204138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「んんっ……確かに、これなら本当に孕んでしまうかも知れません……ご主人\n様の赤ちゃん……ご迷惑になりませんか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_0204139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「お優しいお言葉……ありがとうございます。こうして愛して頂けるだけでも\n……私はとても幸せです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_0204140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「あの……その、お優しさに甘えてしまっても……よいでしょうか？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021802_02_07" ]},
		{"command":[ "PLAYVOICE", "v2_218_0204201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「もう少し、ご主人様のご寵愛を頂きたいと言いますか……その、まだ続きが\n出来るなら……もう一回……お願いしてもよろしいですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_0204202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「ひぁっ……！　あっ、はぁんっ……ありがとうございますっ……あっ、まだ\n……硬いままのオチンチンっ……逞しいですっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021802_02_06" ]},
		{"command":[ "PLAYVOICE", "v2_218_0204203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「お体に……負担はありませんか？　私の身体は、連続的な行為にも十分耐え\nられるようになっていますが……んぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_0204204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「３発でも４発でもっ……あぁっ、頼もしいですっ……んっ、ふっ、好きなだ\nけ……私のオマンコを……お使い下さいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_0204205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「あっ、はぁ、さっきより……オチンチンの感覚が変わってきている気がしま\nす……んっ、その、ご主人様と一つになっているというか……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021802_02_08" ]},
		{"command":[ "PLAYVOICE", "v2_218_0204206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「オチンチンとの繋ぎ目が分からなくなっているような……あぁっ、そんな感\n覚が……気持ち……いいですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_0204207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「いつになく饒舌に……あぁ……そうですね……どうしてでしょうか……無言\nであっても、セックスは出来ると思いますが……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021802_02_06" ]},
		{"command":[ "PLAYVOICE", "v2_218_0204208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「こうして、言葉を交わしていると……より、喜びを深められると言うか……\nもっとご主人様のことが好きになって行きます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_0204209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「はぁっ、あぁっ、気持ちいいです……はい……んっ、おっぱいも……お腹も\n……どこでもお好きなようにお触り下さい……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021802_02_08" ]},
		{"command":[ "PLAYVOICE", "v2_218_0204210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「私の身も心も……どこからどこまでも……全てご主人様のものですから……\nあっ、あぁうんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_0204211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「はぁぁ……身体全体が……本当に敏感になっています……どこを触られても\n……くぅんっ、気持ちよくてっ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021802_02_06" ]},
		{"command":[ "PLAYVOICE", "v2_218_0204212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「行き来する情報量が多すぎて……処理が……追いつきませんっ、もう身を任\nせるしかっ……身体が勝手に……動いて……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_0204213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「あぁっ、また……オマンコが……自然にオチンチンに吸い付いて行きますっ\n……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021802_02_08" ]},
		{"command":[ "PLAYVOICE", "v2_218_0204214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「ご主人様の為にと思っていたのに……自分自身の欲望がどんどん膨らんで行\nって……あぁっ、もっと……して欲しいって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_0204215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「はっ、んひっ、あぁんっ、いいんですかっ？　私が求めてしまって……いい\nんですかっ？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021802_02_09" ]},
		{"command":[ "PLAYVOICE", "v2_218_0204216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「はいっ、オチンチン欲しいですっ、私の蕩けたオマンコッ……もっとかき回\nしてっ、またご主人様に射精して欲しいですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_0204217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「んくぁっ、あぁっ、オマンコがいいっ！　ご主人様っ……はぁっ、私……ま\nたっ、絶頂にっ……達してしまいそうですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_0204218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「はぁっ、はいっ、ご主人様もっ……イッて！　出して下さいっ！　私も一緒\nにっ……イキたいですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_0204219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「ご主人様のっ……生命の証っ……私に全部出してっ……あぁっ、思いっきり\n射精して下さいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_0204220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「中にっ……はいっ、お願いしますっ……もう一回、中にっ……オマンコの奥\nに出して下さいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_0204301" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「んくぅぅぅぅぅぅんっ！　あぁっ……中っ……出てますっ、あふぁ……入り\n切らない位いっぱい……あ、溢れて来ます……」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021802_02_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_0204302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「んふぁ……あぁ、一番奥にこつんってオチンチンが当たって……あぁ、そこ\nに……精液がとぷんって……こんなにぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_0204303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「んんっ、ふは……あぁ、ご主人様の射精……こんなに続くんですね……人間\nの男性の中でも、特別なのでしょうか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_0204304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「でも、この出されている感じが続くのは……とても、好きです……余韻と言\nうのでしょうか……暫く味わっていたい感触です……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_0204305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「あ……射精……終わりましたか……？　はい、こんなにも励んで頂いて……\n本当にお疲れさまでした」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021802_02_12" ]},
		{"command":[ "PLAYVOICE", "v2_218_0204306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「んっ……オチンチンゆっくり抜いて下さい……これ以上こぼしてしまいたく\nないんです……あ、ふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_0204307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「あぁ……やはり駄目です……ぴったり閉じるように指示を出していますが…\n…完全には行かないようです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_0204308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「え……？　必要な分はまた出して頂ける……はい、そうですね……それは、\nとても魅力的なご提案です……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021802_02_11" ]},
		{"command":[ "PLAYVOICE", "v2_218_0204309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「はい、またしたくなったら、いつでもお申し付け下さい。私もご主人様と…\n…また、したいですから……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_0204310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「あっ……オチンチン抜けてっ……あっ……顔にっ、はいっ……おっぱいにも\nっ、出して……下さいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_0204401" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「んぁぁぅっ！　あぁっ……びゅくって出てますっ……！　ご主人様の精液っ\n……降り注いで……ますぅっ！」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021802_02_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_0204402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「んんっ……ご主人様の匂いです……身体に、たっぷり染み込んで……はぁぁ\n……温度は高くないのに……熱く感じます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_0204403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「んっ、あぁ……びくびくって……まだ出ています……あ、どうか……全部出\nしきって下さい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_0204404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「あぁ、凄いです……こんなにオチンチンが震えて……思わず見入ってしまい\nますね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_0204405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「あ……収まって来ましたか……？　はぁ……はぁ、はい、お疲れさまでした\n……こんなに沢山出して頂けて……とても嬉しいです」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021802_02_15" ]},
		{"command":[ "PLAYVOICE", "v2_218_0204406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「ゆっくりと肌に浸透していくような……そんな感じですね。あ……大丈夫で\nす、ちゃんと自分で拭う機能は備えていますから……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_0204407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「こうして拭くのも楽しみの一つ……そうなのですか……はい、そういうこと\nでしたら……ご主人様にお任せ致します……んふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_0204408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「確かに……こんな風にお世話をして頂けるのは……何だか幸せな気持ちにな\nりますね……はい、ありがとうございます」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021802_02_14" ]},
		{"command":[ "PLAYVOICE", "v2_218_0204409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「ええ、またしたくなったら、いつでもお申し付け下さい。私もご主人様と…\n…また、したいですから……♪」", "NORMAL" ]},
