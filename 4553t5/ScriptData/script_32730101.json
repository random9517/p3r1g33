{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0075" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「……し、失礼します……。ふふ、やっぱりご入浴中でしたか。そろそろ浴場\nに来られるんじゃないかって思って……そ、その、待ってました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0103101" ]},
		{"command":[ "SETCHARA", "0", "char_00027301_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「ええっ？　どうして私がここにいるのか、ですか？　驚かせてしまいました\nか……。私は三助、お背中を流すのが仕事ですから……。えっと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0103102" ]},
		{"command":[ "SETCHARA", "0", "char_00027301_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「もしよろしかったら、ぜひとも私を使ってください。隊長様のお身体を洗わ\nせていただきたいんです。……いいですか？　え、身体じゃなくて？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0103103" ]},
		{"command":[ "SETCHARA", "0", "char_00027301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「ひゃ、ひゃっ……！？　おちんぽを洗ってほしい……！？　た……隊長様、\n男の方の身体も洗うのが私の仕事です……。で、でも……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0103104" ]},
		{"command":[ "SETIMAGE", "0", "still_00027301_01_01" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「こ、ここだけを集中的に……だなんて。そんなことを言われたのは初めてで\nす。……そ、それに……こんなに大きなおちんぽ……見たことがなくて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0103105" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「は、恥ずかしい……っ。お。お父さんのおちんぽとまったく違う……。これ\nが隊長様の股間……、う、うぅ、ど、どうしたら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0103106" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「え……。私の胸の間に挟んで洗うんですか？　そ、そんなやり方……聞いた\nことがないです。隊長様は三助の仕事にお詳しいんですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0103107" ]},
		{"command":[ "SETIMAGE", "0", "still_00027301_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「わかりました。すごく恥ずかしくて……顔が熱くなってしまいますが……。\n隊長様は嘘をつかれるような方ではありません……。し、信用します」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0103108" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「……こう、ですか？　もっと大胆に全体を挟む……？　は、はい……。乳房\nの一番奥におちんぽを差し込みました。そして両側から肉を押しつけて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0103109" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「私の胸でここを丁寧に洗っていくのですね……。知りませんでした。勉強不\n足で申し訳ありません……。えっと……力加減はどれくらいでしょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0103110" ]},
		{"command":[ "SETIMAGE", "0", "still_00027301_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「これくらい……？　弱すぎますか。んっ……これくらい？　ま、まだまだ？\n　では……えいっ、こ、これくらい？　強すぎませんか？　平気ですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0103111" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「心をこめて、乳房で洗う……。んっ……んっ、んっ……！　胸を上下に揺さ\nぶって……、はぁ、はぁ……。あ、あの……隊長様のおちんぽって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0103112" ]},
		{"command":[ "SETIMAGE", "0", "still_00027301_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「形、がいやらしくて……。でこぼこしていて、胸で洗うと……なんだかヘン\nな気分になってしまいます……。む、胸を刺激されているみたいで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0103113" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁ、ふぅ……っ。ん……、んっ、んっ……。……あっ！　隊長様\n……。おちんぽ、まだ大きくなってきているみたいです、あ、す、すごい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0103114" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「は、はい。こんなにご立派なモノ……見るのは初めてです。もちろん、触る\nのも、いじるのも……。き……気持ちいいですか？　っんっ……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0103115" ]},
		{"command":[ "SETIMAGE", "0", "still_00027301_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「気持ちいいから大きくなってきている？　そ、そうなら嬉しいです。もっと\nできることがある？　それはなんですか。なんでも教えてください……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0103116" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「え……？　舌先で舐めてほしい……ですか？　く、口……。唇や舌でおちん\nぽをキレイにするんですね。わかりました……失礼いたします……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0103117" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「ぴちゃ……。っちゅっ、わ……！　ぁ、あ、あ……！　おちんぽ……っ。男\nの方の大切なところを、私なんかの舌が舐めてしまいました……。ぺろっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0103118" ]},
		{"command":[ "SETIMAGE", "0", "still_00027301_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「こ、これで本当に大丈夫なんですか？　もっとしてほしい……？　そ、そう\nなんですね……！　特に先端……？　きとう？　をまんべんなく……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0103119" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「あ、はい……。私はご奉仕させていただけるのはとても嬉しいです。ただ…\n…初めてこういった洗い方をしますので、たどたどしすぎて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0103120" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「隊長様の敏感な場所に、何か粗相をしてしまわないかと……。し、失敗を恐\nれているだけです。……違和感をおぼえたらすぐに教えてくださいね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0103121" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「ん……。ぴちゃっ、ぴちゃ、ちゅぷ……、ぺろっ、ぴちゃっ、ぴちゅっ、ち\nゅっ、ちゅぅ……くちゅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0103122" ]},
		{"command":[ "SETIMAGE", "0", "still_00027301_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「意外とうまい？　……本当ですか？　濡れた舌先が心地いい？　……わ……\n、嬉しすぎます、褒めてもらえて……感動しています……。ぴちゃっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0103123" ]},
		{"command":[ "SETIMAGE", "0", "still_00027301_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「私が舐めると、気持ちがよすぎて腰がビクビク跳ねてしまう……？　そ、そ\nんなに喜んでいただけるなら……こちらも本望です。がんばりますね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0103124" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「っちゅっ、くちゅっ、れろっ……ぴちゃっ。こうですか？　優しく……だけ\nど、先端を丹念に……。んちゅっ、唇ではさんで、接吻をするみたいに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0103125" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「あ、む、胸も一緒に動かした方が感じますか……？　それなら……！　んっ\n……！　こうやって揺らし、ながら……舐めます。い、いきます……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0103126" ]},
		{"command":[ "SETIMAGE", "0", "still_00027301_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「ん……あむっ、ちゅぷっ、ちゅっ、ちゅぅっ……くっちゅっ。ちゅ……れろ\n……ぴちゃ、ちゅぅっ、ちゅっ……。んっ、んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0103127" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「隊長ひゃまが気持ちよくなりますように……。ぴちゃっ、日々の疲れと汚れ\nを、洗い流せまひゅように……♪　んれろっ、ちゅぱっ、くちゅっちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0103128" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「心をこめて……洗います……。ん……、んっ、ンンッ……♪　ちゅぷ……ぷ\nちゅっ、くっちゅっ、ちゅぅっ……。れろれろれろっ……んぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0103129" ]},
		{"command":[ "SETIMAGE", "0", "still_00027301_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「ピクピク震えてます……。私、お役に立てているんですね……♪　ぴちゃ、\nぴちゃ……、んっ、んっ、んん……！　洗い方の筋がいい、ですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0103130" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「そんな風に言われると……舌先に、胸に熱が入ります……っ。ご奉仕、させ\nてください……！　私に隊長様を気持ち良くさせてください……れろっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0103131" ]},
		{"command":[ "SETIMAGE", "0", "still_00027301_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「はむっ、んむ……♪　んぅっ、ん、ん、ん……♪　あら……？　おちんぽの\n先から透明なお汁が……。これが汚れ……？　舐め取りますね……ちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0103132" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「じゅる……じゅるじゅるじゅるっ……、んぅ……♪　味は……特にしません\nが、胸で圧迫すると、次々にお汁が溢れてきて……。んっんっんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0103133" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「心配ひないれくだひゃいね……。隊長様の汚れはひゅべて、私がキレイにひ\nまひゅから……。じゅる……じゅる、んん、まだ出てくる……じゅるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0103134" ]},
		{"command":[ "SETIMAGE", "0", "still_00027301_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「えい、えいっ……。隊長様のおちんぽから出ていってくだひゃい……っ。ど\nうか、わたひの口の中に……！　んれろっ、じゅるっ、じゅるるるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0103135" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「……んっ！？　んむぅううっ！？　んぷっ……！？　んんんんっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0103136" ]},
		{"command":[ "SETIMAGE", "0", "still_00027301_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「な、何か苦いのが……！　白い汚れがドパッと一気に流れこんできて……！\n　んんんんむっ……！　んぅ！？　こ、これは……！？　あっ、ぅっうっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0103137" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「ふ、ぅうううっ……！？　せ……精液？　ひゃ、ひゃい……。どこかで聞い\nたことはありまひゅが、目にしたことも口にしたことも……な、ないれす」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0103138" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「んんぅっ！　止まりません！　どんどん出てきまひゅ……っ、あっ……♪　\nお風呂の床を汚す、わけにはいきまひぇんから……う、受け止めまひゅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0103139" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「ん……！　ん、ん……っ！　なんて苦されひょう……っ。それに、ドロドロ\nのネバネバれ……。んむっ、お口の中がいっぱいにぃい……！　うううっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0103140" ]},
		{"command":[ "SETIMAGE", "0", "still_00027301_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「……と、止まっひゃ……？　よ、良かったぁ……。んん、でも、このお口の\n中の精液はどうひゅれば……？　た、隊長ひゃま、これは……？　は、はい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0103201" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「おちんぽから精液を出せれば、正しくキレイにお掃除れきた証拠……？　そ\n、そうだったのれひゅね！　じゃ、じゃあこれで良かったのですね……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0103202" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「……隊長ひゃまの汚れ……。これを飲み干せば、おちんぽがスッキリする…\n…？　わ、わかりました。それなら努力ひて飲んでみまひゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0103203" ]},
		{"command":[ "SETIMAGE", "0", "still_00027301_01_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「……ごく……。……んんんんん！　に、苦い……っ、でも……っ！　……ご\nくっ……！　ごくっ、ごく……。ん……。ぅ……ごくん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0103204" ]},
		{"command":[ "SETIMAGE", "0", "still_00027301_01_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「な、なんとか……飲めました……。けふっ……、ま、まだ喉奥に残っている\n気はしますが。隊長様、こんなに汚れを溜めていて辛かったでしょう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0103205" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「……私のおかげで楽になった？　わ、わぁあ……！　良かったです！　ここ\nからはどうすればいいですか？　私にできることならなんでも……って」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0103206" ]},
		{"command":[ "SETIMAGE", "0", "still_00027301_01_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「……おちんぽ……ま、また大きくなってきました。あ……、まだ、汚れが…\n…。精液が出せるくらいに溜まってきている？　そ、それなら……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0103207" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「も、もう一度洗わせていただいても……よ、よろしいですか……？　は、は\nい。大丈夫です。むしろ一度経験したことで、二度目はもっとうまく」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0103208" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「もっとキレイにできると思います……。ですから、隊長様は気持ちを楽にし\nて、身体をゆっくり休めていてください。私が……お掃除しますから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0103209" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「ん……、ぁっ……？　さっき、汚れをたくさん出したからでしょうか……？\n　まだ、苦味とぺとぺとした感触が残っている感じが……します。んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0103210" ]},
		{"command":[ "SETIMAGE", "0", "still_00027301_01_12" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「精液って……結構しつこい汚れなんですね。こんなものがおちんぽの中に詰\nまっていたら、大変でしたよね。定期的にお掃除しないとです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0103211" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「……んっ。もちろん、私に頼んでくださってかまいませんので……。隊長様\nがより多くの汚れを……精液を出せるように、色々と教えてください……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0103212" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「ん……ちゅっ……ちゅ、くちゅ……。ちゅ、ちゅぅ……。んん……♪　あっ\n……♪　精液のお汁が残っているところがありました……舐め取ります」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0103213" ]},
		{"command":[ "SETIMAGE", "0", "still_00027301_01_14" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「んっ、じゅるっ……じゅる……。これを、飲むんでしたよね……。じゅるっ\n、ごく……。んん……♪　そして、舌先で舐めて清める……。れろぉっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0103214" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「んっ、じゅる……じゅるっ。ふふ……♪　隊長様は、私がちゅう～って、お\nちんぽを吸うのがお好きみたいですね。この、精液出る穴のところ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0103215" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「ここを、舐めながら、吸います……。んれろっ、ぴちゃっ、ぴちゃ、ぴちゃ\n……じゅるっ。えへへ……また、透明なお汁が出てきましたよ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0103216" ]},
		{"command":[ "SETIMAGE", "0", "still_00027301_01_15" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「なるほど……こうやってお掃除の回数を重ねれば……ぢゅるっ、どんどん短\n期間に……たくさんの汚れを吐き出してもらえるようになるんですね……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0103217" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「ぴちゃっ、ぴちゃっ、れろっ、れろ……れろ……ちゅ、じゅるっ、じゅるっ\n、じゅっ……！　ぢゅるっ、じゅる、じゅる、じゅるるるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0103218" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「んっ……！　お口の中れ、おちんぽが硬く……太くなってきてまひゅ……♪\n　じゅるっ、これはまた、お掃除のチャンスれひゅね……っ。じゅるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0103219" ]},
		{"command":[ "SETIMAGE", "0", "still_00027301_01_13" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「どうぞ、私の口の中に……んんっ、胸の中に、汚れを……精液を出ひてくだ\nひゃい……！　ぴちゃっ、ぴちゃ、じゅるっ……じゅるるっ、じゅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0103220" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「んっ、んんんんん……！　じゅるっ、じゅるるっ……！　勢い良く、汚れが\n……精液が出ました、今ですっ……。すすりとりますっ……じゅるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0103301" ]},
		{"command":[ "SETIMAGE", "0", "still_00027301_01_18" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「んぷっ、んん、んぅうう……ごくっ！　じゅるっ……ごくっ！　あ、あぁあ\nあ……♪　わたひが飲む速さより……お汁が出てくる方が速いれひゅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0103302" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「どんどん飲んでいかないと……！　あむっ……じゅる……！　ごくっ……ご\nくっ、んんっ！　一度目よりも濃くて苦いれひゅ……っ！　ごくっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0103303" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「飲み、きれない……！　んっ、んっ……。胸で絞り出して……んんっ……！\n　あぁ……♪　わたひの口の中、身体の中……精液でいっぱいれひゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0103304" ]},
		{"command":[ "SETIMAGE", "0", "still_00027301_01_17" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「ん……じゅるっ、じゅるっ、じゅる……♪　汚れは残さないで、私に譲り渡\nしてくださいっ……。んっ……、いくらでも飲みまひゅ、から……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0103305" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「じゅるっ、じゅるるっ……！　ごくっ、ごくっ……♪　もっと……もっとで\nす、私のお口、胸……隊長様に使ってほしいんれひゅ……っ！　じゅるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0103306" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「はーっ……はぁ、はぁーっ……。ご、ごめんなさい……。なんだか夢中にな\nって、精液を……汚れを要求してしまいました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0103307" ]},
		{"command":[ "SETIMAGE", "0", "still_00027301_01_16" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「私なんかの胸と口で、どれだけ汚れを出せたかはわかりませんが……。ど、\nどうでしょうか。気に入っていただけましたか？　私の……ご奉仕……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0103308" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「わぁ……、そ、そうですか！　褒めてもらえるなんて……。むしろ私の方が\n隊長様に気持ち良くしていただいてしまいました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0103309" ]},
		{"command":[ "SETIMAGE", "0", "still_00027301_01_17" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「こんなことでよければ、いつでもご奉仕いたしますので……汚れが溜まった\nなぁ、と思ったらすぐに呼んでください。私、いつでもお待ちしてます！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「んっ、ひゃっ……！　ご、ごめんなひゃいっ……！？　唇が外れて……、あ\nっ！　た、隊長様の汚れが……！　精液が外に出ちゃいました……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0103401" ]},
		{"command":[ "SETIMAGE", "0", "still_00027301_01_21" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「あぷっ……！　んぷっ、わ、わぁっ……。ど、どうしましょう……っ！　早\nくもう一度咥えないと……。っぷっ……！　だめです、暴れてますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0103402" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「胸で押さえても……っ、あッ！？　おちんぽの力の方が強くて……！　あっ\nぁっあっ……！　たくさんの汚れが……精液が、そ、そんなぁ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0103403" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「びゅっ、びゅっと……汚れがどんどん出てきます……。なのに私は何もでき\nずに……っ。な、なんですか？　浴びてほしい？　精液をですか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0103404" ]},
		{"command":[ "SETIMAGE", "0", "still_00027301_01_19" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「あっ……！　直接飲むだけではなく……浴びて、キレイにする方法もあるん\nですね……っ！　それなら失敗でなくて良かったですっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0103405" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「はいっ……はい、浴びます……！　ん……んんっ。熱い、です……っ。それ\nにこの臭い……飲んでいた時よりもずっと強くて、あっ、溺れますっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0103406" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「はぁっ……はぁ、はぁ……♪　たくさん出ましたね……♪　でも、お風呂場\nを汚してしまいました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0103407" ]},
		{"command":[ "SETIMAGE", "0", "still_00027301_01_20" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「私はこれから、この場所を片付けて……お掃除しますけど……。あ、あの…\n…。もしよかったら、その後で……一緒にお風呂に入れたらって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0103408" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「はい！　もちろん、三助ですから……背中もお流ししますし、隊長様なら…\n…洗ってほしいところ、どこだって気持ちをこめて洗います」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0103409" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「そうやって、隊長様のお役に立てたら……私はとても幸せです。どうか、\nすべてお任せください。河童は水場が得意なんですよ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0103410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}