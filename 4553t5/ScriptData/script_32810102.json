		{"command":[ "SETNAME", "ヒルデガード" ]},
		{"command":[ "SETTEXT", "「んんんんんんぅぅぅんっ！　イグッ……まら、イグぅっ！　どぷどぷっ、オ \nマンコ中出しでイグぅぅぅぅっ！」", "NORMAL" ]},
