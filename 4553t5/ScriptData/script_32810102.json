		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒルデガード" ]},
		{"command":[ "SETTEXT", "「ここのっ、気持ちいいところっ、ズリュズリュ……擦ってぇっ、あぁっ、ら \nめっ、ホントにらめっ、イグッ……イッちゃいまひゅからぁっ！」", "NORMAL" ]},
