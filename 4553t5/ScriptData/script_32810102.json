		{"command":[ "PLAYVOICE", "v2_281_0104218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒルデガード" ]},
		{"command":[ "SETTEXT", "「オマンコっ、キュンってしますからぁっ、あぁぁっ、はいっ、激しいのっ、 \nしゅごいっ、オマンコ気持ちいいっ、オマンコイグッ！」", "NORMAL" ]},
