{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「……夜も更け、月も雲に隠れたというのに……。こんな時間に、ウチに、な\n、何の用……ですか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0904101" ]},
	{"command":[ "SETCHARA", "0", "char_00000509_01", "0", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPTEXT", "TRUE" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「どうせ、一人で式神と遊んでいたのだろう、ですか？　……フッ、それがど\nうしたです。ウチの自由でしょう。べ、別に……寂しくなんかないですし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0904102" ]},
	{"command":[ "SETCHARA", "0", "char_00000509_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「誰かに構ってほしいとか、主様のことが気になったりなんかしていないです\nし……。意地悪言うなら戻っていいですか？　……なんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0904103" ]},
	{"command":[ "SETCHARA", "0", "char_00000509_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「ナデナデしてやるからこっちに来い？　……バッ……！　そ、そんな幼稚な\n誘いに、賢人であるウチがノるとでも？　えっ、ハグしてぎゅーもつける？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0904104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「……あ、主様がしたいだけでしょう。でも、まあ……主様がどうしても！　\nウチを甘やかして可愛がりたいなら……。少しだけ……。少しなら……ええ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0904105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「って、あああっ！？　な、なんです！？　いきなり持ち上げて……えっ！？\n　ちょっ！　下着脱がすなです！　あれっ、なでなでしてハグは！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0904106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00000509_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「あっ！？　だ、騙しやがったですね！？　は、離せですっ……あっ……！　\nやめっ……そんなニンジンみたいなモノ、ウチの股間に近づけるなです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0904107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「『この極太ニンジンでアソコをナデナデしてやる』……？　うあああっ、そ\nんなの全然優しくないです、嬉しくないです……こらっ、……あっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0904108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「ぬ、濡れてる……！？　ち、違う……コレは……！　ぎゅうしてもらえると\n思って、期待したから……あっ！　だ、だめ……チンポあてがわないでっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0904109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、あ、ぁ、あ……！　やめるです、アソコの入り口でオチンポに\nゅるにゅる動かすのやめ……！　くぅっ……！　ンッ、んんんっ、はぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0904110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「そ、そりゃ……気持ち、いいですけど……！　ウチがして欲しかったのとは\n違って……あっ！　ううっ……！　ゾクゾクして、蜜が……あっ、溢れる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0904111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「愛液が……！　ウチの愛液が、主様の極太ニンジンにまとわりついて……あ\nっ、あっ、テロテロになって……。いやらしすぎです……んぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0904112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「……わ……わかりました……。主様がウチに興奮してくれてるのは……。そ\nれに、ウチも……最近は、主様のことを考えると……身体が火照って……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0904113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「ギュウもハグも嘘で悲しいです。で、でも……。あ、あの……構ってくれる\nなら。ウチだけを可愛がってくれるなら……。し、していいですよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0904114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「している間は、ウチのことだけ考えていてくださ……い。ほら……。指で広\nげて、オ、オマンコ……拡げて待ってますから、い、入れてくだ……さい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0904115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「ニンジンは大嫌いですけど……。主様のはもう、ナスっていうかゴーヤです\nから……。ど、どうぞ……。あ……あ！　あっ、ぁっ、ああああ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0904116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「ふ……ふっとい……ぃいっ……！　あっ……思わず腰が逃げちゃうのです、\nぁ……！　き、気にしないでそのまま突き上げてくださ……あぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0904117" ]},
		{"command":[ "SETIMAGE", "0", "still_00000509_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「ズンッていきなり奥まで入っ、て……ああああっ！　目の前が、チカチカ、\nします……あぁっ、情け容赦ない太さ、なのです……んぅううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0904118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「ウチのオマンコ……しっかり濡れていたのに、ギチギチになって……んぁっ\n！　無理やり拡げられてるみたいで……ああ、クラクラ、する……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0904119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「これが、これが主様の、なのですね……。ひぃ、ひぃ……はぁっ……。は、\nは……い……少しずつですが、ジワジワと慣れてきました、ので……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0904120" ]},
		{"command":[ "SETIMAGE", "0", "still_00000509_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「最初はゆっくり動い……、って、んぁああああっ！　しょっぱなからズッコ\nンバッコン前後するやつがありますかぁあっ！　やぁっ、あああっあぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0904121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「壊れ、ちゃいますぅ壊されちゃいますぅうっ！　ウチ、身体、ちっちゃいの\nにぃ！　オマンコだってちびっこなのに！　いき、なり……んあああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0904122" ]},
		{"command":[ "SETIMAGE", "0", "still_00000509_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「強いぃい……！　オチンポの攻撃強すぎですぅうっ！　ああーっ！　やだぁ\n、やだ、やだ、やだぁあ……グリグリされて、ニュリニュリされてっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0904123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「あひぃっ……ひぃっ、ひぃいいんっ！　意識っ、強制でトばされそうで……\nんあああっ！　オマンコ壊れないように、ひ、広げているので精一杯っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0904124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「やさっ……優しくっ、優しくしてくださいよぉ……っ！　灼熱グツグツの肉\n棒、で……！　そんなに攻められたら、ウチ、ウチ、ウチぃいい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0904125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「がっくんがっくん全身ゆさぶられ、て……！　身体丸ごとオナホールにされ\nてるみたい、ですっ……！　あぁっ！　あぁ……あはっ、あぁああ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0904126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「ずりゅんずりゅん引き抜かれてっ……どっちゅんどっちゅんねじこまれ、て\n……ぇ！　あふぁああっ！　なにこれっ、ジェットコースターみたい、れす」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0904127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「もう、何がなんだか……わっかんないですぅ……！　ぁっ！　あうっ……奥\nっ……奥でオチンポがひっかかっ……て……あひぃっ！　ひぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0904128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「ビリビリっ……ビリビリしま、す……んぅうっ！　奥ぅ……！　ひっかかれ\nると、爪先まで電流、走ったみたいに……んひぃっ、ひぃっ、はうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0904129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「気持ち……い……、あっ！　あっぁっあっ！　出し入れ繰り返される、と…\n…！　抜く時ぬぽぉってひっかかれて、入る時ズンって衝撃きて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0904130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「ウチのオマンコの、至る所が気持ち良すぎてバカになっちゃってますっ！　\nっあぁ……！　あぁっ、あぁっ、あぁーあぁー……！　んあああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0904131" ]},
		{"command":[ "SETIMAGE", "0", "still_00000509_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「おかし、くなるぅ……おかしくなりゅぅうっ！　ろんっりっ、論理的に物事\nが考えられなくな……って、何の策も練れなくなって……んあああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0904132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「交尾するだけの、脳のない野兎にされてしまってますっ……あっ！　バカに\nなっちゃいけない、のに……！　ウチは、ウチは賢くないとダメなの、に」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0904133" ]},
		{"command":[ "SETIMAGE", "0", "still_00000509_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「……んぐぅうっ！　やめっ……！　奥を、奥をグリグリするのはやめてくだ\nひゃいぃ……！　そこっ、ヘンなんです、おかしいんです、……んんぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0904134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「んぁううっ！　あふっ！？　ひぃっ……！　んひぃっ！　こ、このぉ……っ\n！　ウチの弱点を見つけたとばかりにガン攻めする、なんてっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0904135" ]},
		{"command":[ "SETIMAGE", "0", "still_00000509_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「っぁッ……、イ……っちゃいます、イッちゃいますからぁっ！　あぁっ！　\nだめなんです、本当にダメなんです奥ぅ……子宮口どちゅどちゅしないれっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0904136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「ッんんんんーっ！！　んんんんー！！　っかはっ……！　あ……あ……、イ\n、イかされちゃいました……絶頂スイッチ入れられちゃいまし、た……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0904137" ]},
		{"command":[ "SETIMAGE", "0", "still_00000509_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「ふぁっあっあっあっ……！　らめ、らめぇ、イくの止まらないです、止まん\nないですぅ……もうズンズンしないれぇ……んあああっ！　あーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0904138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「……えっ？　中が？　膣内がギュウギュウ締まる？　……わ、わっかんない\nです、そんなの……っ、こっちじゃ制御できないんですぅっ！　んあああ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0904139" ]},
		{"command":[ "SETIMAGE", "0", "still_00000509_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「イ……くですイくっ、またイくですっ……！　あっ♪　主様、主様……ああ\nあああっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0904140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「んんんぅう～～～♪　主さ、まぁ……あったかいのが、ウチの……ウチのオ\nマンコの奥に入ってくるぅ……あぁ、あああ……気持ちいいです……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0904201" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000509_02_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「す……ごい、すごいぃ……！　どくっ、どくって注がれているのが生々しく\n感じられて……あっ♪　この感覚……ハマってしまいます……んぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0904202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「ものすごい量を出すのですね……ってんぁっ！？　出しながら子宮口、ちゅ\nくちゅく開かないでくださいぃ……入っちゃう、入ってきちゃいます！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0904203" ]},
		{"command":[ "SETIMAGE", "0", "still_00000509_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「赤ちゃんのお部屋に……ぃ♪　んん！　んんっ！　んんんんーっ……！　っ\nはぁっ……はぁ、はぁああ……ひゅごい……ひゅごいぃい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0904204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「腰も脚もガクガクで……それ、なのに……オチンポで身体、支えられている\nから倒れられなくて……。どんだけ強靭な肉棒してるんですかぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0904205" ]},
		{"command":[ "SETIMAGE", "0", "still_00000509_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「ウチっ……ウチの体重支えるどころか……！　全身貫いて……！　な、中出\nし……！　中出しした後も全然柔らかくなってくれなくて、硬すぎて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0904206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「……ウ……ウチの中に出すのじゃあ満足できません、でしたか……？　そう\nじゃなくて？　……まだしたくって、それでバキバキのままなのですか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0904207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「……ぁ……。してもいい、ですけど……けど、ウチ……。本当に脚が痺れて\nて……ずーっと小さくイッたままなんです、お腹に精子も入りっぱなしだし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0904208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「こんな状況でまた……ズポズポされたら、今度は偏差値、下がるどころじゃ\nないかもしれないんです！　ウチ、ウチ、術が使えなくなっちゃいます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0904209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「主様にオチンポ入れてもらうだけの……アホのオチンポケースになってしま\nいます！　だから……だから、怖い……。んっ……あっぁっあっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0904210" ]},
		{"command":[ "SETIMAGE", "0", "still_00000509_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「主様ぁ！　人の話、まったく聞いてないですよねぇ！　あああっ！　鼻息荒\nいですっ、それに……オチンポ、一回目より太く固まって……んあああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0904211" ]},
		{"command":[ "SETIMAGE", "0", "still_00000509_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「そんなのでほじんないでくださいぃいいっ！　あひぃいっ、ひぃいいっ、ひ\nううううっ……ひぃいいっ！　あっ、乱暴に動かさ、ないれ、あぁああう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0904212" ]},
		{"command":[ "SETIMAGE", "0", "still_00000509_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「あっんっ！？　あっんんっ！　んんっ、あぁああっ……！　ああっ、あーっ\n！　あーっ！　無間（むげん）地獄です、イキ地獄ですぅううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0904213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「容赦なく、ブッといゴリゴリチンポはめられてぇっ……！　ウチ、ウチ、知\n能、が……！　今まで学んできた知識、が……あああっ！　奪われて！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0904214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「んんんーっ！　ンンッ！　イ、きますぅ！　おっきいのキますぅ！　絶頂…\n…絶頂の波が、あーっ！　高くって、大きくって、荒くって……んぅう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0904215" ]},
		{"command":[ "SETIMAGE", "0", "still_00000509_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「オマンコ……オマンコがばがばになっちゃいますぅ……！　あぁっ、手加減\nしてください、あっ！　馬鹿になるっ……あーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0904216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「んぅっ……んんんん……！　もうダメ、もうだめ、もうらめぇえええ……！\n　主、様……主ひゃま、主ひゃまぁああ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0904217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「ウチのこと、もっと愛してください！　ウチを甘やかしてぇええっ！　ウチ\n、ウチ、ずーっと寂しかったんですっ、だから……だからぁああ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0904218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「主ひゃまの極太オチンポで独り占め出来て嬉しいです、主様のゴツゴツオチ\nンポに構ってもらえて嬉しいです、オマンコきゅんきゅんいってますぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0904219" ]},
		{"command":[ "SETIMAGE", "0", "still_00000509_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「わかりますかっ！？　オチンポを！　ウチのオマンコがギューッてだっこし\nてますぅっ、もう離さないです、離れたくないですぅ……あぁイくぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0904220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「イ……くです、イ……く、あっ♪　膣内射精キメられて、はしたなくイかさ\nれてしまいま、すぅうう……！　んぅうううう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0904301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000509_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「んはぁっ……あぁ、だ、出しながら動かすの、だめですっ……！　精液っ、\n無理やり押し込まないれくだひゃ……あうっ、あう、出てるぅうう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0904302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「んぁううううっ……んんーっ！　んんんっ！　これ好きぃ……好きです、こ\nれ好きぃいい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0904303" ]},
		{"command":[ "SETIMAGE", "0", "still_00000509_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「一番奥、に出してください、ブッかけてくださいぃ……！　んぁああっ！　\n中に出されるの気持ちいいです、気持ち良すぎてたまらないですぅうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0904304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「アソコから……溢れるくらい注いでください……！　なんて、余計な心配、\nは♪　いらないようですね……っ。すごい勢いです……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0904305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「んゥっ……くぅうっ♪　子宮に染み込むような熱い濁流……♪　こんなもの\nを直撃させられたら、ウチとてひとたまりもありません……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0904306" ]},
		{"command":[ "SETIMAGE", "0", "still_00000509_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「ドロドロで重い子種……。あぁっ、あ、あ……♪　限界知らずに注がれて…\n…。コレ、絶対に赤ちゃん出来ちゃってます……んんんう……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0904307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「あ……はぁ……♪　お腹の中があたたかいもので満ちていく喜びぃ……。こ\nれで、ウチはもう寂しくなんかない……。ありがとう、ございます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0904308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「ずーっとずっとこうしていたい……。んぁあっ♪　スゴいです、少し身震い\nするだけで……お腹の奥で精液がちゃぽちゃぽと……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0904309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「しっかり子宮の隅々にまでマーキング……してくれたですね……。なんと罪\nな極太ニンジンです……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0904310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「イ……っ♪　って、あああっ、ウチのっ、ウチのオチンポがずるんと逃げて\nしまって……やぁっ、やだぁあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0904401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000509_02_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「一番のクライマックスで抜くなんて、イジワルすぎです……って、んんんぅ\nうっ！？　溜めに溜めた精液を……おしっ、おしり、に……ぃ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0904402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「んあっ、ああっあうっ！　な、なんでお尻なんですかぁ……！　オマンコっ\n……精液もらえると思ってまっていたですのに……っ、んぁああんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0904403" ]},
		{"command":[ "SETIMAGE", "0", "still_00000509_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「ウチの、おっきくもない、小ぶりなお尻を狙い撃ちでびゅるびゅるひっかけ\nるだなんて……マニアックにも程がある、でしょう、に♪　ん、んぅうっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0904404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「はぁっ……はぁ、はぁ……♪　精液が熱すぎて、アソコもお尻も……腰も、\n全部がジンジン疼いてます……。下半身全部もっていかれたカンジです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0904405" ]},
		{"command":[ "SETIMAGE", "0", "still_00000509_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「んっ……トロトロの精液が、お尻の谷間に……流れ落ちて……んひぃ……♪\n　下から強烈な臭いがのぼってくるぅ……。んん～、イカくさいぃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0904406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「……さ……さっき……アソコにも、これが……発射されたのです、よね……\n。っ……この、臭くて、熱くて、真っ白な体液が……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0904407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「主様の精液……。ごくっ……。改めて目の当たりにすると……。思っていた\nよりずっと卑猥で……。見ちゃいけないのに、目が奪われる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0904408" ]},
		{"command":[ "SETIMAGE", "0", "still_00000509_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「これって、ウチの本能が……この汁を、白濁液を求めているってこと……な\nんでしょうか。ウチはいつのまに、そんなエロい子に成り下がったのか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0904409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「く、屈辱……なような、……逆にちょっぴり嬉しいような……。くぅううっ\n……ウチに、こんな感情を味合わせるのは、いつだって主様だけです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0904410" ]},
		{"command":[ "WAITINPUT" ]},
