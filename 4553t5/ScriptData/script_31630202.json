		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「はふぁ……んひぃぃ……この流れ込んでくる感じがたまらない……メスの悦 \nびがオマンコいっぱいに広がっていくぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0204302" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「全部……今度は残さず全部出して……今もビクビクイッてるオマンコを精液 \n漬けにして……奥の奥まで染み込ませてぇ……」", "NORMAL" ]},
