		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「んふぁっ……まだチンポが動いてる……イッたままのオマンコを可愛がって \nくれてる……はへぁ……嬉しい……これが幸せというものか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0204304" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「んんっ……はふぁ……あぁ、射精が……弱くなっている……名残惜しいが… \n…ずっとという訳にはいかないものな……」", "NORMAL" ]},
