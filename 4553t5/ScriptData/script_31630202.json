		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「はふぁ……あぁ……これで、私のオマンコは完全にお前のチンポのモノにな \nったな……産まれてくる子どもも楽しみだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0204309" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
