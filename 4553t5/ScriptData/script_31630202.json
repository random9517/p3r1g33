		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「だが、まだすぐにはチンポを抜かないでくれ……私も余韻に浸りたい。お前 \nのチンポをもう少し感じていたいんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0204306" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「オマンコがヒクヒクしている……？　それは……ただじっとしているだけだ \nと退屈だろう？　少しでもサービスをしておかなければな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0204307" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「それで、もう少し出そう……？　ふふっ……それは願ったりだ……最後の最 \n後まで搾り出してしまうからな……んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0204308" ]},
