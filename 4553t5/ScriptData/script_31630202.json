{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「おお、来てくれたか。度々になるが、呼び出して済まなかったな。うむ、今 \n回もお前にしか頼めないことがあってな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0204101" ]},
		{"command":[ "SETCHARA", "0", "char_00016302_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「ほら、肩が凝るからとオッパイをマッサージしてもらっただろう？　あのパ \nイズリ以降、どうにも身体に異変が起きていてな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0204102" ]},
		{"command":[ "SETCHARA", "0", "char_00016302_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「いや、また肩が凝ったということではない。その、お前のことを思うと、身 \n体が熱くなって気持ちが切なくなるのだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0204103" ]},
		{"command":[ "SETCHARA", "0", "char_00016302_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「これを客観的に判断した時に考えられる理由は一つ。どうやら、お前を運命 \nの相手として身体が認識してしまったということだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0204104" ]},
		{"command":[ "SETCHARA", "0", "char_00016302_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「そうだ……今、私は発情している……お前が運命の相手だということを、こ \nの濡れまくったオマンコに……分からせて欲しいのだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0204105" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00016302_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「ど、どうだ……？　私のオマンコの様子は……全く触っていないのに……お \n前の顔を見た時から疼き始めて……もうこんなになってるんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0204106" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「あっ……入り口にチンポが当たってる……んっ、もう待てない……頼む…… \n早く入れてくれ……私のオマンコを、その太いので貫いてくれぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0204107" ]},
		{"command":[ "SETIMAGE", "0", "still_00016302_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「はぁぁぁぁぁっ……！　んっ、あぁぁうっ……あっ、あぁっ、入ってくるっ \n……！　あっ、ずぶずぶっ……奥に、あっ、来るぅぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0204108" ]},
		{"command":[ "SETIMAGE", "0", "still_00016302_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「はっ、ふっ、ひぁっ……んっ、イ、イッた……チンポ……入れられただけで \n、もうイッたぁ……はぁ、あっ、ふぁぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0204109" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「い、いや、大丈夫だ……嬉しくて我慢しきれなかったが、まだ軽くイッただ \nけだからな……これで終わりになる訳じゃない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0204110" ]},
		{"command":[ "SETIMAGE", "0", "still_00016302_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「続けてくれ……もっと奥に入れてくれ……突いて欲しい……ぐっと、チンポ \nをオマンコでいっぱいにして欲しい……あっ、あぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0204111" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「あっ、あぁぁぁんっ！　そうだっ……あっ、一番深いところまで……ずぶっ \nと挿し込んでぇっ……そこからっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0204112" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……あぁっ、くんっ！　んくんっ！　はぁぁん……深い……後ろ \nから、んっ……打ち込まれるの……感じるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0204113" ]},
		{"command":[ "SETIMAGE", "0", "still_00016302_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「はっ、んっ……あぁっ、この体位は……動物がしている交尾に近いのだろう \nっ……？　だからだろうか……私のメスの本能が刺激されて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0204114" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「あっ、ふっ、あぁっ、チンポが押し込まれる度にっ、腰が……震えてっ！　 \nはぁっ、身体を支えるのがやっとな位……足がもつれるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0204115" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「んんっ、済まない……しっかり押さえていて欲しい……そして、このまま続 \nけてオマンコをかき回して欲しい……んふぅっ、くうんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0204116" ]},
		{"command":[ "SETIMAGE", "0", "still_00016302_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「あぁ……太いチンポがいい……私の濡れた襞を、ずるりと引きずりだしなが \nら抜けて……また、すぐにみっちり埋め込まれてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0204117" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「ずぷずぷっ、ぐちゅぐちゅっ、音を鳴らしながら、何度もオマンコ貫いてぇ \nっ……あぁっ、このピストン好きっ、強引にされるの好きぃっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0204118" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「はぁんっ、もっと分からせて欲しいっ……！　もっとチンポズボズボさせて \nっ、私のオマンコがこのチンポに逆らえないって教えて欲しいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0204119" ]},
		{"command":[ "SETIMAGE", "0", "still_00016302_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「んっふっ！　んくんっ！　くぅぅっ……わ、私もお尻を振って……気持ちよ \nく……？　わ、分かった……ん、んふっ、はっ、んっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0204120" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「こ、これでどうだ……？　ちゃんと出来ているか？　ま、まだまだ？　あっ \n、ひぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0204121" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「あぁ……わ、分かった。もっとだなっ？　んっ、ふっ……あっ、お尻っ…… \nパチンってされてるっ、あぁっ、ちゃんとするっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0204122" ]},
		{"command":[ "SETIMAGE", "0", "still_00016302_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「んふっ、どうだっ？　チンポがちゃんと……オマンコの中で喜んでいるかっ \n？　私のオマンコ……言う通りに出来ているかっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0204123" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「もっと、しっかり命令していいからなっ……！　私のオマンコはっ、もうお \n前のチンポのものだからなっ……好きなようにしていいのだっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0204124" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「あぁっ……あんっ、はぁっ、んぁぁんっ！　声がっ……止まらないっ……チ \nンポがオマンコを突く度にっ、メスの声が出てしまうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0204125" ]},
		{"command":[ "SETIMAGE", "0", "still_00016302_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「はぁんっ、これが……お前を興奮させるのかっ……！？　んっ、あぁっ、そ \nれならっ……もっと出すぞっ、あぁぉっ、おぉんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0204126" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「もっといやらしくっ、具体的にっ？　はぁんっ、あぁっ、チンポがいいんだ \nっ……！　太いチンポがっ、オマンコの襞を擦ってるとこぉっ！」　", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0204127" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「ズポズポっ……汁まみれの音をさせてぇっ……そこっ、弱い所ぉっ！　オマ \nンコの弱点をっ、チンポの先で突き回されてるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0204128" ]},
		{"command":[ "SETIMAGE", "0", "still_00016302_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「はひっ、気持ちいいっ……オマンコが気持ちいいっ！　チンポでズンズンさ \nれるのっ、好きっ、大好きなんだぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0204129" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「あぁぁっ、言葉にすると……尚更快感が増幅される気がするっ……！　はぁ \nんっ、チンポの出入りしている感覚がよりはっきり伝わってくるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0204130" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「このままされたらっ……もうっ、私は……待ちきれないっ……んっ、あぁっ \n、イッてしまうっ……もうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0204131" ]},
		{"command":[ "SETIMAGE", "0", "still_00016302_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「あっ、んんっ……チンポっ……！　奥で膨らんでる気がするっ……もうすぐ \n……出るっ、のかっ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0204132" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「はっ、んんっ、だったら……中がいいっ、私は……お前との赤ちゃんが欲し \nいっ……だから、このまま……中に出してくれっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0204133" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「そうだっ、種付けしてっ……！　ズボズボっ、チンポピストンしまくってっ \n！　イカせてっ、中出しっ……してぇぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0204134" ]},
		{"command":[ "SETIMAGE", "0", "still_00016302_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「私もっ……あっ、イクっ！　もう一回イクっ！　チンポっ……気持ちよすぎ \nてっ！　オマンコっ……イクゥゥゥゥゥゥゥんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0204135" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「はぁぁぁぁっ……んんんんんっ！　あぁぁぁ……出てるっ……濃すぎるのが \nっ、いっぱいっ、オマンコ……出てるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0204136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016302_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「はへぁぁ……そうだ、これを待っていたんだぁ……あぁぁ……バックから種 \n付け、気持ちよすぎる……チンポに服従させられるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0204137" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「あっ、ふっ、はぁぁぁ……んんっ、あぁっ……全部入った……隙間から、汁 \nがポタポタ……垂れている……勿体ない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0204138" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「はっ、んんっ……あぁ……受精した……完全に分からされたぁ……お前のチ \nンポの形にさせられたぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0204139" ]},
		{"command":[ "SETIMAGE", "0", "still_00016302_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「んっ、最高だったぞ……んふっ……私の求めていたもの以上の快感だった… \n…はぁ、はぁ……んふぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0204140" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「あぁ……嵌ったままのチンポが、まだ私の奥でヒクヒクしている……これは \n、全部出しきれていないんだな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0204201" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「だったら、迷うことはない……はっ、んふっ……もっと、私のオマンコを使 \nって欲しい……私も、まだ欲しがってるからぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0204202" ]},
		{"command":[ "SETIMAGE", "0", "still_00016302_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「そうだ……続けてイッたが、まだ私のはしたないオマンコはもっとチンポを \n欲しがってる。中をかき回して欲しいとヒクついているっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0204203" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「ほらっ、お尻を振ってアピールするっ！　メスの本能が、オスを誘う求愛の \n腰振りダンスするぅっ……だからっ、まだしてっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0204204" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「オマンコっ……もっといっぱいハメてっ、太いチンポっ……ズボズボさせて \nくれっ……！　あっ、あぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0204205" ]},
		{"command":[ "SETIMAGE", "0", "still_00016302_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「あぁっ、また、チンポピストン来たっ……イッたばかりのオマンコっ、また \nかき混ぜられてるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0204206" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「はふっ、くぅんっ、すごい音だ……オマンコの奥で、精液と愛液が……ぐち \nゅぐちゅ……混ざり合う音ぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0204207" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「チンポが奥に届く度に……はしたない音がしてぇ……はぁんっ、あぁっ、興 \n奮っ……してしまう……あ、んぁぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0204208" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「わ、分かっている……もっとチンポに媚びるようにっ、はんっ、腰をヘコヘ \nコ振って……アピールするぞっ、んっ、こうっ、してぇっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0204209" ]},
		{"command":[ "SETIMAGE", "0", "still_00016302_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「もっとしてっ……求愛のオマンコダンスっ、するからぁっ……ふっ、はっ、 \nんぁぁぁっ、またチンポっ……届くぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0204210" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「はぅんっ、んぁぁっ、太くて……硬いっ……！　熱いの……絡みついてぇっ \n……はぁんっ、ずっと気持ちいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0204211" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「あっ、あぁぁっ……亀頭が子宮の近くでめり込んでくるっ、何度も、何度も \n……突きまくられてぇっ……チンポが中で暴れてるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0204212" ]},
		{"command":[ "SETIMAGE", "0", "still_00016302_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「んんっ……！　あぁっ、今度はゆ、ゆっくりになって……ふぁぁ……痺れて \nる場所……丁寧に扱かれてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0204213" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「ああ……巧みすぎる……私を骨抜きにする術を心得て……何をされても、オ \nマンコ感じてしまう……はぁぁ……んっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0204214" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「同じところも……違うところも……あぁぁ……チンポ良すぎて……はぁん… \n…また、身体が……イク準備……始めてるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0204215" ]},
		{"command":[ "SETIMAGE", "0", "still_00016302_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「んっ、はぁ……あぁ、もうちょっとだけ我慢したい……あぁ、でも……やっ \nぱり気持ちいいとこ……ずっと突いて欲しい……どうしたら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0204216" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「あっ、あぁぁんっ！　やっぱり我慢できるわけないっ……！　もっと激しく \nチンポしてっ……ズリズリオマンコしてっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0204217" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「んぅっ、くぅんっ……お前も……イクんだな？　あぁっ、このまま一気にイ \nッて欲しいっ！　私も最後っ、いっぱいオマンコ締め付けるからっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0204218" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「はぁぅっ、出してっ……！　また精液ドピュドピュ出してっ！　服従オマン \nコにっ……お前のものだってっ、ぶっといチンポで分からせてぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0204219" ]},
		{"command":[ "SETIMAGE", "0", "still_00016302_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「あぁっ、ダメだっ……またイクっ！　チンポでイクッ！　オマンコッ……ま \nたイクぅぅぅぅぅぅぅんっ！」", "NORMAL" ]},
