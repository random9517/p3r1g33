		{"command":[ "PLAYVOICE", "v2_012_0404306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「あっ……んふっ……また、出てきた……本当に残ってたんだ……あ、ふっ…\n…はぁ、はぁ……これで出し切ったんだ……ね？」", "NORMAL" ]},
