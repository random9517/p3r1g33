		{"command":[ "PLAYVOICE", "v2_012_0404303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「はぁぁぁあ、あふっ……あっ、た、垂れて……来てる……隙間から、精液…\n…漏れちゃってる……」", "NORMAL" ]},
