		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「よい……しょっと……んふっ、さあ……つーかまえたっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0404101" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「うわぁ……改めて、このカッコ……メチャクチャ大胆……だよねぇ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0404102" ]},
		{"command":[ "SETIMAGE", "0", "still_00001204_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「だって、こんなに思いっきり足を広げて……一番大事な場所だけ丸見えにさ\nせちゃって……そ、それで……オチンチン……目の前にして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0404103" ]},
		{"command":[ "SETIMAGE", "0", "still_00001204_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「あ……オチンチンビクビクしてる……そっちも、やっぱりちょっと緊張して\nる感じ……？　だよね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0404104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「うん、でも今は誰も来ないし……大丈夫だから……しちゃお……ね？　わた\nし、ずっともうムラムラしっぱなしなんだから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0404105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「という訳で……んんっ、はぁ……中に……入れちゃいまぁす……はぁぁぁぁ\nぁっ、あふんっ……んっ、くぅぅんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0404106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「ほぉらぁー、オマンコ……オチンチンを全部ぱくってしちゃったぁ……んく\nぅぅぅっ……んふぅんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0404107" ]},
		{"command":[ "SETIMAGE", "0", "still_00001204_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「あぁ……腰……ぺたんって落としてぇ……んっ、一番奥まで……しっかり飲\nみ込んでぇ……はぁぁっ……オチンチン見えなくなっちゃった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0404108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「はぁ、あふっ……すごいね……繋がってるトコ……全部見えてる？　オマン\nコ……こんな風に広がって、オチンチンと重なっちゃうんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0404109" ]},
		{"command":[ "SETIMAGE", "0", "still_00001204_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「って……ホントにマジマジ見てるし……うぅ……さすがに、そこまでじっと\n見つめられたら、恥ずいってば……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0404110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「ま、まぁ……見ちゃダメってことはないけど……えっ、ちょっと力、入れて\nみせるの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0404111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「分かった……んふぅっ、んっ、うんっ……んふっ、こ、こんな感じ……？　\nあっ、やだ……オマンコ、ホントにヒクヒクしちゃってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0404112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「うぁぁ……自分でしてることだけど、これ……すっごく恥ずかしい……！　\nと、とりあえず一旦ストップで！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0404113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「あぁう……今のだけで、ちょっとお汁……溢れて来ちゃった……体もウズウ\nズして……んんっ、エッチな気分になっちゃってる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0404114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「もう、いいよね……？　オチンチン……かき混ぜちゃうからぁ……あっ、は\nっ、あんっ、はぁんっ、あっ、あぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0404115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「うんっ、ふっ、はぁっ、速さ……どぉっ？　んっ、そこまで強すぎってこと\n……ないよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0404116" ]},
		{"command":[ "SETIMAGE", "0", "still_00001204_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「んっ、んくぅぅ……最初は……ゆっくりで、ぐりぐりって……濡れてるとこ\nぉ、こすって……行くからぁ……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0404117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「はぁっ、んふっ、んくんっ……あっ、あんっ、はんっ、ウソ……これ、ヤバ\n……んっ、ちょっと、動かしてる……だけ、なのにっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0404118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「オマンコ……んんっ、すごく……ジンジンしてぇ……はぁっ、んっ、くぅ…\n…気持ち……良すぎるぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0404119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「はぁっ、あんっ、あはっ、はんっ、あふっ……声、勝手に出ちゃうし……息\n……上がるしっ……心臓、ドキドキしてるしっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0404120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「何度も、何度も……したくなって……止まらないよぉっ……あぁんっ、はぁ\nっ、んくぅっ……あひんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0404121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「なんだろ……これぇ……スーツのせい？　んっ、それとも……何か他の理由\n……あるのかな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0404122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「あぁ……オチンチン……ぐぐーって、めり込む時の……そ、そうっ、今のが\n……あっ、よ、良すぎるぅっ……んくぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0404123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「はぁっ、あふっ、んはっ、あぁっ……すご……また、えっちな汁……出ちゃ\nってる……あんっ、隙間から……垂れて来てる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0404124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「あひっ、はぁっ、ダメ……これ、止められないのっ……どんどん漏れて来ち\nゃうけど……あぁっ、オマンコ……かき混ぜちゃうからぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0404125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「ねっ……んっ、オチンチンもっ、動かしてっ……一緒に、合わせてっ……感\nじっ……たいのっ、あっ、はぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0404126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「はんっ、うんっ、いいっ、感じぃっ……このままっ、ちょっとずつっ……ペ\nースあげてこっ、はっ、あんっ、あふっ、んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0404127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「どうっ、んっ、ちゃんとっ……気持ちよくっ……なってくれてるっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0404128" ]},
		{"command":[ "SETIMAGE", "0", "still_00001204_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「えへへぇ……わたしばっかりだったら悪いもんね……よかったっ……んっ、\nきゅうってする、ねっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0404129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「んんっ！　今の……よかったでしょっ……んふふぅっ、わたしも……テクニ\nック、磨いてるんだからぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0404130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「ここから、本気のピストンしちゃうよぉっ……うんっ、はっ、あっ、うんっ\n、んくんっ、はんっ、あんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0404131" ]},
		{"command":[ "SETIMAGE", "0", "still_00001204_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「あぁぁっ……あぁっ、きもちいーっ、オチンチンっ……オマンコにグリグリ\n当たるのっ、すっごい……きもちいーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0404132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「これっ、このまましたらっ……あんっ、はぁんっ、イクっ……イッちゃう…\n…はぁぁっ、オマンコっ……イッちゃうよぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0404133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「きゃっ！？　あっ、あぁっ！　そんな、急にっ……あっ、激しくぅっ！　あ\nっ、イ、イカせるって……そんなっ、あひっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0404134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「はんっ、あんっ、い、今までの……本気じゃなかったのっ？　あっ、あぁっ\n、ダメっ……そんなにされたらっ、イ、イクっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0404135" ]},
		{"command":[ "SETIMAGE", "0", "still_00001204_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「あひっ、はぁんっ、わらひっ、オマンコ……イッちゃうのっ、あんっ、あな\nたもっ……イッてっ！　あぁっ、中にっ……出してっ、してぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0404136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「はひぃぃぃんっ！　イクぅぅぅぅぅぅっ！　あぁっ……オマンコ……イ、イ\nッてる……あっ、きもちいーの、出されてっ……イッてるぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0404137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001204_02_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「んんっ、中に精液……流れ込んで来てる……はぁぁ……お腹、いっぱいにな\nる感じ……気持ち、よすぎぃぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0404138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「はぁぁ……はふぁ……お、終わった？　はぁぁー、も、もうっ……あんな不\n意打ち……ズルいよぉっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0404139" ]},
		{"command":[ "SETIMAGE", "0", "still_00001204_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「余裕なさそうな顔しちゃって、最後にあんな激しくされたら……イ、イッち\nゃうに決まってるし……もうっ、悔しいー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0404140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「ふんっ……そういう訳だから、もちろん……これで終わりじゃないよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0404201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「まだオチンチンもコチコチだしぃ……私ばっかりやられっぱなしじゃ終われ\nないもん……だからぁ……また、動くねぇっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0404202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「んんんっ！　あはぁぁぁ……一回、イッたから……ずっと感じやすくなっち\nゃってる……んくぅ……はぁぁん……あっ、ふっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0404203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「ま、まだまだ……レイジョーラベンダーの名にかけてっ……しっかり、攻撃\n……するんだからぁっ……はんっ、あひんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0404204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「ほらっ、どうっ……？　んっ、オマンコの……三段締めっ……先の方と……\n真ん中……それからっ、根元っ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0404205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「お腹の力の込め方で……はぁんっ、オチンチンの好きな所っ……キュンって\nしてあげるんだからぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0404206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「んふふっ、表情変わってるう。やっぱり、先っぽがぎゅってされるのがいい\nんだ？　いいよぉ……もっとしてあげる……んっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0404207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「んふっ、ほら、オチンチン喜んでるし……このままなら、すぐ次の射精……\n始まっちゃうんじゃない？　あっ、あぅんっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0404208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「んくぅっ！　ま、また……反撃してくるなんてっ……しつこい、んだからぁ\nっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0404209" ]},
		{"command":[ "SETIMAGE", "0", "still_00001204_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「あっ、ちょっ……ふ、太もも抑え込むのはズルいっ……あっ、あぁっ！？　\nんくぁっ、はぁぁぁんっ、待って、動けないっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0404210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「あんっ、はぁんっ！　そ、そんなっ……そこで突き上げっ、あっ、されたら\nっ、あひぁっ、はんっ、あへぁっ、あぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0404211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「やらっ、また……先にイッちゃうっ、あひっ、オマンコっ……オチンチンで\nイカされちゃうのっ、んひっ、いひぃんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0404212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「あっ、イクっ……あひぃぃっ……イッ……イクっ！　はぁぁぁんっ！　イッ\n、イクぅぅぅぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0404213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「はぁっ、あっ、ふぁっ……ま、また……イッちゃった……はぁ、ふっ……オ\nマンコ……痺れてるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0404214" ]},
		{"command":[ "SETIMAGE", "0", "still_00001204_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「んっく、でも……諦めないよ……まだまだ……ちゃんと、んっ、オマンコ…\n…負けてないんだからぁ……んっ、んくぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0404215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「さあ……今度は、オチンチンが泣いちゃう番だよ……しっかり気持ちよくさ\nせて……射精……させちゃうんだからぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0404216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「ふっ、はっ、うんっ、はんっ、あんっ、あぁっ、ぐちゅぐちゅの中っ……も\nっと、感じてっ……あひっ、ほらぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0404217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「はふっ……あぁっ、オチンチン……震えて来たっ……出るでしょっ……？　\n最後の最後は……必ずレイジョーラベンダーが勝つのっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0404218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「さあ、観念してっ……オチンチン……出しちゃいなさいっ、中でも……掛け\nても……どっちでもいいからっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0404219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
