		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「いーっぱいオマンコ締め付けて、勃起チンポをぎゅってして……あんたのザ\nーメン、どぴゅどぴゅさせたげるね……！」", "NORMAL" ]},
