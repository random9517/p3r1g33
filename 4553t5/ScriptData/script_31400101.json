{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「おいっすー！　暇してそうだから、遊びに来てあげたよー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0103101" ]},
		{"command":[ "SETCHARA", "0", "char_00014001_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「おやおやー？　こんな美少女に抱き着かれて嬉しいのはわかるけど、オチン\nチンを大きくするのは、ちょっとデリカシーに欠ける感じかな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0103102" ]},
		{"command":[ "SETCHARA", "0", "char_00014001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「あははっ！　そんなに照れなくてもいいじゃん。うちとあんたの仲なんだし\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0103103" ]},
		{"command":[ "SETCHARA", "0", "char_00014001_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「それとも、うちにオチンチン気持ちよくしてほしくて、わざと照れたふりし\nてるとか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0103104" ]},
		{"command":[ "SETCHARA", "0", "char_00014001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「あはっ！　マジでー！　ちょー素直じゃん！　じゃあ、その素直さに免じて\n、一肌脱いであげる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0103105" ]},
		{"command":[ "SETCHARA", "0", "char_00014001_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「もうバッキバキになってんじゃん。そんなに、うちの胸が気持ちいい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0103106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00014001_01_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「えへへっ。素直に頷いてくれるのは、ちょー嬉しいよ。じゃあ、いっぱい気\n持ちよくしてあげるね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0103107" ]},
		{"command":[ "SETIMAGE", "0", "still_00014001_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「んっ、しょ……んっ、あっ……どうー？　おっぱいの感触、ちゃんと伝わる\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0103108" ]},
		{"command":[ "SETIMAGE", "0", "still_00014001_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「うちもあんたのオチンチンの感触、すっごい感じてるし……熱すぎて、火傷\nしちゃいそうなぐらい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「せっかくだし、もっと気持ちよくしてあげる……んっ、こうして、乳首を触\nって……きゃっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「軽く乳首触っただけなのに、オチンチンちょー硬くなってんですけど！　も\nしかして、乳首で感じちゃうとか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0103111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「なら、もっと気持ちよくしたげるし！　こうして、おっぱいでオチンチン擦\nりながら、乳首をクリクリして……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「あはっ！　オチンチンビクビクしまくって、めっちゃカウパー汁吹いてるし\n！　ちょー面白いんだけど！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0103113" ]},
		{"command":[ "SETIMAGE", "0", "still_00014001_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「あー、ごめんって！　そんな拗ねなくていいじゃん！　ちゃんとご奉仕して\nあげるから……ね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0103114" ]},
		{"command":[ "SETIMAGE", "0", "still_00014001_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ、ふああぁ……これ、ヤバいね……！　うちの乳首も擦れて、す\nっごい感じちゃう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0103115" ]},
		{"command":[ "SETIMAGE", "0", "still_00014001_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「ね、わかる……？　うちの乳首、めっちゃ硬くなってるの……気持ちいいっ\nて証拠だよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「あんたの乳首も同じぐらい、硬くなってるね！　これは弄りがいあるかな！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「ほら、遠慮しないでいっぱい感じて……オチンチンも乳首も、両方気持ちよ\nくしてあげるからさ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0103118" ]},
		{"command":[ "SETIMAGE", "0", "still_00014001_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「んっ、んんっ……あっ、あぁん……ちょっと、オチンチンの滑りがよくない\nね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0103119" ]},
		{"command":[ "SETIMAGE", "0", "still_00014001_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「それじゃ、こうして唾液を垂らして……んっ、れろっ、ちゅる……んんっ…\n…！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0103120" ]},
		{"command":[ "SETIMAGE", "0", "still_00014001_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「うわー……ちょー滑りよくなって、谷間からぐちゅぐちゅって、いやらしい\n音聞こえるんですけど……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0103121" ]},
		{"command":[ "SETIMAGE", "0", "still_00014001_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「ほらっ、どう？　こうやって、カリのとこグリグリされるの、ちょー気持ち\nいいっしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「答えなくてもわかるって！　オチンチン擦るたびにビクビクしてるし、乳首\n捻ると気持ちよさそうな声漏らしてるし！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0103123" ]},
		{"command":[ "SETIMAGE", "0", "still_00014001_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「それにしても、すっごいいやらしいニオイだよねー……あんたの我慢汁と、\nうちの唾液と汗が混じって……こう、蒸れたようなニオイがしてさ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「んっ、くうううぅ……！　これ、ヤバ……！　なんか、鼻から犯されるって\nいうか、ニオイでクラクラするっていうか……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0103125" ]},
		{"command":[ "SETIMAGE", "0", "still_00014001_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「うちの乳首も擦れて……めっちゃ感じる……！　オチンチン擦ってオマンコ\n濡らすって、なんか変態みたいじゃない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「でも、乳首弄られながら、オチンチンおっぱいでぐちゅぐちゅされて悦んで\nるあんたも、相当変態だよね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「ふふっ……うちら変態同士、お似合いって感じしない……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0103128" ]},
		{"command":[ "SETIMAGE", "0", "still_00014001_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「ああぁん！　ちょ、なにオチンチンビクビクさせてんの……！？　もしかし\nて、変態って言ったこと、怒ってる……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0103129" ]},
		{"command":[ "SETIMAGE", "0", "still_00014001_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「えっ……違うの？　気持ちよくて、もうすぐイキそうだから、オチンチンが\n自然と跳ねただけ……？　あはっ！　そーなんだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0103130" ]},
		{"command":[ "SETIMAGE", "0", "still_00014001_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「気持ちいいなら、もーっと気持ちよくしてあげる！　んっしょ、んっ……あ\nっ、んぐっ、れろっ、ちゅぱっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0103131" ]},
		{"command":[ "SETIMAGE", "0", "still_00014001_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「オチンチンがドクドク脈打って、ますます硬くなってるし……！　こんなオ\nチンチン……ううん。凶悪チンポで犯されたら、どーなっちゃうんだろ……！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「うちも試してみたいけど……今日はおっぱいで我慢してね……！　はぁ、は\nぁ……んっ、あっ、んうううぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「くっ、れりゅ、ぴちゃ、ずちゅ……！　イッ、イキそうなんだね……！　い\nいよ……うちの胸にたくさん出して……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0103134" ]},
		{"command":[ "SETIMAGE", "0", "still_00014001_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「ドロッドロの白濁ミルク……いーっぱい、どぴゅどぴゅ出して……！　あっ\n、ああっ……んはあああぁ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0103135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「ああぁん！？　すっごい出てる……！　おっぱいの間に、びゅるびゅるって\n熱いザーメン出てるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0103136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00014001_01_06" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「はああぁ……この生臭いニオイ……！　初めて嗅いだのに、クセになりそ…\n…！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0103137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「あんんっ……！　まだ出るとか、すごくない……！？　どんだけ精子溜め込\nんでたの……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「うちのパイズリが気持ちよかったからって……もー、嬉しいこと言ってくれ\nるじゃん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「あはっ……！　あんだけ出したのに、まだガッチガチだね……よかったら、\nもう一回したげよっか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0103140" ]},
		{"command":[ "SETIMAGE", "0", "still_00014001_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「あんっ……！　返事を聞くまでもないぐらい、ガチ勃起じゃん……！　期待\nしすぎって感じ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0103201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「じゃあ、もう一回おっぱいマンコで、チンポ絞ってあげる……乳首もいーっ\nぱい気持ちよくしてあげるね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「んっ、ぐちゅ……唾液をもっと垂らして……ぺちゃ、ちゅ、じゅるっ……ん\nっ、れろっ、ずちゅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0103203" ]},
		{"command":[ "SETIMAGE", "0", "still_00014001_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「ちゅ……れろっ、れりゅ……こんなもんでいいかな……もっと唾液欲しかっ\nたら、いつでも言ってね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0103204" ]},
		{"command":[ "SETIMAGE", "0", "still_00014001_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「それじゃ、うちのおっぱい……好きなだけ味わってね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0103205" ]},
		{"command":[ "SETIMAGE", "0", "still_00014001_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「んっ、ふううぅ……あっ、ふああぁ……！　おっぱいが擦れるたびに、ザー\nメンのニオイが強くなって……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0103206" ]},
		{"command":[ "SETIMAGE", "0", "still_00014001_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「あはああぁん！　ち、乳首に精液が付いて、変な感じがするぅ……！　これ\n、気持ちよすぎるってぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「んんっ……！　ぐちゅぐちゅって擦れて……ち、乳首で妊娠しちゃうかも…\n…！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「むっ……その顔、バカにしてるっしょ……！　本当にそんな感じがするんだ\nからね……！　信じてくれない人には……こうだぞ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0103209" ]},
		{"command":[ "SETIMAGE", "0", "still_00014001_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「あはっ……！　どう……？　こうして指で乳首をクリクリされると、感じま\nくるでしょー……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0103210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「んで、乳首で感じてる間に……こうして、全身で擦るようにおっぱいを前後\nさせるとぉ……んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「チンポがビクンってしたね……！　うちに任せとけば、もーっとチンポ気持\nちよくしたげるよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「こうして……んっ、ぴちゃ、れりゅ……れろっ、ずりゅ……唾液でもっと滑\nりをよくしてあげてー……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0103213" ]},
		{"command":[ "SETIMAGE", "0", "still_00014001_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「からのー……乳圧責めー……！　あはっ！　どう？　おっぱいでチンポ潰さ\nれるの、気持ちいいでしょ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0103214" ]},
		{"command":[ "SETIMAGE", "0", "still_00014001_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「気持ちよすぎて、声も出せないみたいだね……！　なら、もっとおっぱいを\n押し付けて……あっ、あああぁ……ああぁん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0103215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「これ……うちの乳首も押し潰されて……すっごく感じるぅ……！　ずりゅず\nりゅって擦れるたびに、強く乳首が刺激されて……あはぁん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0103216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「あっ、あっ……んっ、ああぁ……！　やっ、ヤバ……うち、イキそ……！　\nねっ、ねぇ……！　うち、イッてもいい……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0103217" ]},
		{"command":[ "SETIMAGE", "0", "still_00014001_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「んはあぁ……あ、あんたのチンポも、小刻みに震えまくってるね……！　う\nん……いっぱい擦るから、一緒にイこ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0103218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「やっ、あくうぅ……！　あっ、ふああぁ、あっ、ひああぁ……！？　だ、ダ\nメ……うち、もう我慢できないっ……！」」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「あっ、イク……！　イクッ……！　あっあっあっ……！　イッ、イク……！\n　イクうううううぅ～～～～～！！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「やあああぁん……！　あぐっ、熱っ……あっ、ふあああぁ……！　おっぱい\nに、またたくさんザーメン出されてぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0103301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00014001_01_10" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「ドクン、ドクンって、チンポ震えるし……！　さっきよりも精子出される気\nがするぅ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「だ、ダメっ……精液の感触を味わってたら、またイク……あっ、ああぁん！\n　ダメえええぇ～～～～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0103303" ]},
		{"command":[ "SETIMAGE", "0", "still_00014001_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……んっ、ふくうぅ……！　ざ、ザーメンぶっかけられてイクと\nか、ヤバくない……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0103304" ]},
		{"command":[ "SETIMAGE", "0", "still_00014001_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「ひょっとして、うちら身体の相性バッチリなんじゃない……？　あんたも、\nそう思わない……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0103305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「でしょー……ね。よかったら、うちら付き合わない……？　もちろん、みん\nなに内緒でさ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0103306" ]},
		{"command":[ "SETIMAGE", "0", "still_00014001_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「うちと付き合ってくれたら、もっと気持ちいいことしたげるよ……おっぱい\nだけじゃなくて、オマンコも使わせたげるし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0103307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「あはっ！　オマンコって言ったら、チンポがビクッってしたね……！　ひょ\nっとして、ちょー期待してる……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0103308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「えー、どうしよっかなー……？　今すぐオマンコさせたげてもいいんけどー\n……今日はダメかな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「ふふっ。この続きはまた後日ね……いーっぱい気持ちよくしたげるからさ…\n…ね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「んぶっ！？　あっ、あうううぅ……！　ちょ、顔に出すとか聞いてないしぃ\n……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0103401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
