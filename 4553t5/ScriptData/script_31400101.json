		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「んちゅ、じゅるっ……口にザーメン入っちゃったじゃん……！　んくっ、じ\nゅる、じゅぞっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「はああぁ……あんたのドロドロザーメン、飲んじゃったし……！　っていう\nか、ちょー喉に絡むんだけど……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0103403" ]},
		{"command":[ "SETIMAGE", "0", "still_00014001_01_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「どんだけ濃いい精子してんのって感じ……！　でも、嫌いじゃない味かなー\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0103404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「それにニオイもすっごく強烈で……ああぁんっ……！　これ、嗅いでるだけ\nでイキそ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0103405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「ねぇ……こんなに凶悪なザーメン、オマンコに注がれたら……うち、どうな\nっちゃうのかな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0103406" ]},
		{"command":[ "SETIMAGE", "0", "still_00014001_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「試してみたい……？　おっぱいマンコじゃなくて、本当のオマンコに、びゅ\nるびゅる精子出してみたい……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0103407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「あはっ！　そんなに頷かなくてもいいじゃん！　必死すぎだし！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0103408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「じゃあー……うちともっといい感じになったら、オマンコさせたげる……」", "NORMAL" ]},
