{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「あの……。今日は、戦闘中にわたしを助けてくれてありがとう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0103101" ]},
		{"command":[ "SETCHARA", "0", "char_00024201_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「最近、わたし……ずっとあなたに助けられっぱなしだから……。何かお返し\nしたくて、来たの。してほしいこととか、……ある？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0103102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「うん。ぱいずりふぇら？　ぶっかけ？　……ごめん。何を言ってるかよくわ\nかんない。え？　どうやってするのか教えてくれるの？　ありがとう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0103103" ]},
		{"command":[ "SETCHARA", "0", "char_00024201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「え、と……。これがあなたが、わたしにしてほしいパイズリフェラ？　パイ\nズリのパイはおっぱいのぱい？　そうなんだ……知らなかった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0103104" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00024201_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「うん。べつに、おっぱいを見せるくらいは減らないし、いいんだけど……。\nあの……少し気になるのが……。どうして、その……なんていうのかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0103105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「あなたのおちんちんを、わたしのおっぱいで挟むんだろうってこと……。こ\nれがパイズリフェラ？　違うの？　挟むのは第一段階で……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0103106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「おちんちんをこすったり、おっぱいを揺らしたり……？　あなたを誘惑した\nりしながら……口でおちんちんを舐める……？　え？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0103107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「口でおちんちんを舐める？　それで、ちゅぱちゅぱぺろぺろしゃぶったり吸\nったり唇で愛でたり？　それ……本当の話？　それがパイズリフェラ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「……ごめん。後半のフェラ？　お口で色々するのは、まだ理解が追いつかな\nいけど……。おっぱいでゆさゆさプルプルふにふにするのは、なんとなく」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「だから……パイズリからするね。それで、理解できたら口でもするから……\n。パイズリ……おっぱいでずりずり……。こうかな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0103110" ]},
		{"command":[ "SETIMAGE", "0", "still_00024201_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「ふ、ぅ……っ、ふんっ……ふんっ……んん……！　わ……！　谷間でムクム\nク～っておちんちんが上がってきた……それになんか硬くなって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0103111" ]},
		{"command":[ "SETIMAGE", "0", "still_00024201_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「あれ……っ。おっぱいの間から飛び出しそう……。えっ……？　力、すごく\n強いんだけど……？　おちんちん、どうかした？　すっごく腫れてる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0103112" ]},
		{"command":[ "SETIMAGE", "0", "still_00024201_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「赤黒くなって……ビキビキって血管が浮いて……。もしかして怒ってる？　\nちがう？　……これが気持ちいい状態？　へええ……？　信じられない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「形、最初と全然ちがくなってきた……。ん……っ、なんか……、ふぅっ……\n！　わたしの顔に突き刺さりそうでこわいよ……。んっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「……あ、そっか。この……飛び出してきたおちんちんのさきっちょを口で舐\nめるってこと？　それなら、ちょうど位置が合うね……そっか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0103115" ]},
		{"command":[ "SETIMAGE", "0", "still_00024201_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「わかった……。じゃあ、もっと、もっとおっぱいでおちんちんを大きくして\n……。ふぅっ……ふぅっ、たくさん先っちょはみださせて……んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「ふぁ……。これでいいかな……。んっ……。舌を伸ばして……こう？　えい\nっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0103117" ]},
		{"command":[ "SETIMAGE", "0", "still_00024201_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「ぴちゃっ……。ンッ……。なんかしょっぱい……？　ぺろっ……ちゅぷ、ぷ\nちゅっ、ぴちゅ……ん、ん、ん……。むずかしい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「おっぱいで刺激しながら……舐める。……ん……、ぴちゃ……ぴちゃ、ぴち\nゃ……ちゅぷ……。……もっと速く？　わかった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「ちゅぷ、ぷちゅ、ぴちゅ、くちゅ、……ちゅっ、ちゅっ……。あれ……？　\nなんか、ここ……ぬるぬるしてて……。ん……ちゅ、くちゅ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「ここ？　ここを舐めると気持ちいいの……？　んっ……ヘンなの……。おち\nんちんを口に入れるなんて、考えたこともなかった……ぺろっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0103121" ]},
		{"command":[ "SETIMAGE", "0", "still_00024201_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「あなたはこういうこと、わたしにしてほしかったんだね……。気付かなくて\nごめんなさい。……ちゅ。ちゅぷ……くちゅ、にゅぷ……ちゅぷぷぷ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「んぁ……だんだん、やり方がわかってきたかも……。くちゅっ……。ふぅっ\n、こうしておっぱいでモニモニしながら……口を開けて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0103123" ]},
		{"command":[ "SETIMAGE", "0", "still_00024201_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「唾でおちんちんを濡らして……舐め取って……ちゅる……。くちゅ、ちゅる\n……。ん、ぁ……ちゅぷ、ぷっちゅっ、にゅぷ……くっちゅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「あはは……♪　そんなに反応してくれるんだ。だったらもっとやってみたい\nかも……。それじゃあ、こういうのはどうかな……？　っぺちゃっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「舌全体で……太いところを舐め回ひて……。んッ……ねろぉ……っ。れろぉ\n……れろっ、ちゅぱ……ちゅぱ、くちゅっ、ちゅぷ……んん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「ん、ぁ……ぷぁ……っ。口の中で暴れひぇる……。逃げないで……ちゅぷっ\n。れろれろれろ……れるぅ……ちゅぅ、ちゅ、ぴっちゃっ、ぴちゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「……いちいち反応してくれるのが、うれしい……。楽しくなってきた。いっ\nぱいする……。んっ……くちゅっ、ちゅっ、くちゅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁ……。むちゅっ……ぺちゃ……ぺちゃ、ぴちゃ……。あむっ…\n…んむ……むぅ……っ、れろ……ぴちゅっ、ぺちょ、ちゅっぷ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0103129" ]},
		{"command":[ "SETIMAGE", "0", "still_00024201_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「んっぅ……息が苦ひぃ……。くちゅ……ちゅっ。はぁっ……はぁ、はぁ、は\nぁ……。胸とお口とどっちも動かすと……たいへん……。っちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0103130" ]},
		{"command":[ "SETIMAGE", "0", "still_00024201_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「ふむぅ……っ。んちゅ……！　ちゅぷ、ちゅぷ、ちゅぷ、ぷっちゅっ。くち\nゅ……ぴちゃぴちゃ……。んっ、ふんん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「ねえ……？　わたしのおっぱいってどんな……感じ？　んっ……人肌だから\nあったかい？　ふにふにしてて柔らかい……？　れろっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0103132" ]},
		{"command":[ "SETIMAGE", "0", "still_00024201_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「……えっ。結構重たいんだ……？　そうなんだ……。ずっしりしてて、モチ\nモチで……股間全部があったかい……？　へぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「じゃあ、わりとしっかり触感があるんだね。おっぱいにおちんちん潰される\nの……好き？　お口でぺろぺろされながら……んっ、ふぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0103134" ]},
		{"command":[ "SETIMAGE", "0", "still_00024201_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「こうやって……。ぁっ……。ぴちゃ……ぺちょ……。んん……！　おっぱい\nでぐりぐりされて……。んぁ……れろっ……れろ、れろれろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0103135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「揺さぶられて……。ぴちゃっ、舐められて……れろ……。そういうのが大好\nきなんだね……。っちゅぷ……くちゅ、ちゅっ、ちゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0103136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「んぷ！？　んんんぅうううう……！　は、ぅ……うう……っ、んむ……！　\nこふっ……！　けふ、けほ……！　んんん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0103137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024201_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「な、なに……っ？　いきなり……！　んぶっ……んぷぅうっ！？　やっ……\n！　なにか、何かビュッビュッて……うむぅうんっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「んっ、ふぅっ……ふぅうっ……んん！？　ごくっ……ごくっ、けふっ……！\n？　ごくっ……ごく、ごく……！　うぇえ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「飲んじゃった……喉に流れこんできて……。んぷ……。どういうこと……？\n　この汁、どんどん口の中に入ってきて……。んんんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0103140" ]},
		{"command":[ "SETIMAGE", "0", "still_00024201_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「あ……、んぁ……。いっぱい……。ふぇ……コレ、すごく変な味……。ネバ\nネバで……苦味があって……んっ。舌に絡まる、うまく飲めない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0103201" ]},
		{"command":[ "SETIMAGE", "0", "still_00024201_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「待って。ちょっと食べてみるね。もぐ……もぐ……んんっ……。ご……ごめ\nん、慣れるまで、これでおなかいっぱいにするのは難しいかも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「でも……嫌な感じではないよ。やっぱり……。あなたのだからかな。おちん\nちんやこの汁……味わったのは初めてだけど。ん。いやじゃ……ない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0103203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「怖くは……なかったけど……。さすがにわたしでも驚いたかも……。油断し\nているところにびゅぅってきたから……。でもね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0103204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「さっきはよく、仕組みがわからなかったから……もっと回数をこなして、あ\nなたのことを知りたいとは思ってる。戦いや食事と同じ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「精進あるのみ、だから……。だからね、……このままもう一回、するね……\n。うん、探求心がくすぐられたっていうか……。言わせないで」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「あなたがすごく喜ぶことみたいだから……上手になりたい。練習台にしてわ\nるいけど……。あと少し、付き合ってほしい……。続けるね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0103207" ]},
		{"command":[ "SETIMAGE", "0", "still_00024201_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「んっ……ぴちゃ……ぴちゃ、くちゅ、くちゅ……れろ……。ん、んっく……\n。ちゅこっ……ちゅぽちゅっぷっちゅぷ……れろれろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0103208" ]},
		{"command":[ "SETIMAGE", "0", "still_00024201_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「はぁあぁ……。くさい……♪　こんなお汁……おちんちんについたままだと\n気持ちわるいでしょ……？　ぜんぶ、とってあげるね……ぴちゃっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0103209" ]},
		{"command":[ "SETIMAGE", "0", "still_00024201_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「おっぱいと、口でぬぐって……。ん……。ごくっ……。へへ、大丈夫だよ…\n…おいしくないけど、身体に悪そうな味じゃあないし……れろっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0103210" ]},
		{"command":[ "SETIMAGE", "0", "still_00024201_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「たぶん、飲んでも問題ないとおもう……。ちゅぷ……くちゅ、ん、ん、ん…\n…ごくっ……ごきゅっ……。れろ……れろれろれろ……。はぁあ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「おっぱい……胸の先っちょ、気持ち良くなってきた……。一所懸命パイズリ\nフェラしてると、わたしにもご褒美があるんだね……。っちゅっ、ちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「そっか。これ……二人で一緒に気持ち良くなれる方法なんだ……？　れろ…\n…れろ、……あっ♪　すごく……すごくドキドキする、あっ♪　あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「ひぅっ……！？　んひぅっ♪　や……。今、おまたが熱くなって……ニュル\nニュルしたのが溢れ出してきた……。知らなかったことばかり……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0103214" ]},
		{"command":[ "SETIMAGE", "0", "still_00024201_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「おもひろい……♪　れろ……れろ、もっとする……♪　んれろっ……れろっ\n、れろ……。え？　わたし……えっちな顔してる？　ほんとう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0103215" ]},
		{"command":[ "SETIMAGE", "0", "still_00024201_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「……そっか。じゃあ、きっとパイズリフェラに向いてるタイプ……なのかな\n。それならがんばるね。んっ……んっ、ちゅぷ……ちゅぷ、ちゅっくっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0103216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「おちんちん……コチコチになぁれ……。ガチガチになって、いいんだよ……\n。れろ……れろ、ちゅぱ……くちゅっ、くっちゅっ、くちゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「わたし、いやじゃないから……っ。れろ、さっきみたいにびゅーびゅーさ\nれても……今度はびっくりしないから……安心ひてね……♪　れろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0103218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「んっ……んっ……ぷは……っ。ちゅる……ちゅるっ、じゅっ……ぢゅる……\nっ。くちゅ、ちゅく……れろ……れろ、ちゅぅ……ちゅっ、ちゅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0103219" ]},
		{"command":[ "SETIMAGE", "0", "still_00024201_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……っ♪　出ひていいよ……。くちゅ……ちゅっ、口の中……狙\nって……。っぢゅるっ……ぢゅるっ、んっ、お汁ちょうだい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「あっ……ぅ……！　んぷんん……！　はぅっ……うう……！　ふぅんん……\nッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0103301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024201_01_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「あれっ……１回目より量が多くて……！　あっ、ぷ……！？　んうっ、ぷぁ\n……！？　ぢゅるっ……ぢゅるるるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「あ、あ、あ、あ……！　飲んでも飲んでもどんどん出てきて……！　っごく\nっ……ごくっ、ごく……！　んっ、追いつかない……ぢゅる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0103303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「んぐっ……ん、んぅ……んんん……！　っぷぅ……！　……んぁ……喉がお\n汁でいっぱい……口も、舌がうまく動かひぇないくらい……。んむ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0103304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「見、て……？　このお汁……歯でも噛みきれないくらい粘ってて……濃い…\n…。もぐ……もぐ……んんっ……くちゅ……唾と混ぜて……んぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0103305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「ぁ……。やっと飲めるようになってきた、かも……。お汁を集めて……唾液\nとくちゅくちゅして……。んっ、くちゅ……くちゅ、……ごく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0103306" ]},
		{"command":[ "SETIMAGE", "0", "still_00024201_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「ごくっ……ごく……。……んはぁ……♪　少し、こぼしたけど……ほとんど\n飲めたよね……？　わたし、お礼……ちゃんとできたかな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0103307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……パイズリフェラって難しかったけど、やりがいがあったし…\n…次の課題も大体わかったかも。うん、それに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0103308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「今まで見た事ないあなたの顔……見れた。ね、他にもわたしにしてほしいこ\nと……ある？　わたし、こういう知識が今までなかったから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「詳しいんだったら、教えてほしい。物覚えは悪くない方だと思うから……す\nぐに覚えるから。約束だよ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「ひゃっ……あぁっ！　きゃっ……、ぁっ……あっ、あぁ……！　熱い……っ\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0103401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024201_01_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「え……？　えっえっえっ……？　どうして……どうして口じゃなくて、おっ\nぱい……！　あっ……！　だ、だめ……そんなところにかけるの……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「あっ……！　そ、そこ……そこじゃないのに……あっ……！　だめっ……ダ\nラダラこぼれて……もうお口で飲めな……い……あっ！　あっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0103403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「……あ、あぁあ……。ごめん……。せっかく出してくれたのに……照準をわ\nたしがズラしてしまった？　……え？　胸に出したかった？　そうなの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0103404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「１回お口に出したから、パイズリしていたおっぱいに……？　な、なんだ…\n…そうだったんだ……。良かった。それなら……いいの。大丈夫」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0103405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「わたし……ちゃんとパイズリフェラで感謝の気持ちを伝えられたってこと…\n…だよね。はぁああ……！　よかった……ほっとした……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0103406" ]},
		{"command":[ "SETIMAGE", "0", "still_00024201_01_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、はぁ……。あ……動揺して、呼吸が荒くなってごめんなさい…\n…。……さっき口に入ってきたお汁って、こんな色だったんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0103407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「どうしてこんなに真っ白で、熱くて……くさいんだろう……？　もっと飲み\nやすくて、おいしかったら……ごくごく飲んであげられるのにね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0103408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「ふ、ふふ……♪　冗談。でも、……あなたがしてほしいって思うなら……こ\nういうことはまた、してみたいかな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0103409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「おっぱいにお汁をかけるなんて……考えたこともなかった。とっても面白い\n……。もしかしてもっとすごいことがあるのかなって、今、わくわくしてる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0103410" ]},
