{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「清水紅羽、参りました。こんな時間にどうされましたか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0203101" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00005602_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「えっ？　隊長のパワーアップのお手伝い……？　なるほど、承知しました。\nではまずは何からすればよろしいでしょうか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0203102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「む、胸で……奉仕、を……？　水着だからそのままできるだろうって……べ\nつにその為に水着を着ているわけでは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0203103" ]},
		{"command":[ "SETCHARA", "0", "char_00005602_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「い、いえ、不満などありません……は、はい……うぅぅ……わかっています\n、そんなにおっぱい、おっぱい連呼しないでください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0203104" ]},
		{"command":[ "SETCHARA", "0", "char_00005602_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「で、では……どうすれば……あ、はい、まずは隊長のズボンを脱がせる……\nは、はぅ……そこからなのですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0203105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「わかっています。もちろんこれは命令だと。文句などありません……えっと\n、では始めさせていただきます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0203106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「ひゃあっ！　な、なんで、もうこんなに大きくなってるんですか……？　え\nっ、私の水着姿がエロい……ななな何を言ってるんですか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0203107" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00005602_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「は、恥ずかしいじゃないですか……え？　今度は私が乳首を見せろ……？　\nもう、隊長ったら……命令ですもんね、仕方ないです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0203108" ]},
		{"command":[ "SETIMAGE", "0", "still_00005602_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「何をしてるって、胸を見せろとおっしゃるから水着を脱ごうと……はい？　\n水着はつけたまま少しずらして乳首を見せろ……ですか……？」　", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0203109" ]},
		{"command":[ "SETIMAGE", "0", "still_00005602_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「い、いえ……ため息なんてついていません！　もちろん、隊長のことをマニ\nアックだとも思ってません……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0203110" ]},
		{"command":[ "SETIMAGE", "0", "still_00005602_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「そ、そうですよね……隊長のパワーアップのためですからね……より効率よ\nくやらないと。隊長のおっしゃる通りです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0203111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「それでは……こうやって水着をずらして……うぅっ、恥ずかしいから……次\nはこのままおっぱいで挟む……こんな感じ、ですか……？　んっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0203112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「はっ、うぁぁ、隊長の……これ、あ、熱い……です……それにすっごく硬い\n。こんなになっちゃうものなんですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0203113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「はい？　もっと強く押しつけろ……こ、こんな感じですか……？　こう、ぎ\nゅっと……する感じで……んっ、ふぅうっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0203114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「合ってますか？　気持ちいい……ということはこれでいいんですね。良かっ\nたです。私、こういうこと……あまり慣れてなくて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0203115" ]},
		{"command":[ "SETIMAGE", "0", "still_00005602_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「今度は胸を上下に揺らして、これを擦り上げるんですね……わかりました、\nやってみます……んっ、んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0203116" ]},
		{"command":[ "SETIMAGE", "0", "still_00005602_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「はっ、はあっ……強く挟んだまま擦る、んですね……こ、こう？　ですか？\n　ふぅ、んっはぁあっ……隊長のと、擦れて……胸が熱い……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0203117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「はい？　気持ちいい、ですか？　あぁ、よかった……隊長に喜んでもらえて\n、嬉しいです……もっとしっかりご奉仕しますね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0203118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「はぁ、はっ……なんだか、先っぽが濡れてきました……不思議な匂いがしま\nす……隊長が感じてる証拠、ですか？　これが……なるほど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0203119" ]},
		{"command":[ "SETIMAGE", "0", "still_00005602_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「確かに隊長のこれ……どんどん大きくなって、熱くなってます……え？　オ\n、オチンポ……ですか？　うぅ、言わせないでください……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0203120" ]},
		{"command":[ "SETIMAGE", "0", "still_00005602_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「命令ですか？　ううっ……了解しました。オ、オチンポ……隊長のオチンポ\n、さっきよりずっと熱くて硬くなってます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0203121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「はふっ……んっ、はぁあっ……え？　私の水着がエロくて興奮してるんです\nか……？　それは光栄、と言っていいのか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0203122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「あ、いえ、不満などありません。正直を言うと……隊長に喜んでもらえて嬉\nしいです……ただ、ちょっと恥ずかしくて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0203123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「恥ずかしがらなくていいって……そんなの無理ですよぉ……こんな格好で、\n隊長のオチンポ挟んで……おっぱい揺らして……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0203124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「あぁ、もうっ……そんなにジロジロ見ないでください……わかりますよ、さ\nっきからずっとおっぱいばかり見てますし……隊長は……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0203125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「あ、あンっ……し、知りません！　乳首が勃起してるって……私のせいじゃ\nなくて、隊長のオチンポがっ……うっ、はぁあぁぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0203126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「はっ、はっ……はっあんっ……隊長だって、さっきから……我慢汁、いっぱ\nい溢れてて……谷間がドロドロですよ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0203127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「もうすぐ出そう、なんですか？　はい、私のおっぱいで……うぅ、はしたな\nく乳首の勃起したエロおっぱいで、いっぱい扱いてあげます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0203128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「隊長のオチンポ、気持ちよくしますから……はぁ、ンっ……私の……ち、乳\nマンコに……遠慮なく中出ししてください……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0203129" ]},
		{"command":[ "SETIMAGE", "0", "still_00005602_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「ああっ！　恥ずかしいっ……なんてこと言わせるんですかぁ……はっ、はぁ\n……はふっ……んっ……あっ、あっ……はぁああっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0203130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「あっ、あふぅうっ……た、隊長っ……オ、オチンポが震えて……腰も勝手に\n動いてますよ……？　えっ、いいからこのまま続けろ……わかりました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0203131" ]},
		{"command":[ "SETIMAGE", "0", "still_00005602_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「はあっ、はっ……おっぱいで、オチンポを包み込むように……ですね……は\nい、こうですか……はっ、んんっ！　すごいっ、また大きくなって……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0203132" ]},
		{"command":[ "SETIMAGE", "0", "still_00005602_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「ひっううっ！　んっんんんっ！　はっ、あぁぁぁぁぁっ！　あっ、あぁっ…\n…！　な、なにっ……おっぱいの中でオチンポが暴れてるっ……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0203133" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00005602_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「はぁはぁ、あっ、あふぅ……え？　ええ？　出ちゃった……んですか……？\n　これが、精液……ですか？　は、はぁ……こんなに熱いんですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0203134" ]},
		{"command":[ "SETIMAGE", "0", "still_00005602_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「あ、いえ……突然だったので、驚いただけで……おっぱいに出されたことは\n、べつに……えっと、はい……気にしてないというか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0203135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「隊長に喜んでもらえたなら……隊長のパワーアップのお手伝いになったのな\nら、私も嬉しいですから……とても嬉しいですよ、本当です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0203136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「そんなお礼なんて……でも、そんなにこの水着、よかったのですか？　いえ\n、疑っているわけではなくて……自分ではピンとこなくて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0203137" ]},
		{"command":[ "SETIMAGE", "0", "still_00005602_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「え？　チンポを見ろ……？　はっ、ええっ！　なんでまだこんなにガチガチ\nになってるんですか、これ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0203138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「普通、射精したら小さくなるのでは……？　隊長のオチンポはむしろ大きく\nなってるように見えますが……これが水着効果、なんですか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0203139" ]},
		{"command":[ "SETIMAGE", "0", "still_00005602_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「まだ終わってない……ですよね？　この状態では……はい、すぐ続きを……\nおっぱいはこのままでいいんですか？　わかりました。では……んっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0203140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「あっ、あぁっ……出したばかりなのに……オチンポ……熱くて、硬くて……\nんっ、んんっ……また大きくなってるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0203201" ]},
		{"command":[ "SETIMAGE", "0", "still_00005602_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「はぁっ……おっぱいが擦れて、んっ……ドロドロになって……こ、これ気持\nちいい……ですか？　すごくいい？　そうですか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0203202" ]},
		{"command":[ "SETIMAGE", "0", "still_00005602_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「もっと動かした方がいいですか？　はい……じゃあ、またおっぱいで、ご奉\n仕しますね……んっ……はあっ……はぁ、あぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0203203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「あぁ……すごい……ビクビクいってます……隊長のオチンポぉ……んんぅ、\nふぅうっ……はぁあっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0203204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「ううっ、ふっ……んふっ……ヌルヌルしてて、おっぱいがすべって……はぁ\nっ……あんっ……んはぁぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0203205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「んっ、んはぁっ……た、隊長……じっとしててください……奉仕が上手くで\nきません……はぁ、あっ、あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0203206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「はい？　気持ち良すぎるから、勝手に腰が動いてしまう？　そ、そんなに…\n…感じてくれてるんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0203207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「も、もう……水着がエロすぎるって……大げさですよ……んんっ……た、確\nかにすごく興奮されてるみたいですけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0203208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「はっ、あぁ、あんっ……ああっ！　また大きくなって、ます……んんっ……\nはあっ……あっあふ……んんぅんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0203209" ]},
		{"command":[ "SETIMAGE", "0", "still_00005602_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「なんですか？　乳首……？　ええっ、もっと乳首を擦りつけろ……って……\nこ、こうですか？　んっ、ひぃうっ……はぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0203210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「ふぅ、ふぅうっ……エッチな声、と言われても……だって、先っぽが擦れて\n……こんなの、声が出ちゃいます……よぉ……ひぃうっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0203211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「はあっ、あふっ……！　んんっ！　あぁ……隊長のオチンポ……硬くて、先\nっぽ……擦れて……くひっ、ひぃうぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0203212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「ちゃんと乳首って言え？　もうっ……本当に意地悪なんですからぁ……そう\nです、乳首です……乳首感じちゃってます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0203213" ]},
		{"command":[ "SETIMAGE", "0", "still_00005602_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「申し訳ありません……ご奉仕なのに、私が感じてしまって……はあっ……あ\nっ、あぁ……おっぱいが熱くて……はぁんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0203214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「ひぃあっ……あんっ、あっ、あふぁ……た、隊長もイキそうだから、問題な\nい……ですか？　あぁ、よかったぁ……あぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0203215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「出してください……さっきみたいにいっぱい……好きなだけ射精してくださ\nい……はぁ、はぁっ……んっ、ンぅうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0203216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「隊長が気に入ってくださった……水着おっぱいで、受け止めますから……は\nっ、ふぅうっ……全部受け止めますからぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0203217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「はぁ、んんっんんっ……が、我慢なんてしなくていいんです……遠慮せず、\n出してくださいっ……はぁっ、あぁぁぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0203218" ]},
		{"command":[ "SETIMAGE", "0", "still_00005602_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「ンっんんっ！　ああっ……！　オチンポがまた大きくなって……くっ、ふぅ\nうっ……あっ、あっ、はぁぁっ！　は、はやく……んんぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0203219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「た、隊長ぉ……出してぇっ……！　出してください！　私のおっぱいに……\nんっ、はっ……はあっ、はっはっ……はぁあぁぁぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0203220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「はんっ！　んっ、んんぅぅぅぅぅ！　んっ、んあっ……あぁぁ～～～～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0203301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00005602_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「あっ、あぁっ……んふぅっ……さ、さっき……出したばかりなのに……こん\nなにたくさん……んっ……匂いも、すごい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0203302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「本当に水着……興奮してくれたんですね……あっ、あぁ……熱い……おっぱ\nいの中でドクドクいってます……ンはぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0203303" ]},
		{"command":[ "SETIMAGE", "0", "still_00005602_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「あぁあっ……はぁはぁ……ふぅ、んぅぅっ……すごい……まだ出てます……\nどんだけ溜めてたんですかぁ……あぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0203304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「はあ、はぁっ……はっ、はぁ……んっ、ふぅううっ……あぁ、もう……おっ\nぱいが隊長の精液まみれになってます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0203305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「ふぅ……終わったようですね……それにしてもすごい量……ご満足いただけ\nましたか？　そうですよね、これだけ射精してくれたんですし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0203306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「隊長に喜んでもらえてうれしいです。これで無事にパワーアップしますよね\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0203307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「え？　また今度も……ですか？　隊長がそこまで言うなら……はい、また水\n着でご奉仕しますけど……え？　私も喜んでる……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0203308" ]},
		{"command":[ "SETIMAGE", "0", "still_00005602_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「な、なにをニヤニヤしてるんですか……私のことはいいんです……隊長の命\n令だからしただけで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0203309" ]},
		{"command":[ "SETIMAGE", "0", "still_00005602_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「で、でも……もちろん嫌な気分ではないですよ……命令されればいつでもご\n奉仕しますから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0203310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「はぁっ……あっ、だめっ……そんなに腰を動かしたら……あっ、あぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0203401" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「ひゃぁぁぁぁっ！　んっ、ああっ……か、顔にっ……んっ、んんっ……精液\nがかかって……ひゃっ、うぅぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0203402" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00005602_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「おっぱいで受け止めますって、言ったのにぃ……はっ、あぁぁ……私の顔に\n……かけないでください……あぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0203403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「しかも……すごい量……さっき出したばっかりなのに……ンンっ……顔が、\nドロドロ……匂いも、鼻にくる……はぁ、あっあぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0203404" ]},
		{"command":[ "SETIMAGE", "0", "still_00005602_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「あぁ、もうっ……顔だけじゃなくて、おっぱいまで精液が……水着も隊長の\nザーメンでぐちゃぐちゃですよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0203405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「ええ？　ザーメンまみれになってる私はエロい、ですか……？　うぅ、そん\nなこと言われても、嬉しくないですよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0203406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「ひゃうっ……おっぱいの中でオチンポをピクピクさせないでください……な\nんでそんなに嬉しそうなんですか……あぁあっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0203407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「あぁ……いっぱい出してくださいとは言いましたけど……顔やおっぱいにま\nでぶっかけられるなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0203408" ]},
		{"command":[ "SETIMAGE", "0", "still_00005602_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「それだけ水着姿の私がエロくて、ご奉仕も最高だったと……そ、それは……\nまあ、喜んでいただけたなら嬉しいですよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0203409" ]},
		{"command":[ "SETIMAGE", "0", "still_00005602_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「え？　また水着でしてほしいですか？　隊長がそう言うなら、もちろんです\n。命令されればいつでもご奉仕します」", "NORMAL" ]},
