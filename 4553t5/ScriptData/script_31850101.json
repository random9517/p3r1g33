{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「隊長ちゃーん。お姉ちゃんよー。お姉ちゃんを呼び出してー、なにをして欲\nしいのかしらー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0103101" ]},
		{"command":[ "SETCHARA", "0", "char_00018501_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「んー？　ご奉仕なのー？　お姉ちゃんがー隊長ちゃんの身体をー気持ちよー\nくしてあげればいいのねー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0103102" ]},
		{"command":[ "SETCHARA", "0", "char_00018501_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「それでーお姉ちゃんはどうすればいいのかしらー？　……え？　隊長ちゃん\nのおちんちんを踏むのー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0103103" ]},
		{"command":[ "SETCHARA", "0", "char_00018501_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「んー、そんなことして、隊長ちゃんは平気ー？　えっとー、隊長ちゃんがし\nて欲しいっていうならー……お姉ちゃん、してあげるー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0103104" ]},
		{"command":[ "SETCHARA", "0", "char_00018501_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「わー、これが隊長ちゃんのおちんちんなのねー。これをーお姉ちゃんのナメ\nクジ足で踏めばいいのー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0103105" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00018501_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「そ、それじゃあ……。あんまり痛くないように、お姉ちゃん、そーっと踏ん\nで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0103106" ]},
		{"command":[ "SETIMAGE", "0", "still_00018501_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「んんんぅっ！　ああー……隊長ちゃんの、おちんちんー……温かいのねー。\nはぁー……はぁー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0103107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「どうかしらー？　お姉ちゃんのーぬめぬめした足でーおちんちんーふみーふ\nみー……ってー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「ああ……なんだか……足の裏に当たるーおちんちんの感触ー……隊長ちゃん\nのーむくむくしてるー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「お姉ちゃんに踏まれながらーおちんちんーどんどん、おっきくーなっている\nのねー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0103110" ]},
		{"command":[ "SETIMAGE", "0", "still_00018501_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「んっ、ああ……すっごーい……。お姉ちゃんもー隊長ちゃんのおちんちんー\n感じちゃうー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0103111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「お姉ちゃんのぬめぬめーすっごく、敏感だからー……んっ、ああ……こんな\nにー熱いおちんちんにー触れてたらー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「火傷ーしちゃいそうよー……。ん……んふぅ……はぁ……はぁ……。隊長ち\nゃんーお姉ちゃんの足ー気持ちいいー……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「お姉ちゃんのぬめぬめナメクジ足ーいーっぱい感じてねー……。ん……ああ\n……おちんちんーびくびくー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「んんぅ……お姉ちゃんもー興奮してきちゃってるーわー……。はぁー……ど\nんどん粘液がー溢れてーきちゃうのー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0103115" ]},
		{"command":[ "SETIMAGE", "0", "still_00018501_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「んー……んぅ……もっとー強くしちゃって、いいのー？　んふぅ……はぁー\n……はぁー……もっとねー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「んぅー……っ！　思いっきり体重をかけてーおちんちん、ふみーふみー……\n。はぁー……はぁー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「お姉ちゃんー、隊長ちゃんのーおちんちんを感じてー……ああ……すっごく\nドキドキしてきちゃってるー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「隊長ちゃんもーお姉ちゃんの足をーいーっぱい感じてくれているのねー。ぬ\nるぬるー気持ちいいのねー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「ああー、隊長ちゃんの気持ちよさそうな顔を見てたらーお姉ちゃんーますま\nすご奉仕したくなっちゃうー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「こうしてーびくんびくんしてきたおちんちんー。いーっぱい、お姉ちゃんの\nぬめぬめお汁でー……んふふー……感じるようにーしちゃうー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「ああー……気持ちいいでしょー？　隊長ちゃんのおちんちんーナメクジ足で\n包んでーしーこしーこしてるのー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0103122" ]},
		{"command":[ "SETIMAGE", "0", "still_00018501_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「んぁ……っ、おちんちん、むくむくー。いーっぱい、感じてー。おちんちん\nからー白いのびゅーって、しましょうねー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「んぁあー……あはぁー……はぁー……。おちんちんー……んふぅー……おっ\nきくなってー……ああー、ますます熱いー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「足を使ってーおちんちんのことお世話しちゃってるのにー。お姉ちゃんーな\nんだか身体が熱いのー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「はぁー……はぁー……。おちんちんからもーぬるぬるしたお汁ー溢れてきて\nいるわねー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「隊長ちゃんがー、とーっても感じてくれているみたいでーお姉ちゃんー嬉し\nくなってきちゃってー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「ん……っ。なーにー？　もう、イキそうになっちゃってるのー？　お姉ちゃ\nんの足にー、びゅーって射精ーしちゃうー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「いいのよー……。んふぅー……。お姉ちゃんの足にー隊長ちゃんの精液ーび\nゅーってしちゃってーいいのよー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「射精してー……だしてー、だしてー……。隊長ちゃんのーおちんちんの中に\n溜まってるー白いのー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「びゅーってー……びゅびゅーってー……っ！　はぁー……はぁー……足でい\nっぱいー絞りだしてーあげるからー……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「しーこ、しーこ、ああっ、きて、きて……っ！　んっ、んんー……っ！　あ\nあっ、おちんちんー……びっくんー……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「ああー……っ！　足にー……お姉ちゃんの足にーアツアツの精液ー感じるわ\nー……。たっぷりー……でてるー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0103133" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018501_01_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「こんなにー濃いのねー……隊長ちゃん、お姉ちゃんにいっぱい、びゅーって\nできてーえらいわねー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「……ええー？　お姉ちゃんのお汁が気持ちよかったからー？　んふふー、お\n姉ちゃん汁は特別製だからー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0103135" ]},
		{"command":[ "SETIMAGE", "0", "still_00018501_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「ふふー。まだー、おちんちんがびっくんびっくんしてー精液ーだしたそうに\nしているわねー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0103136" ]},
		{"command":[ "SETIMAGE", "0", "still_00018501_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「なーにー？　まだまだーお姉ちゃんとーエッチなコトしたいのー？　ふふー\n、隊長ちゃんったら、仕方がないんだからー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0103137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「いいわよー。隊長ちゃんのおちんちんのお世話ー最後までちゃーんとしてあ\nげるんだからねー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「おちんちんー、こーんなにパンパンに勃起したままはーつらーいもんねー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「じゃあー、お姉ちゃんにーもーっとおちんちんの面倒、見させてちょうだい\nねー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「はぁー……はぁー……。それにしてもー、お姉ちゃんの足が精液でねっとね\nとー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0103201" ]},
		{"command":[ "SETIMAGE", "0", "still_00018501_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「こんなに濃いのをだしたのにー、おちんちんは全然萎えないのねー……おち\nんちんって不思議ねー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「……えー？　勃起が収まらないー？　感度もあがってるー？　んー……ああ\nー……それってお姉ちゃん汁のせいかもー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0103203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「お姉ちゃん汁にはー弟みたいな隊長ちゃんをーいーっぱい気持ちよくしちゃ\nう成分がー含まれているんだよー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0103204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「んんー……っ！　だからー……おちんちんー、腫れちゃってー……はぁー…\n…ビンビンおちんちんになっちゃうのー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「大丈夫よー……お姉ちゃんがーちゃーんと治るまでーしこしこーってしてあ\nげるからねー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0103206" ]},
		{"command":[ "SETIMAGE", "0", "still_00018501_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「んふー……はぅー……。さっきの精液とーお姉ちゃんのねとねと汁があわさ\nってーぐちゅぐちゅってエッチな音してるー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「おちんちんーアツアツになってー……はぁー……お姉ちゃんの足の下でーび\nくびく暴れちゃってるー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「はぁー……はぁー……大変ねー……。おちんちんーこーんなにふくらませち\nゃってー……。んふふー、お姉ちゃんの足ー、気持ちいいー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「ああー……お姉ちゃんもーっと足を激しく動かしちゃうわねー。ごーしごー\nし……ええー、これでも激しくしているわよー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0103210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「ゆっくりすぎてーむずむずしちゃうー？　んんぅー……隊長ちゃんってばー\n自分から腰を動かしちゃっているわよー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「お姉ちゃんの足にーおちんちんーこすりつけるみたいにー……ああーっ、お\nちんちんーこすれて感じちゃうのー……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「んんーっ？　なーにー？　早く動けないなら、もっと体重をかけるのー？　\nんー、お姉ちゃんーちょっぴり重たいよー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「んふーっ！　ああー、体重をかけたらー足に隊長ちゃんのおちんちんをーも\nーっと感じられるようになったよー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0103214" ]},
		{"command":[ "SETIMAGE", "0", "still_00018501_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「ビンビンになっちゃってるー。勃起おちんちんーああーこうしてー足でーた\nっぷりーしごいてー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0103215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「はぁー……どんどんお姉ちゃん汁が足から溢れてー。隊長ちゃんのことーぬ\nめぬめにしちゃってるよー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0103216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「隊長ちゃーん、またー、精液でちゃいそうー？　お姉ちゃんにー、白いのび\nゅーっておもらししちゃうー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「いーよー。我慢しなくてーいいからねー。お姉ちゃんがー隊長ちゃんの精液\nー受け止めてあげるんだからー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0103218" ]},
		{"command":[ "SETIMAGE", "0", "still_00018501_01_05" ]},
