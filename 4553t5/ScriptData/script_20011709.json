		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「コンテスト会場が壊れちゃったのは残念だけど、仕方ないね……」", "NORMAL" ]},
