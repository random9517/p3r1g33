		{"command":[ "SETCHARA", "0", "char_00009802_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「そんなワケで隊長さん。引き続き、襲来者（インベーダー）退治よろしくね\n～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_010021540005" ]},
