		{"command":[ "SETCHARA", "0", "char_00010002_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「コンテスト会場もなくなっちゃったし、この勢いと戦力で敵の本拠地を叩き\nに行こうよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010021540005" ]},
		{"command":[ "SETCHARA", "0", "char_00009602_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「そうだな！　これだけの戦力があれば、すぐに制圧できるぜ！」", "NORMAL" ]},
