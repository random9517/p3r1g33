		{"command":[ "SETCHARA", "0", "char_00001402_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「余力を持って戦えば、危険だったです。結構キツめのヤバめだったですよ！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021540057" ]},
