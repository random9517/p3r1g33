{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0128" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_020" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「お、おぼえてろ～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010113690001" ]},
		{"command":[ "SETCHARA", "0", "char_00090101_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "さっくりと襲来者（インベーダー）たちを追っ払う。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "夜の学園にガラスを割って忍び込んでいたなんて、油断ならない連中だ。戸締\nりしとこ。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「結局、幽霊騒動の正体は襲来者（インベーダー）でしたか。わかってみれば\n単純なものです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_050113690001" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "見回りを続けながら兎子がつぶやく。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「まーそうだよなー。襲来者（インベーダー）だってわかったし、全然怖くな\nくなったな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040113690001" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「で、でも、サメはでるかもよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_020113690001" ]},
		{"command":[ "SETCHARA", "0", "char_00001802_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「どうせそのサメも襲来者（インベーダー）の見間違いじゃないですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_050113690002" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「サメ型の襲来者（インベーダー）ってこと？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_020113690002" ]},
		{"command":[ "SETCHARA", "0", "char_00001802_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「そんなやついないでしょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_050113690003" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「いや、サメを舐めない方がいい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010113690001" ]},
		{"command":[ "SETCHARA", "0", "char_00012701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「サメはとても賢い生き物だ。狩りをするときも数頭が連携をとって獲物を追\nい込む」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010113690002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「あれは私がまだ駆け出しのハンターだったころだ。クルーザーの真下に魚群\nができた」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010113690003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「何事かと思って船を止めてレーダーの探知範囲を広げた。すると……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010113690004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「す、すると……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_020113690003" ]},
		{"command":[ "SETCHARA", "0", "char_00001802_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「魚群の周りをサメが泳いでいたんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010113690005" ]},
		{"command":[ "SETCHARA", "0", "char_00012701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「さ、サメが！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040113690001" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「ああ、徐々に円を狭めるように、サメたちは見事なチームワークで泳いでい\nた」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010113690006" ]},
		{"command":[ "SETCHARA", "0", "char_00012701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「獲物の群れを、海底から海面へ追い込むように」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010113690007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「まったく、敵ながら感心したよ。まあ、連中がご飯にありつく前に、私が殲\n滅したけどね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010113690008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「そんなこと、本当にあり得るんですか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_050113690004" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「サメと出会ったのは海だけじゃない。とある村では、ため池で突然変異した\nサメと、戦ったことがある」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010113690009" ]},
		{"command":[ "SETCHARA", "0", "char_00012701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「淡水のサメって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_050113690005" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「でも、サメってお魚でしょ～。水がないなら安全よね～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040113690002" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「そうでもない。サメは空も飛ぶ。サメが出る土地に安全な場所なんてないん\nだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010113690010" ]},
		{"command":[ "SETCHARA", "0", "char_00012701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「いや、さすがに空を飛ぶなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_050113690006" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "後ろから聞こえてくる会話は、すっかり緊張感もなくなっている。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「見回りというか、女子会になってないか？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「サメと女子会という、およそ交わることのないものが今ここに出会ったので\nすなぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113690001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なに感慨深そうにしてるんだよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0151" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "早く帰りてえ。そう思いながら中庭までやってきた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「とにかく、サメはどこにでも現れる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010113690011" ]},
		{"command":[ "SETCHARA", "0", "char_00012701_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「どこにでも、ね……。そこにある噴水からでも？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_020113690004" ]},
		{"command":[ "SETCHARA", "0", "char_00001802_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「んなわけないでしょ。どんな設定ですか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_050113690007" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「いや、あり得ない話じゃない。ここはサメに狙われているからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010113690012" ]},
		{"command":[ "SETCHARA", "0", "char_00012701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「ばかばかしい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_050113690008" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "と、兎子が噴水の方へ近寄ると……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYBGM", "BGM_007" ]},
		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「見つけたぜぇえええーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_010113690001" ]},
		{"command":[ "SETCHARA", "0", "char_00009501_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「ひぃいいいっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_050113690009" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "噴水の中からサメ？が飛び出しただと！？", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「わぁっ、本当にでたっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_020113690005" ]},
		{"command":[ "SETCHARA", "0", "char_00001802_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「サメ！？　でも、手足がついてるぞ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040113690002" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「サメマン！？　サメマンよ～っ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040113690003" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「シャークガール……やっぱりお前が犯人だったか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010113690013" ]},
		{"command":[ "SETCHARA", "0", "char_00012701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「知り合いなのか！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャークガール" ]},
		{"command":[ "SETTEXT", "「スーザン、てめぇなんでこんなところに……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_010113690002" ]},
		{"command":[ "SETCHARA", "0", "char_00009501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「サメを殺すためならどこにだって駆けつける。それがサメキラーだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010113690014" ]},
		{"command":[ "SETCHARA", "0", "char_00012701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「サメを殺す。サメをすべて殺す。当然お前も殺す。サメを！　殺す！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010113690015" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャークガール" ]},
		{"command":[ "SETTEXT", "「上等だゴラァッ！　かかってきやがれ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_010113690003" ]},
		{"command":[ "SETCHARA", "0", "char_00009501_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "因縁のある相手なのはわかった。わかったから、頼むから俺の話も聞いてくれ\nっ！", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}