		{"command":[ "SETNAME", "襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「こちらも、順調に進んでいます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_020115370001" ]},
		{"command":[ "SETCHARA", "0", "char_00022701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「うむ……ごくろう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010115370002" ]},
		{"command":[ "SETCHARA", "0", "char_00020199_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「えっと……女王様、なにやら顔色が……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_030115370001" ]},
		{"command":[ "SETCHARA", "0", "char_00022801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ぷぇ？　そんなことはないぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010115370003" ]},
		{"command":[ "SETCHARA", "0", "char_00020199_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「女王様のあの状態……本当に大丈夫なのかのう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100115370001" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「なんていうか最近、上の空だよなぁ。虚空を見つめている時間が多いという\nか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080115370001" ]},
		{"command":[ "SETCHARA", "0", "char_00000408_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010115370004" ]},
		{"command":[ "SETCHARA", "0", "char_00020199_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「なんか、玉座の上でため息をついてばかりよね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_010115370001" ]},
		{"command":[ "SETCHARA", "0", "char_00019501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「更年期……か？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_010115370001" ]},
		{"command":[ "SETCHARA", "0", "char_00019401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「そんなクロちゃんじゃないんだから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_010115370001" ]},
		{"command":[ "SETCHARA", "0", "char_00019601_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「誰が更年期だ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_010115370002" ]},
		{"command":[ "SETCHARA", "0", "char_00019401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「エルフにも更年期ってあるのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080115370002" ]},
		{"command":[ "SETCHARA", "0", "char_00000408_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「そこはあまり掘り下げんでもよいじゃろ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100115370002" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「まったく、女王があんななのはキミたちが原因なのに」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010115370001" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ジェスタ！　それはどういう意味じゃ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100115370003" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ふがいな～いキミたちが、カツマを連れてくるのに時間をかけすぎているか\nらってこと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010115370002" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「そのせいで女王様は、深刻なムスコニウム不足に陥っちゃったんだよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010115370003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「な……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_010115370003" ]},
		{"command":[ "SETCHARA", "0", "char_00019401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「ムスコニウム不足ですって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_010115370002" ]},
		{"command":[ "SETCHARA", "0", "char_00019501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「なにそれ～っ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_010115370002" ]},
		{"command":[ "SETCHARA", "0", "char_00019601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「まーた道化師の与太話じゃろ。そう何度も振りまわされると思ったら大間違\nいじゃぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100115370004" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「そうだそうだ！　こないだのタヌキみたいに、適当なこといってオレらを振\nりまわすつもりだろ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080115370003" ]},
		{"command":[ "SETCHARA", "0", "char_00000408_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「心外だな～、大真面目だって！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010115370004" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「母系キャラが息子とらぶらぶちゅっちゅすることで摂取できる栄養素のムス\nコニウムだよ？　ご存じない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010115370005" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「しらなーい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_010115370003" ]},
		{"command":[ "SETCHARA", "0", "char_00019601_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「女王にとってはカルシウムの次くらいに重要な栄養素なんだから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010115370006" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「そんな大事な栄養素なのに、どうして今になって足りなくなってるの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_010115370003" ]},
		{"command":[ "SETCHARA", "0", "char_00019501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「だって女王様だよ？　きっと、不足しているのをずっと我慢していたんじゃ\nないかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010115370007" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ボクたちには、『かっこいい女王様』の姿を見せないと、部下に示しがつか\nないでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010115370008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「その気持ち、私もよくわかる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_010115370004" ]},
		{"command":[ "SETCHARA", "0", "char_00019401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「私もモイライシスターズの長女として、妹たちには常に威厳ある姿を見せね\nばと思うからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_010115370005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「おねーさまが……威厳ある長女……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_010115370004" ]},
		{"command":[ "SETCHARA", "0", "char_00019501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「お正月のころ、たいちょーさん相手にあーんなにしどろもどろしちゃってた\nのにー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_010115370004" ]},
		{"command":[ "SETCHARA", "0", "char_00019601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「それはアトロポスも一緒だろう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_010115370006" ]},
		{"command":[ "SETCHARA", "0", "char_00019401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「あ、アーちゃんはいいのーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_010115370005" ]},
		{"command":[ "SETCHARA", "0", "char_00019601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「お前たち……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010115370005" ]},
		{"command":[ "SETCHARA", "0", "char_00020199_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「女王様！　えっと、お身体は大丈夫ですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_010115370007" ]},
		{"command":[ "SETCHARA", "0", "char_00019401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「私の身体……？　なんともないが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010115370006" ]},
		{"command":[ "SETCHARA", "0", "char_00020199_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「そんなことよりも、地球への侵略はどうなっている」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010115370007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「そ、そのことについてはぁ、アーちゃんたちぃ、作戦会議中でぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_010115370006" ]},
		{"command":[ "SETCHARA", "0", "char_00019601_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「そうか……ふむ……。では、私は少し自室で休ませてもらう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010115370008" ]},
		{"command":[ "SETCHARA", "0", "char_00020199_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「はーい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_010115370005" ]},
		{"command":[ "SETCHARA", "0", "char_00019501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「いつも通りといえばいつも通りじゃが……やはり、覇気がないのぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100115370005" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「たしかに」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_010115370008" ]},
		{"command":[ "SETCHARA", "0", "char_00019401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「いつもなら、ここでカミナリがずどーん！　だよ？　どう、おかしいでしょ\n女王様！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010115370009" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「まあ、そういえば……そうかも……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080115370004" ]},
		{"command":[ "SETCHARA", "0", "char_00000408_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「たしかに。ムスコニウムが原因かはわからぬが、なんとかしないといけない\nのぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100115370006" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}