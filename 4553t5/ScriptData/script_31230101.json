{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "PLAYVOICE", "123_0103101" ]},
		{"command":[ "SETNAME", "フロール" ]},
		{"command":[ "SETTEXT", "「こんにちは、隊長さん。わたしに用って、なんですか？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00012301_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "123_0103102" ]},
		{"command":[ "SETNAME", "フロール" ]},
		{"command":[ "SETTEXT", "「え？　ごほう……えええええ！？　ご、ご奉仕～！？　え、エッチなこと、\nするんですか～！？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00012301_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "123_0103103" ]},
		{"command":[ "SETNAME", "フロール" ]},
		{"command":[ "SETTEXT", "「あ、あの、そういうこと、わたし、したことがなくて！？　なのに、いきな\nりエッチなことだなんて～！？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00012301_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "123_0103104" ]},
		{"command":[ "SETNAME", "フロール" ]},
		{"command":[ "SETTEXT", "「いや、もちろん、年頃の女の子ですから、そういうのに、興味がないと言え\nば嘘になりますけど……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00012301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "123_0103105" ]},
		{"command":[ "SETNAME", "フロール" ]},
		{"command":[ "SETTEXT", "「それに、隊長さんは、エッチなことをすると、相手をパワーアップできる能\n力があるんですもんね。そのお話しは、前に聞いて、知ってましたし」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "123_0103106" ]},
		{"command":[ "SETNAME", "フロール" ]},
		{"command":[ "SETTEXT", "「それで、その……ご奉仕って、具体的には、どういうこと、するんですか？\n」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00012301_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "123_0103107" ]},
		{"command":[ "SETNAME", "フロール" ]},
		{"command":[ "SETTEXT", "「む、胸で……おっぱいで。な、なるほど。それなら、わたしにもできそうで\nす」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "123_0103108" ]},
		{"command":[ "SETNAME", "フロール" ]},
		{"command":[ "SETTEXT", "「いきなり最後までするのは、さすがにちょっと怖いですけど、おっぱいで挟\nむぐらいなら、なんとか……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "123_0103109" ]},
		{"command":[ "SETNAME", "フロール" ]},
		{"command":[ "SETTEXT", "「は、はい。それじゃあ……始めます、ね。んっしょっと」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00012301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "123_0103110" ]},
		{"command":[ "SETNAME", "フロール" ]},
		{"command":[ "SETTEXT", "「は、はうぅぅ。凄く、大っきい。それに、熱い、です。男の人のおちんちん\nって、こんなに熱いんですね。知りませんでした」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012301_01_02" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "123_0103111" ]},
		{"command":[ "SETNAME", "フロール" ]},
		{"command":[ "SETTEXT", "「ぴくぴく動いてて、血管が浮き出てますよ。形も変だし、なんだか見た目は\n凄く痛々しいんですけど」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "123_0103112" ]},
		{"command":[ "SETNAME", "フロール" ]},
		{"command":[ "SETTEXT", "「それに、すっごくかたいです。まるで鍛えあげられた筋肉みたいです。あ、\nほら、またぴくって動いた。ますます筋肉みたいです」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "123_0103113" ]},
		{"command":[ "SETNAME", "フロール" ]},
		{"command":[ "SETTEXT", "「そ、そうですか。柔らかくて、気持ちいいから、ぴくぴくしちゃうんですか\n。あ、あはは。知らなかった、です」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "123_0103114" ]},
		{"command":[ "SETNAME", "フロール" ]},
		{"command":[ "SETTEXT", "「じゃ、じゃあ、この匂いは……だんだん、つんってするような匂いが、濃く\nなってますけど、これも、ひょっとして？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "123_0103115" ]},
		{"command":[ "SETNAME", "フロール" ]},
		{"command":[ "SETTEXT", "「やっぱりそうなんですね。どんどん、男の人の匂い、濃厚になってきてます\n。頭、ぼうっとしちゃいそうです、この匂い」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "123_0103116" ]},
		{"command":[ "SETNAME", "フロール" ]},
		{"command":[ "SETTEXT", "「次は……はい。胸を動かすんですね。こう、持ち上げるような感じで、下か\nら上に……押しつけるように、しながら……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "123_0103117" ]},
		{"command":[ "SETNAME", "フロール" ]},
		{"command":[ "SETTEXT", "「あっ、またびくって震えた。それも、今まで以上に強くです。わたしの胸に\n、ぴくぴくって震えてるの、響いてきてます」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "123_0103118" ]},
		{"command":[ "SETNAME", "フロール" ]},
		{"command":[ "SETTEXT", "「なんだか、これ、凄く不思議な気分です。隊長さんにご奉仕してるだけなの\nに、なんだか、わたしの身体、うずうずしちゃってます」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "123_0103119" ]},
		{"command":[ "SETNAME", "フロール" ]},
		{"command":[ "SETTEXT", "「嫌じゃないです。だって、むしろ嬉しいですから。わたし、この大っきな胸\nがコンプレックスで。だって、運動するときに邪魔でしょうがないですし」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "123_0103120" ]},
		{"command":[ "SETNAME", "フロール" ]},
		{"command":[ "SETTEXT", "「でも、そんな邪魔だったのが、こうやって隊長さんのお役に立てるんですか\nら……嬉しいに決まってます」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "123_0103121" ]},
		{"command":[ "SETNAME", "フロール" ]},
		{"command":[ "SETTEXT", "「えへへ。だんだん、隊長さん、声が漏れてきてますよ。そうなんですね。男\nの人も、気持ちいいと、声が出ちゃうんですね」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012301_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "123_0103122" ]},
		{"command":[ "SETNAME", "フロール" ]},
		{"command":[ "SETTEXT", "「じゃあ、もっともっと、声を出させてあげます。それっ、ん！　んんん！　\nしょっ、えい！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "123_0103123" ]},
		{"command":[ "SETNAME", "フロール" ]},
		{"command":[ "SETTEXT", "「ふふふ。どんどんおちんちんが膨らんできてます。ぴくぴくって、震えも強\nくなってきて……あぁ、凄いです」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "123_0103124" ]},
		{"command":[ "SETNAME", "フロール" ]},
		{"command":[ "SETTEXT", "「んふふ、もっと……もっともっと、してあげますね。ん、んん！　んんん！\n　わたしの、おっぱいで、もっと、気持ち良くなって、ください！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "123_0103125" ]},
		{"command":[ "SETNAME", "フロール" ]},
		{"command":[ "SETTEXT", "「あはっ。そうですか、嬉しいです。涙、滲んじゃうほど、気持ちいいんです\nね！　ふふふ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "123_0103126" ]},
		{"command":[ "SETNAME", "フロール" ]},
		{"command":[ "SETTEXT", "「じゃあ、もっと強くしますね。ぎゅ～～～～～！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "123_0103127" ]},
		{"command":[ "SETNAME", "フロール" ]},
		{"command":[ "SETTEXT", "「あっ、おちんちんから、透明なのが出てきましたよ？　これ……おしっこじ\nゃないですよね？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "123_0103128" ]},
		{"command":[ "SETNAME", "フロール" ]},
		{"command":[ "SETTEXT", "「そうなんですね。やっぱりこれが、カウパーなんですね。知ってますか？　\nこれにも精子がちゃんと混じってて、妊娠もしちゃうんですよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "123_0103129" ]},
		{"command":[ "SETNAME", "フロール" ]},
		{"command":[ "SETTEXT", "「何で知ってるって、そりゃあ授業で習いましたから。今時、性的な知識がな\nい女の子なんていませんよ、隊長さん」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "123_0103130" ]},
		{"command":[ "SETNAME", "フロール" ]},
		{"command":[ "SETTEXT", "「このまま続けると、透明なのだけじゃなく、白く濁った精液も出ちゃうんで\nすよね、きっと。それが、絶頂の証拠なんですよね」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "123_0103131" ]},
		{"command":[ "SETNAME", "フロール" ]},
		{"command":[ "SETTEXT", "「えへへ。なんだか楽しみになってきたかも。わたし、男の人の射精を見るの\n初めてです」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "123_0103132" ]},
		{"command":[ "SETNAME", "フロール" ]},
		{"command":[ "SETTEXT", "「だから、思いっきり出してくださいね。わたしのおっぱいに、好きなだけ、\n出してくださいね、隊長さん」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "123_0103133" ]},
		{"command":[ "SETNAME", "フロール" ]},
		{"command":[ "SETTEXT", "「わたしも、たくさん出るように、頑張りますから。もっと、おっぱい、たく\nさんたくさん、ぎゅーってしながら、動かしますね」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "123_0103134" ]},
		{"command":[ "SETNAME", "フロール" ]},
		{"command":[ "SETTEXT", "「あ、ふあぁ。透明なの、たくさん……おちんちんが、もうパンパンです。胸\n、痛いぐらい、かたいです」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012301_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "123_0103135" ]},
		{"command":[ "SETNAME", "フロール" ]},
		{"command":[ "SETTEXT", "「イクんですね？　いいですよ、イッちゃってください、隊長さん！　射精す\nるところ、見せてください！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "123_0103136" ]},
		{"command":[ "SETNAME", "フロール" ]},
		{"command":[ "SETTEXT", "「あっ、ふあ！？　ひゃうううううううううう！　熱いのが、胸にぃぃぃ！」", "NORMAL" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012301_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "123_0103137" ]},
		{"command":[ "SETNAME", "フロール" ]},
		{"command":[ "SETTEXT", "「ふあぁ……す、凄い。こんなにたくさん、出るんですね。精液って。わたし\nの胸、それと、顔……どろどろですぅ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "123_0103138" ]},
		{"command":[ "SETNAME", "フロール" ]},
		{"command":[ "SETTEXT", "「おまけに、匂い……すぅぅ……はぁぁぁ……やっぱり、頭、痺れるような匂\nいで、癖になりそうです」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012301_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "123_0103139" ]},
		{"command":[ "SETNAME", "フロール" ]},
		{"command":[ "SETTEXT", "「これ、不思議な気分です。まるで、初めてプロレスを見た時みたいに、全身\nが痺れちゃってます」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "123_0103140" ]},
		{"command":[ "SETNAME", "フロール" ]},
		{"command":[ "SETTEXT", "「ふふふ。はまっちゃいそうで、ちょっと怖いですけど……でも、隊長さんが\n相手なら、良いですよね？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}