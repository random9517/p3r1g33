		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「……きたよー、隊長くん。私のパワーアップ……してくれるって聞いた。う\nん……興味津々」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0103101" ]},
	{"command":[ "SETCHARA", "0", "char_00004201_01", "0", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
	{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「どうすればいいの？　うん……強くなるの……面白そう。だから、何でもや\nってみたいお年頃」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0103102" ]},
	{"command":[ "SETCHARA", "0", "char_00004201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「……気持ちいいこと、する？　隊長くんの……おちんちんに？　それでパワ\nーアップできるの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0103103" ]},
	{"command":[ "SETCHARA", "0", "char_00004201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「……んー……どーだろー……やったことないから、よくわからないけどー…\n…興味……ちょっとある」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0103104" ]},
	{"command":[ "SETCHARA", "0", "char_00004201_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「よーし、じゃあ、やってみよー……おー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0103105" ]},
	{"command":[ "SETCHARA", "0", "char_00004201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「……あー……でも、私、どうすればいいかわからなーい……隊長くん、教え\nて、教えて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0103106" ]},
	{"command":[ "SETCHARA", "0", "char_00004201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「……おっぱい、出せばいいの？　んー……恥ずかしいけど……でも、隊長く\nんなら、まあ、いいかー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0103107" ]},
	{"command":[ "SETCHARA", "0", "char_00004201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「それで……おっぱいで……おちんちんを挟む？　それは……無理かもー。私\nのおっぱい、小さいし－」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0103108" ]},
	{"command":[ "SETCHARA", "0", "char_00004201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「ぎゅーって押しつければ、それでいい？　そっかー……んー……それで気持\nちいいの？　本当にー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0103109" ]},
	{"command":[ "SETCHARA", "0", "char_00004201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「じゃあ、やってみよっかー……ベッド……上がって。うん……頑張ってみる\nー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0103110" ]},
	{"command":[ "SETCHARA", "0", "char_00004201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「こう……だよね？　おっぱい……できるだけ寄せて……んー……谷間、でき\nたかなー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0103111" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004201_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「ここにおちんちん……ぎゅー……ぎゅーって……挟めた……かも？　ちょっ\nとだけ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「隊長くん、どうかなー？　……ん……ちゃんと、気持ちいい？　ポカポカし\nて温かい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「じゃあ、よかったー……ぎゅー……ぎゅー……こうして、おっぱい、押しつ\nけてるだけでいいの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「私、こうしてるだけで、おっぱいの奥……心臓、ドキドキしてきたー。おち\nんちんで感じてる？　ドキッ、ドキッて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0103115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「びっくりするくらい、大きく鳴っちゃってる……んぅ……何だか、ほっぺも\nちょっと熱くなってきたー……不思議－」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0103116" ]},
		{"command":[ "SETIMAGE", "0", "still_00004201_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「……ちょっと動いてほしい？　うん、いいよー……じーっとしてるの、何だ\nか落ち着かないしー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0103117" ]},
		{"command":[ "SETIMAGE", "0", "still_00004201_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「おっぱい、こうして寄せたまま……おちんちんの裏側、こするみたいに動け\nばいいの？　こう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「身体、揺さぶって……おっぱいの谷間で、おちんちんの裏……しこ……しこ\n……こするー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「んっ……なんだろ……ちょっと変な臭い、してきた……クンクン……イカみ\nたいな臭い……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「……甘くない臭い、好きじゃないんだけどー……でも……クンクン……隊長\nくんのおちんちんの臭いは、悪くない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「嗅いでると、胸のドキドキが早くなってきて……何だか、気持ちいい……は\nふぅ……んぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「隊長くんも、気持ちいい？　おちんちん、さっきより大きくなってきちゃっ\nたねー……おっぱいで挟むの、難しい－」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「そっかー、ちっちゃいおっぱいでも、ちゃんと気持ちよくなれるんだー……\nうん、何だか、嬉しいー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「もっと、もっと早く動いちゃうね。……しこ、しこ……しこ、しこ……おっ\nぱいで、おちんちん、撫で撫で……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「……透明のお汁、垂れてきてる……クンクン……臭い、濃くなってきた……\nはふぅ……んぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「ヌルヌルしてるから、さっきまでより動きやすくなったかもー……しこしこ\n、しこしこ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「おっぱいとおちんちんがこすれると、クチュッて、エッチな音するね。くち\nゅっ、くちゅって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「ヌルヌル、クチュクチュ……感触、面白い……うん……これ、好き……好き\nかも……クチュッ、クチュ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「んふっ、はぁ、んぅっ……私も……おっぱいの先っぽ、隊長くんのおちんち\nんとこすれると……ジンッてして、気持ちいい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0103130" ]},
		{"command":[ "SETIMAGE", "0", "still_00004201_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「もっともっと早く動く……もっと気持ちよく……はふっ、んっ、隊長くんも\n……気持ちよさそう。凄く、息、荒くなって……はんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「……出る？　おちんちんから……んっ……わからないけど、面白そうだから\n……いいよ、出して」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「いっぱい……出して……おちんちんから、出して……はふっ、んっ、出して\n……ふぁぁっ、ああ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「んんんっ、あぁ……出たぁ……凄い……噴水みたいに、ビュービューって、\n真っ白なお汁……出てる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0103134" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004201_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「んふっ、はぁんっ……おっぱい……ベトベトぉ……臭いも、凄く濃くて……\nクンクン……変な感じ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0103135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「これ……何？　……精液って言うんだ……ふーん……精液……温かくて、気\n持ちいい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0103136" ]},
		{"command":[ "SETIMAGE", "0", "still_00004201_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「いいよ、隊長くん、もっともっと出して……精液。おっぱい、もっとべとべ\nとにしていいから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0103137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「真っ白なお汁で、おっぱいヌルヌル……気持ちいい……ふふっ、楽しい、こ\nれ……凄く……んっ、はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0103138" ]},
		{"command":[ "SETIMAGE", "0", "still_00004201_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「乳首も……どんどん気持ちいいの、止まらなくなって……はぁ、くふぁ……\nんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「これ……本当に面白い……おっぱいでおちんちん、可愛がってあげるの……\n楽しいね……ふふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0103140" ]},
		{"command":[ "SETIMAGE", "0", "still_00004201_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「んー……もっとしていい？　隊長くんのおちんちん、まだカチカチで元気だ\nしー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0103201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「パンパンにふくらんでて、何だか弾けちゃいそー……大丈夫？　もっと精液\n出して、しぼませたほうがいいよねー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「うん、また、おっぱいでしこしこ、クチュクチュってして……精液、出させ\nてあげるねー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0103203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「さっきより、たーくさん出してもいいから。んー……どうやれば、もっと早\nく動けるかなぁー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0103204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「寄せたおっぱい、上に、下に、揺さぶってぇ……間で、ごしごし、思いっき\nりこするように……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「はふぅ……んぅっ、うん……精液、凄くヌルヌル、グチョグチョで……動き\nやすい……さっきより」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0103206" ]},
		{"command":[ "SETIMAGE", "0", "still_00004201_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「おちんちんに……こうして、いっぱい塗りたくって……うん……これでもっ\nと早く……動ける」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「グチュグチュ……いっぱい音、鳴らして……早く……はふっ、んぅっ……気\n持ちよく……なるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「どう？　隊長くん……おっぱいの先……乳首、おちんちんに当てるようにし\nて……んぅっ、あぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「私も、ジンジン、気持ちいい……隊長くんも、さっきより気持ちよくなって\nる？　おちんちん、凄くビクビクしてきた」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0103210" ]},
		{"command":[ "SETIMAGE", "0", "still_00004201_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「先っぽの硬いところ……ここ、出っ張ってるところに……おっぱい、ぎゅー\nって食い込ませて……弾いて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「んっ、あぁ……先っぽの穴、広がった……透明のお汁、またいっぱいあふれ\nて………はふっ……臭い、濃い……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「ちゃんと気持ちよくなってくれてるんだ……うん……隊長くんが気持ちいい\nと、私も気持ちよくなれる……みたい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「どうしてだろ……隊長くんの気持ちよさそうな声……おちんちんの反応……\n凄く……好き」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0103214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「もっと……もっと気持ちよくなって……私も気持ちよくなるから……もっと\n、もっと……はぁ、はんっ……あぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0103215" ]},
		{"command":[ "SETIMAGE", "0", "still_00004201_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「おっぱい、たくさん揺らして……おちんちん、しごく……くふぁっ、はぁ、\nしこしこ……グチュグチュ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0103216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「また精液出ちゃいそう？　おちんちん、震えてる……私のおっぱいまで、震\nえちゃうくらい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「うん、いいよ……精液、出して、また……ビューッ、ビューッて出しちゃえ\n……はふっ、はぁ……はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0103218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「隊長くんの精液の臭い……もっと嗅ぎたい……もっと、ヌルヌル……べとべ\nとになりたいから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0103219" ]},
