{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015702_01_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「さぁご主人様、お覚悟はよろしいですか？　た～っぷり搾り取って上げちゃ\nいますからね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0203101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「――え？　いきなりパイズリなんて始めて、なんのつもりか、ですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0203102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふふ♪　そんなのはもちろん、ご主人様がここに――おちんちんに隠し\nたお宝を盗みに来たんですよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0203103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「――何言ってるんですか、ご主人様の遺伝子が詰まった精液は、私にとって\nはかけがえのない『お宝』に決まってるじゃないですか♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0203104" ]},
		{"command":[ "SETIMAGE", "0", "still_00015702_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「今の私はメイドであると同時にいたずら好きなドロボウ猫ですからね。お宝\nをどこに隠そうと、ぜーんぶ盗み出してあげちゃいます♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0203105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ほらほら、無駄なおしゃべりはおしまいです。ご主人様のビンビンおちんち\nん、私のおっぱいでぎゅーっ、ってして上げちゃいます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0203106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んっ……んふっ……ぷっくり膨らんだ括れの部分がヒクヒクしてる……んん\nっ……ご主人様のおちんちん、かわいーですねぇー♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0203107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んんっ……どうですか、このパーツを装着した私のおっぱいの感触は？　ご\n主人様好みの柔らかさをしてるでしょ？　にゃふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0203108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「機能性ももちろんですが、その辺りの好みも考えてこのパーツに換装したん\nですよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0203109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「よりご主人様好みになれるように……んっ……いっぱい、気持ち良いいたず\nらをして差し上げれるように……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0203110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふふ♪　腰が引けてますよーご主人様、括れの部分をぎゅっぎゅってさ\nれちゃうの、そんなに気持ちいいですかー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0203111" ]},
		{"command":[ "SETIMAGE", "0", "still_00015702_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ほーら、おっぱいをぎゅーーって、押し付けて……んんっ……谷間ですりす\nり、タプタプ、すりすり、タプタプ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0203112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「おちんちんこんなにピクピク震えさせちゃって……にゃふふ、これなら『お\n宝』を見つけるのも早そうですねー♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0203113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「でもでも、わたしの『いたずら』はまだまだ始まったばかりですよ、ご主人\n様？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0203114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んんっ……こうやって、おっぱいで……私のおっぱいおまんこの中でオチン\nチンを左右にぐりぐり……ぐりぐり……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0203115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ぎゅーって力を入れて、離して、入れて、離して……んんっ……根元から搾\nり上げる様にぎゅっ、ぎゅっ、おっぱいおまんこでおちんちんシコシコ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0203116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「にゃは、おちんちんの先っぽからエッチなガマン汁が溢れてきちゃいました\nねーご主人様♪　お宝発見が近いのかなー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0203117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「え？　さっきから私の言葉遣いが気になる、ですか？　――にゃふふ、今日\nの私はいたずらドロボウ猫ですからね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0203118" ]},
		{"command":[ "SETIMAGE", "0", "still_00015702_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「えっちないたずら大好きな、あなただけのドロボウ猫。えっちな言葉もいっ\nぱいインプットしてきちゃいました♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0203119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「だから、ほら……んんっ……ご主人様はされるがままに、私にいたずらされ\nてればいいんですよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0203120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「こうやって……んっ……溢れたガマン汁をおっぱいおまんこの中でぐちゅぐ\nちゅって擦り合わせて、おちんちんにゅるにゅるって扱いて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0203121" ]},
		{"command":[ "SETIMAGE", "0", "still_00015702_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んふっ、あっ、んんっ……にゃふふ、おちんちんまたビクンッてなって大き\nくなりましたね～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0203122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「これってどこまで大きくなっちゃうんですかね？　人間の身体ってほんとー\nに不思議ですね～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0203123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「さぁ、ご主人様が隠したお宝はどっこかな～♪　あと少しで発見できる気が\nするんですよね～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0203124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「オチンチンの根元からにゅるにゅる、すりすりぃ～♪　裏筋の所をゆっくり\n、ぎゅ～、って押し上げていってっと……んにゃん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0203125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふふ、お宝に向かう最後の扉の鍵を見つけちゃいました♪　なるほどな\nるほど、ご主人様は下から上まで、じーっくりすりあげられるのがお好きと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0203126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ほらほらぁ～、諦めて私にお宝を渡しちゃいましょうよーご主人様♪　我慢\nは身体に毒ですよ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0203127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「にゅるにゅる、すりすりぃ、ぎゅ～～♪　にゃふふ、ほんと、すごいガマン\n汁の量……おっぱいおまんこの中熱すぎて、熱暴走を起こしちゃいそうかも」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0203128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んふっ、んんっ……すりすり、シコシコ……んっ……おちんちん、ドクドク\nって……ご主人様の鼓動……んふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0203129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふふっ、ご主人様の声もかわいーです♪　分かってますよー、もう我慢\nの限界なんですよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0203130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ラストスパートですっ！　おちんちんにいーっぱいいたずらしてあげますか\nら、ご主人様のお宝をびゅっびゅって出しちゃってくださいな♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0203131" ]},
		{"command":[ "SETIMAGE", "0", "still_00015702_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ぎゅ～、っておちんちんに体重をかけてぇ～♪　おっぱいたぷたぷ、にゅる\nにゅるおっぱいおまんこでシコシコ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0203132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「こうですよね？　さっきインプットしたから完璧ですよ♪　根元から搾り取\nる様にぎゅ～♪　括れの部分をいじめるようにぎゅ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0203133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふふ、ご主人様、降参の時間ですよ♪　にゅるにゅるのおっぱいおまん\nこでいたずらされて、精液をびゅーびゅー吐き出しちゃってください！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0203134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んにゃん……！　にゃふふ、ご主人様が隠したお宝みーっけ♪　頑張って隠\nしてた精液が、おっぱいおまんこの中にびゅーびゅー出ちゃってますよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0203135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015702_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「――ご主人様？　なんだか気の抜けたような顔をしてますけど、本番はここ\nから、ですよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0203136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふふ、私は『いたずらドロボウ猫』ですよ？　一回お宝を搾り取ったぐ\nらいで終わるはずないじゃないですか～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0203137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「敏感になってるのはわかってます。だからこそ、こうやって……んんっ……\n精液をぐちょぐちょってかき混ぜて、オチンチンを圧迫してあげれば――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0203138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「にゃは♪　ほーら、次のお宝はここにあるよー、ってオチンチンが教えてく\nれてますね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0203139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「言ったでしょ、ご主人様。お宝はぜ～んぶ盗み出してあげちゃいますって♪\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0203140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んんっ、んふっ……やっぱり二回目は動きやすいですねー。おっぱいおまん\nこがさっきの精液でぐちゅぐちゅになってて……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0203201" ]},
		{"command":[ "SETIMAGE", "0", "still_00015702_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ご主人様も聞こえてますよね、このえっちな音。オチンチンもずーっとビク\nビクしてて……にゃふふ、これはいたずらのし甲斐がありますねぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0203202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んにゃんっ！？　ど、どうしたんですか突然、頭を撫でたりなんてしてきて\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0203203" ]},
		{"command":[ "SETIMAGE", "0", "still_00015702_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「え？　やられっぱなしは性に合わない？　私がいたずらをするなら俺もいた\nずらをし返す？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0203204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ご主人様のそーゆーところ、ほんっとに子供っぽいですよねぇ――いえ、嫌\nじゃありませんよ、頭なでなでされるのは大好きですから♪　んにゃん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0203205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふふ、私だって負けませんよ♪　さっきインプットしたご主人様の弱点\n、またじーっくりいたずらしてあげちゃいますからね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0203206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「おっぱいをたぷたぷして、すりすり、ぎゅっぎゅっ……んふっ、んぁ、んん\nっ……血管がこんなにも浮き上がっちゃってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0203207" ]},
		{"command":[ "SETIMAGE", "0", "still_00015702_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「痛くはない、ですよね？　――にゃふふ、今度は素直ですねーご主人様。い\nいですよ、お望み通り満足するまでいたずらを続けてあげちゃいます♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0203208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「オチンチンを根元から押さえて……んふっ……先端までじっくり搾り上げる\nように……んんっ、んふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0203209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「今度は括れの部分もです。おっぱいオマンコの中でぐちゅぐちゅに掻き回し\nて、擦り合わせて、っと……んっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0203210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふふ♪　さっきからえらく真剣に私の耳をなでなでしてますねー♪　こ\nのパーツそんなに気に入って頂けましたか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0203211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「――にゃふふ、私もです。メイドとしてご奉仕するのも好きですけど、こう\nやってご主人様にいたずらするのも悪くないなって思います♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0203212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「にゃは、またお宝の気配が近づいてきましたね～♪　おっぱいおまんこのな\nかで、オチンチンがピクピク跳ね回っちゃってます♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0203213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「両側からおっぱいをぎゅ～、って押さえつけて……んんっ……にゅるにゅる\n、シコシコ……括れにいたずら、ぎゅ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0203214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「見てくださいご主人様、私の乳首も、気が付いたら勃起しちゃってますよ？\n　――にゃは♪　オチンチンビクンッてした♪　いい反応ですねー♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0203215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「もちろん恥ずかしくはありますけど……それでお宝に近づけるなら、私は自\n分の全てを使ってご主人様にいたずらしちゃいます♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0203216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「おっぱいおまんこで、オチンチンをすりすり、すりすり～♪　ご主人様の身\n体の事ですもの、ぜーんぶお見通しですよ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0203217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「もうイッちゃいそうなんですよね？　残りのお宝もぜ～んぶぶちまけちゃい\nたいんですよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0203218" ]},
		{"command":[ "SETIMAGE", "0", "still_00015702_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「――もちろんですよ、ご主人様。おっぱいおまんこで搾り取ってあげちゃい\nますから、ご主人様のお宝を大放出させちゃってください！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0203219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「にゃは、オチンチンの先っぽが可愛くピクピクってしてる♪　ほら、出して\nくださいっ！　必死に溜めた精液をた～っぷりぶちまけてください！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0203220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んにゃんんっ！　おっぱいおまんこの中にドクドクって膣内出しされちゃっ\nてます♪　ご主人様のお宝、こんなにいっぱい、んにゃうっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0203301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015702_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「おー、二回目だと言うのにすごい勢い！　むしろ一回目より多いかな？　こ\nんなにお宝を隠し持って、わるーいオチンチンさんですね～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0203302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ほーら、今度はぜ～んぶ出し切ってくださいねー♪　玉の中がすっからかん\nになるまで搾り取ってあげますからね～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0203303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「――射精中におっぱいを動かすのはやめてほしい、ですか？　にゃふふ、も\nちろん、そんなお願い却下です♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0203304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「もう一度言いますけど私は『いたずら好きのドロボウ猫』。ご主人様へのい\nたずらがだーい好きなんですから♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0203305" ]},
		{"command":[ "SETIMAGE", "0", "still_00015702_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ほーら、おっぱいふよふよ、パフパフ、ぎゅ～♪　ぐちょぐちょのおっぱい\nおまんこの中で、おちんちんを振り回しちゃいます♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0203306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「お宝を残すことは許しません、オチンチンぴくぴくさせて、おっぱいおまん\nこに全部出しきってください！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0203307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「分かってるんですよ、まだまだ出せるって事は♪　んにゃん♪　にゃふふ、\n射精が全然止まりそうにありませんねー♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0203308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「このまままた括れを圧迫しますか？　それとも根元から搾り取る様におっぱ\nいを押し上げますか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0203309" ]},
		{"command":[ "SETIMAGE", "0", "still_00015702_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふふ、ご主人様へのいたずらはまだまだこれから♪　お宝が尽き果てる\nまでいくらでも探し出して、盗んで上げちゃいますね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0203310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んにゃんんっ！　せ、精液が顔に……んんっ！　にゃふふ、おっぱいおまん\nこだけじゃ受け止めきれませんでしたね～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0203401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015702_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ご主人様ってば、おちんちんの中にお宝を隠し持ちすぎですよ～。にゃふふ\n、尿道口がひくひくしてる、かわいい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0203402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「それにしても、これ……んんっ……精液が掛かった顔の部分が熱くなって…\n…んにゃうぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0203403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「排熱機構をフル稼働しないと、これほんとに熱暴走起こしちゃいそう……で\nも、それもそれでいいかも……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0203404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「え？　せっかくのパーツを汚しちゃってごめん、ですか？　……にゃふふ、\nご主人様のそーゆー思いやりがあるところ、私大好きですよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0203405" ]},
		{"command":[ "SETIMAGE", "0", "still_00015702_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「そもそも、私がいたずらを仕掛けたんですから、ご主人様は気にしなくてい\nーんですよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0203406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「それに……せっかくの新しいパーツですもの、むしろご主人様に汚して頂い\nて嬉しかったり……なーんて、にゃふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0203407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ねぇご主人様？　射精の勢いは治まってきましたけど……おちんちん、まだ\nまだ固いままですよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0203408" ]},
		{"command":[ "SETIMAGE", "0", "still_00015702_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「――にゃふふ、もちろんですよ。ご主人様が望み、そしてお宝を隠している\nというなら、三回でも四回でも♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0203409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ご主人様から全てを搾り取るまで、えっちないたずら、い～っぱい続けちゃ\nいますからね♪　にゃふふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0203410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}