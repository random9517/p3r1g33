{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0116" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_019" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「……悪ぃ。今、なんつった？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020110130001" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「こんばんは。犬一匹ですが、よろしいですかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010110130001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「常識で考えろ。よろしいわけねえだろ。飼い主っつーか、上司はどうしたん\nだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020110130002" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「……それを言ってくださるな。可愛いだけが取り柄の私ですが、時には一人\nで酔いたい夜もあるのですぞ。お金のことでしたら、これこの通り」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010110130002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「どっから持ってきたんだよ。……んじゃまあ、いいよ、飲んでけよ。とりあ\nえずこれ、お通しな。玉ねぎとニラの炒めもの──あ、いや、犬にはダメなん\nだっけ、これ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020110130003" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「お気遣い感謝いたしますぞ。お通しはパスしまして、お酒を一杯いただけま\nすかな？　冷やで結構」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010110130003" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「……まさか犬に酒を注ぐ日がくるとはなあ。まあ、いいけどよ。はいよ、お\n客さん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020110130004" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「おっとっとっと、受け皿にこんなにこぼしていただいて、かたじけないです\nなぁ。では……ピチャピチャ…………ふぅ、沁みますなぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010110130004" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「さすがにコップ持って一気には飲めねえのか。ボウルかなんかあった方がい\nいか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020110130005" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「いえ、結構。こうしてチビチビと舐めるように飲むのが良いのです……時間\nを掛けて酔えますからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010110130005" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「……しっかし、お前が一人……じゃねえや一匹で飲みに来るとはなぁ？　な\nんか訳アリか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020110130006" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「……まあ、なんというか仕事で、人をだまさねばならなかったのです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010110130006" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「……ああ、隊長のことか。話は聞いてるよ。いったい、どういうことだった\nんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020110130007" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「……冴島長官直々に言い渡されてしまったので、断ることもできませんでし\nた。半ば脅迫でしたな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010110130007" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「なんて言われたんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020110130008" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「『言うことを聞かないと、向こう一か月、食事をお徳用のドライフードのみ\nにする』と言われまして、やむを得ず……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010110130008" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「あの長官らしいっつーか、セコい脅迫だなあ……で、引き受けたってわけか\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020110130009" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「はい。主人を騙し、憎まれ役を演じる……つらい仕事ですが、なんとか上手\nくいきました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010110130009" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「……まあ、もう二度と御免ですがね……ぴちゃ、ぴちゃぴちゃ……ふぅ……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010110130010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「上手くいったんならいいじゃねえか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020110130010" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ええ、まあ、ぼちぼち。それなりに成果はありましたかねぇ……あったと信\nじたいですなぁ……ぴちゃぴちゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010110130011" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「でもよ、おまえ自身は、その成果とやらでそこそこ満足したんだろ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020110130011" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「おや。なぜそのようなことを？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010110130012" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「さっきより少し、いい顔になってるからよ。鼻の頭がつやつやしてんぜ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020110130012" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「……おやおや、からかわないで下さい。ほむら殿、お代わりを置いておいて\n下さいますかな。少し一人で飲みたい気分でしてな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010110130013" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「はいよ。んじゃ、注文あったらそこのボタン押してくださいよ。お客さん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020110130013" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「はいはい。それでは後ほど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010110130014" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「……それにしても……あのご主人が、まさか本気で悲しみ、本気で怒ってく\nださるとは……ぺろ、ぴちゃぴちゃ……ぴちゃん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010110130015" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「わたくしもうちょっと、ご主人を信じてあげてもいいのかもしれませんなぁ\n……ぺろぺろ、ぴちゃぴちゃ──」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010110130016" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「あ！　ほむら殿！　レバーとナンコツを塩でお願いしますぞー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010110130017" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}