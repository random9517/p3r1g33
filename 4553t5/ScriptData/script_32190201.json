		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "鳥人・チキン乙女" ]},
		{"command":[ "SETTEXT", "「まずは胸でご奉仕……？　キミって本当に胸が好きだね……べつにいいけど\n。いつもいつもやってて飽きないのかなって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0203101" ]},
		{"command":[ "SETIMAGE", "0", "still_00021902_01_01" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳥人・チキン乙女" ]},
		{"command":[ "SETTEXT", "「……そ、そう？　私の胸……そんなに気持ちいいんだ……。じゃあ、うん…\n…そこまで言うなら、今日もやってあげるね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0203102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳥人・チキン乙女" ]},
		{"command":[ "SETTEXT", "「よいしょ……っと……んっ、今日も元気だね、キミのこれ……んんっ……待\nってて、今、すぐ挟んであげるから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0203103" ]},
		{"command":[ "SETIMAGE", "0", "still_00021902_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳥人・チキン乙女" ]},
		{"command":[ "SETTEXT", "「あんっ、んぅ……熱い……ホント熱い……ここだけ、こんなに熱くなるなん\nて、本当に男の人って不思議だね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0203104" ]},
		{"command":[ "SETIMAGE", "0", "still_00021902_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳥人・チキン乙女" ]},
		{"command":[ "SETTEXT", "「それに硬くて……ゴツゴツしてて……すごい……胸の間でヒクヒク動いてる\nし……生きてるみたい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0203105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳥人・チキン乙女" ]},
		{"command":[ "SETTEXT", "「慣れてきた、っていうと変な感じだけど……キミが感じることは、なんとな\nくわかってきたよ……ほら、こうやって……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0203106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳥人・チキン乙女" ]},
		{"command":[ "SETTEXT", "「胸で左右から強く挟むの、好きでしょ？　それから……グイグイって、上下\nさせて……はっ、んっ……ンっ、ふうっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0203107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳥人・チキン乙女" ]},
		{"command":[ "SETTEXT", "「んうっ！　ほらぁ……腰が動いてる……んっ、腰だけじゃなくて……これも\n、胸の中で……え？　なにって……これ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0203108" ]},
		{"command":[ "SETIMAGE", "0", "still_00021902_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳥人・チキン乙女" ]},
		{"command":[ "SETTEXT", "「えー、わざわざ言わせるの……？　チ、チンポ……キミのチンポ……もうっ\n、いちいち言わなくてもわかるよね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0203109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳥人・チキン乙女" ]},
		{"command":[ "SETTEXT", "「この方が興奮するの？　はぁ……変態っていうか、物好きだね……いいけど\n……はっんっ……ふうっ……はっ、あんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0203110" ]},
		{"command":[ "SETIMAGE", "0", "still_00021902_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳥人・チキン乙女" ]},
		{"command":[ "SETTEXT", "「チンポ……デカ、チン……？　そう言った方がいい……？　うん……なんと\nなく意味はわかるよ。キミの大きいもん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0203111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳥人・チキン乙女" ]},
		{"command":[ "SETTEXT", "「だから、チンポ……キミのチンポがデカい、ってこと……でしょ？　うん、\nイヤらしい……言い方、だと思う……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0203112" ]},
		{"command":[ "SETIMAGE", "0", "still_00021902_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳥人・チキン乙女" ]},
		{"command":[ "SETTEXT", "「ふっ、うぅんっ……でも、その方がいいんでしょう？　じゃあ、そう……す\nる、から……んっ、んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0203113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳥人・チキン乙女" ]},
		{"command":[ "SETTEXT", "「キミのデカチンを、私の胸で、挟んで……はっ……んっ……擦って、気持ち\nよく、してあげる……ね……あ、んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0203114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳥人・チキン乙女" ]},
		{"command":[ "SETTEXT", "「なんか、また大きくなった？　興奮してるから……？　そう、なんだ……悦\nんでくれてるなら、よかった……続ける、ね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0203115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳥人・チキン乙女" ]},
		{"command":[ "SETTEXT", "「あ、あんっ……ふうっ……擦ると、余計に熱くなる……あっあふっ……うん\n、熱いから……胸が汗ばんできた……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0203116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳥人・チキン乙女" ]},
		{"command":[ "SETTEXT", "「確かに、滑りやすくなってる、かも……んっ……あふぅ……もっと早く、動\nかした方がいい？　んっ……わかった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0203117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳥人・チキン乙女" ]},
		{"command":[ "SETTEXT", "「でも……これ、私の汗だけじゃないよ……キミの、デカチン……んんっ……\n先っぽから、我慢汁、出てるよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0203118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳥人・チキン乙女" ]},
		{"command":[ "SETTEXT", "「はぁあ、うっ……わかるよ……だって、さっきから……どんどん溢れてきて\nるし……んっ……ふぅ……気持ちいいって、ことだよね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0203119" ]},
		{"command":[ "SETIMAGE", "0", "still_00021902_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳥人・チキン乙女" ]},
		{"command":[ "SETTEXT", "「ふふ……嬉しい……もっとよくしてあげるから……んっ……はぁあぁ……は\nっ、あふっ……んっんんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0203120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳥人・チキン乙女" ]},
		{"command":[ "SETTEXT", "「胸がヌルヌルしてて……すべっちゃう……はうっ……あんっ……硬い、デカ\nチン……擦れて……はっ、ううっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0203121" ]},
		{"command":[ "SETIMAGE", "0", "still_00021902_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳥人・チキン乙女" ]},
		{"command":[ "SETTEXT", "「谷間から、キミのデカチンの先っぽが……ぬっぷ、ぬっぷって、顔出してて\n……なんか……えっち、だね……んうっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0203122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳥人・チキン乙女" ]},
		{"command":[ "SETTEXT", "「ふぅっ……は、あっ、あんっ……私の、胸の方が……えっち、なの？　自分\nでは、そう思わない、けど……キミがそう言うなら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0203123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳥人・チキン乙女" ]},
		{"command":[ "SETTEXT", "「はぁ、はあっ……んっ……私の、胸……気に入って、くれて……嬉しい……\nんっ、べつに緊張はしてないよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0203124" ]},
		{"command":[ "SETIMAGE", "0", "still_00021902_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳥人・チキン乙女" ]},
		{"command":[ "SETTEXT", "「ただ、こういうとこ……あまり来たことがなかったから……ちょっと普段と\n、雰囲気違うなって……思った、けど……あんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0203125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳥人・チキン乙女" ]},
		{"command":[ "SETTEXT", "「キミは慣れてる、みたいだけどね……んんっ……！　さっきから、我慢汁ど\nんどん溢れてきて……もう射精しそうなの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0203126" ]},
		{"command":[ "SETIMAGE", "0", "still_00021902_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳥人・チキン乙女" ]},
		{"command":[ "SETTEXT", "「やっぱりそうなんだ……んっ……いいよ、私のおっぱいに出して……ふぅ、\nふっ、ふうっ……ンうっ……胸、で……擦って、あげるから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0203127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳥人・チキン乙女" ]},
		{"command":[ "SETTEXT", "「うん……キミのしたいように、してあげるから……おっぱい、なか、出し…\n…？　谷間で……受け止める……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0203128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳥人・チキン乙女" ]},
		{"command":[ "SETTEXT", "「はっ、はぁっ……！　あっ、ふっ……出して……！　んんっ……おっぱいご\n奉仕……パイズリ、で……射精して……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0203129" ]},
		{"command":[ "SETIMAGE", "0", "still_00021902_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳥人・チキン乙女" ]},
		{"command":[ "SETTEXT", "「んぅっ！　はっ……ふぅうっ……！　イヤらしい、音……してるっ……おっ\nぱいが熱ぃ……あぁ、んっ……あんっ、んっ、んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0203130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳥人・チキン乙女" ]},
		{"command":[ "SETTEXT", "「出る？　もう出る？　いいよ……きて……！　出して……！　はっ、あっ…\n…あっ、んっ！　んっ！？　んんぅぅぅぅぅっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0203131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳥人・チキン乙女" ]},
		{"command":[ "SETTEXT", "「はっ、くふぅっ……！　ンンっ……！　あっ……あっぁぁ……でて、るっ…\n…おっぱいの中で、ドクドクいってるっ……！」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021902_01_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0203132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳥人・チキン乙女" ]},
		{"command":[ "SETTEXT", "「もう少しですか？　んんぅっ……わかっています……しっかり胸で受け止め\nますから……あっ、あふうっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0203133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳥人・チキン乙女" ]},
		{"command":[ "SETTEXT", "「出して……気持ちよくなってぇ……！　ああっ……はぁんっ！　いいよ……\nいっぱい、いっぱい……出してぇっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0203134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳥人・チキン乙女" ]},
		{"command":[ "SETTEXT", "「はっ、あはっ……んっ……はぁぁっ……で、て……熱いの……出てるぅ……\nはぁはぁ……あん……まだ、出てるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0203135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021902_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳥人・チキン乙女" ]},
		{"command":[ "SETTEXT", "「なんだか、いつもより……多くない……？　気のせい、かな……？　やっぱ\nり、そうだよね……ンンっ……ふぅう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0203136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳥人・チキン乙女" ]},
		{"command":[ "SETTEXT", "「うん、ありがとう……そう言ってもらえて……私も、嬉しい……ご奉仕、し\nたかいがあった……けど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0203137" ]},
		{"command":[ "SETIMAGE", "0", "still_00021902_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳥人・チキン乙女" ]},
		{"command":[ "SETTEXT", "「まだ、大きくなったままだね……キミのデカチン……このまま続ける？　そ\nれとも、えっち……する……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0203138" ]},
		{"command":[ "SETIMAGE", "0", "still_00021902_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳥人・チキン乙女" ]},
		{"command":[ "SETTEXT", "「もう一回おっぱいがいいの？　うん、わかった……じゃあ……はふっ……キ\nミの、精液でヌルヌルになったおっぱいで……ご奉仕……するね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0203139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳥人・チキン乙女" ]},
		{"command":[ "SETTEXT", "「一生懸命、動かす……から……キミもいっぱい気持ちよくなって……ね……\nんっ……んっはあっ……はっ、あっ……あんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0203140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳥人・チキン乙女" ]},
		{"command":[ "SETTEXT", "「出したばかりなのに……勃起しっぱなし……何回でも、射精できちゃいそう\n、だね……たくましい、って言えばいいのかな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0203201" ]},
		{"command":[ "SETIMAGE", "0", "still_00021902_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳥人・チキン乙女" ]},
		{"command":[ "SETTEXT", "「んっ……硬くなったままで、熱くって……すごいね……こっちまで、胸が火\n照ってくる……あ、ふうっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0203202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳥人・チキン乙女" ]},
		{"command":[ "SETTEXT", "「精液、まみれで……肌、滑って……んっ……ぐちゅ、ぐちゅって……いって\nる……はぁ、あぁぁ……んっ……どう、気持ちいい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0203203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳥人・チキン乙女" ]},
		{"command":[ "SETTEXT", "「さっきより、いいの？　うん……精液のおかげで、すごく滑るから……はっ\n、ふうっ……もっとよくしてあげるね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0203204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳥人・チキン乙女" ]},
		{"command":[ "SETTEXT", "「もっと、強くおっぱいで扱いてあげるね……ほら、こんな感じで……んっ…\n…精液、塗り込んで……むにむにって……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0203205" ]},
		{"command":[ "SETIMAGE", "0", "still_00021902_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳥人・チキン乙女" ]},
		{"command":[ "SETTEXT", "「はっ、はっ……んっ……はっ、ああっ……息、荒い……？　だって、ずっと\nおっぱい……揺らしてる、から……あふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0203206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳥人・チキン乙女" ]},
		{"command":[ "SETTEXT", "「うん……興奮も、してるよ……おっぱいで、キミのチンポ挟んで、擦ってる\nと……胸、ドキドキするし……はっ、うぅん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0203207" ]},
		{"command":[ "SETIMAGE", "0", "still_00021902_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳥人・チキン乙女" ]},
		{"command":[ "SETTEXT", "「あ、あんっ……それに、匂いも……精液の、生ぐさい匂いが……して……こ\nの匂いかぐと、余計に興奮しちゃう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0203208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳥人・チキン乙女" ]},
		{"command":[ "SETTEXT", "「はあ、あふぅっ……だって、すごくえっちな、匂い……だから……んっンっ\n……あぁ、あん……うん、もっとかぎたい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0203209" ]},
		{"command":[ "SETIMAGE", "0", "still_00021902_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳥人・チキン乙女" ]},
		{"command":[ "SETTEXT", "「キミのチンポの匂い……好き……んっ、もっと、おっぱいでご奉仕するから\n……またいっぱい出して……んっ、はっ、はっんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0203210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳥人・チキン乙女" ]},
		{"command":[ "SETTEXT", "「うん……わかってる……胸、揺らして……キミの視線、を……楽しませなが\nら……チンポにご奉仕、でしょ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0203211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳥人・チキン乙女" ]},
		{"command":[ "SETTEXT", "「キミが悦ぶ、こと……ちゃんと知ってるよ……もう、何回も、んっ……胸で\n、ご奉仕してるから……ほら……あっ、あふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0203212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳥人・チキン乙女" ]},
		{"command":[ "SETTEXT", "「もっと、リズムよく……谷間に……押しつけながら……おっぱい、揺らして\n……んっ、んんぅっ……はぁあっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0203213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳥人・チキン乙女" ]},
		{"command":[ "SETTEXT", "「また、チンポが震えてる……嬉しそうに、ヒクヒク動いてる、よ……また出\nそうになってるんじゃない？」", "NORMAL" ]},
