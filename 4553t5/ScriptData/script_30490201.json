{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「……休暇中に呼び出すとは何事だ？　せっかくいい気分で晩酌していたとこ\nろを……。当然重要かつ緊急の用件なのだろうな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0203101" ]},
	{"command":[ "SETCHARA", "0", "char_00004902_01", "1", "CENTER", "0" ]},
	{"command":[ "DISPTEXT", "TRUE" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「……何？　いい年をして独り身一人寝の私が可哀想だったから呼んでやった\n？　……帰る。不愉快だ！　どいつもこいつも私を侮辱して……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0203102" ]},
	{"command":[ "SETCHARA", "0", "char_00004902_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「ん？　冗談？　どういうことだ。……『私に会いたかったから』？　それに\nいい話がある？　……ふぅむ……？　一応、聞いておくか。言ってみろ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0203103" ]},
	{"command":[ "SETCHARA", "0", "char_00004902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「な、何！？　ここで隊長に性的な奉仕をすることで能力が上がる？　は、は\nは……なんという眉唾な。それに、私の能力は高い。これ以上必要ない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0203104" ]},
	{"command":[ "SETCHARA", "0", "char_00004902_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「……ただ……その、なんだ……。パワーアップだのなんだのという御託は置\nいておいて……。私に会いたかった、という部分は……嬉しかった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0203105" ]},
	{"command":[ "SETCHARA", "0", "char_00004902_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「だから……ただ、隊長が私とそういう……男女の……。うん。濃密な時間を\n過ごしたいというのならば……か、考えんことも……ない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0203106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「どうせ寂しい独身年増女だ。その、キ、キスだとか抱き合ったりだとか……\nと、なんだと？　しゃ、しゃぶれ、だと！？　お、お、お、お前ぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0203107" ]},
	{"command":[ "SETCHARA", "0", "char_00004902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「いや！　別にそれでも構わんが！　構わんが！　くそっ……情を出した私が\n馬鹿だった。すまんが、一杯飲ませてもらうぞ。ごくごくごく……ぷはぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0203108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「うぃー……ヒック……。そら。とっととペニスを出せ。こぉおおーんな酒臭\nい女でいいなら相手をしてやるぞ。……何をしている。早く出せ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0203109" ]},
	{"command":[ "SETCHARA", "0", "char_00004902_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「んぅ！？　ず、図体ばかり……態度とチンポばかりでかくなりおって……。\nこ、これを……しゃぶればいいのだな。ふん、造作もない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0203110" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00004902_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「が、……その……大きくしすぎではないか？　よ、よくもまあ、こんなジャ\nージ姿の酔っ払い女に劣情を抱けるものだな……？　ん……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0203111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「ぷはぁああ……♪　ど、どうだ？　酒臭いだろ、それに……れろ……んッ…\n…。アルコールで濡れた舌で舐められるのはどうだ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0203112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「ぺろ……れろっ、れろ……れろ……。尿道から酔ってくるだろう……？　ん\n……ねろっ……れろっ、にちゅ……ちゅぱっ、ちゅ、れろ……れる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0203113" ]},
		{"command":[ "SETIMAGE", "0", "still_00004902_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「下品な年増女に大切なチンポをしゃぶられていいのか？　んん？　ほら……\n酒の臭いが移ってしまうぞ？　ぴちゃっ……ぺちゃっ、れろ、ねろ、れろ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0203114" ]},
		{"command":[ "SETIMAGE", "0", "still_00004902_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「れろ……れろ、れろれろ……。ン……。なんだ、素直に感じているのか……\n。鈴口から汁が垂れてきた……。ふむ……こうなっては仕方ない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0203115" ]},
		{"command":[ "SETIMAGE", "0", "still_00004902_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「べ、別に私がしたくてするのではないが。不憫な隊長のために、人肌脱いで\nやるとしよう……。咥えるぞ、いいな？　……はぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0203116" ]},
		{"command":[ "SETIMAGE", "0", "still_00004902_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「ぐちゅっ！　ぐっぷっぐぷっ、ぐちゅっぬちゅっ……ぬっぷっぬぷっ、ぬち\nゅ……！　ぢゅる……ぢゅるるるっ！　ぐちゅっ！　ぐっちゅっぐちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0203117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「ン……ん、ん、ン……！　ぬちゅっ、ぷちゅ、ぐちゅ……ぢゅるるっ、ぢゅ\nるっ！　じゅぷっ、じゅぷ、ずちゅっ！　ぬりゅっ、ぬりゅぷちゅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0203118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「ど……どうら……？　わ、わらひの口マンコは……。年期の入った年増フェ\nラもたまにはよかりょぉ……。べろっ！　べろっ、れろ、れる……ぢゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0203119" ]},
		{"command":[ "SETIMAGE", "0", "still_00004902_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「ぢゅるるっ、ぢゅるっ、じゅる……じゅるっ、ぢゅるるる……！　がぽっ！\n　ぐぽっ！　ぐっぽっぐぽっ！　ぶちゅっ、ぶっちゅっぶっちゅっぐちゅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0203120" ]},
		{"command":[ "SETIMAGE", "0", "still_00004902_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「ン、ん、ん、ん、お……♪　んぷぅ……ぐちゅっ！　ぐっちゅっぬちゅ……\nはは……顎が外りぇそうなほど昂って……愚かもにょが……ぢゅるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0203121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「そりゃ、しょっぱいが……こんなもの、酒のつまみにはならん……。だ、が\n……んぅ……。口寂しい時には、いいのかもな……コレも……んん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0203122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「せっかくしてやるんだ。お前も集中して私の舌の動きを堪能していろ……。\nずぞっ……！　れろれろれろ……レロレロレロ……ぺちゃっ、ぴちゃっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0203123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「んんむ……んむぅ……！　くぷっ、ぐぷっ！　ぷちゅっぱちゅっぐちゅっぐ\nちゅっ……！　ぢゅるる……ぢゅる、ぢゅるるる……んん？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0203124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「しっかり感じているじゃないか……腰が浮いてきたぞ。れろ……。こら……\n股間を顔に押し付け、るな……ちゅぷっ！　にゅぷっぬぷっぬっぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0203125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「んんん……れろぉ……！　ぢゅっぷっぢゅぷっぢゅぷっ、ンっんっんっ……\n！　ずるるるっ……ぢゅるるるっ！　じゅっ……ぢゅるるるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0203126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「ンぅ……イ、イキたくなったらすぐにイ、け……。わたひも暇じゃないんら\n……。口も疲れてくる、ひ……早く、出せ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0203127" ]},
		{"command":[ "SETIMAGE", "0", "still_00004902_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「ん？　どこに出せばいいからとぉ……？　ど、どこでもいい……お前の好き\nなところに出せばいいだろう。」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0203128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「妙な遠慮をするな……はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0203129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「おまへは……ぢゅるっ、自分勝手に射精すればいい……。ほら、スパートを\nかけるぞ……。ぐちゅっ！　ぐっちゅっぐちゅっぬちゅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0203130" ]},
		{"command":[ "SETIMAGE", "0", "still_00004902_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「レロレロレロ……れるっぢゅぱっ！　ぐちゅっ、じゅっぷっじゅっぷっじゅ\nぷっ！　んん？　出そうなのか？　精子あがってきたか？　んん？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0203131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「出せ、出せぇ……。くっさい精液わたひに差し出せぇ……！　れろぉ……ね\nろぉ……！　にゅるっ、にゅぷぷぷ……ぐちゅっぐっちゅっぐぷっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0203132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「そら、そらそらぁ……！　んんっ！　にゅぷ、ぬぷ、ぷちゅ、ぢゅぷ、ぢゅ\nぷっぢゅぷっぢゅぷっぢゅぷぷ……ぢゅーっぢゅーっ、んん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0203133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「んっぐっ、むぐぅううっ……！　んぐぅううう！　で、出たぁ……んぷぁっ\n……！　口っ、わたひのくひの中、にぃ……んんんむぅう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0203134" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00004902_01_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「おえっ……なんという悪臭だ……。それに……。ぷぁああ……♪　この粘り\n気、ドロドロの……固形物の混ざった濃い精液ぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0203135" ]},
		{"command":[ "SETIMAGE", "0", "still_00004902_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「ふふ……口の中が粘ついて仕方ないが、そうだな……こういう成功体験は悪\nくない……。ん、よく見ていろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0203136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「お前の精液を私が飲み干してやる……。っごく……ごきゅ……ん……。ぷぁ\n……ど、どうだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0203137" ]},
		{"command":[ "SETIMAGE", "0", "still_00004902_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「スッキリしたらさっさと寝ることだ。……と、まだ尿道に精液が残っている\nようだな。これも吸い出しておくか……。ん、ちゅ……ぢゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0203138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「ごきゅ……ごくんっ……。んぅ……。残り汁まで自己主張が激しすぎる……\n。この味、この臭い……一日やそこらでは取れないぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0203139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「だが、まあ……嫌いでは……ない。……ま、また困ったことがあれば私を呼\nび出せばいいだろう。行くかどうかはわからんがな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0203140" ]},
		{"command":[ "WAITINPUT" ]},
	{"command":[ "EXIT" ]}
	]
}