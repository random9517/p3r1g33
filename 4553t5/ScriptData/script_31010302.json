		{"command":[ "PLAYVOICE", "v2_101_0304401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010103_02_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「精液とお潮が、シャワーみたいになってる……はぁ、ふぅ……ドロドロにな\nっちゃうですぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0304402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「精液、あったかくて、気持ちいい……隊長さんの体温と、日差しの熱さが、\n肌に刷り込まれて……あぁん……これ、すごくいい……」", "NORMAL" ]},
