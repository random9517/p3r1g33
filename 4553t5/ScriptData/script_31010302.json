		{"command":[ "SETIMAGE", "0", "still_00010103_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「あああ……射精が、止まりません……私も、まだ、イッてるですぅ……はー\n……はー……あはぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0304404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「目の前が真っ白です……私、熱中症にでもなっちゃった、かも……ひうぅ…\n…はへぇぇ……」", "NORMAL" ]},
