		{"command":[ "SETIMAGE", "0", "still_00010103_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「はー……全身から力が抜けると、身体が敏感になるですね……精液の暖かさ\nや、日差しの熱さ……風や波がいっぱい、感じられるです……」", "NORMAL" ]},
