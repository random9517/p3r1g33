	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「あ～～……いい日差しです！　こうして浜辺でお日様をいっぱいに浴びてい\nると、成績とかテストとか赤点なんてどうでもよくなりますね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0304101" ]},
		{"command":[ "SETCHARA", "0", "char_00010103_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「…………はぁ、ウソです。結構ヤバいです……もっと戦って、悪を斬りに斬\nりまくらなきゃ……また赤点かも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0304102" ]},
		{"command":[ "SETCHARA", "0", "char_00010103_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「はぁ……憂鬱な気分になりました。少し休ませてもらっていいです？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0304103" ]},
		{"command":[ "SETCHARA", "0", "char_00010103_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ふえ？　日焼け止めを塗ってやる？　確かに必要ですね。ありがとうござい\nます。お願いするです──」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0304104" ]},
		{"command":[ "SETCHARA", "0", "char_00010103_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「って、どーしてこんなことになってるですか～～……ひうぅ、隊長さん……\n駄目ぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0304105" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00010103_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ん、んん、やぁぁん……もう、誰かに見られたら、どーするです……？　妹\nたちに知られたら、私どんな顔すればいいのか……はぁ……あぁん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0304106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「あはぁ……その触り方、すごくエッチで、気持ちいい、ですぅ……ん、ん、\nはぁ……あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0304107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「あぁあ、乳首が、もうこんなになってるですぅ……ローションが塗り込まれ\nて……あ、あ、はぁ……ヌルヌルして、気持ちいい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0304108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「あぁ……身体が揺れる……ん、あぁ……はぁ……おっぱいが波打ってるぅ…\n…たぷたぷ揺れてるですぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0304109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「はぁぁん……駄目ぇ……身体がおかしくなっちゃうです……おちんちん、欲\nしくなっちゃう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0304110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「はぁ……ローションが、肌にまとわりついてくる……ん、はぁ……アソコが\n、熱いぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0304111" ]},
		{"command":[ "SETIMAGE", "0", "still_00010103_02_16" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「た、隊長……そんなおっぱいばっかりイジメないでぇ……あ、ああ、やだ、\n乳首が、こねくり回されてる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0304112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「やっ、あ、ああぁんっ！！　声、出ちゃうですぅ……はぁ……はぁ……はぁ\nうぅん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0304113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ん、ふぅ……隊長さん……ローション、私のもっと大事な場所に塗って欲し\nくなっちゃいました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0304114" ]},
		{"command":[ "SETIMAGE", "0", "still_00010103_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「えぇ……そうです……水着の奥の……女の子の一番大事なところにたーっぷ\nり塗ってくださいね……お願いするです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0304115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「んはぁぁぁん♪　はー……あぁああん……おちんちんが、入って……くるぅ\n……あ、ああ、すごぉい……気持ちいい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0304116" ]},
		{"command":[ "SETIMAGE", "0", "still_00010103_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「入り口が、先っちょにこじ開けられて……あ、ああ、アソコの隙間に、潜\nり込んでくる……はぁ……はぁ……あはぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0304117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「アソコが、濡れてる……ズブズブ入ってくるぅ……あ、ああ……太くて、\n硬くて……お腹の中が、えぐられちゃうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0304118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「はー……あぁぁ……奥まで、届いちゃうぅ……一番深いところに、先っちょ\nが……あ、ああ……はぁぁああん……あはぁ、届いちゃったぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0304119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「コツコツ、ぶつかってる……はぁ、はぁ……アソコと奥が擦り合わされ、火\n花が散ってるみたい、です……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0304120" ]},
		{"command":[ "SETIMAGE", "0", "still_00010103_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「んんっ……ぐぅ、はぁ……あぁん♪　身体が持ち上がっちゃう……すごぉい\n……隊長さん、もっとしてぇ……私を気持ちよくして、です……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0304121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ひやぁ！？　はぁ、はぁ……ああぁあん……コツコツと音が聞こえてくる\n……アソコの奥、いっぱいぶつかってる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0304122" ]},
		{"command":[ "SETIMAGE", "0", "still_00010103_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「私のエッチなローションが、どんどん溢れてくるです……あはぁ、隊長さん\nのおちんちんで、深いところまで塗り伸ばされてる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0304123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「おっぱいからトロトロが滴ってるです……ああん、隊長さんの指先で弄ばれ\nるたびに、にゅるにゅるうごめいてる……あはぁ、いやらしい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0304124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「んくぅ、あはぁぁ……乳首が、ジンジンする……おっぱいが熱い……あ、あ\nあ、谷間の中にトロトロが溜まってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0304125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ふぅ……日差しが強すぎて、身体が沸騰してしまいそう……あぁん、汗が止\nまらない……ローションと混じって、もっとトロトロになってるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0304126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「あぅぅ、水着が台無しですぅ……。ブラもショーツも、グチャグチャのトロ\nトロ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0304127" ]},
		{"command":[ "SETIMAGE", "0", "still_00010103_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……もっと隊長さんに汚されたいです……はぁ、はぁ……あああ\n、奥まで、激しくガンガン突き上げてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0304128" ]},
		{"command":[ "SETIMAGE", "0", "still_00010103_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「きゅううぅぅ……身体が弾む……あ、ああ、駄目ぇ……私も、身体が動いち\nゃう、です……ん、んんん、ぐぅ、あはぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0304129" ]},
		{"command":[ "SETIMAGE", "0", "still_00010103_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「あっ、んひぃ！　やっ、だ、駄目ぇ……イク……イキ、そう……です！　は\nぁ、はぁ……っ、んんんっ！　ひやぁぁぁぁ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0304130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ひやぁぁぁぁ！！　あっ、あっ、あああ……や、やだ、出てる……あぁぁぁ\nあん……繋がったまま、こんなにいっぱい……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0304131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……あうぅぅ、ごめんなさいです……隊長さん……はー……はー\n……ああああ、まだ出てる……止まりません……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0304132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「え？　た、隊長さんも出す……？　そんな、今、発射されたら、私、もう…\n…ひっ！　ひゃうぅぅ！　あっ、駄目……あ、ああ！　あひぃぃぃ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0304133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「はぁあぁぁぁん……おちんちんが、アソコの中で、暴れてるです……あ、あ\n、膨らんでる……頑張って精液汲み出してる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0304134" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010103_02_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ああぁぁ、お腹の奥の奥まで、精液が染み込んでくる……はぁ、熱い……お\nへその裏がポカポカするです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0304135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「日差しを子宮で浴びてるみたいな気分です……はぁ、あはぁぁ……気持ちい\nい……頭が、ぼーっとするですよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0304136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……はぁぁぁぁん……中で、精液が渦巻いてるみたい……ああ、\n子宮がビクンビクンしてるです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0304137" ]},
		{"command":[ "SETIMAGE", "0", "still_00010103_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「はぁ……ふぅ、過呼吸のせいですかね……それとも、日差しのせいでしょう\nか……ふぅ、ふぅ……目の前が真っ白になってる、です……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0304138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「はぁ……すごかったー……でも、おちんちん、まだ硬いまま、ですね……ふ\nふふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0304139" ]},
		{"command":[ "SETIMAGE", "0", "still_00010103_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「おちんちん、まだまだ出し足りないって感じ、ですね……私も、もっと日焼\nけ止めローション、アソコにぬりぬりして欲しいです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0304140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ふぅ……ふふ、古人いわく『据え膳食わぬは乙女の恥』です。こんな硬くて\n気持ちいいおちんちん、楽しまない手はないですよね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0304201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「あはぁ……中でジュボジュボ音が聞こえてくる……はぁ……すごぉい……出\nされた精液が、おちんちんに掻き混ぜられて……あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0304202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「はぁ、ふぅ……もっと掻き混ぜて、ローションをお腹の中全部に塗り伸ばし\nて、下さいね……さあ、もっと激しくお願い、します」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0304203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「あはぁぁぁっ、はぁ、あぁぁあん……隊長さん、すごぉい……そんなに激し\nく、されたら……お腹、壊れちゃう、です……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0304204" ]},
		{"command":[ "SETIMAGE", "0", "still_00010103_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……わ、私も、がんばらなきゃ……ん、んん、水のように滑ら\nかで変幻自在な身体使いが、この新フォームの極意ですから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0304205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「私も、いっぱい動いて、隊長さんを、もっと気持ちよく……んん、はぁ……\nはぁ……んんんっ、い、いかが、です？　気持ちいい、ですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0304206" ]},
		{"command":[ "SETIMAGE", "0", "still_00010103_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「あああ……駄目ぇ、気持ちよすぎて……身体が思うように、動けない、です\nぅ……はぁ、はぁ……あはぁぁあん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0304207" ]},
		{"command":[ "SETIMAGE", "0", "still_00010103_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「はぁ……ふぅ……チャプチャプ音がする……溜まった精液が、お腹の中で揺\nれてるです……あぁん、子宮が弾んでるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0304208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「はぁ……なんだか水中にいる気分、です……ふふ、きっと、新フォームの効\n果、です……感謝します、お亥さま……はぁ……あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0304209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「あはぁ……はへぇぇ……もっと気持ちいいのが、欲しいです……もっと、も\nっといっぱい突いてぇ……隊長さん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0304210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「あっ、あぁぁん！　身体が浮かんじゃうぅ……ああ、本当に水の中にいる、\nみたい、です……はぁ、あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0304211" ]},
		{"command":[ "SETIMAGE", "0", "still_00010103_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「やっぱり、水着姿は偉大です……はぁ、ふぅ……妹たちにこの素晴らしさを\n、もっと伝えなきゃ……はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0304212" ]},
		{"command":[ "SETIMAGE", "0", "still_00010103_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「え？　あ、もちろん隊長さんとエッチしてることはナイショです……そんな\nこと、言えるわけが、ないですし……はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0304213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ん、はぁ……あぁぁん……潮風が気持ちいい……浜辺エッチ、最高、ですね\n……水着姿で、本当によかった、です……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0304214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ひゃうぅっ、んっ、んくぅ……はぁ、あはぁぁあん……！　水中にいるみた\nいに、息苦しい、です……はぁ、ふぅ……はへぇぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0304215" ]},
		{"command":[ "SETIMAGE", "0", "still_00010103_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「気持ちよすぎて、ぼーっとしてきました……はぁ、はぁ……ああ、またイキ\n、そうです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0304216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「え？　また潮噴きするのか、ですって？　あはは……どうでしょう？　わか\nんない、です……はぁ、ふぅ……でも、また噴いちゃう、かも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0304217" ]},
		{"command":[ "SETIMAGE", "0", "still_00010103_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ひっ！　ひゃぅぅっ、駄目ぇ、そんなに激しくされたら……ま、また出ちゃ\nいます……お潮ぶちまけちゃうですぅ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0304218" ]},
		{"command":[ "SETIMAGE", "0", "still_00010103_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……はぇぇ？　隊長さんもイク、ですか……？　あはぁ、一緒に\n発射しちゃいそう、ですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0304219" ]},
		{"command":[ "SETIMAGE", "0", "still_00010103_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「わ、私は、いつでもオッケーです……はぁ、はぁ……隊長さん、お好きにお\n出し下さい、です……ん、あ、駄目……い、イク……んんんん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0304220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ひゃひぃぃ……！！　あっ、あああっ、ひやぁぁぁぁ！！　出てる……こん\nなに、いっぱい……溢れて……ぐっ、うぁぁ、あはぁぁん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0304301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010103_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「イッてる、です……今、いっぱいイッてます！　あ、あああ……イキながら\n、子宮に精液注がれるの……気持ちよすぎ、ですぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0304302" ]},
		{"command":[ "SETIMAGE", "0", "still_00010103_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ああぁぁ……潮が止まらない……射精してるみたに、ビュルビュル出ちゃう\nぅ……はぁ、はひぃぃ……きゃうぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0304303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「精液、まだ出てる……お腹の奥で、ビクンビクン震えてる……あはぁぁ……\n子宮が、温かい……おへその裏がポカポカしてる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0304304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「はー……子宮が、喜んでるです……あはぁぁ♪　精液をたっぷり飲んで、げ\nっぷしそうになってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0304305" ]},
		{"command":[ "SETIMAGE", "0", "still_00010103_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「隊長さんの精液、気持ちいい……体温が、身体に染み込んでくるみたい、で\nす……はへぇぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0304306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「日差しと、精液で、身体の外と中から温められる感じ……最高に気持ちいい\n、です……ああ、汗が、止まりません……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0304307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「あはぁ……まだ気持ちいいのが、続いてる……子宮が深呼吸してます……は\nー……ふぅー……気持ち、いい……身体に力が入らない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0304308" ]},
		{"command":[ "SETIMAGE", "0", "still_00010103_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ふう、風や、波の音が気持ちいい……身体が敏感になってるです……風で空\n気が動く感触、音の振動が身体に伝わってくる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0304309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「……脱力……完全な脱力が、『水になること』の真意なのかも……？　ふふ\nふ、隊長さんとセックスして、よかったです……はふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0304310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "序" ]},
