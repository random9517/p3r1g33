		{"command":[ "SETIMAGE", "0", "still_00010103_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「気持ちいい……あぁん、イクのが、止まらない……イキ過ぎて、どうにかな\nってしまいそう、です……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0304406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「あー……アソコの入り口から、空気が入ってくる……ん、ふぅ……さっき出\nされた精液が、ゆっくり滴ってくるです……」", "NORMAL" ]},
