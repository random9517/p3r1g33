{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「来たでござるよ～♪　さーてとぉ、今日は忍術の強化をするために、拙者お\n呼ばれしたんだよねぇ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0203101" ]},
		{"command":[ "SETCHARA", "0", "char_00015102_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「あっれ～～？　目が泳いでるでござるよ……うふふふ……さて、どんなこと\nをさせられるのやら……楽しみぃ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0203102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「楽して強くなるなら、それに越したことはないでござるから……で、何をす\nればいいの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0203103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「……え？　口で……？　あははは～……やっぱり、そんなことだろうと思っ\nたでござるよぉ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0203104" ]},
		{"command":[ "SETCHARA", "0", "char_00015102_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「まあ、断るのも面倒だし……別に構わないでござるよ～。ということで、オ\nチンポ出してぇ……隊長氏ぃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0203105" ]},
		{"command":[ "SETCHARA", "0", "char_00015102_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「うわぁ……大きいでござるねぇ……拙者、その、あんまり見慣れていないで\nござるから、ちょっとビックリしたでござる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0203106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015102_01_01" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「おー……すごいすごい。先っちょ、こんなに丸く膨らんで……血管もバキバ\nキに浮いてて……結構グロイでござるねぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0203107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「くんくん……すんすん……んん～～……少しおしっこ臭いでござる……でも\n、めちゃくちゃ臭いってわけでは……くんくん……ふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0203108" ]},
		{"command":[ "SETIMAGE", "0", "still_00015102_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「はぁ……最初、ちょっと面倒臭かったでござるけど、だんだんエッチな気分\nになってきたでござるよ……ニンニン……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0203109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「はぁ……え？　そろそろ始めて欲しい？　もう、せっかちさんでござるねぇ\n……ふふ……ん～～…………れろれろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0203110" ]},
		{"command":[ "SETIMAGE", "0", "still_00015102_01_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「んふぅ、こんな感じでどうでござるか？　ねるん、れろ、ぴちゃ、ねるん…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0203111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「はぁ……少ししょっぱいでござる……汗の味と……ねろん、れるれる……少\nしおしっこの味……？　んちゅ、ぴちゃ、ねろん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0203112" ]},
		{"command":[ "SETIMAGE", "0", "still_00015102_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「んはぁ……微かに臭うでござるね……れろれろ、にちゃ、ぴちゅ、ぬるぬる\n……んふぅ……でも、好きな味と匂いでござる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0203113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「れろ、ねろん、ぴちゃぴちゃ、んちゅぅ……はぁ、興奮してきたでござる…\n…れろれろ、ぬるる、にちゃあ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0203114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「ん、ふぅ……なんだか、もっと大胆なこと、したくなってきたでござる……\nんふふ、拙者がこんなに乱れるの、珍しいことでこざるよ……んはぁむ――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0203115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「むぐ、もごもご、ぬる、にゅちゃぁ……れろれろ、んちゅ……んふぅ、美味\nしいでござるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0203116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「ねるる、ぬちゅ、ぴちゃぴちゃ……はぁ、舌を動かすと、味が濃く感じるで\nござるな……ねるれる、ちゅぷぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0203117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「先っちょ、ぐにゅぐにゅするでござる……結構柔らかいんでござるね……れ\nるる、ぬるちゅぼ、くちゅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0203118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「んあむ、んちゅ、ねるれろ、はぁ、あふぅ……この味……この匂い……んん\n、興奮するでござるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0203119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「ぬる、ちゅぼ、ちゅぶじゅぼ、くちゅねろん、ぬるぅ……はぁ、はぁ……な\nんだか変な感じでござる……拙者がこんなに積極的になるだなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0203120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「はぁ、んん、あむ、むぐ、んちゅ、ちゅぼ、じゅぶじゅぼ……んん、ふぅ…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0203121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「んあむ、んぐ、ちゅぼ、じゅぐじゅぐ、ちゅぼぉ、くちゅぅ……はぁ、口の\n中で、オチンポが出たり入ったりしてるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0203122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「ああ、すごぉい……亀頭のスベスベした感じ……喉奥で感じちゃうぅ……ん\nぁむ、むぐ、ちゅぼ、くちゅ、れろじゅぶ、ぐじゅるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0203123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「ねろん、んちゅ、ぬるれろ、んんんぅ……はぁ、はぁ……喉奥と、口元、同\n時にオチンポ感じちゃうでござる……少し変な感じでござるよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0203124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「んぶぅ、ちゅぼ、んちゅ、ちゅちゅじゅる、じゅぼぉ……ん、んん……んぐ\nぅう……ッ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0203125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「んぶぅ！？　げほっ、ごほっ……はぁ、はぁ……もう、奥まで押し込まない\nで欲しいでござる……隊長氏ぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0203126" ]},
		{"command":[ "SETIMAGE", "0", "still_00015102_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「はぁ……苦しかったぁ……でも、んん、ふぅ……ちょっと興奮したでござる\n……れるれる、にゅる、くちゅ、じゅぶじゅるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0203127" ]},
		{"command":[ "SETIMAGE", "0", "still_00015102_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「ねる、れろ、れるれる、ちゅじゅ、じゅるじゅるぅ……んんぁ、はぁ……よ\nだれがこんなに……あぁん、滴っちゃうでござるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0203128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「んぐ、んん、ぬる、れろん……ん、んふふ、隊長氏、気持ちよさそうでござ\nる……んぁむ、ぬるる、れろん、くちゅちゅるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0203129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「んはぁ……なんだか、オチンポも、隊長氏も、愛おしくなってきたでござる\nよ……もぐもぐ、むぐ、ちゅぶじゅる、れろぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0203130" ]},
		{"command":[ "SETIMAGE", "0", "still_00015102_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「んふぅ……オチンポ、震えてるでござる……はぁ、あふぅ……ん？　もっと\n激しく……？　わかったでござる……やってみるでござるよ――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0203131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「ちゅぼじゅるる、くちゅじゅる、ぬるれる、ぬちゅじゅる、ちゅぼじゅずず\nるぅ……はぁ、はぁ……いかがで、ござる？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0203132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「ぢゅるじゅぢゅる、ぴちゃ、じゅるぬるるぅ、ちゅくちゅるん、ねろねろ、\nぬちゅぴちゃ……じゅずるるぅ……はぁ、ふぅ……苦しかったぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0203133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「でも……んん、お口が止まらないでござるぅ……ねるる、れろん、ちゅぶぴ\nちゃ、ずるん、れろれろ、ぬちゅぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0203134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「ん、はぁ、オチンポ震えてる……え？　出そう？　いいでござる……このま\nま出すでござるよ……んん、ちゅちゅじゅる、ずずぴちゃずちゅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0203135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「んっぶぅ！？　んぐぅ！　んっ、んっ、んんん～～……んふぁぁ、すごぉい\n……んんん、出てる……いっぱい、出てるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0203136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015102_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「ん、んん、はぁ……んんぅん……口の中が、精液でいっぱいになってる……\nんぐぅ、ゴクン……はぁ、あはぁ……苦しかったぁ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0203137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「ん、れろれろ、んちゅ、ねろん……ちゅる、じゅるるるぅ……ゴクン……は\nぁ、はぁ……すごい味ぃ……舌がしびれちゃうぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0203138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「あ、ああ、まだ出てる……ぬるぬるが滲み出してくるよぉ……れろれろ、ね\nるん、ずずるるぅぅ……ゴクン……ふへぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0203139" ]},
		{"command":[ "SETIMAGE", "0", "still_00015102_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「あふうぅ……これで、終わったでござるかぁ……はぁ、はぁ……すごかった\nでござるぅ……では、しからば御免――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0203140" ]},
		{"command":[ "SETIMAGE", "0", "still_00015102_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「……というわけには、いかなさそうでござるなぁ……まだ、こんなに大きい\n……ふぅ……れろれろ、ねろ、ぴちゃ、ちゅちゅう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0203201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「ふふ、わかってるで、ござるよ……このまま、続けさせてもらうでござるよ\n♪　その代わり……後で仕事、サボらせてもらうでござる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0203202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「ん～……れろ、ねろねろ、れろん……んんぅん……精液味が、まだこんなに\n……れろぬる、ぴちゃ、くちゅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0203203" ]},
		{"command":[ "SETIMAGE", "0", "still_00015102_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「あぁん、こんなところに、こびり付いてる……ぴちゃ、ねろ、れろれろ、ん\nちゅぅ……はぁ、ん、美味しいでござるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0203204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「ねろ、ぴちゃ、ねるれろ、ぬちゅぅ……はぁ、先っちょから、精液が滲んで\nるでござる……ねる、ぬるる、ぴちゃ、ちゅちゅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0203205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「んはぁむ、むぐむぐ、もご、ぬるる、ぴちゃぁあ……はぁ、ふぅ……オチン\nポ味、美味し……んぁむ、もごご、じゅる、ちゅるじゅるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0203206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「んふぅ……はぁ、はぁ……え？　気持ちいいでござるか？　えへへ、そりゃ\nどうも……はぁむ……むぐむぐ、くちゅ、ちゅるれろ、ちゅぢゅるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0203207" ]},
		{"command":[ "SETIMAGE", "0", "still_00015102_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「はぁ……ふぅ……ふえぇ？　あたし……じゃなくって、拙者、上手でござる\nか？　適当にやってるだけなのでござるけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0203208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「むぐ、ぴちゃぴちゃ、ちゅるじゅるるぅ……はぁ、ふぅ……きっと奉仕が好\nきなんでござるよ、拙者……れるぬる、ちゅじゅぢゅずるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0203209" ]},
		{"command":[ "SETIMAGE", "0", "still_00015102_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「はぁ、んん……れろれろ、ぬるちゅる、ずずるぅ……はあぁぁん……舌が止\nまらないでござるぅ……ねるる、ぬちゅぴちゃ、ちゅぢゅぼぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0203210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、はぇぇ……？　もっと深く、でござるか？　もう、仕方ないで\nござるなぁ……んんむぅ……んぐぅ、んぐじゅぶ、ちゅぼじゅるるう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0203211" ]},
		{"command":[ "SETIMAGE", "0", "still_00015102_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「ぐぶ、じゅぼ、ぢゅぶずじゅるぅぅ……ん、んんんぁ……んはぁ、はぁ……\n苦しいでござる……窒息しそうだったでござるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0203212" ]},
		{"command":[ "SETIMAGE", "0", "still_00015102_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「けど……ん、ふぅ……いくら苦しくても、喜んでもらえてると思うと……苦\nしさもぶっとぶでござるよ……んふふ……はぁむ、むぐむぐ、もごぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0203213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「んぐ、んじゅぶ、ぴちゃれろ、ぬるぅ……はぁ、拙者、きっと根っからの奉\n仕好きなのでござるな……ちゅるじゅる、ちゅぐじゅぶぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0203214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「んぶっ、んぐっ、んんん……んはぁっ、はぁ……あぁあん、よだれが、こん\nなに溢れてるでござるぅ……んはぁ……んぁむ……もぐもぐ、むぐぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0203215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「ちゅぶじゅぶ、ぐぼじゅぶ、ぴちゃ、ぬるる、れろん……はぁ、はぁ……あ\nあん、おちんぽ、震えてるでござる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0203216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「口の中で、ビクンビクンしてる……はぁ、これ、嬉しいでござるよ……じゅ\nぶ、じゅぼ、くちゅる、れろぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0203217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「ずずる、ぴちゃん、ぬちゅ、ずずちゅるぅぅ……はぁ、はぁ……え？　吸わ\nれると気持ちいい……？　左様でござるか……では、もっと吸うでござるよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0203218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「ず、ずずる、ぢゅるじゅる、ちゅちゅぴちゃ、ずにゅる、れろれろ、ちゅち\nゅぴちゃずぢゅるぅぅ……はぁ、はぁ……イキそう、でござるか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0203219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「結構でござる……いつでもイクでござるよ……ん、んん、ずずれろ、ちゅぬ\nる、れろぬるる、ぴちゃぢゅる、ずずれろぢゅずるぅぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0203220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「んっ、んん！？　んんん～～～～……んぐっ、んんっ、んふぅぅ……ん、ん\nはぁ、出てる……いっぱい出てるぅ……んんんぅん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0203301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015102_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「んはぁ、んぅん……喉が詰まっちゃうぅ……んんん……ゴクン……はぁ、は\nへぇえ……まだ、出てるぅ……んんんぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0203302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「んはぁ、まだ出てる……お口の中、ゆるゆる溜まってる……んん、溢れてる\n……やぁん、止まらない……んんぅ……ゴクン……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0203303" ]},
		{"command":[ "SETIMAGE", "0", "still_00015102_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「あはぁ……はぁ……すごぉい……まだ溢れてる……れろ、ねろ、ぴちゅぴち\nゃ……ちゅちゅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0203304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「ん、んんぅ……んん～～……ゴクン……はへぇぇ……ああ、すごぉい……喉\nの中に張り付いてるぅ……あへぇぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0203305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「精液って、すごい味でござるねぇ……はぁ、ふぅ……匂いもすごぉい……は\nぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0203306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「れろ、ぴちゃ、ねろん、れろれろ……んん、はぁ……あはぁ、隊長氏……嬉\nしそうにしているでござるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0203307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「あぁん、まだ先っちょから滲んでる……ぺろ、れろん……んん、美味しいで\nござるぅ……あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0203308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……やっと終わったで、ござるか……？　おちんぽ、萎み始め\nてるでござるよ……ふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0203309" ]},
		{"command":[ "SETIMAGE", "0", "still_00015102_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「これで、終わりでござるね？　ふぅ……楽しんでもらえてよかったでござる\n……では、しからば御免――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0203310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「ひゃあぁん！？　出てる！！？　いっぱいピュッピュされちゃうぅぅ……！\n　あ、ああ……駄目……顔に、ぶちまけられてるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0203401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015102_01_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「んくぅ！　あはぁぁ……はぁ、あへぇぇ……顔が、精液で塗りつぶされちゃ\nうぅ……はぁ、あぁん……すごぉい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0203402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「んぅん……顔に膜が張り付いちゃった……はぁ、あふぅ……息が出来ないよ\nぉ……んん、ずるる、れろれろ……ちゅるん……ゴクン……あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0203403" ]},
		{"command":[ "SETIMAGE", "0", "still_00015102_01_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「ふぅ……飲んじゃったぁ……♪　う～ん、美味しい……ってこともないでご\nざるね……ネットリして、んん、変な味でござる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0203404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「ん、ふぅ……はぁ……ああ、鼻が詰まって、息が出来ないでござる……はぁ\n……はぁ……ああ、空気が精液の味になってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0203405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「ん、んん……ずるるる…………んはぁ、鼻の中で精液が張り付いて……あは\nぁ……喉に流れてくる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0203406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「んん……ふぅ……はぁ……あはぁぁ……いっぱい出したでござるねぇ……ふ\nぅ、息が出来なくて、苦しかったでざる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0203407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「でも、隊長氏が喜んでくれるなら、何よりでござるよ……ニンニン……はふ\nぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0203408" ]},
		{"command":[ "SETIMAGE", "0", "still_00015102_01_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……満足、したみたいでござるね……ふふ、ほら、オチンポ、\nちょっと小さくなってるでござるよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0203409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「ふ～～……では、拙者、お役目を終えたでござるな……このまま、少しゴロ\nゴロさせてもらうでござる……しからば御免――」", "NORMAL" ]},
