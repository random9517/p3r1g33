		{"command":[ "SETCHARA", "0", "char_00020104_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ち、違うんだ！　これはさっきもらったもので！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「こんな趣味があったとは……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00020104_01", "3", "CENTER", "0" ]},
