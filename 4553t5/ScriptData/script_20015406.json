		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「私をこのまま召し上がれと言っているだけだ。……ん？　何を持っている？\n」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00020104_01", "3", "CENTER", "0" ]},
