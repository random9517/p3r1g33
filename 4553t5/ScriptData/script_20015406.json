		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「人からもらったもので俺が買ったんじゃない！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「こういう本を母に見つけられた息子は、大抵そう言って言い訳をするものだ\n。しかし……これは問題だな」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00020104_01", "2", "CENTER", "0" ]},
