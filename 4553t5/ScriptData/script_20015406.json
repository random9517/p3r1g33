		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "ルナテミス、修羅姫、サンタガール、クィン・テイルと解散した俺はようやく\n自分の部屋の前まで戻ってきた。", "NORMAL" ]},
