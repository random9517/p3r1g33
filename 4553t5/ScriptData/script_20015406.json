		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お、お袋！？　どうしてココに！？　てか、何やってるんですか！？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPIMAGE","1", "FALSE" ]},
