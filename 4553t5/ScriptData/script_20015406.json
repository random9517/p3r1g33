		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あ、こ、これは……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「待て。それを私に見せてみろ……。な、何？　グラビア写真集……？」", "NORMAL" ]},
