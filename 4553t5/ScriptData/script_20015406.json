		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ううう、寒い。こんな日は早く寝るに限る……って、あれ？　なんで鍵が開\nいてるんだ？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「出る時締め忘れたか……？　我ながら不用心だな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETTEXT", "泥棒を疑いつつも部屋に入ると、そこは真っ暗でしーんと静まり返っている。", "NORMAL" ]},
