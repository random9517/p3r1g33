		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……よく考えたら、クリスマスの夜だってのに、ボロボロで一人ぼっち……\n。さすがに辛くなってきたぞ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
