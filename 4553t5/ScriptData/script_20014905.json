		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「強い願いがあれば、あの光に負けない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010023290001" ]},
		{"command":[ "SETCHARA", "0", "char_00001801_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「スタークリスタルは、邪な願いを邪なまま叶える……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010023290002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「私の願いは……きっと……誰にも負けないくらい強くて、邪な願い……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010023290003" ]},
		{"command":[ "SETCHARA", "0", "char_00001801_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「みんなで不幸せになるの……この世界……すべての世界……みんな……誰も \nが……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010023290004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「さあ……スタークリスタル……！　あなたの力で、私の願いを叶えてみせて \nよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010023290005" ]},
		{"command":[ "SETCHARA", "0", "char_00001801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_009" ]},
		{"command":[ "SETTEXT", "光が止んだ。", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0031" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「アン！？　グリムロック！？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "目の前に立っているふたりの姿に、俺は困惑してしまう。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……。……あれ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010023290006" ]},
		{"command":[ "SETCHARA", "0", "char_00001805_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「これって、もしかして……。は、花嫁衣裳ですか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_010023290001" ]},
		{"command":[ "SETCHARA", "0", "char_00022105_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「え？　ええ？　花嫁衣裳なの？　こんな……ビキニというか……露出の多い \n服装が……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010023290007" ]},
		{"command":[ "SETCHARA", "0", "char_00001805_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "混乱しているのは、グリムロックも同じだった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "一方、アンはシースルーのケープをひらひらと翻しながら嬉しそうにしている \n。", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00022105_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「わっ、わぁ～っ。憧れの花嫁衣裳ですの～。ドレスではないようですが、で \nも嬉しいですの～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_010023290002" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「旦那さま。わたくし、旦那さまにふさわしい花嫁になれているでしょうか… \n…？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_010023290003" ]},
		{"command":[ "SETCHARA", "0", "char_00022105_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お、おう。すごく似合ってると……思うぞ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「旦那さまに褒めてもらいましたの～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_010023290004" ]},
		{"command":[ "SETCHARA", "0", "char_00022105_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "気が動転したまま返事をすると、アンは小躍りするほど喜んでいた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「うぅ……なんでこんな、普通じゃない花嫁衣裳になっちゃったの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010023290008" ]},
		{"command":[ "SETCHARA", "0", "char_00001805_01", "4", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「なるほど……そういうことですか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110023290001" ]},
		{"command":[ "SETCHARA", "0", "char_00000519_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ふたりの姿を見ていたハルノブが、なにかに気づいたように頷く。黒いオボロ \nも同じリアクションをしていた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おまえたち、なにかわかってそうだな」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「どうやらその花嫁衣裳は、誰かの願いで形になったもののようです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090023290001" ]},
		{"command":[ "SETCHARA", "0", "char_00000520_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「先ほどおふたりがクリスタルの光を浴びたのと、同じタイミングで誰かが光 \nを浴びたのでしょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110023290002" ]},
		{"command":[ "SETCHARA", "0", "char_00000519_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「その誰かの強い願いがかなったということです。あなた方に、花嫁衣裳を着 \nて欲しかったのでしょうね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090023290002" ]},
		{"command":[ "SETCHARA", "0", "char_00000520_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「まあ、その中に邪な願いも含まれていて……このデザインの花嫁衣裳となっ \nたようですが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110023290003" ]},
		{"command":[ "SETCHARA", "0", "char_00000519_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「そっか……。たしかにこの衣装……だれかの思いを感じる……。ひとりだけ \nじゃなくて、たくさんの人の……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010023290009" ]},
		{"command":[ "SETCHARA", "0", "char_00001805_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「わたくしも感じます……。なんだか、不思議な気分ですの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_010023290005" ]},
		{"command":[ "SETCHARA", "0", "char_00022105_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「私に向けられたたくさんの願いが、私の願いよりも強かったんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010023290010" ]},
		{"command":[ "SETCHARA", "0", "char_00001805_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「にしても、こんな生き恥ウェディングドレスを着せたいだなんて。ウチなら \n土下座されても着ませんよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110023290004" ]},
		{"command":[ "SETCHARA", "0", "char_00000519_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「生き恥……？　そんなことありませんの。かわいくて素敵だと思いますの～ \n♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_010023290006" ]},
		{"command":[ "SETCHARA", "0", "char_00022105_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ハルノブは皮肉っぽく言うが、アンには通じていないようだった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ちょっと～。カツマちゃんたち、ダイヤナちゃんがいるのに、なに内緒話し \nてるのかしら～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_130023290001" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00000613_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ダイヤナに気づかれた！", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「ちっ。クリスタルの力がどういうものかも確認しましたし、もうここに用は \nありません。撤退です！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090023290003" ]},
		{"command":[ "SETCHARA", "0", "char_00000520_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "黒いオボロがワームホールを出現させ、その中へと消えていく。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「むっ、逃がしませんよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110023290005" ]},
		{"command":[ "SETCHARA", "0", "char_00000519_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ハルノブも黒いオボロを追いかけて、ワームホールの向こうへ行ってしまった \n。まってくれ、この状況で戦力が減るのはかなり痛いのだが！？", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そ、そんなことよりどうすんだよ……！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「カツマちゃん、そんなことってなに？　どんなことよりもダイヤナちゃんを \n見なさ～いっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_130023290002" ]},
		{"command":[ "SETCHARA", "0", "char_00000613_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "例の洗脳光線が放たれ、姫様たちがまた浴びてしまった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あ……ああ……ダイヤナ……ッ！　ダイヤナ……ッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_280023290001" ]},
		{"command":[ "SETCHARA", "0", "char_00000128_01", "9", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「だ、だめだ身体が……。ダイヤナ……ダイヤナ……ッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_290023290001" ]},
		{"command":[ "SETCHARA", "0", "char_00000129_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "強い願いを持っていたらしい姫様たちだが、今度はその光に抗えず、踊りなが \nらダイヤナの方へ吸い寄せられてしまう。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「あ……あれ……なんともない……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010023290011" ]},
		{"command":[ "SETCHARA", "0", "char_00001805_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「それほど、わたくしたちに向けられた願いは、強かったということでしょう \nか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_010023290007" ]},
		{"command":[ "SETCHARA", "0", "char_00022105_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "しかし、グリムロックとアンは平気な顔で立っていた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんだか知らないが、チャンスじゃないか！？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「そうですの！　グリムロックさま、こうなったらクリスタルを破壊しましょ \nう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_010023290008" ]},
		{"command":[ "SETCHARA", "0", "char_00022105_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「そうすれば、きっとみんな元に戻りますの！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_010023290009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「う……うん……。わかったよ……はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010023290012" ]},
		{"command":[ "SETCHARA", "0", "char_00001805_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "グリムロックは、大きなため息をついた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「自分の願いは叶わないし……誰かの願いのおかげでこんなエッチな花嫁衣装 \nを着ちゃうし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010023290013" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「もう……なんて『不幸』なの……。フフ……フフフ……フフフフ……ッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010023290014" ]},
		{"command":[ "SETCHARA", "0", "char_00001805_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "なにかのスイッチが入ったのか、不気味に笑いながらグリムロックがダイヤナ \nに向かって突撃する。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「えぇっ、なにその衣装！？　水着なの？　ウェディングドレスなの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_130023290003" ]},
		{"command":[ "SETCHARA", "0", "char_00000613_01", "9", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ど、どっちだっていいけど、ダイヤナちゃんより目立とうとするなんて、許 \nさないんだから～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_130023290004" ]},
		{"command":[ "SETCHARA", "0", "char_00000613_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "グリムロックに向かってダイヤナが光を放つ。それをグリムロックは自分の魔 \n法で相殺していた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「スタークリスタルの力は、人を不幸になるほど幸せにする力……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010023290015" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00001805_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「だったら、私の魔法で不幸せにしちゃえば、無力化できちゃうよね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010023290016" ]},
		{"command":[ "SETCHARA", "0", "char_00001805_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「そうですの！　グリムロックさまの魔法で、ダイヤナさまの目を覚ましてあ \nげるんですの！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_010023290010" ]},
		{"command":[ "SETCHARA", "0", "char_00022105_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "グリムロックの理屈通りなら、確かにダイヤナを元に戻すことができるかもし \nれない。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「んも～っ！　ダイヤナちゃんが一番なんだからっ！　一番目立つの！　一番 \nキラキラなの～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_130023290005" ]},
		{"command":[ "SETCHARA", "0", "char_00000613_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ダイヤナちゃんより目立つコなんて許さないっ！　あたしの目の前から、い \nいえ、この世界から消えちゃいなさ～いっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_130023290006" ]},
		{"command":[ "SETCHARA", "0", "char_00000613_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「くぅっ！　すまない、グリムロック！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_290023290002" ]},
		{"command":[ "SETCHARA", "2", "char_00001805_01", "3", "CENTER", "0" ]},
		{"command":[ "SETCHARA", "1", "char_00000129_01", "4", "CENTER", "-700" ]},
		{"command":[ "SETCHARA", "0", "char_00000128_01", "4", "CENTER", "700" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "DISPCHARA", "2", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「身体が勝手に……！　だ、ダイヤナに逆らえないんだっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_280023290002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ダイヤナの言葉に応じ、その願いを叶えるかのように、姫様とアナザーがグリ \nムロックの前に立ちふさがり襲い掛かる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「わかってる。だからちょっとだけ、ふたりとも不幸になってて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010023290017" ]},
		{"command":[ "SETCHARA", "2", "char_00001805_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "グリムロックはひらりとふたりの攻撃をかわすと、魔法で生み出した弾丸で的 \n確に急所を撃ちぬき、気絶させてしまった。", "NORMAL" ]},
		{"command":[ "SETCHARA", "1", "char_00000129_01", "9", "CENTER", "-700" ]},
		{"command":[ "SETCHARA", "0", "char_00000128_01", "9", "CENTER", "700" ]},
		{"command":[ "DISPCHARA", "2", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "弾丸そのものにダメージはないってわかっているが、ばたりと倒れる姿をみる \nと本当に大丈夫か不安になるな……。", "NORMAL" ]},
		{"command":[ "FADEOUTCHARA", "1", "NORMAL" ]},
		{"command":[ "FADEOUTCHARA", "0", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あとはダイヤナをどうにかすれば……でも、どうすりゃいいんだ？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「スタークリスタルの力が一番強いところに、グリムロックさまの弾丸をあて \nて無力化しますの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_010023290011" ]},
		{"command":[ "SETCHARA", "2", "char_00022105_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "2", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「その場所は……わたくしの力で、グリムロックさまの弾丸を導きますの！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_010023290012" ]},
		{"command":[ "SETCHARA", "2", "char_00022105_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「アンちゃん、お願い。それじゃあ……不幸になろっか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010023290018" ]},
		{"command":[ "SETCHARA", "2", "char_00001805_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ちょっと、なに言っちゃってるの！？　ダイヤナちゃん、いまとっても幸せ \nなのにぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_130023290007" ]},
		{"command":[ "SETCHARA", "2", "char_00000613_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「幸せになったら、あとは不幸になるしかないんだよ。それに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010023290019" ]},
		{"command":[ "SETCHARA", "2", "char_00001805_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「ダイヤナちゃんの幸せは、“これ”じゃない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010023290020" ]},
		{"command":[ "SETCHARA", "2", "char_00001805_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "一言つぶやき、グリムロックが弾丸を放ち、アン＝クァーが力を乗せる。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "2", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ダイヤナはその攻撃をかわした。すると弾はぐいっと軌道を変えて標的に向か \nって飛んでいく。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「いやぁんっ！　こ、こっちこないで～！　みんな、ダイヤナちゃんを守って \n～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_130023290008" ]},
		{"command":[ "SETCHARA", "2", "char_00000613_01", "4", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "2", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ダイヤナは自分のバックダンサーを盾にしようとした。ダイヤナに操られる彼 \nらは、喜んで盾になる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "しかしその隙間を縫うように弾丸は飛び、確実にダイヤナを、スタークリスタ \nルを撃ちぬいた！", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「きゃぁあああぁぁぁっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_130023290009" ]},
		{"command":[ "SETCHARA", "2", "char_00000613_01", "9", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ダイヤナが悲鳴をあげる、その身体がまた強烈な光に包まれた。まぶしすぎて \n、目を開けていられない。", "NORMAL" ]},
