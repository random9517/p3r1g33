	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「隊長さん、お時間を取ってくださってありがとうございます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0104101" ]},
		{"command":[ "SETCHARA", "0", "char_00020501_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「実はその……折り入ってお願いがあるんですが……その……あのですね……\nんんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0104102" ]},
		{"command":[ "SETCHARA", "0", "char_00020501_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「隊長さん、わ、私の処女をもらってくれないでしょうか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0104103" ]},
		{"command":[ "SETCHARA", "0", "char_00020501_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「そんな顔しないでください！！　隊長さんも悪いんですからね！！　あんな\nエッチなものたくさんもらったら、私だって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0104104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「だから隊長さん、私にエッチな特訓、お願いします！！　って満面の笑みで\n頷いてる！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0104105" ]},
		{"command":[ "SETCHARA", "0", "char_00020501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「あ？　へ？　ひあっ、早速するんですか？　そうですよね……んっ、おっぱ\nいを？　はい……んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0104106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00020501_02_02" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「隊長さん、凝視してる……そんなにおっぱいが好きなんですか？　私のおっ\nぱいだから好き？　あ、あははは、照れますね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0104107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「証拠を見せる……って、ふああ、隊長さんのおちんちん、バッキバキになっ\nてる……私の身体を見てそうなったんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0104108" ]},
		{"command":[ "SETIMAGE", "0", "still_00020501_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「あ……う……隊長さん、ちょっと顔が怖いですよ……？　え、我慢できそう\nにない？　ふあっ、ああっ、そんな、覆いかぶさって……んっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0104109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「んん……凄い、まだ入ってないのに、おちんちんの熱が伝わってきます……\n隊長さんが興奮しているのが分かります……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0104110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、入れるんですね……？　隊長さんのおちんちん、私の中に入れ\nるんですね？　私の処女、もらってくれるんですね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0104111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「んっ……先端が私の入り口に当たって……あっ、ふうっ、隊長さんが……中\nに入ってきてます……んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0104112" ]},
		{"command":[ "SETIMAGE", "0", "still_00020501_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「はっ……あっ……中を広げてるのが分かります……んんっ、隊長さんのおち\nんちん、中でみっちり……あっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0104113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「これが、男の人とのエッチなんですね……んんっ、隊長さんの先端が……一\n気に、お願いします……んううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0104114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「ああっ、凄い、身体の中にぶつって、音が……私の初めてを、隊長さんがも\nらってくれた音が……ふあっ、あああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0104115" ]},
		{"command":[ "SETIMAGE", "0", "still_00020501_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「痛みは大丈夫です……気づかってくれてありがとうございます。えへへ、こ\nれで私は隊長さんのものになったんですね……嬉しい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0104116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「ひゃんっ！？　隊長さんが中で大きく……んんっ、私の言葉で興奮したんで\nすか？　眼鏡越しの瞳が可愛い？　急に何を……んうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0104117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「こういう会話も重要なんですか？　分かりました……その、隊長さんの身体\nもたくましくて素敵です。中にあるおちんちんも太くて……ひあっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0104118" ]},
		{"command":[ "SETIMAGE", "0", "still_00020501_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「顔も素敵で……んんっ、おちんちんがぐりぐりって動くたびに、痛さじゃな\nく私のお腹がじんじんしてます……んっ、好き……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「あんっ、その、奥をぐって押されると、凄く切なくなって……ふあっ、隊長\nさんの視線、感じちゃいます、んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0104120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、あっ、そんなに激しく動かれたら、おっぱいが揺れて、んんっ\n、それがいいって、ふああっ、あっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0104121" ]},
		{"command":[ "SETIMAGE", "0", "still_00020501_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「あんっ、あっ、ああっ、んんっ、隊長さん、眼鏡も見てる……珍しいものじ\nゃないでしょう？　あんっ、んっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「眼鏡が可愛いって、そんなこと言われたの初めて……あんっ、んっ、何回も\n言わなくても分かりましたってば！！　やんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0104123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「あうっ、むっ、んんっ、ちゅっ、んっ……えへへ、キスすると眼鏡と顔が当\nたっちゃいますね……あんっ、ああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0104124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「あんっ、あっ、隊長さんのおちんちんが私の中をかきまぜて……んんっ、あ\nっ、あっ、お腹の中で動いて……ふあっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0104125" ]},
		{"command":[ "SETIMAGE", "0", "still_00020501_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「んうっ、その動き、好きです、奥をぐりぐりってするの、好き、隊長さんの\nおちんちんを一番感じます……ふあっ、あっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「あっあっあっ、ふうっ、もっと、もっと突いてください、私の中、隊長さん\nのおちんちんでもっと突いて！！　んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0104127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「はあっ、あああっ、いいっ、気持ちいいっ、おちんちんがごしごし中をこす\nっていくの、気持ちいいっ！！　んんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「隊長さん、隊長さん！！　もっと！！　私の中、もっと動いてください！！\n　ああっ、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0104129" ]},
		{"command":[ "SETIMAGE", "0", "still_00020501_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「ああんっ、眼鏡がずれて……んっ、隊長さんの顔が……あっ、んっ、んむっ\n、キスすれば見えますね……えへへっ、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「んんっ、隊長さんのおちんちん、また大きくなってきました……んうっ、う\nっ、隊長さんも気持ちよくなってるんですね……やんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「あ、隊長さんの顔も切なくなってる……ふふ、私の顔をじっと見て……んん\nっ、あっ、中がきゅって締め付けちゃう……んっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「あんっ、隊長さん、おちんちんが、私の中で暴れて……私の中が締め付けて\n……ふああっ、あっ、ああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「ふうっ、うっ、凄く力強い……これが男の人とのセックス……ふあっ、ああ\nっ、あああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「んっ、ああっ、あっ、隊長さん、イくんですね、私の中でイくんですね。お\nちんちん、凄く熱く膨らんでる……あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0104135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「私も、お腹の中がじんじんして……あっ、ああっ、隊長さんのおちんちんが\n動くたびに……これがイくってことなんですね……ふああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0104136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「イって、隊長さん、私の中でイってください！！　私、私も、隊長さんのお\nちんちんでイきますっ！！　んううううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0104137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、あっ、ああっ、イく、イく、隊長さんのおちんちんで、イっく\nううううううう！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0104138" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00020501_02_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「ふああっ、ああっ、んんっ、あっ、隊長さんのおちんちんから熱いものが…\n…んんっ、うっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0104139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「ふううっ、うっ、これが、セックス……隊長さん、教えてくれてありがとう\nございます……好き……好き……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0104140" ]},
		{"command":[ "SETIMAGE", "0", "still_00020501_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「あうっ、んんっ、隊長さんのおちんちん、まだ硬いまま……もう一回、する\nんですか？　私もしたいです、やんっ、あっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0104201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「はあっ、ああっ、なにっ、なんでさっきより気持ちよく……んううっ、私の\n中が隊長さんの形になってる……あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0104202" ]},
		{"command":[ "SETIMAGE", "0", "still_00020501_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「んうっ、んんっ、お腹の中が、凄い、かき混ぜられて……ああっ、ふあっ、\nこれ、これが隊長さんに抱かれてるって感覚……んっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「いいっ、気持ちいいっ！！　んっ、むっ、隊長さんとのキスも気持ちいいっ\n、ふああっ、あっ、あんっ、あっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0104204" ]},
		{"command":[ "SETIMAGE", "0", "still_00020501_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「んむっ、んっ、その舌を絡めるの……もっと、んっ、ちゅっ、れるっ、んっ\n、んふうっ、あああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0104205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「ああっ、上も、下も、隊長さんと繋がって、隊長さんのものになって、あん\nっ、はっ、うううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0104206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「んうっ、あっ、好き、好きです！！　隊長さんも、隊長さんとのセックスも\n！！　あんっ、またおちんちんが硬く……ひああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0104207" ]},
		{"command":[ "SETIMAGE", "0", "still_00020501_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「中が、中がごつごつって、ふうっ、うっ、あああっ！！　隊長さん、隊長さ\nん、好きっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「あんっ、ああっ、あうっ、この体中をかき混ぜられるような感覚……これが\nセックスの気持ちよさ……んっ、あっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「はあっ、ああっ、んっ、男の人が、私の中を出入りしてる……私が、隊長さ\nんに抱かれてる……んうううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0104210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「それが、それが凄く嬉しい。気持ちいい！！　ああっ、隊長さん、隊長さん\n！！　ふあああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0104211" ]},
		{"command":[ "SETIMAGE", "0", "still_00020501_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「隊長さんのおちんちん、きゅって締めると反応してきて……私の中をごりご\nりって削ってきて……あうっ、あああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0104212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「大きな先端も、段差のあるカリ首も、太い竿も、全部……全部素敵……私の\n中を、満たしてくれてる……ふああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0104213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「隊長さんの顔もいつもと違って……ギラギラして……私をそんなにもとめて\nくれてるんですね……あうっ、んっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0104214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「うふふ、これが女としての幸せなんですね……隊長さんとセックスして、初\nめて理解できました……嬉しい、あんっ、あっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0104215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「んうっ、うっ、隊長さんのおちんちんがまた大きくなってきてます。もう一\n回出すんですね。いいですよ、いっぱい出して……あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0104216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「あんっ、ああっ、あっ、はああっ！！　私、私もまたっ、隊長さんのおちん\nちんで、んんっ、イく、イくうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0104217" ]},
		{"command":[ "SETIMAGE", "0", "still_00020501_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「ふあっ、あああっ、おちんちん、おちんちんが私の中、ごつごつって、あっ\n、ああっ、ひあっ、あんんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0104218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「隊長さん、隊長さん！！　イく、イく、イっく、んんんっ！！　あああああ\nあああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0104219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「一緒に、一緒にイって、隊長さん、ふあっ、ああああああああああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0104220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「ふうっ、ああああっ、来てる！！　隊長さんの精子、私の中にどくどくって\n、いっぱい来てる！！　あんっ、ああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0104301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00020501_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「はあっ、はっ、熱い、んっ、隊長さんの、やけどしそう……ふうっ、ああっ\n、あっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「あっ、んっ、やあっ、出しながらぐりぐりって動かしちゃだめです……やん\nっ、ああっ、んんっ、奥に、注がれてる……んっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0104303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「こんな、こんなに出されたら、隊長さんの赤ちゃんできちゃう……んんっ、\nやあっ、また出てきた……んうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0104304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「んんっ……幸せ……隊長さんとエッチできて、私幸せです……んっ、お腹も\n暖かくて、満たされます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0104305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「隊長さんも気持ちよかったですか？　えへへ、ならよかったです……初めて\nだったけど、満足してもらえて、嬉しい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0104306" ]},
		{"command":[ "SETIMAGE", "0", "still_00020501_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「あ……んっ、出し切りましたね。お腹の中、いっぱいになりました。締め付\nけで分かる……って、改めて言われると恥ずかしいですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0104307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「ふうっ、ううっ、隊長さん、もう少しこのままで……もう少し隊長さんを感\nじていたいので……んっ、ほら、私の中も動いてる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0104308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「あっ……んっ……ふふ、あんなに激しかったのに、今凄く安らいでます。隊\n長さんに抱かれたからかな……好き……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「隊長さん……またエッチな特訓、してくださいね。私、頑張りますから……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「ふああっ、あっ、なんで、抜いちゃう……んっ、あっ、隊長さんのおちんち\nんが目の前に……あうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0104401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00020501_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「んんんんんっ！！　熱い……隊長さんの精液、あんっ、顔に……眼鏡に、い\nっぱいかかってる……んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0104402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「あうっ、んんっ、凄い匂い……濃くて……どろっとしてて……ふあっ、あっ\n、私の顔、汚されてる……んうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0104403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「隊長さんのおちんちんから出てるのが、見える……んんっ、やんっ、レンズ\nがもうべとべとに……ふあっ、ああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0104404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「かけられてるだけなのに、眼鏡にかけられてるだけなのに、なんだか私も…\n…んんっ、イっく……んうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0104405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「ふはっ、あっ……隊長さんの顔、精子で見えなくなっちゃった……んんっ、\n垂れ落ちて……んくっ、口の中にも……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0104406" ]},
		{"command":[ "SETIMAGE", "0", "still_00020501_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「隊長さんの味……んくっ、はっ、あっ……おいし……んっ、ふうっ、ああっ\n、またお腹がうずいて……んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0104407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「ね、隊長さん、次はちゃんと中に出してくださいね？　眼鏡にかけられるの\nも、嫌いじゃないですけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0104408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「やっぱり、隊長さんのを中で受け止めたいから……ね、隊長さん、お願いし\nます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0104409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "頼母木マミ" ]},
		{"command":[ "SETTEXT", "「んっ……でも、隊長さんの精子を浴びるのは好きかな……えへへ、隊長さん\nがしてくれるなら、なんでも好きですけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_0104410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
