{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0075" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「お前と一緒に湯あみができるとは、嬉しい限りだ。どんなことでもするから\n、遠慮なく言ってくれ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0203101" ]},
		{"command":[ "SETCHARA", "0", "char_00025702_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「えっ……いつもしているオナニーを、ココでしてみせろ？　ち、ちょっと待\nってくれ！　確かに、どんなことでもとは言ったが、そういう意味では！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0203102" ]},
		{"command":[ "SETCHARA", "0", "char_00025702_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「あっ、うぅ……わ、わかった。言う通りにさせてもらう……ここで、オナニ\nーをすればいいんだな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0203103" ]},
		{"command":[ "SETCHARA", "0", "char_00025702_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「はぁっ……んっ、あぁっ……皆が使う場所なのに、こんなことっ……はっ、\nぐっ！　んふっ、はっ、あっあっ、あぁぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0203104" ]},
		{"command":[ "SETIMAGE", "0", "still_00025702_01_02" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「んなっ……！？　ただオナニーするだけでなく、実況までしろというのか！\n？　くぅぅっ……それが、命令であれば……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0203105" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「あっ、んぐっ！　ふっ、あっ！　い、いま、オマンコの入口に、指を這わせ\nながら……クリトリスを、摘まんでいるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0203106" ]},
		{"command":[ "SETIMAGE", "0", "still_00025702_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「いつもは、こうしてクリトリスを引っ張ったり、叩いたりしながら……ゆ、\n指をズポズポしてっ……はひっ！　んっ、あっ！　ひゃ、あはぁっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0203107" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「あぁぁっ！　ど、どうして……いつもよりオマンコが濡れているっ……指が\n簡単に、奥まで入ってくるっ……ふひっ！　はっ、くっ、くぅぅ～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0203108" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「クリトリスも、どんどん大きくなってきているぅ！　触っていないのに、乳\n首もカタくなって……んっ、はふっ！　ひゃ、あぁっ、あぎひぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0203109" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「あっ、あっ！　んっ、はぁぁっ！　こ、これで、いいだろうか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0203110" ]},
		{"command":[ "SETIMAGE", "0", "still_00025702_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「ひぃぃっ！？　な、なんでチンポを取り出して……もしかして、私のオナニ\nーを見て、興奮してくれたのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0203111" ]},
		{"command":[ "SETIMAGE", "0", "still_00025702_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「あっ、んはぁっ……すごく、大きくて太いチンポっ……これ、見ているだけ\nで、オマンコが気持ちよくなるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0203112" ]},
		{"command":[ "SETIMAGE", "0", "still_00025702_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「それに匂いもすごく濃くて……はぁっ、はぁぁっ……ここからでも、いやら\nしい香りが伝わってくるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0203113" ]},
		{"command":[ "SETIMAGE", "0", "still_00025702_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「こんなのを見せられながら、オナニーをするだなんてっ……あっ、あっ！　\nひゃひっ、んひっ！　はっ、くっ！　んぐぐっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0203114" ]},
		{"command":[ "SETIMAGE", "0", "still_00025702_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「お前のチンポっ……とても苦しそうだ……んっ、はふっ……その苦痛から解\n放してあげるのも、私の役目だからな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0203115" ]},
		{"command":[ "SETIMAGE", "0", "still_00025702_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「あむっ、ちゅぐっ……んっ、じゅぱっ、じゅるるっ！　ちゅ、じゅぼっ、ち\nゅぼっ……ちゅぱっ、ずぷぷっ、ちゅぱぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0203116" ]},
		{"command":[ "SETIMAGE", "0", "still_00025702_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「んぐっ、ぢゅむっ、ぐむぅ！　チンポ、しゅごくあちゅいっ……しょれに、\n濃厚にゃ味がひてっ……んぢゅ、ちゅぐっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0203117" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「ちゅぶぶっ、じゅばっ、じゅぽぉっ！　あっ、んぶっ、んんぅ～！　指が勝\n手に動くぅ！　オマンコにょ奥、グリグリひてしまうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0203118" ]},
		{"command":[ "SETIMAGE", "0", "still_00025702_01_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「あぁぁっ、見ないれくれぇ……私のはしたないオナニー姿、凝視ひないれく\nりぇっ……ちゅばっ、じゅばばっ！　んっ、じゅぞぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0203119" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「んちゅ、ちゅぶぶっ！　ちゅぱっ、ずぷぅ！　はぁ、はぁぁっ……チンポが\nしゃらに大きくっ……んっ、あぐっ、ちゅ、ちゅるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0203120" ]},
		{"command":[ "SETIMAGE", "0", "still_00025702_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「お前にょ腰も、カクカク動ひてて……もひかして、もっひょ奥まれ、咥えて\n欲ひいにょか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0203121" ]},
		{"command":[ "SETIMAGE", "0", "still_00025702_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「ずずっ、じゅぞっ……んっ、くぷっ……しょれが、望みでありぇば……応え\nるのが、ニンジャというもにょらっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0203122" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「んっ、ちゅちゅ……ずっ、ぐっぷっ！　じゅぞっ、ぢゅ……ちゅばばっ、じ\nゅぱっ、んぢゅ！　ちゅ、るっ、れろれろっ、ずりゅうぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0203123" ]},
		{"command":[ "SETIMAGE", "0", "still_00025702_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「お、奥まれ咥えりゅから、もっひょ腰を突き出ひてくりぇ……喉の奥まれ、\nチンポをねじ込んでくりぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0203124" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「ぜんぶ、受け止めりゅからっ……指でオマンコぐちょぐちょしながりゃ、い\nっぱい、咥えりゅからぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0203125" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「ぐっ、んぶぅぅぅっ！？　じゅぞぞっ、ぢゅぞっ！　んごっ、ぢゅ、んぱっ\n！　じゅるぢゅ、ずぱっ、じゅぞぞっ、ぐちゅりゅうぅぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0203126" ]},
		{"command":[ "SETIMAGE", "0", "still_00025702_01_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「じゅぽっ、ぢゅぼっ！　おっ、んごっ！？　じゅばばっ、ぐ、ぐるじっ……\nぢゅぞぞっ、じゅぞっ、ずぞぞぞっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0203127" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「おっ、おぉぉっ……クチいっぱいに、チンポにょ味がしゅるぅ！　太いガチ\nガチにょチンポれ、クチマンコ犯しゃれてぇ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0203128" ]},
		{"command":[ "SETIMAGE", "0", "still_00025702_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「しゅごく苦ひくて、息ができにゃいのにっ！　オ、オマンコ、気持ひいいっ\n！　子宮がズキズキしゅるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0203129" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「もっひょ奥れ咥えひゃいっ！　お前りょチンポ、ぜんぶクチマンコに突っ込\nんれ欲しいっ！　んぶぶっ、ぢゅぞっ、じゅっぽっ！　ぐぼぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0203130" ]},
		{"command":[ "SETIMAGE", "0", "still_00025702_01_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「おごっ！？　んごっ、おっ、ぢゅごぉっ！？　チンポ、奥まれきひぇるぅ！\n　クチにょなか、ぜんぶチンポにょ味がしゅるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0203131" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「ぢゅぞぞっ！　んぶっ、ぐぶぶっ！　こんらの、イグッ！　チンポとオナニ\nーで満たしゃれて、イッへひまうぅぅ～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0203132" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「ぢゅぼぼっ、じゅっぽっ！　ぐぼっ、ぢゅぶぅぅっ！　ア、アクメしながら\n射精しゃせろらと！？　わ、分かっひゃ、射精しゃせるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0203133" ]},
		{"command":[ "SETIMAGE", "0", "still_00025702_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「じゅぱっ、ぐぼっ！　ちゅ、れろれろっ、じゅろろっ、んぢゅぷぅ！　ぐぽ\nっ、じゅぽっ！　ぢゅ、ぢゅぢゅ！　ずちゅ、ちゅるるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0203134" ]},
		{"command":[ "SETIMAGE", "0", "still_00025702_01_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「んっぶぅぅ！　チンポがクチにょ中れ、暴れへっ……イッ、イクッ！　イグ\nイグぅぅ！　チンポしゃぶりながら、アグメしゅるぅぅ～～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0203135" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「じゅぢゅぶぅっ！？　ぐっ、ぢゅぼぼっ！　ごっ、おごっ！？　ぢゅ、ぱっ\n！　んぢゅるるっ、ぢゅ、じゅぞぉっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0203136" ]},
		{"command":[ "SETIMAGE", "0", "still_00025702_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「ひっ、あひっ！　お、おしっこ漏れてりゅうぅ！　お漏らししにゃがら、イ\nッひぇるぅぅっ！　おっ、んおぉぉ～！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0203137" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「は、はひぃ！　ちゃんと精子飲みましゅ！　ザーメン、ぜんぶゴクゴクしま\nしゅうぅ！　んぐっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0203138" ]},
		{"command":[ "SETIMAGE", "0", "still_00025702_01_11" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「ぢゅぞぞっ、じゅ……んぐっ、んぐぅ！　ぢゅ、ぞっ、ちゅるるっ、じゅず\nっ！　んぐっ、んぐっ……ごくっ、ごっくんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0203139" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「チンポにょ奥に残ってる精子も、ぜんぶすすりましゅからぁ！　ずずずっ、\nじゅぞぞっ……じゅるるっ！　んっ、んぐっ、ごくっ……ごくんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0203140" ]},
		{"command":[ "SETIMAGE", "0", "still_00025702_01_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「ぷはぁっ……はぁぁっ、はぁぁ～っ……このザーメン……とても濃くて、ド\nロドロだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0203201" ]},
		{"command":[ "SETIMAGE", "0", "still_00025702_01_15" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「喉に絡みついてっ……んっ、けほっ、けほっ！　あぁっ……むせ返るような\n香りが、身体の奥からしてくるぞっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0203202" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「はふっ、はっ……あはぁぁっ……満足、いただけただろうか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0203203" ]},
		{"command":[ "SETIMAGE", "0", "still_00025702_01_14" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「えっ、あっ……そんな……あれだけ出したのに、まだこんなにチンポが勃起\nしてっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0203204" ]},
		{"command":[ "SETIMAGE", "0", "still_00025702_01_13" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「ヒクヒク疼いて、射精したがっているのが分かる……あぁぁっ、ダメだ！　\nこんなのガマンなんてできない！　し、失礼するっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0203205" ]},
		{"command":[ "SETIMAGE", "0", "still_00025702_01_14" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「じゅぞぞっ、じゅぞぉ！　ちゅ、んぢゅるっ！　ちゅぱじゅぱっ、れろっ、\nじゅるっ……じゅるるっ！　ぐっちゅ、ぢゅっぱぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0203206" ]},
		{"command":[ "SETIMAGE", "0", "still_00025702_01_17" ]},	
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「んぅぅぅ～！　チンポ美味ひいっ！　射精ひたばかりにょ、ガチガチチンポ\n……んぅ、ぢゅぞぞっ！　たまりゃないっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0203207" ]},
		{"command":[ "SETIMAGE", "0", "still_00025702_01_18" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「んあっ、ぢゅぼっ、あはぁっ！　指ももっひょ激ひく動いてっ……クリトリ\nスを引っ張りゅと、身体中に電気が走りゅみたいれぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0203208" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「じゅじゅじゅ、ぢゅ、ぞっ！　ちゅぷっ、ずぶぶっ！　ちゅぱっ、じゅばっ\n！　れぢゅ、れぶっ、ぐぽっ、ぐぽっ、じゅぼぼっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0203209" ]},
		{"command":[ "SETIMAGE", "0", "still_00025702_01_16" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「ま、まひゃ、奥まれ突っ込んれくりぇっ！　クチマンコと喉奥れ、チンポズ\nリズリしゅるからぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0203210" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「おごごっ！？　ぢゅ、んごぉぉぉ～っ！？　ちゅっばっ、じゅぶぶっ！　じ\nゅるっ、ぶぶっ！　ちゅごっ、じゅごっ！　ぢゅぱっ、じゅぱぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0203211" ]},
		{"command":[ "SETIMAGE", "0", "still_00025702_01_17" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「んっ、んっ、んんぅぅ～～～～！　チンポを吸えば吸うほりょ、エッチにゃ\nお汁が溢れてくりゅうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0203212" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「ずずっ、ぢゅ、んっ、んぐっ！　ぢゅ、じゅぱっ！　はぁぁっ、喉に絡みち\nゅくぅ！　こにょ味と匂いれ、オマンコ疼くっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0203213" ]},
		{"command":[ "SETIMAGE", "0", "still_00025702_01_18" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「んぢゅ、ぢゅぢゅ、じゅ、じゅっぱっ！　もっひょ、いっぱいペロペロしゅ\nるから、ガンガン突いて！　クチマンコ犯してくりぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0203214" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「ぐっ、おごっ！？　じゅ、ぞぞっ！　ぢゅぐぐっ、じゅっぱっ、ぐっぽっ！\n　ずぽずぽっ、ぢゅばっ！　れりゅ、にちゅる！　ぐじゅるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0203215" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「んおっ、おっおっ、おぉぉぉ～っ！　まひゃ、オマンコにょ奥かりゃ、しゅ\nごいのくるっ！　気持ちいいにょ、止まりゃないぃ～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0203216" ]},
		{"command":[ "SETIMAGE", "0", "still_00025702_01_16" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「イクッ！　イクッ！　アクメひちゃうっ！　またオマンコイキにゃがら、エ\nッチな顔を晒ひてひまうぅぅ～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0203217" ]},
		{"command":[ "SETIMAGE", "0", "still_00025702_01_18" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「んぶぶっ、ぢゅ、じゅっぱぁぁっ！　チンポにょ動きも激しくぅ！？　おっ\n、んおぉっ！　もひかして、まひゃイクにょかっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0203218" ]},
		{"command":[ "SETIMAGE", "0", "still_00025702_01_17" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「ぐちゅるっ、じゅぞぞっ、ぢゅぷぅぅ！　まひゃ、ぜんぶ受け止めりゅっ！\n　クチれも顔れも、好きにゃところに出ひてくりぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0203219" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「ちゅ、ちゅちゅちゅ！　じゅ、ぢゅばっ、ずっぷっ！　れろっじゅるっ、ぐ\nぼぼっ、ぢゅぞっ！　んっ、んむっ！　ぐむぅぅぅ～～～～！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0203220" ]},
		{"command":[ "SETIMAGE", "0", "still_00025702_01_18" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「おぶぅぅぅっ！？　まひゃ、クチのナカにぃ！？　んごっ、ぢゅ、ぢゅぞっ\n！　ごっ、おごごっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0203301" ]},
		{"command":[ "SETIMAGE", "0", "still_00025702_01_21" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「こ、今度は……喉奥に直接っ……せ、精子、流ひ込まれへっ……ごっ、ぢゅ\nごっ！　ぐぶっ、ぢゅぞぞっ！　おっ、おぉぉっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0203302" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「は、はひっ！　ぜんぶ、飲みましゅっ！　一滴足りひょも、こぼひませんっ\n！　ぢゅぞっ……じゅる、じゅるるっ！　ぢゅっぞっ、ずぞぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0203303" ]},
		{"command":[ "SETIMAGE", "0", "still_00025702_01_20" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「んぐんぐっ、ごくっんっ！　ぢゅ、ぢゅるるっ……ずっ、ずずずっ！　おっ\n、おぉ！　精子飲みにゃがら、イグッ！　ちゅぱっ、ぢゅ、じゅるるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0203304" ]},
		{"command":[ "SETIMAGE", "0", "still_00025702_01_21" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「こくっ……ごくっ……んっ、ごくっ！　ごっくんっ！　ちゅ、じゅるるっ…\n…ずぞっ、ぢゅぞっ……ちゅぱっ、くっ、ちゅぷぅぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0203305" ]},
		{"command":[ "SETIMAGE", "0", "still_00025702_01_19" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「んっ、ちゅぱぁっ……んっ、はぁぁぁっ……ど、どうだったりょうか……私\nのクチマンコと、オナニーは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0203306" ]},
		{"command":[ "SETIMAGE", "0", "still_00025702_01_14" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「お前にょチンポを咥えていりゅらけれ……胸にょ奥が熱くなっへ……幸せに\nゃ気持ちが、溢れて……んぅ、ちゅぶぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0203307" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「ずっと、こうしていひゃいくりゃいだ……チンポ咥えて、オナニーひていた\nいっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0203308" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「んっ、ちゅぱっ……ぢゅ、じゅるっ……あぷっ、んぷぅ……もっひょ、命令\nひてくりぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0203309" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「立派なユアミ・ニンジャマスターに、なりぇるように……いりょんなボウチ\nュウジュツを、教えひぇくらはいぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0203310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「んぅっ！？　んぷぅぅぅ！？　ひゃ、あぁぁっ！？　顔に精子がかかって…\n…んぅぅ～！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0203401" ]},
		{"command":[ "SETIMAGE", "0", "still_00025702_01_24" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「熱いのが、まだこんなにもびゅーびゅー出てくるなんてぇ！？　さ、さすが\nだな……んっ、あっ！　んふぅ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0203402" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「あっ、あふっ！　んっ、あっあっ……濃厚な香りが、鼻から強く伝わってく\nるっ……はぁぁぁ、これ、匂いだけで感じすぎるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0203403" ]},
		{"command":[ "SETIMAGE", "0", "still_00025702_01_23" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「イクッ！　イクイクッ！　ぐちゃぐちゃした精子をかけられながら、イッ…\n…グッ……おぉぉっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0203404" ]},
		{"command":[ "SETIMAGE", "0", "still_00025702_01_24" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「んほっ！　おっおっ、おっ！　んおぉぉぉ～！？　おほっ！　んっほぉぉっ\n！　ア、アクメ、止まらないぃぃぃぃ～～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0203405" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、ふぅぅっ……いっぱい出たみたいだな……まさか、こんなに\n出してもらえるなんて、思ってなかったぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0203406" ]},
		{"command":[ "SETIMAGE", "0", "still_00025702_01_23" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「フフッ。これは私のクチマンコが、かなり気持ちよかったと見える……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0203407" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「え？　オ、オナニーをする姿も、すごくよかった……？　そ、そうか……そ\nう言ってもらえると、すごく嬉しい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0203408" ]},
		{"command":[ "SETIMAGE", "0", "still_00025702_01_22" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「その……できれば、これからも、いっぱい気持ちよくして欲しい……もっと\nもっと、ボウチュウジュツを教えて欲しい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0203409" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「こういうことを頼めるのも……したいと思うのも、お前だけだからな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0203410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
