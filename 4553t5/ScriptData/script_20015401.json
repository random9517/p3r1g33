{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0043" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_019" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "スナック停留所では、２人の女が飲んだくれ、酔いどれている最中だった。", "NORMAL" ]},
		{"command":[ "SETCHARA", "1", "char_00000701_01", "0", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "0", "char_00002502_01", "0", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SPOTCHARA", "1"]},
		{"command":[ "SETTEXT", "「うぃ～、ひっく……。まだじゃ、まだまだイケるぞぉ～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010023520001" ]},
		{"command":[ "SETCHARA", "1", "char_00000701_01", "8", "CENTER", "-400" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SPOTCHARA", "0"]},
		{"command":[ "SETTEXT", "「もう、あまり飲みすぎるんじゃないよ。あんたともあろう者が、情けない姿\nを晒すつもりかい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_020023520001" ]},
		{"command":[ "SETCHARA", "0", "char_00002502_01", "2", "CENTER", "400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SPOTCHARA", "1"]},
		{"command":[ "SETTEXT", "「と、偉そうに言うておるお主もすでにベロベロではないか～。ひっく……っ\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010023520002" ]},
		{"command":[ "SETCHARA", "1", "char_00000701_01", "6", "CENTER", "-400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SPOTCHARA", "0"]},
		{"command":[ "SETTEXT", "「やれやれ。ほら、水だよ。今年もそろそろ終わりだねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_020023520002" ]},
		{"command":[ "SETCHARA", "0", "char_00002502_01", "5", "CENTER", "400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SPOTCHARA", "1"]},
		{"command":[ "SETTEXT", "「今年は～……あまり活躍できんかったなぁ。暗躍は色々としていたのじゃが\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010023520003" ]},
		{"command":[ "SETCHARA", "1", "char_00000701_01", "6", "CENTER", "-400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「なかなか様子を見に行けんから……カツマら……。いや、みんなが今、どう\nしているのかもわからんのじゃよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010023520004" ]},
		{"command":[ "SETCHARA", "1", "char_00000701_01", "8", "CENTER", "-400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SPOTCHARA", "0"]},
		{"command":[ "SETTEXT", "「あいつらは……皆、元気にしているよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_020023520003" ]},
		{"command":[ "SETCHARA", "0", "char_00002502_01", "6", "CENTER", "400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SPOTCHARA", "1"]},
		{"command":[ "SETTEXT", "「うぅ～、我ながら余が死んだという設定は、ちょ～っと裏目に出てしまった\nかものう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010023520005" ]},
		{"command":[ "SETCHARA", "1", "char_00000701_01", "4", "CENTER", "-400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「はぁ……。余の事など、みんな忘れているんじゃろうな……」　　", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010023520006" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SPOTCHARA", "0"]},
		{"command":[ "SETTEXT", "「まさか。あんたの存在は、全員の心に深く刻まれていると思うよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_020023520004" ]},
		{"command":[ "SETCHARA", "0", "char_00002502_01", "8", "CENTER", "400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SPOTCHARA", "1"]},
		{"command":[ "SETTEXT", "「それは……そうじゃろうが。ぬうう……それだけでは物足りん！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010023520007" ]},
		{"command":[ "SETCHARA", "1", "char_00000701_01", "1", "CENTER", "-400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「……そろそろ余の事を、思い出させてやろうかの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010023520008" ]},
		{"command":[ "SETCHARA", "1", "char_00000701_01", "6", "CENTER", "-400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SPOTCHARA", "0"]},
		{"command":[ "SETTEXT", "「と、言うと？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_020023520005" ]},
		{"command":[ "SETCHARA", "0", "char_00002502_01", "3", "CENTER", "400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SPOTCHARA", "1"]},
		{"command":[ "SETTEXT", "「少々、計画しておることがあってな……。ひそひそひそ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010023520009" ]},
		{"command":[ "SETCHARA", "1", "char_00000701_01", "6", "CENTER", "-400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SPOTCHARA", "0"]},
		{"command":[ "SETTEXT", "「おお！　それは良いじゃないか。それならもっと……。ひそひそひそ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_020023520006" ]},
		{"command":[ "SETCHARA", "0", "char_00002502_01", "8", "CENTER", "400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
		{"command":[ "SETIMAGE", "0", "bg_0014" ]},
		{"command":[ "SETTEXT", "そんなやりとりが交わされた、次の日。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "俺は、大戸岐学園の廊下で鼻歌を歌いながらスキップしているルルーナを見か\nけた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「ふんふんふ～ん♪　ふんふんふーん♪　ク～リス～マス～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_060023520001" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……めちゃくちゃ上機嫌だな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "ルルーナはだんだんこちらに近づいてきて、そのままドンッ！　と俺にぶつか\nってくる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ぐぇええええっ！？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "激しく吹っ飛ばされた俺とは対照的に、ルルーナは身じろぎ１つしていない。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「な、なんなんですか、一体……！？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「あら……失礼。まったく気が付きませんでしたわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_060023520002" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「ところで……サンタって実在すると思いますか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_060023520003" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「唐突になんだ！！？　サンタなんていないですよ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「ふふふっ。残念でしたね、私こそがサンタなのです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_060023520004" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ぶつかって頭でも打ったんですか！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "そんなやり取りをしていると、鼻歌でクリスマスソングを歌いながらスキップ\nをしていた明日楽が俺にぶつかってきた。", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「どぉうぇええええええっ！？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "先ほどのルルーナより格段に強い衝撃が全身に走る。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「あら、あなたでしたか。すみません、うっかり気づかず。」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020023520001" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "（少しぶつかったくらいで、どんなフィジカルしてんだよ……！）", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うぅ……。揃いも揃って不注意が過ぎるぞ。どうしたんだよ、一体……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「カツマ先生は、サンタが実在すると思いますか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020023520002" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「げっ。一体どうしたんだ、この質問……２人目だぞ？　いません！　サンタ\nなんかいません！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いくらクリスマス直前だからって……。２人とも、洗脳されてるんじゃない\nか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「あらあら。この人ったら、この年でまだサンタがいないって信じているみた\nいですわね、信じられませんわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_060023520005" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「誰も本当のことを教えてくれなかったんでしょうか……？　フフ、可哀想に\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020023520003" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「今時、子どもでも知っていることですのに。うふふふっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_060023520006" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……なんで俺が嘲笑される流れになってんだ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「だってあなたが、あまりにもおかしなことを言うから。笑いが止まらなくて\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_060023520007" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「そうですよ。サンタがいないだなんて……誰に言っても笑われますよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020023520004" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「えええええ……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "俺が呆然としていると、校内放送が聞こえてきた。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "校内放送" ]},
		{"command":[ "SETTEXT", "「カツマ先生とジュンジローさん、至急学園長室までお越しください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020023520001" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はぁ？　呼び出し……？　なんだ、今日はまだ何もヘマなんかしちゃいない\nぞ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "嘆く俺の足元に、ひょっこりジュンジローが現れた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「いつも、何で呼び出されているか悲しいほどによくわかる台詞ですぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023520001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うるせえ！　でも、まあ呼ばれたからにはいかなきゃいけない……のか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "はっきり言って逃げ出したいところだが、このままここにいて、ルルーナと明\n日楽にからかわれているのも気味が悪い。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……行くか」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「その方が良さそうですな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023520002" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "というわけで、俺達はしぶしぶ学園長室に向かったのだった。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0127" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……で、何の御用ですか。学園長」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「サンタは実在すると思いますか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020023520002" ]},
		{"command":[ "SETCHARA", "0", "char_00002602_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ひぃっ！　ま、待ってくれ……。さすがにこれはおかしいだろ、なあ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「新しい宗教の勧誘か何かか！？　それとも俺への嫌がらせか！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「まあまあまあ。落ち着いて、私の話を聞いてください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020023520003" ]},
		{"command":[ "SETCHARA", "0", "char_00002602_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「この学園では、毎年地域貢献のためにクリスマスの時期にパトロールを行っ\nていることは知っていますね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020023520004" ]},
		{"command":[ "SETCHARA", "0", "char_00002602_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああ……。そういえば、そんな話を前にもされたような……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「はい。今年は、北の国からレジェンドサンタの助手の『サンタガール』さん\nが来日して、お手伝いをしてくださるそうなんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020023520005" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「サンタガール……？　またあやしい名前が飛び出してきたぞ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「サンタガールさんは、生前のルナルバース陛下と古くからの知り合いだった\nそうで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020023520006" ]},
		{"command":[ "SETCHARA", "0", "char_00002602_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「パトロールの後に、陛下がグレート・ルナリアムのために遺したクリスマス\nプレゼントを配りたいそうで、人手が欲しいとおっしゃっているんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020023520007" ]},
		{"command":[ "SETCHARA", "0", "char_00002602_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「へえ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「それで、サンタガールさんは、そのお手伝いをルナテミスさんと修羅姫さん\nに依頼したとのことでした」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020023520008" ]},
		{"command":[ "SETCHARA", "0", "char_00002602_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なるほど。それで、さっきルルーナと明日楽がサンタはいるって言ってたの\nか……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "サンタ本人ではないものの、サンタガールから直々に依頼が来たなら、そりゃ\nあサンタがいるってことになるのかもしれない。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "（とはいえ、レジェンドサンタにサンタガール、陛下の遺産とあやしいワード\nがてんこもりだな）", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「それで、貴方をここに呼び出した理由なのですが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020023520009" ]},
		{"command":[ "SETCHARA", "0", "char_00002602_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ようは俺とジュンジローに、サンタガールの手伝いをしろ……ってことです\nよね？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「おおむね正解です。正しくは、サンタガールのお手伝いのルナテミスさんと\n修羅姫さんのお手伝いですが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020023520010" ]},
		{"command":[ "SETCHARA", "0", "char_00002602_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「手伝いの手伝いですか……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "がっくりと肩を落とした俺に、さらにジュンジローが追い打ちをかけてきた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「サンタガールもサンタの助手ですぞ？　つまり、手伝いの手伝いの手伝いで\nすな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023520003" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「俺はどんっだけ下っ端なんだよ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}