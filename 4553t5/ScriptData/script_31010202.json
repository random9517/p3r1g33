		{"command":[ "PLAYVOICE", "v2_101_0204307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「つまり！　私の成績が、めちゃんこ悪過ぎたおかげで、ん、んん、こんなに\n気持ちいいことが、出来たんです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0204308" ]},
