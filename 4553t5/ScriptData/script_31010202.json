		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「んひぃぃぃぃぃ！？　あ、あはぁ……ひゃうぅぅん……出されてる……あ、\nああ、すごぉい……いっぱい、出てるぅ……」", "NORMAL" ]},
