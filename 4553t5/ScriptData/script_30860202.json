		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「あんっ♪　んんっ……まだこんなにも残りの汁を隠し持っていたのですねっ\n……！　今回はもう、一滴も残してはなりませんよ、いいですねっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0204402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「ああっ……♪　あああっ……♪　二度目の射精でも変わらないこの臭い、こ\nれに包まれると……幸福感でクラクラしてしまいます……！　ふぁぁっ♪」", "NORMAL" ]},
