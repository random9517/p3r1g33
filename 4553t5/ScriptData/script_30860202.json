{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0046" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「……良かった。ここにいたのですね。はぁっ、はぁっ……さ、先ほどの戦い\nの後……どうしても興奮がおさまらなくて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0204101" ]},
		{"command":[ "SETCHARA", "0", "char_00008602_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「貴方を探していたんです。ああ、良かった。他のニンゲンではだめなのです\n。貴方でないと……こんなはしたないことは頼めません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0204102" ]},
		{"command":[ "SETCHARA", "0", "char_00008602_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「お願いです。どうか、この森の中で私を抱いてください。そうしないと、も\nう……疼きが、どうしても収まらないのです……っ！　はぁ、はぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0204103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「ここはハイエルフ達の憩いの場。仲間がいつ来るかもしれません。ですから\n早く……私を満たしてください。この熱を発散させてほしいの……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0204104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「あっ……♪　み、見えますか……？　私のここが火照って、潤んでいること\nが……。さっきからずっと、ここが熱くてたまらなくて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0204105" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00008602_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「戦えば戦うほど、ジンジン痺れて、どうにもならなくなってしまったんです\n……。っふぅっ……す、すごく濡れてしまっていますよね？　んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0204106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「あ、貴方の吐息が、鼻息が粘膜に触れてくすぐったい……。わ……わかりま\nすよね？　私が何をしてほしいのか。疼きを鎮めるには何が有効か」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0204107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「ですから、愛撫と挿入をお願い……したいのですが。……んっ？　な、なぜ\n、まじまじ見つめるだけで何もしてこないのですか……？　ううっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0204108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「花弁が充血して、陰唇がぷっくり腫れてきているんです。ク……クリトリス\nもずっと勃起したままで。一人でいじっても、どうにもならなくて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0204109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「んぅっ！？　な、なんです突然！　肉棒を取り出して、見せつけて焦らすだ\nけだなんて！　貴方のモノが立派なことはもうわかっています！　あ、あの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0204110" ]},
		{"command":[ "SETIMAGE", "0", "still_00008602_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「それを……！　ここに、このピンク色の穴の奥に……っ。ねえっ、どうして\n意地悪をするのですか？　え？　おねだりをしないとあげない、ですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0204111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「おねだり……？　バカを言わないでください！　私は由緒正しきハイエルフ\nの……！　と、本気でおあずけを続けるつもりですか！　く、くぅう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0204112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「わかり……ました。願い乞います。えっと……おちんぽ……。ニンゲン様の\n、逞しく赤黒く光輝くその聖なる剣を、わ、私、私の卑しいおまんこに」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0204113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「ぐちょぐちょに濡れたハイエルフまんこに挿入してください！　そして！　\nめちゃくちゃにかきまわしてほし……。んっ！？　んんんっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0204114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「きゃ、あッ……♪　んああああああっ♪　いっ、いきなり挿入っ、ですか！\n？　確かに私がお誘いしましたけど……！　あッ！？　あっあっあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0204115" ]},
		{"command":[ "SETIMAGE", "0", "still_00008602_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「ダ、メ！　油断していたから……入れられただけで絶頂してしまいます！　\nあああっ！　恥ずかしいッ、いやぁっ、み、見ないでくださいいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0204116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「あっ、ああああああぁっ！　イって……っ！　私、おちんぽ挿入されただけ\nでこんなに感じて！　いやっ、やぁっ、おかしくなってしまいますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0204117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「んあああああっ……！　はぅっ！？　あっ！？　お、おやめなさいっ！　絶\n頂中に激しくピストンを始めるなんて！　マナー違反……んああああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0204118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「やぁっ♪　気持ち、イイっ……！　ちんぽ♪　ちんぽすご……いぃ♪　大き\nい……！　あッ、あぁ、私、私が悪かったです、やめ……ないでっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0204119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「そのままっ……突いて、突き上げてくださ……いぃっ！？　イッ……！　あ\nっ♪　突かれるたびに絶頂の波が……あっ！？　あっあっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0204120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「乱暴にされるなんて……プライドが許さないはず、なのに……んぁあっ♪　\nそれが心地いい……！　屈服させられて♪　従順なメスとしてっ♪　あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0204121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「貴方のおちんぽに酔いしれているこの瞬間が……ああああっ♪　気持ち良す\nぎて腰が砕けてしまいそうっ……！　絶対にやめないでくださいぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0204122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「あ～っ♪　あっぁっあっ！　ご、ごめんなさい……！　中、窮屈でしょうっ\n……勝手に締まってしまうんです、おちんぽ締めつけてしまうんですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0204123" ]},
		{"command":[ "SETIMAGE", "0", "still_00008602_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「あああっ！　いけないことなのに！　おまんこが勝手にオチンポを欲しがっ\nて……！　あふっ！　自分が自分でないみたいに感じます……ぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0204124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「やっ♪　こ、このままでは精液が中に出てしまう……ですか？　そ、そんな\nことわかっています……子種を直接受け取れば、妊娠の可能性も……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0204125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「はっきりそれを理解しているのに……それでも止めてほしくないんです！　\nあうっ！　今やめられたら、私……ヘンになってしまいます、ですからっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0204126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「ピストンっ！　やめないで、このまま続けて中に出してください！　精子！\n　貴方の粘り気の強い精液を、私の膣奥……子宮で飲み干したいのですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0204127" ]},
		{"command":[ "SETIMAGE", "0", "still_00008602_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「んんんんっ♪　んん～ッ♪　んんっ、んぅうう～～～っ♪　中出し♪　エル\nフの私に無慈悲な中出し射精♪　射精……精液♪　おちんぽから精液♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0204128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「ほ……しい♪　あぁっ♪　どうしても貴方の精液が欲しいです……！　この\n中に、おまんこいっぱいに赤ちゃんの種を撒かれると思うと……あああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0204129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「ゾクゾクして♪　身体が歓喜しているのがわかります！　もう気付いている\nでしょう！？　大好きな貴方の精子が欲しいんですっ、赤ちゃん欲しいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0204130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「ずーっとずーっと望んでいるんですっ！　貴方に……強引に抱かれて、誰に\nも見られたことすらない清らかなおまんこを開発、されて……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0204131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「無理やり犯されて孕みたかったのです！　っぅうっ♪　おちんぽ、また太く\nなりました……貴方も、出したいですよね？　ぶちまけたいですよねっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0204132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「お願いします……！　いやらしいハイエルフの私を、エアルミンを貴方だけ\nの女にしてください、貴方の色に染めて……！　んっ、うううっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0204133" ]},
		{"command":[ "SETIMAGE", "0", "still_00008602_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「嫌だと言っても♪　あっ、もう離しませんっ！　おちんぽにゅるにゅるシゴ\nいて絞って……無理やりにでも摂取したい！　ください……くださいぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0204134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「あ……ッ♪　精液♪　せいえきぃい……！　んぁあああっ♪　だいしゅきな\n貴方のぉ……赤ちゃんの種ぇ……！　熱い……それにたっぷりとぉおっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0204135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「うれ、しい……嬉しいぃっ！　あぁっ！　絶頂しますっ！　射精の最中に貪\n欲に絶頂するエルフで申し訳ありませんんっ！　イキます！　んうううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0204136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「ああああああッ♪　ああ～っ♪　あぁあああんっ♪　好き♪　好きぃ♪　ど\nうか受精して……！　あのっ、もっと、もっと出してくだひゃいぃっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0204137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「腰を掴んで、一番奥で射精して……！　おっ♪　おッぉっ♪　そうです、そ\n……こっ！　そこが子宮口、です、そこに注ぎ込むのですうううっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0204138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「んっく……っ♪　くふぅううう……っ！　ドクドクと脈打つおちんぽから、\n無限に精液が射出されて……イキ終わることすら出来ないなんて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0204139" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00008602_02_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「あっ♪　貴方を選んで正解でした……っ！　貴方だけです、私をこんなにも\n満たしてくれるのは……あぁっ♪　好き……好きっ……んうっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0204140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「ふぁああああ……♪　ようやく出し終わりましたか……。ええ、わかります\n。感じます……子宮口がべっとりとした体液で塞がれているのが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0204201" ]},
		{"command":[ "SETIMAGE", "0", "still_00008602_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「こんな量を受け止めたのですから、妊娠……しているでしょうね。でも、私\nは後悔しません。この子は大切に森で……って、ひゃんっ！？　何です！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0204202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「あくぅっ♪　んっうっ！？　いやです……っ♪　あっあっ、おちんぽ、まっ\nたく萎えていなくて……あっ！　あっ、腰をなおも動かすですって！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0204203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「あッ！？　いやっ♪　精液で満ちたおまんこを♪　ガチガチのおちんぽがえ\nぐってるっ！　ウソ……っ♪　ウソです、こんなに硬いままだなんてぇっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0204204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「う……動いていいだなんて許可、していませんよっ……♪　それなのに……\nあぁ♪　あぁああっ♪　激しい……！　奥っ、突かれてますっ！　ううっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0204205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「んぁうううっ♪　あああぁうううっ♪　こんな、こんなの……っ♪　耐えら\nれません、私だって……したい、もっとしたい……あっあっあっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0204206" ]},
		{"command":[ "SETIMAGE", "0", "still_00008602_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「待ってくださ、いぃ♪　私も腰を揺らし、ますっ♪　ん～っ、あうっ♪　ん\nんんっ……ああんんっ！？　すご……い、これキくぅ♪　おっぉっおっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0204207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「快感の波が、ずっとやまないっ……！　ああっ！　おちんぽが、おちんぽが\n先程の精液を掻き出して……新しい精液を注入しようと蠢いているぅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0204208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「あーっ♪　あっぁっあっ♪　壊れてしまい、ますぅ……！　優しくぅ……！\n　あっ♪　そうでした、お尻を振っているのは私、です……っ、あぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0204209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「イキ癖がついてしまって♪　途中でやめられないんですっ……！　あっ！　\nずうっと、ずうっとおちんぽを感じていたい……あぁ、太いぃ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0204210" ]},
		{"command":[ "SETIMAGE", "0", "still_00008602_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「んぁああっ♪　イキすぎておまんこの中が麻痺してもっ♪　角度を変えてこ\nすれば……！　ふぁあああああぁ♪　すぐ、また気持ち良く……ぅうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0204211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「あっ♪　うっ♪　気持ちいいっ……！　気持ちいいぃ……！　快楽に溺れて\n腰をくねらせる私を、よーく見てくださ、いっ♪　見て……ぇっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0204212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「ハイエルフはっ♪　高貴なる存在なのに……！　あうっ♪　おうっ♪　んう\nっ♪　清らかな森の民、性欲の薄い種族のはず、なのにぃっ！　おっおっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0204213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「私だけどうかしてしまいました♪　おちんぽを愛してしまいました♪　んん\n～～～っ♪　このゴリゴリ♪　どっちゅどっちゅ突かれるのがいいっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0204214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「必死になっておまんこをうねらせて……あああっ♪　貴方の硬いおちんぽに\nお仕えするたびに知らなかった快感に震えてしまいます……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0204215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「ご奉仕♪　気持ちいいんですっ！　おちんぽにおまんこで奉仕するのが私達\nハイエルフのお役目♪　みんなにも♪　教えてあげないと♪　っん～～っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0204216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「こんなに気持ちいいこと♪　私だけで独占するなんて許されません……！　\nねえっ、みんなにもしてあげてくださいね！　子作り……ああああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0204217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「でも！　今は、今だけは私だけの専用ちんぽです……！　あぁあ♪　トロト\nロになって貴方のこわばりを受け止めている私のおまんこ……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0204218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「優しく、あたたかく締めつけて絞り上げますからっ！　どうかもう一度……\n私だけにお慈悲をくださいませ！　あぁ、精子、精子が欲しいのです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0204219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「一番奥に……ッ♪　あっぁっふぁああっ……！　数日間は忘れられないよう\nな、強烈な射精をください！　締めますよ！　っんっ、んんんんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0204220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「あ……♪♪　うぁあああっ♪　あああああっ♪　射精の勢いっ……♪　勢い\nがすごすぎて腰が、浮いて……ッ！　あああああっ、すごいぃいっ♪」", "NORMAL" ]},
