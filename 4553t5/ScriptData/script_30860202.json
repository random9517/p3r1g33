		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00008602_02_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「んあはぁああっ♪　びゅくっ、ぶびゅくっと何度も何度も、おちんぽが痙攣\nして……！　子宮にこってりした精液が……！　次々にぃ……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0204302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「一度目にあれだけ射出したというのに、貴方という人はっ……♪　そんなに\n私を、ハイエルフを妊娠させたいのですね♪　望むところですっ、くぅうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0204303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「いいでしょうっ……♪　貴方の種で妊娠、しますっ……♪　あああっ、ここ\nまで強力な精液を持つ男が父親、ならば……強い子が受精出来ますっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0204304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「あ、あ、あ、あ……ッ♪　もう逃がしませんよ……！　限界まで、おちんぽ\n絞って、精子を奪い尽くしてさしあげましょう……！　それ、それそれぇっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0204305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「っんんんんん……！　尿道に残った分の精液までもが、私の子宮にっ……♪\n　きっと、私の卵子すら……すぐに攻め落とされてしまうはず……ぅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0204306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「あ……♪　あ……♪　妊娠が……、受精がここまで気持ちいいだなんて……\n♪　やめられなくなってしまいそうです……♪　んぁっあっぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0204307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「私、は……♪　清楚なハイエルフだったはず、なのに♪　戦えば股を濡らし\nてしまい、抱かれれば子を孕みたがってしまう……♪　これではまるで」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0204308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「変態淫乱ハイエルフではありませんか……♪　でも……でも、もうそれでい\nい……♪　貴方の精に支配されるのなら、他には何も必要ない……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0204309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「んぁああ……♪　今日も明日も……頼めば抱いてくれ、ますか？　妊娠確定\nするまで、何度でもしたい……♪　したいのです……っ♪」", "NORMAL" ]},
