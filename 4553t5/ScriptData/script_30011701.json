{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000117_01_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「んっ、よいしょ……えぇと……こんな感じで大丈夫……でしょうか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1703101" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「はぁぁ……んっ、貴方のオチンポさんが……すっかり勃起しきってます……\nんふっ、おっぱいに入り切らない位です……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1703102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「でも、こうやって……んっ、寄せてあげたら……何とか、包み込める感じで\nすね……はふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1703103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「えっと……気持ちいいですか？　ふふっ、よかったです……その、今日は…\n…日頃お世話になっているお礼と言ってはなんですが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1703104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「わ、私のおっぱいを使って……その、パイズリで……ご、ご奉仕させて頂け\nたらな……と。ご迷惑じゃ……ありませんか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1703105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「大丈夫ですか。はい、そう言って頂けると安心です。その、色々と拙い所も\nあるかと思いますけど、一生懸命頑張りますから……よろしくお願いします」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1703106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「で、では、早速……オチンポ……扱かせて頂きますね。あ……もし、こうし\nて欲しいとか……ご希望はありますか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1703107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「はい、最初はお任せで……はい、お任せされました。頑張っていきます……\nんっ、ふっ、んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1703108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「それでは、まず……オーソドックスに……上下に、動かして行きますね……\nんっ、んしょっ、んっ、ふっ……はっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1703109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あぁ……改めて、立派なオチンポだって実感出来ますね……おっぱいの中で\n……存在感がすごいです……んっ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1703110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「とても大きくて……熱くて、とくとく……脈を打っていて……硬さと柔らか\nさが共存していて……男の人の匂いがして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1703111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あぁ……自分にない場所ですから……とても不思議な感じがします……でも\n、こんなに立派なのに……可愛い感じもして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1703112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あ、ごめんなさい……口ばっかり動かしてもダメですよね……ちゃんと、ん\nっ、おっぱいを動かして行かないと……んふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1703113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「はっ、あっ、ふっ、んくっ、んふっ……どうですか？　こんな感じで……大\n丈夫でしょうか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1703114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「えっと、皮の部分を、痛くならないように……捲り返してあげるようにする\nといいんですよね……んっ、んっ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1703115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「ちゃんと出来てるか分からないですけど……大体、こんな感じ……でしょう\nか……はっ、んふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1703116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あっ、オチンポが震えました……この感じでよさそうですね……んっ、んし\nょっ、んっ、はっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1703117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「はだけちゃってますけど……んっ、このスーツ姿だと……ちょっと気分も違\nって来る気がしますね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1703118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「ちょっと非日常的というか……本当は任務とか……使命とか……そんなもの\nがある筈なのに……いけないことをしてしまってるような……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1703119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「けど、それが……とてもドキドキして……あっ、はっ、んっ……何だか、興\n奮してきちゃいます……私、いやらしい気分なんです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1703120" ]},
		{"command":[ "SETIMAGE", "0", "still_00000117_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「んっ、んふっ、あっ、はふっ……んくっ、もうちょっと滑る方がいいですよ\nね……んっ、唾液……垂らしちゃいますね……んれろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1703121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「んちゅぷ……こんな感じで……もっとしてみます……んっ、ふっ、あぁ……\nさっきより、くちゅって……よく滑るようになりました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1703122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ、ぎゅうっと押し潰して……んっ、軽い円を描くような感じで…\n…あっ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1703123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「え……？　おっぱいの形が……すごく、いやらしい……？　あっ、あぅっ…\n…そ、そのように言われると……は、恥ずかしいです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1703124" ]},
		{"command":[ "SETIMAGE", "0", "still_00000117_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あ……も、申し訳ありません。ちゃんと続けます……んっ、はい、動きも大\nきくして……んっ、ひしゃげさせちゃいます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1703125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「んんっ……あぁぁ……はぁ、オチンポ……いっぱいに感じます……あぁっ、\nちょっと腰が動いて……んっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1703126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「い、いえ、ダメじゃないです……でも、最初は……私のご奉仕で気持ちよく\nなって頂きたいので……犯すのは程々にして頂けると……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1703127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「はい、ちゃんといっぱい出して頂けるように頑張りますので……んっ、はぁ\nっ、うんっ、んくっ、あっ、ふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1703128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「どうですか……？　私のおっぱい……感じてくださってますか？　オチンポ\n……気持ちいいですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1703129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「はい……私も、んっ、ドキドキして……気持ち……いいです……乳首……硬\nくなって来ちゃってますぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1703130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あぁっ、はい……硬くなった乳首も、オチンポに重ねます……はぁんっ、敏\n感になってるの……んっ、いいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1703131" ]},
		{"command":[ "SETIMAGE", "0", "still_00000117_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あふっ……オチンポも感じてくれてますね……小刻みに震えてるの……おっ\nぱいで分かります……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1703132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「んふっ、先端から我慢汁も浮いて来ました……いいんですよ、そんなに我慢\nしなくても……出しちゃっていいんですから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1703133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「私は……んっ、その為に……おっぱいでご奉仕しているんです……はぁんっ\n、射精して……オチンポミルク……ぴゅっぴゅって……出して下さいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1703134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「はぁんっ、はいっ、このまま……おっぱいの中にっ……思いっきり……はん\nっ、あっ、あぁっ、はぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1703135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あぁっ！　いっぱい出てます……んんっ、おっぱいが、どんどんドロドロに\nさせられて……んふっ、精液のヌルヌルがいっぱい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1703136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000117_01_03" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「はぁぁぁ……んんっ、オチンポビクビクしながら射精してる……間近で見る\nと、かなり迫力がありますね……じぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1703137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あ……ふふっ、亀頭を覗かれるの恥ずかしいですか？　すみません、つい…\n…でも、見入っちゃって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1703138" ]},
		{"command":[ "SETIMAGE", "0", "still_00000117_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「落ち着いてきましたね……いっぱい出してくれてありがとうございました…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1703139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「はい、レイジョーモモのご奉仕……無事に成功したようで、何よりです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1703140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あぁ……ネバネバしてる……でも、この滑る感じがまた……変な気分になっ\nて来ますね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1703201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「その……ええと、差し支えなければ……このまま続きをしてもいいですか？\n　はい、もっと気持ちよく射精してもらえるように、頑張ります」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1703202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「んっ、んふっ……っしょ……うんっ、んっ、はっ……あぁ……さっきよりも\n、ぬめぬめして……おっぱいへの感触が変わって来ています……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1703203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「んんっ！　お肌……全体がじんわり……痺れているような……あんっ、すご\nく不思議な感じがして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1703204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「はい、今度はお好きに動いて頂いても大丈夫です……私のおっぱい……道具\nのように使って、気持ちよくなって下さい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1703205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あふっ……んっ！　遠慮されることはありませんよ……私も、もっと貪欲に\n動いて……んくっ、おっぱい……気持ちよくなっていきますから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1703206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「オチンポとおっぱい……ずっと擦り合わせて……まるでセックスしてるみた\nいに……はぁんっ、二人の気持ちを……高めあっていきましょう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1703207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あっ、んんっ！　はぁっ……すごく、ドキドキしますね……敏感な場所同士\nが……こんなに密着して……んっ、ふっ……はぁっ、んっ……ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1703208" ]},
		{"command":[ "SETIMAGE", "0", "still_00000117_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「くすっ……先端……くすぐったいですか？　ごめんなさい、私の息が掛かっ\nちゃって……どうしても、呼吸が乱れてしまいますね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1703209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「でも、貴方の方も同じ……呼吸が乱れてるのが、すぐ近くで伝わってきます\n……おっぱいの中の感触で、興奮してくれてるんですよね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1703210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「はい、私も……いつも以上に興奮しています……この衣装で、いけないこと\nをしているのに……止められないで……んぁ……はぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1703211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あぁ……オチンポと乳首……あひっ！　そこっ、あっ、ぐにゅって潰れてっ\n……は、ひぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1703212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あぁっ、そんなに……先っぽ、押し付けられたらっ……んくぅっ、あふんっ\n、あぁっ、もっと乳首……硬くなってしまいますっ、あんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1703213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「んっ、私も……もっと……頑張らないと……はぁっ、んっ、あふぁっ……オ\nチンポ、もっと揉みくちゃにして……あっ、はぁんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1703214" ]},
		{"command":[ "SETIMAGE", "0", "still_00000117_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「んんっ…ぎゅうって……押し付けて……はひっ、このまま腰を振って下さい\nっ……あぁっ、はいっ、おっぱい犯してっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1703215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あぁっ、はぁんっ、おっぱいが……オマンコみたいにされてますっ……ずり\nゅずりゅっ、擦れてっ……気持ちっ……いいですぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1703216" ]},
		{"command":[ "SETIMAGE", "0", "still_00000117_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「はひっ、あぁっ、んっ、はいっ……もっとして下さいっ……ずりゅずりゅっ\n、擦りつけてっ……はふぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1703217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あん、あぁっ……いいですっ、んんっ、私がご奉仕したいのに……おっぱい\n、どんどん気持ちよくなって……あっ、はぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1703218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「貴方も……そろそろ限界……ですかっ？　んっ、はいっ、分かります……幹\nが……ビクビク震えてっ、近づいてるのっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1703219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「んんっ、あぁっ、このまま一緒にイキたいですっ、んんっ、おっぱいとオチ\nンポ……一緒にっ、あぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1703220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「はっ、んっ、あふっ……もう一回、おっぱいに中出し……大丈夫ですっ……\n掛けて下さいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1703301" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「んぁぅっ！　あっ、あふぁっ……いっぱい出てる……さっきより、もっと白\nいの……びゅくびゅく……出てます……んんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1703302" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000117_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あぁん……おっぱいが熱い……私のおっぱい……沢山精液浴びて……すごく\n喜んじゃってます……はぁぁぁ……あふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1703303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あっ……まだオチンポ出そうですか？　残さないで、ちゃんと出し切っちゃ\nって下さいね……このスーツもどうせクリーニングしますから遠慮なさらない\nで」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1703304" ]},
		{"command":[ "SETIMAGE", "0", "still_00000117_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「んっ！　ふふっ、すごい……まだこんなに残ってたんですね……元気なオチ\nンポさん……本当に逞しいです……んぁふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1703305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あぁ……終わっちゃいました……んっ、少し名残惜しいですね……あ、オチ\nンポの先端についてる分……全部おっぱいに擦り付けて下さい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1703306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「んぁふっ、ちょっとくすぐったいです……んふっ、でも……いい気持ち……\nはぁん……あぁ、ありがとうございます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1703307" ]},
		{"command":[ "SETIMAGE", "0", "still_00000117_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「ちゃんと全部出してくれました……私のおっぱい……ご満足頂けましたか…\n…？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1703308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「ふふ、直接そういうお言葉が聞けてよかったです。レイジョーモモとしての\nご奉仕……普段より、ちょっと大胆に出来たかも知れません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1703309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「これからも、貴方と一緒に戦っていく……そんな気持ちになれた気がします\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1703310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あんっ、はぁんっ、顔に……出したいんですね？　もちろん……いいですっ\n、貴方の好きなように……出して下さいっ……んぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1703401" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「はふっ！　んんっ……！　あぁっ、ネバネバ……いっぱい出てるっ……！　\n顔に……シャワーされてますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1703402" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000117_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「んぁぁ……２発目なのに……まだ、こんなに……頬がねっとりしちゃってま\nす……んふぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1703403" ]},
		{"command":[ "SETIMAGE", "0", "still_00000117_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「まだ、先端がヒクヒクしてます……どうしましょう、ちょっと舐めたりした\n方がいいですか？　ひゃうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1703404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「んっ！　あふっ……舐める前に出ちゃいましたね……ちゅぱっ、いえ……大\n丈夫です、ちゃんと全部出しちゃって下さいね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1703405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「残さず顔に……はい、オチンポについてるのも……擦り付けて下さい……あ\nぁ……あったかい先端……感じます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1703406" ]},
		{"command":[ "SETIMAGE", "0", "still_00000117_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「んふっ……あぁ……大丈夫そうですか？　全部出してくれてありがとうござ\nいます……んちゅ、失礼します……綺麗にしちゃいますね……ぴちゃ……」", "NORMAL" ]},
