		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「はい、これで大丈夫ですよ。いかがでしたか……ちゃんと、私のおっぱい…\n…ご満足頂けましたか？」", "NORMAL" ]},
