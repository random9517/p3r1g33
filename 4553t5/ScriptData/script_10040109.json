{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0108" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「来てしまったぜ……またここに」", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「さようですな。ご主人は気に入らないことがあると、すぐいじけて競艇に逃\n避するくせがありますな。４８の悪いくせのひとつですな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020116470001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うるせーっつーの！　今度こそ隊長辞める！　辞めてやる！　どうせ俺なん\nか必要ねえんだからな！　ふんっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「それで？　また舟券拾いの才能を活かして、地見師（じみし）になろうとで\nもおっしゃるのですかな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020116470002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ふっ、さすがにオレも成長したぜ。そんな夢物語みたいなことはもう言わね\nえ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「では、隊長を辞めてどうなさるので？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020116470003" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうだな、提督かトレーナーにでも転職しようかと……今日はそれをゆっく\nり考えるためにここに――」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「いた！　カツマ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010116470001" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「やっぱりここでしたか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010116470001" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「げえっ！　カグヤにまりあ！？　どうしてここがわかった！？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "400" ]},
		{"command":[ "SETCHARA", "1", "char_00001401_01", "3", "CENTER", "-400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「いつものことだし、わからないわけがない。むしろ、ここ以外を探す理由が\nない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010116470002" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "7", "CENTER", "400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "1" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「カツマさんがいじけて、本部に出てこなかったら絶対ここに来てますからね\n。だから、迷わずここに直行しました！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010116470002" ]},
		{"command":[ "SETCHARA", "1", "char_00001401_01", "6", "CENTER", "-400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「な、なんてこった……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「まあ、当然の結果ですな。お２人は、ご主人を連れ戻しに来られたので？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020116470004" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「え……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010116470003" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "400" ]},
		{"command":[ "SETCHARA", "1", "char_00001401_01", "0", "CENTER", "-400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "1" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「そ、それは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010116470003" ]},
		{"command":[ "SETCHARA", "1", "char_00001401_01", "1", "CENTER", "-400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「おやおや、それではどうしてここに？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020116470005" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「……カツマが……隊長を辞めたいというのなら……それはそれでかまわない\n。生活の心配は……いらない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010116470004" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "1", "CENTER", "400" ]},
		{"command":[ "SETCHARA", "1", "char_00001401_01", "0", "CENTER", "-400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「どういうことだ？　もしかして、転職先の心当たりでもあるのか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ううん、そうじゃない。カツマの面倒は、わたしが……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010116470005" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "2", "CENTER", "400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "1" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ちょっと待ちなさい！　なんであなたが面倒を見るの！？　カツマさんは私\nの扶養家族にするんだから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010116470004" ]},
		{"command":[ "SETCHARA", "1", "char_00001401_01", "7", "CENTER", "-400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ダメ！　そうはいかない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010116470006" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "7", "CENTER", "400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "1" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「私だって！　……どうやらここは、お互い１歩も引けないみたいね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010116470005" ]},
		{"command":[ "SETCHARA", "1", "char_00001401_01", "7", "CENTER", "-400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「もちろん。と、いうことはここで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010116470007" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "7", "CENTER", "400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "1" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ええ、共闘はおしまいね！　決着をつけようじゃない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010116470006" ]},
		{"command":[ "SETCHARA", "1", "char_00001401_01", "7", "CENTER", "-400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "1","0" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「って！　なんなんだよ！　なんでいきなりここでケンカを始めるわけ！？　\nやめなさいって！　おーい！　２人ともやめろーっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}