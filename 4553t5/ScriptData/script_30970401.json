{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009704_01_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「へへっ。相変わらずいい形と臭いのするモン持ってやがるな。嗅いでるだけ\nで、アソコが濡れてきちまうぜ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0403101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「軽く挟んでるだけなのに、おっぱいの中でビクビク跳ねて来るし……私に弄\nってもらえるのが、嬉しくてたまらねぇって感じだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0403102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「……おいおい。何でそんなイヤそうな顔してんだよ。これはおまえへのご褒\n美なんだぜ？　もっと悦んだらどうなんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0403103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「こんなこと望んでない？　ご褒美なら、もっと違うことの方がいい？　はっ\n！　んなこと知らねぇよ。私は私のしたいことをするだけだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0403104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「それに口では嫌がってても、こっちはやる気みたいだぜ。こうして指で軽く\n弄ってやるだけで……んっ……！　メチャクチャ震えまくるじゃねぇか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0403105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「こりゃ随分と弄りがいがありそうだな。たっぷり可愛がってやるから、気を\n失わないように気合入れとけよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0403106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「んっ、あっ……ふっ、あっ……！　どうだ、私のおっぱいの感触は……！　\n柔らかくて、サイコーにクレイジーだろ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0403107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「こうやってカリの部分に圧をかけながらシコシコすると……んんっ……！　\n谷間の中で熱いのが脈打ってくるぜ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0403108" ]},
		{"command":[ "SETIMAGE", "0", "still_00009704_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「だが、今日はパイズリだけじゃねぇぞ。さっきみたいに、指でもいっぱい可\n愛がってやるからな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0403109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「あぁん？　パイズリしながら指で可愛がるのが、どういう意味がわからない\n？　へへっ！　安心しろ。今からたっぷりと教えてやるからよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0403110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「あははっ！　どうだっ！　おっぱいで勃起したモンをズリズリされながら、\n亀頭の先端を指でホジられるの、たまらねぇだろっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0403111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「おっと！　気持ちよすぎるからって、腰引いてんじゃねぇぞ！　逃げられね\nぇように、もっとおっぱいを押し付けてやるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0403112" ]},
		{"command":[ "SETIMAGE", "0", "still_00009704_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「こうして左右から思いっきり挟み込んで……んっ、んんっ……！　おっぱい\nがおまえの形になるくらい、強く圧迫してやるよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0403113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「はぁ、んっ……あふっ、くっ、ああぁ……！　へへっ……どうやら観念した\nみてぇだな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0403114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「おまえが力で私に勝てるワケねぇし、そもそもこうして男にとって大事なモ\nンをおっぱいで挟み込まれてんだ。無駄な抵抗はしない方が身のためだぜ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0403115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「それに私も、こいつを痛めつけようだなんて思ってねぇんだ。ただほんの少\nし、可愛がってやろうと思ってるだけだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0403116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「どんな風に可愛がる気かって？　そりゃさっきみたいに、指でこいつを弄っ\nてやるんだよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0403117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「あっ、んっ、あはぁ……！　どうだ……！　さっきみたいに先っぽをホジる\nだけじゃなくて、亀頭の周りを撫でられるのもサイコーだろ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0403118" ]},
		{"command":[ "SETIMAGE", "0", "still_00009704_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「こうしてクリクリって指で撫でて……時々、爪で引っ掻いてやれば……んっ\n……！　小刻みにイチモツが暴れまくってくるぜ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0403119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「ふぐっ、んんっ……！　あっ、あっ……んふっ……！　エッチな汁も溢れま\nくって来やがる……臭いもかなり濃くなってるぞ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0403120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「シコりながら指を撫でまわすだけで、産まれたての小鹿みたいにブルブル震\nえやがって……！　私のおっぱいに出したくてたまらねぇって感じだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0403121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「んふっ、くっ、あっ……！　わかってんだろうが、射精したいならおねだり\nは必須だぜ……！　ちゃんと口に出して、私に懇願しろよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0403122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「……あぁ？　おねだりなんて情けないこと、出来るワケない？　へぇ……そ\nうかい。そういう反抗的な態度を取るってんなら、私にも考えがあるぜ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0403123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「こうして胸の動きを抑えて、射精するかしないかのところで指を止めてやれ\nば……んっ！　案の定、切なそうにイチモツがヒクついてやがるな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0403124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「どうして急に胸と指を動かすのをやめるのかって？　へへっ……！　そりゃ\n、おまえに生殺しの感覚を味わってもらうために決まってんだろ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0403125" ]},
		{"command":[ "SETIMAGE", "0", "still_00009704_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「射精したいのに出来ないってのは、切なくて、苦しくて、つらいだろ？　こ\nんな感覚、ずっと味わいたくねぇよなぁ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0403126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「気持ちよく精子びゅるびゅる出すには……何をしないといけないのか、馬鹿\nなおまえでもわかるだろ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0403127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「へへっ……！　ちゃんと言わなきゃ、生殺しのパイズリと亀頭弄りを続ける\nだけだぜ……！　ほらっ……気持ちよくなりたいなら、早く言いやがれ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0403128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「全世界で一番可愛くて、強くて、エロエロなウタマロ様の胸に出したいです\n！　おっぱいと指で感じる変態の情けない射精を見てください、ってなぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0403129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「ぷっ……！　あははっ！　射精したいからって、本当に言いやがったぜっ！\n　男としてのプライドなんて、欠片もねぇって感じだなっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0403130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「そのプライドのなさに免じて、さっきの態度は許してやるっ！　お望み通り\n、情けなく射精させてやるよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0403131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「んっ、んっ！　くっ、あっ！　ほらっ！　これがいいんだろっ！　おっぱい\nシコシコと指でグリグリされるの、たまらねぇんだろっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0403132" ]},
		{"command":[ "SETIMAGE", "0", "still_00009704_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「くっ、うぐっ……あっ、んんっ！　我慢なんてしてねぇで、思いっきり出し\nやがれっ！　おまえの臭いザーメン、私にぶっかけやがれっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0403133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ！　くるっ……！　女を孕ませることも出来ないクソッタレなザ\nーメンがすぐそこまで来てるの感じるぜっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0403134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「出せっ！　出せっ！　おまえの情けない無駄打ち精子、私のおっぱいにブチ\n撒きやがれっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0403135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「んくうぅぅ……！　臭くて濃厚なドロドロザーメンがこんなに出て……！　\nあっ、あんんっ……！　アソコがビクビク跳ねまくってるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0403136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009704_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「くっ、んふぅ……！　勢いづいてて、情けなくないアピールでもしてるつも\nりなんだろうが……生意気なことしてんじゃねぇぞ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0403137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「こうして射精中におっぱいでシコシコしながら、指で強く亀頭を刺激してや\nれば……へへっ！　感じすぎて、たまらねぇみたいだな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0403138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「おっと！　気持ちよすぎるからって、射精を止めようとしても無駄だっ！　\n思いっきり弄りまくって、もっともっと精子を吐き出させてやるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0403139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「おまえの情けない射精をもっと見せろっ！　私のパイズリと亀頭弄りは宇宙\n一だってことを、その小さい脳みそと勃起したモンに刻み込めっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0403140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、あふっ……しっかり出したみたいだな……肌だけじゃなくて\n、ビキニまで精子でドロドロだぜ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0403201" ]},
		{"command":[ "SETIMAGE", "0", "still_00009704_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「もうこれ以上出ないから、早く離れて欲しい……？　へぇ……おまえ、私に\n命令するってか？　自分の立場ってモンを、まだ理解してねぇのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0403202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「いいか。おまえは私のモノであると同時に、オモチャでもあるんだ。つまり\n私が主人でおまえは下僕……そうだろ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0403203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「よし。ちゃんと理解できたみてぇだな。なら、ここからはご褒美じゃなくて\n、躾の時間だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0403204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「おまえは私のモノだってことを、このイチモツを通じてしっかりと教え込ん\nでやる！　気持ちよすぎて、壊れたりするんじゃねぇぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0403205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「んんっ、くっ、ひっ、あはぁ……！　出したばっかりなのに、またガチガチ\nに勃起してんじゃねぇか……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0403206" ]},
		{"command":[ "SETIMAGE", "0", "still_00009704_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「胸や指で弄ればどんどん我慢汁も溢れ出してくるぜ……さっきの射精で全部\n搾りきったと思ってたのに、まだ玉の方に精子が残ってるみてぇだな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0403207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「あぁ？　そんなことない？　もう本当にこれ以上出ない？　はっ……！　出\nるか出ないかなんて、おまえが決めることじゃねぇんだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0403208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「それにもし私のパイズリと指弄りでもう１回射精したら……下僕が主人に対\nして、嘘をついたってことになるぜ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0403209" ]},
		{"command":[ "SETIMAGE", "0", "still_00009704_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「へへっ……！　まあいいや。これは躾だしな。主人である私に逆らうこと…\n…嘘をつくことがどういうことか、しっかりと教え込んでやるよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0403210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「んっ、んんっ！　あっ、ふっ、ひあっ……！　どうだ……さっきよりも強く\nおっぱいを挟んでるから、気持ちよさが段違いだろ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0403211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「根本からしっかりズリズリしてるし、指も先端とカリの裏側を刺激しまくっ\nてるから、たまらねぇみたいだな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0403212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「この粗末なモンもビクビク震えまくってるし……こりゃさっきみたいに、す\nぐに射精しちまうかもな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0403213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「射精するのは勝手だが、出したらおまえは嘘つきってことだ。嘘つきじゃな\nいって言うなら、我慢くらいできるよなぁ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0403214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「ぷっ……！　あははっ！　気持ちよすぎてだらしない顔してるクセに、必死\nに耐えるじゃねぇか！　我慢しようって魂胆が見え見えだぜ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0403215" ]},
		{"command":[ "SETIMAGE", "0", "still_00009704_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「ほらっ、イキたいんだろっ！　さっきみたいにびゅーびゅー精子出して、気\n持ちよくなりたいんだろっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0403216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「我慢は身体によくねぇぞ！　ガチガチに勃起したイチモツから、さっさと精\n子吐き出しちまえっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0403217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「くははっ！　絶対に射精しない？　これくらい耐えて見せるだぁ？　下僕の\nクセに私の指とパイズリに抗おうなんて、１００万年早いんだよっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0403218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「なら、無理やりにでも射精させてやるよっ！　指先をイチモツの先端の中に\nブチ込んで、思いっきりかき回してやるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0403219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「おらっ！　出せっ！　精子出せっ！　我慢しまくってブルブル震えてるモン\nから、ドロドロのくっさいザーメン、全部吐き出しやがれっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0403220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「あっ、あはあぁぁぁ……！　またおっぱいの中に精子がどぴゅどぴゅ出て…\n…！　ふっ、あっ……！　これ、さっきよりも濃い感じがするぜ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0403301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009704_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「奥の方に溜まってたせいか、臭いも強烈だな……！　しっかり熟成された、\n濃厚ザーメンって感じだ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0403302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「あっ、んふっ……！　まだ出てるっ……！　このまま最後の一滴まで、搾り\n出してやるからなっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0403303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「こうして指先で射精中のモノを撫でて、シコシコすれば……！　んんっ！　\nさらに勢いづいた精子が、先端から飛び出て……ああぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0403304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「ああぁ！　やっぱり精子の臭いや感触はたまらねぇぜ……！　感じるだけで\n、イッ……イクッ……！　んくぅぅぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0403305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、はあぁ……へへっ……！　何がもう出ないだ……まだこんな\nにも出せるじゃねぇか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0403306" ]},
		{"command":[ "SETIMAGE", "0", "still_00009704_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「おっと。イイワケなんてしてんじゃねぇよ。大事なのは、おまえが出ないっ\nて言ってたのに、ちゃんと出たっていう事実だけだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0403307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「それはつまり、おまえが私に嘘をついたっていう証拠なワケだが……嘘つき\nにはしっかりと教育……いや、調教が必要だよなぁ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0403308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「へへっ……！　そう不安そうな顔すんなって。別に痛めつけたりしねぇから\nよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0403309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「むしろ気持ちよくて、クセになると思うぜ。それこそ、私のことしか考えら\nれなくなるくらい、脳みそを快楽で染め上げてやるからな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0403310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「うぶっ！？　あっ、うぐっ！？　お、おまえっ！　勝手に顔にかけやがって\n……んくうぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0403401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009704_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「私の許可なしに顔にかけるとか……！　いい度胸してんじゃねぇか……！　\nんんっ！　あっ、あっ！　ひゃうぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0403402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「くっ……！　まだ出るとか……！　もう出ないとか言ってたクセに、しっか\nり溜め込んでんじゃねぇか……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0403403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「嘘ついたのは許せねぇが……この臭いと感触は嫌いじゃねぇぜ……！　感じ\nるだけで、アソコが疼いてきちまうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0403404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ！　これ、感じすぎて……イッちまうっ……！　ビキニだから、\nいつもより精子の感触を強く感じて……んふぅぅぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0403405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「んっ、ふぅ……さて、と。色々と言いたいことはあるが、まずは勝手に顔に\nかけたことについて話しをしようじゃねぇか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0403406" ]},
		{"command":[ "SETIMAGE", "0", "still_00009704_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「下僕のクセに主人を汚すとは、どういうつもりだ？　まさか、無意識だった\nとか言わねぇよなぁ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0403407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「……へぇ。おっぱいからイチモツを引き抜こうとしたけど、間に合わなくて\n顔にかかったねぇ……イイワケにしちゃ、よくできてる方だな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0403408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「まあ、どんな理由であれ主人を汚したことに変わりはねぇんだ。二度とこん\nな粗相をしないよう、調教してやんねぇとな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0403409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「へへっ……そう怖がるなって。ちゃんと気持ちよく躾けてやるから、楽しみ\nにしておくんだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0403410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}