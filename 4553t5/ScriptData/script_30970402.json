{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009704_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
