		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「んっ、くふっ……私のアナル、見えてるか？ちゃんと洗って来たから、\n奥まで綺麗になってるだろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0404101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「へへっ……！　そんなに鼻息荒くしなくても、尻の穴は逃げねぇよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0404102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「んっ……あっ……！　そうだ、もっと顔を近づけてこい……！　おまえの舌\nで尻穴を舐めて、ヌルヌルにするんだ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0404103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「あぁんっ……！　息が肛門にあたって……んっ、くうぅ……！　それに、奥\nの方まで空気が入って来る感じが……あああぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0404104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「もう我慢できねぇ……！　早くアナルを舐めて奉仕しろっ……！　いっぱい\n感じさせやがれ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0404105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「あはあぁぁぁっ……！　あっ、あっ！　舌の柔らかくてヌルヌルした感触が\n、肛門から伝わってくるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0404106" ]},
		{"command":[ "SETIMAGE", "0", "still_00009704_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「舐められるたびに勝手に力が入って……！　んっ、んんっ……！　アナルが\n締まっちまう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0404107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……！　んっ、あっ……！　もっと激しく舌で肛門を舐め回せ…\n…！　ローションを垂らしたくらい、ヌルヌルにしろ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0404108" ]},
		{"command":[ "SETIMAGE", "0", "still_00009704_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「それとアナルの皺も丁寧に舐めろよ……！　１本１本、舌先でホジりながら\nグリグリするんだ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0404109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「おっ、おぉぉぉ……！？　このアナルを舐められて、ほぐされる感じっ……\n！　サイコーにクレイジーだっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0404110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「この快感はアソコじゃ味わえねぇ……！　尻の穴だからこそ感じる、極上の\n快楽だぜ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0404111" ]},
		{"command":[ "SETIMAGE", "0", "still_00009704_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「んっ、あふっ、ぐっ……！　おっ、おほっ……！　んひぃ……！？　尻の奥\nから、いやらしい汁が溢れて来ちまうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0404112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「私の肛内から溢れ出る貴重な汁だ……！　しっかり舐め取って、味わってお\nけよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0404113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「ぐっ、おっ……！　ひっ、ああぁ……！　あっ、あっ……！　そろそろ、ほ\nぐれてきたみたいだな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0404114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「おまえも我慢できねぇんだろ。いいぜ……私の尻の中にその思いっきり勃起\nしたモンをブチ込んで来なっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0404115" ]},
		{"command":[ "SETIMAGE", "0", "still_00009704_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「あっ……！　ああぁぁぁっ……！？　奥まで、来るぅ……！　太くて、硬く\nて、熱いのが……私の尻の中をえぐって来て……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0404116" ]},
		{"command":[ "SETIMAGE", "0", "still_00009704_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「はぁ、あっ……！　この肛門が拡がっていく感覚……！　たまらねぇぜ……\n！　おいっ！　もっと気合入れてブチ込んで来いっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0404117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「おほおおおぉぉぉ……！？　イチモツの先端が直腸にまで届いてっ……！　\nあっ、あっ！　これ、ヤバいっ……！　気持ちよすぎるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0404118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「はぁ、んっ……あっ、あぐっ……！　おまえ……いつまで挿れたままでいる\nつもりだ……！？　奥まで突っ込んだら、さっさと動けっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0404119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「アソコと同じように、カリで尻の中を引っ掻きながらズリズリ出し入れしろ\nっ！　中途半端な動きしたら、許さねぇからなっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0404120" ]},
		{"command":[ "SETIMAGE", "0", "still_00009704_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「おっ、おっ！？　ぐっ、あっ、あはぁぁぁっ！？　いっ、いいっ！　このズ\nリズリ擦られる感じ、サイコーすぎるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0404121" ]},
		{"command":[ "SETIMAGE", "0", "still_00009704_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「身体の中を直接犯されるような感じが……！　あああぁ！　いいっ！　肛門\nズポズポされるの、気持ちいいぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0404122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「はぁ、あっ！　んっ、あっ！　あっ、ひっ、あひぃ！？　その調子だっ……\n！　もっと根本までその粗末なモンを突っ込んで来いっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0404123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「思いっきりピストンして、ズポズポしまくれよっ！　尻から溢れ出る汁を亀\n頭に絡ませて、滑りをよくして……ああぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0404124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「そ、そうだっ……！　カリを腸にあてて、思いっきり擦って来いっ……！　\n尻の中が火傷するくらい激しく……んっ、んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0404125" ]},
		{"command":[ "SETIMAGE", "0", "still_00009704_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「くっ、おぉぉ……！？　感じすぎて、尻の中だけじゃなくてアソコからも汁\nが溢れて……！　あっ、あっ！　あはぁぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0404126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「こんなに動かれたら、もっとアナルを締め付けたくなっちまうっ……！　く\nっ……！　んんっ……！　ふぐうぅぅぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0404127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「あっ、ひっ、あっ……！？　尻の穴を締め付ければ締め付けるほど、亀頭の\n形がはっきり伝わってくるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0404128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「ズポズポされる快感も強くなって……！　あっ、あっ！　本当にたまらねぇ\n！　こんなに感じたら、イッちまいそうだっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0404129" ]},
		{"command":[ "SETIMAGE", "0", "still_00009704_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「んおほぉぉぉっ！？　締め付けに合わせて、尻の中でイチモツが激しく暴れ\nて……！　おまえもイキたいのかっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0404130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「ぐっ、うぐっ……！　イキたいなら、イカせてやるっ……！　このまま私の\n尻の中で、射精しまくれっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0404131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「いろんな汁でベトベトになったアナルに、おまえの臭いザーメンをブチ撒け\nろっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0404132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「あああぁっ！　尻穴をえぐられる速度がまた上がってっ……！　あっ、あっ\n！　くるっ！　精子来るのわかるぞっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0404133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「イッ、イケッ！　このまま私の中で果てて、最後の最後まで感じさせろっ！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0404134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「あああぁっ！　イクッ！　イクぅ！　アナルをかき回されながら……イッ、\nイクッ……！　イクぅぅぅぅぅんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0404135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009704_02_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「あっはあああぁぁぁっ！　熱くてドロドロの精子が、お尻の中にどぴゅどぴ\nゅ出てるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0404136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「子宮に流し込まれるのと違って、腹の奥の奥まで流し込まれてる感じがする\nぜっ！　あああぁ！　これ、たまらねぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0404137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「そのままもっと流し込めっ！　尻の穴で妊娠させるくらい、勢いよく精子を\n吐き出し続けろっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0404138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「んっ、ぐっ！　がっ、あはあぁぁぁっ！　そっ、そうだっ！　アソコを根本\nまで尻の中に突っ込んで、グリグリしながら射精しろっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0404139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「あっ！　イクッ！　またイクぅ！　イッたばっかりなのに、また子宮が疼い\nて……！　イッ、イクッ……！　イクぅぅぅっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0404140" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009704_02_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、はあぁ……！　中々いい射精だったぞ。さすがはオモチャな\nだけのことはあるな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0404201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「それに１回出したくらいじゃ治まらないこの性欲……やっぱりおまえはサイ\nコーだよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0404202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「尻の中でこんなに勃起したままなんだ。出し足りなくて、ウズウズしてんだ\nろ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0404203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「へへっ……！　いいぜ。私もまだまだヤり足りなくて、尻の奥が疼いてんだ\n。このまま２回戦としゃれ込もうぜ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0404204" ]},
		{"command":[ "SETIMAGE", "0", "still_00009704_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「さっきみたいに思いっきり突いて尻穴を犯しまくれ。もし手ぇ抜いたりした\nら、痛い目見てもらうからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0404205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「あっ、おっ、おおぉ！？　さっきよりも動きが速くて……！　おっ、おほぉ\n！？　尻のいいところに亀頭があたるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0404206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「精子のおかげでもっと滑りがよくなったから、さっき届かなかったところに\nまでカリが擦れて……ひぎっ、がっ、あはあぁぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0404207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「ああっ！　あっ、んっ、あっ！　そっ、そこっ！　いいっ！　子宮の裏側の\nとこ、グリグリされるのたまらねぇぜ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0404208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「そのまま思いっきり突き上げて、尻の穴から子宮を刺激しろっ！　気持ちよ\nすぎて排卵するくらい、激しく突きまくれっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0404209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「あっ！　あっ！　あああぁんっ！　パンパンっていやらしい音が強くなって\nるぜっ！　それに尻穴からぐちゅぐちゅした音もしやがるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0404210" ]},
		{"command":[ "SETIMAGE", "0", "still_00009704_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「さっき出した精子と私のエッチな汁が絡み合って……！　こんなの、聞いて\nるだけで身体が疼いてくるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0404211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「もっとだっ！　もっと動きを速くしながら、奥までねじ込んで来いっ！　肛\n門が擦り切れるくらい動いて……んひっ、あっ！　あひぃ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0404212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「んぐっ、あっ、ひっ、おほぉぉぉ！？　くっ、来るっ！　またすごいのが子\n宮の奥から来てるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0404213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「おまえのぶっといモンで、またイクッ！　アナルをズポズポされながら、イ\nキまくっちまうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0404214" ]},
		{"command":[ "SETIMAGE", "0", "still_00009704_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「はぁ、んっ、あっ！　あはぁ！　おっ、おまえもイキたいのか！？　なら、\n２回目は特別に好きなところに出していいぜっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0404215" ]},
		{"command":[ "SETIMAGE", "0", "still_00009704_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「このまま尻の奥に出してもいいし、私にぶっかけてもいいぞっ！　おまえの\n出したいところに精子を吐き出しまくれっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0404216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「ただし、私がイクまで絶対にイッたり、動きを止めたりするんじゃねぇぞっ\n！　そんなことしたら、タダじゃ済まさねぇからなっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0404217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「わかったら、私がイクまで腰を振れっ！　その硬くて熱いモンで、私を感じ\nさせ続けろっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0404218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「んはっ、あっ！　あっ！　ひっ、うぐっ！　くううぅ……あっ、あっ！　お\nっ、んほっ！　おっほおぉぉぉ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0404219" ]},
		{"command":[ "SETIMAGE", "0", "still_00009704_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「イッ、イグッ！　イグぅ！　おまえもイケッ！　私の身体に思いっきり濃い\nミルクをブチ撒けやがれっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0404220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「ひぐぅぅぅっ！？　また奥の方に精子が流れ込んできて……！　あっ、あっ\n！　これ、尻が焼けるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0404301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009704_02_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「それにこの量……！　２回目とは思えないほど多いじゃねぇか……！　腹が\n膨れちまいそうだぜ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0404302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「ひぎっ！？　がっ、はぁ、んんっ！　おぉぉぉ！？　だっ、出しながら動く\nとか……相当私の尻穴が気に入ったようだなっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0404303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「まあ、私もおまえのモンは気に入ってるからな……！　いいぞっ、そのまま\n射精しながらピストンし続けろっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0404304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「んおっ、おっ、おおおぉぉぉっ！　イクッ！　イクぅ！　射精されてる最中\nなのに……！　イッ……イクッ！　イクぅぅぅ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0404305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「んんっ……あっ、ふぐっ……あはあぁぁぁ……何か今日は、いつも以上に気\n持ちよかったぜ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0404306" ]},
		{"command":[ "SETIMAGE", "0", "still_00009704_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「普段とは違う恰好だし、野外でしてるから、余計に興奮したんじゃないかっ\nて……？　あー、そうかも知れねぇな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0404307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「へへっ……それにしても、あんな大声で喘いでたから、誰かに見られたりし\nてな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0404308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「あぁ？　別に私は誰に見られようが関係ねぇよ。ヤりたいときに、ヤりたい\nことをする。それだけだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0404309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「ってことで、もう１回戦付き合ってもらうぜ。今度は尻じゃなくて、前の方\nでな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0404310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「おっほおおおぉぉぉぉぉ！？　熱いのが一気に尻穴から抜けて……！　ひぎ\nっ、あひぃぃぃ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0404401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009704_02_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「肛門と尻に熱いのがどぴゅどぴゅブッかけられてるぅ！？　ビキニのせいで\n布が少ないから、地肌に精子があたりまくるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0404402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「いつも以上に精子が染み込んで来る感じがして……！　んひっ！　あっ、ふ\nっ、あああぁ！　気持ちいいぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0404403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「精液の臭いもこんなに強くて……！　んっ、あっ！　嗅いでるだけで、イッ\nちまうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0404404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「あっ！　イクッ！　精子の臭いと熱さを感じながら……！　イクッ！　んっ\n、あっ、あっ……！　イクぅぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0404405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「んっ……あっ……尻の中も外も、おまえの子種汁でベトベトになったな……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0404406" ]},
		{"command":[ "SETIMAGE", "0", "still_00009704_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「いやらしい感触が尻から伝わってくるぜ……あっ、んんっ……！　たまんね\nぇな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0404407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「ふっ、んぐっ……！　さすがに精子を腹の中に入れたままじゃ、垂れてきち\nまうからな……しっかり出しておかねぇと……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0404408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「あぁ？　私が精子を尻からヒリだすところが見たいだぁ？　別に構わねぇけ\nど……排泄する姿を見たいとか、相当変態だな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0404409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aウタマロ" ]},
		{"command":[ "SETTEXT", "「まあ、そういうプレイも嫌いじゃないけどな。そんじゃ、しっかりヒリだす\nからよく見てろよ……！　ふっ、んぐっ……！　んんんんんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0404410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
