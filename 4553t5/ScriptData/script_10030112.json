		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「やった……！　クリスタルモンツキハカマアゲハ、捕まえた！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010114740001" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「くっ……！しかたない！　今日のところは譲ってやるわ！　引き上げるぞ、\nセレーナ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100114740001" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「いっとくがそっちの偽者のことじゃないぞ！　私のことだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080114740001" ]},
		{"command":[ "SETCHARA", "0", "char_00000408_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「うるせー！　とっとと尻尾巻いて帰りやがれこのバカ犬！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010114740001" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「ルナテミス！　蝶を捕まえたよ！　ルナテミス！　あれ？　ルナテミスはど\nこ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_020114740001" ]},
		{"command":[ "SETCHARA", "0", "char_00001302_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「きゅううう～……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114740001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「わーっ！　ルナテミスがズタボロに！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_020114740002" ]},
		{"command":[ "SETCHARA", "0", "char_00001302_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「しまった！　蝶に気を取られて……ルナテミス様！　しっかりしてください\n！　ルナテミス様ぁ～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010114740001" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「……あれは絶対、みんなわかっててやったんだ。きっとみんな、私のことが\n嫌いなんだ……ううう……あいつら、覚えてろよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114740002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0184" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_011" ]},
		{"command":[ "SETNAME", "統制局員" ]},
		{"command":[ "SETTEXT", "「お待たせしました。局長はこちらです」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「どうだ、レディ・ホープ！　依頼通り、クリスタル……クリスタル……なん\nとなくクリスタルな蝶を捕まえてきたぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114740003" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「拝見します。……ふむ、どうやらクリスタルモンツキハカマアゲハのように\n見えますね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_090114740001" ]},
		{"command":[ "SETCHARA", "0", "char_00000609_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「だろう！？　そのアゲハだろう！？　では、さっさとカツマを解放してもら\nおうか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114740004" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「少々お待ちください。ＡＩに確認させますので――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_090114740002" ]},
		{"command":[ "SETCHARA", "0", "char_00000609_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "レディ・ホープが言うが早いか、部屋中に『ブッブー！』と不正解のブザーが\n響き渡る。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ＡＩ" ]},
		{"command":[ "SETTEXT", "「これはクリスタルモンツキハカマアゲハではありません。よく似た蛾の、ク\nリスタルモンツキハカマアゲハダマシです」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ダマシだとぉ～～～っ！？　なんでそんな紛らわしいのがいるんだぁ～～～\nっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114740005" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 		
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「自然の営みに文句を付けても仕方ないでしょう。しかし残念ですが、これで\nは任務達成とはみなせません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_090114740003" ]},
		{"command":[ "SETCHARA", "0", "char_00000609_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「と、いうことは……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114740006" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「お疲れでしょうが、もう一度お願いします。再度、捕獲に向かってください\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_090114740004" ]},
		{"command":[ "SETCHARA", "0", "char_00000609_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「再度……捕獲……！　もう一度、行くということか……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114740007" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ルナテミスは泣きそうな顔でその場にへたりこむ。そして……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「こんな苦労をかけさせて……！　いいかげんにしろ～～～～っ！　カツマの\nボケナスビ～～～～～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114740008" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

