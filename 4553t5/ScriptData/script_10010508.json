{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0027" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……さすがにうんざりしてきたな。どんだけいるんだ、ルナテ\nミス」", "NORMAL" ]},
	{"command":[ "DISPTEXT", "TRUE" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「さすがの私も『偽ルナテミスだ』とツッコむ気力が尽きてきたぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010105150001" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "1", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あー、もう！　マジでルナテミスうざいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010105150001" ]},
	{"command":[ "SETCHARA", "0", "char_00000601_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「どこからともなく現れるもんな。こっちの迷惑とか考えずに！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010105150001" ]},
	{"command":[ "SETCHARA", "0", "char_00000401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「ホント、空気読まないよねえ、ルナテミス！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010105150001" ]},
	{"command":[ "SETCHARA", "0", "char_00001201_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ルナテミスをまとめて消し去る方法はないものでしょうか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010105150001" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「お前たち、もしかしてわざと言ってないか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010105150002" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「とはいえ……ルナテミスを見かけなくなってきましたね。さすがに傍若無人\nなルナテミスも、警戒し始めたということでしょうか？」", "NORMAL" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "0", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_014_010105150001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なるほど、学習能力はあるんだな。ルナテミスにしてはなかなかやるな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「おい下僕！　今のはわざとだろ！　明らかにわざとだろっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010105150003" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いやいや！　とんでもない！　あくまでも偽の話で――」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おっと、本部からの通信だ。長官かな？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「こ、こいつ……！　あとで覚えてろっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010105150004" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「隊長！　こちら、冴島だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010105150001" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「長官、どうかしたんすか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「パトロールからの報告だ。市内全域で暴れていた偽ルナテミスたちが、一か\n所に集結し始めたらしい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010105150002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「長官……！　あなただけだ、ちゃんと『偽』をつけてくれるのは！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010105150005" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "8", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「営倉に入れていた偽者たちも逃げだしたらしい！　おそらく、そいつらの行\nき先も同じだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010105150003" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「くそっ……！　奴らは、いったいどこに集まっているのだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090105150001" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "1", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「今、そちらに位置情報とルートを送った。現場に急いでくれ！　ルナテミス\nたちが何をしでかすかわからない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010105150004" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「だから！　『偽』を忘れるなーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010105150006" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「姫様、落ち着いて！　あいつらが一か所に集まってくれるんなら好都合です\nよ。偽ルナテミスを一網打尽にしましょう！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そ、そうだな。下僕にしては、いいことを言うじゃないか。って――んん！\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010105150007" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「貴様！　ちゃんと『偽』をつけられるんじゃないか～～～～～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010105150008" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「長官によると、このあたりにルナテミスが集まってるはずなんだが――」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「あ！　カツマさん！　あそこ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010105150002" ]},
	{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「うわっ！　なんだあれ！　ルナテミスがうじゃうじゃいる！　キモッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010105150002" ]},
	{"command":[ "SETCHARA", "0", "char_00000401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「うわぁああ……おっきな石をひっくり返したときに、虫がウジャウジャ出て\nきたのを見ちゃった気分……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010105150002" ]},
	{"command":[ "SETCHARA", "0", "char_00000601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010105150009" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ルナテミス、こらえてくれ……さすがに今の例えは、私もどうかと思った」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090105150002" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「わかっている……！　わかっている……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010105150010" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「に、しても結構な数だねえ。これはちょっと面倒だよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010105150001" ]},
	{"command":[ "SETCHARA", "0", "char_00000301_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ですが、先ほどまでに遭遇した偽者たちの戦闘力を考えれば、どうにか相手\nできない数でもないと思います」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010105150002" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いちおう、本部に応援も要請しておくか……それなら、なんとかいけるんじ\nゃないか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ふん、誰もやれないとは言ってないさ。面倒だ、って言ったまでだよ。妙な\n心配するんじゃない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010105150002" ]},
	{"command":[ "SETCHARA", "0", "char_00000301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ならいいけどな。それじゃ、片付けるか！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａジュンジロー" ]},
		{"command":[ "SETTEXT", "「注意！　前方でエネルギー反応増大！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_040105150001" ]},
	{"command":[ "SETCHARA", "0", "char_00000904_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「は？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「気をつけろ！　奴ら、何か企んでいるようだぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090105150003" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「企んでる？　いったい何をだい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010105150003" ]},
	{"command":[ "SETCHARA", "0", "char_00000301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「……あいつら、何をしてるの？　一か所に密集して――あっ！　ああっ！？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010105150001" ]},
	{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ええええっ！？　なにあれ！？　集まったルナさま同士が、どんどんくっつ\nいて大きくなってく！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010105150003" ]},
	{"command":[ "SETCHARA", "0", "char_00000601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんだよあれ！？　合体か！？　合体してるのか！？　あいつらにそんな技\nがあるんなら、最初から教えといてくれよ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「私に言ってるのか！？　そんなこと言われても、私が知るわけないだろう！\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090105150004" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「す、すげえ……！　見る見るうちに、ルナ様があんなに大きく……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010105150003" ]},
	{"command":[ "SETCHARA", "0", "char_00000401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「態度だけじゃなく、図体まででかくなりやがったか！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「巨大化した偽者たちの話をしてるんだろうな！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010105150011" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「体重もきっと、すごいことになってるわね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010105150004" ]},
	{"command":[ "SETCHARA", "0", "char_00000601_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「おい待て！　今、私の腹をちらっと見なかったか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010105150012" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「どうします？　カツマさん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010105150003" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「どうするって……いったん隠れて応援を待つか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "っていうか、あんなでけぇの俺たちだけで相手できるのか！？", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「なるほど。それもひとつの手ではあるが――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090105150005" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "巨大ルナテミス" ]},
		{"command":[ "SETTEXT", "「巨大ルナ～～～～～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_998_130105150001" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "一同" ]},
		{"command":[ "SETTEXT", "「わあああああーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010105150013" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "-600" ]},
	{"command":[ "SETCHARA", "1", "char_00000109_01", "3", "CENTER", "-200" ]},
	{"command":[ "SETCHARA", "2", "char_00001201_01", "3", "CENTER", "200" ]},
	{"command":[ "SETCHARA", "3", "char_00001401_01", "3", "CENTER", "600" ]},
	{"command":[ "DISPCHARA", "1", "TRUE" ]},
	{"command":[ "DISPCHARA", "2", "TRUE" ]},
	{"command":[ "DISPCHARA", "3", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "巨大ルナテミスの一撃で、地面が揺れた！", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「どうやら、隠れてやりすごせるほど甘い相手ではなさそうだぞ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090105150007" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "1", "FALSE" ]},
	{"command":[ "DISPCHARA", "2", "FALSE" ]},
	{"command":[ "DISPCHARA", "3", "FALSE" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「当たり前だ！　偽とはいえルナテミスなのだからな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010105150014" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんで急に自慢げなんすか！　しょうがねえ！　みんな！　あのでけぇのを\n倒すぞ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「了解っ！　まりあ姉ちゃん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010105150004" ]},
	{"command":[ "SETCHARA", "0", "char_00001201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ええ！　モード『ＳＩＬＶＥＲ・ＳＴＡＲ』スタンバイ！　シルバドライブ\n・リンケージ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010105150005" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「銀星装甲シルバスター、オーバードライブ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_020105150001" ]},
	{"command":[ "SETCHARA", "0", "char_00001302_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「よし、行くぜ！　態度も図体もでかすぎるルナテミスに、現実ってもんを思\nい知らせてやれ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「おう！　――って、相変わらず引っかかる言い方だな！　だが、まあいい！\n　行くぞ、皆の者っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010105150015" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "巨大ルナテミス" ]},
		{"command":[ "SETTEXT", "「ルナーーーーーーーッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_998_130105150002" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "一同" ]},
		{"command":[ "SETTEXT", "「うわあああああーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010105150016" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "-600" ]},
	{"command":[ "SETCHARA", "1", "char_00000109_01", "3", "CENTER", "-200" ]},
	{"command":[ "SETCHARA", "2", "char_00000201_01", "3", "CENTER", "200" ]},
	{"command":[ "SETCHARA", "3", "char_00001302_01", "7", "CENTER", "600" ]},
	{"command":[ "DISPCHARA", "1", "TRUE" ]},
	{"command":[ "DISPCHARA", "2", "TRUE" ]},
	{"command":[ "DISPCHARA", "3", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「くそっ！　あのルナテミス、図体がでかいだけに手ごわいな！」", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
	{"command":[ "DISPCHARA", "1", "FALSE" ]},
	{"command":[ "DISPCHARA", "2", "FALSE" ]},
	{"command":[ "DISPCHARA", "3", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あれだけ大きいと、こちらも攻撃しづらい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010105150004" ]},
	{"command":[ "SETCHARA", "0", "char_00000201_01", "2", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「このままあいつにでかいツラさせとくのか！？　なんかいい手はないのかよ\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010105150006" ]},
	{"command":[ "SETCHARA", "0", "char_00000401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「とは言ってもなあ。あいつ、ツラもでかけりゃパワーもでかいからな。態度\nだけがでかい本物のルナテミスとは――」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「おい、ちょっと待て！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010105150017" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ん……！？　ツラ？　でかい……ツラ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「戦闘中とはいえ、今のはさすがに聞き捨てならんぞ下僕！　おい下僕！　聞\nいてるのか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010105150018" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうだ！　でかいツラ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「――って！　いきなり大声を出すなっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010105150019" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああ、すんませんね姫様！　それよりアナザー！　こっちにも、あれ以上に\nでかいツラの持ち主がいたよな！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「カツマ。それ以上ルナテミスをからかうな。あまり感心しないぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090105150009" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ちがう！　そういうことじゃなくて、物理的にでかいツラ！　金属製の！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「はっ！　そうか！　ドラグソード！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090105150010" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうだ！　あいつを呼べるか！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「エネルギーが足りるか、少し不安だが……やってみよう！　皆、時間を稼い\nでくれ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090105150011" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「了解っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_020105150003" ]},
	{"command":[ "SETCHARA", "0", "char_00001302_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「仕方ないな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010105150020" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「それじゃ、みんな！　もう一度行くぞーーーーっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
	{"command":[ "EXIT" ]}
	]
}