{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0131" ]},
		{"command":[ "DISPIMAGE","0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……よしっ！　これで大体は片付いたか……うわあああああっ！？」", "NORMAL" ]},
	{"command":[ "DISPTEXT", "TRUE" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「な、なんだなんだ！？　ロケットが揺れてるぞ！？　地震か！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010107050001" ]},
	{"command":[ "SETCHARA", "0", "char_00000401_01", "3", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ちょっと待ちなよ！　このロケット、動き出してないかい！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010107050001" ]},
	{"command":[ "SETCHARA", "0", "char_00000301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「うそ！？　ロケットが発射態勢に入ってるわ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010107050001" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なぁにいぃいいっ！？　誰か、なんか変なとこ押したのか！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「わからない。でも乱戦で、みんながあちこちにぶつかったりしたから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010107050001" ]},
	{"command":[ "SETCHARA", "0", "char_00000201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「かんべんしろよーっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａジュンジロー" ]},
		{"command":[ "SETTEXT", "「ロケットのシステムとデータリンク。発射まで、あと７２秒」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_040107050001" ]},
	{"command":[ "SETCHARA", "0", "char_00000904_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「まずい！　早く降りなければ、全員もろとも打ち上げられるぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090107050001" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「う……宇宙に！？　宇宙にか！？　それはまずくないか！？　宇宙には電車\nもバスも通ってないんだろう！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010107050001" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「それ以前に空気がないよーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010107050001" ]},
	{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「と、とにかく外に……って、ハッチが開かねぇーっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「開かねー！　ではなぁーい！　　なんとかしろ、このボケナスビ―！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010107050002" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「管制室！　管制室聞こえるか！　発射中止！　発射中止だ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090107050002" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そ、そうだ！　通信！　ロケットの中からなら……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "管制官" ]},
		{"command":[ "SETTEXT", "「……申し訳ありません」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「やぁ～ん！　通信がつながった瞬間に謝らないでーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010107050001" ]},
	{"command":[ "SETCHARA", "0", "char_00000601_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "管制官" ]},
		{"command":[ "SETTEXT", "「どうやら、制御システムが破壊されたようで、こちらからの信号を受け付け\nないんです！　ごめんなさい！」", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａジュンジロー" ]},
		{"command":[ "SETTEXT", "「ＡＥ３５ユニットが不調だ。船外作業で交換する必要がある」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_040107050002" ]},
	{"command":[ "SETCHARA", "0", "char_00000904_01", "0", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「だから出られないんだってばーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010107050002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "管制官" ]},
		{"command":[ "SETTEXT", "「大丈夫です！　貨物用の小型ロケットでも、しばらくの間なら皆さんの生命\nを維持できます！　その間に、なんとか助け出す方法を……」", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「救助の手段があるんですか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010107050002" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "管制官" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「そこで黙らないでーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010107050003" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "管制官" ]},
		{"command":[ "SETTEXT", "「大丈夫！　必ず方法を考えます！　ですから希望を失わないで！　７０億人\nが、あなたたちの帰りを待っています！」", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「待たんでいいから今助けろ―っ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そんな悲痛な俺の叫びを無視するかのように、ロケットは重低音を響かせて真\n上に加速していく。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「なんでこの私が、貨物ロケットで飛ばされるんだぁあああああー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010107050003" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "絶叫するルナテミスに完全同意するしかなかった。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ぎゅうううううう！　体が重い重い重い！死ぬ、死ぬ、死ぬ死ぬ死ぬううう\nうううう！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010107050004" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「Ｇがこんなにすごいなんて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010107050004" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「……カツマ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090107050003" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "急に、Ａ・ルナテミスが俺の腕をつかみ、真剣な声で何かを言おうとした。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「私はあなたに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090107050004" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "4", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……え……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「うぁあああああ！？」」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090107050005" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「って、なんだよ、いきなり！？　わああああああっ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ぎゃああああああああーっ！体が浮いているううううう！　浮いているうう\nううううーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010107050005" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0132" ]},
		{"command":[ "DISPIMAGE","0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "Ａジュンジロー" ]},
		{"command":[ "SETTEXT", "「現在の高度３００ｋｍ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_040107050003" ]},
	{"command":[ "SETCHARA", "0", "char_00000904_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「３００ｋｍ……つまり、ここは……ここは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010107050005" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「宇宙に出ちゃったぁーーーーー！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010107050003" ]},
	{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「クドリャフカ先輩。我らもついにここまで到達しましたぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010107050001" ]},
	{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「こんなときになに浸ってんだこのバカ犬ーーーーっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
	{"command":[ "EXIT" ]}
	]
