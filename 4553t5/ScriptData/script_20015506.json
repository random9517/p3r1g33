		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「あら～。もう私とうららちゃんは固く結ばれてるのよ。ほら、この通り～！\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_010023630019" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「ええい、よしなさい！！　姉は私だけでいいのです！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_010023630005" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「ええ～。私もお姉ちゃんでもいいじゃない～。ブラックちゃんだって私に甘\nえていいのよ～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_010023630020" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「誰がお前などに……！！　とにかく離れなさいっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_010023630006" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「離さないし離れないわよ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_010023630021" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「ひあああああ、２人とも引っ張らないでください～！！　んんっ、フライア\nさん、蔦で縛らないでっ、んっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_020023630013" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「色っぽい声、もっと聞かせて～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_010023630022" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「貴様っ、うららにいかがわしいことを……ええい、私だって！！　うらら、\n私を受け止めて！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_010023630007" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「あううううっ！！　おっぱいに顔を埋めちゃダメ～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_020023630014" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「ああ、久しぶりのうららの胸……これが母性……うらら～～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_010023630008" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「ダメっていってるのに～！！　妹に母性を感じないで～！！　ひあああ、蔦\nでさわさわしないで～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_020023630015" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「えーと……フライアがやられたって言ったし、これはこっちの勝ちでいいん\nだよな？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「戦わずして勝つ。兵法の極意だな。もしかしたら、歴代のマスカレードで最\n強かもな、マスク・ザ・ホワイトは」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023630006" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0022" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ま、まあ何はともあれ、ブラックも戻ってきたし、ホワイトも戦いに目処が\nついて加入できたし、賑やかになりそうだな」", "NORMAL" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「私は本家のこともあるから戻りませんよ。戻れないと言う方が正しいですが\n。うららのためには戻りたいところではありますけれど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_010023630009" ]},
		{"command":[ "SETCHARA", "0", "char_00027501_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「私も学業があるのでフルタイムは無理ですし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_020023630016" ]},
		{"command":[ "SETCHARA", "0", "char_00026102_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ん？　じゃあブルー１人のときとそんな変わらないってことか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「まあ、もともとあいつ１人で回してたわけだしな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023630007" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「それにブルー先輩は昔から連携とかしませんでしたし、うららが加入しても\n個々で活動するというようになると思います」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_010023630010" ]},
		{"command":[ "SETCHARA", "0", "char_00027501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "1"]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "（連携に関してはほむらも静夜も似たようなもんだと思うが……やはり言わな\nい。俺は学んだからな）", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "（さすがですご主人）", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023630007" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "（だからお前は頭の中に直接話しかけてくるなっ！！）", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0"]},
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「それでも……ブルー先輩の復帰までは頑張って代役を務めますね！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_020023630017" ]},
		{"command":[ "SETCHARA", "0", "char_00026102_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「あ、そうだ！！　ご挨拶がてらに皆でブルー先輩のお見舞いに行くっていう\nのはどうですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_020023630018" ]},
		{"command":[ "SETCHARA", "0", "char_00026102_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「絶対嫌だ！！　ブルーの見舞いなんか、死んでも嫌だね！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023630008" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ホワイトにはあんなに心を砕いたのに……まあ、これがほむらの通常運転か\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「人はそう簡単には変わりませんな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023630008" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「うるっせえ！！　とにかく絶対行かねえからな、俺は！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023630009" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}