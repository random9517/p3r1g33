{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0022" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "オーディションから３日後。", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「オーディションから３日……今日は春風うららことマスク・ザ・ホワイトの\nお披露目戦とのことだが」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「サポートに我々とほむら殿が駆り出されたというわけですな。とはいえ、我\n々はうらら殿のスーツも知らぬわけですが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023630001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「噂をすれば……ほら、来たぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023630001" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「お、遅れてごめんなさい～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_020023630001" ]},
		{"command":[ "SETCHARA", "0", "char_00026102_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お……おう」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「いやはや、なんというか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023630002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「結構大胆なデザインだな、それ。いや、俺は嬉しいけど」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「新人だし、うららのスタイルに合わせて新しいデザインにしたらしいぜ。ま\n、俺には似合わねえな！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023630002" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いやいや、案外ほむらみたいな女にこういうスーツがギャップで……とかあ\nるんだぜ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「さすがご主人、女性の可能性の探究については他の追随を許しませんな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023630003" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「あうう……これ、この太ももの露出とか本当に必要なんですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_020023630002" ]},
		{"command":[ "SETCHARA", "0", "char_00026102_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「少なくとも目の保養にはなってるな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「はううううう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_020023630003" ]},
		{"command":[ "SETCHARA", "0", "char_00026102_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「あの～……そろそろ始めてもいいかしら～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_010023630001" ]},
		{"command":[ "SETCHARA", "0", "char_00027401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おっとそうだった。うらら、大事なデビュー戦だ。バックアップは充分にす\nるから、思い切って行ってこい！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「は、はい！！　頑張りますっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_020023630004" ]},
		{"command":[ "SETCHARA", "0", "char_00026102_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「うふふふふ～、手加減しないわよ～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_010023630002" ]},
		{"command":[ "SETCHARA", "0", "char_00027401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「って送り出したのはいいけど、うららの戦闘力の問題はどうなったんだ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「あー、まあ見てろよ。俺の勘が正しければ、そろそろ来るはずだから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023630003" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「私の蔦は鉄板も引き裂く威力よ～！！　銃弾だってはじき返すわ～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_010023630003" ]},
		{"command":[ "SETCHARA", "0", "char_00027401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「どうでもいいけど、こういう怪人とかヒーローの能力って、やたら派手に盛\nられてるよな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「パンチ力１トンとか、ダイヤモンドすら砕くキックとかそういうのですな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023630004" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ヒーローや怪人ってのはそうじゃなくちゃな！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023630004" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「こ……怖いけど、頑張ります……うううううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_020023630005" ]},
		{"command":[ "SETCHARA", "0", "char_00026102_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「うららちゃんは可愛いけど、バトルはバトルなのよ～。さて、どう料理しよ\nうか、し、ら……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_010023630004" ]},
		{"command":[ "SETCHARA", "0", "char_00027401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「え？　え？　なにこの殺気は～？　山の向こうから……近づいてきてる～？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_010023630005" ]},
		{"command":[ "STOPBGM" ]},
		{"command":[ "SETCHARA", "0", "char_00027401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「へ？　え？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_020023630006" ]},
		{"command":[ "SETCHARA", "0", "char_00026102_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「ちょっ、ちょっと～、一瞬でこっちに～ーー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_010023630006" ]},
		{"command":[ "PLAYBGM", "BGM_022" ]},
		{"command":[ "SETCHARA", "0", "char_00027401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「悪は全て斬り伏せる……マスク・ザ・ブラック見参！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_010023630001" ]},
		{"command":[ "SETCHARA", "0", "char_00027501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うおわっ！？　いきなり出てきたっ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「はははは。来ると思って、本部にあったスーツを郵送しておいて良かったぜ\n。」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023630005" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「今回は感謝しておきますよ先輩。しかし家から６分もかかってしまいました\n。やはり少し鈍っていますね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_010023630002" ]},
		{"command":[ "SETCHARA", "0", "char_00027501_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いやここ車で２時間かかるんだが……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人、ヒーローを常人の尺度で測ってはいけませんぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023630005" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「それにしたって限度があるだろ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「かわいい妹のデビュー戦と聞いてやってきました。特等席で見守らせてもら\nいましょう。うららの奮闘を」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_010023630003" ]},
		{"command":[ "SETCHARA", "0", "char_00027501_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「ゴ……ゴホン。改めて、行くわようららちゃん～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_010023630007" ]},
		{"command":[ "SETCHARA", "0", "char_00027401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「は、はいっ！！　かかってきてください！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_020023630007" ]},
		{"command":[ "SETCHARA", "0", "char_00026102_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "（でもこれ、うららちゃんに攻撃したら絶対私処されるわよね～）", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_010023630008" ]},
		{"command":[ "SETCHARA", "0", "char_00027401_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "（だったら蔦を脚に絡めて、転ばせるぐらいで～……）", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_010023630009" ]},
		{"command":[ "SETCHARA", "0", "char_00027401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "（うららちゃんは気づいてない……もう少し……後３０センチ――っ！？）", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_010023630010" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "（え……え……？　蔦が斬られてる……？　嘘～！！　これブラックちゃんの\n斬撃、音も軌道も見えないんだけど～！！）", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_010023630011" ]},
		{"command":[ "SETCHARA", "0", "char_00027401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "（そこまでしてうららちゃんを……ていうかぜんぜん見守ってないじゃない！\n！　普通に護ってる～！！）", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_010023630012" ]},
		{"command":[ "SETCHARA", "0", "char_00027401_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「こ、来ないならこちらから行きますっ！！　えええええいっ！！　あっ！？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_020023630008" ]},
		{"command":[ "SETCHARA", "0", "char_00026102_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あっ、こけた」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ですがその拍子にうまく押し倒しましたな。まるでご主人がやるようなラッ\nキースケベ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023630006" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0"]},
		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「あうっ、いたたたた……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_010023630013" ]},
		{"command":[ "SETCHARA", "0", "char_00027401_01", "4", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "1", "char_00026102_01", "4", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SPOTCHARA", "1"]},
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、ごめんなさい！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_020023630009" ]},
		{"command":[ "SETCHARA", "1", "char_00026102_01", "3", "CENTER", "400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0"]},
		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「ふふ、いいのよ～。デビュー戦で固くなっていたのね～。それにしても――\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_010023630014" ]},
		{"command":[ "SETCHARA", "0", "char_00027401_01", "6", "CENTER", "-400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "1"]},
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「へ？　なんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_020023630010" ]},
		{"command":[ "SETCHARA", "1", "char_00026102_01", "3", "CENTER", "400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0"]},
		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「改めて見ると可愛い顔ね～、お肌も柔らかいし～、髪もさらさら～。いい匂\nいもしてるし～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_010023630015" ]},
		{"command":[ "SETCHARA", "0", "char_00027401_01", "8", "CENTER", "-400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「なにより敵の私に謝るその優しさ～。私、やられちゃったわ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_010023630016" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "1"]},
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「ふえ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_020023630011" ]},
		{"command":[ "SETCHARA", "1", "char_00026102_01", "3", "CENTER", "400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0"]},
		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「うららちゃんの柔らかさ、もっと感じていたいわ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_010023630017" ]},
		{"command":[ "SETCHARA", "0", "char_00027401_01", "8", "CENTER", "-400" ]},
		{"command":[ "MOVECHARA", "0", "CENTER", "200", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "1"]},
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「あんっ！！　抱きしめないでください～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_020023630012" ]},
		{"command":[ "SETCHARA", "1", "char_00026102_01", "9", "CENTER", "400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0"]},
		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「うふふ、私をお姉ちゃんって呼んでもいいのよ～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_010023630018" ]},
		{"command":[ "SETCHARA", "0", "char_00027401_01", "8", "CENTER", "200" ]},
		{"command":[ "WAITINPUT" ]},
		
