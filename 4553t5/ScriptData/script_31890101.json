{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ローズ" ]},
		{"command":[ "SETTEXT", "「……なんだ、こんな夜中に呼び出して。騎士は常に体調を万全にしなくては\nならない。夜更かしをしている場合ではないのだが？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_189_0103101" ]},
		{"command":[ "SETCHARA", "0", "char_00018901_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ローズ" ]},
		{"command":[ "SETTEXT", "「まあ、貴公のことだ。何か深い考えがあってのことなのだろうが……、ん？\n　今何と口走った？　服を脱げ？　気でも触れたのか、唐突な……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_189_0103102" ]},
		{"command":[ "SETCHARA", "0", "char_00018901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ローズ" ]},
		{"command":[ "SETTEXT", "「私の胸が気になって戦いに集中出来ない？　……乳房とはこれか？　こんな\nもの、ただの脂肪の塊に過ぎん。特に私の胸など筋肉で硬いだけだろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_189_0103103" ]},
		{"command":[ "SETCHARA", "0", "char_00018901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ローズ" ]},
		{"command":[ "SETTEXT", "「『一度その胸を自由にさせてくれたら満足するから』？　はァ……くだらな\nい。だが、押し問答が長引いて無意味な時間を過ごすのも良くない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_189_0103104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ローズ" ]},
		{"command":[ "SETTEXT", "「私は何もせんぞ。ただ、生肌を晒し、貴公に一時的に乳房を貸すだけだ。そ\nれでいいなら……、と、こらっ！　前のめりになって迫ってくるんじゃない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_189_0103105" ]},
		{"command":[ "SETCHARA", "0", "char_00018901_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ローズ" ]},
		{"command":[ "SETTEXT", "「……くぅううっ……！　やめろ！　こちらにも心の準備というものがある！\n　このようなバカげた願いを申し出る者など今までにいなかったからな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_189_0103106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ローズ" ]},
		{"command":[ "SETTEXT", "「『早く胸を出せ』？　ぐぅっ……勝手なことを……！　こ……これで……い\nいか？　もっと？　……ならばこうだ！　そらっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_189_0103107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ローズ" ]},
		{"command":[ "SETTEXT", "「う、ぐ、ぐぅう……ッ。王家直属の騎士ともあろう私が、男の前に乳房を譲\nるとは……。屈辱だ……。おい、顔を赤らめてニヤニヤするんじゃない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_189_0103108" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00018901_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ローズ" ]},
		{"command":[ "SETTEXT", "「とっとと胸を自由とやらにすればいいだろう。ジロジロ眺めまわすな。『綺\n麗』？　お世辞もいらない！　ハハ、男のような醜い乳房だろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_189_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ローズ" ]},
		{"command":[ "SETTEXT", "「貴公もさぞやがっかりしたに違いな……。んあッ！？　嬉しそうに手を伸ば\nすな！　さわ……るな！　はしゃぐな！　う、ぁ……あっ、あっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_189_0103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ローズ" ]},
		{"command":[ "SETTEXT", "「い、いいのか……こんな胸、で……？　あ、ああ……もちろん、今まで誰か\nに触れられたことなどない。指でなぞられた、ことも……。ッくぅうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_189_0103111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ローズ" ]},
		{"command":[ "SETTEXT", "「貴公の、ように……！　劣情丸出しで、手のひらいっぱいに鷲掴みにされた\nことも……！　ん、う、う……うぁあ……妙な気分だ、落ち着かない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_189_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ローズ" ]},
		{"command":[ "SETTEXT", "「う……くぅう……！　ぐぅう……くぅうう……！　んん？　なん、だ……？\n　『この胸にチンポも挟みたい』？　チンポ？　男根をこの胸に？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_189_0103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ローズ" ]},
		{"command":[ "SETTEXT", "「なぜそんな、頭のおかしなことをしたがる……！　何？　『騎士は主の命令\nに従うべき』だと？　そ、それはそうだが……肉棒をなどと……。んッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_189_0103114" ]},
		{"command":[ "SETIMAGE", "0", "still_00018901_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ローズ" ]},
		{"command":[ "SETTEXT", "「んあああああッ……！？　ほん、とうに……本当に無理やり乗せるやつがあ\nるか！　チ、チチチ、チンポを乳房に挟んで何が楽しい！　変態め！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_189_0103115" ]},
		{"command":[ "SETIMAGE", "0", "still_00018901_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ローズ" ]},
		{"command":[ "SETTEXT", "「『この国では女騎士の胸にチンポを挟むのが礼儀』……！？　ふざけるな！\n　そんな恐ろしい国があってたまるか！　ッ……や、めろ……やめ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_189_0103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ローズ" ]},
		{"command":[ "SETTEXT", "「んんんっ……！　なんだこの生臭いにおい、は……！　貴公、きちんと風呂\nに入っているのか！？　それに……チンポ、が生温かくて……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_189_0103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ローズ" ]},
		{"command":[ "SETTEXT", "「とても正気とは思えん！　早く外せ……、うぁっ！　何をしているっ……！\n　乳房の谷間に、チンポをなすりつけて……、んぐぅうっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_189_0103118" ]},
		{"command":[ "SETIMAGE", "0", "still_00018901_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ローズ" ]},
		{"command":[ "SETTEXT", "「胸っ……私の胸、で……！　騎士の胸で刺激している……のか？　パイズリ\n？　パイズリとはなんだ！？　やめ……やめろ、やめ……っんああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_189_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ローズ" ]},
		{"command":[ "SETTEXT", "「『筋肉質で硬いかと思ったら、重くて柔らかくて最高の肉質だ』と！？　く\n、ぅ……！　『鍛え抜かれたロケットおっぱいが分厚くて気持ちいい』？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_189_0103120" ]},
		{"command":[ "SETIMAGE", "0", "still_00018901_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ローズ" ]},
		{"command":[ "SETTEXT", "「わ、私の肉体はこんな淫らなことをするために鍛え上げたものでは……ッ、\nない！　侮辱するのもいい加減に……！　うっ……、う、ぅ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_189_0103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ローズ" ]},
		{"command":[ "SETTEXT", "「はぁっ……はぁっ、はぁっ……！　な、んだ……この、ゾクゾクするような\n感覚は……！　快感？　まさか……ち、違う！　私は違う……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_189_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ローズ" ]},
		{"command":[ "SETTEXT", "「胸を掴まれて、チンポをこする肉穴にされて……喜悦を感じているなどと…\n…！　断じてありえん、私……は！　私は騎士……女騎士……ッ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_189_0103123" ]},
		{"command":[ "SETIMAGE", "0", "still_00018901_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ローズ" ]},
		{"command":[ "SETTEXT", "「戦い以外のことで身体を昂らせたりするわけがないっ……！　っうぅ……ッ\n！　い……いやらしくまさぐるな、揉みこむな……んうううっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_189_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ローズ" ]},
		{"command":[ "SETTEXT", "「わた、しの胸を汚すなぁ……！　チンポとは排泄器官だろうっ！　にょ、尿\nをするような場所を……胸に包ませ、いじくる、などと……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_189_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ローズ" ]},
		{"command":[ "SETTEXT", "「ん、ぁう！　常軌を逸している……！　ああッ……くぁああっ！　だ、から\n……！　その卑猥な手つきをやめ、ろ……、んぁあああっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_189_0103126" ]},
		{"command":[ "SETIMAGE", "0", "still_00018901_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ローズ" ]},
		{"command":[ "SETTEXT", "「ンッ……、あぁ……っ、はぁ、は、ぁ……んぁああ……！　胸の中で……ど\nんどんどんどん、チンポが硬くなって、反り返って……！　んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_189_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ローズ" ]},
		{"command":[ "SETTEXT", "「貴公はこんなことをして感じて……いるのか？　どうしてっ……あっ！　む\n、ね……特に私の胸、など……！　性的な価値もあるまいに……ぃっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_189_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ローズ" ]},
		{"command":[ "SETTEXT", "「ん、くぅ……！　『ずっしりと重たい乳房にチンポがめりこんで、埋まって\n気持ちいい』？　『ここまで強いおっぱいはそうそうない』？　フンッ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_189_0103129" ]},
		{"command":[ "SETIMAGE", "0", "still_00018901_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ローズ" ]},
		{"command":[ "SETTEXT", "「ち、乳房なんかが強くてどうする……！　戦いの役にたたない、邪魔な肉袋\nだ……！　んっ！　だから揉むな、こねるな、揺さぶる……なぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_189_0103130" ]},
		{"command":[ "SETIMAGE", "0", "still_00018901_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ローズ" ]},
		{"command":[ "SETTEXT", "「あっ！　チンポ……チンポを喜ばせるために私の胸は育ったわけではな、い\n……！　ない、はず……！　なのに……なのに、なぜ……なぜだァっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_189_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ローズ" ]},
		{"command":[ "SETTEXT", "「貴公のチンポを押し当てられて、差し込まれ、挟まれると……ううっ、心臓\nの動機が止まらん。汗が滲み出してくる。体温が上昇する……ッ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_189_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ローズ" ]},
		{"command":[ "SETTEXT", "「あっ、くぅっ、くぅうっ、ふぅうっ……！　あっ！　あっ！　あっ！　揺ら\nすな……んあああっ！　そんなに私の脂肪が気持ちいいのかっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_189_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ローズ" ]},
		{"command":[ "SETTEXT", "「あっ！　ンぁあっ……ああっ！　硬い……太いモノが、チンポが胸を突き刺\nす……っ！　肉をよりわけて、あっ……！　めりこんでいく……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_189_0103134" ]},
		{"command":[ "SETIMAGE", "0", "still_00018901_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ローズ" ]},
		{"command":[ "SETTEXT", "「んっ！　んんぅっ！　こんな……こんな臭いものを、陰部をねじ入れて楽し\nむなどと……！　貴公の性欲は歪んでいる、歪んでいる……がっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_189_0103135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ローズ" ]},
		{"command":[ "SETTEXT", "「それが楽しいのなら勝手にしろ……！　ッ……ふ……！　んく……！　んん\n……！　あっ……くふぅっ……ふぅっ、ふぅううっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_189_0103136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ローズ" ]},
		{"command":[ "SETTEXT", "「左右から乳房を潰す、な……！　寄せるな……！　何！？　『もう少しで出\nそうだから強めに挟む』？　で、出るとはなんだ？　何が出るのだ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_189_0103137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ローズ" ]},
		{"command":[ "SETTEXT", "「んくぅうっ！　あっ！　つ、強いぃ……！　強く掴むなァッ！　ッあっ……\n！　ああっ！　あっ、ぁっあっあっ……！　うぁ、あああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_189_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ローズ" ]},
		{"command":[ "SETTEXT", "「チンポが、チンポが迫ってくるっ……！　あっ！　い、いやだ……膨らんで\n、ビクビクして……うううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_189_0103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ローズ" ]},
		{"command":[ "SETTEXT", "「何を出すつもりなのだっ！　は、挟んで刺激しただけではまだ足りないなど\nと……自由きままにも程があ、る……！　ッあああああっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_189_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ローズ" ]},
		{"command":[ "SETTEXT", "「んぁあああっ！？　ああっ！　なんだこれは、……あっ！？　熱い！　熱い\n液体が……胸の中に注がれ、て……うぷぅうっ、ひどい臭い……ッ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_189_0103201" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018901_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ローズ" ]},
		{"command":[ "SETTEXT", "「あっ！　あっ！　あっ！　……止まらない、止まらないぞ……！　チンポの\n先からびゅくびゅく出てきて……あああっ、わ、私の胸が、胸がっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_189_0103202" ]},
		{"command":[ "SETIMAGE", "0", "still_00018901_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ローズ" ]},
		{"command":[ "SETTEXT", "「くぅうううう……！　うぅうううう……！　あああ……ベタベタした汁で、\n乳房がドロドロに……。いきなり無礼なやつだな！　何事なんだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_189_0103203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ローズ" ]},
		{"command":[ "SETTEXT", "「ペンキをぶちまけたかのようなこの量は……。っけほっ、けほっ……！　む\nわりと広がる悪臭……湯気が顔にかかって……気持ち悪い……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_189_0103204" ]},
		{"command":[ "SETIMAGE", "0", "still_00018901_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ローズ" ]},
		{"command":[ "SETTEXT", "「『精液』……？　な、んだと……！？　貴公、私に精液をぶっかけたという\nことか！？　せ、精液、といえば……子作りのためのものだろうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_189_0103205" ]},
		{"command":[ "SETIMAGE", "0", "still_00018901_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ローズ" ]},
		{"command":[ "SETTEXT", "「それを許可もなく、む……胸に、乳房にぶちまける……！？　この異常性欲\n者め！　何がパイズリだ、胸にかけて女が妊娠するわけが……ってあああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_189_0103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ローズ" ]},
		{"command":[ "SETTEXT", "「突然何をするっ！　あっ！　せ、精液を潤滑油にして……私の胸で疑似交尾\n……せ、セックス、種付けをしたい……だと！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_189_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ローズ" ]},
		{"command":[ "SETTEXT", "「こらっ！　やめ、ろ……！　貴公は頭がどうかしている！　……んくぁあっ\n！　やめろ！　私の胸、の隙間に汚れたままのチンポを突き入れて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_189_0103208" ]},
		{"command":[ "SETIMAGE", "0", "still_00018901_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ローズ" ]},
		{"command":[ "SETTEXT", "「ズボズボ出し入れするんじゃないっ……！　んあああっ！　いやっ……いや\n、いや、だ……！　あっ！　あっ！　精液、精子まみれにされて！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_189_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ローズ" ]},
		{"command":[ "SETTEXT", "「胸に種付けされるだなんて……あああっ！　騎士の、騎士のプライドが絶対\nに許さない……っ！　やめろ、乳房は子どもらに母乳を与えるものだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_189_0103210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ローズ" ]},
		{"command":[ "SETTEXT", "「優しい……聖なる行為に用いるものなのだぞ！？　それを……！　肉欲で！\n　チンポで蹂躙して、……うう！　種付け、などと……くぁあああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_189_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ローズ" ]},
		{"command":[ "SETTEXT", "「は……激しくする、な……！　あっ……あッ、ぁっあっ……！　チンポが出\n入りすると、精液の臭いが何度でも広がって……うっぷっ、えづくのだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_189_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ローズ" ]},
		{"command":[ "SETTEXT", "「んあッ……！　胸が壊れるっ……あっ！　あっ！　乱暴にする、な……ああ\nあっ！　こんなもの、胸へのレイプ……ではないか！　あっあっあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_189_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ローズ" ]},
		{"command":[ "SETTEXT", "「ズボズボ、ズボズボと、こ、腰を振って……私の胸を犯すだなんて……！　\n変態……！　変態、この変態が……んううっ、凌辱者めぇえっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_189_0103214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ローズ" ]},
		{"command":[ "SETTEXT", "「貴公を信用した私が愚かだったっ……！　ふぁああ……ヌルヌルするっ……\nあっ！　胸が犯されて、ギトギトの体液にまみれている……ぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_189_0103215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ローズ" ]},
		{"command":[ "SETTEXT", "「んくぅうっ！　乳首……乳首に触れるなっ……！　つまむな、伸ばすな……\nこね回す、なぁ……！　あっ！　あっ！　どこまでも乳房に失礼な！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_189_0103216" ]},
		{"command":[ "SETIMAGE", "0", "still_00018901_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ローズ" ]},
		{"command":[ "SETTEXT", "「あくっ……くぅうっ！　乳首をいじりながら、乳房でパイズリをさせ……！\n　あふっ！　んふぁっ！　腰を振りたくって、受精させようとするなんて！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_189_0103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ローズ" ]},
		{"command":[ "SETTEXT", "「どうかしている……！　どうかしているっ！　あっ！　精液をなすりつけて\nも、そこでは孕まんッ！　やめろ……やめろ……やめ……ああああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_189_0103218" ]},
		{"command":[ "SETIMAGE", "0", "still_00018901_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ローズ" ]},
		{"command":[ "SETTEXT", "「私の胸をオモチャにするなぁあっ！　あっうっ、うっあっ……！　あっ……\nくぅううっ……！　あッ……痺れ、る……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_189_0103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ローズ" ]},
		{"command":[ "SETTEXT", "「本当、に私の胸を孕ますつもり、なのか……！　あああ、い、嫌だ……！　\n突き入れるな、また、精液を出すつもりだな……！　やめろぉ……ッ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_189_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ローズ" ]},
		{"command":[ "SETTEXT", "「んぐぅうううっ……！　二度も！　二度も私の胸を蹂躙して……！　イヤ、\nだ……そのドロドロは嫌なんだ！　あっ、あっ、本能が恐れているッ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_189_0103301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018901_01_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ローズ" ]},
		{"command":[ "SETTEXT", "「乳房を孕ませようとする貪欲な肉欲を感じる……！　んんン、それに熱量が\n……臭いが……私の騎士の誇りを穢して……うぐ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_189_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ローズ" ]},
		{"command":[ "SETTEXT", "「お前はただのメスだと言わんばかりに白濁に染め上げていく……！　あああ\n……！　いつまでビクビク射精しているんだ、しつこい、汚い……ッ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_189_0103303" ]},
		{"command":[ "SETIMAGE", "0", "still_00018901_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ローズ" ]},
		{"command":[ "SETTEXT", "「二度もこんな大量に出されたら……ほら見ろ！　胸肉で抑えきれなくなって\n……おぁあああ、ダラダラ下に垂れるっ、こぼれていく……ぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_189_0103304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ローズ" ]},
		{"command":[ "SETTEXT", "「なんてだらしない有り様だ……。おいっ……これ以上あたりを汚さないよう\nに……しっかり胸を支えていろ……っ。でないと……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_189_0103305" ]},
		{"command":[ "SETIMAGE", "0", "still_00018901_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ローズ" ]},
		{"command":[ "SETTEXT", "「このいやらしい臭いが、部屋に移って残ってしまうだろう……！　っごくっ\n……それにしても、凄まじい量を吐き出すものなのだな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_189_0103306" ]},
		{"command":[ "SETIMAGE", "0", "still_00018901_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ローズ" ]},
		{"command":[ "SETTEXT", "「乳房ですら白一色に染め上げられてしまうのに……。この量をもし、万が一\n膣内に流しこまれていたらと想像すると、身震いするほどだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_189_0103307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ローズ" ]},
		{"command":[ "SETTEXT", "「『いずれそっちにも』……？　くっ……馬鹿にするな！　鮭の射精かと思う\nほどの量を、私が子宮で受け止めるとでも？　この臭い孕ませ液を？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_189_0103308" ]},
		{"command":[ "SETIMAGE", "0", "still_00018901_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ローズ" ]},
		{"command":[ "SETTEXT", "「腹が破裂してしまうだろうが……！　それ、に……赤子が出来たりしたら…\n…。この私が母になる、のか……？　それは……ッ、ん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_189_0103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ローズ" ]},
		{"command":[ "SETTEXT", "「何！？　頬を赤らめてなどいない！　誰が貴公の子どもなぞ……！　む、胸\nで種付けさせてやっただけで、ありがたいと感謝するんだな……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_189_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ローズ" ]},
		{"command":[ "SETTEXT", "「んぁっ……はぁっ、ああッ……！？　なんだっ、チンポを引きずり抜いて…\n…んあっ！？　あああっ！　嘘だろうっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_189_0103401" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ローズ" ]},
		{"command":[ "SETTEXT", "「ぷぁっ、んぷぁあっ……うぷっ、んん……！！　か、顔……！？　顔に精液\nをぶつける、などと……貴公！　どこまで私の誇りを傷つけ……ぷぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_189_0103402" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018901_01_17" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ローズ" ]},
		{"command":[ "SETTEXT", "「臭いっ……臭い……！　それに生温かくて、おぇっ……！　生き物の体液な\nど、騎士に浴びせかけて……許さんぞ！　私は神聖ネーラ王国の……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_189_0103403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ローズ" ]},
		{"command":[ "SETTEXT", "「って、んっ、んんんッ……！？　ば、馬鹿か！　どれだけ出したら終わるん\nだ、貴公のそれは……！　まともに口もひらけないではないか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_189_0103404" ]},
		{"command":[ "SETIMAGE", "0", "still_00018901_01_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ローズ" ]},
		{"command":[ "SETTEXT", "「んーーーーっ！　んんんん……ッ、うううう……！　はぁっ、はぁ、はぁ…\n…やっと……やっと出しきったか……なんて量だ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_189_0103405" ]},
		{"command":[ "SETIMAGE", "0", "still_00018901_01_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ローズ" ]},
		{"command":[ "SETTEXT", "「……貴公。私が貴公に貸し出したのは、胸だけだったと記憶しているのだが\n？　言い残すことは何かあるか？　すぐに切り捨ててくれる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_189_0103406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ローズ" ]},
		{"command":[ "SETTEXT", "「はぁ……？　『厳しくも麗しいお嬢様女騎士の、美しい顔に種付けしたかっ\nた』？　……美しい……？　この有り様がか……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_189_0103407" ]},
		{"command":[ "SETIMAGE", "0", "still_00018901_01_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ローズ" ]},
		{"command":[ "SETTEXT", "「『男は整った、美しい物を汚したくなることがある』……？　……おべんち\nゃらで命乞いか？　フン……しかし、確かに殺意は削がれた」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_189_0103408" ]},
		{"command":[ "SETIMAGE", "0", "still_00018901_01_16" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ローズ" ]},
		{"command":[ "SETTEXT", "「が！　髪にまで飛び散った臭い汁の片づけは、必ず貴公にしてもらうからな\n！　ぺっぺっ……信じられん、騎士の顔に精液のシャワーなど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_189_0103409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ローズ" ]},
		{"command":[ "SETTEXT", "「おい。何をニヤニヤしている。こんなことは二度とするなよ！　粘り気がひ\nどくて最悪の気分だ。胸も顔も、貴公の好きにされてしまうなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_189_0103410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}