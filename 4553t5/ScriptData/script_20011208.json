{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0000" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「鉄のトップスは外れ、鉄のボトムはゴムが緩み、埋もれたバズーカは二度と\n火を噴く事はない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021430001" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ビキニの戦士は死んだのだ。狼も死んだ、獅子も死んだ。心にビキニを持つ\n者は、すべて逝ってしまった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021430002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "bg_0024" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「はて……どなたか今、ナレーションで大嘘をつきませんでしたかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021430001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なにをワケわかんねえこと言ってんだ、おまえ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「そんなことより！　みんな無事に湿地帯から抜け出せて、よかったですね！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_010021430001" ]},
		{"command":[ "SETCHARA", "0", "char_00005602_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「見えない襲来者（インベーダー）は手ごわかったけどな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_010021430001" ]},
		{"command":[ "SETCHARA", "0", "char_00005802_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「バズ太郎きゅん、大活躍だったねぇ～。よしよし～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_010021430001" ]},
		{"command":[ "SETCHARA", "0", "char_00006402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「さすがに、夜はちょっと冷えるわね……。ビキニ一枚なんだから当たり前だ\nけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_010021430001" ]},
		{"command":[ "SETCHARA", "0", "char_00006702_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「これが、この装備の欠点ですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_065_010021430001" ]},
		{"command":[ "SETCHARA", "0", "char_00006502_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「みんな、寒かったらもっと火のそばに寄れよ。今のうちに休んでおこうぜ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「ふぅ～！　ひとやすみひとやすみ！　長官から指示された町まで、あとどれ\nぐらいっスかね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_010021430001" ]},
		{"command":[ "SETCHARA", "0", "char_00006102_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「もうすぐだ。明日の昼前には着くよ。そこへ行って、指示されたデータを回\n収すれば任務は終わりだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_010021430002" ]},
		{"command":[ "SETCHARA", "0", "char_00005802_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "うまく迎えのヘリと合流できるかどうかが問題だけどな……そのためには……\n。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なあ、無線機の様子は？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「もうちょっとだけ待ってください……いま、なんとか……やった！　直った\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_010021430001" ]},
		{"command":[ "SETCHARA", "0", "char_00006302_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おっし！　よくやったぜ！　ご褒美だ、帰ったらみんなに、なんかおごって\nもらえ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「えへへへっ、隊長さんがおごってくれるんじゃないんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_010021430002" ]},
		{"command":[ "SETCHARA", "0", "char_00006302_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「あ！　隊長、ずるいです～！　私たちにもおごってくださ～い！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_010021430002" ]},
		{"command":[ "SETCHARA", "0", "char_00005602_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はははっ、さすがにそれはキツいからな、割り勘で打ち上げでもやろうぜ。\n無事に本部に帰ったらな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「本部に帰ったら、か……。あんたたち、帰ったら真っ先になにをやる？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_010021430003" ]},
		{"command":[ "SETCHARA", "0", "char_00005802_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「私、帰ったら結婚するんだ。バズ太郎きゅんと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_010021430002" ]},
		{"command":[ "SETCHARA", "0", "char_00006402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「貴方はまず、そのバズーカフェチを治療してもらった方がいいんじゃないか\nしら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_010021430002" ]},
		{"command":[ "SETCHARA", "0", "char_00006702_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「そういうアディーさんはなにをするんです？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_010021430001" ]},
		{"command":[ "SETCHARA", "0", "char_00006802_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「そうね……科学部に戻ろうと思うの。どうしてもやっておきたい研究があっ\nて……って、宵待？　なに読んでるの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_010021430003" ]},
		{"command":[ "SETCHARA", "0", "char_00006702_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「このまえＥＤＯに見学に来た、子供たちからの手紙です。とっても喜んでく\nれたみたいで……ほら、そのときの写真！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_065_010021430002" ]},
		{"command":[ "SETCHARA", "0", "char_00006502_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「はははっ、楽しそうっスね！　自分はやっぱり、帰ったら愛機をピカピカに\n磨いて、大空をぶっ飛ぶっス！　全開バリバリっすよー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_010021430002" ]},
		{"command":[ "SETCHARA", "0", "char_00006102_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「ふっ……あんたらしいよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_010021430004" ]},
		{"command":[ "SETCHARA", "0", "char_00005802_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「先輩は、なにかないんスか？　帰ったらやりたいこと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_010021430003" ]},
		{"command":[ "SETCHARA", "0", "char_00006102_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「あたしかい？　あたしは、そうだなぁ……フカフカのベッドでぐっすり寝る\nかなぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_010021430005" ]},
		{"command":[ "SETCHARA", "0", "char_00005802_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「いけません、これはいけませんな……これは危険です。」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021430002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんだ、ジュンジロー。また妙なこと言い出しやがって。なにが危険だって\nんだよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「皆さん、フラグ立てに熱心すぎますぞ。下手をすれば、このまま全滅もあり\nうるレベルですぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021430003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あのなあ……どうしておまえは、そうやって意味不明なことを――」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "と、言いかけたとたん、どこからか光線が飛んできた！", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「しまった！　敵の奇襲ですか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_010021430003" ]},
		{"command":[ "SETCHARA", "0", "char_00005602_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「敵はあっちです！　みんな、物陰へ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_010021430002" ]},
		{"command":[ "SETCHARA", "0", "char_00006802_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「って、ジュンジローっ！　てめぇが妙なこと言い出すから！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「心外ですな！　わたくしのせいではありませんぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021430004" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0000" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「脱ぐものと脱がされるもの、そのスクリーンショットを狙う者。牙を持たぬ\nものは、生きてゆかれぬ混沌の街」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021430003" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「あらゆるキャラが武装する廃墟の街。ここは次元間闘争が産み落とした、成\n人向けのソドムの市」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021430004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「カツマの体に染みついた不運の臭いにひかれて、危険な奴らが集まってくる\n。次回『ドラ猫は眠らない』」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021430005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「カツマが飲むインスタントコーヒーは、薄い」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021430006" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}