{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0080" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「ふぅ……。やかましいのは苦手かも。でも、夜のビーチは……いいなぁ。静\nかで、暗くて、湿ってて……。落ち着く……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0503101" ]},
		{"command":[ "SETCHARA", "0", "char_00001805_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
				
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「この衣装……。”あの人”が見たら、なんて思うかな。似合うって言ってく\nれるのか、照れてちゃんと見てくれないのか……。でも」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0503102" ]},
		{"command":[ "SETCHARA", "0", "char_00001805_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「きっと「綺麗だね」って言ってくれるに違いない。それどころか、もしかし\nたらムラムラして、いきなり情熱的に迫られたりして……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0503103" ]},
		{"command":[ "SETCHARA", "0", "char_00001805_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「っん……。だ、誰もいないからって、外でいきなり胸でしてほしいとおねだ\nりするなんて……。そんなにこの衣装、気に入ってくれたの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0503104" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001805_01_02" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「それとも……私のことが愛しくてたまらなくなったんだったりして……。な\nんちゃって。って、えっ？　ほ、本当にそう……なの？　……あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0503105" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「月明かりに照らされた私が、綺麗で襲いたくなった、なんて……。そんなこ\nとを言われたら、さ、サービスしたくなる。もっと言って……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0503106" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「うん。もっと、綺麗だって言ってほしい。……ふ、フフフフ……♪　そう。\nそんなに褒めてくれるなら、正直な気持ちには正直に応えてあげる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0503107" ]},
		{"command":[ "SETIMAGE", "0", "still_00001805_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「っんっ……。ぴちゃっ、ちゅぷっ、くちゅっ……。フフフ、気持ちいい……\n？　うん、言葉で気持ち良くしてもらったから……お返し」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0503108" ]},
		{"command":[ "SETIMAGE", "0", "still_00001805_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「私も口でご奉仕して、たくさん感じさせてあげる……。れろっ、ぴちゃっ、\nれるれるれる……。ん……っ、濡れた舌を肉幹に這わせて、絡ませて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0503109" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「ぴちゃぴちゃくちゅくちゅ、いやらしい水音をたてながら……いっぱいいっ\nぱい舐めて、しゃぶって……。こういうの、すごく好きでしょ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0503110" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「君は……何もしなくていい。ただ、快感に身を任せていて。その方が、うん\nと感度も高まると思う。全ての余計な思考を排除して、ただ快楽だけ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0503111" ]},
		{"command":[ "SETIMAGE", "0", "still_00001805_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「快感だけに酔いしれて、溺れて……。ぴちゃっ、んれろぉ……亀頭を舐め回\nして……。んっ、ん、ちゅっ、尿道口をほじくり、ながら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0503112" ]},
		{"command":[ "SETIMAGE", "0", "still_00001805_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「唇で何度も先端にキスをする……。んちゅ、ちゅっ、ちゅっ、ちゅっ……。\nああ、やっぱりこういうのが好きなんだ。愛情いっぱいのフェラ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0503113" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「大丈夫。ちゃんと裏筋も、根元も全部濡らして刺激してあげるから。……ん\nれろぉお……っ。先っちょをチロチロされるのもゾクゾクしていいけれど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0503114" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「こう、やって……んれろっ、れろっ、れろぉ……れるっ。大きく根元から、\nカリ首まで舐め上げて……唾でびちゃびちゃにするのも、いいよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0503115" ]},
		{"command":[ "SETIMAGE", "0", "still_00001805_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「んっ、んっ……ちゅぷっ、んれろぉおっ、れろっ……♪　れろぉおっ、れろ\nっ……♪　たっぷり濡らして、それからすすり取る……じゅるるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0503116" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「ぢゅるっ、じゅるるっ、じゅる……♪　そしてまた舐め回すぅ……。っぴち\nゃっ、くっちゅっちゅぷっ、れろっ、ぺろっ、くっちゅっ、ちゅぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0503117" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「んーふふふ。そうかも。君が激しく反応してくれるから、楽しくなってきた\n。どこが好き？　どんな舐め方がいい？　ここ？　こう？　ぴちゃっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0503118" ]},
		{"command":[ "SETIMAGE", "0", "still_00001805_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「君の要望ならなんでも聞くから……。んっ、ひどいこと、命令してもいいよ\n……ぴちゃっ。どうせ、気をつかってしないだろう、けど。ん、ちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0503119" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「フェラチオは……んんっ、尽くしている気分になれるから、好き……。んち\nゅっ。ねえ、君のおチンポすごいよ……？　れろっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0503120" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「どんどん硬く、太く、大きくなってくる。それに……この、むせかえるよう\nな蒸れた臭い……。あぁああ、くさい、でもそれが……いい……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0503121" ]},
		{"command":[ "SETIMAGE", "0", "still_00001805_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「この、濃い味がクセになる……。んちゅ、ちゅむっ、ぴちゃっ、ぺちゃ……\n♪　フフ、わかるでしょ。私が夢中になってるのが……ぴちゃっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0503122" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「だって君のおチンポ、ずっとビクビクしてて飽きさせないんだもん。それに\n……んっ、ちょっとずつ先走りの透明なお汁が滲み出してきた……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0503123" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「ぴちゃっ、ぴちゃ、これ、ぜーんぶ私だけのモノだから……んれろっ、他の\n誰にもあげない……。ちゅぷっ、私だけのおチンポのお汁……くっちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0503124" ]},
		{"command":[ "SETIMAGE", "0", "still_00001805_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「んん、んんん……っ。そうだ、お口だけで楽しんでるなんてもったいないよ\nね。せっかくだから、この胸も……使って喜ばせたい……ちゅっぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0503125" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「はぁっ、これくらいの強さでシゴいても平気？　んっ、ちゅっ、ちゅるっ…\n…♪　おチンポナメナメされながら、胸でシゴかれるなんて最高でしょ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0503126" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「んっ……♪　安心して。ご奉仕してるこっちも……、んっ、私も感じてるか\nら。興奮して濡らしてる……。ちゅぷっ、ぷちゅ、理由はわかるよね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0503127" ]},
		{"command":[ "SETIMAGE", "0", "still_00001805_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「好きな人……のだから、舐めると頭がぼーっとして……ぴちゃっ、谷間に挟\nむと身体が疼いて仕方ない……。んっ、ちゅっ、ちゅっぷっちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0503128" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「あああ……♪　こんな時間がずっと続いてほしい……れろっ、んっ、ちゅっ\n♪　くちゅっ、ちゅっ、ちゅむっ……ぴちゃっ、ぴちゃっ、れろぉっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0503129" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「気持ひいい……？　れろっ、くっちゅっ、ちゅぷっ、ぷちゅっ……♪　んッ\n♪　また先走りが溢れてきたぁ……れろっ、ちゅくっ、ぷっちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0503130" ]},
		{"command":[ "SETIMAGE", "0", "still_00001805_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「んっ、んっ……君のおチンポ、太すぎて口に全部入らない……。っんむっ…\n…♪　ちゅくっ、くちゅ……♪　んぁあ、舌がヌルヌルひゅる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0503131" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「このヌルヌルをぉ……っ、くちゅっ、おチンポにぬりつけて、舌をすべらせ\nて……♪　んちゅ♪　んちゅ♪　んちゅ……んんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0503132" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「おチンポ……膨らんできてるよ、それに腰を浮かせて、ヘコヘコさせてるね\n……♪　フフ、そろそろ精液を出したくなってきた？　いいよ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0503133" ]},
		{"command":[ "SETIMAGE", "0", "still_00001805_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「素敵な夜の海岸で……私のお口にザーメンどぴゅどぴゅしちゃえばいい……\n。ほら、ほら……出したくて、出したくて震えてる……んちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0503134" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「絞り取るから、おチンポに集中して。……んちゅっ、ちゅぷっ、ぷっちゅっ\n、くちゅ……。ぢゅるっ、じゅるっ、じゅるるるっ……んっちゅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0503135" ]},
		{"command":[ "SETIMAGE", "0", "still_00001805_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「んんんっ……！？　んむぅっ、むぅうううっ、んぅうううっ……！　こほっ\n……！　んぅっ！　んッんっんんんんん……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0503136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001805_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「ご、めん……ちょっとだけ口からこぼれて……ぢゅるっ。今飲みこむから、\n動かないれ……。ん……じゅる……じゅるっ、ごく、ごくっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0503137" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「んんぅ……♪　粘り気がひゅごくて……一度じゃ飲みこめ、にゃい……。ん\nれろ……れろっ、ぢゅる……じゅるっ、じゅっ……んんん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0503138" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「ごくっ……ごく……。んふぅ……、想像よりもずっと濃くて……しつこい味\n……。でも、こんなにたくさん出してくれるなんてうれしい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0503139" ]},
		{"command":[ "SETIMAGE", "0", "still_00001805_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「そんなに私の舌、気持ち良かったんだ……？　それとも……いつもと違う衣\n装で、違う場所でしてたから……？　んっ……臭いもすっごくキツい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0503140" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「口の中にむわぁって広がるくさい臭い……。ザーメンを飲んでも飲んでも、\n全然消えない……。フフ、すっかり君の色に染められてしまっ……んん？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0503201" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「ど……どうしてビュルビュル射精したすぐ後なのに、また君のおチンポが硬\nくなってきているの……！？　ふ、復活したってこんなすぐに……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0503202" ]},
		{"command":[ "SETIMAGE", "0", "still_00001805_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「わ、私の舌でもっと舐めてほしい？　もう一度ぴちゃぴちゃ舐め回して、精\n液を絞り取ってほしい？　君は……その、変な人、だね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0503203" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「私なんかのフェラチオで、そんなに楽しそうに……幸せそうにして……。そ\nんな顔をされたら、しないわけにはいかなくなる。それに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0503204" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「君のおチンポの昂りがすごすぎて……。こ……このままじゃ、どこにも帰れ\nない。とにかく小さくしてからじゃないと……。……だから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0503205" ]},
		{"command":[ "SETIMAGE", "0", "still_00001805_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「もう一度……してもいい。ううん、私もしたいと思ってた……。……ねえ、\nフェラチオ……続けてもいい？　……ん。それなら再開するね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0503206" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「……ん……。れちゅっ……くちゅ、ぴちゃっ、ちゅぷ……♪　んんんっ、ま\nだまだザーメンの味、ぬめり……残ってる。キレイにしないと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0503207" ]},
		{"command":[ "SETIMAGE", "0", "still_00001805_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「んちゅ……ぷちゅ……。は、ぁああ……♪　ネトネトしてる……んちゅ……\n。……え？　胸でも一緒に刺激した方が早い、って……？　そうだね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0503208" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「まだ、尿道の中に出しきれていなかったザーメンが残っているかもしれない\nし……。まずはそれを吸い出すよ。……んっ……ちゅっ、ちゅっちゅぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0503209" ]},
		{"command":[ "SETIMAGE", "0", "still_00001805_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「んむっ♪　ぴゅるって出たぁ……♪　んちゅ、やっぱり奥に残ってた……。\n待って、全部出しきってから、飲む……。っちゅっ、ちゅぅううっ、ちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0503210" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「ん……ん……。またぴゅるって……。フフフ、それじゃあ飲むね。……ごく\n……ごく……♪　ん、これで良し……キレイになった……でも」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0503211" ]},
		{"command":[ "SETIMAGE", "0", "still_00001805_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「おチンポ、どんどん太くなってきてる、から……。またすぐに新しく射精、\nかな……？　っん……♪　清めても清めても、すぐ汚す……♪　ぴちゃっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0503212" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「それくらいじゃないと、この不幸のグリムロックには釣り合わない、かな…\n…？　なんて、……ごめん。おしゃぶりに集中するね。いくよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0503213" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「んッ、ちゅぷっ、ちゅっ、ちゅくっ、くちゅっ、ちゅっちゅっ、ちゅるぅう\nうっ……ちゅむっ♪　フフ、ビリビリくる？　っちゅっ、ちゅ、ちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0503214" ]},
		{"command":[ "SETIMAGE", "0", "still_00001805_01_05" ]},		
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「れろぉおおおっ、れろ……くっちゅっ、ぴちゃ……♪　ちゅむ♪　ちゅむ♪\nくちゅ……。んれろっ……れろぉ……んむっ、くちゅ、くっちゅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0503215" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「先端、を、唇ではさんれ……。シゴきながら、キス……。ちゅっ、ちゅ、く\nちゅ……♪　肉茎を舌先でねぶり回して……れろれろれろ、れろれろれろ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0503216" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「んん、順調におチンポの芯が硬く……んんんっ♪　んちゅ……ぴちゅ、れろ\nっ、んれろ……ん？　ここ？　こっち？　どこが感じる……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0503217" ]},
		{"command":[ "SETIMAGE", "0", "still_00001805_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「んちゅ、ちゅぷ……はぁ、はぁ♪　また君のおチンポがパンパンに腫れあが\nって、きてる……。たっぷり精液が溜まってきた証拠……っちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0503218" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「これを私が……んちゅ、全力で吸い上げて、絞り取ればいいんだね。はぁっ\n、んッ……たくさん出ひて……♪　一度目みたいに、溺れるくらいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0503219" ]},
		{"command":[ "SETIMAGE", "0", "still_00001805_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「びゅるびゅるドクドクザーメン発射して、私のこと、褒めて……！　エッチ\nでキレイだって！　っちゅるっ、じゅるるっ、じゅるるるるっ、出してっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0503220" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「ふむぅっ……！　んッ……んくっ……！　ふぅっ、うう……♪　ん～～～～\n～～っ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0503301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001805_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「んふ……っ、さっきあれだけ出ひたばかり、なのに……またこんなにぃい…\n…。君の凄さを実感させられた、かもぉ……。んっんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0503302" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「いいよ、出せるだけ全部出ひて……君の本気を見へて……！　ッんんんっ♪\nほらぁ、まだまだ出せる、よね……ドクドクッて……ふむぅううっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0503303" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「んんんんん……♪　ごくッ……。ごく、ごく……あぁああああ……♪　とん\nでもないえぐみ……喉奥から鼻に突き抜けてくる、臭さ……んむぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0503304" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「うまく、ひゃべれない……。舌を動かす、のが、むじゅかしいほど……口の\n中に絡みついたネバネバ……。んぅ、ごくっ……飲みきれない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0503305" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「んはぁああ……♪　んくっ、フフ……。鼻から逆流してひまいそう、だった\n……危なすぎる……。そんなに喜んでもらえて、嬉しいよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0503306" ]},
		{"command":[ "SETIMAGE", "0", "still_00001805_01_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「っんんんん……。ふはぁああ……。息までねっとりとザーメン臭がする……\n。君は本当に容赦がないね、勢いが凄すぎて驚いた……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0503307" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「……え？　二回もザーメンを飲ませて怒ってないか？　フフ、フフフフ、今\n更そんなことを気にするなんて……。私と君の仲なのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0503308" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「私は……君のために尽くして、君のためにどんどんエッチに変わっていく自\n分が、嫌いじゃない……。だからこれからも楽しみだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0503309" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「君のために色んな衣装に着替えて、君のためだけに色んなエッチを覚える…\n…。皆を幸せにする前に、私が幸せになってしまって申し訳ないよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0503310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},
		
		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「さあ、私のお口の中にっ……。って、あっ！？　そ、そんなっ……おチンポ\nが抜けて、逃げて……んんぅううううっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0503401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001805_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「んぷぁっ！　こ、こらっ！？　顔に、顔にかかってるっ……ザーメン浴びせ\nかけられてるぅううっ……！　ふ、不幸……っ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0503402" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「せ、せっかく二回目もお口の中に……喉に、しっかり受け止めるつもりでい\nたのに……。って、君がそうしたくてしてるの？　あっ♪　それならっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0503403" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「し、幸せ？　もうわからないっ……、んんんんぁっ。熱い……くさいぃいっ\n……。あっ！　ぁっ……ふぁああ……たくさんかかって……！　あぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0503404" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「はぁーっ、はぁああーっ……。よ、良かった……のかな、せっかくの衣装、\nがザーメンまみれにならずに……私の顔だけにかかったなら……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0503405" ]},
		{"command":[ "SETIMAGE", "0", "still_00001805_01_11" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「ん、ぁ、べ、別にかけられたことは……いい。突然だったから驚いた、だけ\n……。そういう気分の時もあると思う……し……。んぅ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0503406" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「ふー……♪　君も落ち着いた……？　ん、本当にいいよ。顔にかけたかった\nなら、かけてくれるのが一番……。なんだけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0503407" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「もう一度飲みたかったっていうのも、本音だから……。難しい。劣情のまま\nに顔にザーメンを発射され、塗りたくられる快感と……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0503408" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「呼吸すらできなくなるほど、大量にザーメンを口の奥に流しこまれる快感と\n……。私にはとても選べない。どちらも素晴らしすぎて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0503409" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「だから、どうやってザーメンを出すかは……君に任せてる。射精のたびに、\nどちらにされるか楽しめるのも……素敵だと思わない……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0503410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}