{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「オシオキですか……ですが、これも全て私のせいです。好きにしてください\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0204101" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "2", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「それで？　私はなにをすればいいんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0204102" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「えっ……！？　一番思い出に残ってる、エッチの体験談を話せですって……\n！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0204103" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「そうやって、私を辱めるのがオシオキというわけですか……くっ、わかりま\nした……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0204104" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「一番かどうかはわかりませんが、初めてセックスをしたときのことは、今で\nも鮮明に覚えています……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0204105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「あっ、んんっ……！　すごい……これがオチンチンなんですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0204106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001602_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「太くて、カタくて……あっ、はああぁ……！　お、オマンコに軽く触れられ\nるだけで、感じてしまいます……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0204107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「で、ですが……私のような、気ばかり強くて可愛くない女が相手でいいので\nすか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0204108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「いっ、いえ……！　決してイヤというわけではなく……！　その、今までこ\nうした経験がないもので……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0204109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「ああぁんっ……！？　ど、どうして急にオチンチンが大きくなるんですか…\n…！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0204110" ]},
		{"command":[ "SETIMAGE", "0", "still_00001602_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「私が処女で興奮した……？　そんなことで興奮されても、嬉しくありません\n……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0204111" ]},
		{"command":[ "SETIMAGE", "0", "still_00001602_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「ああんっ……！　そうやって、オマンコにオチンチンを擦り付けて、誤魔化\nそうとしてもムダです……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0204112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「はぁ、ああっ……オチンチンで刺激されると、オマンコからエッチなお汁が\n止まりません……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0204113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「は、早く挿れてください……！　私のオマンコに、オチンチンをズブズブっ\nて挿れて……はああぁあん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0204114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「あっ、あっ！　は、入ってくるぅ！　ガチガチに勃起したオチンチンが、私\nの膣内に……んひっ、はああっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0204115" ]},
		{"command":[ "SETIMAGE", "0", "still_00001602_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「んんんっ……！　す、すごい……！　オマンコが押し広げられてるっ……！\n　お腹の中、温かいのでいっぱいだわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0204116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……んっ、くううぅ……！　だ、大丈夫です……痛くありません\nから、好きなように動いていいですよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0204117" ]},
		{"command":[ "SETIMAGE", "0", "still_00001602_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「いっぱいオチンチンをズポズポして、私のオマンコをほじってください……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0204118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「たくさん気持ちよくなってもらって……子宮にありったけの精液を注いでく\nれると、嬉しいです……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0204119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「私が妊娠するぐらい、濃厚なザーメンを赤ちゃんの部屋に……あっ、あああ\nっ！　んっ、はあああぁん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0204120" ]},
		{"command":[ "SETIMAGE", "0", "still_00001602_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「う、動いていいとは言いましたが……！　そ、そんな、いきなり激しく……\nあっ、ふぐっ、あっ、あああっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0204121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「おっ、奥に当たってますっ！　私の大事なところ、オチンチンの先端がトン\nトンってして……んんんっ～～～～！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0204122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「これがセックスなのね……！　すごく、気持ちいいわっ……！　あっ、あん\nっ！　くあっ、ふくうぅぅぅっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0204123" ]},
		{"command":[ "SETIMAGE", "0", "still_00001602_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「オチンチンが出入りするたびに、勝手にオマンコが締まって……あんっ！　\nこんな感覚、初めてだわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0204124" ]},
		{"command":[ "SETIMAGE", "0", "still_00001602_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「くううぅぅぅ～～～……っ！？　オチンチンのカタチがわかるぅ……！　根\n本から先端まで、全部感じ取れるのぉ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0204125" ]},
		{"command":[ "SETIMAGE", "0", "still_00001602_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「傘みたいなところが、オマンコの色んなところに引っかかって……！　あっ\n、あっ！　ゾリゾリって、引っ掻いて来るっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0204126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「ね、ねぇ……！　奥もいいけど、浅いところも好きなの……！　Ｇスポット\nのあたりも、ズポズポしてっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0204127" ]},
		{"command":[ "SETIMAGE", "0", "still_00001602_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「んんっ！　あっ、あっ！　そこ、そこいいっ！　オマンコの入り口のあたり\n、ヌプヌプされるのたまらないわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0204128" ]},
		{"command":[ "SETIMAGE", "0", "still_00001602_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「クリトリスの裏側を刺激されてるみたいで、すごく感じるっ！　一人でオナ\nニーより、全然気持ちいいのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0204129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「あっ、あひっ！　んひいぃぃんっ！？　オチンチンビクビクさせながら、オ\nマンコ引っ掻かないでぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0204130" ]},
		{"command":[ "SETIMAGE", "0", "still_00001602_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「ビンカンなところを、そんな風に刺激されたらイッちゃうっ！　オマンコイ\nッちゃうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0204131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「くひっ、はっ、あううぅぅ！？　オマンコの膣内で、オチンチンがビクンっ\nて暴れて……んぁ、あはあぁっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0204132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「オチンチン、イキそうなのねっ！　いっぱい、膣内出ししたいのねっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0204133" ]},
		{"command":[ "SETIMAGE", "0", "still_00001602_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「いいわよ……来てっ！　オマンコの奥に突き入れながら、膣内出ししてぇ！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0204134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「あっ、あんんっ！　イッ、イキますっ！　私、イッちゃ……あっ、ああっ、\nあはああぁぁぁぁぁんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0204135" ]},
		{"command":[ "SETIMAGE", "0", "still_00001602_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「ふああああぁ……！？　で、出てるっ……温かいの、子宮に流れ込んできて\nるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0204136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001602_02_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「これが膣内出しの感覚……んっ！　あっ！　精液を感じたら、また気持ちよ\nくなってきて……くうううぅ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0204137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「こんなの、またイッちゃうっ！　イッたばかりなのに、またイクぅぅぅんっ\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0204138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「んふぅぅぅ～～～……！　あっ、はああぁ……イキながら膣内出しされるの\n、気持ちいいわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0204139" ]},
		{"command":[ "SETIMAGE", "0", "still_00001602_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「こんな幸せな感覚があるなんて……セックスって、とても素敵なのね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0204140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「はぁ、ああぁ……たくさん出したわね……オマンコに入りきらなくて、精子\nが溢れてきてるわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0204201" ]},
		{"command":[ "SETIMAGE", "0", "still_00001602_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「では、そろそろオシマイに……と、言いたいけど、まだオチンチンがカタい\nままね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0204202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「オマンコの奥でビクビクしてて……もっと射精したいって、言ってるみたい\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0204203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「私ももっと気持ちいいのを感じたいから……よかったら、またオチンチンズ\nポズポしてくれるかしら……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0204204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「ああっ……！　も、もう……！　そんなにやる気を出さなくても……！　あ\nっ、あっ！　ひぐううぅぅぅ～～～！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0204205" ]},
		{"command":[ "SETIMAGE", "0", "still_00001602_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「んんっ！　あっ、はああぁ！　またオチンチンが、浅いところをズポズポし\nてきてるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0204206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「んはっ、あっ、ひぐううぅ……！？　そ、そこも気持ちいいけど、今度は奥\nでイキたいわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0204207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「子宮口をトントンしたりして、いっぱい感じさせてっ！　私のオマンコに、\nオチンチンのカタチを憶えさせてっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0204208" ]},
		{"command":[ "SETIMAGE", "0", "still_00001602_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「くはあああぁ……！？　おっ、奥まできてるぅ！　オチンチンがズンズンっ\nて、一気に奥まで届いて……ふあああぁ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0204209" ]},
		{"command":[ "SETIMAGE", "0", "still_00001602_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「Ｇスポットのところもいいけど、奥もいいわっ！　指だと届かないようなと\nころ、刺激されてるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0204210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「んんっ～～～～っ！　そうやって、グリグリされるのもたまらないのっ！　\n気持ちよくて、エッチなお汁がどんどん出ちゃうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0204211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、あああっ！　もっと大きく動いてっ！　思い切り腰を動かして\n、オチンチンを奥に打ち付けてっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0204212" ]},
		{"command":[ "SETIMAGE", "0", "still_00001602_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「ああぁっ！　そっ、そうよっ！　私のオマンコをほじるみたいに、ズンズン\nってしてっ！　いっぱい、オマンコにキスして頂戴っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0204213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「くっ、あふっ、ああっ、はああぁん！　気持ちよくて、身体が疼いちゃうっ\n！　さっき膣内出しされたのに、また精液欲しくなってきちゃうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0204214" ]},
		{"command":[ "SETIMAGE", "0", "still_00001602_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「はあっ、んっ、ふあっ！　あっ、あひっ、んくううぅ……！　このオチンチ\nン好きっ！　ガチガチの勃起オチンチン、大好きっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0204215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「鬼族の娘なのに、恥を晒しているのはわかってるわ……！　でも、ずっとオ\nチンチン挿れて欲しいって思っちゃうのっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0204216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「あああっ！　締め付けると、オチンチンの振動がすごく伝わってくるっ！　\nこれ、さっきも感じたわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0204217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「い、イキそうなのねっ！　オチンチンから、また特濃ザーメンびゅるびゅる\n出るのねっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0204218" ]},
		{"command":[ "SETIMAGE", "0", "still_00001602_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「あっ、んひっ、くううぅんっ！　わ、私もまたイクから、一緒にイキましょ\nうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0204219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「あっあっあっ！　イクッ！　イクイクイクッ！　オマンコイクぅぅぅぅぅ～\n～～～～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0204220" ]},
		{"command":[ "SETIMAGE", "0", "still_00001602_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「ひああああぁぁぁん！？　またびゅるびゅる出てるぅ！　オマンコの奥に、\n出されてるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0204301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001602_02_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「あっ、あっ！　射精してるのに動くなんて……！　そんなことしたら、赤ち\nゃんの部屋にどんどん精子が流れ込んできちゃうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0204302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「幸せすぎて、オマンコ感じちゃうっ！　イクのとまらなくなっちゃうぅ～～\n～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0204303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「あああっ、あっ、ふああああぁ……！？　かっ、身体の震えが止まらないわ\nっ！　射精に合わせて、何度でもイッてるのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0204304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「くうぅぅぅ～～！　セックス気持ちいいっ！　オチンチン気持ちいいっ！　\nああっ、んっ、あはああぁぁぁあぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0204305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「ふぐっ、んんっ……本当に、たくさん出したわね……オマンコから溢れちゃ\nってるわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0204306" ]},
		{"command":[ "SETIMAGE", "0", "still_00001602_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「確かに、膣内に出してと言ったのは私だけど……子宮にまで流し込まれるな\nんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0204307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「今もオチンチンに残ったザーメンがドクドク出てるし……妊娠したら、どう\nするつもりなの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0204308" ]},
		{"command":[ "SETIMAGE", "0", "still_00001602_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「そのときは、ちゃんと責任を取るって……そ、そんなの当たり前じゃない！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0204309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「今回は仕方ないけど、今後は計画的に膣内出しするのよ。いいわね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0204310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「あああぁん！　お、オチンチンがオマンコから抜けて……あっ、んひっ、ふ\nあああぁっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0204401" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「ザーメンがびゅるびゅる出て、私の身体にかかってるぅ！　な、なによこれ\nぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0204402" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001602_02_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「くううぅ！　ドロドロしたのが、いっぱい付いて……ああっ！　精液のニオ\nイ、すごいぃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0204403" ]},
		{"command":[ "SETIMAGE", "0", "still_00001602_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「オマンコも、身体も真っ白にされて……マーキングされてるみたいっ……！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0204404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「ああっ……でも、こうして精液に染められるのって、幸せだわ……！　オン\nナの悦びって、こういうことをいうのね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0204405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「精液まみれになるなんて……我ながら、酷い姿だと思うわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0204406" ]},
		{"command":[ "SETIMAGE", "0", "still_00001602_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「こんな無様な姿、父さまや母さまには、とても見せられないわね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0204407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「今度、私の両親に挨拶がしたい……？　ちょ、ちょっと！　なにを言ってる\nの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0204408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「あ、挨拶なんてまだ早いわ！　そういうのは、もっと段取りを踏んでからよ\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0204409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「で、でも……婚前交渉をしたのだから、挨拶するのは正しいのかも知れない\nわね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0204410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}