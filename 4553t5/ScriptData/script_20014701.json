{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0117" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "今日も今日とて、多忙過ぎて目が回る。", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "ＥＤＯ本部でしこたま働かされた俺は、夜勤明けにようやく解放され……自分\nの部屋によろよろと向かっているところだった。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「助けてくださいっス～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010023150001" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「……はて。今、誰かの声が聞こえたような」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023150001" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「センパイ～！　マジのガチで今、助けてほしいっス～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010023150002" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ん？　この声は……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "どこかで聞いた声だ、と思った瞬間、あたたかな何かがガバッと背中にしがみ\nついてきた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「センパ～イぃい！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010023150003" ]},
		{"command":[ "SETCHARA", "0", "char_00016501_01", "4", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ひぎぇえええ！　な、なんだ！？　アーマーンか！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「ハイっス！　覚えていてくれたんですねぇえええっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010023150004" ]},
		{"command":[ "SETCHARA", "0", "char_00016501_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「普通に登場すればいいものを、神出鬼没なヤツだなあ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「ひぃいん、それはすみませんっスぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010023150005" ]},
		{"command":[ "SETCHARA", "0", "char_00016501_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「それで、今回はどうした……と聞いてやりたいところだが、俺は今日ヘトヘ\nトに疲れてるんだ。明日にしてくれ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「明日じゃダメなんスよ。疲れはあーしがいくらでも個別マッサージしますん\nで聞いてくださぁい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010023150006" ]},
		{"command":[ "SETCHARA", "0", "char_00016501_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「それに、こんなところでしがみつかれてるのを人に見られるとまずい」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「まるで秘密の恋人同士の逢瀬、ですからの～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023150002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「ひゃっ♪　こ、コイビトっスか！？　あ、あーしは別に～、ソレ系でも～？\n　って、ふきゃっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010023150007" ]},
		{"command":[ "SETCHARA", "0", "char_00016501_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「なんで剥がして遠ざかるんスか～！　悪ノリしたのはあーしですけど、ホン\nトに悩みがあってきたんです～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010023150008" ]},
		{"command":[ "SETCHARA", "0", "char_00016501_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「……真剣に困っているみたいですな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023150003" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「ハイ……。うちって、ぶっちゃけエジプトの神っていうか女神？　じゃない\nスか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010023150009" ]},
		{"command":[ "SETCHARA", "0", "char_00016501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「それにしてはいつもノリが軽すぎるけどな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「エジプトには～、つか、あーしが所属してる蓬莱仙女同盟には他にも女神が\nいるんスよね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010023150010" ]},
		{"command":[ "SETCHARA", "0", "char_00016501_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「知っての通り、アヌビスパイセンとか。色んな動物っぽい神々がたーくさん\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010023150011" ]},
		{"command":[ "SETCHARA", "0", "char_00016501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……あ～、知識としてだけ、なんとなくは知っている……ような？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「今までは比較的、お互いに不干渉だったんスけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010023150012" ]},
		{"command":[ "SETCHARA", "0", "char_00016501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「つい最近、なんかエジプトの神が３つの派閥に分かれて超争ってるっていう\nか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010023150013" ]},
		{"command":[ "SETCHARA", "0", "char_00016501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「地球に昔からあった、ピラミッドやスフィンクスなどの古墳が引き起こした\nナイル川の惨劇から１０年」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010023150014" ]},
		{"command":[ "PLAYBGM", "BGM_009" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "bg_0114" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ナイル川の惨劇！？　なんだそれ！　初めて聞いた！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「……あ。今いいとこなんでちょっと黙っててください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010023150015" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お、おう……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「我が国は、犬派・猫派・その他派の3つに分かれ、混沌を極めていた……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010023150016" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「世界を滅ぼす、強大なエネルギーが秘められたエジプト最強の女神を決める\nため、新たな戦いが幕を開ける……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010023150017" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「ってカンジで超ギスギスギスリまくってるんっス」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010023150018" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0117" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00016501_01", "6", "CENTER", "0" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まじか。わりと大変なことになってるってことじゃないか！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「はい。でも、あーしとしては、全員身内も身内なんで……無駄に争って欲し\nくないんスよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010023150019" ]},
		{"command":[ "SETCHARA", "0", "char_00016501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「どうせ全員神なんだから、みんなエライ！　でまとめときたいと言いますか\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010023150020" ]},
		{"command":[ "SETCHARA", "0", "char_00016501_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「確かにな。……それで、どの派閥にも関係ない俺のところに来たわけか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「大正解！　っス！　お願いします～！　もうセンパイだけが頼りなんスよ～\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010023150021" ]},
		{"command":[ "SETCHARA", "0", "char_00016501_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うーん、しかし無関係の俺が首をツッコむのもまずいような……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「お礼にエジプトの秘宝をさしあげるっス」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010023150022" ]},
		{"command":[ "SETCHARA", "0", "char_00016501_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「秘宝！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「ハイっス。重いんで、今は持ってきてませんが必ずお届けしますんで」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010023150023" ]},
		{"command":[ "SETCHARA", "0", "char_00016501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「重い秘宝……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "といえば金の延べ棒や、古代エジプトの財宝の一部かもしれない。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……話を聞こう」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ああっ！　ご主人、めちゃくちゃ悪い顔をしてますぞ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023150004" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "ジュンジローの声は無視しつつ、俺はアーマーンに詳しい話を聞いてみること\nにしたのだった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}