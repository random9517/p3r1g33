		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「む、向こうの尻尾がっ……凄い勢いで振り下ろされていますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010021810001" ]},
		{"command":[ "SETCHARA", "0", "char_00001101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ゲホッ、ゲホッ！　こ、こっちにまで砂埃がっ……あれに巻き込まれたらひ\nとたまりもありませんぞっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021810001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「イルルっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「どうっ！？　これなら……いくらアンタでもひとたまりもないでしょっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010021810004" ]},
		{"command":[ "SETCHARA", "0", "char_00017501_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「……ヤムの……こうげき……たしかに……すごいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021810003" ]},
		{"command":[ "SETCHARA", "0", "char_00016402_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「な……くっ……う……受け止められてるっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010021810005" ]},
		{"command":[ "SETCHARA", "0", "char_00017501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「でもっ、おとーさんっ……連れてったことっ……イルルっ……おこってるん\nだからっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021810004" ]},
		{"command":[ "SETCHARA", "0", "char_00016402_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「だからっ、イルルの本気っ……ぶつけるっ！　ヴィキニドラグーンッ、展開\nっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021810005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「うぁっ！　ちょっ……待っ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010021810006" ]},
		{"command":[ "SETCHARA", "0", "char_00017501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「纏えっ雷っ……！　イルルに力を与えてっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021810006" ]},
		{"command":[ "SETCHARA", "0", "char_00016402_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「……う、あ……こ、これ……マジのヤバい……やつ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010021810007" ]},
		{"command":[ "SETCHARA", "0", "char_00017501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「集え力よっ！　あらゆる敵を薙ぎ払えっ！　驚天の斬雷（ラグナ・サンダー\n）！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021810007" ]},
		{"command":[ "SETCHARA", "0", "char_00016402_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ちょちょちょちょちょっ、ちょぉっ、ムリムリムリだしっ……うひぁぁぁぁ\nぁぁぁぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010021810008" ]},
		{"command":[ "SETCHARA", "0", "char_00017501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
