		{"command":[ "SETCHARA", "0", "char_00016402_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「あー、もうナマイキナマイキーっ！　こうなったらっ……必殺っ……テイル\nスピンッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010021810003" ]},
