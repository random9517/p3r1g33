		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「……今のは……終わったのかい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010021810001" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「何か、流れ星のようなものが見えましたな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021810002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「あっ……イルルちゃんが、降りて来てますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010021810002" ]},
		{"command":[ "SETCHARA", "0", "char_00001101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「……ふぅ………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021810008" ]},
		{"command":[ "SETCHARA", "0", "char_00016402_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……イルル……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「あっ…………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021810009" ]},
		{"command":[ "SETCHARA", "0", "char_00016402_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「おとーさ……あ、あのね……こ、これはね……その、ね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021810010" ]},
		{"command":[ "SETCHARA", "0", "char_00016402_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「と、とりあえず、これを着ろ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「えっ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021810011" ]},
		{"command":[ "SETCHARA", "0", "char_00016402_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「俺のだからダボダボなのは悪いが、まあ、さしあたっての応急処置だ。とり\nあえず、身体が隠れてくれりゃいい」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「えと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021810012" ]},
		{"command":[ "SETCHARA", "0", "char_00016402_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「と、とにかくだな！　その格好は、ちょっと……いや、かなり色々と問題が\nあるから人前では気をつけるようにな！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「……おとーさん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021810013" ]},
		{"command":[ "SETCHARA", "0", "char_00016402_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あー、いや、なんて言ったらいいんだろうな。別に似合ってないとかいうこ\nとじゃないんだぞ？　ただ、コンプライアンスというのがな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「おとーさん……イルルのこと……こわくないの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021810014" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「え？　いや、別に何も怖いことはないが……ああ、でも凄いな。いきなりめ\nちゃくちゃ強くなっててびっくりしたぞ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「あ……えと……うん、その……えと、おとーさんのこと……助けたくて……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021810015" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「それでちょっと本気を出したって感じか。ははっ、そりゃ頼もしいな。俺な\nんかよりよっぽど強いなら、心配はいらない……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、まぁ、その格好で外に出られるってのは、違う意味で心配は心配だな\n……まぁ、その辺はおいおい教えて行くしかないか……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「……あ…………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021810016" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ん、どうした、イルル。何か、おかしなことがあったか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「う、ううんっ、おとーさんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021810017" ]},
		{"command":[ "SETCHARA", "0", "char_00016402_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おわっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「えへへっ……おとーさんっ、だいすきっ！　イルルねっ、おとーさんのこと\nっ……だいすきなのっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021810018" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お、おお、分かった、分かったから、ちょっと落ち着こうな。そんなにギュ\nッとしたら苦しいぞ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「あっ……ごめんなさい……でもっ、ふふっ、おとーさんっ……やっぱりおと\nーさんだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021810019" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「な、何だ……？　よく話が見えねぇが……まぁ、無事なら何でもいいか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「やれやれ……何だかんだで、こういう時はあいつの能天気ぶりが頼もしいね\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010021810002" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「イルルちゃんの心配が杞憂でよかったです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010021810003" ]},
		{"command":[ "SETCHARA", "0", "char_00001101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「いやはや、娘と父の感動の再会……素晴らしいですなぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021810003" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「あははっ、にいさまもすっかりお父さんな感じですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010021810004" ]},
		{"command":[ "SETCHARA", "0", "char_00001101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「やはりお姉さんとしても微笑ましいものですか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021810004" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「えっ、わ、私がおねぇさんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010021810005" ]},
		{"command":[ "SETCHARA", "0", "char_00001101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「イルル殿は、とても懐いてらっしゃいましたから。ですよねぇ、お母さんも\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021810005" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「だから、あたしはおかーさんじゃないって言ってるだろ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010021810003" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「んふふっ、おとーさんっ、すりすり～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021810020" ]},
		{"command":[ "SETCHARA", "0", "char_00016402_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「分かった、分かったから、頬ずりも程々にな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0102" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んぐっ、ふんぐっ……んっ……ぷはぁぁぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010021810009" ]},
		{"command":[ "SETCHARA", "0", "char_00017501_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁっ、はぁっ、うがーーーーーっ、ナニよあの攻撃っ！　あんな\nのインチキじゃんっ、メチャクチャじゃんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010021810010" ]},
		{"command":[ "SETCHARA", "0", "char_00017501_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ていうか、まだピリピリしてる……ナンなのあの電気！　くぅっ……しかも\nホンキとか言って、ビミョーに手加減された感じだし！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010021810011" ]},
		{"command":[ "SETCHARA", "0", "char_00017501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「うぐーーーっ、ムカつくムカつくムカつくー！　ちょっと油断しただけだし\n！　次は絶対勝つしー！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010021810012" ]},
		{"command":[ "SETCHARA", "0", "char_00017501_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「待ってなさいよっ、イルル！　ゼッタイ、アンタのことっ……マジギャフン\nさせてやるんだからーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010021810013" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
