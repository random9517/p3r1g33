		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ですけど、カツマさんを助けることができてよかったです……うふふ」", "NORMAL" ]},
