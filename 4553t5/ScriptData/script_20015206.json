		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ヒカリ！！　お前も無事だったか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「ああ。あいつら、２人を追うのを優先してとどめは刺してこなかった。足止\nめしかできなくてすまない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_030023460002" ]},
		{"command":[ "SETCHARA", "0", "char_00015605_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いやいや、助かったよ。おかげでなんとか撃退できた。メガデスも……まあ\n、潜入はおいておくとして、ありがとな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「いえ、こちらこそ……同じ推し活仲間の隊長を攻撃してもうしわけありませ\nんでしたわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_010023460001" ]},
		{"command":[ "SETCHARA", "0", "char_00012599_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いいって。これからは協力してくれるんだろ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「それは……まあ。同じ仲間ですし。できることなら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_010023460002" ]},
		{"command":[ "SETCHARA", "0", "char_00012599_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「それならいい。にしても、暴れ回ったな。片付けを考えると頭が痛いが、夜\nが明けてきたし、今は……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「そうですね、今は……」", "NORMAL" ]},
