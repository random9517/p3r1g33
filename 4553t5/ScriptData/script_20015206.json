		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "「救援コールがかかったから来てみたら、ロビーの壁は壊れてるし、あちこち\nに戦闘の痕があるし……」", "NORMAL" ]},
