		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「さすがにテストもなしに使うのは無茶でした……負荷がかかりすぎてスーツ\nも崩壊してしまいましたね」", "NORMAL" ]},
