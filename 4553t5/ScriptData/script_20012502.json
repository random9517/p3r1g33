{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0092" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「今日の調査は完了。それはいいけれど、もう少し成果がほしいところね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_010021980001" ]},
		{"command":[ "SETCHARA", "0", "char_00015903_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「とはいえ、焦りは禁物。まだまだ滞在のための公費はたくさんある」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_010021980002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「世界征服のために、『大いなる力』のために、確実に探索区域を潰していく\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_010021980003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「今はそれが肝心ね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_010021980004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「地元の住民がなにかうるさいけれど、私の魔導があれば問題はない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_010021980005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「一歩一歩、着実に『大いなる力』に近づいているのが分かるわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_010021980006" ]},
		{"command":[ "SETCHARA", "0", "char_00015903_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「さすがは私。計画通り」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_010021980007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「？　変ね、床が濡れているわ。何かこぼしたかしら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_010021980008" ]},
		{"command":[ "SETCHARA", "0", "char_00015903_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「まあいいわ。今日の調査は終わり。ゆっくりするとしましょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_010021980009" ]},
		{"command":[ "SETCHARA", "0", "char_00015903_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_010021980001" ]},
		{"command":[ "SETCHARA", "0", "char_00022201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0078" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あっちい……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「暑いですな。日に焼けた砂浜で私の肉球も焦げつきそうです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021980001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「犬用のサンダル履けよ。しかし、不審な人影が報告されたのはこの辺りか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「なんでもここ最近、地元の人が警告しているのにも関わらず、遊泳禁止の場\n所を泳いだりうろついたりしているとか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021980002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「他にも水の音がしたと思ったら後ろに立っていて驚いた、いつの間にか船に\n置いてあった魚が食べられているとか、色々と被害の訴えが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021980003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「それって、俺の仕事じゃなくて海上保安庁とかの仕事のような気がするんだ\nがな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「それが、警告や制止しようとすると妖しげな術で煙に巻かれるとか。それで\n我々にお鉢が回ってきたというわけですな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021980004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「我々、というか全員が俺とお前に押し付けてきたんだけどな……情報による\nとその人間はあのコテージを拠点にしているらしい」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ふむ……んん？　なにか妙な匂いが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021980005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「どうした、とりあえず訪ねてみようぜ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0092" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「はい、どちらさま？　ってあなたは！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_010021980010" ]},
		{"command":[ "SETCHARA", "0", "char_00015903_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あっ、お前は！！　確か……ラー、ラー、ラー・カイ――」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ラー・サイアム殿ですな。資料で見ました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021980006" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうそれ、ラー・サイアムだ。お前、なにやってんだここで？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「それはこっちの台詞よ！！　学園で戦ったこと、忘れてないんですからね！\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_010021980011" ]},
		{"command":[ "SETCHARA", "0", "char_00015903_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おわっ！！　いきなり魔導を使うな！！　落ち着け！！　俺はここらで活動\nしてる不審な人間の調査に来たんだよ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「不審な人間？　このコテージには私しかいないけれど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_010021980012" ]},
		{"command":[ "SETCHARA", "0", "char_00015903_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「地元の人間によると警告を無視して遊泳禁止の場所で泳ぎ、立入禁止の場所\nをうろつき、警告する人間を妖しげな術で追い払っているらしいが」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「妖しげとは失礼ね。私の魔導はちゃんと系統立った伝統的な流派よ。それに\n少し記憶を消してるけど、安全に帰らせてるから問題ないじゃない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_010021980013" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「その行為自体が問題なんだっつうの……ていうかやっぱりお前じゃねえか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あとは後ろに立って人を驚かせたり、船の魚や食料を食い漁ったりと、色々\nと訴えが出てるんだよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「失礼な！！　私は人のものを盗って食べるほど飢えちゃいないわよ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_010021980014" ]},
		{"command":[ "SETCHARA", "0", "char_00015903_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「とにかく、ここで何してるのか聞かせてもらうぞ。まあどうせ、また世界征\n服でも企んでいるんだろうけど」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「な、なぜそれを。まさかあなた達もこの浜辺に眠るという『大いなる力』を\n狙っているのね！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_010021980015" ]},
		{"command":[ "SETCHARA", "0", "char_00015903_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……本当にわかりやすいよな、お前」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「なんというか、今のやり取りで私にも女魔導士殿の人となりが理解できたよ\nうな気がします」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021980007" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「問答無用！！　こうなったらあなたたちの記憶を消して木偶人形にして、こ\nきつかってあげるわ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_010021980016" ]},
		{"command":[ "SETCHARA", "0", "char_00015903_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「さらっと恐ろしいこと言ってくるんじゃねえよ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「しかし境遇としては今とさして変わらないのが悲哀をそそりますな、ご主人\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021980008" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お前も黙ってろ！！　ってなんだこれ、水？　おい、床が水浸しだぞ。水道\n管が破裂してるんじゃねえのか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「え、そんなはずは……着いたときに入念にチェックしたもの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_010021980017" ]},
		{"command":[ "SETCHARA", "0", "char_00015903_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人、床が水浸しなのはここだけで、他の部分はまったく浸水しておりま\nせん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021980009" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「んん？　どういうこった……って、おい後ろ！！　なにかいるぞ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「へ？　って、きゃああああああ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_010021980018" ]},
		{"command":[ "SETCHARA", "0", "char_00015903_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「カエレ……カエル……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_010021980002" ]},
		{"command":[ "SETCHARA", "0", "char_00022201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うわわわわわっ！！　って前に学校に出てきたお前か！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「カエル……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_010021980003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ラ、ラー・サイアム、このいかにもサメっぽい女はお前の知り合いか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「い、いえ。知らない人……知らないサメよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_010021980019" ]},
		{"command":[ "SETCHARA", "0", "char_00015903_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「言い直す必要はあったのですかな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021980010" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「カエレ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_010021980004" ]},
		{"command":[ "SETCHARA", "0", "char_00022201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「それはいいけど、なんか話通じるような感じじゃないぞ。ていうか、じりじ\nりとこっちに迫ってきてるんだが！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「彼女が近づくにつれて床の水量も増えておりますな。このままですと足首だ\nけでなく膝まで浸かることに」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021980011" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「この水、私の魔導に抵抗してる……彼女、怪人の類よ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_010021980020" ]},
		{"command":[ "SETCHARA", "0", "char_00015903_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「カエル……オマエ、カエル……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_010021980005" ]},
		{"command":[ "SETCHARA", "0", "char_00022201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「俺が蛙？　何いってんだ……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「おそらくご主人を蛙だと思って捕食しようとしているのではないかと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021980012" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ないかと、じゃねえよ！！　だったらこの近づき方って――」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「く、来るわよっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_010021980021" ]},
		{"command":[ "SETCHARA", "0", "char_00015903_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「カエルゥゥゥゥゥゥゥゥゥッ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_010021980006" ]},
		{"command":[ "SETCHARA", "0", "char_00022201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}