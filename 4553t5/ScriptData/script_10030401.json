{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0188" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_019" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「九重市には女幹部の風が吹く……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115090001" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「この町では、うれしいことも悲しいことも、女幹部が運んでくる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115090002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「詩的ねー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010115090001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「その日は、久しぶりの依頼だった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115090003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「これがなければ、今月のガス代が払えないところだった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115090004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「もしそうなったら、瓦斯探偵としての面目丸つぶれだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115090005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「鳳雛ちゃん、月末はここでお冷だけで時間潰すものね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010115090002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「はい、これＭ．Ａ．Ｍ．Ａからのサービスよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010115090003" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0189" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「……ありがとう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115090006" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「小鉢に入ったゆで卵を頬張りながら、僕は依頼主の登場を待った」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115090007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「そういえば鳳雛ちゃん、最近、お客さんが気になる話をしていたのよー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010115090004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「気になる話？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115090008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「神隠し、起きているんですって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010115090005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「人が消えてるってことかい？　それなら、僕に調査の依頼が来てもいいもん\nだけどな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115090009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「消えているのは人じゃなくて物らしいの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010115090006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「なんでも、あるはずのものがなくなって、別のものに置き換わっている……\nとか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010115090007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「最近ＳＮＳでも話題になっているわー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010115090008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「えー、そんなことあるのかい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115090010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「あるらしいわよー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010115090009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「まさかそんな……いや、起こり得る。なぜならここは女幹部のいる街」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115090011" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「“起こり得ることは起きる可能性がある”……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115090012" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「……？　偉い人の言葉？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010115090010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「僕のオリジナルだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115090013" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「……？　……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010115090011" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0043" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「さっきからなにを言っているんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115090001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「おっと、依頼主の登場だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115090014" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「待たせてしまったようで申し訳ない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090115090001" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「別にかまわないよ。事務所にいても大家さんがうるさいだけだからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115090015" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「そうか。まあいい。とにかく、あなたの力を借りたい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090115090002" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「探偵の力が必要だなんて、なにか事件かい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115090016" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「まあ、そんなところだな。実は……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090115090003" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「まあ待って、言わなくてもわかるよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115090017" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「君たちが僕の力を必要とするということは、つまりその依頼を表ざたにした\nくないということだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115090018" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「君たちの関係者で、なにかを極秘に調査できるのは、僕くらいなものだから\nね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115090019" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「その内容も、まあ想像がつくよ。たとえば……ああ……その……あれあれ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115090020" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「見切り発車がすぎる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115090002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「いや、わかってる。君たちが探偵に頼みそうなことと言えば、そう……隊長\nがらみだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115090021" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「まあ、そうだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090115090004" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「君たちが隊長にかかわることで知りたいこと……そう、例えば隊長の浮気と\nか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115090022" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「なっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115090003" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「探偵の仕事と言えば浮気調査だよ。ここ最近、隊長があやしい行動をしてい\nるとか、心当たりあるだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115090023" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「いや、全然」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090115090005" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「まったくないな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115090004" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「え？　そうなの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115090024" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「おかしいなぁ。隊長ならあやしい行動の一つや二つしていそうなものだけど\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115090025" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「じゃあ、猫探し？　迷子になった猫……って、隊長はネコなんか飼っていた\nかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115090026" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「いつも一緒にいるのは犬だよね？　まさか、猫好きの方がウケるからって、\n彼をリストラ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115090027" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「もしそうなら、彼が隊長のことを恨み、犯行に及ぶには十分な動機になる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115090028" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「いや、長年連れ添ったパートナーともいうべきジュンジローを、そう簡単に\n手放すわけがないか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115090029" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「猫探しでもないとなると……いったいなんだ？　この鳳雛を悩ませるほどの\n難解な事件ってことか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115090030" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「ふふふ、これば僕も本気を出さないといけないようだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115090031" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ええい、もういい！　話を聞け！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115090005" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}