		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "みんと" ]},
		{"command":[ "SETTEXT", "「任務が終わったかと思えば、隊長さんからの呼び出し……ですか。私に、特\nに問題はなかったと思いますが……。何かご意見でも？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0203101" ]},
		{"command":[ "SETCHARA", "0", "char_00001502_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "みんと" ]},
		{"command":[ "SETTEXT", "「……パワーアップのための特別訓練？　はぁ……、まあ、確かに私は参謀タ\nイプでパワー……には縁遠いとは思いますが、力……ですか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0203102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "みんと" ]},
		{"command":[ "SETTEXT", "「本当にそれは私に必要な要素ですか？　……え？　腕力のパワーではなく、\nもっと他人の感情の機微に詳しくなれる、洞察力を磨く訓練？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0203103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "みんと" ]},
		{"command":[ "SETTEXT", "「……それなら……確かに必要かもしれません。私は真面目すぎて、カタには\nまりすぎなところがありますから。わかりました。特訓を受けましょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0203104" ]},
		{"command":[ "SETCHARA", "0", "char_00001502_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "みんと" ]},
		{"command":[ "SETTEXT", "「それで、具体的には何をすれば……。って、キャッ！？　隊長さん！　どう\nしてズボンを脱ぐのですか！　えっ！？　これを胸で挟め！？　そんな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0203105" ]},
		{"command":[ "SETCHARA", "0", "char_00001502_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "みんと" ]},
		{"command":[ "SETTEXT", "「あ……あぁ……。制服を剥ぎ取られた上に、男性器を包みこめだなんて……\n。私、こんなことしたこともないんですよ、キ、キスだってまだだし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0203106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "みんと" ]},
		{"command":[ "SETTEXT", "「でも……。こ、こういった行為がコミュニケーションの最上級のカタチだと\nは本で読んだことがあります。裸の付き合い……試してみる価値があると」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0203107" ]},
		{"command":[ "SETCHARA", "0", "char_00001502_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "みんと" ]},
		{"command":[ "SETTEXT", "「んっ……。パイズリって……こうして胸でペニスを刺激するんですよね……\n。っはぁっ、はぁ……これでいいんでしょうか……。んぅっ、んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0203108" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00001502_01_02" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "みんと" ]},
		{"command":[ "SETTEXT", "「どうしてやり方を知っているのか、ですか？　委員長ですから……。保健体\n育に関しても当然予習は完璧、です……っ。でも……んん……ッ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0203109" ]},
		{"command":[ "SETIMAGE", "0", "still_00001502_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "みんと" ]},
		{"command":[ "SETTEXT", "「実際にやってみる、と……想定よりもペニスが巨大すぎ、て、胸が上手に動\nかせません……。っはぁっ……こうですか？　こう？　それとも、こう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0203110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "みんと" ]},
		{"command":[ "SETTEXT", "「ンッ……！？　肉茎がビクビクしている……。それになんだか膨らんできた\nような……？　方向性は間違っていないということですね、えいっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0203111" ]},
		{"command":[ "SETIMAGE", "0", "still_00001502_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "みんと" ]},
		{"command":[ "SETTEXT", "「力をこめて……、めいっぱい寄せて、谷間……でグニグニと……。っはぁっ\n、はぁ、はぁ……あッ！？　何！？　きゅ、急に熱く……やぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0203112" ]},
		{"command":[ "SETIMAGE", "0", "still_00001502_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "みんと" ]},
		{"command":[ "SETTEXT", "「んはぁっ！？　はぁっ、はぁああっ！？　な、なんですかこれはっ！？　ん\nぁっ……男性器の先端から、粘り気のある白いものが……あっあっあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0203113" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001502_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "みんと" ]},
		{"command":[ "SETTEXT", "「射精……！？　これが射精！？　ほ、本で見たのと全然違う……ッ！　本じ\nゃあこんなにたくさん出てなかった、それに……んぷっ、臭いがキツくて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0203114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "みんと" ]},
		{"command":[ "SETTEXT", "「んぁっ……あぁ、まともに息ができな……い……。でも、やり方は間違って\nいなかったみたい、ですね……であれば安心です。つ、続けますね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0203115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "みんと" ]},
		{"command":[ "SETTEXT", "「んん……んんっ……ンン……♪　ふぁ……、ドロドロの精液で胸がネトネト\n……。でも、量が多いほど、より多く感じた、良かったということですよね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0203116" ]},
		{"command":[ "SETIMAGE", "0", "still_00001502_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "みんと" ]},
		{"command":[ "SETTEXT", "「それなら私は嬉しいです……。んん……っ。せっかくです、隊長さん……私\nのパワーアップのついでに、うんと気持ち良くなってください……。あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0203117" ]},
		{"command":[ "SETIMAGE", "0", "still_00001502_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "みんと" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁっ、はぁっ……あぁ……あぁっ、あぁっ……♪　あは……♪　\n胸がたぷたぷ弾んで、面白い……普通こんなに動かしませんし……あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0203118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "みんと" ]},
		{"command":[ "SETTEXT", "「隊長さん、の……男根が、パイズリの良さを評価してくれるバロメーターみ\nたいで……どんどん精子、出させたくなってしまいます……ふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0203119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "みんと" ]},
		{"command":[ "SETTEXT", "「肉棒って……確か、嘘がつけないんですよね？　本当にヨかった時しか反応\nしないって……参考書に♪　あっ……またピクピクって、んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0203120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "みんと" ]},
		{"command":[ "SETTEXT", "「ダイレクトに評価が返ってくると……こっちも本気になっちゃいます。もっ\nともっと感じさせたくなる……。んんぁっ、ぁっ、ぁっ、あぁ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0203121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "みんと" ]},
		{"command":[ "SETTEXT", "「亀頭……から根元、まで……♪　あんっ、フワフワのおタマタマまで巻き込\nんで……。一秒だって油断させず、性感で煽り立てていく……ぅ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0203122" ]},
		{"command":[ "SETIMAGE", "0", "still_00001502_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "みんと" ]},
		{"command":[ "SETTEXT", "「あっ♪　あっ♪　硬い陰茎でこすられると、私の胸もとても気持ちいいです\nっ……あっ♪　こ、これも参考書、どおり……あぁんっ、あぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0203123" ]},
		{"command":[ "SETIMAGE", "0", "still_00001502_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "みんと" ]},
		{"command":[ "SETTEXT", "「そんなエッチな参考書があるか……ですか？　ふふ……。委員長って読書家\nです、から♪　当然本屋さんの書物は全て目にしています……つまり♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0203124" ]},
		{"command":[ "SETIMAGE", "0", "still_00001502_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "みんと" ]},
		{"command":[ "SETTEXT", "「エッチな本も私の専門分野というわけ、です……あんっ♪　純粋な女の子じ\nゃなくてごめんなさい……。もちろん経験は一つもないです。でも」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0203125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "みんと" ]},
		{"command":[ "SETTEXT", "「良い子じゃなくって、私……エッチに興味深々な悪い子なんです……。んっ\n、んっ……隊長さんとのこういうことだって、妄想してました、よ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0203126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "みんと" ]},
		{"command":[ "SETTEXT", "「だから……ちょっとはしゃいじゃっているのかも……。どうせなら……、っ\nぁ……気心が知れている隊長さんとがいいと思ってました、し」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0203127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "みんと" ]},
		{"command":[ "SETTEXT", "「フタを開けてみたらとても立派なおちんちんで……、私の探求心がくすぐら\nれます……。もっと、もっと、もっと知りたい……はぁぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0203128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "みんと" ]},
		{"command":[ "SETTEXT", "「本にはない、知識だけではわからない生の情報が欲しいから……。んっ、ん\nん……パイズリ、楽しんじゃいます……。ふぁっ、あぁ、硬……い♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0203129" ]},
		{"command":[ "SETIMAGE", "0", "still_00001502_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "みんと" ]},
		{"command":[ "SETTEXT", "「張りも強くて、……あっ、見惚れてしまうような美しく、逞しいフォルム…\n…♪　それに……んっ、実際触れてみてわかった熱さ、蒸れた臭い……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0203130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "みんと" ]},
		{"command":[ "SETTEXT", "「精液の♪　トロッとした感触……♪　はぁっ……はぁ、はぁ……どうしよう\n……♪　どんどん惹かれていってしまいます、あっ、あっ、す、好き♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0203131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "みんと" ]},
		{"command":[ "SETTEXT", "「好き……！　好きっ……好きっ、あぁ……あぁ、おちんちんの質感も♪　あ\nっ……精子にまみれてヌルヌル輝く私の胸もっ、あっ……好き、好き♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0203132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "みんと" ]},
		{"command":[ "SETTEXT", "「こねて、こねて、溶け合って……あっ♪　このまま一つになってしまいたい\n……あぁっ、だ、ダメです、私……興奮しすぎて……イ、イクっ、あぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0203133" ]},
		{"command":[ "SETIMAGE", "0", "still_00001502_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "みんと" ]},
		{"command":[ "SETTEXT", "「パイズリさせられて♪　ゾクゾクしちゃって、胸だけでイッちゃった……あ\nぁ……。悪い子、悪い子……悪い子のおっぱいは気持ちいいですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0203134" ]},
		{"command":[ "SETIMAGE", "0", "still_00001502_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "みんと" ]},
		{"command":[ "SETTEXT", "「んぅ……またビクビクしてきた……。さっき出したばかりなのに連射ですか\n？　委員長の悪い子おっぱいにトドメの二発目射精するんですか？　あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0203135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "みんと" ]},
		{"command":[ "SETTEXT", "「あはぁーーーー♪　出た♪　出たっ♪　ドパドパ出しちゃってるじゃないで\nすかぁーーーー♪　あっ♪　あっ♪　なんてはしたないおちんちんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0203136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "みんと" ]},
		{"command":[ "SETTEXT", "「可愛いっ……全部ください、作った精子、私の顔と胸にかけて精液くさくコ\nーティングしちゃってくださぁい……♪　あーっ、あーっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0203137" ]},
		{"command":[ "SETIMAGE", "0", "still_00001502_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "みんと" ]},
		{"command":[ "SETTEXT", "「あつっ、熱ぅい……♪　それにくさぁい……んぷっ、んはぁ……好き……♪\n　パイズリからのお顔にぶっかけ……満点ですっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0203138" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001502_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "みんと" ]},
		{"command":[ "SETTEXT", "「見てください、このもったりとゼリーのようにへばりつく精液……♪　一回\n目よりドロドロがキツくて……あぁ、私の胸が妊娠しちゃう……ぅ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0203139" ]},
		{"command":[ "SETIMAGE", "0", "still_00001502_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "みんと" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁっ……♪　射精したての尿道口が、ヒクヒクしてカワイイ……\n♪　パイズリって、なんて素敵な経験なの……感動してしまいましたぁ♪」", "NORMAL" ]},
