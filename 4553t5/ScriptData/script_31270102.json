{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012701_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "PLAYVOICE", "127_0104101" ]},
		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「……緊張しているのか、だと？　ははは……バカ。しているに決まっている\n。キミがこんなにも私を求めているとは知らなかったからな」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "127_0104102" ]},
		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「なあ、他にも女はいるだろう？　でもどうして私とこんなことをしようとい\nうんだ？　キミならもっと他にも……いや、よそう」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "127_0104103" ]},
		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「せっかくの私の晴れ舞台なんだからな、余計な話に気を取られる必要もない\nはずだ……そう、今は私とキミの時間……他の誰にも邪魔されたくはない」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012701_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "127_0104104" ]},
		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「それがたとえ、話の上だけであったとしてもな……ふふふ……どうやら私は\nキミに執着しているらしい……まったく、困ったことだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "127_0104105" ]},
		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「これまでサメにしか興味がなかった。軟骨魚類野郎と、サメを保護する団体\nと、なぜかサメを守るミュータントしか関心がなかった……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "127_0104106" ]},
		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「それをキミは何を好き好んで私なんかと……ふふふ、ダメだ、考えれば考え\nる程、緊張してしまう……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "127_0104107" ]},
		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「こんな時、普通の女はどんな顔をするんだ？　右手の無い女はどんな顔をす\nべきなんだ？　参ったな……胸のドキドキが治まらないぞ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012701_02_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "127_0104108" ]},
		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「その顔……私の胸を見て、いやらしい気分になっているのだろう？　胸を見\nられるのは嫌いじゃない……私の数少ない女性らしい部分だからな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "127_0104109" ]},
		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「ふぅ……息が熱い。胸のうちで炎が燃え上がって、吐息から漏れ出してくる\nようだ……はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "127_0104110" ]},
		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「何？　止めてもいいんだぞ、だと？　お優しいことだな。だが……私はサメ\nであろうと男であろうと一歩も引くつもりはない……！　さあ来いっ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012701_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "127_0104111" ]},
		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「ふぐぅっ！　あうぅぅぅぅ……あっ、あっ、あぁぁぁぁ……こ、これが、セ\nックス……なのか……痛いとは聞いていたが……ん、んん……」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012701_02_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "127_0104112" ]},
		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「ふふふ、想像していたほどでは、ないな……もっと、こう……死ぬような苦\n痛が待っているのかと思っていた……はぁ、あふぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "127_0104113" ]},
		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「サメに右腕をもぎ取られた時も痛くはなかった。両親を眼の前で食い殺され\nては、痛がる余裕もないからな……と、これも余計な話だな」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012701_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "127_0104114" ]},
		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「ふふ、つまり……何かに気を取られていれば、痛みを感じることもないとい\nうことだ……だから、ん、んん、遠慮なく動いて、くれ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "127_0104115" ]},
		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「え？　今何に気を取られているのかって？　ははは、意地悪な男だな、キミ\nは……はぁ、ふぅ……あいにく私は虐められて喜ぶタイプではないんだ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012701_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "127_0104116" ]},
		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「けど、この……ん、んぐ、中で引っかかるような、痛みとかゆみと、快感が\n入り混じった刺激……気持ち、いい……はぁ、あふぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "127_0104117" ]},
		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、あぁぁぁ……あぐぅ！？　ん、ふぅ……い、今、根本まで、入\nった、のか……？　はぁ……はぁ……ふぅ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012701_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "127_0104118" ]},
		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「腹の奥の、一番大事な部分を、キミに明け渡してしまった……はぁ、ふぅ…\n…ふふ……『サメ絶対殺すウーマン』の、この私ともあろう者が……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "127_0104119" ]},
		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「はぁ、ふぅ……ふふふ……一生、女の悦びなんて知らないままだと思ってい\nた……なのに……ん、んんぁ、はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "127_0104120" ]},
		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「くぅ、ふぅ……い、いざ動かれると、んんっ、少し、苦しいな……いや、止\nめないでくれ……だんだんよくなってきた……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "127_0104121" ]},
		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「はっ、はぁ……はぁぁぁ……アソコの中で、太くて、大きなものがゴリゴリ\n動いてる……ああ、すごい……振動が、全身に伝わって、くる……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "127_0104122" ]},
		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「これが、ん、んん、セックス、なんだな……はぁ、ふぅ……あああ、私は今\n、女の悦びを感じてる……ふふふ、堕落させられた、気分だ……」」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "127_0104123" ]},
		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「サメを殺すことだけに、人生を費やしていたというのに……キミのおかげで\n、今後の使命に支障を来しそうだ……ＳＫＣ財団が文句を言うかもな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "127_0104124" ]},
		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「いや、いい……そんなこと、どうでも、いいんだ……今は、このセックスに\n集中、したい……はぁ、はぁ……あ、ああぁぁ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012701_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "127_0104125" ]},
		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「わ、私も動いて、構わないのか？　というより、ふぅ、ふぅ……ふふふ、勝\n手に動いて、しまうんだ……はぁ、あふぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "127_0104126" ]},
		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「身体が、ん、んん、ペニスを……欲しがってる……はぁ、ふぅ……女の身体\nの一番深いとこでお、キミを待ち望んでるんだ……んん、あぁぁあん……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012701_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "127_0104127" ]},
		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「あああ、すごぉい……気持ちいいところ、コリコリこすってる……ひぐぅ、\nきゃうぅぅ……身体に電気が走るようだ……はぁ、はぁ……あふぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "127_0104128" ]},
		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「何匹ものサメを高圧電流で感電死させてやったのに……ふふ、まるでその仕\n返しを受けているみたいだな……ああ、アソコが痺れて、止まらない……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "127_0104129" ]},
		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「くっ、うっ、うああ……はぁ、はぁ……はあぁぁん……快感の波が、押し寄\nせて、くる……ああ、ダメ……波にさらわれて、しまう……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "127_0104130" ]},
		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……そ、そうか……キミも、イキそう……なのか。ふふ、どうす\nるんだ？　まさか、このまま中に出すのか……？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012701_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "127_0104131" ]},
		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……ははは、酷い男だな……この身体、キミに委ねると決めたか\nらな……仕方ない……いいぞ、このまま出してくれても……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "127_0104132" ]},
		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、すごい……中で、震えてる……あっ、あああ、アソコの奥に密\n着して、ん、くぅ！？　はぁ……あぁぁぁ……っ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012701_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "127_0104133" ]},
		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「わ、たしも……イッ、イクッ……イッ……グ……ッ！！　はぁ、はぁ……あ\nっ、ひやぁぁぁぁぁ……っ！！！！」」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "127_0104134" ]},
		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「ひゃぐぅぅぅっ！！？　ひゃひぃぃぃぃ……！！？　あっ、あぁっ、あひぃ\nぃぃ……す、ごぉい……こんなに、気持ちいいもの、なのか……」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012701_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "127_0104135" ]},
		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「うあぁぁ……中で、ペニスが、暴れてる……はぁ、はぁ……熱い、液体が、\n子宮の奥に、染み込んで、くるぅ……んん、あはぁぁ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "127_0104136" ]},
		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「ああぁぁ……すごいな、女の身体は……こ、こ、こんなにも、快感を受け止\nめることが、出来るのか……はあ、はぁ……あふぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "127_0104137" ]},
		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「まいったな……サメを追うことが、馬鹿らしくなりそうだ……だが、ん、ん\nん、今更、使命を放り捨てることなんてできないからな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "127_0104138" ]},
		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……はふぅ……ようやく、射精も治まったらしい……ふふふ、\n気持ちよかったか？　私の身体、変じゃなかったか？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012701_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "127_0104139" ]},
		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「そうか……それならいい……はぁ、はぁ……キミを気持ちよくさせることが\n できて……本当によかったぁ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "127_0104140" ]},
		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「ふふ、ＳＫＣ財団に頼んで、右手をもっとプレイの足しになるようなアタッ\nチメントを開発してもらうべきかもしれんな……あふぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}