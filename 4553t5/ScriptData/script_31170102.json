		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「淑女であるべき轟琴の娘の秘裂……、嫁入りまでは処女であるべきわたくし\nのアソコが、肉棒をがっちりホールドして離さない……♪」", "NORMAL" ]},
