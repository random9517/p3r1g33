{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0151" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "Ａ・ジュンジロー" ]},
		{"command":[ "SETTEXT", "「周辺に敵影なし。時空変動を感知。敵部隊は撤収したものと思われる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_040113120001" ]},
		{"command":[ "SETCHARA", "0", "char_00000904_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「やった！　おっぱらったぜ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010113120001" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「どうだ、襲来者（インベーダー）め！　見たか、私の実力を！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010113120001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ルナテミス様……ご立派な戦いぶりでした！　普段から、これぐらいの実力\nを発揮してくだされば……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113120001" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「……ルナテミス」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113120001" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「む……！　なんだ、修羅姫！　さっきの続きをしようというのか！？　相手\nになるぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010113120002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「いや……そのことはいい。ただ、あっぱれな戦いぶりだったと、そう伝えた\nかっただけだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113120002" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「え……？　ほ、ほめて……くれるのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010113120003" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「ああ。たいしたものだ。どうやら私は、貴様たちの力を見誤っていたらしい\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113120003" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そ、そうか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010113120004" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「はい！　ルナテミスさんはすごいって、私も思いました！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010113120001" ]},
		{"command":[ "SETCHARA", "0", "char_00001701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そ、そうか……そうかそうか！　いや、そうだろうそうだろう！　わかれば\nいい！　わかってくれればいいんだ！　はははははははは！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010113120005" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ふふっ……いろいろあったけど、どうだい修羅姫。くだらん誤解も解けたこ\nとだし、例の勝負とやらは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113120002" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「ああ、なかったことにしよう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113120004" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「本当か！？　よかった……！　本当によかった……！　それを聞いて、やっ\nと安心した……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010113120006" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「ああ。貴様にも、やらねばならぬことがあるのだからな。それを邪魔しては\nいかんと思ってな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113120005" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「修羅姫……！　ありがとう！　よく言ってくれた！　貴様は本当はいいヤツ\nだったのだな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010113120007" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そうだ！　そうなんだよ！　立派な女王になるため、私にはやるべきことが\nいくらでもある！　妙な勝負に関わっているヒマはないんだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010113120008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「そうですとも、ルナテミス様」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113120003" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はははははは！　やった！　やったぞーっ！　私は自由だ　もう、勉強なん\nかしなくってもいいんだーーーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010113120009" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「……は？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113120004" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ええ～……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010113120001" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「それは……どうでしょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010113120002" ]},
		{"command":[ "SETCHARA", "0", "char_00001701_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「……え？　い、いや、だって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010113120010" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「……誰が、勉強から解放すると言った？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113120006" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「……ふぇ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010113120011" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0149" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_016" ]},
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「いやぁあああああああーっ！　なぜ！？　どうしてこうなるの！？　変な勝\n負は、取りやめるはずじゃなかったのぉーっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113120001" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "9", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「誰が勉強までやめろと言いました？　あなたのいまやるべきこと、それは、\n学習の遅れを取り戻すことです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020113120001" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「さすがに、あの成績では委員長として心配です！　私も、お勉強を手伝いま\nすね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020113120001" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「ひいいいいいーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113120002" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「はーい、さっき解いてもらった問題集だけどー？　採点してみたら全部――\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040113120001" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「言わないで！　その先は言わないでーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113120003" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「いくら泣いても逃がしませんよ！　さあ、次はこの問題を解いてみなさいっ\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060113120001" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「らめぇえええええーっ！　ルルーナの頭、壊れちゃううううううううーっ！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113120004" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はぁ……大変だな、教えるほうも教わるほうも」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「まあ……なんと申しますか。学問は一日にしてならず。これが今回の教訓で\nすな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113120001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なにいい話風に締めようとしてんだアホ犬」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "やれやれ……学園生活も始まったばかりでこの調子じゃ、俺たちこの先、どう\nなっちまうのかねえ……？", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「ちょっと下僕！　助けなさいよ下僕！　私をここから連れ出して！　下僕ぅ\nーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113120005" ]},
