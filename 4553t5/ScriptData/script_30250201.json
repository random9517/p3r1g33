{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002502_01_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「よいせっと……さて、それじゃ……お願いしようかねぇ……ふふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0203101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「どうしたんだい、お前さんの日頃の頑張りを認めているから、私が直々にそ\nのねぎらいをしようっていうんじゃないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0203102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「どうだい……ずっと見たかった場所だろう？　オマンコ……ふふっ、かぶり\nつきの特等席で見られる男なんて、そうそういるもんじゃないよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0203103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「さあ、ここは……どうなっている？　今、どんな状態になっているか言って\nご覧？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0203104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「ふふ……濡れている……そうだねぇ、あんまり当たり前過ぎて、５０点って\nとこだね。もう３０点位は頑張らないとねぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0203105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「うん？　綺麗で……ひくひく……震えてる……？　ふふっ、ありきたりな形\n容詞だけどもう１０点位は足しといてあげようか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0203106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「さて、まだまだ６０点だ。ご褒美が欲しかったら、どうすればいいか……分\nかるだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0203107" ]},
		{"command":[ "SETIMAGE", "0", "still_00002502_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「ああ……そうだねぇ、んっ……しっかり舌で舐めてごらん。私を気持ちよく\nさせる権利をあげる……結構なご褒美だと思わないかい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0203108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「お前さんも……んっ……色々と、女を泣かせたり……悦ばせたりして来たん\nだろう……？　その技を私にも見せてごらん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0203109" ]},
		{"command":[ "SETIMAGE", "0", "still_00002502_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、ふふ……なるほど……そうだね、最初はまず割れ目の入り口\nからだね……んぅっ、いいよ……遠慮しなくていい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0203110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「これでも、お前さんのことは信用しているんだ。ちゃんと良くしてくれるん\nだろうってね……んっふ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0203111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「あっ……くぅ……んっ、へぇ……思ったより、思い切りがいいじゃないの…\n…んっ、そうね……よじれた所は……んっ、なかなか気持ちいいよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0203112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「はんっ、そう……舌を尖らせるようにして……ついばむ感じか……あぁ……\nんふっ、これが……お得意の技って所……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0203113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「っと……こんな時に上から目線でテクニックを評価するのも野暮だったね…\n…気持ちいいよ、もっともっと私を感じさせてもらえるかい……んぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0203114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「あふっ……ほら……分かるだろう？　じんわりと……マン汁が……ふふっ、\nんっ、滲んできたよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0203115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「溢れた分は……当然、お前さんへのご褒美にしていいからね……ほら、遠慮\nなく飲んでいいよ……腰を押し付けてあげるからね……んふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0203116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「ふふっ、ちょっとプレスしすぎたかね？　息が苦しい位にオマンコを押し付\nけられるなんて経験はそうそうないだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0203117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「おや……？　けど……結構ひどいことをしたと思った割には……チンポの方\nは案外、面白い反応を見せているねぇ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0203118" ]},
		{"command":[ "SETIMAGE", "0", "still_00002502_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「ふふ……さっきまで半立ち位じゃなかったかい？　いつの間にか、しっかり\nビンビンにおっ立ててるのはどういうことなんだろうね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0203119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「案外とそういうのが好きと……中々どうして、お前さんもこじらせた所を持\nってるのかも知れないね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0203120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「んっ、ふふ……そうだね、生憎と今の状態じゃ私がどうにかしてやることは\n出来ないけど……自家発電なら許してあげようじゃないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0203121" ]},
		{"command":[ "SETIMAGE", "0", "still_00002502_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「決まってるだろう？　自分でチンポを扱くんだよ。まさか、何もなしに私に\nチンポをシコシコしてもらえるなんて……思ってないだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0203122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「それとも、何か不満があるのかい？　まだ、お前さんは十分な仕事をしてる\nとは言えない状況だ……それでも権利を主張するのかい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0203123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「ふふ……そうだね、んっ……しっかりオマンコを舐める……そして、チンポ\nを扱く……それがお前の役割だよ……はぁっ、んっ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0203124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「あぁ……いやらしい音がしてきたじゃないか……じゅくじゅく……皮がめく\nれた時の音だ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0203125" ]},
		{"command":[ "SETIMAGE", "0", "still_00002502_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「ふふ……思ったより、激しくチンポを扱くんだねぇ。んっ、舌の方も同じ調\n子で頼むよ……あっ、はぁっ……んっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0203126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「あぁ……んっ、そうだ……ヒダを一つ一つ……丁寧に唾液を塗り込めて……\nんっ、悪くないよ……もっと音をさせてみせな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0203127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「あっ、んふっ、いいねぇ……どんどんオマンコ汁が溢れて来るのが分かるよ\n……いい感じだ……はあ……んふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0203128" ]},
		{"command":[ "SETIMAGE", "0", "still_00002502_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「んんっ！　ふふっ、不意打ちでクリトリスをつつくなんて……やってくれる\nじゃないか……そういうイタズラっ子には……ふんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0203129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「どうだい……お気に入りだろう、このオマンコプレス……お前は、ちょっと\n苦しい位でもしっかり快感にしちまう変態のようだからね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0203130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「あぁ……そうだよ、もっと舐めて……んっ、はぁぁ……ちょっと、ムズムズ\nして来たよ……んくぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0203131" ]},
		{"command":[ "SETIMAGE", "0", "still_00002502_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「ふふ……でも、丁度いいかも知れないねぇ……今のお前には、こんなのでも\nご褒美になっちまうのかも知れない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0203132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「何の話かだって？　すぐに分かるさ……ほら、行くよ……んっ、はぁっ……\nあっ、ふぁぁぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0203133" ]},
		{"command":[ "SETIMAGE", "0", "still_00002502_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「あぁ……んっ、そうだよ……おしっこさ……お前さんの舌で催して来ちまっ\nてね……だから、飲ませてやろうってのさ……はぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0203134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「ふふっ、何だかんだでゴクゴク飲むじゃないか……まあ、それより他に方法\nはないけどね……あぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0203135" ]},
		{"command":[ "SETIMAGE", "0", "still_00002502_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「んっ、こんなに気持ちいいおしっこは久しぶりだよ……ふふっ、どうしたん\nだい……夢中でチンポを扱いて……出したいのかい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0203136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「いいよ……ちゃんと飲めたご褒美だ。射精を許してやるから、派手な噴水を\n見せてみな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0203137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「んぁっ！　あぁっ……いっぱい出してるじゃないか……いいねぇ、その生命\n力……私が見たかったものだよ……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0203138" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002502_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「はぁぁ……あぁ……中々いい気持ちだったね……いいクンニリングスだった\nって褒めてあげるよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0203139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「んふ……これだけ出来るなら、また使ってあげなくもない。私にしちゃあ、\n最大限の褒め言葉だと思ってくれればいいさ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0203140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「……さてと……十分楽しんだ……と言いたいところだが、私はまだイクまで\nは到達してないんだよねぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0203201" ]},
		{"command":[ "SETIMAGE", "0", "still_00002502_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「それに、お前さんのチンポも派手にザーメンを飛ばした割には、まだガッチ\nリ勃起して、終わりたくないって言ってるねぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0203202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「ああ、察しの通りだよ。ほら、続けるんだ。今度は、ちゃんと私のオマンコ\nをイカせるように、今まで以上に熱心に舐めるんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0203203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「んんっ……あぁっ、そうそう……ふふっ、んくっ……別の生き物みたいに舌\nがオマンコのヒダを這い回ってくるよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0203204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「はふっ……どうだい、私のマン汁は美味しいかい？　おしっこよりはマシだ\nろう？　どんどん出てくるから、遠慮なく飲んでいいからね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0203205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「ふふっ、そうかいそうかい、美味しいんだね……夢中になってチンポを扱い\nちゃって……中々可愛いじゃないか。気に入ったよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0203206" ]},
		{"command":[ "SETIMAGE", "0", "still_00002502_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、あぁ……何だか私も気分が出てきたよ……んっ……いつの間\nにか乳首がコリコリになって来てる……あぁ……指が動いちまう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0203207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「んっくっ、あふっ……あぁっ、はぁんっ……ふふ、おっぱいを触りたいかい\n？　させてやってもいいが……今はチンポを扱く方が先だろうね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0203208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「んふ、そうそう……いい音させてるじゃないか……あぁ、オマンコがウズウ\nズするぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0203209" ]},
		{"command":[ "SETIMAGE", "0", "still_00002502_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「今の調子で……もっと舐めるんだ……んくぅっ……はぁ……あぁ……そうだ\nよ、唾液を……どんどん塗って……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0203210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「あひぉっ！　いいよっ……くぅぅっ……んっ、ふっ、舌が……めり込んで…\n…んくぅっ……このままされたら……ホントにイクところまでぇ……あっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0203211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「はぁっ、んっ……吸い付いて来るっ……！　ここに来て……そんなやり方…\n…あっ、くぅんっ……！　してくるなんてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0203212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「はぁんっ、あぁっ、でも……すぐにイクのは……勿体ない感じがするねぇ…\n…んふぅっ……もうちょっと我慢して……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0203213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「もっと凄いことをしてもらわないと……あっ、んぅぅっ！　音を立ててっ…\n…あぉっ、オマンコっ……吸われてっ……はぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0203214" ]},
		{"command":[ "SETIMAGE", "0", "still_00002502_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「あぁっ……いいねぇっ……刺激的だよっ……そのままっ……んくっ、はぁん\nっ、いいっ……オマンコ来てるっ、いいのが……来てるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0203215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「はぁんっ、そっちは……どうだいっ……？　チンポっ……また出そうになっ\nてるのかいっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0203216" ]},
		{"command":[ "SETIMAGE", "0", "still_00002502_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「みたい……だねっ……ならっ、このまま……一緒にイクよっ、んんっ、私に\n……上手く合わせてっ……精液っ、出すんだよっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0203217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ、そうそうっ……もっと激しくシコシコさせてっ……おぉっ！　\n今のっ……くぅんっ！　クリトリスっ……いいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0203218" ]},
		{"command":[ "SETIMAGE", "0", "still_00002502_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「あっ、はぁっ、んっ、もうっ……イクっ……お前はどうしたいっ……？　今\nは、気分がいい……好きな場所に出させてやるよっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0203219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「私の身体がいいかい……？　それとも、顔に出すなんて度胸があるのかい…\n…？　さあ……どうするんだいっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0203220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「ふふっ、本気で顔に掛ける気かいっ、いい度胸だっ……いいよっ、私もイク\nっ……このままっ、はぁっ、んんんんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0203301" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「はぁぁぁ……あぁ……私も出てる……んっ、また汁が飛んでる……んふぅ…\n…顔に潮吹きしちまってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0203302" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002502_01_17" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「んっ！　そっちも派手に飛ばしてくれるじゃないか……んっ、ふっ……直接\nザーメンを浴びることになるとはね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0203303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「れろ……ちゅぷっ……うん、悪くない味だ……男の生命力をそのまま頂いて\n……どんどん若返っていくような感じがするよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0203304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「さあ、まだ出せるんだろう？　もっと激しくチンポを扱いて、枯れ果てるま\nで出し続けて、もっと顔に浴びせるんだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0203305" ]},
		{"command":[ "SETIMAGE", "0", "still_00002502_01_16" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「そうそう、あぁ……激しいねぇ……また先っぽが震えて……んっ……ふっ！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0203306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「ほら、もう一発出てきたね……おっと、勿体ない……零しちゃ台無しになる\n……んちゅぅ……ちゅぷっ、んっ、れろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0203307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「んはぁっ……ふぅ……あぁ……どうやら終わっちまったみたいだね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0203308" ]},
		{"command":[ "SETIMAGE", "0", "still_00002502_01_16" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「そうだねぇ、ちょっとしたお遊びのつもりだったけど、思った以上に楽しめ\nたよ。嬉しい誤算ってやつだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0203309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「ふふ……また気が向いたら、お前さんと遊んでやるよ。もちろん、まだそん\nな気力と根性が残ってるなら……だけどね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0203310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「ふふっ、私の身体にザーメンをぶち撒けたいんだね？　お望み通りにしてや\nろうじゃないかっ……私もイクよっ、さあ……出しちまいなっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0203401" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「んぁぁぁぁぁっ！　来たっ……熱いのっ、身体に掛かってるぅぅっ！　んぁ\nぁぁぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0203402" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002502_01_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「あっ、はぁぁぁっ……私もイッてるっ……んんっ、気持ちいいのが続いてっ\n……んんっ、あぁっ……また、出るっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0203403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「んはぁぁぁ……これは……潮吹き……んっ、おしっこじゃない……のかねぇ\n……どっちでもいいや……飲んでくれよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0203404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「んふっ、そうそう……一生懸命喉を鳴らして……チンポも扱いて……もっと\n出せるんだろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0203405" ]},
		{"command":[ "SETIMAGE", "0", "still_00002502_01_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「頑張ってシコシコしていくんだよ……ほら……またチンポが震えて来た……\nいいよ！　また出しなっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0203406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「はぁんっ！　あぁっ……濃いのが出てるっ……んっ、むわっとしたザーメン\n臭が広がってくるよ……んふぁ……いいねぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0203407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「んはぁっ……ふぅ……あぁ……どうやら終わっちまったみたいだね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0203408" ]},
		{"command":[ "SETIMAGE", "0", "still_00002502_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「そうだねぇ、軽いお遊びのつもりだったけど、思った以上に楽しめたよ。\nちょっとしたご褒美のつもりだったけど、嬉しい誤算ってやつだ」", "NORMAL" ]},
