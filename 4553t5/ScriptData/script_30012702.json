		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「明日……ここでライブが行われるのですね……この広い会場がいっぱいにな\nると……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2704101" ]},
		{"command":[ "SETCHARA", "0", "char_00000127_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「ステージに立ってみて分かりましたが……本当に客席の全てが見渡せますの\nね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2704102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「……不安は……ないといったら嘘になりますわ。当日、緊張して満足なパフ\nォーマンスができなかったらという気持ちは……どうしても」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2704103" ]},
		{"command":[ "SETCHARA", "0", "char_00000127_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「えっ……緊張を取り除く方法？　それは……もちろん、本当にそんなものが\nあるのならぜひ試してみたいですけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2704104" ]},
		{"command":[ "SETCHARA", "0", "char_00000127_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「踊るよりも、もっと恥ずかしいことをここですれば度胸がつく……？　踊る\nより恥ずかしいことというのは何のことですの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2704105" ]},
		{"command":[ "SETCHARA", "0", "char_00000127_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「えっ……あっ？　ちょっ……な、何を脱がせようとして……えっ、この方法\nしかないって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2704106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00000127_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「あっ……な……こ、こんな……足を広げさせた格好なんて……ど、どういう\nつもりでっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2704107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「た、確かに恥ずかしい……けど、それは……こんなポーズをさせられたらっ\n、恥ずかしいに決まっていますわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2704108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「ここで……こうすることで……当日は、普通の状態でいられる……それは…\n…確かに、こんなポーズは取らないですが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2704109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「えっ、ちょっと……な、何を……このままっ、あっ、はぁぅっ、んっ、くぅ\nぅぅぅぅぅんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2704110" ]},
		{"command":[ "SETIMAGE", "0", "still_00000127_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「そんな……急にチンポを、い、入れるなんて……あっ、あぁっ……こんな、\n格好……は、恥ずかしいですわっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2704111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「こ、この状態で……羞恥心を克服……そ、そういう……ことですの……んん\nっ、はぁっ、でも、こんな場所で……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2704112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「当日……舞台に立っていることをイメージする……んっ、こ、このままで…\n…？　あぁ……客席からの視線が……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2704113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「あぁ……一階席は……し、下から……オマンコを覗き込まれて……つ、繋が\nっている場所が、丸見えになっています……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2704114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「二階席のお客さんは……上から……わ、私のおっぱいを……食い入るように\n見つめて……はぁん、いやらしい目で見ています……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2704115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「この状態で……あっ、あぉっ、あっ、ひっ！　あぁっ、んんっ、出し入れが\nっ……は、始まってっ……あ、あぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2704116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「いやっ、あぁっ、声が響くっ……！　わ、私のいやらしい声がっ……客席に\n届いてしまいますわっ……あっ、あぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2704117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「はぁっ、なんですの……これは……んんっ！　肌が……ピリピリ痺れてっ…\n…全身がっ……すごく敏感になっていてっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2704118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「あっ、ひっ！　チンポっ……太いっ！　あぁっ、オマンコっ……こじ開けて\nっ……めちゃくちゃにっ……かき回されて来ますわぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2704119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「はひっ！　あっ、んひぃっ！　こんなっ、上下に揺するなんてっ……うんっ\n、くぅんっ……あっ、見せびらかすっ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2704120" ]},
		{"command":[ "SETIMAGE", "0", "still_00000127_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「あぁ……客席に……ファンの方々に……絶対に見せてはいけないオマンコを\n見せてっ……いやらしく発情した顔を見せてしまってるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2704121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「あんっ、はっ、んぁぁっ、いやですっ……おっぱい……揺らさないでっ……\nあぁっ、乳首が立っているなんて、そんなことっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2704122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「だってっ、こんな風に見られていたらっ……あっ、くぅぅんっ……！　どう\nしても……身体が……反応してしまいますわっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2704123" ]},
		{"command":[ "SETIMAGE", "0", "still_00000127_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「駄目……見ないで……あぁっ、オマンコなんて……人に見せていいところじ\nゃ……あぁっ……まだ、足が広がるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2704124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「あっ、ひんっ！　あぁっ、いやっ……！　チンポがっ……あっ、縦に……ズ\nリズリ……ヒダを擦ってっ……あくぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2704125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「はぁっ、そこはっ……いけませんわっ……！　あっ、オマンコ……敏感なと\nころのっ……一番……力が抜けてしまうとこっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2704126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「そんな風に……擦られ続けるとっ……内側から……あぁっ、愛液がっ……溢\nれて……しまいますのっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2704127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「はぁんっ、マ、マン汁なんてっ……あぁっ、そんな言い方……あっ、ひぃっ\n！　チンポっ、また深くぅっ……くぅぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2704128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「あひっ、アリーナ席にっ、そんな……見せつけるみたいに動いちゃっ……も\n、もう下ろしてっ……あふぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2704129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「あぁっ……ズボズボされてっ……身体の火照りが……止まらないっ……！　\nくふぅぅぅんっ……あっ、あぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2704130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「も、もっと声を出せとっ……？　本番で……あっ、いい声が出るようにっ…\n…んっ、ふっ……それは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2704131" ]},
		{"command":[ "SETIMAGE", "0", "still_00000127_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「あっ、んんっ！　わ、分かりましたわっ！　なんて言えば……い、今の……\n気持ちをっ……は、はひっ、あっ、チンポっ……いいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2704132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「そうですわっ！　あぁっ、オマンコっ……ズボズボされてっ、チンポが気持\nちいいっ！　あぁっ、チンポ気持ちいいんですのっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2704133" ]},
		{"command":[ "SETIMAGE", "0", "still_00000127_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「ファンの方々の前でっ……！　チンポで犯されているところを見せつけてっ\n！　はひっ、オマンコ感じていますわぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2704134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「も、もっと！　はひっ、チンポ気持ちいいっ！　チンポして下さいませっ！\n　このまま最後までっ！　チンポっ、あぁっ、チンポぉぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2704135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「あぁっ、チンポ……震えてっ……あひっ、で、出す気ですのっ？　くひぃん\nっ！　中にっ……このままっ、んぁぁぁぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2704136" ]},
		{"command":[ "SETIMAGE", "0", "still_00000127_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「あぁぁぁっ……出てるっ……中出しされているとこっ……みんなにっ……見\nられてぇっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2704137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000127_02_05" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「んんんんんっ……！　はぁぁ……気持ちよすぎる……こんな……あぁっ、ス\nテージの上でイクなんてぇ……は、ひぁぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2704138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「あふっ……あぁ、流し込まれてる精液が……いっぱいになって、垂れてしま\nう……みんなのステージを汚してしまう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2704139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「はぁ、はふぁ……あぁ……駄目ですわ……気持ちよすぎて……何も考えられ\nなくなってしまいます……んふぁ、ぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2704140" ]},
		{"command":[ "SETIMAGE", "0", "still_00000127_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……はぁ……こんな体験……初めて味わいましたわ……視線を意\n識しながら、大きな声で乱れることがこんなにすごいなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2704201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「この体験をしたなら……明日の本番も、きっと乗り越えられるような……そ\nんな感じですわ……あっ、んんっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2704202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「ま、まだ……終わってない……？　んっ、あっ、もっと堂々とできるように\n……更に恥ずかしいことを……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2704203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「そ、そんなこと……あぁ……どうすれば……あひっ！　あっ、ファンに向か\nって……今、されていることを……大声でっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2704204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「わ、分かりましたっ……してみせますわっ！　んっ、くっ……い、今から…\n…していることをっ……包み隠さずお話ししますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2704205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「皆様っ！　わ、私っ……ルナテミスDはっ、今……後ろから抱きかかえられ\nてっ……チンポをハメられている真っ最中です！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2704206" ]},
		{"command":[ "SETIMAGE", "0", "still_00000127_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「ファンの皆様の前でっ……あぁっ、大きく足を開いてっ……おっぱいもっ…\n…オ、オマンコもっ……丸見えにさせてっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2704207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「ズボズボっ……チンポでっ、中のヒダをっ……こねくり回されておりますわ\nっ！　あぁっ……は、恥ずかしいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2704208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「じ、自分がしていることを……こんな、声高に……叫ぶなんてっ……あぁっ\n、自分がスケベだとっ……宣言しているようなことっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2704209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「はっ、ひっ……！　だけどっ、これが……私の本当の姿っ……あぁっ、チン\nポが大好きなっ、いやらしいアイドルなんですわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2704210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「あっ、あぁっ、見てっ……！　もっと見てぇっ！　チンポを咥えて、ヒクヒ\nクしてるオマンコっ！　ビンビン乳首のおっぱいも見てぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2704211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「はひぁっ、あぁっ、そうですわっ……チンポが好きっ！　太くて硬いっ……\n！　オマンコしてくれるチンポが好きですわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2704212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「はぁぁんっ……一階席からもっ、二階席からもっ……私が浅ましくチンポで\nよがる姿が見えますわねっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2704213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「もっと見てっ……私の恥ずかしい大股開きの姿をっ……！　はひぃっ、チン\nポっ……また激しくてっ、オマンコっ……捲れますわぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2704214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「あっ……はぁぁっ、声が……響くっ！　ステージにっ……私のいやらしい叫\nび声が反響してっ……身体……熱くなってっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2704215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「またっ、またイキそうですっ！　あぁっ、何度もチンポされてっ……！　オ\nマンコっ……もう限界ですわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2704216" ]},
		{"command":[ "SETIMAGE", "0", "still_00000127_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「はいっ……皆さんに見てもらいますっ……！　私がっ……ステージの上でっ\n、されるままによがりながらイクところっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2704217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「んぁぁっ！　ラストスパートでっ……あぁっ、チンポがっ……深いところっ\n……抉っていますわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2704218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「はぁっ、あぁっ、もうすぐですわっ……私がっ……ズボズボ犯されながらっ\n……イクところまでっ、あともう少しっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2704219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「見てっ……！　チンポでイクところっ！　はぁぁんっ、見てっ、下さいませ\nぇぇぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2704220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「んぅぅぅぅんっ……！　なかっ……またっ……どぷどぷっ……オマンコっ…\n…出てっ……いますわぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2704301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000127_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「はぁぁ……イ、イキ顔……見せてます……ファンの皆さんに……だらしない\nトロ顔……見せてしまっていますわぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2704302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「あぁ……オマンコ……ヒクヒク震えてぇ……ずっと……チンポ……気持ちよ\nすぎますの……んぁぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2704303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「あふっ……種付けされてるところを直接見せてしまうなんて……許されない\nことなのに……気持ちいい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2704304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「んっ、はぁぁぁ……あぁ……射精……終わった……あぁ……私は……何とい\nうことを……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2704305" ]},
		{"command":[ "SETIMAGE", "0", "still_00000127_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「あ……トレーニング……そ、そうでしたわ……本当に見られた訳ではなかっ\nたんでした……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2704306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「それだけ集中していた……確かに、そう……なのかも知れません。この集中\n力があれば……明日も万全のパフォーマンスを発揮できる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2704307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「礼を言っておきましょう……確かに、この特訓には大きな意味がありました\nわ。明日の晴れ舞台に自信を持って臨めそうです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2704308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「んっ……ところで……ま、まだ下ろしていただけませんの？　チンポが……\nあっ、ずっと……オマンコに入ったままで……その……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2704309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「あっ、あんっ……あと一回……？　全く……仕方ありませんわね……明日に\n響かない程度に……お願い、あっ……しますわ……んっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2704310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「きゃぁんっ！　あぁっ……今度は……身体にっ……びゅくって……精液っ…\n…掛けられてますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2704401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000127_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「あはぁ……熱い……ザーメンシャワー浴びながら絶頂してるところ……見せ\nています……私のイキ顔……見せてますわぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2704402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「はぁん……どぷどぷっ……ずっと溢れて……止まらない……んんっ、貴方も\n興奮なさってたんですね……いっぱい出て……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2704403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「ああっ……精液まみれの姿をファンに見せつけるなんて……あぁ、許されな\nいことなのに気持ちいいですわ……はぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2704404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……終わり……ましたか……？　んっ、あぁ……私……なんて姿\nを……あ、そ、そうでした……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2704405" ]},
		{"command":[ "SETIMAGE", "0", "still_00000127_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「そうですわ……これはトレーニングで、んっ、度胸付け……大きな声も出ま\nしたし、特訓の意味はあったかも知れません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2704406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「ふふっ、明日のステージが楽しみになって参りましたわ……！　必ず、ファ\nンの皆が喜ぶ……最高のステージにしてみせましょう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2704407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「それにしても……その舞台を思いっきり汚してしまいましたわね……もちろ\nん、掃除はきっちりしてもらいますわよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2704408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「ここで、いやらしいことをしたなんて痕跡が少しでも残ってたら大変ですか\nらね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2704409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「後……そろそろ降ろして頂けると助かりますわ……このポーズ……やっぱり\n恥ずかしいですから……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2704410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
