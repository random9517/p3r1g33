		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「んんっ！　あっ、ああっ！！　私の口から、チンポが逃げて……んふぅっ！\n！　はぁあああぁぁぁっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0103401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00020101_01_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「お前のチンポがっ、精液を……んぁっ、母の顔に……いっぱい……かけて…\n…んっ、んふぅうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「すごい、すごいぞ……。まだこんなに、ねっとりとした濃厚精液を放てるの\nだな……はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0103403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「顔中、お前の匂いで埋め尽くされて……んふぅ、頭がどうにかなってしまい\nそうだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0103404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「いくら我慢できなくなったからって、母の顔にこんなに精液をひっかけると\nは、いけない息子だな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0103405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ちゅっ、ちゅぱっ。これは母親として……んちゅっ、しっかりとチンポを躾\nける必要がありそうだ……ちゅるるぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0103406" ]},
		{"command":[ "SETIMAGE", "0", "still_00020101_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「んふっ、あんなに射精したのにまたチンポをビクつかせて……ちゅぱっ、も\nっと私の口を味わいたいか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0103407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「いいだろう……。お前の気が済むまで付き合ってやる。このチンポの滾りが\n収まるまで、いつまでも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0103408" ]},
		{"command":[ "SETIMAGE", "0", "still_00020101_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ふふ……。そのための時間なら、たっぷりと用意してあるからな。だから、\n安心して私に身をゆだねるがいい……」", "NORMAL" ]},
