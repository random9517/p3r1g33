{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0180" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ふふ、なにを緊張している？　せっかくふたりっきりの時間ができたのだ。\n肩の力を抜いていいのだぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0103101" ]},
		{"command":[ "SETCHARA", "0", "char_00020101_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「それとも、母になにかしてほしいことがあるのか？　息子の頼みとあらば、\n可能な限り叶えてやろう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0103102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「……ん？　奉仕しろ、と？　ほう……私にシモの世話をしてほしいと、そう\nいうことか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0103103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ふふっ、久しぶりに再会した息子が、そんなスケベに育っていたとはな……\n。まあ、よかろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0103104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「どうした？　奉仕してやると言ったのだ。お前の望み通りな。さあ、はやく\n脱いで、横になれ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0103105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ほう……これはなんとも立派な……。こんなに勃起させて、いやらしいチン\nポだな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0103106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00020101_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ガッチガチではないか……それに、こうして触れると、火傷しそうなほど熱\nい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0103107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ああ……これがお前のチンポの匂いか……。くんくん……男らしい匂いだ…\n…身体が昂ってしまうな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ん？　まだなにか言いたげだな。母が息子の世話をするのは当然ではないか\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「それが息子にとっても大切な、チンポの世話であるなら、なおさらだ。それ\nじゃあ、息子の成長を口で味わわせてもらおうか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「んちゅっ、ちゅぶ……。んふぅ……舌でも、感じるぅ……ちゅるっ、お前の\n、チンポの滾り……んっ、んふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0103111" ]},
		{"command":[ "SETIMAGE", "0", "still_00020101_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「母が……んちゅるっ、この勃起チンポの面倒を、しっかり見てやるから、な\n……。ちゅぶっ、んふっ、ちゅぱっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「こらこら、チンポを暴れさせるな。おとなしくしていろ……。んちゅっ、ほ\nらぁ……私の舌を、もっと感じるのだぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「んちゅっ、ちゅっ、れろっ、れろれろぉ……っ！　私の舌が気持ちよくて、\n腰が動いてしまうのか？　ふふっ、仕方のないやつめ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「んっ、んちゅぶっ、それならぁ……こうして咥えるのは、どうだぁ……？　\n勃起チンポ……頬の裏に、あててぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0103115" ]},
		{"command":[ "SETIMAGE", "0", "still_00020101_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「んじゅるっ、んっ、んじゅっ、じゅぶっ、じゅぷぅっ！　んふっ、これなら\n、逃げられないだろ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「太い、チンポが……じゅぶっ、私の頬を、押しあげて……んっ、わかるか？\n　ここに、チンポがあるぞ……んじゅぶっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「んふふっ、んっ、じゅぶっ、じゅぷぷっ！　母の口を感じて、ンッ、チンポ\nも、気持ちよくなっているようだな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「じゅぷっ、じゅぷっ、もっとよくしてやるからな……んじゅるっ、こうして\n、頭を動かして、……んちゅっ、じゅぶっ、じゅぶっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ンンッ、腰が震えているではないか……じゅぷっ、母の口が気持ちいいよう\nだな……じゅるっ、じゅぷっ、じゅぷじゅぷっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0103120" ]},
		{"command":[ "SETIMAGE", "0", "still_00020101_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「口の中で、どんどん膨らんでいく……じゅるるっ、先端から、汁もあふれて\nきたではないか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「息子の先走り汁……じゅるるっ！　ああ、母として、しっかりと味わわなけ\nればな……じゅずっ、ずずずぅっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「んふっ、また腰をビクつかせて。息子よ……思ったよりも敏感なチンポをし\nているのか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0103123" ]},
		{"command":[ "SETIMAGE", "0", "still_00020101_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「母の口が気持ちよすぎるせいか？　ふふっ、気持ちいいのは当然のこと、な\nぜならお前の母なのだから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「母の奉仕が……ちゅぷっ、息子のお前にとって、快感になるのは、必然……\nじゅぶっ、じゅぶっ、じゅるるぅっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ほら、こうして……じゅるるっ、頬張ったまま、頭を動かして、チンポを舐\nりぃ……じゅるっ、じゅぶっ、じゅぶっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「母の頬と……歯を……じゅぶっ！　母の、厳しさと、優しさを……じゅるっ\n、同時に感じるが、いい……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「んふふっ、カリや、エラが、歯にあたっているのが、気持ちいいようだな…\n…じゅばっ、そのまま……射精、してしまうか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「母の口に……このまま……っ！　んっ、じゅぶっ、じゅぶじゅぶっ！　いい\nぞ、限界の時がきたのであろう……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「んふっ、ここまできて、遠慮する必要などない……んじゅぶっ、母の口に…\n…お前の精液、だ、だしてしまうがいい……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「んんぅっ！！　んふっ、んっ、んぶぅ……っ！　で……ででる……お前の精\n液が……んっ、んっくぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0103131" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00020101_01_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「んくっ、んっ、んふぅ……んじゅるぅ……っ！　熱い精液が、たくさん……\nじゅるっ、じゅずずぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「んはぁ……これが、お前の精液の味か……じゅるるっ、男らしい味……ちゃ\nんと、大人の男の味がするぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「んふっ、じゅるるっ、濃さも、量も……申し分ない……。ふふっ、息子の成\n長を実感できて、母はうれしいぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ちゅぶっ、じゅるっ、口の中で、まだまだビクンビクンいっているではない\nか……。母の口は、そんなによかったか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0103135" ]},
		{"command":[ "SETIMAGE", "0", "still_00020101_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「私も、息子にたっぷりと射精してもらえてうれしいぞ……ちゅぱっ、まだま\nだ元気だな、お前のチンポは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0103136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「どうやら、まだまだ射精し足りないようだな。まあそうだろう、私の息子が\n、一度の射精で萎えるほど軟弱なわけがない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0103137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ほら、こうして……やさしくチンポをさすってやろう……。ふふっ、先端か\nら、先ほどの射精の残りが垂れているな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「んちゅっ、ちゅぶっ、これもきれいに吸い取って……ちゅぱっ。腰が跳ねた\nな？　母が、もっと奉仕してやろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「お前は遠慮なく、母の口に身をゆだねればよい……。さあ、まだまだ奉仕の\n時間は終わらないぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「んじゅるっ、じゅぶっ、じゅぶっ、んちゅぅっ！　またこうして、咥えてや\nるのがいいだろうか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0103201" ]},
		{"command":[ "SETIMAGE", "0", "still_00020101_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「んっ、んんっ、さっきあんなに射精したというのに……チンポは硬いまま…\n…んふっ、立派になったな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「じゅぶっ、じゅぶっ、こうして口に頬張っていると、私の口から、どんどん\nよだれが溢れてしまう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0103203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「母も、興奮しているのだぞ……？　こうして、再会できた息子のチンポを、\nしゃぶることができているのだから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0103204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「じゅぶっ、じゅぶっ、じゅるるっ、じゅぱっ！　もっと、咥えて……んっ、\nじゅるるっ、また、膨らんできた……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「口の中に……じゅるるっ、お前の、先走りが……んっ、んちゅるぅっ！　本\n当に、いやらしい味だな……んっ、んふぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「お前も、我慢できないのか……？　んっ、さっきから、腰をずっと震わせて\nるようだな……じゅるるっ、ンッ、じゅぶぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0103207" ]},
		{"command":[ "SETIMAGE", "0", "still_00020101_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「いいのだぞ？　相手は母なのだから。お前も、このひと時の快楽に、身をゆ\nだねてしまえばいい……じゅばっ、んふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「んぁっ、そうだっ、お前も……腰を……んじゅるっ、じゅぶっ、んふぅっ！\n　あっ、頬に、先端が……んっ、んじゅるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「んぶっ、んっ、んんぅっ！　母の口に、チンポ擦りつけるように……んじゅ\nるっ！　いっぱい、動くがいい……んっ、んぶぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0103210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「私も、お前のことを気持ちよくするように……んじゅるるっ！　たっぷりよ\nだれを溢れさせて、チンポ、ヌルヌルにするからなぁ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0103211" ]},
		{"command":[ "SETIMAGE", "0", "still_00020101_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「んっ、んっ、んっ、んんぅっ！！　チンポ、んじゅるっ、いいぞ、その調子\nで……んふっ、もっと、動かすんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「欲望のままに、精液が、こみあげてくるように……っ！　じゅるるっ、じゅ\nぶっ、じゅぶっ！　私が、息子精液、受け止めるから……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「んっ、んっ、じゅぶっ、じゅぶっ！　じゅるるっ、じゅぶっ、んんっ、んふ\nぅ……っ！　すごい、匂いが、ちゅぶっ、チンポの匂い、強く……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0103214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「口から鼻に届く、いやらしい匂い……！　ああ、私も興奮して、たまらない\nぞ……息子チンポに、欲情、しまくってる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0103215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「んんっ、んじゅるっ、じゅぶっ、じゅぶっ！　お前も、限界か？　また、精\n液をだしてしまいそうか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0103216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「母の口が気持ちよくて、また我慢できなくなっているのだろう？　それなら\nまた、射精すればいい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「遠慮するな……んじゅるっ、じゅぶっ、じゅぶっ！　親子なのだから、射精\nを遠慮する必要など、ないだろう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0103218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「私も、お前の精液が欲しい……また、射精して欲しいんだ……じゅぶじゅぶ\nっ！　んじゅるっ！　じゅばっ、じゅばっ、じゅばっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「こうして吸いあげてやるっ！　お前が射精するよう手伝うから……！　じゅ\nるるぅっ！　だ、だせぇえええぇぇぇっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「んんんぅうううぅぅぅっ！！　んむっ、んっ、んふぅっ、うううぅぅぅ～～\n～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0103301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00020101_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「んぐっ、また、口の中がいっぱいにぃ……！　お前の、精液が……母の口を\n、満たしている……んっ、んんぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「な、なんだ……？　口の中に射精されながら、イッただろうって……？　ふ\nふっ、さすがだな、息子よ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0103303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「母も、イッたぞ……。息子の精液を、口の中で浴びながら、イッてしまった\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0103304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「んっ、んくっ、そして、この精液を飲みながらも……。んんぅっ！　母の身\n体は……快感に震えているぞ……はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0103305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「どうだ……？　母の口は、気持ちよかったか……？　ふふふ、これだけ大量\nに射精したのだ、ごまかすことはできまい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0103306" ]},
		{"command":[ "SETIMAGE", "0", "still_00020101_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「お前は覚えていないだろうな……。昔はこうやって、よくお前のチンポの掃\n除もしてやったのだぞ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0103307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ちゅっ、ちゅぱっ。たっぷり射精したチンポを労うように……んちゅっ、キ\nスもして、やってな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0103308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「……ん？　なんだ、またチンポが勃起してきたではないか。どうやらここは\n、母にもっと甘えたいらしい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「それなら、私も付き合おう。お前のチンポが満足するまで、何時間でもな…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0103310" ]},
