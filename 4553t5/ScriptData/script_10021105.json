{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0174" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「さすがに、ウチひとりでは分が悪いですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010114390001" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「そうだろうとも。早く降参しなさい。決して悪いようにはしないぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010114390001" ]},
		{"command":[ "SETCHARA", "0", "char_00010001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「……今宵は名月。その光で我が身を隠せ！　月光障壁の陣！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010114390002" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0174" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「きゃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010114390001" ]},
		{"command":[ "SETCHARA", "0", "char_00001102_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「うわっ！　まぶしっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_010114390001" ]},
		{"command":[ "SETCHARA", "0", "char_00009901_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「光でこっちを幻惑しようったって……あ、あれ……！？　オボロはどこ！？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010114390001" ]},
		{"command":[ "SETCHARA", "0", "char_00009601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「くっそー！　隙を見て逃げやがったな！　追っかけようぜ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_010114390001" ]},
		{"command":[ "SETCHARA", "0", "char_00009701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「でも、オボロはいったいどこに逃げたの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010114390001" ]},
		{"command":[ "SETCHARA", "0", "char_00009801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「それは……えーっと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_010114390002" ]},
		{"command":[ "SETCHARA", "0", "char_00009701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「あ！　みんな、見て！　あそこに地下への入口が！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_010114390001" ]},
		{"command":[ "SETCHARA", "0", "char_00002801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「そうか！　オボロはあの中だな！　みんな、行くぜーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_010114390003" ]},
		{"command":[ "SETCHARA", "0", "char_00009701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「あ！　ウタ！　待ちなさい！　待ちなさいってばー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010114390002" ]},
		{"command":[ "SETCHARA", "0", "char_00009601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「やれやれ……相変わらず、落ち着きのない子たちだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010114390002" ]},
		{"command":[ "SETCHARA", "0", "char_00010001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "などと言いつつ、地下へと降りて行ったニンジャラビッツとバッケンローダー\nたち。そこで彼女たちが見たものは！", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0175" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「……なんだこれ！　隊長じゃねえか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_010114390004" ]},
		{"command":[ "SETCHARA", "0", "char_00009701_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「……隊長だねえ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_010114390002" ]},
		{"command":[ "SETCHARA", "0", "char_00002801_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「なーんだ。隊長かぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_010114390002" ]},
		{"command":[ "SETCHARA", "0", "char_00009901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「こらこら、おまえたち。そうあからさまにガッカリするんじゃない。まあ、\nガッカリするのも無理はないが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010114390003" ]},
		{"command":[ "SETCHARA", "0", "char_00010001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「いやはや、なんとも申し訳ございませんな。うちのご主人がふがいなく頼り\nないばかりにご迷惑を……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010114390001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うるへー……頼りなくて悪かったな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「にいさま！　よかった、気が付いたんですね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010114390002" ]},
		{"command":[ "SETCHARA", "0", "char_00001102_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「だいぶ前から気が付いてたけどな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "あからさまにガッカリされて、声をかけるにかけられなかっただけだ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「そう。じゃあ、ひとまず隊長のことは置いといて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_010114390003" ]},
		{"command":[ "SETCHARA", "0", "char_00002801_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「置いとかれちゃうのかよ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「みんな、これからどうしたらいいと思う？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_010114390004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「本気で置いとかれた……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「そうだね……オボロはたぶん見つからないだろうし、まずは他のみんなを探\nしたほうがいいんじゃないかな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010114390002" ]},
		{"command":[ "SETCHARA", "0", "char_00009801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「それもそうね。いつまでも、バラバラに行動してるわけにもいかないし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010114390003" ]},
		{"command":[ "SETCHARA", "0", "char_00009601_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「でもよ、他のみんなはいったいどこにいるんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_010114390005" ]},
		{"command":[ "SETCHARA", "0", "char_00009701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「翔生子ちゃん、どこか心当たりとかなーいー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_010114390003" ]},
		{"command":[ "SETCHARA", "0", "char_00009901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「それが、その……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010114390003" ]},
		{"command":[ "SETCHARA", "0", "char_00001102_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「ふむふむ……？　急に列車が出てしまって？　翔生子ちゃんは置き去りに…\n…って！　大変じゃない！　どうするのよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_010114390005" ]},
		{"command":[ "SETCHARA", "0", "char_00002801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「列車の行き先に心当たりは？　そこに行けば、みんなと合流できると思うけ\nど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010114390003" ]},
		{"command":[ "SETCHARA", "0", "char_00009801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「ですよね……。そういうことであれば、時間城へのゲートを探したほうが\nいいと思います」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010114390004" ]},
		{"command":[ "SETCHARA", "0", "char_00001102_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「ゲートを？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_010114390006" ]},
		{"command":[ "SETCHARA", "0", "char_00002801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「そうです。そこがわたしたちの目的地です。列車がそこに向かうのかどうか\nは、わかりませんが――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010114390005" ]},
		{"command":[ "SETCHARA", "0", "char_00001102_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「インクレディブル・スクワッドの皆さんなら、必ず時間城にたどり着くと\n思います。ですからわたしたちも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010114390006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「なるほど。いい案だと思うが、どうかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010114390004" ]},
		{"command":[ "SETCHARA", "0", "char_00010001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「そうね！　私も、それがいいと思う！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010114390004" ]},
		{"command":[ "SETCHARA", "0", "char_00009601_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「まあ、それが一番確実かな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010114390004" ]},
		{"command":[ "SETCHARA", "0", "char_00009801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「わかった！　それじゃ、まずはゲートを探そう！　シャラク！　隊長の\n手当てをお願い！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_010114390007" ]},
		{"command":[ "SETCHARA", "0", "char_00002801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「はいは～い。それじゃ隊長さん、立てるかな～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_010114390004" ]},
		{"command":[ "SETCHARA", "0", "char_00009901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああ、まあ……立てるけどな。だけどさぁ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「『だけど』なんですかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010114390002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんでバッケンローダーが仕切ってんのかなぁ……隊長、俺なんだけどなあ\n……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「まあまあ。ご主人が隊長扱いされないのは、いつものことではありませんか\n。気にするようなことでもありませんぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010114390003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おまえの、そういう心のこもってない慰め方もいつも通りだよな！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}