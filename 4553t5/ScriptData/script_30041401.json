		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「……って、なんだよ急に。トリックオアトリート？　……急に言われても、\nなにも持ってきてねーけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1403102" ]},
		{"command":[ "SETCHARA", "0", "char_00000414_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「ちょ、なんだよその顔。こっちくんなよ。お、おい……お前……。うわぁあ\nああぁぁぁっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1403103" ]},
		{"command":[ "SETCHARA", "0", "char_00000414_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「油断した……まさかお前に押し倒されるなんて……。ん？　おい！　なにや\nってんだよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1403104" ]},
		{"command":[ "SETIMAGE", "0", "still_00000414_01_01" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「お、おっぱい……丸出しになってるじゃんか……。この衣装のせいで……ん\nぁっ、チンポが間にぃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1403105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「んんっ、谷間に、お前のチンポ感じるぅ……。はぁ、はぁ、なにガチガチに\n、勃起させてんだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1403106" ]},
		{"command":[ "SETIMAGE", "0", "still_00000414_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「くぅ……熱いチンポが、肌にこすれて……ンッ、ああっ、いやらしい匂いも\n、漂ってくる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1403107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……。……ああ？　なんで動きを止めるんだよ。ここまでシて\nおいて、いまさら怖気づいたのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1403108" ]},
		{"command":[ "SETIMAGE", "0", "still_00000414_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「お前……。今日は、お菓子をもってないといたずらされる日なんだろ？　こ\nの部屋を選んで……つまり、そういうことなんだろ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1403109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「オレも、手ぶらできたのが悪かったわけだし。お前のいたずら、しょーがね\nーから受け入れてやるよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1403110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「んっ、んぁっ、さっそく腰動かして……オレのおっぱい、好きに使うつもり\nだな……ああっ、んくぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1403111" ]},
		{"command":[ "SETIMAGE", "0", "still_00000414_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「なんだよ、んっ、おっぱい、締めろって……こうか？　んっ、チンポをます\nます感じるようになる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1403112" ]},
		{"command":[ "SETIMAGE", "0", "still_00000414_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「じっとりした勃起チンポが、お、俺のおっぱい犯して……んっ、んくっ、ど\nんどん硬く、大きくなってるじゃんかぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1403113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「んんっ、そんなに、オマンコを犯すみたいに、おっぱいを犯すな……。あっ\n、あぁ？　なんだよ、口も……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1403114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「チンポを、このまま舐めろってのか？　んっ、わ、わかったよ……。んぁっ\n、舐めるからちょっと、チンポじっとしてろって……んっ、ちゅる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1403115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「んぁ、ん、ちゅ、ちゅぷ……。こうで、いいか？　んちゅっ、チンポ、舐め\nるんだろ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1403116" ]},
		{"command":[ "SETIMAGE", "0", "still_00000414_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「んれろ、れろぉ……。谷間から、顔をだしてる先っぽを……んちゅっ、舌で\n……れろ、れろぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1403117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「んふぅ……んちゅ、ちゅ……んはぁ……。れろれろぉ……んっ、しょっぱい\n味だな……んっ、ちゅるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1403118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「くそ……。ちゅぱっ。返り討ちにして、こっちが主導権を握ってやるつもり\nだったのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1403119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「どうせ、お前だってオレのためのお菓子を用意してなかったんだろ？　んち\nゅ、ちゅぷぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1403120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……。それにしても……んちゅっ、どんどんエロい匂いが、強\nくなってくるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1403121" ]},
		{"command":[ "SETIMAGE", "0", "still_00000414_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「れろ、れろぉ……。舌が、ピリピリして……ンッ、れろっ、チンポ舐めるの\n……止まらなくなるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1403122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「んぁっ、お前の腰……どんどん動きが激しくなってるじゃないか……。んれ\nろっ、オレのおかげだって……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1403123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「チンポが、オレのよだれまみれになったから……ちゅぱっ、おっぱいがヌル\nヌルで……動きやすくなった……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1403124" ]},
		{"command":[ "SETIMAGE", "0", "still_00000414_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「それで？　オレにいたずらしながら、ンッ、気持ちよくなってるのか……ん\nちゅ、ちゅぱっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1403125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「オレもいたずらされながら、興奮してるんじゃないかって？　んちゅっ、ば\n、バカ言うなよ。そんなこと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1403126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「ンンッ！　そんなにチンポ、押しつけてくるなよ……じゅるっ、な、舐めに\nくいだろうが……んっ、じゅるるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1403127" ]},
		{"command":[ "SETIMAGE", "0", "still_00000414_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「お、オレはしかたなく、お前のいたずらにつきあってやってるだけなんだか\nら……んちゅっ、ちゅぱっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1403128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「どうせ、オレのおっぱいを犯しながら、れろ、チンポ舐めさせて……ンッ、\n射精するまで、終わらないんだろ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1403129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「だから、こうして……ちゅるっ、先走り垂らしてる、チンポ……れるっ、舐\nめてやってるんだよ……れろれろぉっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1403130" ]},
		{"command":[ "SETIMAGE", "0", "still_00000414_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「れろんっ、ちゅぱっ。服も、おっぱいも、ヌルヌルになって……んちゅるっ\n、チンポも、痙攣してる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1403131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「ビクビクって、ンッ、おっぱいの間で、暴れながらこすれて……んぁっ、犯\nされまくってる……んっ、あぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1403132" ]},
		{"command":[ "SETIMAGE", "0", "still_00000414_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「限界……っぽいな？　んっ、なんだよ、どこに射精しようか、迷ってるのか\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1403133" ]},
		{"command":[ "SETIMAGE", "0", "still_00000414_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「そんなの、どこだっていいだろ。お前のいたずらなんだから、ンッ、好きな\nところに、射精すれば……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1403134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「ああ、だせ、だせよ……。お前の、精液ぃ……っ。んれろっ、おっぱいで締\nめつけて、搾ってやるからぁ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1403135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「んぁあっ、ああっ！　でてる……チンポが震えて、おっぱいの間に精液だし\nてる……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1403136" ]},
		{"command":[ "SETIMAGE", "0", "still_00000414_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁ……っ！　すっごい濃い……オスの匂いも、キツいぃ……。こ\nんなにたくさんだすなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1403137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「ん……なんだ？　先っぽに、精液ついてるじゃんか……んれろ、れろぉ……\n相変わらず、変な味だよな……コレ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1403138" ]},
		{"command":[ "SETIMAGE", "0", "still_00000414_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「オレのおっぱいを犯しまくって、汚しまくって……んちゅる、綺麗にしてや\nるから、覚悟しろ……んれろっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1403139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「んふぅ……ちゅるるぅ……どうせ、ここまでさせるつもりだったんだろ？　\nお前の考えそうなことは、オレでも想像つくんだからな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1403140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「れろ、れろれろ……なんだよ？　もう少し、いたずらを続けるって？　んっ\n、ちゅる、それってどういう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1403201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「ひゃぁっ！　こ、腰をまたうごかして……んっ、オレのおっぱいを、犯して\nくのか……あっ、ああっ、んひゃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1403202" ]},
		{"command":[ "SETIMAGE", "0", "still_00000414_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「ま、まって、なんだか……おっぱいが感じやすくなってるっていうか……感\n度、上がってるっていうか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1403203" ]},
		{"command":[ "SETIMAGE", "0", "still_00000414_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「精液で、もっとヌルヌルになったせいで、お前のチンポめちゃくちゃ感じて\n……ああっ、変な声でるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1403204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「喘いでないで、またチンポ舐めろって？　んっ、しょうがないな……んちゅ\n、ちゅるっ。こうかよ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1403205" ]},
		{"command":[ "SETIMAGE", "0", "still_00000414_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「んれろ、れろぉん。はぁ、はぁ、チンポすごく感じるぅ……。おっぱいに、\n密着して……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1403206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「カリが、おっぱいひっかきながら、出入りすると……んじゅるっ、すごく、\n身体が疼くぅ……れろれろ、ンッ、ちゅぱぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1403207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「身体も……むずむずって、してきて……ンッ、まさかこんなときに……発情\n期がやってきたってのか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1403208" ]},
		{"command":[ "SETIMAGE", "0", "still_00000414_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「んちゅっ、ぢゅぱっ。ああ……精液の匂いを嗅いで、頭がクラクラしてくる\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1403209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「チンポこすれる感覚で……んぁっ、変な声でて……おかしくなるぅ……。ん\nっ、じゅるるっ、よだれも止まらないぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1403210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「んじゅるっ、うるひゃいぃ……ちゅばっ、お前が、変ないたずらしてくるか\nらぁ……じゅるるっ、んっ、ちゅぷぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1403211" ]},
		{"command":[ "SETIMAGE", "0", "still_00000414_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「発情期……きちゃったぁ……。じゅるるっ、身体が勝手に、チンポに反応し\nて……んっ、れろれろぉ、抑えられないぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1403212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「も……もっと……。オレにチンポでいたずらして……おっぱい、チンポで犯\nしまくって……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1403213" ]},
		{"command":[ "SETIMAGE", "0", "still_00000414_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「んぁっ、チンポが出入りするたびに、よだれと精液が混じったいやらしい音\nがする……！　んふぅ……んぁっ、ちゅちゅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1403214" ]},
		{"command":[ "SETIMAGE", "0", "still_00000414_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「またチンポが膨らんできた……んちゅっ、またチンポが射精しそうになって\nる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1403215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「きっとまた、いっぱいだすんだろ？　オレに向かって、ドロドロのいやらし\nい匂いのヤツ、たくさん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1403216" ]},
