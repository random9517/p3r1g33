		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「きてやったぞ。こんな部屋に呼び出されるようなことをした覚えはないんだ\nけどな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1403101" ]},
