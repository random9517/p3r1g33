		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「ああ……オレ……受け止めるから……。だから、好きなところに……んれろ\n、精液……だして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1403217" ]},
