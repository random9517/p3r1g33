{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「あの……お話聞いて、来ました。分かってます、私がこれから、なにをする\nのか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0203101" ]},
		{"command":[ "SETCHARA", "0", "char_00012202_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「嫌……といえば、まあ、嫌です。だって、こんなのまるで、枕営業じゃない\nですか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0203102" ]},
		{"command":[ "SETCHARA", "0", "char_00012202_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「私も他のメンバーも、それだけは絶対にしないって約束してたのに……なの\nに、私がその約束破っちゃうなんて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0203103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「まあ、正確には枕営業じゃないんで、セーフなんですけど、見た目がそれっ\nぽいって言うか……だから、嫌なのは嫌です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0203104" ]},
		{"command":[ "SETCHARA", "0", "char_00012202_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「でも、必要なことなんですよね？　だったら、やります。それに、隊長のこ\nと、まるっきり嫌いってわけでもありませんし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0203105" ]},
		{"command":[ "SETCHARA", "0", "char_00012202_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「その代わり、こういうことするの初めてなんで、期待しないでくださいね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0203106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「じゃ、じゃあ、始めます。えっと……これを、どうしたらいいんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0203107" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00012202_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「えええ！？　な、舐めるんですか、これ！？　そんなこと、しなきゃだめな\nんですか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0203108" ]},
		{"command":[ "SETIMAGE", "0", "still_00012202_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「ふぇらちお？　な、なるほど……みんな、こういうこと、してるんですか。\n全然知りませんでした」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0203109" ]},
		{"command":[ "SETIMAGE", "0", "still_00012202_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「うぅぅぅ……嫌ですけど、うぅぅ……ん、れろ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0203110" ]},
		{"command":[ "SETIMAGE", "0", "still_00012202_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「ひああ！？　ベロが当たった瞬間、おちんちんがびくってしましたよ！？　\nひょっとして、痛かったですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0203111" ]},
		{"command":[ "SETIMAGE", "0", "still_00012202_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「へ？　気持ち良くて、震えた？　気持ちいいと、おちんちん、びくってしち\nゃうんですか？　そ、そうなんですね……良かった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0203112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「それじゃあ、続き……し、します、ね。ん、れろ……うぅぅ、れろぉ。れる\n。れるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0203113" ]},
		{"command":[ "SETIMAGE", "0", "still_00012202_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「こ、こんら、かんじれ、いい、れすか？　れろ、れるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0203114" ]},
		{"command":[ "SETIMAGE", "0", "still_00012202_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「ふえ？　もっと、ソフトクリーム、舐めるみらいに？　は、はひ。れうぅぅ\n。ん、れろぉ、れる、れろ、れろ……れるぅぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0203115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「んあ、ふあぁ……しゅごい。おちんちん、ろんろん、おっきくなっれる。れ\nろって、舐める度に、びくっれ震えれ、おっきく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0203116" ]},
		{"command":[ "SETIMAGE", "0", "still_00012202_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「れるぅ、ん、れお、れるぅ……ん、れるぅぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0203117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「ふあぁぁ……なんか、すごい、匂い、してきましたぁ。青臭くて、むわっと\nするような、匂い、ですぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0203118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「か、感じてきた証拠なんですか、この匂い。なるほど……よ、良かったです\n。ちゃんと、できてるみたいで」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0203119" ]},
		{"command":[ "SETIMAGE", "0", "still_00012202_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「次は……は、はい。じゃあ、そうします。えっと……い、いきますね。あー\nむっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0203120" ]},
		{"command":[ "SETIMAGE", "0", "still_00012202_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「うむぅ、ん、じゅる……ぶぅ、ん、むぅぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0203121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「く、唇、れ……ん、むぐ、んむぅ。扱くように、動かす……あむぅ、んむぅ\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0203122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「こ、こう、れすか？　ん、むぅ、むぅぅ、ん、む、むぐっ、んむぅ。じゅる\nぅぅぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0203123" ]},
		{"command":[ "SETIMAGE", "0", "still_00012202_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「わ、わらひ、ちゃんろ、できれ、まふか？　ふえ？　咥えながら、舌も……\nあーそっか、そっち、忘れてました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0203124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「むぅ、んじゅる、じゅぶぅ、ん、じゅ。むぅぅ、じゅるる、じゅぶぅ、ん、\nじゅるぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0203125" ]},
		{"command":[ "SETIMAGE", "0", "still_00012202_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「んんん！？　なんか、先っぽから、出てきてます。これ、おしっこなんじゃ\nあ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0203126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「へ？　これも、気持ち良くなった証拠なんですか？　感じてくると、勝手に\n、滲んでくるんですか……へ、へぇ……知らないこと、だらけです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0203127" ]},
		{"command":[ "SETIMAGE", "0", "still_00012202_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「じゃあ、このまま続けた方がいいんですね？　は、はい。もっと強く……頑\n張ります。あーむ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0203128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「んぶぅ、ん、じゅるうぅ、ぶぅ、んじゅるるる。じゅる、ちゅ、ちゅぶ。ん\nぶんぶんぶ、んっ、ぶぅ、じゅるぅううぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0203129" ]},
		{"command":[ "SETIMAGE", "0", "still_00012202_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「ふあぁぁ……ろんろん、かたくなっれ、じゅるうぅ、ぶぅ、んじゅるるる。\nお、おっきくぅ……おくひのなか、くわえきれない、れふぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0203130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「んぐ！？　ん、ぶ！？　おひんひん、また、びくびくっれ？　ふえ？　イク\n？　イクっれ？　なにが……んんん！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0203131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「んあ、んん！？　何か、あぶっ！？　出てきてるぅ！？　んぶぅんんんんん\nんんん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0203132" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00012202_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「えほっ！　えほえほ！　えほ！　おえぇぇ……な、なんですか、いきなり、\n口の中に、何か出しちゃうなんてぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0203133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「うわ、白くて、ドロドロしてる。ひょっとしてこれって……あ、あうぅ、あ\nうぅぅ。そうなんですね、これが、精液……なんですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0203134" ]},
		{"command":[ "SETIMAGE", "0", "still_00012202_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「当然です！　こんなの見たの、初めてです！　おちんちんだって、弟の以外\n、初めて見ましたし！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0203135" ]},
		{"command":[ "SETIMAGE", "0", "still_00012202_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「え、エッチなこと、最後までしなくても、ちゃんと出ちゃうもんなんですね\n、これって。不思議です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0203136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「うぅぅぅ……おかげで、口の中、どろどろで、いがいがで、ちょっと気持ち\n悪い……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0203137" ]},
		{"command":[ "SETIMAGE", "0", "still_00012202_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「それに、急だったからちょっと飲んじゃって、おかげで喉の奥から匂いが…\n…うぅぅ。早くうがいしたい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0203138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「はあ！？　飲んでくれて嬉しかった！？　正気ですか！？　こんなの飲むの\nが、嬉しいなんて！？　男の人のそういうの、全然理解できないです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0203139" ]},
		{"command":[ "SETIMAGE", "0", "still_00012202_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「とにかく、これでお終いですよね？　それじゃあ、これで失礼します。お疲\nれ様でしたー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0203140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「えっ……？　まだ終わりじゃないって……それって、どういう……きゃっ！\n　ちょっ、なっ、何……また大きくさせてるんですかっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0203201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「続けてもう一回って、正気ですかっ？　普通って、一回出してそれで終わり\nって話じゃないんですかっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0203202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「誰に聞いたかって……そ、そんなのは、どうでもいいじゃないですか。企業\n秘密ですっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0203203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「ま、まあ……確かに、今のおちんちんが……とてもお元気そうに見えるのは\n……はい、私にも分かります……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0203204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「分かりました……とにかく、もう一回ですね？　でも、もう一回だけですよ\n？　３回目とかナシですからね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0203205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「もう……こんな所ばっかり元気なのって、どうかと思いますよ？　はいはい\n、ちゃんとおっぱい……擦りますってば……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0203206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「んっしょ……んしょ……んっ、さっきは……あんまり動かしてなかったから\n……今度は、もっと本格的に……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0203207" ]},
		{"command":[ "SETIMAGE", "0", "still_00012202_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「どう……ですか？　んっ、あぁ……精液が……うぅ……ぬるって……変な感\nじです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0203208" ]},
		{"command":[ "SETIMAGE", "0", "still_00012202_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「また……舐めないと、なんですよね……分かってます……ちゃんとしますよ\n……んっ、えろ……れろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0203209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「じゅぷっ……んっ、ぁっ……んふっ、ベロ……くっつけてぇ……んりゅっ、\nじゅるっ、れろ……えろぉっ、れろんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0203210" ]},
		{"command":[ "SETIMAGE", "0", "still_00012202_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「あれ……？　もっとやな味かと思ってたけど……ちゅぷっ、そうでも……ん\nっ、ない、かも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0203211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「れるっ、んっ、あ……んりゅっ……またビクビクさせて……んちゅっ、これ\n……気持ち、ひーんれふね……んちゅ、ちゅぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0203212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「んふっ、慣れてくると……案外可愛い……かも……ちゅぱっ、ぴちゃ……ん\nっ、んちゅ……んりゅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0203213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「どうしたんですか隊長、んりゅっ、変な声、出ちゃってますよ……？　こう\nして舐められるの……んちゅっ、そんなにいいですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0203214" ]},
		{"command":[ "SETIMAGE", "0", "still_00012202_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「れろっ、えろぉっ、んっ、あむっ、くぽっ、もっと深く……咥えちゃいまふ\n……くぽっ、んっ、ふぐっ、りゅぷっ、んじゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0203215" ]},
		{"command":[ "SETIMAGE", "0", "still_00012202_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「りゅぱっ、んぷっ、ふぉら……んじゅるっ……この辺とか……すっごく震え\nて……んむっ、じゅぽっ……くぽっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0203216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「それで……おっぱいも一緒に動かしたら……んんっ、あっ……りゅぷっ、ま\nた……おちんちん……ビクってしてまふ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0203217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「んっ、じゅぱっ、これ……また出るんですよね……？　んっ、さっきと同じ\n……んじゅるっ、この感じ……分かりまふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0203218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「私の……準備は出来てますからっ……後は……いつでも……いいですからっ\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0203219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「変に我慢しないで……さっさとっ、出しちゃって下さいっ！　んりゅっ、じ\nゅぷっ、ちゅぶっ、んんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0203220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「はぷっ……んんっ、ま、まらっ……このまま……ふぁっ、ひっ……んんっ！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0203301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00012202_01_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「んぐっ、ふぶっ……んんんんんーっ！　んぐっ、あぷっ……またっ、むっ、\nんぐっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0203302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「だ、いじょうぶ……れふ……もう、慣れましたからぁ……ちゃんと飲みます\n……んっく……それがいいんれひょ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0203303" ]},
		{"command":[ "SETIMAGE", "0", "still_00012202_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「んっく、こく……んくんっ……んぅっ……でも、量が多すぎます……隊長…\n…節操なし過ぎませんか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0203304" ]},
		{"command":[ "SETIMAGE", "0", "still_00012202_01_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「んふぁっ、はぁっ、はぁっ、けほっ、けほけほっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0203305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「はぁ……やっぱり、うがいしたい……飲めましたけどぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0203306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「そのうち、この味が大丈夫とかになるんでしょうか……んっ……もう、少し\n慣れかけてるのがフクザツですけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0203307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「が、頑張りましたか……まぁ、そう言って頂けるなら……一応、やってよか\nったとは……思います」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0203308" ]},
		{"command":[ "SETIMAGE", "0", "still_00012202_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「早くシャワー浴びないと……えっ？　い、いえいえっ、一緒にはっ、遠慮し\nておきますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0203309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「とにかくっ、今度こそお疲れさまでしたっ。隊長もずっとその格好だと風邪\n引きますよっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0203310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「く……んんっ、あっ、えっ……何で、抜いて……あっ、ひゃあっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0203401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00012202_01_17" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「わぷっ！　あっ……ちょっ、顔に……そんなっ、んぷっ、いきなり掛けるな\nんてぇっ……あぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0203402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「んぁぁ……すごい……匂い……んんっ、粘ってるのが……べとって……へば\nりついて来ます……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0203403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「あぷっ……ま、まだ出るんですか……？　どれだけ出したら……んくっ、気\nが済むんですか……もうっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0203404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ、んっ、終わり……ました？　うぅー……もう、顔が精液でガ\nビガビしてます……なんか固まってきてるし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0203405" ]},
		{"command":[ "SETIMAGE", "0", "still_00012202_01_16" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「ちゅぷっ……んぅ……ちょっと味には慣れましたけど、やっぱりそこまで美\n味しいものじゃないですよね……これ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0203406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「でも、飲んだ方が嬉しいんですよね。はぁ……男の人って本当に……しょう\nがないと言うか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0203407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「まぁ、それでも喜んで頂けたのなら……一応よかったかな……とは思います\nけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0203408" ]},
