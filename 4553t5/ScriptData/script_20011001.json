{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0116" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_019" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「さて、野菜よし、肉もよし、ミネラルウォーターに牛乳もよしと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020021270001" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……おい、もういいだろ。めちゃくちゃ重いんだが……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「何だよ、男がこれくらいの荷物で泣き言かー？　まだまだ全然行けるだろっ\nて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020021270002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「これぐらいって量じゃねえだろ！　大体、何で俺が買い出しに付き合わなき\nゃなんないんだ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「まぁまぁ、どうせヒマそうにしてたじゃんか。終わったら発泡酒の一杯くら\nいは飲ませてやるから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020021270003" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そこはビール位出せよ！　あーもう、ほら着いたんだから終わり終わり！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「んー、まぁいっか。サンキュー、一応助かったぜ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020021270004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「感謝の仕方も雑！　ったく……俺の周りの女どもはどうして揃いも揃ってこ\nうなのかね……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ははっ、女もちゃんと相手を見てるってことさ。いや、マジで感謝はしてる\nって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020021270005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ふん……そこら辺は、もっと態度で表して欲しいもんだな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「分かった分かった、ちゃんと生中、奢ってやるから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020021270006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おっ、それなら……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "男" ]},
		{"command":[ "SETTEXT", "「うわぁぁぁぁーっ！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ん……？　何だ、今の叫びは？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「向こうだ、行くぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020021270007" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「えっ、あっ、おいっ！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0041" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_009" ]},
		{"command":[ "SETNAME", "男" ]},
		{"command":[ "SETTEXT", "「ひっ、ひぃっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「どうしたんだ、一体何があった！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020021270008" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "男" ]},
		{"command":[ "SETTEXT", "「あ、あっちで……何か、得体の知れないのが……た、戦ってて！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あれか……？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「くっ……はぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021270001" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「ふっふーん♪　結構やるじゃん、イグニス」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_010021270001" ]},
		{"command":[ "SETCHARA", "0", "char_00016601_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「アルマッ！　観念して、無駄な抵抗はやめろ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021270002" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「やーだよぉ♪　悔しかったら、捕まえてみたらー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_010021270002" ]},
		{"command":[ "SETCHARA", "0", "char_00016601_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「ええいっ、ちょこまかとすばしっこい奴めっ！　はぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021270003" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「おぉっとぉ！　ひゅー、今のはちょい危なかったかも♪　じゃあ、こっちか\nらも行こうかなー、えやっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_010021270003" ]},
		{"command":[ "SETCHARA", "0", "char_00016601_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「うくっ！？　くっ……貴様っ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021270004" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「ほらほら、どうしたのー？　私を捕まえるんじゃなかったのかなーっとっ！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_010021270004" ]},
		{"command":[ "SETCHARA", "0", "char_00016601_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「くっ！　やめろっ、こんな狭い場所で……周囲を巻き込むなっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021270005" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「えー？　仕掛けて来たのはそっちだしー？　私に言われてもなー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_010021270005" ]},
		{"command":[ "SETCHARA", "0", "char_00016601_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「……っ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021270006" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「なーんか、イグニスちょっと調子悪そうだし？　いい機会だから、ボコっち\nゃおうかな～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_010021270006" ]},
		{"command":[ "SETCHARA", "0", "char_00016601_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「何なんだアイツら……それに、あの格好は……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「おう、アイツら止めんぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020021270009" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はっ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「往来で派手に暴れやがって……商店街の奴らにめちゃくちゃ迷惑掛かるだろ\nうが！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020021270010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや……そりゃそうだけど、あいつらまともそうじゃ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「だったら余計に放っとけないだろうがっ！　おらっ、ついてこい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020021270011" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「な、何で俺が！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「男ならピーピー言わないでさっさと来い！　ぶん殴るぞっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020021270012" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「くそっ……こいつマジだから嫌なんだよ……！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「おらっ、てめぇら！　大人しくしやがれぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020021270013" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
