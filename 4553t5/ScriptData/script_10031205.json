		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「くそっ！　地球から仲間を呼ぶとか、卑怯だぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080116280001" ]},
		{"command":[ "SETCHARA", "0", "char_00000408_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「わははははは！　おまえたちだって時間帝国兵を呼んだではないか！　おあ\nいこだ、おあいこ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010116280002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「勝てないとわかったら、さっさと兵たちを連れて撤退することだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090116280001" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうだそうだ！　おまえたちがいなくなったら、ここはゆっくり爆破させて\nもらうぜ、こいつでな！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そう言って俺は、爆弾を取り出して相手を威嚇しようとしたが――", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ふふっ、ふふふふふ……貴様たち、この程度で勝ったつもりか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100116280001" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あ？　なんだと？　はは～ん、さては負け惜しみだな？　いいんだぞ。今の\n俺は寛大な気分だから、負け惜しみぐらいいくらでも聞いてやるぜ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「おや、そうですか。そう思うですか。これを見てもまだ、そんなことを言え\nますか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090116280001" ]},
		{"command":[ "SETCHARA", "0", "char_00000509_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なにぃ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「出番じゃ、円盤少女Ａ、Ｂ！　インクレディブル・スクワッドをギッタギタ\nのメッタメタにせよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100116280002" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "円盤少女Ａ" ]},
		{"command":[ "SETTEXT", "「なになに～？　暴れていいの～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_010116280001" ]},
		{"command":[ "SETCHARA", "0", "char_00016202_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "円盤少女Ｂ" ]},
		{"command":[ "SETTEXT", "「やりぃ～！　きょーかかいぞーとか、訓練とか、退屈でしょうがなかったん\nだよね～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_010116280001" ]},
		{"command":[ "SETCHARA", "0", "char_00016302_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お、おまえら！　最近出てこないと思ったらこんなところに……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄr.サイレーン" ]},
		{"command":[ "SETTEXT", "「っていうか、強化改造だって？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010116280001" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "円盤少女Ａ" ]},
		{"command":[ "SETTEXT", "「そうそう！　わたしたち、前よりもっともーっと強くなったんだからね～！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_010116280002" ]},
		{"command":[ "SETCHARA", "0", "char_00016202_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "円盤少女Ｂ" ]},
		{"command":[ "SETTEXT", "「あんたたちみたいなザコザコなんか、ピーピー泣かせてあげちゃうんだもん\nね～♪」", "NORMAL" ]},
