		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「んあああぁぁ！！？　やあぁぁ！？　いまぁ！　いまっ！　ひとこすりごと\nにイッてるの分かりますか？」", "NORMAL" ]},
