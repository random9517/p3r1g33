		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「聞いて貰ってもいいですか？　私っ……初めてなので、や……優しく、して\n下さい……んっ、んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0104102" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あぅっ、んっ……ん～～っ！！　乳首っ、いじくり回すのダメです、ダメっ\n……ダメぇぇ！　弱いっ……のぉ……んあぁ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0104103" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「はぁ、はっ……あうぅ、もう濡れてるとか言わないで下さい、だって……だ\nって……あうあぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0104104" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「変態なんかじゃ……あっ！？　お、おちんちんがいつもより硬くて大きい…\n…気がしますっ……んあぁ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0104105" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あっ！　あぁ！？　んんっ、あっ！　あぁ～～っ！！　入っ……てくる……\nひゃうぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0104106" ]},
		{"command":[ "SETIMAGE", "0", "still_00013101_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ひっ！　ひぃぃん！　大きすぎっ……んあぁぁん、はぅぅ！　いっ、痛くは\nない……です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0104107" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ひゃぅ、ひっ……ひゃうぅぅ！！？　そ、そんっ……なぁ、奥まで入って…\n…？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0104108" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「きゃうぅん！　あっ、あぁ～～！？　優しくしてって言ったのにぃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0104109" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「んあぁ！　あぅ！　あぅぅん！　子宮ぅ、ぐりぐりって突かれて……あっ、\nああぁ～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0104110" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「子宮におちんちん入ってきちゃいます……っ！！　はひっ、ひっ、ひぅぅ！\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0104111" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「このまま射精されたらっ……やっ、やあぁ！　私っ孕む……孕んじゃいます\n……くひぃぃ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0104112" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「奥にっ、奥に届いてる、やぅ、やぁっ！　んああぁぁ～～！！　やだぁ、言\nわないで下さい……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0104113" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「か、感じて……感じてなんて、んん～～！？　感じ……て、ますっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0104114" ]},
		{"command":[ "SETIMAGE", "0", "still_00013101_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「初めてなのに、くぅぅ！　ひゃぅ！　おちんちん奥にまで入れられて、んあ\nあぁぁん！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0104115" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あんっあぁぁん、あんあんあぁぁ！？　子宮ぅ突き上げられてぇ……あ、あ\nそこから愛液がぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0104116" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「んあぁ、おまんこから愛液ぃどぷどぷ垂らして、感じちゃってるんです、く\nひぃぃ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0104117" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あ～っ！！　あっああぁ、あぁ～～っ！！　頭の奥ぅ……じんじんきちゃっ\nて……ひぃ、あひぃぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0104118" ]},
		{"command":[ "SETIMAGE", "0", "still_00013101_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「しびれてるんです、突かれてっ……んんあぁ！　快感っ、突き抜けてきてぇ\n……ひぃぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0104119" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「カラダ中、電気がぁ……駆け巡って、もう何も考えられなくなっちゃう……\n！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0104120" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「やっ、やああぁ～～！！？　おっぱいも責めるなんてダメ、ダメですっ……\n感じすぎちゃう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0104121" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「やだぁ、やだっ、やだやだっ……ダメッ、イク！　イクぅ！　んあああぁぁ\n～～～～！！！？？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0104122" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「はひぃ……ひあぁ、はぅん！　はっ、はあぁん……い、言わないでくだ……\nさいぃ、変態、だなんて……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0104123" ]},
		{"command":[ "SETIMAGE", "0", "still_00013101_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あなたに抱かれてるって思うだけで、んあぁぁ！！　激しく責められてるっ\nて思うだけで……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0104124" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「おまんこの奥から、いやらしい汁が溢れて止まらなくなってきちゃうんです\n……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0104125" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「やあぁぁ！？　また奥ぅ、がつがつって責める……！　私っ、い……いまイ\nッたばかりなのにっ……ひぃぃ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0104126" ]},
		{"command":[ "SETIMAGE", "0", "still_00013101_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「またぁ、またイッちゃいます……どうか、お願いです、一緒に、一緒にぃ…\n…んああぁぁ～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0104127" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「出すんですか？　子宮にたっぷりだなんて……そんなぁ！　子宮ぅ下りてき\nちゃってるのに……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0104128" ]},
		{"command":[ "SETIMAGE", "0", "still_00013101_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「このまま種付けプレスされちゃったら……私のカラダ、なびいちゃいます…\n…ぜ、絶対に妊娠しちゃう……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0104129" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あっ、あああぁぁ～～～！？　来るっ……来るぅぅ！　激しっ、激しいぃ…\n…あぁぁんあんあんあっ、んああぁ！！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0104130" ]},
		{"command":[ "SETIMAGE", "0", "still_00013101_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「イクッイクイクッ、来てっ、来て下さ……き、てぇ……あっ！？　あああ！\n？　あぁぁ～～～！！！！　イクぅぅぅ～～～～！！！！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0104131" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ひゃふぅぅ！！？　くひっ…………！！　出てりゅう……子宮に熱いのが、\n精液がたっぷり注ぎ込まれて……んああぁぁん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0104132" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00013101_02_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「んはああぁ！　はああぁ！　頭クラクラしてきちゃって……んあぁ、おほぉ\nぉ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0104133" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ほ、本番はこれから……！？　そんなぁ、入れっぱなしのおちんちん勃起し\nてきちゃってるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0104134" ]},
		{"command":[ "SETIMAGE", "0", "still_00013101_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「に、妊娠するまでやめない……！？　どっドＭ女を調教、だなんて……あう\nぅ、はああぁぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0104135" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あぁ、お願いです……やめないで、続けて下さい……あなたがくれたエッチ\nなビデオであったみたいに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0104136" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「手足を縛り付けて、お腹がぽっこり膨らむまで精液流し込んで下さい………\n…っ！！」", "NORMAL" ]},
