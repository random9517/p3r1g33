		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「ちっきしょー！　展示でさんざん期待させやがって、この根性なしーっ！　\n返せ！　私の期待と飯代返せーっ！」", "NORMAL" ]},
