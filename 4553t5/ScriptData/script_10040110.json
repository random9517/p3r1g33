		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「やっぱり冴島長官……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010116480003" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「そういえばあの人、今日は非番だった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010116480003" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「今のレース、外したらしいな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「くそっ！　こうなりゃ次のレースで取り返すしかねえな！　おっと……その\n前にカップ酒もう１本……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_020116480003" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「やべ！　こっちに来る！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「仲間だと思われちゃう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010116480004" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「カツマさん！　気づかれる前に逃げ――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010116480004" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0108" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「あれぇ～？　カグヤにマリアにジュンジローに、おまけにカツマじゃ～ん。\nおまえらも勝負しに来たのかぁ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_020116480004" ]},
		{"command":[ "SETCHARA", "0", "char_00004902_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "カグヤ＆まりあ＆カツマ" ]},
		{"command":[ "SETTEXT", "「見つかっちゃった……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010116480005" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "400" ]},
		{"command":[ "SETCHARA", "1", "char_00001401_01", "3", "CENTER", "-400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「それともまたカツマが『隊長辞める～！』とか言い出したの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_020116480005" ]},
		{"command":[ "SETCHARA", "0", "char_00004902_01", "2", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんで長官にまで見抜かれてんだよ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「だって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010116480006" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ねえ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010116480006" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「いやはや。進歩も成長もまったく望めないダメご主人で、たいへん申し訳あ\nりませんぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020116480001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「だからお前はいちいちうるさいっつーんだよ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「まあまあ。カツマちゃんの気持ちもわからんではないけどなあ。最近は給料\nも上がらないのに、仕事は忙しくなる一方だしさあ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_020116480006" ]},
		{"command":[ "SETCHARA", "0", "char_00004902_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうそう！　めんどくせえヤツが次から次へとめんどくせえことを持ち込ん\nでくるから、俺の仕事なんか増える一方だし！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「上からは防衛の成果が上がってないとどやされ、下からはあーだーこーだと\n不平不満をぶつけられ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_020116480007" ]},
		{"command":[ "SETCHARA", "0", "char_00004902_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "美鈴＆カツマ" ]},
		{"command":[ "SETTEXT", "「はぁ～！　もうやってらんねえ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_020116480008" ]},
		{"command":[ "SETCHARA", "0", "char_00004902_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「いや、そこで意気投合されましても！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010116480007" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「よしわかった！　カツマ、もうあんた隊長辞めていい！　いっそ私も辞めて\nやる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_020116480009" ]},
		{"command":[ "SETCHARA", "0", "char_00004902_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「なんで長官まで！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010116480007" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「辞めてどうなさるおつもりで？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020116480002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「決まってんだろ！　独立するんだよ、どくりつ！　カツマ、組んで商売やる\nか！　居酒屋・正義の支店出すかぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_020116480010" ]},
		{"command":[ "SETCHARA", "0", "char_00004902_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なるほど、そういう方向も――」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ちょっとカツマっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010116480008" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「長官も落ち着いてっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010116480008" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "と、また大騒ぎが始まったところで――", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「あー、ご主人。電話が鳴っておりますぞ。転職の話は後にして、いったん出\nられたほうがよろしいのでは？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020116480003" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お、おう、そうか。まあいいや……って、昴から！？　いったいなんだ……\n？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「もしもし？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "クロノスストライダー・昴" ]},
		{"command":[ "SETTEXT", "「カツマ隊長！？　お願い、すぐに採石場に来て！　みんなが……大変なの！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_010116480001" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
