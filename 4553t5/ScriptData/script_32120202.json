		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「お、お願いっ……！　もうこれ以上、あの人のことを忘れさせないでっ……\n！　オマンコプラグ、メチャクチャにしないでぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0204216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「本当にやめていいのかって……そんな言い方卑怯よっ……！　こんな状態で\nやめられたら、回路が暴走しちゃうわっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0204217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「あっ、んんっ！　最後までメンテナンスしてっ！　隊長さんのオチンチンで\n、最後までイカせてぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0204218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「あああっ！　くるっ！　また来ちゃうぅ！　おっぱいミルクもどんどん溜ま\nってきて……あっ、あっ！　出るっ、出るのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0204219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「隊長さんもイッてっ！　膣内でも膣外でも、好きなところに出していいから\n……あっ、あふっ、くっ、あっ！　ふああああっ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0204220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「あああああぁぁぁ～～～……！　熱いのが、また一番奥で出されてるわっ…\n…！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0204301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021202_02_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「子宮口が勝手に降りてきて、オチンチンの先っぽとキスしてるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0204302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「もっと精子を補充したいって、ちゅうちゅう吸い付いてるのぉ……！　ああ\nっ、あっ！　こんなの感じたら、私のおっぱいも吹き出ちゃうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0204303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「んはあああぁ……！　乳首を弄れば弄るほど、特製ミルクが溢れてくるわっ\n……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0204304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「せっかくメンテナンスで補充したばかりなのに……！　また補充しないとい\nけなくなっちゃうっ……！　んんんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0204305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、あっ……隊長さん……たくさん出してくれてありがとう……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0204306" ]},
		{"command":[ "SETIMAGE", "0", "still_00021202_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「おかげでプラグの奥の疼きもおさまったわ……これなら、暫くメンテナンス\nしなくても大丈夫そうね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0204307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「でも、今回の快感を記憶装置が憶えちゃったから……もう普通のメンテナン\nスじゃ満足できそうにないわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0204308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「ねえ、隊長さん……もしよかったら、次のプラグ調整のときもメンテナンス\nしてくれないかしら……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0204309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「いいの……？　うふふっ。嬉しいわ……それじゃあ、次もよろしくお願いす\nるわね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0204310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「きゃあああぁ！？　隊長さんの精子がボディに降りかかって……んああっ！\n　耐熱仕様なのに、装甲が溶けちゃいそうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0204401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021202_02_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「んっ、あふっ……！　パーツの隙間に精子が入っていくわっ……！　せっか\nく、全身ピカピカに磨いたのにっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0204402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「このままじゃ、シミになっちゃうっ……！　私のボディ、ワックスじゃなく\nて精子のニオイでいっぱいになるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0204403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「ああっ、んっ……あっあっあっ！　そんなのダメっ……！　ダメなのに……\n幸せな気持ちが全身の回路を駆け巡って……はあああぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0204404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「幸せすぎて、特製ミルクがどんどん溢れてくるぅ！　止めようとしても、エ\nラーが出て止まらないのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0204405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「はああぁ……私のボディ、隊長さんの精子でいっぱい汚されちゃったわ……\n！　まるで自分の所有物みたいな扱いをされて……あんんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0204406" ]},
		{"command":[ "SETIMAGE", "0", "still_00021202_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「こんなに気持ちのいい思いが出来るなら、ずっとメンテナンスしたい……？\n　できれば、専用機に欲しい……？　そ、それはダメよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0204407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「私は旅客輸送を目的に設計されてるの……隊長さんだけのモノになるなんて\n許されないわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0204408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「でも……隊長さんの専用機になれば、このメンテナンスをまたしてもらえる\nと思うと……心が揺らいじゃう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0204409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「もう……！　私をこんな切ない気持ちにさせるなんて、隊長さんは本当に悪\nい人だわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0204410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}