{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001703_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「レイジョーベビーの衣装でエッチをするなら、どんな感じでしたいって……\nな、なに言ってるんですか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0304101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「まったくもう……！　真面目な顔してるので、なにかあったのかと思って声\nをかけたのに……そんなことを考えていたなんて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0304102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「で、ですが、そうですね……仮の話ですけど、もしエッチをするなら……こ\nんな感じのエッチがいいかなって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0304103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「あっ……お、大きいのが、私のアソコに当たって……ふああぁ、あっ……ん\nはあぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0304104" ]},
		{"command":[ "SETIMAGE", "0", "still_00001703_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「そ、そんな……！　大きいのとか、アソコとか、そんな曖昧な言葉じゃなく\nて……どこに、なにが当たっているのか、ちゃんと言えだなんて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0304105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「この大きいのでなにをして欲しいのか言わないと……ずっとこのままなんで\nすか……？　そんなの、生殺しすぎます……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0304106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「やっ、ああぁんっ！　い、言います……！　ちゃんと言いますから、そんな\nに擦り付けないでください……！　おっぱい、揉まないでくださいぃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0304107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「はあ、はあ……あっ、んふっ……！　くっ、ああぁ……！　わ、私のオマン\nコに……大きなオチンチンが当たって、ズリズリ擦れてます……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0304108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「裏筋が……く、クリトリスに当たって、気持ちいいです……！　オマンコか\nら、エッチなお汁がどんどん溢れてきます……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0304109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「こんなの……我慢できません……！　エッチでいやらしい、レイジョーベビ\nーのオマンコに……お、大きなオチンチン……挿れて、ください……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0304110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「くああっ、ああっ、ああん！　あっ……んひっ、ふぎゅ、いっ、いあああぁ\n……！　あぐっ、うぅ、ひうううぅぅぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0304111" ]},
		{"command":[ "SETIMAGE", "0", "still_00001703_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「はあ……ああああっ……！　お、オチンチン……奥まで入ってます……！　\n私のオマンコ、いっぱい広げられて……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0304112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「ダメぇ……！　挿れられただけで、幸せな気持ちが溢れてきちゃいます……\n！　子宮が悦んでますぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0304113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「あっ、んんっ……！　ち、乳首も大きくなって……ああぁ！　こ、擦れて…\n…気持ちいいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0304114" ]},
		{"command":[ "SETIMAGE", "0", "still_00001703_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「やああぁ……！　おっきくなってる乳首、触らないでください……！　ビン\nカンになりすぎてて、イッちゃいそうになるからぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0304115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「淫乱なレイジョーベビーを、オチンチンで成敗するんですか……？　やっ、\n私……淫乱なんかじゃ……あひいぃぃぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0304116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「い、淫乱でいいですっ！　わ、私……レイジョーベビーは……エッチなこと\nが大好きです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0304117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「あなたの太くてカタいオチンチンで、オマンコをホジホジして欲しくてたま\nらない……いやらしい正義の淫乱ヒロインですぅ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0304118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「で、ですから……たくさん犯してください……！　あなたのオチンチンのこ\nと、もっと好きになるような……ドスケベヒロインにしてくださいぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0304119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「あっ、あっ……！　オチンチンが動いてる……！　カリの部分が、オマンコ\nのお肉を引っ掻いて……！　んっ、あっ！　うあああぁ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0304120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「んひゃうううぅんっ！？　いきなり、激しっ……！　あっ、あっ！　これ、\nすごいぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0304121" ]},
		{"command":[ "SETIMAGE", "0", "still_00001703_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「無理やり犯されてるみたいで、すごく気持ちいいっ……！　あっ、あああぁ\n！　オマンコ、ダメになっちゃいますぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0304122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「オマンコズポズポされると、感じちゃいますっ！　奥をズンズンってされる\nの、たまりませんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0304123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「あっ、やああぁ！　おっぱい弄られると、オマンコが勝手に締まっちゃうっ\n！　オチンチン、ギチギチに締め付けて……あああっ！　もっと感じるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0304124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「今までのセックスも気持ちよかったけど、こんなセックスも素敵ですっ！　\n本当に淫乱なヒロインになっちゃいますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0304125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「あっ、うひっ！　はひいいぃぃぃんっ！？　やああぁ、それ、ダメですっ！\n　子宮口を責めるの、ダメぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0304126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「子宮口の周りをトントンしながら、撫でまわさないでくださいっ！　か、感\nじすぎて怖いですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0304127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「やっ、んひゃっ！？　あふっ、んふううぅ！　正義のヒロインが守らないと\nいけない、一番大事なところ……赤ちゃんの部屋が開いちゃいますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0304128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「やあああぁ！　ダメっ、ダメぇ！　私の子宮口、精液欲しくてオチンチンに\n吸い付きたくなってるからぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0304129" ]},
		{"command":[ "SETIMAGE", "0", "still_00001703_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「あはああああぁ！　ひぐっ、あっ、んふうぅ！　こんな状態で膣内出しされ\nたら、妊娠しちゃいますっ！　妊娠ヒロインになっちゃいますぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0304130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「正義のヒロインなら、子供を産んで社会に貢献しろだなんてぇ……！　そ、\nそんなこと言われても……くひいいいぃん！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0304131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「やっ、あっ！？　オチンチン震えてる……！　ほ、本当に膣内出しする気な\nんですか……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0304132" ]},
		{"command":[ "SETIMAGE", "0", "still_00001703_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「ダメ……！　ダメぇ！　お腹大きくなったら、正義のヒロインができなくな\nっちゃいますっ！　レイジョーベビーじゃなくなっちゃいますぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0304133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「堕ちちゃうっ！　私のオマンコ、オチンチン大好きになって、淫乱ヒロイン\nにされちゃうぅ！　あっ、あっ！　やっ、ああああぁん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0304134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「ダメっ！　ダメぇ！　だ、出すならせめて膣外に……！　あっ、ああっああ\nあっ！　うぐっ、んくうううぅぅぅんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0304135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「ふあああぁ！？　あひっ、んふううぅ！　し、子宮の奥に精液流し込まれて\nますぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0304136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001703_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「温かいのがどんどん注ぎ込まれて……！　あひっ、おふっ……！　ダメなの\nに、気持ちいいですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0304137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「私のオマンコ、完全に堕ちちゃってる！　淫乱なヒロインの証、刻み込まれ\nてるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0304138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「あああぁ！　こんなに出されたら、イクの我慢できませんっ！　あっ、あっ\n！　イクッ、イッちゃいますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0304139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「来るっ！　来ちゃうぅ！　あっ、イクッ！　イクイクイクッ！　イクううう\nううぅぅぅぅぅん！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0304140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「はあ、はあ……ふふっ……こんなに穢されたら、もうゴレイジョーじゃいら\nれませんね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0304201" ]},
		{"command":[ "SETIMAGE", "0", "still_00001703_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「さっき言った通り……私、正義のヒロインじゃなくなっちゃいました……淫\n乱なヒロインになっちゃいました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0304202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「あ、あの……淫乱になったということは……え、エッチなことが大好きにな\nったので……その。出来れば、もう一回シて欲しいです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0304203" ]},
		{"command":[ "SETIMAGE", "0", "still_00001703_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「堕ちた正義のヒロインは……あ、あなたのオチンチンの虜になっちゃったワ\nケですから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0304204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「あっ……！　オチンチンが、また大きく膨らんで……んんっ！　は、はい…\n…好きに動いてください……また、いっぱい犯してください……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0304205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「ふあああぁ！　んふっ、ふぐううぅ！　イッたばかりだから、オマンコがビ\nンカンになってますっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0304206" ]},
		{"command":[ "SETIMAGE", "0", "still_00001703_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「やっ、あっ！　また強くおっぱい揉みながら、オチンチン出し入れされて…\n…！　んんっ！　こ、今度はＧスポットに当たってるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0304207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「こ、こんなの、もっと淫乱になっちゃいますっ！　セックスのことしか、考\nえられない身体にされちゃうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0304208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「やああぁ！　そんなことになったら、オチンチンのこと大好きになっちゃう\nっ！　オチンチンが入ってないと、不安になっちゃうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0304209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「そ、そんなのダメぇ！　いくらあなたのオチンチンの虜な淫乱なヒロインで\nも、そこまで堕ちるのはダメですぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0304210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「あああぁ！　ダメって言ってるのに、Ｇスポットグリグリしないでっ！　乳\n首グリグリしながら、オチンチンでビンカンなとこ虐めないでぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0304211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「突くなら、奥にしてくださいっ！　赤ちゃんの部屋の入り口を、トントンし\nてくださいぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0304212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「あーーーっ！？　あっ、あっ、んあっ！　ひああああぁん！？　な、なんで\nぇ！　子宮口とＧスポットを、交互にトントンするなんてぇ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0304213" ]},
		{"command":[ "SETIMAGE", "0", "still_00001703_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「確かに赤ちゃんの部屋の入り口って言いましたけど……！　そんな、二つの\n性感帯を責めて欲しいって意味じゃなくて……！　んふうううぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0304214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「ひぎっ、んぎいいいぃ！？　お、オマンコがまた勝手に締まって……！　お\n、オチンチン締め付けてます……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0304215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「ダメですっ！　ま、またイッちゃいますっ！　あああっ、イクッ！　イクぅ\nぅぅん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0304216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「やっ、やああぁ！　一人でイキたくないですっ！　イクなら一緒に……！　\n大好きなオチンチンと、一緒にイカせてくださいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0304217" ]},
		{"command":[ "SETIMAGE", "0", "still_00001703_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「ひぎゅっ！？　んっ、くふうぅん！？　オチンチンが暴れながら、膨らんで\n……！？　イッ、イッてくれるんですか……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0304218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「は、はい……！　また膣内でも……そ、膣外でもいいですっ！　淫乱ヒロイ\nンに、精液を恵んでくださいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0304219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「エッチなレイジョーベビーに、ザーメン出して……！　んむっ、あっ、あひ\nっ！　あうぅ、ああぁ、ああっあっあっ！　あああああぁんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0304220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「あっはあああああぁ！？　ま、また膣内に出されてますぅ！　熱くて濃いザ\nーメン、いっぱい……はひいいいぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0304301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001703_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「さっきの精子と合わせて、確実に妊娠しちゃっいますっ！　レイジョーベビ\nーが、本当の意味で子持ちになっちゃいますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0304302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「あうっ、あふうぅ！　で、でも……あなたとの子供なら、すごく嬉しいです\nっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0304303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「何人でも産みます……！　だから、もっと出して……！　たくさん孕ませて\nください……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0304304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「あっ、あっ！　気持ちいいっ！　イク、イクイクッ！　またイッ、イクぅぅ\nぅぅぅ～～～～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0304305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「はあ……はあああぁ……どうでしたか……私のレイジョーベビーの演技……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0304306" ]},
		{"command":[ "SETIMAGE", "0", "still_00001703_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「本当に正義のヒロインを犯してるような感じがして、気持ちよかった……？\n　ふふっ……それはよかったです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0304307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「いつもよりオチンチンも大きかったですし……たまには、こういうプレイも\n悪くないですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0304308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「あっ、でも……妊娠しそうなのは本当ですよ。だって、こんなに出されたら\n本当に赤ちゃん出来ちゃいそうですし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0304309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「レイジョーベビーだけに、ベビーが居てもおかしくないって……さすがにそ\nのギャグは、寒すぎる気がします……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0304310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「あううううぅ！？　オチンチンが抜けて……！　あっ、あっ！　やっ、ああ\nぁ……！　いっぱい、かかってますっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0304401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001703_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「膣内だけじゃなくて、膣外にもザーメンを塗りたくるなんて……！　私のこ\nとを、精液まみれのヒロインにしたいんですね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0304402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「いいですよ……！　もっと、いっぱいザーメン振り撒いてください……！　\nピンクの衣装を、真っ白にしてくださいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0304403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「あなたの精液なら、イヤじゃありませんから……！　淫乱ヒロインは、ザー\nメン大好きですから……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0304404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「私のこと……レイジョーベビーじゃなくて、レイジョーホワイトにしてくだ\nさい……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0304405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「んっ、あっ……本当に、たくさん精液出しましたね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0304406" ]},
		{"command":[ "SETIMAGE", "0", "still_00001703_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「あふっ、んふうぅ……！　もう……いつまでおっぱい弄るんですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0304407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「レイジョーホワイトになったら、母乳が出ると思って弄ってる……？　ぼ、\n母乳なんて出るワケないじゃないですか……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0304408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「で、でも……妊娠したら、出るようになりますよ……？　ですから、出来る\nなら……その。もう一度シませんか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0304409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「あっ……！　また、オチンチンが大きくなってきてます……！　はい……挿\nれたいなら、いつでも挿れていいですから……！　あああぁん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0304410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
