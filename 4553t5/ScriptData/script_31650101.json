{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016501_01_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「えへへー、センパイのチンポ、捕まえちゃったっスよー。はーい、頭のカメ\nさん、こんにちはーっス！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0103101" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「いやぁ……いよいよっスねぇ……結構前から、センパイのチンポ……こうし\nておっぱいでムニュってしたかったんですよねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0103102" ]},
		{"command":[ "SETIMAGE", "0", "still_00016501_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「えへへ……だって、噂になってますよ？　長さも硬さも申し分ないって、そ\nりゃあもう評判でー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0103103" ]},
		{"command":[ "SETIMAGE", "0", "still_00016501_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「どこ情報かって……へへ、残念ですけどそれはおおっぴらには言えないっス\nねぇ、オンナの秘密の一つってことで」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0103104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「それで、どうですか？　あーしのおっぱい、やらかくないっスか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0103105" ]},
		{"command":[ "SETIMAGE", "0", "still_00016501_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「一応、これでもぉ……大きさは悪くないと思うし、形も自分なりに気に入っ\nてるんですけどぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0103106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「ほら、やっぱし、このチンポさんがどれだけ喜んでくれるかってのが重要じ\nゃないスか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0103107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「そこんところ、どうかなーって……んふふっ、悪くない感じっスか？　へへ\nー、良かったぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0103108" ]},
		{"command":[ "SETIMAGE", "0", "still_00016501_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「まぁ、それなら、まだまだこんなものじゃないって、分かってもらえるよう\nにそろそろズリズリしちゃうっス……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……んふふっ……まずは、横からぎゅぎゅーっておっぱいプレス\n～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0103110" ]},
		{"command":[ "SETIMAGE", "0", "still_00016501_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「おっ、チンポがぷるんって顔だして来ましたねぇ、このままぁ、むにゅむに\nゅって……なかなかいいでしょー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0103111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「まだまだ、色々やってきますよぉ。今度は左と右のを……両方捕まえてぇ、\nはい、ずりゅずりゅ～ずりずり～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「んんっ……センパイのチンポ、めっちゃ熱くなってますね。あーしのおっぱ\nいにも、そのまま伝わって来てるっスよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「んっ、うんっ、んふっ……ほら、カメのとこぉ……ぐにって当たって……気\n持ちいいでしょぉ？　んっ、んふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0103114" ]},
		{"command":[ "SETIMAGE", "0", "still_00016501_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「分かりますよぉ、センパイの顔、マジ分かりやすいし……それにチンポも、\nぴくぴくしちゃって……かーわいいっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0103115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「やっぱり縦ズリが好きっスか？　んっ、ふっ……これ、あーしの方も……け\nっこーいい感じになるんスよねぇ……は、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「ほら、見て下さい、あーしのちくびっ。もう、結構コリコリしちゃってぇ、\nヤバい感じでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「えへへぇ……ここも、時々……ちょこんって、突っついたりしてぇ……あは\nっ、またチンポ跳ねてる、センパイのチンポ敏感過ぎぃー♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「でもぉ、こんなにプルプルしてるの見ると……色々ムラムラ来ちゃいますよ\nねぇ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「んっ、はぁ……やっぱ我慢出来なくなっちゃいますね……パイズリだけじゃ\n、もう……足りないっス……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「てことでぇ……んっ……れろっ、れろぉ……える、れる……れりょ、ぺちゃ\n、ちゅぱっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0103121" ]},
		{"command":[ "SETIMAGE", "0", "still_00016501_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「センパイチンポ……舐めちゃいまぁすー、ちゅぱっ、んちゅっ、あはっ、め\nっちゃピクピクしてるの、超かわいー♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「ぺろぺろされるの、いー感じっスかー？　へへー、あーしもセンパイのチン\nポ舐めるの楽しーっスよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「あっと、もちおっぱいの方もサボりませんよ～。ちゃんと、ぎゅーってして\n、いーっぱい、しこしこしてあげますから～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0103124" ]},
		{"command":[ "SETIMAGE", "0", "still_00016501_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「んふっ、ふんっ、んっ……あんっ……チンポ……さっきより硬くなってるぅ\n……おっぱいの中でむくむくっておっきくなるみたいな～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「ほらぁ、もうちょっと大人しくして下さいねぇ、れろ……ぺろっ、えろんっ\n……心配しなくても、やさしーくしますからぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0103126" ]},
		{"command":[ "SETIMAGE", "0", "still_00016501_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「れろぉ……んれろぉっ、れろっ、れろぉぉっ……んぁ……チンポの先から、\nじわって出てきまひたよぉ……んちゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「んふふーっ、これって我慢汁って奴ですよねぇ？　知ってますよぉー、チン\nポが感じてぇ……出したくなってる時のやつー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0103128" ]},
		{"command":[ "SETIMAGE", "0", "still_00016501_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「これが出たってことはぁ、もう一押しってトコですからぁ……うんっ、ふっ\n、んっ、うんっ……こーしてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「ずりずりって……おっぱいしたげたらぁ……ほぉら、気持ちいいー。センパ\nイの顔、分かりやすすぎ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0103130" ]},
		{"command":[ "SETIMAGE", "0", "still_00016501_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「いーっスよぉ、そのまま気持ちよくなっちゃってぇ……ぴゅっぴゅしましょ\n、ほぉらぁ……チンポぴゅっぴゅー♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「あーしのおっぱいご奉仕ぃ……んっ、もぉ我慢できないでしょぉ？　ぴちゃ\nっ、飲ませて下さいよぉ……ちゅぱっ、んちゅぅぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0103132" ]},
		{"command":[ "SETIMAGE", "0", "still_00016501_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「りゅぷっ……んっ、あーしのお口にぃっ、りゅぷっ、センパイの濃いのっ…\n…飲ませてっ、んちゅっ、りゅぷっ、んちゅうぅぅぅぅっーーーーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「んぁんっ！　んぁぷっ……れてまふっ……んぐっ、せんふぁいの……せーえ\nきっ……んぐっ、んふぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0103134" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016501_01_05" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「んくっ、こくんっ、ふごい……いっぱい……んく、こくっ、んくんっ……ん\nっ、ごくっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0103135" ]},
		{"command":[ "SETIMAGE", "0", "still_00016501_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「んぱっ……はふぅ……めっちゃ出たぁ……濃厚ミルク、たーっぷり頂いちゃ\nいましたよ……んちゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0103136" ]},
		{"command":[ "SETIMAGE", "0", "still_00016501_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「りゅぷっ……クセはあるけど……んっ、ちょっと慣れたら、かなりイケる味\nな感じっス！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0103137" ]},
		{"command":[ "SETIMAGE", "0", "still_00016501_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「あ、一応、きれーきれーにしないとっスよね。今やりますからねぇー、れろ\n、ちゅぱ……んちゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0103138" ]},
		{"command":[ "SETIMAGE", "0", "still_00016501_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「はーい、オッケーっス。へへー、あーしのごほーし、どーでしたか？　まぁ\nまぁイケてたっスか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0103139" ]},
		{"command":[ "SETIMAGE", "0", "still_00016501_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「また、その気になったらいつでも呼んで下さいっス！　あーしは、いつでも\n待ってますから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「って言うか～、フツーにチンポ、まだビンビンっスよねぇ？　これは、延長\n行っちゃいますか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0103201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「だって、ほら……ちゅぷっ……チンポも、もっとして欲しい～って、おねだ\nりしてますよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0103202" ]},
		{"command":[ "SETIMAGE", "0", "still_00016501_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「はいはい、分かってます。んっ、れろ……ぺろっ、れろぉ……んっ、先っぽ\nカメさんだけじゃなくて、チンポ全体がいいっスよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0103203" ]},
		{"command":[ "SETIMAGE", "0", "still_00016501_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「ちゅぷっ、ちゅぱっ、ぴちゃ……んちゅっ……ザーメンの味が結構残ってて\n……ちゅぱっ、味変してる感じっス……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0103204" ]},
		{"command":[ "SETIMAGE", "0", "still_00016501_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「ふふっ、いくらあーしが食いしん坊だからって、別にチンポ食べちゃったり\nはしませんよぉ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「でも、あぁん……かぷっ……んふふっ、ちょっとかみかみしちゃったりして\n……あんむ……アクセントになるれひょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「でもってぇ……これから、また本格的におっぱい攻めっス……むぎゅっとし\nてぇ……はーい、ぐりぐり～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「あはっ、ホント分かりやすく反応してくれて楽しいっスね。マジで、ごほー\nしのしがいがありますよ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0103208" ]},
		{"command":[ "SETIMAGE", "0", "still_00016501_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「ていうか……んっ、あーしも……おっぱい、気持ちよくてぇ……ほらぁ、乳\n首とかぁ……もう、こんなぁ……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「ねっ？　ツンツンしちゃってるでしょ？　チンポの敏感なとことぉ……くっ\nつけあってぇ……はひっ、今のヤバっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0103210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「んっ、ぴちゃ、ちゅぱっ……れろっ、んりゅぷっ……れろぉっ、チンポとお\nっぱいと……一緒に気持ちよくなってぇ……んかぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0103211" ]},
		{"command":[ "SETIMAGE", "0", "still_00016501_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「んふふーっ、歯が当たるとピクってするの、ちょーカワイイっス！　だいじ\nょーぶ、痛くしませんからー、あむ、はむ、かぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「ふふっ、チンポプルプルさせちゃってぇ……ちゅぷっ、れろ……あはぁっ、\nおっぱいの中で暴れてますよぉ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「これ、またヤバそうっスねぇ？　あーしのおっぱいプレスで、ドピュッとイ\nキたくなってますよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0103214" ]},
		{"command":[ "SETIMAGE", "0", "still_00016501_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「んふふぅっ、口数が減りましたよぉ？　このままやめちゃいますか～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0103215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「ふふっ、うっそー。ちゃんと……んっ、パイズリぃ……んふっ、ずりゅずり\nゅしますからぁ……はぁっ、んっ、ふっ、んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0103216" ]},
		{"command":[ "SETIMAGE", "0", "still_00016501_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、油断したチンポぉ……ちゅぷっ、また汁が滲んで来てますよ\nぉ……？　イキそっスねぇ？」", "NORMAL" ]},
