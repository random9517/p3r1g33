{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0101" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "襲来者" ]},
		{"command":[ "SETTEXT", "「ちっきしょぉ～！　覚えてろっ！　今度こそ、コントやるヒマもないぐらい\nコテンパンにしてやるからなぁ～～～っ！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「うるせー！　二度と来んなーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010114920001" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「お？　終わったか！　みんなご苦労だった！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010114920001" ]},
		{"command":[ "SETCHARA", "0", "char_00004999_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「って！　あんたなにもしてねーじゃねえかっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「しょうがないだろう？　私はリモート勤務なんだから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010114920002" ]},
		{"command":[ "SETCHARA", "0", "char_00004999_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そういう問題じゃねえだろ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「まあまあ、ご主人。そうとんがらずに」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010114920001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「もう一匹出てきたよ、安全にならねえと姿をあらわさねえヤツが！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ですから落ち着いて。どうですかな、長官。今回もいろいろありましたが、\nご主人も無事、職場に復帰されたということで――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010114920002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0116" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
		{"command":[ "SETNAME", "みんな" ]},
		{"command":[ "SETTEXT", "「かんぱーい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114920001" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "-700" ]},
		{"command":[ "SETCHARA", "1", "char_00000401_01", "8", "CENTER", "-300" ]},
		{"command":[ "SETCHARA", "2", "char_00000601_01", "8", "CENTER", "300" ]},
		{"command":[ "SETCHARA", "3", "char_00000101_01", "8", "CENTER", "700" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "DISPCHARA", "2", "TRUE" ]}, 
		{"command":[ "DISPCHARA", "3", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「また乾杯かよ……今日何回目の乾杯だよ。っていうか、どうせこうなるんじ\nゃないかと思ったんだよ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "この連中、なんか口実さえつけば飲み会になだれこむんだもんなぁ……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「はーい、お待たせ。揚げギョウザにハラス焼きにホルモン炒めな～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020114920001" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "DISPCHARA", "2", "FALSE" ]}, 
		{"command":[ "DISPCHARA", "3", "FALSE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「わーい！　ホルモン炒め大好き―！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010114920002" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あぁ！？　なんだいカツマぁ！　辛気臭い顔してぇ！　飲みが足りないんじ\nゃないのか？　飲みがぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010114920002" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「飲んでるよ！　飲んでるってば！　頼むからもうちょっと離れて――うわっ\n！　酒くせっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「なにがお酒くさいよぉ！　カツマちゃんだって、人のこと言えないでしょう\nにぃ！　ほら、もっと飲んで飲んでぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010114920002" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「っていうかなぁ！　カツマぁ！　貴様いったいどういうつもりだぁ！？　こ\nとあるごとに辞める辞めると言い出して――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114920002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「って、ちょっと待った姫様！　もしかして飲んでます！？　姫様、飲んでい\nいんだっけ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「なんだぁ！？　おちゃけなんか飲んでないぞぉ！　わらしはジュースしか飲\nんでなぁい！　あはははははははは！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114920003" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ホントかぁ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "sbg_0182" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「んんん？　だぁ～いじょうぶ！　ルナちゃん飲んでない！　私が保証する！\n　上司の言うこと疑うな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010114920003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「長官！？　あんた家にいるんじゃなかったの！？　風邪はどうした風邪は！\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「そんなもん、とっくに治ってんだよ！　飲み会っていうから駆けつけてきた\nんだ！　おーい！　ほむらたん！　冷酒おかわりー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010114920004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「治ってんなら戦闘中に駆けつけてくださいよ！　なんで飲み会のときにだけ\n……って、長官！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「なんだぁ？　飲みたいのか？　いいぞいいぞ！　ほら飲め！　わははははは\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010114920005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「違うそうじゃない！　あんた、自分のカッコよく見てみろ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「カッコ？　なんだよ。一部の隙も無い、バリバリのお仕事スタイルじゃない\nか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010114920006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「上半身はな！？　問題は下半身だよ！　下半身っ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0116" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「え……！？　うわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010114920003" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ちょ、ちょっと長官！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010114920002" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「うわあああ！？　長官、パンツいっちょじゃん！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010114920003" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ん？　ああ！　ホントだ！　いやぁ、リモート中は下半身見えないからな！\n　いつもこのカッコで仕事してたんだ！　わはははははははは！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010114920007" ]},
		{"command":[ "SETCHARA", "0", "char_00004905_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「わはははじゃねえよ！　そのまんまのカッコで外に出てくんな！　今すぐ帰\nって着替えて来なさいよ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「えー？　今から帰るのめんどくさーい！　っていうかぁ……カツマちゃんこ\nういうの嬉しいんでしょ？　嬉しいよなぁ！　がはははは！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010114920008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「こ、このセクハラ上司がっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「カツマ……嬉しいの？　そういう格好……好きなの！？　だったら私も……\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010114920002" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「って、カグヤなにしてんの！？　まずいまずい、それはまずいっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「カグヤぁっ！　抜け駆けは許さないわよ！　わたしだって……わたしだって\nぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010114920003" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「うわああああああ！　まりあ姉ちゃん服着てぇぇぇっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010114920004" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お……おまえらなぁっ！　いいかげんにしてくれーっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「そりゃこっちのセリフだ！　おまえら店ん中で大暴れしてんじゃねええええ\nええーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020114920002" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

