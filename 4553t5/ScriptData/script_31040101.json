{

	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
        {"command":[ "SETIMAGE", "0", "bg_0004" ]},
        {"command":[ "DISPIMAGE", "0", "true" ] },
        {"command":[ "FADEOUT", "NORMAL" ]},
        {"command":[ "PLAYBGM", "BGM_015" ]},
        {"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "虎之丞" ]},
		{"command":[ "SETTEXT", "「隊長どの、拙者に何か用事があるということでござるが……はて、一体何用\nでござるか？」", "NORMAL" ]},
        {"command":[ "DISPCHARA", "0", "TRUE" ]},
        {"command":[ "SETCHARA", "0", "char_00010401_01", "0", "CENTER", "0" ]},
        {"command":[ "PLAYVOICE", "v2_104_0103101" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "虎之丞" ]},
		{"command":[ "SETTEXT", "「ふむ……トレーニング？　鍛錬のことでござるか？　ふむ、羞恥心を刺激し\nて胆を練る……なるほど」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00010401_01", "0", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_104_0103102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "虎之丞" ]},
		{"command":[ "SETTEXT", "「時代が変われば、鍛錬法も変わるものでござろうな。よかろう、隊長殿、そ\nのトレーニングとやら、お願いいたす」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00010401_01", "6", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_104_0103103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "虎之丞" ]},
		{"command":[ "SETTEXT", "「それで──む？　股間をマッサージ……？　ああ、按摩のことでござるな。\nしかしなぜ股間を……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00010401_01", "0", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_104_0103104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "虎之丞" ]},
		{"command":[ "SETTEXT", "「ふむ、な、なるほど……それが『羞恥心で胆を練る』ということでござるか\n……承知いたした。それで？　如何ようにすればいいのでござる……？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00010401_01", "2", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_104_0103105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "虎之丞" ]},
		{"command":[ "SETTEXT", "「──ふむ、ふむふむ。なるほど……あ、足で……このようにして、刺激をす\nればよいのでござるな？」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00010401_01_01" ]},
		{"command":[ "PLAYVOICE", "v2_104_0103106" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "虎之丞" ]},
		{"command":[ "SETTEXT", "「いささか妙な感触でござるな……うむぅ、ぐにゃりとしていて、まるでコン\nニャクでも踏みつけたかのような……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_104_0103107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "虎之丞" ]},
		{"command":[ "SETTEXT", "「いや、柔らかいのは表面のみで、中は鉄の芯でも入っているかのように硬い\n……ううむ、不思議な感触……これが男性器……いや、ちんぽでござるか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_104_0103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "虎之丞" ]},
		{"command":[ "SETTEXT", "「ちんぽ……ちんぽ……はぁ、うむむ、口で唱えると、心がザワザワと揺れる\n……ちんぽ……はぁ、ふぅ……興奮してしまうでござる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_104_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "虎之丞" ]},
		{"command":[ "SETTEXT", "「そ、それで、このまま続けておればよいのでござるか？　え？　下履きを脱\nがす……こうでござるか──」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_104_0103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "虎之丞" ]},
		{"command":[ "SETTEXT", "「……ちんぽを、こうして生で触れるのは初めててござる……。ん？　見たこ\nとはあるのか……でござるか？　それはもちろんでござるよ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010401_01_02" ]},
		{"command":[ "PLAYVOICE", "v2_104_0103111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "虎之丞" ]},
		{"command":[ "SETTEXT", "「武芸の稽古をすると、どうしても殿方を混じって行うことになるでござる…\n…そうなると見たくもない時に見てしまうこともあるでござるよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_104_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "虎之丞" ]},
		{"command":[ "SETTEXT", "「まあ、見慣れてるというほどではござらぬが……ふむ、それにしても変な感\n触でござるな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_104_0103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "虎之丞" ]},
		{"command":[ "SETTEXT", "「ところで、隊長殿……一体どのようにすれば…………ふむ、足で挟んで扱け\nばよいのでござるか？　承知した……せぇの──」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_104_0103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "虎之丞" ]},
		{"command":[ "SETTEXT", "「ん……んん、なかなか上手に出来ぬものでござるな……はぁ、んふぅ……こ\nれは、結構大変でござる……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010401_01_01" ]},
		{"command":[ "PLAYVOICE", "v2_104_0103115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "虎之丞" ]},
		{"command":[ "SETTEXT", "「隊長殿は、こうされるのがお好みなのでござるか？　え？　ああ、そうそう\n、これは鍛錬の一つでござったな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_104_0103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "虎之丞" ]},
		{"command":[ "SETTEXT", "「しかし、なぜこのような鍛錬方法を？　ふむ？　拙者が恥ずかしがると思っ\nて……？　なるほど……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010401_01_02" ]},
		{"command":[ "PLAYVOICE", "v2_104_0103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "虎之丞" ]},
		{"command":[ "SETTEXT", "「たしかに少し恥ずかしいでござるが、悪霊と切った張ったし続けた拙者でご\nざる……殿方のイチモツなど物の数ではござらん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_104_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "虎之丞" ]},
		{"command":[ "SETTEXT", "「ま、まあ、隊長殿のモノともなれば、流石に無碍には扱えんでござるからな\n、少しだけ緊張しているんでござるよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_104_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "虎之丞" ]},
		{"command":[ "SETTEXT", "「まあ、そういうわけで……この鍛錬は失敗かもしれんでござるな……いやぁ\n、隊長殿はお喜びのご様子……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_104_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "虎之丞" ]},
		{"command":[ "SETTEXT", "「なぁに、照れたりせずともよろしかろう？　拙者は命を隊長殿に預けた身で\nござるからなぁ……こうした下のお世話ぐらいどうとも思わないでござる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_104_0103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "虎之丞" ]},
		{"command":[ "SETTEXT", "「むしろ、恥ずかしいのは隊長殿ではござらんか？　くふふ……女にモノを足\n蹴にされ、このようにカチカチにしておられる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_104_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "虎之丞" ]},
		{"command":[ "SETTEXT", "「ほーら、硬い……こんなに硬い……先程から、ずーっとビクビクし続けてい\nるでござるよ……？　なんだか可愛く思えてきたでござる」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010401_01_01" ]},
		{"command":[ "PLAYVOICE", "v2_104_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "虎之丞" ]},
		{"command":[ "SETTEXT", "「このまま続けると、射精するのでござろう？　拙者……おぼこでござるが…\n…多少、閨の営みについては乳母から聞いておりましてな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_104_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "虎之丞" ]},
		{"command":[ "SETTEXT", "「もっとも……足蹴にされて喜ぶ殿方など、初めて知ったでござるが……ふふ\nふ……それで、気持ちいいでござるか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_104_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "虎之丞" ]},
		{"command":[ "SETTEXT", "「ん？　んん？　なんでござる？　吐息で言葉が聞き取れないでござるよ……\nはぁ、ふう……ふふふ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010401_01_02" ]},
		{"command":[ "PLAYVOICE", "v2_104_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "虎之丞" ]},
		{"command":[ "SETTEXT", "「ん？　気持ちいい……？　おやおや、雌牛の如き、可愛らしい声でおっしゃ\nられると、何やらくすぐったく感じてしまいますなあ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_104_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "虎之丞" ]},
		{"command":[ "SETTEXT", "「はぁ……ふぅ、拙者、段々興に乗って参りましたでござる……もっと喜んで\nもらうといたそうぞ……ん、ん、はぁ……んんん……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_104_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "虎之丞" ]},
		{"command":[ "SETTEXT", "「はっ、はっ、はぁ……ふぅ……いかがでござるか？　拙者、侍ゆえ、武芸は\nしっかり修めておりまする……足さばきには些か自信がありましてな」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010401_01_01" ]},
		{"command":[ "PLAYVOICE", "v2_104_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "虎之丞" ]},
		{"command":[ "SETTEXT", "「ふぅ……んん、さあ、さあさあっ、もっと激しくさせていただきましょうぞ\n……はぁ、ふぅ……んっ、んん～～～……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_104_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "虎之丞" ]},
		{"command":[ "SETTEXT", "「ほう？　もう限界ですと？　はー……ふぅ……隊長殿、もう少し我慢をして\nいただきたいでござるなぁ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010401_01_02" ]},
		{"command":[ "PLAYVOICE", "v2_104_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "虎之丞" ]},
		{"command":[ "SETTEXT", "「なぜ？　さあ、意味などござらぬ……拙者がそう望んでおるから、でござる\nよ……ふぅ、ふぅ……ふふふ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_104_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "虎之丞" ]},
		{"command":[ "SETTEXT", "「え？　もう、無理？　粗相は関心いたしませぬなぁ……もう少し、もう少し\nの辛抱でござるよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_104_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "虎之丞" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……ふふふ、さあ、このままずーっと……まだ、まだですぞ…\n…その顔、はぁ……はぁ……たまらんでござる……っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_104_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "虎之丞" ]},
		{"command":[ "SETTEXT", "「あっ、ああ、隊長殿？　ちんぽが……根本からビクビクと……あっ、駄目…\n…ひっ、ひやああ……あぁぁぁぁあん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_104_0103135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "虎之丞" ]},
		{"command":[ "SETTEXT", "「はー……はー……こ、これが、精液……殿方の放つ、精の籠もった力水……\nほう、まるで粥の如き色合い……感触……」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010401_01_03" ]},
		{"command":[ "PLAYVOICE", "v2_104_0103136" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "虎之丞" ]},
		{"command":[ "SETTEXT", "「うう、酷い匂い……ですが、はぁ、はぁ……不思議と胸にしみる……くんく\nん……はぁ……はぁ……ああぁぁん……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010401_01_05" ]},
		{"command":[ "PLAYVOICE", "v2_104_0103137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "虎之丞" ]},
		{"command":[ "SETTEXT", "「はぁ……ふぅ、まだ溢れてるでござる……隊長殿……ぐふふ、たっぷり楽し\nんでくれたようでござるなぁ……？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010401_01_04" ]},
		{"command":[ "PLAYVOICE", "v2_104_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "虎之丞" ]},
		{"command":[ "SETTEXT", "「いえいえ、拙者の方はなんでもござらん。大した手間でもなし、この程度な\nら、いつでも拙者をお呼びつけいただいて結構でござる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_104_0103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "虎之丞" ]},
		{"command":[ "SETTEXT", "「子孫が世話になっておるようですからな、いつでもお相手を務めてしんぜよ\nう……しからば今宵はこれにて御免──」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_104_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "虎之丞" ]},
		{"command":[ "SETTEXT", "「……と思ったのでござるが、ふふふ、どうやらまだまだ続きをご所望の様子\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_104_0103201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "虎之丞" ]},
		{"command":[ "SETTEXT", "「ふふ、そうとぼける必要はござらん。拙者、こうしてちんぽを足蹴にする遊\n戯、少々気に入ってまいったでござる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_104_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "虎之丞" ]},
		{"command":[ "SETTEXT", "「もしお嫌でなければ、このまま、今一度精を搾らせていただいても構わぬで\nござるが……さて？　いかがなさいますかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_104_0103203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "虎之丞" ]},
		{"command":[ "SETTEXT", "「おやおや、そんなに吐息混じりの可愛らしい声をあげられては……さて、ど\nうしたものか図りかねますなぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_104_0103204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "虎之丞" ]},
		{"command":[ "SETTEXT", "「ふむ……ふむふむ、まだ精液の残滓がこんなに……ほら、おわかりになりま\nすか？　踏みつけるたびに、ジワリと溢れ出してまりますぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_104_0103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "虎之丞" ]},
		{"command":[ "SETTEXT", "「これはこれは……チンポとは面妖なものでござるなぁ……ふふふ……なんと\nも踏みつけがいがあるでござる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_104_0103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "虎之丞" ]},
		{"command":[ "SETTEXT", "「はぁ……つま先がドロドロでござる……ん、ふぅ……精液が、指の股に絡み\nついて……なんともいえぬ感触でござりますな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_104_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "虎之丞" ]},
		{"command":[ "SETTEXT", "「はぁ……ふぅ、ふふふ、ほれ、ほれほれ……気持ちいいでござるか？　え？\n　なんでござるか？　ほら、もっと大きな声で鳴くでござる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_104_0103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "虎之丞" ]},
		{"command":[ "SETTEXT", "「ふ、ふふふ……はぁ……ドキドキが治まらぬでござる……ああ、身体が熱い\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_104_0103209" ]},
		{"command":[ "SETIMAGE", "0", "still_00010401_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "虎之丞" ]},
		{"command":[ "SETTEXT", "「ふぅ、おぼこだというのに……おまたがジンワリと濡れているでござる……\nはぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_104_0103210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "虎之丞" ]},
		{"command":[ "SETTEXT", "「おっと、拙者の話など、どうでもいいでござるな……今一度、発射させるた\nめ、集中せねばならぬでござる……ん、ん、んん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_104_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "虎之丞" ]},
		{"command":[ "SETTEXT", "「あぁ、精液がベトベトして……チンポとつま先に絡みついて……ああ……い\nやらしい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_104_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "虎之丞" ]},
		{"command":[ "SETTEXT", "「ほら、おわかりになるでござるか？　チンポが……ああ、チンポがこんなに\n震えてる……はぁ、あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_104_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "虎之丞" ]},
		{"command":[ "SETTEXT", "「はぁ……隊長殿が、そのような顔をされては、拙者がいじめているようでは\nござらぬか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_104_0103214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "虎之丞" ]},
