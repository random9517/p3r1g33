	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「んーっ……いっぱい泳いでしまいました。プライベートビーチは優雅でとて\nもいいですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1004101" ]},
		{"command":[ "SETCHARA", "0", "char_00000510_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「海が苦手？　いいえ？　ウチは平気ですよ。どなたと勘違いしてるかは知り\nませんが……ええ、堪能させていただきました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1004102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「ふぅ……ひとまず身体を休めましょうか……んーっ……こうして寝そべるの\nは気持ちがいいです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1004103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「くくっ……どうしました？　なんだかそわそわと落ち着きがありませんね？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1004104" ]},
		{"command":[ "SETCHARA", "0", "char_00000510_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「ウチのお尻をジロジロと見て……なんだかとってもいやらしい視線を感じま\nすねぇ……これは、どういうことですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1004105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「くくっ……とぼけてもムダですよ。もうムラムラしてるのも全部わかってい\nるんですから……さぁ、観念してオチンポを出しやがれです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1004106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「ほら……もうビンビンに勃起してますね。んっ……しょっ、こうしてっ……\nんふっ……ぎゅっと……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1004107" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00000510_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「おやおや、どうしました？　ウチの足の指がそんなに気に入りましたか？　\nんっ、くくっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1004108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「そうでしたねぇ、このオチンポは足蹴にされるのが大好きな、マゾっ気のあ\nるオチンポでしたものねぇ。むぎゅっと……んふぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1004109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「んふ……ビキニがずらされてる所を見て……突っ込みたいって……訴えてる\nんでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1004110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「さて……どうしましょうね。このポーズでの足コキは……ちょっとコツがい\nりそうですが……んっ、ふっ、はっ、んしょっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1004111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「なんだかんだで……気持ちよくなってるじゃないですか。ウチのお尻がよく\n見えるからですか？　こんな荒っぽい動きでも感じるんですね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1004112" ]},
		{"command":[ "SETIMAGE", "0", "still_00000510_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「んっ、はっ、んくっ……ふふっ……ほら……こうしてシコシコされるの……\nいい気持ちなんでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1004113" ]},
		{"command":[ "SETIMAGE", "0", "still_00000510_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「くくっ……そんなにこくこく頷くなんて……本当に欲望に正直なオチンポで\nす」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1004114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「そうですね……んふっ……今日は気分もいいですし……特別に入れさせてあ\nげてもいいですよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1004115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「ええ……ウチも、今日はちょっとそんな気分なんです。ここは邪魔が入るこ\nともないでしょうし……このまま……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1004116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「あんっ、そんなに慌てなくても……すぐに気が変わったりはしませんよ。ち\nゃんと……あっ、えっ……ちょっ、そこは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1004117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「くひぃっ！？　まっ……待って下さいっ……違いますっ、そ、そこはっ……\nオマンコじゃなくてっ、おっ、お尻っ……！　あぉっ、おっ、おぉぉんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1004118" ]},
		{"command":[ "SETIMAGE", "0", "still_00000510_02_03" ]},
		{"command":[ "WAITINPUT" ]},


		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「だ、ダメですっ……！　お尻の穴になんてっ……許した覚えはっ、あっ、く\nぅぅぅんっ、あぁっ、入って来るっ、んくぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1004119" ]},
		{"command":[ "SETIMAGE", "0", "still_00000510_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「あっ、おぉぉぉぉぉ……奥ぅ……あぁ、オチンポが……ウチのお尻に……ぬ\nるんって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1004120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「あぁ……めり込むぅ……そんな、あくぅ……き、キツいのに……んんっ、ふ\nっ……滑って来るのが……あ……あぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1004121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「んくぅぅ……はぁ、はぁ……やってくれましたね……勝手な真似を……んっ\n、して……くれて……タダで済むと……思わな……あぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1004122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「あっ、あぁっ、んぁぁぁっ！　あひっ、はひぃっ、あっ、あぉぉぉっ、おっ\n、おぉぉぉぉぉんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1004123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「ダメですっ、あぁっ、こんなっ……あっ、オチンポ……激しくズボズボなん\nてっ……あひっ、あぁっ、でっ……出ちゃうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1004124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「んんっ……！　ち、違いますっ……今のは……漏れちゃうのかと……思った\nだけで……そういうことじゃ……うひぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1004125" ]},
		{"command":[ "SETIMAGE", "0", "still_00000510_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「はぁぁぁっ、お尻にっ……あぁっ、オチンポっ……こんな止まらないのっ…\n…ダメっ、はぁぁぁんっ、これ、ダメですっ、あへぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1004126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「あっ……あぁっ……あくぅっ……め、めくれるっ……内側のお肉がっ……引\nきずられてっ、オチンポっ……擦れてぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1004127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「はぁぁんっ、あっ、あぁぁぁっ、これ……らめっ、あぁっ、ダメなやつです\nっ……中からっ……おかしくなってっ、んひぃぃんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1004128" ]},
		{"command":[ "SETIMAGE", "0", "still_00000510_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「きっ、気持ちよくなってる訳じゃっ……あっ、あぁっ、違うっ……この感じ\nは違うのですっ……！　あぁっ、でもっ、はぁんっ、でもぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1004129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「はっ、あひっ、あぁぁっ……！　続けてされたらっ……気持ちよくなるっ…\n…お尻の穴がトロトロにされてっ……そ、それぇっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1004130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「はんっ、あっ、あぁっ……ダメ……お尻のお肉……揉み込まないで下さいっ\n……ウチの……お尻が……分からなくなるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1004131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「はひぃっ！　ペシペシもダメですっ！　あぁっ……熱いっ……オチンポが…\n…熱いのっ、くぅぅんっ……あ、おぉぉぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1004132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「嘘……こんなことって……あぁっ、お尻……気持ちいいっ……あぁっ、オチ\nンポが気持ちいいっ、はっ、ひぃんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1004133" ]},
		{"command":[ "SETIMAGE", "0", "still_00000510_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「あぁっ……あなたもっ……オチンポ出ちゃうんですかっ……？　あぁっ、中\nで震えてっ……こ、このまま……お尻にっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1004134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「はぁぁっ、そんなことされたらっ……ウチっ……あぁっ、イクっ……あっ、\nお尻でなんてっ……ダメなのにぃッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1004135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「んくぅっ……来ちゃうっ……来ちゃいますっ……！　精液っ……あっ、びゅ\nくってっ……あっ、んぁぁぁぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1004136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「くぅぅんっ！　あぁっ……イクっ……！　ひっ、イクのっ、あおぉぉぉぉっ\n、お尻……イキますぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1004137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「あぁぁ……中ぁ……どぷって……お尻にぃ……中に入って来るぅぅ……あ…\n…へぁぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1004138" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000510_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「熱い……あぁぁ……お尻の穴が蕩けるような……こんな、感覚ぅ……は……\nぁぁぁぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1004139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「んんっ……あぁ……射精……今、終わり……ましたか……？　はぁ……あふ\nぁっ……こんなに……なんてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1004140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……随分と……やりたい放題に……やってくれましたね……んっ\n、ウチのお尻を……好き放題に突いてくれたじゃないですか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1004201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「こんなにされたら……んっ、くぅ……お尻が疼いて……仕方ないじゃないで\nすか……責任……取ってくれますよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1004202" ]},
		{"command":[ "SETIMAGE", "0", "still_00000510_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「そんなの決まってます……んぁふっ！　そうです……もっと、お尻……んん\nっ……ズボズボ……してっ、下さいっ……あっ、あぉっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1004203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「はあぁぁ……あぁ……やっぱり太いっ……んんぅっ、お尻の穴のシワが……\nいっぱいに広げられて……いき、ますぅぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1004204" ]},
		{"command":[ "SETIMAGE", "0", "still_00000510_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「くぅぅぅっ……んぁぁ……オチンポの感触ぅ……あぁぁ……さっきより、ち\nゃんと感じますぅ……あぁ、ウチのお尻の穴……喜んでますぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1004205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「はぁぁ……んくっ、あぁ……もっと……オチンポ……押し込んで……んくぅ\nっ、あぁ……熱い……身体……火照って……たまらないです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1004206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「んぅぅぅ……あ、ふっ……汗が……浮いちゃう……んんっ、滲んで……あぁ\n、そんなに密着されたら……はぁぁ……あなたの熱も感じます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1004207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「くっ……んぅぅぅっ……！　お腹の中が引きずり出されるような……この感\nじ……くぅぅぅっ……肛門が熱くなって……ジンジン痺れてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1004208" ]},
		{"command":[ "SETIMAGE", "0", "still_00000510_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「あぁ……ゆ、ゆっくり出たり入ったりするだけで……引っ掛かる時の感じが\n……いいっ……お尻の穴が……吸い付いてしまうですっ……あ、あぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1004209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「は、はい……大丈夫です……もう少しっ、強く……激しく、してもぉ……オ\nチンポ……いっぱいめり込ませて下さい……あ、ひぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1004210" ]},
		{"command":[ "SETIMAGE", "0", "still_00000510_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「あっ、おぉぉっ、あぉぉぉっ！　あぁぁっ、グポグポって……い、いやら\nしい音っ……してっ、ますぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1004211" ]},
		{"command":[ "SETIMAGE", "0", "still_00000510_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「あひぉっ、おぉっ、あぁぁっ、お尻っ……燃えちゃうっ！　あぁっ、こんな\nのっ、感じすぎてぇっ……あっ、オマンコも濡れちゃいまひゅうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1004212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「うぁひぃっ！　あぁ……お尻……かき回されながらっ、オマンコも弄られる\nのっ……くぅぅんっ……変にっ……なるくらいっ、気持ちいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1004213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「そこっ、あぉっ、もっとして欲しいですっ！　あぁっ、お尻の奥からっ……\nズルって抜ける瞬間のとこぉっ、そっ、それぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1004214" ]},
		{"command":[ "SETIMAGE", "0", "still_00000510_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「はひっ、あっ、はぁぁぁんっ……そのままっ、何度も行ったり来たりさせて\nっ……くひぃっ……あ、くぅっ……んふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1004215" ]},
		{"command":[ "SETIMAGE", "0", "still_00000510_02_09" ]},
