		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「我々が目指すはあの時計台！　約束の地、バイキングはそこにある！　みよ\n！　あの日の差す方向を！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
