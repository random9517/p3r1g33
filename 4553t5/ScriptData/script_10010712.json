		{"command":[ "PLAYVOICE", "v2_003_010107120001" ]},
	{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「さあ、行くんだ！　その顔をあげて！　冷たい風に心を洗え！　ここから新\n天地を目指すんだ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
