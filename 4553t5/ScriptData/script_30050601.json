{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「それで？　こんなところに呼び出して、いったい何の用です？　いえ、言わ\nずともわかります。水泳の訓練をさせるつもりなのでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0603101" ]},
		{"command":[ "SETCHARA", "0", "char_00000506_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「え？　違う？　はぁ……じゃあ、なんのためウチに水着を着せてるんです？\n　泳がないならこの水着、もう脱いでしまいたいんですが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0603102" ]},
		{"command":[ "SETCHARA", "0", "char_00000506_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「……はぁ、いったいどういうつもりです？　つまらない用事なら、マジで怒\nりますよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0603103" ]},
		{"command":[ "SETCHARA", "0", "char_00000506_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「……ちょ、いきなりパンツを脱がないで下さい！　うぐっ……あ、あなた最\n初からそのつもりでウチに水着を……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0603104" ]},
		{"command":[ "SETCHARA", "0", "char_00000506_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「はぁ……呆れました。見上げた変態根性ですね……わかりました。気が済ん\nだら、もういい加減着替えさせて下さいよ──」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0603105" ]},
		{"command":[ "SETCHARA", "0", "char_00000506_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「……ふーん？　あなた、こういうことをしたかったんですか？　もっと痛く\nて、辛くて、汚らしいことをさせられるかと思ってたです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0603106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00000506_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「それって何、ですって？　しらばっくれるのは止めるですよ。ふふふ……あ\nいにく、ウチはそこまで簡単な女ではないのです。殘念でした」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0603107" ]},
		{"command":[ "SETIMAGE", "0", "still_00000506_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「……それにしても、おちんちんって、変な感触ですね。硬いようで、柔らか\nい……。それに……んん、少し臭います」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0603108" ]},
		{"command":[ "SETIMAGE", "0", "still_00000506_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「くんくん……ふぅ、イヤな匂い……すんすん……はふぅ……え？　嬉しそう\n、ですって？　嬉しいわけないじゃないですか。バカバカしい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0603109" ]},
		{"command":[ "SETIMAGE", "0", "still_00000506_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「それで？　どうなんです？　気持ちいいです？　ほらほら、ちゃんと言わな\nいと、止めてしまいますからね……ん、ふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0603110" ]},
		{"command":[ "SETIMAGE", "0", "still_00000506_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「はぁ？　恥ずかしがると思ってた？　何を今更……恥ずかしいに決まってる\nじゃありませんか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0603111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「泳ぎもしないのに、ずーっと水着姿でいさせられたんですよ？　毎日毎日、\n恥ずかしくて死にそうでしたよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0603112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「で？　ここまでウチを辱める理由はなんです？　言わないと……手を止めて\nしまいますよ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0603113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「はぁ……？　恥じらいでパワーアップ……？　あなた、何を言ってるんです\n？　わけがわからないです……まあ、でもこのまま続けるですよ、ふふふ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0603114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「だって近頃偉そうにしているくせに……今、ウチのシコシコで、すごく情け\nない顔してるです……ふふふ、すごくいい気分です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0603115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「ほ～ら、ほらほら……ここをこうするとどうです？　この先っちょの丸いと\nころ、気持ちいいでしょう……ほら、先っちょのくぼんだところ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0603116" ]},
		{"command":[ "SETIMAGE", "0", "still_00000506_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「うふふ、ビクンビクンしてる……近頃偉そうにしているくせに、情けないで\nす。昔のヘタレだったころを思い出しますね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0603117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「それにしても、本当に偉くなってしまったものです……ウチにこんな恰好を\n強要できるのは、陛下かあなたぐらいです」」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0603118" ]},
		{"command":[ "SETIMAGE", "0", "still_00000506_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「まあ、陛下はそんなこと、お命じにならないでしょうけど…………いえ、あ\nの御方なら、可能性がないわけでもないですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0603119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「……とまあ、そんなこと言ってる間に、おちんちんが苦しそうです。ほら、\nこんなに痙攣を繰り返して……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0603120" ]},
		{"command":[ "SETIMAGE", "0", "still_00000506_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「え？　もっと気持ちよくして欲しい？　生憎、こんなことウチ、初めてなの\nで、どうしていいのかわからないですね……でも、こんなのはどうです？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0603121" ]},
		{"command":[ "SETIMAGE", "0", "still_00000506_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「んちゅ、ぴちゃ……れろ、れろれろ……ほーら、男性も、乳首が感じるんで\nしょう？　ふふ……ちゅ、れろ、ぬちゅぴちゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0603122" ]},
		{"command":[ "SETIMAGE", "0", "still_00000506_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「え？　くすぐったいだけ……？　そんな掠れた声で言われても、説得力がな\nいですね……ふふ、れろ、れろん、んちゅ、ちゅちゅぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0603123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……ふふふ、ほーら、先っちょがヌルンヌルンしてきたですよ\n。ウチ、知ってるんです……これ、気持ちよくなった証拠なのでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0603124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「我慢汁……第一ちんぽ汁……そんな呼び方だったはずです……ほら、ん、は\nぁ……指の股までヌルヌルして来ました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0603125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「ああぁ、少し変な匂いがする……くんくん……うう、生臭いような、おしっ\nこ臭いような……はぁ、ふぅ……変な匂いです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0603126" ]},
		{"command":[ "SETIMAGE", "0", "still_00000506_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「ああ、頭がぼーっとする、です……ん、くぅ、はぁ……あふぅ…ちゅ、ちゅ\n、れろ、んんん……カプッ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0603127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「ふふ、歯を立てちゃいました……痛かったです？　へぇ、そんな風には見え\nませんね。それに、おちんちん、気持ちよさそうにしてるですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0603128" ]},
		{"command":[ "SETIMAGE", "0", "still_00000506_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「はぁ……んふぅ、ほらぁ、もう我慢の限界って感じです。射精をしたいんで\nしょう？　いいです……いつでも発射して下さい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0603129" ]},
		{"command":[ "SETIMAGE", "0", "still_00000506_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「ふふふ、れろ、れるれる、んちゅ、ずるる、んんん、カプッ……あはは、い\nい顔です……ほら、どうぞ、出すですよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0603130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「ひゃうぅぅ！？　あはぁ……すごいすごい……これが精液……うわぁ、ビュ\nルビュル噴き出してくるです……はぁ、あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0603131" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000506_01_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「んん、ヌルヌルして、トロトロして……生暖かい……それに、この匂い……\nくんくん……はへぇぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0603132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「酷い匂い……鼻がバカになってしまいそう……ん、んん、体に匂いが染み付\nいてくるようです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0603133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「うう、水着が汚れちゃう……ドロドロがこびりついて……ああう、もう、替\nえの水着、ちゃんと用意して下さいよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0603134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「あああ……まだ出る……いっぱい出る……はぁ、はぁ……匂いで窒息しちゃ\nうそう……くんくん……はへぇぇぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0603135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「はー……あふぅ……やっと、止まったです……ふぅ、ふぅ……こんなに出る\nとは思ってなかったですよ……ふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0603136" ]},
		{"command":[ "SETIMAGE", "0", "still_00000506_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「さて、と。満足したです？　え？　これからが本番……？　あんまり図に乗\nるなですよ……ふぅ……いったい何をさせるつもりですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0603137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「このまま続けてくれればいい……ですって？　まあ、それくらいなら別にや\nってあげてもいいですけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0603138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「でも、あまり長引いては困るですよ。明日も仕事ですからね……くんくん…\n…あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0603139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「匂いが、水着に染み付いてくる……くんくん……この匂い、水泳のプールを\n思い出します……あまり思い出したくありませんけどね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0603140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「さて、と……それじゃあ、もう一度シコシコしてあげます……ふふふ、精液\nが少し乾いて、ニチャニチャしてるです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0603201" ]},
		{"command":[ "SETIMAGE", "0", "still_00000506_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「ふふ、その顔……その表情……たまんないです……！　無意味に水着を着さ\nせられていた恨み、晴らしてやるです……はぁ、はぁ……ふふふ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0603202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「あはぁっ、おちんちん、硬ぁい……手の中でゴリゴリ音立ててる……はぁ、\nふぅ……ああ、この匂い……たまんないですぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0603203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「精液が、手だけじゃなく、空気の中に漂ってるみたいです……ああ、鼻だけ\nじゃなく、水着の繊維一本一本に絡みついてくる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0603204" ]},
		{"command":[ "SETIMAGE", "0", "still_00000506_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「今、おちんちん、ビクンビクンしてるです……手を上下に動かすたびに、更\nに大きく、硬くなってくるみたい……くんくん……すんすん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0603205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「はぁぁあん♪　臭い……臭いです……ウチにこんなものを嗅がせるだなんて\n……無意味に水着姿にさせるだなんて……許さないです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0603206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「ほら、ウチに嫌がらせしたこと、反省するですよ……さもないと、いっぱい\nいじめてあげますからね……はぁ、ふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0603207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「おちんちん、血管が浮かんで……うう、気持ち悪い……見た目も、触り心地\nも、匂いも最悪です……ふぅ……ふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0603208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「ふふ、息をするだけで、目眩がしそうです……体が、熱い……水着姿で良か\nったです。汗と精液でビチャビチャですからね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0603209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「ふぅ……はぁ……ほら、早く射精するです！　ふ、ふふふ……さっきよりも\n、もっと絞り出してあげるですよ……ふぅ、ふふふふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0603210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「え？　楽しそう？　ええ、楽しいです。最初、どうしてあなたとこんなこと\nをって思ったですよ……今も、少し疑問に感じています」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0603211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「けど……はぁ、ふぅ……あなたの、その情けない顔を見ていると、ん、んん\n……水着姿の恥ずかしさ、忘れられそう、です……ん、ふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0603212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「さあ、もっともっと気持ちよくするですよ……あなたの、そのアホ面、だん\nだん気に入ってきました……ふー……あはぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0603213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「ん？　乳首がビンビンになってるですよ……もう、さっきのアレ、気に入っ\nたみたいですね……いいでしょう。楽しませてあげるです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0603214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「れろ、んちゅ、ちゅ、れろれろ、にちゃぁ……はぁ、あはぁ……今、あなた\n、変な声あげたですね……ふふ、もっと声を上げていいんですよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0603215" ]},
		{"command":[ "SETIMAGE", "0", "still_00000506_01_09" ]},
		{"command":[ "WAITINPUT" ]},

