		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「……こうして……足を開けばいいのだな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0104101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「視線が向けられることは当然承知しているが……いざ、改めて経験すると…\n…これは……中々、だな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「だが、問題はない。お前のチンポがその気になる為に、私の身体……特にオ\nマンコを見たいというのなら、甘んじてその視線は受けるつもりだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0104103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「それで……問題はないか？　形状や、色など……興奮を阻害させるようなこ\nとにはなっていないか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0104104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「大丈夫か……ならば、いい……お前の気が済むまで、オマンコでも……おっ\nぱいでも……眺めて構わない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0104105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「……………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0104106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「だが、希望を言わせてもらうならば……ずっと、ではなく……そろそろ、始\nめて貰えると助かるのだが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0104107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「視線を受けているだけで……自律神経が乱れ、身体に熱がこもって行く……\nつまり、これは……恥ずかしい、のだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0104108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「そうだ、チンポをそのまま……一息に貫いて……私のオマンコをいっぱいに\nして、くれ……あ……んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0104109" ]},
		{"command":[ "SETIMAGE", "0", "still_00016301_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「……っくぅ……問題ない……多少の痛みなど、戦いの中では日常のこと……\nいや、痛みも……覚悟していたような感じでは、ない、な……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0104110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「まだ半分位……か……あぁ、大丈夫だ、そのまま沈み込ませて行くんだ……\nは……んんっ、あっ、ふっ……んんぅぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0104111" ]},
		{"command":[ "SETIMAGE", "0", "still_00016301_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「入った、か……？　はぁ……はぁ……んっ、あぁ、少しずつ、今の状態に対\n応してみせる……んっく……ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0104112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「はふぅ……チンポの方はどうだ。私のオマンコをちゃんと味わえるような状\n態か……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0104113" ]},
		{"command":[ "SETIMAGE", "0", "still_00016301_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「んっ……ふっ、まだ、私の身体に力が入っている……？　もっとリラックス\nか……自分では出来ているつもりだったが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0104114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「あ……ふっ、そうか……もっと全身に愛撫を加えると、ほぐれてくる……な\nらば、任せよう……んっ、く……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0104115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「やはり……地球の男は、この……おっぱいに目が行くのだな。あぁ、好きに\n触るがいい……んぅ、あ……はっ……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0104116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「ここは、確かに……不思議な気持ちになる……パイズリの時にも思ったが、\n乳首から身体に広がるむず痒い感覚は……心地いい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0104117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「だが、今はオマンコの方が大事ではないのか。んっ……感覚が連動する……\nなるほど、個々の刺激が共鳴して相乗効果を呼ぶと……あひぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0104118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「あっ……はっ、んぁっ、今……また、痺れが来た……んっくぅ……こ、この\n状態でチンポが出入りすると、言うのか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「いや、大丈夫だ……そのまま続けてくれ。オマンコを……もっと感じさせて\nくれ……はぁっ、んっ、うんっ、あぉっ、んくぅん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0104120" ]},
		{"command":[ "SETIMAGE", "0", "still_00016301_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「あっ、はっ、お前のチンポが……私のオマンコに……出たり、入ったりして\n、いる……っ、んふっ、うんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0104121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「手は……私の肌を撫で回し……指が……乳首をつまみ……転がし、あっ、ふ\nぁっ、あっ、んんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「すまない……声が出てしまう……んっ、あっ、いい……のか？　もっと、乱\nれた声を出す方が……興奮する、のか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0104123" ]},
		{"command":[ "SETIMAGE", "0", "still_00016301_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「分かった……あっ、では……出るままに、声を……だそう……はひっ！　あ\nっ、ひぁっ、あぉぉんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0104124" ]},
		{"command":[ "SETIMAGE", "0", "still_00016301_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「あぁっ……何だ、これは……あっ、ぉっ……声が出るとっ……身体が火照る\nっ……あっ、あぉっ、んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「だ、ダメだ……今、顔を……覗き込まないでくれっ……は、恥ずかしいっ…\n…！　あぁっ、この感じはっ……あっ、あぁぁーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「はっ、んんっ、んぁぁっ……か、かき混ぜられる度にっ……あっ、腰が……\n勝手にっ、跳ねっ……あっ、おぉぉんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0104127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「はひっ、これが……快感っ……んんっ、あぁっ、気持ちっ……いいっ……！\n　んっ、オマンコ気持ちいいっ……おひっ、オマンコいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「今までの……開発はっ……このっ、為にっ……あったのかっ……んぅんっ、\n生チンポっ……全然……違うっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「あぉっ、あっ、首筋をそんなに舐めてっ……腋もっ……ひっ、腹もっ……あ\nぁっ、身体中……そんなにっ……舐め回されてっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0104130" ]},
		{"command":[ "SETIMAGE", "0", "still_00016301_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「はぁぁっ、こんなっ……全身されてっ……はぅんっ、おぉっ……あっ、あぁ\nっ、オマンコっ……お、おかしくっ……なるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「んぁぁぁぁぁっ、はぁっ、チンポ……感じるっ、さっきよりもっ……あぁっ\n、速いっ、出し入れっ、あぉっ、も、もうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「あっ……これっ、イクのかっ？　私のオマンコっ……チンポでっ、い、イカ\nされるのかっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「あひぁっ、あっ、あぁっ、イクっ……もうすぐだっ、もうすぐオマンコがイ\nクっ！　私のオマンコがっ、お前のチンポでイカされるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「あっ、あぁぁぁっ、波が来るっ……あぉぉぉぉっ、イッ……くっ、イ……く\nぅぅぅぅぅぅぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0104135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016301_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「んぁぁぁぁっ！　何かっ……来ているっ……あっ、はぁっ……出てるっ……\nお、お前もっ……イッて……しゃ、射精……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0104136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「な……中にっ、あぁ……出されてっ……ひぁっ、あぁぁぁっ……そうだ……\n私は……中出し……されてるぅ……オマンコにぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0104137" ]},
		{"command":[ "SETIMAGE", "0", "still_00016301_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、はぁ、はぁ……はぁ……はぁ……あぁ……少しだけ落ち着い\nた……これは……堪らないな……ここまで、とは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0104138" ]},
		{"command":[ "SETIMAGE", "0", "still_00016301_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「オマンコの中が……ぐちゅりとしている……これが、精液……んっ、受精す\nる為の……子種か……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0104139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「これで私も妊娠するんだろうか……ふふ……それも悪くないかも知れんな…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「ん……？　どうした……妊娠したいなら……まだ、足りない……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0104201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「もっと精液があった方が確率は高まる……人の受精は、そういう仕組みにな\nっているのか？　あっ……んんっ、はっ、あっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0104202" ]},
		{"command":[ "SETIMAGE", "0", "still_00016301_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「さては……お前……単純にまだやり足りないという……それ、だけだな……\n？　あっ、んんっ、あくっ、あふっ、んふんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「それなら、それで……いい……望むところだ……もっと、私を……私のオマ\nンコを感じさせてくれ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0104204" ]},
		{"command":[ "SETIMAGE", "0", "still_00016301_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「お前の……この太いチンポを……いっぱい味わわせてくれ……はぁっ、あ、\nんぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0104205" ]},
		{"command":[ "SETIMAGE", "0", "still_00016301_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「あぁっ、はんっ、あっ、あぁっ、かき混ぜられるっ……精液が入ったオマン\nコがっ……チンポでっ……かき回されているっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0104206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「私の汁も……出ているのかっ……んぁっ、くぅんっ……あぁっ、汁が混ざり\nあって……こんな、音をっ……あっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「身体もっ……このように……重ね合わせるとっ……汗がっ……滲んで……溢\nれてっ……止まらないっ……はひっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「こんなにっ、なるっ……なんてぇっ……あぁっ、オマンコっ……熱いっ……\nとろける感触が……気持ち……いいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「んふっ……あっ、な、何だ……？　キ、キス？　口と口を……急に……あっ\n、んむっ、ちゅぷっ、あ、ふっ……んりゅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0104210" ]},
		{"command":[ "SETIMAGE", "0", "still_00016301_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「な、なぜだ……んんっ、こんな、ことでも……はぁっ、身体は……快感を覚\nえてしまうのか……は……んむ、りゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0104211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「んんっ！　あっ……キスしながら……腰っ、振るなんて……く、ひぃっ！　\nさっきより……感じるっ、ひっ、んひぃんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0104212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「んあぁっ、乳首もっ……わ、わき腹もぉっ……身体中っ……どこも、撫でら\nれてぇ……全部っ……全部気持ちいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0104213" ]},
		{"command":[ "SETIMAGE", "0", "still_00016301_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「はへぁっ、あぁっ、チンポっ……膨らんでいるっ……どうしてっ……まだ、\nこんなにっ……私の……オマンコが……そうさせている……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0104214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「そう、かっ……お前もっ……快感に包まれているんだなっ……それで、あぁ\nっ、そんな顔で……激しくっ……は、ひぁっ、あひっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0104215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「ダメだっ……このままされたらっ、私はもうっ……持たないっ……またイク\nっ、またオマンコイッてしまうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0104216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「んぁっ、お前もっ……もうすぐ……なのかっ？　ならっ、もう少しだけっ…\n…こらえてみせるっ、だからっ……同じタイミングでっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0104217" ]},
		{"command":[ "SETIMAGE", "0", "still_00016301_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「だがっ……なるべく早くっ……頼むっ！　もうっ、おっぱいもっ……オマン\nコもっ、気持ちよすぎてっ……何が……何だかっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0104218" ]},
		{"command":[ "SETIMAGE", "0", "still_00016301_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「はひぁっ、あぁっ……ダメだっ……イクっ……イッてしまうっ！　もっ、も\nうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0104219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「んぁっ、あぁぁぁぁぁぁーっ！　イクっ……ひぁぁんっ、オマンコっ……ま\nたイクぅぅぅぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0104220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「んぁぁぁぁぁぁっ！　あっ……中に出てるっ……また熱いの……どくどく…\n…中に出されてるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0104301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016301_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「凄まじいエネルギーが……身体の中に溶けていくような……はぁぁ……これ\nが……人間の奥底にある力の秘密なのか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「あぁ……満たされていく……この感触悪くない……ずっと、味わっていても\nいい位だ……はぁぁ……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0104303" ]},
		{"command":[ "SETIMAGE", "0", "still_00016301_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「それで……どれだけこの射精は続くんだ……？　まだ、緩やかに腰が動いた\nままだが……あと、もう少しだけ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0104304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「んっふ……！　あ……今、また出したな……分かるぞ……チンポが小さく震\nえて、射精した瞬間が認識できる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0104305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……終わったか。出し切ったようだな……あぁ……まだチンポ\nは抜かないでくれ。もう少し、チンポを味わっておきたいんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0104306" ]},
		{"command":[ "SETIMAGE", "0", "still_00016301_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「全く……稀有な経験だった。この体験は、私の中で必ず新たな力の源になる\nだろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0104307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「相手がお前だということも大きいのだろうな……ふむ、自分でも驚いている\n。出会う前にはまさかそんなことを思う日が来るとは夢にも思うまい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0104308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「だが、その変質に不快感はない。私は今の私の状態をありのままに受け入れ\n、それを前向きに昇華する意志がある」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「だから、またお前とはセックスしたいぞ。私のオマンコが欲しくなったら、\nまたいつでも呼びつけるがいい。むしろ私から求めるとしよう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「んぁぁぁぁぁぁっ！　身体にっ……あっ、精液がっ……はぁぁんっ……こん\nなに……んぁふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0104401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016301_02_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「身体の内側だけでなく……外皮までも……精液で浸すつもりなのか……んふ\nぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0104402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「あぁ……だが、このぬめりも心地良い……いつの間にか、私の身体は、お前\nにすっかり作り変えられてしまっていたのか……んぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0104403" ]},
		{"command":[ "SETIMAGE", "0", "still_00016301_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「んんっ！　あっ……顔にも精液が飛んで……んぷっ、あぁ……この匂い……\nちゅぷっ、これが私を狂わせるんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0104404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「ん……はぁ……はぁ……全部出したか……先に付着している分も私の肌にな\nすりつけてくれ……全身に染み込ませておきたいんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0104405" ]},
		{"command":[ "SETIMAGE", "0", "still_00016301_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「あぁ……チンポはもう抜けているのに……まだ、オマンコの中に残っている\nような感じがする……ここまで存在感があるとはな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0104406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「ちゅぷ……精液の味も濃い……んむ……ちゅぱ……これだけ濃厚ならば、着\n床していても何の不思議もないという訳だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0104407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「お前の子供を宿す可能性か……ふむ、まさか地球に来て、そのようなことを\n考える日が来るとは思いも寄らなかったな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0104408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「だが、その変質に不快感はない。私は今の私の状態をありのままに受け入れ\n、それを前向きに昇華する意志がある」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0104409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「だから、またお前とはセックスしたいぞ。私のオマンコが欲しくなったら、\nまたいつでも呼びつけるがいい。むしろ私から求めるとしよう」", "NORMAL" ]},
