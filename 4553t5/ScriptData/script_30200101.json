{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「ふむ。そなたの体験談は、中々に興味をそそられるものがあったのである。\n今後の参考にさせてもらうとしよう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0103101" ]},
		{"command":[ "SETCHARA", "0", "char_00002001_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「次は我の番だが……そうであるな。せっかくだから、少し変わったエッチを\nした話を聞かせてやろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0103102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「そなたも知っての通り、我は機械だ。それも身体の一部が機械なのではなく\n、全身が機械で出来ておる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0103103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「それ故に腕や足、頭を分離できたりするのである。はたから見れば、少々変\nな感じとは思うがな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0103104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「それで、以前に我が行ったエッチなのだが……頭や腕を分離させつつ、奉仕\nをするというものである」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0103105" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "sbg_0000" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「ふふふっ。機械の身体とはいえ、胸や皮膚の感触は人のモノと相違ないであ\nろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0103106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002001_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「人の身ではできぬ戯れである。存分に楽しむがよい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0103107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「なに？　パイズリぐらい、普通の人でもできると……？　無粋なことを言う\nものではないのである」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「確かに、人間であってもパイズリぐらいできよう。こうして……んっ、あっ\n……チンポをシゴくことなど、容易いのである」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「もっと言えば、身体をそなたに預ければ、パイズリをしながら舌で乳首を愛\n撫することもできるだろう……こんな風にな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「んっ、ちゅ……れろっ、ぴちゅ……くちゅ、ちゅぷ……気持ちよさそうであ\nるな。乳首がカタくなってきているのである」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0103111" ]},
		{"command":[ "SETIMAGE", "0", "still_00002001_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ、れりゅ、れろっ……話の続きだが、人間であれば身体を倒し、そ\nなたに身体を預けなければ、こうした行為はできないのである」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「だが、我の姿を見るといい……身体を倒すなど、無粋なことをしていないの\nだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0103113" ]},
		{"command":[ "SETIMAGE", "0", "still_00002001_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「さらに言えば、勃起に逆らうことなく、真っすぐにチンポを胸で挟み、思い\n切り左右から押し付けているであろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「この状態であれば、チンポはより強く胸の感触を味わえること間違いなしで\nある……現に、そなたのチンポはバキバキに勃起しているのである」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0103115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「ふふふっ。いくら否定してもムダであるぞ。我の生体スキャンから逃れるこ\nとなどできないのである……んっ、ちゅぱっ……れろっ、ちゅちゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0103116" ]},
		{"command":[ "SETIMAGE", "0", "still_00002001_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「んちゅ、ぐちゅ……ぬちゅ、にちゅるっ……チンポに負けないぐらい、乳首\nも大きくなってきているのである……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「どちらも熱くて……はああぁ……我の回路に、熱が伝わってくるのである…\n…そんなに我の胸と舌が気に入ったのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0103118" ]},
		{"command":[ "SETIMAGE", "0", "still_00002001_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「そんなに激しく頷かれると、変な気分になってくるのである……我に感情な\nど、ないはずなのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「それにこれは、我にチカラを授けてくれる礼なのだ……遠慮せずに、気持ち\nよくなるといいのである」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「ずちゅ、ちゅぷ……んっ、はぁ、んんっ……！　ちゅぱっ、れりゅ、じゅぷ\n……ちゅちゅ、くちゅ……ずちゅ、ぬちゅるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0103121" ]},
		{"command":[ "SETIMAGE", "0", "still_00002001_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「じゅるっ、んちゅ……チンポの先端から、エッチな汁が出てきているのであ\nる……我の胸の中で、いっぱい吹き出しているのがわかるのである」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「我は分離していても、感覚を共有しておる……そなたのチンポがどうなって\nいるかなど、見なくてもわかるのだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0103123" ]},
		{"command":[ "SETIMAGE", "0", "still_00002001_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「だから乳首を舌先でペロペロすると、チンポが強く反応して……何度もビク\nビクしているのも、手に取るようにわかるぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「ぐちゅ、ちゅぱっ……ふふふっ。また汁を吹き出したのである。この傘の部\n分をシコシコされるのが、気持ちいいのであるか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0103125" ]},
		{"command":[ "SETIMAGE", "0", "still_00002001_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「それならば、さらに強く胸を押し付けて……たくさん乳首を舐めるとするの\nである……くちゅ、れろっ……ちゅちゅ、ちゅぱっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「くちゅ、ずちゅ……ちゅるっ、ぬりゅっ……！　くっ、ああっ……！　我の\n谷間が、そなたの汁でベトベトになっているのである……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「イヤらしいニオイも漂ってきているのである……こんなに離れていても感じ\n取れるとは、相当濃いニオイであるな……くっ、んちゅうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「王である我の胸をエッチな汁で汚したのだ……お返しに、そなたの乳首も唾\n液でベトベトにしてやるのである……ちゅぱっ、ちゅちゅうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「ちゅるっ、ずちゅっ……！　んっ、れろれろっ……ちゅぱっ、じゅぱっ……\n！　舐められるだけでなく、吸われるのも好きなようであるな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「チンポをシコシコしながら吸い付くと、全身のビクビクが止まらないのであ\nる……んちゅっ、ずちゅ……！　ずぷっ、ちゅぽっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「れりゅ、くちゅ……ずぷっ、ちゅぱっ、ちゅるるっ……血液と意識が、下半\n身に集中しているのである……そろそろ、イキそうなのであるな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「思い切りチンポを胸で締め付ければ、射精を阻害することもできるのである\nが……それはいささか、酷というものであるな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0103133" ]},
		{"command":[ "SETIMAGE", "0", "still_00002001_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「んちゅ……ちゅぱっ、れりゅ、ぐちゅるぅ……よかろう。我の胸に出すこと\nを許す」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0103134" ]},
		{"command":[ "SETIMAGE", "0", "still_00002001_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「好きなだけ出すがいいのである……我の身体を、そなたのザーメンで汚すと\nよいのである……！　んっ、ちゅううぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0103135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002001_01_05" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「くっ、あああぁ……！　熱いザーメンが、たくさん降り注いでいるのである\n……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0103136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「ちゅ、じゅちゅ……！　んちゅ、れろちゅぷ……！　んっ、ちゅぱっ……射\n精している時に乳首を舐めると、もっと勢いが増してくるのである……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0103137" ]},
		{"command":[ "SETIMAGE", "0", "still_00002001_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「あっ、はあぁ、くあっ、んんっ……！　いっぱいシコシコして欲しいのであ\nるか……？　仕方のないヤツであるな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ！　んはぁ……！　こんなにも熱いザーメンをかけられたら、身\n体が熱を持ってしまうのである……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「オマンコの方まで熱が伝わってきて……へ、変な気分になるのである……！\n　あっ、あんんっ……！　ふあああぁん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「はぁ……あっ、はああぁ……不覚にも、ザーメンを浴びて軽くイッてしまっ\nたのである……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0103201" ]},
		{"command":[ "SETIMAGE", "0", "still_00002001_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「なんであるか、そのニヤニヤした顔は……別にそなたのザーメンで、気持ち\nよくなったわけではないのである」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「先ほどのは谷間の熱がオマンコに伝わって、生殖器が反応してしまっただけ\nである……人間の言葉で表すと、生理現象というヤツであるな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0103203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「どうやら信じていないようであるな……人間の分際で我を侮辱するとは、い\nい度胸である」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0103204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「そなたが犯した罪……チンポと乳首で、しっかりと支払ってもらうのである\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「くちゅ……ちゅぱっ、れりゅ……！　んちゅ、じゅるるっ……ちゅ、じゅる\nぅ……！　れろれろっ、ずりゅ……ちゅぱっ、ちゅちゅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0103206" ]},
		{"command":[ "SETIMAGE", "0", "still_00002001_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「ふふふっ。人間のチンポは、イッたばかりの状態で刺激されると、ものすご\nい快感を憶えるのであろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0103207" ]},
		{"command":[ "SETIMAGE", "0", "still_00002001_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「その上で、こうやって乳首を吸い上げてやれば……んっ、ちゅぱっ……ぢゅ\nちゅるぅ……！　気持ちいいのが止まらないといった様子であるな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0103208" ]},
		{"command":[ "SETIMAGE", "0", "still_00002001_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「今更謝っても遅いのである。これは我を侮辱した罰であり、二度とこのよう\nな過ちを犯さぬための教育である……くちゅ、んちゅ、じゅるるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「んっ……ちゅぷっ、ぬちゅ、ずりゅっ……！　チンポがビクビクと動いて、\n我の胸から抜け出そうとしているようであるな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0103210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「だが、ムダなことである……そなたのチンポは、我の手の中……いや、胸の\n中であるのだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0103211" ]},
		{"command":[ "SETIMAGE", "0", "still_00002001_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「故に、こうして胸の圧を強めれば、抜け出すことなど出来ぬのである……ん\nっ……あふっ……！　あ、あれ？　チンポが滑るであるな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「ぐっ、んんっ……ちゅ、じゅるっ……！　先ほどのザーメンのせいで、滑り\nがよくなっているようであるな……これでは、挟みづらいのである……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0103213" ]},
		{"command":[ "SETIMAGE", "0", "still_00002001_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「んっ、んううぅ……！　ヌルヌルしすぎて、シゴきづらいのである……あっ\n、んちゅ……ちゅぷっ、ずちゅうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0103214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
