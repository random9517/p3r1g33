{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「来てくれたか。済まなかったな……ライブの打ち上げの後で、大分疲れてい\nるだろうとは思ったのだが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1504101" ]},
		{"command":[ "SETCHARA", "0", "char_00000215_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「その、どうしても今日伝えておきたかったのだ。ライブが無事に成功したの\nは、今日までお前が特訓に付き合ってくれたからだと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1504102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「何もしていないなんて……そんなことはないっ。本当に感謝しているっ……\nその、それで、だな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1504103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「その感謝の気持ちを……どうか受け取って欲しいのだ。今日一日……色々と\n疲れただろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1504104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「せめてものお礼として……今日は、私の身体を使って……疲れを癒やしてく\nれ……そこのベッドに横になってもらえるか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1504105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……それでは……後ろ向きだが……これで失礼する……あぁ、も\nうチンポをバキバキにしているではないか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1504106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00000215_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「待っててくれ。今回は、私がリードするから……どうかリラックスして身を\n任せて欲しい……構わないか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1504107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「ありがとう……それでは、このまま入れさせてもらう……んっ、あぁぁっ、\nあふっ……あぁっ、チンポっ……入るぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1504108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「んんんんんっ……！　はぁぁぁぅっ……んっ、あぁぁ……一番深いところま\nでぇ……一息に入ってしまった……んくぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1504109" ]},
		{"command":[ "SETIMAGE", "0", "still_00000215_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「あぁ……こつんって……亀頭が子宮に当たって……あふっ、軽く……イった\nかも知れない……んっ、はぁ、あふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1504110" ]},
		{"command":[ "SETIMAGE", "0", "still_00000215_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「いや、大丈夫だ……ちゃんとご奉仕はできる……。どうか、私のオマンコを\n……存分に味わって欲しい……動かしていくからな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1504111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「ふっ……んむっ、うんっ、ふっ、んっ……くっ、はっ、あっ、んむっ……ん\nくぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1504112" ]},
		{"command":[ "SETIMAGE", "0", "still_00000215_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「済まないな……まだ、どうすればいいか……完全に把握している訳ではない\nのだ……だが、誠心誠意尽くすつもりだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1504113" ]},
		{"command":[ "SETIMAGE", "0", "still_00000215_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「とにかく……この勃起チンポに気持ちよくなってもらう……その為に、こう\nして……オマンコを締め上げていくっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1504114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「ふんっ、うんっ……！　大きく尻を振り、腰を後ろに突き出すことでっ……\nオマンコがチンポを咥えるところがよく見えるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1504115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「あぁ……尻の穴まで丸晒しにするのは恥ずかしい……だが、全てをさらけ出\nして尽くすことでっ……お前が気持ちよくなってくれるなら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1504116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「私は、恥を忍んで、このチンポを扱き上げるっ！　ズボズボ出し入れしてっ\n、オマンコご奉仕をしていくっ……んぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1504117" ]},
		{"command":[ "SETIMAGE", "0", "still_00000215_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「あっ、はぁんっ、あぁっ、そうだ……オマンコからどんどん汁が溢れ出して\nいるっ……お前の特訓で、すっかり濡れやすくなってしまった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1504118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「だが、このいやらしい音が……私を興奮させるっ……お前のチンポも喜んで\nくれるなら一石二鳥っ……言うことなしだっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1504119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「ふっ、んふっ、はぁんっ……どうだ……気持ちいいか？　私のオマンコ接待\n……楽しんで貰えているか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1504120" ]},
		{"command":[ "SETIMAGE", "0", "still_00000215_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「んっ、あぁっ……後ろから生々しい視線をずっと感じるっ……オマンコとチ\nンポがまぐわっているところを、じっと見られている……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1504121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「恥ずかしい……恥ずかしいに決まっているが……この視線を意識することも\nアイドルには重要なことっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1504122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「ぱっくり口を開けている……スケベオマンコを見て欲しい……お前になら…\n…何もかも見せてしまえるんだっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1504123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「あぁ……身体が火照るっ……たまらない……ここの、気持ちいい場所を……\nチンポのカリで引っ掻くように……んっ、ひっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1504124" ]},
		{"command":[ "SETIMAGE", "0", "still_00000215_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「くぅぅんっ！　あぁあ……オマンコが欲しがっているっ……あぉっ、もっと\nチンポを頬張ってっ……何度もズボズボしてしまうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1504125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「あぁぁ……ヌルヌル滑るのが気持ちいいっ……！　敏感な場所同士を押し付\nけてぇ……染み渡るこの快感っ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1504126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「んふぅ……ほら、ここだ……カリとヒダが……何度もキスしてぇ……じゅぷ\nっと汁が溢れ出してくるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1504127" ]},
		{"command":[ "SETIMAGE", "0", "still_00000215_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「ふっ、んふっ、はぁっ、あっ、あぁっ……ヘコヘコとみっともなく腰を振っ\nて、チンポを貪るこの姿っ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1504128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「あぁっ、ファンが見たらショックを受けて卒倒するような……浅ましいセッ\nクスが止まらないんだっ……んくぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1504129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「はぁっ、はひっ、んんっ、あぁっ……じわじわ……痺れて来た……修行の時\nと同じ……あぁっ、乳首もギチギチに硬くなっている……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1504130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「ふふっ……こちら側からだとよく分からないか……？　また、後で……じっ\nくり触る機会も作ってやる……今はチンポに集中してくれ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1504131" ]},
		{"command":[ "SETIMAGE", "0", "still_00000215_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「んんっ、あふっ……その、チンポの方も……そろそろ、んっ……余裕がなく\nなってきたようだな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1504132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「分かるさ……漏れて来る悩ましい鼻息……チンポの震え……敏感になったオ\nマンコも、変化を見逃さないでいる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1504133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……中出しがいいか……？　もちろんいいぞ……ならば、もっと\n激しくさせていくっ……ふっ、ふんっ、んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1504134" ]},
		{"command":[ "SETIMAGE", "0", "still_00000215_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「ふふっ……上擦った声がっ……心地いいっ！　さぁっ、遠慮はいらぬっ……\nお前の子種をっ……存分にオマンコの中に出すがいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1504135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「はぁんっ、あぁっ、私もイクッ……！　一緒に果てるからなっ……ぎゅっと\n絞り込んでっ……チンポっ……イケっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1504136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「んんんんんんんーーーーっ！　あぁっ……！　出てっ……来たっ……ドピュ\nって……中っ……いっぱい出てるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1504137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000215_02_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「あぉぉぉ……子宮に熱い感覚……届いてるっ……はぁぁ、これだぁ……中が\n一杯になる感じ……最高だ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1504138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「んっ、ふふ……本当に遠慮なく出してくれたな……いや、呆れている訳では\nない。期待に応えてくれたこと……嬉しく思うのだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1504139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「んんっ……あぁ、オマンコがいっぱいだ……メスとしての悦び……今、これ\n以上ないくらい実感している……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1504140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「ふふ……さて、満足したか……と聞きたいところだが、まだチンポが私のオ\nマンコの中でもっとしたいと訴えていることは明白だな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1504201" ]},
		{"command":[ "SETIMAGE", "0", "still_00000215_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「皆まで言わずともよい。私の感謝の気持ちは、一発出した位では終わらない\n……このまま抜かずの２回目……させてもらうぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1504202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「んっ……ふっ、たっぷりと出してもらって、ぐちゅぐちゅになったオマンコ\n……ここからが本気だからな……あっ、おっ、んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1504203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「はぁっ、んんっ、こうしてっ、尻を突き出しっ……ぺたんと腰を落とすっ…\n…んんっ、亀頭がヒダに食い込むのが……あぁっ、分かるぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1504204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「そのまま、また引き抜いて……ふんっ、んふんっ、あぁっ……イッたばかり\nのオマンコっ……感じるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1504205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「はっ、ふっ……んんっ、どうやらピストンも……やっとコツが掴めてきた…\n…下半身への力の入れ方も、分かって来たぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1504206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「はぁっ、んっ、どうだ……？　チンポがキュンと絞られる感じ……こういう\nのが好きなんじゃないか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1504207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「いいぞ……もっと味わってくれ……ふんっ、んくんっ、ふっ……んんっ、ズ\nボズボ出し入れしながらの締め付けっ……あっ、いいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1504208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「また視線が泳いでいるな……な……し、尻の穴のヒクつきを見ているっ……\n！？　力を入れると……キュンと窄まる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1504209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「ど、どこを見ているかと思えばっ……うぬぅっ、ウカツ……！　まだ、そん\nないやらしい視線をっ……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1504210" ]},
		{"command":[ "SETIMAGE", "0", "still_00000215_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「だ、だが……見るなとは言えぬっ……この羞恥も快感に変えてこそっ……ニ\nンジャアイドルっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1504211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「多少下品であろうともっ、いっぱいに尻を振りっ……いやらしくチンポを扱\nきっ……オマンコピストンを繰り返すっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1504212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「んんっ、あぁっ……！　はぁっ、改めて肛門への視線が熱いっ……！　ムズ\nムズしてっ……自然にヒクついてしまうのが分かるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1504213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「あっ、はぁんっ、あっ、あぁっ……！？　しかもっ……急に突き上げてっ…\n…も、もっとオマンコを貪りたいっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1504214" ]},
		{"command":[ "SETIMAGE", "0", "still_00000215_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「んふぅっ……こ、断れる道理もなしっ！　私のオマンコはお前のものだっ…\n…あぁっ、激しく突いてくれっ、あぉっ、おぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1504215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「すごっ、あひぁっ、すごいいっ！　太いチンポでっ……広げられるぅっ！　\nあくぅっ……本気チンポっ、奥に……届くぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1504216" ]},
		{"command":[ "SETIMAGE", "0", "still_00000215_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「はぁぁっ、あぁっ、これは、またすぐ達してしまうっ……！　お前のチンポ\nにオマンコ分からされてっ、イキ顔を晒してしまうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1504217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「あぁっ、んはぁっ、あひぁっ、お前もっ……また出るのかっ！？　あぁっ、\n射精……またすぐに出るんだなっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1504218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「ならばっ……そこまでは耐えるっ……！　一緒に達するまでっ……あと少し\nぃっ、はぁんっ、チンポ熱いっ……ズボズボ来るぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1504219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「まだかっ！？　あぁっ、出してっ……早く出してっ！　私と一緒にっ……あ\nぁっ、イッてくれぇぇっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1504220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「んぁぁぁぁぁぁぁーーっ！　出たっ……また、中出しっ……二発目ぇっ……\n子宮に直接ぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1504301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000215_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「はぁぁっ、なんて勢いだ……あぁぁ……イクッ！　また……中出しアクメっ\n……してしまってるぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1504302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「あぁぁぁ……オマンコがいい……精液が奥の奥まで染み込んで……身体……\n蕩けてしまいそうだ……んふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1504303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「んくぅ……あぁ、これは受精したんじゃないか……？　妊娠……お前の子を\n孕むのなら……悪くないかも知れんな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1504304" ]},
		{"command":[ "SETIMAGE", "0", "still_00000215_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「あっ、ふっ……言った傍から、また精液……出ている……あぁ……本気で孕\nませようとしているのか……？　あっ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1504305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「あぁ……射精……終わったか？　ふぅ……やっとチンポが落ち着いたようだ\nな……全く、本当にやんちゃなチンポだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1504306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「んっ……だが、これだけ出してくれて何よりだ。私の気持ちがちゃんと伝え\nられたようで、それが一番嬉しい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1504307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「今回のライブは成功だったが……まだまだ私自身、ニンジャアイドルとして\n足りないものが多いと自覚させられた」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1504308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「その、お前さえよかったら……また、私に色々と指導して欲しい。も、もち\nろん……タダでとは言わない。これからも、奉仕を約束する」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1504309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「私の身体を全て使って尽くすから……どうか、これからもよろしく頼む……\nな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1504310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「んあぁぁぁぁーーっ！　あぁっ……チンポ抜けてっ……お尻っ……背中にっ\n、精液……出てるぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1504401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000215_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「はぁぅんっ……私もイクッ……！　あぁっ、イッてるっ……！　オマンコ…\n…一緒にアクメしてるぅぅぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1504402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「んふぁぁ……ザーメンシャワー……今、私が全て独り占めしているんだ……\n全身気持ちよくて……幸せだ……あふぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1504403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……んっ、あぁ……やっと勢いが落ち着いてきた……身体中……\nすっかりドロドロにされてしまったぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1504404" ]},
		{"command":[ "SETIMAGE", "0", "still_00000215_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「んっ……このオスの臭いだ……こうやってマーキングされていると、私のメ\nスの本能が悦びに震えてしまう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1504405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「あぁ……満足してくれたか？　んふ……たっぷり射精してくれて嬉しいぞ…\n…私のご奉仕も満更でもなかったようだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1504406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「尻をじっくり眺めて楽しんだ……ま、またお前はそういう露骨な言い方を…\n…そうやって、私を惑わせようというのだろう……フン！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1504407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「だが、私としてもお前との修行のお陰で、アイドルニンジャとしてより上を\n目指すことができたと思っている」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1504408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「だから、その、何だ……ま、また、これからも……私に様々な指導をして欲\nしい……その、どんな試練でも受けるからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1504409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「ああ……私の身体を隅々まで味わうような……そんな試練を……心待ちにし\nているからな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1504410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}

