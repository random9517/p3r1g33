{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0101" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_011" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「来たか。突然の呼び出しで済まなかったな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021830001" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「呼び出しはいいんですけどね、これはまたどういうメンツで……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「確かに、今ひとつ脈絡を感じないところであるな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_010021830001" ]},
		{"command":[ "SETCHARA", "0", "char_00002001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「そうだねぇ、今は特に同じ作戦行動を取っている訳でもないし……どういう\nことだろうね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010021830001" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「百聞は一見にしかずだ。まずは、これを見てもらいたい。モニター、準備い\nいか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021830002" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "部下Ａ" ]},
		{"command":[ "SETTEXT", "「はい、カメラＡ、映し出します」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「これは、衛星カメラが捉えたある物体についての映像だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021830003" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0048" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ん……？　何だこりゃ……空を飛んでるのか……？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00021801_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「所属不明の機体だ。速度はさほどでもないが、真っ直ぐに学園の方に向かっ\nて来ている」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021830004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「機体ってことはメカなんですよね。しかし、何て形だよ……あれじゃまんま\nピラミッドじゃねぇか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0101" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「あ……あれは……も、もしかして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010021830002" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ん？　何だ、知ってるのかサイレーン？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「間違いない……あれは……ピラミドン！　まさか、実在していたの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010021830003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「ピラミドン？　何であるか、それは？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_010021830002" ]},
		{"command":[ "SETCHARA", "0", "char_00002001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「他でもない、キミの研究を進めていた時に見つけた情報だよ。マシンファラ\nオをサポートする為に作られたロボットさ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010021830004" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「我をサポートする……？　はて、あまり聞いたことがないが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_010021830003" ]},
		{"command":[ "SETCHARA", "0", "char_00002001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「知らないのも無理はない。残された古文書に記述はあったけど、実際に存在\nが確認出来たものはないからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010021830005" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「あくまでも存在が示唆されていた程度のもので、このボクでも実際に見るの\nは初めてさ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010021830006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ふむ……ドクターでも、詳しいことは分からないということか。まぁ、そう\nなるとやはり彼女達の力も必要になってくるか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021830005" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「えへへー、話は聞かせて貰ったっす！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010021830001" ]},
		{"command":[ "SETCHARA", "0", "char_00016501_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「えと……お話……聞いた」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_010021830001" ]},
		{"command":[ "SETCHARA", "0", "char_00008101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ん、あんたらは……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「うぃーっす、初めまして！　あーしはアーマーンって言います。どぞ、お見\n知りおきを！　でもってこっちが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010021830002" ]},
		{"command":[ "SETCHARA", "0", "char_00016501_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「え……えと……ぁ、ぁう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_010021830002" ]},
		{"command":[ "SETCHARA", "0", "char_00008101_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「いや、背中に隠れないで下さいよ、アヌビス様。ちゃんとご挨拶しましょ？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010021830003" ]},
		{"command":[ "SETCHARA", "0", "char_00016501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「ア……アヌビス……よろしく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_010021830003" ]},
		{"command":[ "SETCHARA", "0", "char_00008101_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「すいません、ウチの神様、ちょーっと人見知りでして」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010021830004" ]},
		{"command":[ "SETCHARA", "0", "char_00016501_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「彼女達は蓬莱仙女同盟に所属していて、我々ＥＤＯにも力を貸してくれてい\nるのだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021830006" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「はいです。そっちのお二人とは一応面識もあるんですけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010021830005" ]},
		{"command":[ "SETCHARA", "0", "char_00016501_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「そうだね、ちょこちょことね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010021830007" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「相変わらず、引っ込み思案のようであるな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_010021830004" ]},
		{"command":[ "SETCHARA", "0", "char_00002001_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「そ、そんなこと……ある、けど……アーマーンがいるから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_010021830004" ]},
		{"command":[ "SETCHARA", "0", "char_00008101_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「彼女達には、あれに多少の心当たりがあるらしくてな。ご足労頂いたという\n訳だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021830007" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「それで……？　結局の所、アイツらは何なんだ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「あの……えっと、ごにょごにょ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_010021830005" ]},
		{"command":[ "SETCHARA", "0", "char_00008101_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「はい、はい……つまりっすね、ピラミドンはハルカプトラさんと同じく、機\n械生命体による王国の管理・防衛を目的としたロボットっす」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010021830006" ]},
		{"command":[ "SETCHARA", "0", "char_00016501_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「……それでね、ごにょ……ごにょ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_010021830006" ]},
		{"command":[ "SETCHARA", "0", "char_00008101_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「もっと言うと、ハルカさんをサポートする為に作られた存在で、それこそ今\nのＳＰみたいに、側に付き添う感じのイメージっす」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010021830007" ]},
		{"command":[ "SETCHARA", "0", "char_00016501_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「ごにょ……ごにょ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_010021830007" ]},
		{"command":[ "SETCHARA", "0", "char_00008101_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「ふむふむ……で、多分ずっと休眠状態だったけど、何故か目覚めたから、本\n来の任務を果たそうとしてるんじゃないかと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010021830008" ]},
		{"command":[ "SETCHARA", "0", "char_00016501_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「本来の任務……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「えと……だから……むにゃむにゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_010021830008" ]},
		{"command":[ "SETCHARA", "0", "char_00008101_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「ほら、ハルカさんをサポートするって言ったでしょう？　だから、学園に向\nかうってより、ハルカさんのトコに来ようとしてるのかなーって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010021830009" ]},
		{"command":[ "SETCHARA", "0", "char_00016501_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「どうでもいいけど、何でお前が全部説明してるんだ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「いやー、アヌビス様って、ちょっとこういうの苦手っすから。あーしがやる\n方が分かりやすいかなーって。まあ、通訳みたいなもんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010021830010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「その……と、とっても……助かる……あ、ありがと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_010021830009" ]},
		{"command":[ "SETCHARA", "0", "char_00008101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ふむ……とにかく、あのロボットは学園を目指していると言うよりも、ハル\nカプトラ君を目指している可能性が高いと？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021830008" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「絶対かどうかは……で、でも……多分、そう……かも」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_010021830010" ]},
		{"command":[ "SETCHARA", "0", "char_00008101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「となると……まずは、それをはっきりさせないとならないようだな。ハルカ\nプトラ君、聞いていたな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021830009" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「うむ。おおよそのことは把握したのである」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_010021830005" ]},
		{"command":[ "SETCHARA", "0", "char_00002001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「実質、囮にしてしまうようなもので申し訳ないのだが……任務という形で、\n迎撃を任せていいだろうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021830010" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「どの道、我がターゲットであるならば、我が迎え撃つのが自然であろう。し\nかと任された」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_010021830006" ]},
		{"command":[ "SETCHARA", "0", "char_00002001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「それにしても……何だって今になって、ピラミドンは現れたんだろうね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010021830008" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「ふむ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_010021830007" ]},
		{"command":[ "SETCHARA", "0", "char_00002001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「流石に、目覚めさせるようなことに心当たりはないよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010021830009" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「心当たりも何も……そもそも、そいつの存在を今初めて知ったのであるが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_010021830008" ]},
		{"command":[ "SETCHARA", "0", "char_00002001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「だよねぇ……じゃあ、何かがあって目覚めたのか……そして、一体どういう\n目的で、こっちを目指してるのか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010021830010" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「…………えと、ごにょ」", "NORMAL" ]},
