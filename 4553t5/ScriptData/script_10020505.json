{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0000" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「令嬢戦隊ゴレイジョーＶＳアクレイジョー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_999_010113460001" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「ヒロインとその敵役の配役も無事決まり、明日からさっそく練習が始まろう\nとしている」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_999_010113460002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0121" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ま、どんな形であれ主役ができるんだからよかったわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020113460001" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「はぁ……なんで私が主役なんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020113460001" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「あたしも女幹部をやることになるなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020113460001" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ちょっとあなたたち、もっと堂々としたらどうなの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020113460002" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ヒロインの私と同じステージに立つんだから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020113460003" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「でも、劇の主役なんてやったことないから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020113460002" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「そもそも、演劇が初挑戦だよ。あー、まさか悪の女幹部なんて役になっちゃ\nうなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020113460002" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「でも、成績アップもかかってるし、みんなやる気みたいよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020113460004" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「美術担当の生徒たちなんか、さっそくでっかい発泡スチロールを用意してた\nし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020113460005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「な、なにするの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020113460003" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「きっとすっごいセットを用意するつもりじゃないかしら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020113460006" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「なるほどねー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020113460003" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「背景美術は素晴らしいが演者が未熟で見ていられない、なんて言われたら大\n変よ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020113460007" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「た、たしかに……。演技する私たちも頑張らないと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020113460004" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「あたしも役作りしないとかなー。女幹部か……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020113460004" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「女幹部ってどういう感じ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020113460005" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「組織の人たちを参考にしたら？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020113460008" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「そうですよ。すっごい人ばかりですし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020113460005" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「んー……。まあ、考えとく」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020113460006" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "sbg_0000" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "「一方、下校中のルルーナたち」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_999_010113460004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0160" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「まさか三人で変身ヒーローものの劇に参加できるなんてね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010113460001" ]},
		{"command":[ "SETCHARA", "0", "char_00001205_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「そ、そうね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113460001" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「うん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130113460001" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「……二人ともなんだか顔が赤いよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010113460002" ]},
		{"command":[ "SETCHARA", "0", "char_00001205_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「そ、そうかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130113460002" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「気のせいですわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113460002" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「でも、少しだけ気持ちは高ぶっています。ラストのことを考えると……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130113460003" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「あっ、カツマ先生とのキス？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010113460003" ]},
		{"command":[ "SETCHARA", "0", "char_00001205_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「王子役とのキスシーンがあるなんて、最近の演劇ってそういうものなのかし\nら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113460003" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「どうなんだろう。あ、でもキスについては任意だから、別にしなくてもいい\nんだよね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010113460004" ]},
		{"command":[ "SETCHARA", "0", "char_00001205_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「私はしますけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130113460004" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「流々那さん！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113460004" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「あはは、相変わらず流々那ちゃんは大胆だなー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010113460005" ]},
		{"command":[ "SETCHARA", "0", "char_00001205_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「ヒロインは横並びという体ですけど、最後のシーンでキスをするのは一人な\nんですよね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130113460005" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「そう考えると、投票で選ばれた人が真のヒロインってことかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010113460006" ]},
		{"command":[ "SETCHARA", "0", "char_00001205_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「真のヒロイン……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113460005" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "（私こそ真のヒロインにふさわしいに決まっているわ）", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113460006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "（……けど、それって下僕とキスをすることに！？）", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113460007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "（そうなるのは……でも、ステージの上で大勢の前でだなんて……）", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113460008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「ルルーナちゃーん、ぼーっとしちゃってるけどどうしたの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010113460007" ]},
		{"command":[ "SETCHARA", "0", "char_00001205_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「なんでもありませんわ。ちょ、ちょっと用事を思い出したので、ここで失礼\nします」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113460009" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「あ、うん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010113460008" ]},
		{"command":[ "SETCHARA", "0", "char_00001205_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「わたしたちはどうする？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010113460009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「一緒に台本の読み合わせでもしますか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130113460006" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「うん、そうしよう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010113460010" ]},
		{"command":[ "SETCHARA", "0", "char_00001205_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}