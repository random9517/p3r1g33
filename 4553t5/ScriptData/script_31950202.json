{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0041" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「隊・長・さぁん♪　こっちこっち。忙しいのにぃ、来てくれてありがとうね\nぇ～。今日はねぇ、お疲れのあなたに～……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0204101" ]},
		{"command":[ "SETCHARA", "0", "char_00019502_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「わたしとえっちな事が出来ちゃう権利をあげちゃいま～す♪　え？　どこで\nするのかって……それはねぇ……ついてきて？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0204102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「こ・こ♪　……なんのへんてつもない路地裏じゃないかって？　そうだよ？\n　ここでねぇ。あなたとど～～っしてもしたいことがあるの♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0204103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「いちゃいちゃのデートもいいけど、そんな事は他の子とでも出来るでしょ？\n　だから……わたしは、わたしにしかできない癒し方で迫っちゃう……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0204104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「んっふふふふ……♪　えっちな服を着て、えっちなダークエルフのおねーさ\nんが、えっちなことをさせてくれるのって良くない？　いいよねぇ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0204105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「おっぱい、ちゃんと掴めた？　握れそう？　えへへへ……。この服を見つけ\nた時にね、思ったの♪　こういうシチュエーションで、したいなぁ～って」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0204106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00019502_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「そう思いながらあなたの事を見てたら～……発情しちゃった。したくてした\nくてたまらなくなっちゃって。だから、少しだけわたしに付き合ってね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0204107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「あなたの手をおっぱいに誘導して、おちんちんはわたしのお股……。あ、ま\nだ挿れちゃだめだよ？　前戯として、今日は素股をしてほしいんだぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0204108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「んっ……。わたしの太もも、なかなか心地いいでしょお？　まずはわたしの\nプニプニお肉でぇ……おちんちんを包み込んであげるねぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0204109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「……あれ？　キョロキョロしてどうしたの？　あ、人が来ないか気になるの\nかな？　じゃあ……早くはじめよっか。このカチコチおちんちんをぉ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0204110" ]},
		{"command":[ "SETIMAGE", "0", "still_00019502_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「誰かが来るまでに、ふにゃふにゃになるまで気持ち良くしちゃいま～す♪　\nんっ……♪　そうだぁ、今日はすっごいおクスリも飲んできたんだよぉ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0204111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「ボニューデマクール……。気持ち良くなると、おっぱいからびゅーって母乳\nが出るおクスリ……。だから頑張って、わたしのおっぱい感じさせてね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0204112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「ん……んっ……ふふふ♪　レクチャーするまでもなく、本能でおっぱいをモ\nミモミしてくるねぇ♪　あぁっ、このスリルと背徳感……感じるぅ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0204113" ]},
		{"command":[ "SETIMAGE", "0", "still_00019502_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「お外でするのって本当に好き……♪　だってエルフだもん、風を……感じな\nがらえっちなことすると、すごくすごく感じるの……♪　んっ、んん～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0204114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「あなたのおちんちん……。上を向いてるから、おまんこにジャストフィット\nして、すっごくいいよ……♪　硬くて重くて、理想の形をしているしぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0204115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「は、ぁ……♪　あぁああ……♪　ンン、当たってるぅ……♪　私のアソコに\nあなたのがこすれて……すっごくすっごく気持ちいい……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0204116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「っえぇ……？　愛液でおちんちんがヌルヌルしちゃう？　ごめんねぇ……♪\n　もう待ちきれなくて、濡らしちゃってたぁ……。はぁっ♪　あぁ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0204117" ]},
		{"command":[ "SETIMAGE", "0", "still_00019502_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「ヌルヌルシロップいっぱい絡み付けてぇ……オマンコにおちんちんをぶつけ\nて、すりあわせて……。あっ♪　あっあっ、じれったくて感じちゃう……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0204118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「淫乱なダークエルフだ～って思ってるでしょ～？　そうなの……♪　わたし\n、痴女でビッチで淫乱なダークエルフなの……だから♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0204119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「おっぱい、潰れるくらいキツく揉んでほしいし……♪　あんっ♪　いやらし\nい手つきで撫でまわされたいし、おまんこだって刺激してほしい……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0204120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「っひゃぅうんっ……♪　乳首……！　乳首くにくにいじるの、それ……スゴ\nぉい……もっとして、もっとしてぇ……ちぎれるくらいぃ♪　あぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0204121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「んぁんんっ！　乳首から母乳っ……母乳溢れるぅ……♪　あっ……！　どう\nかなっ？　手……あったかい？　甘い匂いがするぅ？　あぁああっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0204122" ]},
		{"command":[ "SETIMAGE", "0", "still_00019502_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「どんどん溢れ出てきて止まらないよぉ……♪　あぁっ！　出す時すっごく気\n持ち、よくて……♪　乳牛さんみたいでエッチすぎるぅう……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0204123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「もっと……もっと揉んで、母乳搾り出して♪　母乳いっぱい出すからおちん\nちんも動かして……！　……んくぅううう♪　ひゅごい、ひゅごいぃ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0204124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「ダークエルフのお乳搾りながら……腰をヘコヘコさせるの気持ちいいでしょ\nぉ？　わたしも……わたしもすっごくいいもん、わかるよぉ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0204125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「あっあっ、もう……もうだめぇ。本当のエッチしたくなってきちゃったぁ…\n…♪　ね～ぇ、しよぉ？　本当のえっち……ここにおちんぽ入れるやつぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0204126" ]},
		{"command":[ "SETIMAGE", "0", "still_00019502_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「えへへ……おねだりしてほしいの？　いやらしい言葉でぇ、上手におねだり\n出来たら挿れてくれるぅ？　じゃあ……お願いしちゃおうかなぁ～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0204127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「お外で興奮して、ゴム無し生セックスをおねだりしちゃう淫乱ダークエルフ\nのわたしにぃ……その逞しくてふとぉいおちんちん入れてちょーだい……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0204128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「あなたのおちんちんが欲しくて、わたしのオマンコがキュンキュン疼いて止\nまらないの……♪　早くここに栓してぇ、どうしてもチンポ欲しいのぉ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0204129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「……あっ♪　おちんぽっ……！　おちんぽ入れてくれるのぉ！？　やったぁ\nあ♪　嬉し、い……！　ッあああああっ！　すごっ、すご……すごいぃい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0204130" ]},
		{"command":[ "SETIMAGE", "0", "still_00019502_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「トロトロのおまんこをかきわけて、スッゴい太いのが入ってきたぁあ……！\n　っああああっ♪　なにっ、おっきすぎ……壊れちゃう壊れちゃうぅ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0204131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「うん、わたしが挿入してって頼んだんだけどぉ……！　ああああっ♪　ここ\nまでおっきいのねじこまれたら、女の子はみんなびっくりしちゃう、よぉ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0204132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「……あっ♪　美味しすぎるゴツゴツのおちんぽ……♪　グルメなわたしです\nら降参しちゃいそうな……最高のオチンポをありがと、気持ちいい……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0204133" ]},
		{"command":[ "SETIMAGE", "0", "still_00019502_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「あは……♪　素股でお互いに高まってたからかなぁ？　挿入されただけでイ\nッちゃったぁ……♪　あなたもそうだよね、すぐ射精しちゃいそう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0204134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「うん、うん♪　イキたい時にイっちゃって、出したい時に出しちゃうのが一\n番気持ちいいとおもうよぉ～？　だから……すぐに出していいんだよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0204135" ]},
		{"command":[ "SETIMAGE", "0", "still_00019502_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「その後でまたすればいいんだから……。まずはびゅるびゅるして？　あッ♪\n　んんん……わたしのオマンコにご挨拶の射精して、お願いぃ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0204136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「あふぅうううっ♪　ふぅううん♪　くふぅううっ……ん～～～～～～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0204137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019502_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「一発目のお漏らし射精きたぁああ♪　あはっ、やっぱり我慢出来なかったん\nだぁ～♪　でもいいよぉ？　私もおんなじだもん……あんっ、あんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0204138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「射精されながら♪　中出しされながらずーっと細かくイッてるの♪　えへへ\nっ、わかるでしょ？　オマンコの中痙攣してうねってるでしょお？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0204139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「こうやってぇ……♪　イキ続けながらおちんちん絞って、少しでも多くの精\n子を絞り上げちゃうの……♪　あは、他のエルフには出来ない必殺技ぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0204140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「……ラケシスさんのオマンコに一度挿入しちゃったからには、タマタマがす\nっからかんになるまで絞り尽くしてあげちゃうんだから……♪　あぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0204201" ]},
		{"command":[ "SETIMAGE", "0", "still_00019502_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「たっぷり中に出てる……♪　んぅううう♪　あれぇ？　もしかして色々と溜\nまってたぁ？　ドップドプ入ってくるよ♪　中に……子宮にぃ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0204202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「んぉっ！？　んっ！？　あれっ……！　想像より多い、かもぉ……！？　あ\nッ♪　スゴいっ！　あなたの精子でお腹たぷたぷぅ……！　最高だよぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0204203" ]},
		{"command":[ "SETIMAGE", "0", "still_00019502_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「ふぁああ♪　あぁっ……あっ、あぁああ……！　お外で直接、子宮に種付け\nされるのってすっごい開放感……！　クセになる感覚ぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0204204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「ねぇ？　ねぇ？　このままもっとするよね？　挿入して、すぐに射精して、\nそれで終わりなんかじゃないよねぇ？　……全力で孕ませて……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0204205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「わたし、お尻ふりふりしてあなたを誘惑しちゃうからぁ……♪　種付けされ\nてすぐの、ザーメンまみれのおまんこをあなたのおちんちんで突いてほしい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0204206" ]},
		{"command":[ "SETIMAGE", "0", "still_00019502_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「突いて、突いて、突きまくって……あぁ♪　かきまわしてほしいのっ！　お\n願い……お願い、あなたのがいいの、あなたに犯してほしいのぉ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0204207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「ん……ぁ♪　あぁ……あぁあ♪　腰を使って……エッチなダンス踊るからぁ\n……♪　おちんちん、いっぱい締めて気持ち良くするからぁ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0204208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「にゅるにゅるうねってるわたしのおまんこ、おまんこズポズポして……♪　\n……っあっ！　そう、そんな感じ……で♪　激しくしていいよ……ぉ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0204209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「あんっ！　あンッ♪　力強いピストン、で……っ！　わたしのこと自分のも\nのにしてっ……自分の女にして、わたしのおまんこ犯してぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0204210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「はぁっ……あぁあ……あっ、あっ、あんっ……！　えへへっ……♪　だんだ\nんっ……、腰のリズムが合ってきたね……っ♪　気持ちいい……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0204211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「ずん、ずんっておちんちんが響いて……あっ♪　それをわたしのヒダヒダが\nきゅっ、きゅうって締めつけて……すっごく仲良くなってきたぁ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0204212" ]},
		{"command":[ "SETIMAGE", "0", "still_00019502_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「っあふ……♪　あぁあ～～～～♪　わたしっ、ほんっとうにあなたのおちん\nちんとエッチが好きぃ……♪　誰よりもなじんで、おまんこ気持ち良くて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0204213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「あたまっ……フワフワして……好きなだけおかしくなれちゃうぅ……♪　あ\nんっ、あんっ……もう腰だって止められない、イクのだってやめられないっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0204214" ]},
		{"command":[ "SETIMAGE", "0", "still_00019502_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「ずちゅずちゅ突かれれば突かれるほど……あぅぁあんんっ♪　あなたじゃな\nきゃだめになっちゃう！　オマンコも、おっぱい、もぉ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0204215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「あなたじゃなきゃ感じないのっ……！　あぁっ、あぁあっ……！　わたしの\n母乳、わたしのおまんこ……全部独占して、狂うくらい使ってっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0204216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「どんなプレイでもしてあげられるしっ……あぅっ♪　なんだってＯＫだよぉ\n……！　……あっ♪　そ、想像だけでまたイッちゃったぁ、ごめんねぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0204217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「もうっ……イキすぎて全身ガクガクだよぉ……♪　あなた、はどうしたい？\n　次もわたしのオマンコに出す……？　それとも……、きゃっ！？　あっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0204218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「今っ♪　一番イイところ突き上げられちゃったぁ♪　あっ♪　そこっ、一番\n奥ぅ……そこ突かれると弱いの、溶けちゃう、頭溶けちゃうよぉ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0204219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「好きなところ……に出していいから、だから……！　あと１回だけっ、１回\nだけわたしもイかせてね……♪　あっ、クるぅ……今イクよぉ……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0204220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「あっあぁあああっ♪　あああぁっ、あふぁああああぁ……♪　やっぱりおま\nんこ、おまんこに射精、射精……！　中出しするのが好きなんだ……ぁあ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0204301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019502_02_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「わたしも、わたしもオマンコに注入されるのが一番好きぃ……い♪　あっ♪\n　見て……うれしすぎて、また母乳っ……母乳いっぱい噴き出しちゃう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0204302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「はぁうううううう～～～♪　あぅううう、んはぁあああああ……♪　ビュル\nビュル母乳っ……母乳出しながら精液ドクドク注がれて……絶頂……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0204303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「こんな幸せなこと他にないよぉ！　あぁああんっ♪　声っ……声、おっきい\n？　でも……でも我慢できない、喘ぎ声我慢できないのぉお……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0204304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「誰かに聞こえちゃっても、見られちゃってもい、い……♪　それくらい気持\nちいいの、あなたのおちんちん……種付け、射精、全部最高ぉ……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0204305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「んっあぁ、あっ、あぁっ……ああ……！　全部出しきるまで……絞り取るよ\nぉ♪　こうかなぁ……こう？　ぎゅぅううう……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0204306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「わぁ……♪　あなたが一番奥に注いでくれた精液が、わたしのおっぱいから\nぴゅーっぴゅーって溢れ出してくるみたい……♪　すごぉいぃ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0204307" ]},
		{"command":[ "SETIMAGE", "0", "still_00019502_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「これっ……、身体の中でエッチな液体が循環してるみたいで……新感覚、か\nもぉ……。ボニューデマクール……試して良かったぁ、気持ち良くて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0204308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「その上、見た目もこんなにエッチで……気にいっちゃった♪　ねぇ……あな\nたはどうだったぁ？　母乳ありとなし、どっちが好きぃ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0204309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「その返答によっては～……また、使っちゃうかも♪　このおクスリ……♪　\n病みつきになっちゃったらどーしよー♪　困っちゃうよねぇ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0204310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「あぁああああああぁん……！　って、あ、あれっ……？　アレッ……？　い\nいのっ？　膣内じゃなくて……ぶっかけでっ……あぁああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0204401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019502_02_16" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「わたしの母乳がダラダラのところにぃ、更に精液ぶっかけちゃうなんてすご\nすぎない～！？　ふぁああぁ♪　こんなの、こんなのはじめて♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0204402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「もうわたしの身体……どこもかしこも真～っ白で卑猥すぎ……♪　きゃぅん\nっ♪　ウソみたいな量がドパドパかかってるっ……あったかぁい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0204403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「それにこのニオイ……♪　わたしのだぁい好きな臭い……♪　あなたの精子\nって、女を狂わせるいやらしいニオイなの……だから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0204404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「こうやって浴びちゃうとぉ……全身にそのニオイが染みつくような気がして\n、すっごく満たされた気持ちになっちゃう……ふふふっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0204405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「んふふふ……♪　ここまで淫らなことになっちゃったらぁ～……絶対バレち\nゃうね？　色んなヒ・ト・に♪　だぁってそうでしょう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0204406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「こいつら路地裏で、本気の生ハメしまくってたんだ～って誰だってわかるよ\nぉ。わたし、あなたの精液まみれだし……母乳も全然止まらないし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0204407" ]},
		{"command":[ "SETIMAGE", "0", "still_00019502_02_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「……え？　そういう状況にわたしがトキメいてるみたいだって？　……せ～\nいかい♪　そうだよ、今までで一番興奮してる……。クラクラしてる♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0204408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「路地裏を出て……人通りの多い場所に出たら、わたしたち……どんな風にジ\nロジロ見られちゃうんだろって想像したら……。あっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0204409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「感じちゃうねぇ？　楽しみだねぇ？　……えぇ？　ダメかなぁ……２人でだ\nったら、きっと楽しいよぉ♪」", "NORMAL" ]},
