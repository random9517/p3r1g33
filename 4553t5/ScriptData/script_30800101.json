		{"command":[ "SETIMAGE", "0", "still_00008001_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "080_0103116" ]},		{"command":[ "SETNAME", "ヴィシュヌ" ]},		{"command":[ "SETTEXT", "「ふふ、ふふふふ……。ほら……お胸の中におちんちんがズッポリ埋まってし\nまいましたよ？　苦ちいでちゅか？　狭くて暗いでちゅねえ……？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00008001_01_02" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "080_0103117" ]},		{"command":[ "SETNAME", "ヴィシュヌ" ]},		{"command":[ "SETTEXT", "「怖くなっても逃がしませんよ。貴方は今から、私の……ヴィシュヌのおもち\nゃです。動き、反応する肉の棒のオモチャ……ふふふふっ」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "080_0103118" ]},		{"command":[ "SETNAME", "ヴィシュヌ" ]},		{"command":[ "SETTEXT", "「んっ、んっ、んっんっ……あは……♪　精一杯先っちょ出して、可愛いです\nねぇ……。でも、私の方が上手ですよぉ……そぉーーれ……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "080_0103119" ]},		{"command":[ "SETNAME", "ヴィシュヌ" ]},		{"command":[ "SETTEXT", "「おっぱいで押し潰してあげる。だらしない、柔らかい、しっとりした私の胸\n肉で圧迫して、ぎゅーってイジワルしてあげる……♪」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "080_0103120" ]},		{"command":[ "SETNAME", "ヴィシュヌ" ]},		{"command":[ "SETTEXT", "「あっ♪　んっ、んっ、んっんっ……♪　あは……苛められるのがいいのです\nか？　私がおちんちんにイタズラすると……必死に硬くなって……んっ」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "080_0103121" ]},		{"command":[ "SETNAME", "ヴィシュヌ" ]},		{"command":[ "SETTEXT", "「なんといじらしいのかしら……。あっ♪　貴方が私のおっぱいに敵うわけが\nないでしょう？　残念でしたねぇ……。ほぉーら♪　ほぉーら♪」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "080_0103122" ]},		{"command":[ "SETNAME", "ヴィシュヌ" ]},		{"command":[ "SETTEXT", "「おっぱいのお肉が隊長さまのスケベなおちんぽを、正しい道に導いてあげま\nしょうねぇ……♪　ふふ、女の子の胸を見るだけで勃起するような……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00008001_01_03" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "080_0103123" ]},		{"command":[ "SETNAME", "ヴィシュヌ" ]},		{"command":[ "SETTEXT", "「変態おちんちんを矯正してぇ……。私のおっぱいにだけ反応する、淫乱おち\nんちんに改造してあげます……。あはっ、ふふ、ふふふ……♪」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "080_0103124" ]},		{"command":[ "SETNAME", "ヴィシュヌ" ]},		{"command":[ "SETTEXT", "「よーちよち……気持ちいいねぇ？　神おっぱいにズリズリされて、おちんち\nんめちゃくちゃに揉まれるので感じますよねぇ……？」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "080_0103125" ]},		{"command":[ "SETNAME", "ヴィシュヌ" ]},		{"command":[ "SETTEXT", "「んっ、ぁ、は、あはは……♪　まだ少ししかこすってないのに、もうイキそ\nうなんですか？　早漏なんですか？　ふふ、いつもはこんなんじゃない？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00008001_01_01" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "080_0103126" ]},		{"command":[ "SETNAME", "ヴィシュヌ" ]},		{"command":[ "SETTEXT", "「本当かなぁ～？　でも、ね……。簡単にはイカせてあげませんよぉ……。隊\n長さまは、私のおっぱいで……あっ♪　もみくちゃにされながら……っ♪」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "080_0103127" ]},		{"command":[ "SETNAME", "ヴィシュヌ" ]},		{"command":[ "SETTEXT", "「イキたいのにイケなくって悶えるんです。ね？　ね？　ねぇ？　苦ちいです\nよねぇ……精子ぴゅっぴゅしたいのに、出来なくて辛いですよねぇ……♪」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "080_0103128" ]},		{"command":[ "SETNAME", "ヴィシュヌ" ]},		{"command":[ "SETTEXT", "「いっちばん感じるところを、刺激して、刺激して、刺激して……最高潮に高\nまったところで根本を……あん♪　こうしてギューっと抑えてぇ……♪」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00008001_01_02" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "080_0103129" ]},		{"command":[ "SETNAME", "ヴィシュヌ" ]},		{"command":[ "SETTEXT", "「射精寸前のギリギリのところで焦らして焦らして焦らして……狂っちゃうま\nでムニュムニュしてあげる♪　ん♪　んん♪　いいんですよ♪」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "080_0103130" ]},		{"command":[ "SETNAME", "ヴィシュヌ" ]},		{"command":[ "SETTEXT", "「先走りのお汁、私のお胸に垂れ流してください……♪　でも、イくのはダぁ\nメ……。ほら？　まだ私、お口も使ってませんよぉ……？」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "080_0103131" ]},		{"command":[ "SETNAME", "ヴィシュヌ" ]},		{"command":[ "SETTEXT", "「あっ♪　目の焦点が合わなくなってぇ……。おっぱいおまんこに射精したく\nてしたくて気絶しちゃうまで可愛がってさしあげます……ふふ、ふふふ」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "080_0103132" ]},		{"command":[ "SETNAME", "ヴィシュヌ" ]},		{"command":[ "SETTEXT", "「はい♪　はい♪　はい♪　たぷたぷたぷっ♪　それ♪　それ♪　にゅるっ、\nにゅるっ、にゅるっ！　にゅぷぷぷ♪　にゅぷぷ♪　ぬっぷっぬぷ♪」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "080_0103133" ]},		{"command":[ "SETNAME", "ヴィシュヌ" ]},		{"command":[ "SETTEXT", "「あぁあん……♪　いやだ♪　隊長さま、こんなに透明のお汁を分泌して……\n。気持ちいいんでちゅねえ……♪　恥ずかちいでちゅねえ……♪」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00008001_01_03" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "080_0103134" ]},		{"command":[ "SETNAME", "ヴィシュヌ" ]},		{"command":[ "SETTEXT", "「自分の出したカウパーでおちんちんヌルヌルにして……それで感じてしまう\nだなんて、なーんて恥ずかしくて敏感なんでしょう……♪」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "080_0103135" ]},		{"command":[ "SETNAME", "ヴィシュヌ" ]},		{"command":[ "SETTEXT", "「強いつよーい男の子、なのに……♪　おっぱいに負けて、情けないお顔して\n……。あら♪　あら♪　これがいいんですか？　ここ？　ここですか？」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "080_0103136" ]},		{"command":[ "SETNAME", "ヴィシュヌ" ]},		{"command":[ "SETTEXT", "「うふふふふ♪　おっぱいでニュルニュルゴシゴシされてるだけで、女の子み\nたいにあまぁい声が漏れてますよ♪　そういう性癖なんですか？」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "080_0103137" ]},		{"command":[ "SETNAME", "ヴィシュヌ" ]},		{"command":[ "SETTEXT", "「私みたいな優しい神様に……おちんちんいじめられて、いじいじされると感\nじちゃうんですか……？　恥ずかしいでちゅねぇ……ふふふっ」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "080_0103138" ]},		{"command":[ "SETNAME", "ヴィシュヌ" ]},		{"command":[ "SETTEXT", "「にゅるにゅるにゅる♪　にゅるにゅるにゅる♪　上手♪　上手♪　イキたい\nですねぇ♪　限界ですよねぇ♪　許してほしいですよねぇ♪」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "080_0103139" ]},		{"command":[ "SETNAME", "ヴィシュヌ" ]},		{"command":[ "SETTEXT", "「……でも、許しません♪　貴方のおちんちんをパンパンのまま維持して……\n。もっともっと罰を与えます……♪　当然でしょう」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00008001_01_01" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "080_0103140" ]},		{"command":[ "SETNAME", "ヴィシュヌ" ]},		{"command":[ "SETTEXT", "「貴方は神におちんちんを向けたのです。傲慢なる人の子に、神の裁きを……\n。ほら、して欲しかったんですよね？　お・く・ち・で……♪」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "080_0103201" ]},		{"command":[ "SETNAME", "ヴィシュヌ" ]},		{"command":[ "SETTEXT", "「ぺろっ……ぺろぺろっ……♪　ちゅぱっ、ちゅっぷっちゅぷ♪　ぺろっ、ぺ\nろっ、ぺろ……んふふふ……♪」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00008001_01_04" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "080_0103202" ]},		{"command":[ "SETNAME", "ヴィシュヌ" ]},		{"command":[ "SETTEXT", "「お胸で限界だったところにぃ……舌が加わるとどうです？　死にたくなるく\nらい気持ちいいでしょう……？」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "080_0103203" ]},		{"command":[ "SETNAME", "ヴィシュヌ" ]},		{"command":[ "SETTEXT", "「あん♪　逃げてはいけませんよ……。せっかくこの私が『悪い子』『悪い子\n』と……隊長さまのいけないおちんちんを舐めてさしあげているのです」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "080_0103204" ]},		{"command":[ "SETNAME", "ヴィシュヌ" ]},		{"command":[ "SETTEXT", "「たぁ～～～っぷりと♪　ご堪能くださいね……いきますよ♪　ちゅるっ、ち\nゅるるるっ……ぴちゃっ！　ぴちゃっ、ぴちゃっぴちゃっ……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "080_0103205" ]},		{"command":[ "SETNAME", "ヴィシュヌ" ]},		{"command":[ "SETTEXT", "「んんん……♪　悔い改めなひゃい……♪　ちゅぷぷぷ……。おひんひんを神\nに咥えさせ、るだなんて……罰当たりにもほどがありま、ひゅ……っ♪」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00008001_01_05" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "080_0103206" ]},		{"command":[ "SETNAME", "ヴィシュヌ" ]},		{"command":[ "SETTEXT", "「ちゅっぽっちゅっぽっ！　ぺろ、ぺろぺろぺろぺろ……大量にカウパー漏ら\nひながら……自分のおひんひんを恨むのでひゅね……ちゅぽっ！」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "080_0103207" ]},		{"command":[ "SETNAME", "ヴィシュヌ" ]},		{"command":[ "SETTEXT", "「れろっ、れろれろ……れるれるれるれる……。んふ……♪　さきばひりはぁ\n……あまり味がひまへんね……れろっ、れろ、れろ、れろ……れろ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00008001_01_06" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "080_0103208" ]},		{"command":[ "SETNAME", "ヴィシュヌ" ]},		{"command":[ "SETTEXT", "「もっと舐めればわかるのれひょうか……？　んッ……おだひなひゃい。おだ\nひなひゃい……ってあぁあん♪」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "080_0103209" ]},		{"command":[ "SETNAME", "ヴィシュヌ" ]},		{"command":[ "SETTEXT", "「ふふっ♪　うふふっ♪　出すのは精液ではありませんよ……♪　あっ♪　あ\nぁっ♪　もう♪　イってはいけないと言ったのに……んぷ……♪」", "NORMAL" ]},
