		{"command":[ "PLAYBGM", "BGM_015" ]},		{"command":[ "PLAYVOICE", "080_0103101" ]},		{"command":[ "SETNAME", "ヴィシュヌ" ]},		{"command":[ "SETTEXT", "「……隊長、さま……？　ああ……こちらにいらっしゃったのですね。探して\nしまいました。お部屋にいらっしゃらなかったから……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00008001_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
        {"command":[ "SPOTCHARA", "0" ] },		{"command":[ "DISPNAME", "TRUE" ]},		{"command":[ "DISPTEXT", "TRUE" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "080_0103102" ]},		{"command":[ "SETNAME", "ヴィシュヌ" ]},		{"command":[ "SETTEXT", "「私を呼んでいたと聞きましたけれど……。御用でしたでしょうか？　あっ、\nもしや……何かそそうを？　でしたら謝罪いたします」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00008001_01", "5", "CENTER", "0" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "080_0103103" ]},		{"command":[ "SETNAME", "ヴィシュヌ" ]},		{"command":[ "SETTEXT", "「違うのですか。……私に至らぬところは特にないけれど……。はい。夜伽を\n願いたい……と。そうでしたか……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00008001_01", "0", "CENTER", "0" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "080_0103104" ]},		{"command":[ "SETNAME", "ヴィシュヌ" ]},		{"command":[ "SETTEXT", "「驚かないのか、ですか？　そうですね、驚くべきなのだとは思います。です\nが……話にも聞いていたのです。隊長さまが時々、女の子を呼び出して」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "080_0103105" ]},		{"command":[ "SETNAME", "ヴィシュヌ" ]},		{"command":[ "SETTEXT", "「パワーアップのために、一夜を共にしていると……。その順番が回ってきた\nのですよね。であれば、いいですよ」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "080_0103106" ]},		{"command":[ "SETNAME", "ヴィシュヌ" ]},		{"command":[ "SETTEXT", "「隊長さまのことはまだよく知りませんけれど……嫌いではありませんから。\nそれで、どのようなことをお望みですか？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00008001_01", "8", "CENTER", "0" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "080_0103107" ]},		{"command":[ "SETNAME", "ヴィシュヌ" ]},		{"command":[ "SETTEXT", "「はい。はい。口と胸とで隊長さまの性器を愛撫、する……。……。あ、すみ\nません。私、口で淫行をする文化を耳にしたのが初めてで……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00008001_01", "0", "CENTER", "0" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "080_0103108" ]},		{"command":[ "SETNAME", "ヴィシュヌ" ]},		{"command":[ "SETTEXT", "「人はさまざまな工夫をこらして、快楽を得ているのだな……と感心してしま\nって……。すごいですね、口と胸で……神には想像もつきません」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "080_0103109" ]},		{"command":[ "SETNAME", "ヴィシュヌ" ]},		{"command":[ "SETTEXT", "「ですが、郷に入れば郷に従えと申します。いいでしょう。多少拙くはなる\nと思いますが……それでよろしければ。さあ、性器をお出しになって」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "080_0103110" ]},		{"command":[ "SETNAME", "ヴィシュヌ" ]},		{"command":[ "SETTEXT", "「ふふふ……。お洋服を脱ぎ脱ぎしている貴方は、なんだか子供のようで可愛\nらしいですね……。え？　笑っていては雰囲気が出ない？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00008001_01", "1", "CENTER", "0" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "080_0103111" ]},		{"command":[ "SETNAME", "ヴィシュヌ" ]},		{"command":[ "SETTEXT", "「わかりました。真剣に行いましょう。……あっ……。おっきい……。あらあ\nらあら……♪」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00008001_01", "0", "CENTER", "0" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "080_0103112" ]},		{"command":[ "SETNAME", "ヴィシュヌ" ]},		{"command":[ "SETTEXT", "「これは、本気でかからねば食われるのはこちらでしょうね。……この怒張を\n、胸に挟んで……ふふ……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00008001_01", "6", "CENTER", "0" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "080_0103113" ]},		{"command":[ "SETNAME", "ヴィシュヌ" ]},		{"command":[ "SETTEXT", "「神に夜伽を願ったこと。ゆめゆめ後悔されませんよう……。私、外見はこう\nして穏やかですが……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "080_0103114" ]},		{"command":[ "SETNAME", "ヴィシュヌ" ]},		{"command":[ "SETTEXT", "「愛撫は、だいぶ激しいのですよ。ふふ、ふふふ……♪」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00008001_01", "8", "CENTER", "0" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "080_0103115" ]},		{"command":[ "SETNAME", "ヴィシュヌ" ]},		{"command":[ "SETTEXT", "「ねえ？　どんな風にもてあそんでほしいの？　人の身で、神の偉大なる双球\nを穢す……大罪人にも匹敵するその傲慢さ……胸が高鳴ります」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
