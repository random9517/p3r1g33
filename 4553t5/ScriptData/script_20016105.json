{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0132" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_007" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「よぉしっ、そこで決まりですわっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_010024040001" ]},
		{"command":[ "SETCHARA", "0", "char_00020701_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「……２人の攻撃のコンビネーションに、わたくしが混ざることで敵の予測を\n困難にする……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_010024040002" ]},
		{"command":[ "SETCHARA", "0", "char_00020701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「３人の力が合わさってこその、無限のバリエーション！　これが滅棲俄鬼の\n本当の力です！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_010024040003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「あたいとグラちゃんのぉ～！　法外なパワー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_010024040001" ]},
		{"command":[ "SETCHARA", "0", "char_00020801_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「それをまとめて、的確に判断するスーちゃんの頭脳！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_010024040001" ]},
		{"command":[ "SETCHARA", "0", "char_00020901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「もはやこのコンビネーションを止められるオトナなど、この世界には存在し\nませんわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_010024040004" ]},
		{"command":[ "SETCHARA", "0", "char_00020701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナＤ" ]},
		{"command":[ "SETTEXT", "「完全否定してあげたいけどぉ……っ、実際この連撃は……！　痛いわねぇっ\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_110024040001" ]},
		{"command":[ "SETCHARA", "0", "char_00000611_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナＤ" ]},
		{"command":[ "SETTEXT", "「でもでもぉ、オトナをナメてちゃ足をすくわれるわよぉ？　オトナにはオト\nナの経験値が……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_110024040002" ]},
		{"command":[ "SETCHARA", "0", "char_00000611_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナＤ" ]},
		{"command":[ "SETTEXT", "「……ってなあに？　この音……。船の外から何かが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_110024040003" ]},
		{"command":[ "SETCHARA", "0", "char_00000611_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ダイヤナ・ダークが身構えた瞬間、バン、と扉が開きそこから次元統制局の人\n々が踏み込んでくる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「やっと来たか！　見捨てられたのかと思ってヒヤヒヤしたぜ！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナＤ" ]},
		{"command":[ "SETTEXT", "「うぐぐぐぐ……っ。外部からの干渉はシャットダウンしておいたはずなのに\nぃっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_110024040004" ]},
		{"command":[ "SETCHARA", "0", "char_00000611_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「……もちろん、それも解除させていただきましたわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_010024040005" ]},
		{"command":[ "SETCHARA", "0", "char_00020701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「さっすがスーちゃん！　脳がつよつよ～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_010024040002" ]},
		{"command":[ "SETCHARA", "0", "char_00020801_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「滅棲俄鬼がおばさんに負けるわけないし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_010024040002" ]},
		{"command":[ "SETCHARA", "0", "char_00020901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナＤ" ]},
		{"command":[ "SETTEXT", "「んぎぎぎぎ！　またオバサンってぇ！　ダイヤナちゃんはピチピチの美女な\nのにぃ～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_110024040005" ]},
		{"command":[ "SETCHARA", "0", "char_00000611_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "次元統制局の面々に囲まれていることよりも、おばさん呼ばわりをきにしてい\nるらしいダイヤナ・ダーク。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "しかしさすがに、自分が窮地に立っていることには気が付いたらしい。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナＤ" ]},
		{"command":[ "SETTEXT", "「か、完全包囲される前に、今日は逃げるしかないわね～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_110024040006" ]},
		{"command":[ "SETCHARA", "0", "char_00000611_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あ、逃げたぞ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナＤ" ]},
		{"command":[ "SETTEXT", "「目にも止まらないスピードで、すたこらさっさよ！　ダイヤナちゃんは若い\nからっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_110024040007" ]},
		{"command":[ "SETCHARA", "0", "char_00000611_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナＤ" ]},
		{"command":[ "SETTEXT", "「とってもとっても若くて可愛いからっ！　足が長くて速いのよぉっ！　じゃ\nあねぇ～っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_110024040008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「めちゃくちゃ若さをアピールしていなくなった……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「ちっ。まんまと逃げられた……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_010024040003" ]},
		{"command":[ "SETCHARA", "0", "char_00020901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「でもでも、深手は与えたし、なによりあたいら滅棲俄鬼に負けたトラウマは\nばっちり刻んだっしょ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_010024040003" ]},
		{"command":[ "SETCHARA", "0", "char_00020801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「これからまた、襲ってくることもあるかもしれませんけれど……とりあえず\nは安心といったところかしら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_010024040006" ]},
		{"command":[ "SETCHARA", "0", "char_00020701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「カツマ！　アタシたちを次元統制局のやつらが保護してくれるらしいぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_129_010024040001" ]},
		{"command":[ "SETCHARA", "0", "char_00012901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "（そういや、俺たちは滅棲俄鬼に誘拐されて強制労働させられていたわけで）", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "（保護されるってことは、こいつらとはお別れってことになるのか……） ", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「ジュンジローも一緒に戻してくれるらしいから、とっととここからオサラバ\nしようじゃないか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_129_010024040002" ]},
		{"command":[ "SETCHARA", "0", "char_00012901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「えーと、それなんだが……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「いいよ、おにーさん。行っても」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_010024040004" ]},
		{"command":[ "SETCHARA", "0", "char_00020801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「本当は……わかってたんだ。本当の仕事の邪魔して、遊んでもらってたんだ\nって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_010024040004" ]},
		{"command":[ "SETCHARA", "0", "char_00020901_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「え？　いつもあんだけワガママなお前らが一体どういう風の吹きまわしだ？\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「ふふふ。わたくしたちも、ワガママなだけではないということですわよ。で\nも……忘れないでくださいませ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_010024040007" ]},
		{"command":[ "SETCHARA", "0", "char_00020701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「前にもお伝えした通り、おにーさんはもはや名誉滅棲俄鬼。わたくしたち滅\n棲俄鬼の一員です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_010024040008" ]},
		{"command":[ "SETCHARA", "0", "char_00020701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「あたいらを支えてくれたのはカツマおにーさんだから……今回の勝利はカツ\nマおにーさんのおかげだし！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_010024040005" ]},
		{"command":[ "SETCHARA", "0", "char_00020801_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「今回のＭＶＰってことで、あたしたちからも感謝を伝えとく」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_010024040005" ]},
		{"command":[ "SETCHARA", "0", "char_00020901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おまえらぁ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "なんだか、学園モノの最終回みたいな良い雰囲気だ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "……俺はこうして、今回の任務を気持ち良く終わらせることができたのだった\n。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0000" ]},
		{"command":[ "SETTEXT", "そして後日。", "NORMAL" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0101" ]},
		{"command":[ "PLAYBGM", "BGM_011" ]},
		{"command":[ "SETTEXT", "俺とジュンジローは、いつも通りにインクレディブル・スクワッドの任務のた\nめに走り回っていた。", "NORMAL" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人ご主人、次は外の見回りですぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010024040001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「やれやれ。戻ってきたはいいが、また忙しい毎日の繰り返しか……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「こうなってくると、いちいち喜んでくれてたメス〇キたちとの日々がなつか\nしくなってくるな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「……ご主人？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010024040002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああ、いやいや、なんでもなくて……って。なんだ？　めちゃくちゃ電話が\n鳴ってるな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「さっきからずっとでしたぞ。急用でしょうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010024040003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「わからん……。はい？　もしもし？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYBGM", "BGM_018" ]},
		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「あぁああああ～っ♪　おにーさんっ♪　わたくしです、スーヤチカです～っ\n♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_010024040009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「う、噂をすればメス〇キが！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「ね～っ、ねぇ～！　あたいにもかわって！　かわって、話したい～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_010024040006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「わたしも話したい。もしもし、聞こえてる？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_010024040006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「聞こえてる聞こえてる。……で。何の用だ。俺は今忙しいんだが」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「お腹空いた。早く帰ってきて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_010024040007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「か、か、帰ってきて！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「おにーさんは名誉滅棲俄鬼、ってことはあたいらの船がおにーさんの家だよ\nね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_010024040007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「育児放棄するなぁ！　めし！　めし！　めし！　めし！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_010024040008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「もうわたくしたち、おにーさん無しでは生きていけないのですわ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_010024040010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「あそんであそんであそんで！　あそべ～～～～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_010024040008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……おい。こいつら、通話を切っても鬼電で何度でもかけてくるぞ」　", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「随分好かれたものですなあ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010024040004" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「こら～っ！　電話切るな！　何時に帰ってくるのか言えーっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_010024040009" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「今夜はお肉が食べたい。分厚いの。買ってきて、焼いて、食べさせて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_010024040009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
