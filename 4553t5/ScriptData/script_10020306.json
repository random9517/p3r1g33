		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「シミュレーション終了！　ルルーナさんチームの勝利です！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_072_010113320001" ]},
		{"command":[ "SETCHARA", "0", "char_00007201_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「ほーっほっほっほっほっほ！　当然の結果ですわ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113320001" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "みんと" ]},
		{"command":[ "SETTEXT", "「ううううううううううう～～～っ！　ぐやじいいいいいいいいい～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_020113320001" ]},
		{"command":[ "SETCHARA", "0", "char_00001502_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "sbg_0000" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "と、いうわけで。勝利に味をしめたルルーナは、すっかり『模型シミュレーシ\nョンバトル』に夢中になってしまい……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0138" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「カツマ！　きょうもバトるわよ！　プラモデルを用意しなさい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113320002" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「それはいいですけど、まだ授業中なんで授業に集中してもらえませんかね」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0025" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "てな具合で、毎日放課後は俺たちを引き連れて、地下の『模型シミュレーショ\nンセンター』に通うようになった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「あ！　ルルーナたち来たわね。今日もバトルする？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020113320001" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「当然ですわ！　昨日は４回やって２対２で決着がついていないもの。今日こ\nそ、私たちが圧勝してみせるわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113320003" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「よろしくお願いします……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130113320001" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「はい！　こちらこそ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020113320001" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "でもって、同じようにバトルにハマったマーガレットやグレーテルたちのグル\nープとは毎日ここで顔を合わせ、しょっちゅうバトルをしている。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "まあ、お互いに格好のバトル仲間ができたってとこだな。ルルーナや流々那に\nとっては、いいことだと思う。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「……ミス・パープル。セッティングをよろしく」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_020113320001" ]},
		{"command":[ "SETCHARA", "0", "char_00001802_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「承知しました。それでは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_072_010113320002" ]},
		{"command":[ "SETCHARA", "0", "char_00007201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「それでは！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_072_010113320003" ]},
		{"command":[ "SETCHARA", "0", "char_00007201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "みんな" ]},
		{"command":[ "SETTEXT", "「模型シミュレーション、ゴー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113320004" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0022" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「さー、みんな！　今日こそルルーナチームをボッコボコにして、完勝しちゃ\nいましょ！　いいわね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020113320003" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "8", "CENTER", "0" ]},
