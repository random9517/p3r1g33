		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「……あなたたち、こんな格言を知ってる？　『いいは悪い。悪いはいい』」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_020113320002" ]},
		{"command":[ "SETCHARA", "0", "char_00001802_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「シェークスピアですね。でも、今の状況とどういう関係が？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020113320003" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「……意味はないわ。言ってみたくなっただけ」", "NORMAL" ]},
