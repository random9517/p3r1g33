{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009703_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ヘヘヘ……！　もう逃がしゃしねぇぞ。観念して、その股間のモンを出して\nもらおうか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0304101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「なぁに。別に痛くしたりしねぇよ。むしろ気持ちいいことをするだけだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0304102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「天井のシミの数でも数えてりゃ、すぐ終わるさ。ほら、さっさと服を脱いで\n、アレを出しな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0304103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「無理やり犯されそうになってるってのに、随分といい反応してるじゃねぇか\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0304104" ]},
		{"command":[ "SETIMAGE", "0", "still_00009703_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「私のアソコに擦れて……ああぁんっ！　まだ挿れてないのに、熱さが伝わっ\nてくるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0304105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「当ててるだけで、乳首も大きくなってきやがる……！　ああっ、クソッタレ\n！　じれったいんだよ！　もっとチカラを入れて胸を揉めっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0304106" ]},
		{"command":[ "SETIMAGE", "0", "still_00009703_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「そうそう……！　んっ、あふっ……いっ、いいぞ……！　その調子で、もっ\nとアソコにおまえのモノを擦りつけろ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0304107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ひっ、んあっ、はああぁ……！　くっ、あっ……！　軽く擦ってるだけなの\nに、アソコがびちょびちょになってきたぜ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0304108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「もう我慢できねぇ……！　このガチガチに勃起してるモン、挿れさせてもら\nうぞ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0304109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「あっ……んんっ……！　ゆっくり入ってきて……！　ああっ、アソコの肉が\n掻き分けられてるの、感じるっ……！　ああっ、あっ、くああぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0304110" ]},
		{"command":[ "SETIMAGE", "0", "still_00009703_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「んっ、あっ……！　ふくっ、はあああぁ……！　このずっぽり奥まで入って\nる感じ……エクセレントだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0304111" ]},
		{"command":[ "SETIMAGE", "0", "still_00009703_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ヘヘヘ！　やっぱムラムラしてきたら、おまえのコレを肉バイブにすんのが\n一番だぜ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0304112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ほら。挿れて終わりじゃねぇんだ。ちゃんとおっぱいも揉んどけよ。少しで\nも手ぇ抜いたら、ウチクビ・ゴクモンだからな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0304113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「あっ、んふっ……！　そうそう。いい感じだ……！　乳首もクリクリ弄って\n、いっぱい感じさせろよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0304114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ああっ、あっ、ひああぁ……！？　腹の中で、アレがまた一段と大きく……\n！　ヘヘヘ……！　おまえもヤる気満々みたいだな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0304115" ]},
		{"command":[ "SETIMAGE", "0", "still_00009703_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「あぁん？　勝手に大きくなっただけで、やる気じゃない？　おいおい。冗談\nはフェイスだけにしておくのが一番だぜ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0304116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「今のおまえは、私を気持ちよくするためだけに動く肉バイブだ。それ以上で\nも、それ以下でもねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0304117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「わかったら、もっとこいつを大きくしな！　私が満足するくらい、大きく…\n…んっ、んんっ……！　ふぐぐっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0304118" ]},
		{"command":[ "SETIMAGE", "0", "still_00009703_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「はああぁ……！　軽く締め付けただけなのに、ビンビンになってるじゃねぇ\nか……！　こりゃ、私のアソコが相当気に入ったみたいだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0304119" ]},
		{"command":[ "SETIMAGE", "0", "still_00009703_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「気に入ってくれてるなら、遠慮はしねぇぞ。もっとアタシのアソコの虜にし\nて、他のオンナじゃ満足できない身体にしてやるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0304120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ！　んっ、あああっ！　すごっ……！　少し動いただけなのに、\nカリの部分がアソコをゴリゴリ抉ってくるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0304121" ]},
		{"command":[ "SETIMAGE", "0", "still_00009703_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「くうううぅ……！　ひっ、あああっ！　んひっ、くふっ……！　ああっ、い\nいっ！　私の好きなとこに、どんどん当たるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0304122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「おまえも気持ちいいだろ！？　私のアソコ、最高だろ！？　我慢した顔して\nないで、返事くらいしろよっ……！　んっ、んんんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0304123" ]},
		{"command":[ "SETIMAGE", "0", "still_00009703_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ああぁんっ！　あっ、あっ……！　おまえのが膣内でビクンビクンって大き\nく暴れて……ひゃうっ、はああぁ……！　んふっ、はううぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0304124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「こんなに暴れ回るってことは、相当気持ちいいみたいだな……！　なら、こ\nいつはサービスだ……！　もっと奥まで挿れさせてやるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0304125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ふくうううぅ……！　あっ、あっ……！　はああぁ……！　硬くてコリコリ\nしてる感触、わかるか……？　これが私の子宮口だ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0304126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「気持ちよくなればなるほど、下のクチが開いて……完全に開いた状態で、お\nまえのドロドロザーメンを流し込んだら……どうなるかわかるか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0304127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「そう、妊娠だ。私のお腹はどんどん大きくなって、ボテ腹になっちまうんだ\nぜ？　おっぱいを揉めば、母乳も出て来る……どうだ？　興奮するだろ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0304128" ]},
		{"command":[ "SETIMAGE", "0", "still_00009703_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「んんんっ……！　あっ、ひぐっ……！　ヘヘヘ！　私の大きくなったお腹を\n想像したみてぇだな！　アソコがもっと勃起して、動き回ってるぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0304129" ]},
		{"command":[ "SETIMAGE", "0", "still_00009703_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ひっ、ふぐっ、んふうぅ……！　胸も、強く揉まれて……！　そんなに揉ん\nでも、まだ母乳は出ねぇよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0304130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「そう……まだ出ないだけだ。妊娠すればいくらでも出るようになる……！　\nおっぱいからミルク出しながら、セックスできるんだぜ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0304131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「あぐっ、んんっ……！　でも、本当に妊娠したら、おまえはもう逃げられね\nぇけどな！　一生、私の肉バイブ確定だ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0304132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「おっと！　怖気づいて腰を引いてもムダだぜ！　こうやって締め付けて……\nんっ、ああっ……！　もっと激しく動けば……あっ、あっ！　ああぁん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0304133" ]},
		{"command":[ "SETIMAGE", "0", "still_00009703_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ほらっ、ほらっ！　おまえのが気持ちよくて、下のクチがどんどん開いてる\nぞっ！　そのまま、ザーメン出しちまえっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0304134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「孕ませザーメン全部膣内に注ぎ込んで、責任とらされろっ！　おまえがパパ\nになるんだよ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0304135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「くあああぁ……！　あっ、んひっ、ふあああっ……！　熱くて濃いのが、私\nの奥に流れ込んでくるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0304136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009703_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「あっ、はああぁ……！　んっ、あっあっ……！　気持ちいいっ……！　イッ\n、イッちまうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0304137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「あああぁ……ひぐっ、あひっ……！　あっ、あっ！　イクッ！　膣内出しさ\nれながら、イクううううぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0304138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「んあああっ！　ダメだっ……一回イッただけじゃ、全然おさまらねぇ……！\n　またイクッ……！　す、すげぇ……！　何回でもイけそうだ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0304139" ]},
		{"command":[ "SETIMAGE", "0", "still_00009703_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「はぐっ、ふっ……んふうぅ……！　もっと出せ……！　おまえの溜め込んで\nるザーメン、私の子宮に……！　ああああぁ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0304140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……子宮の奥がずっしりする感じがするぜ……！　こりゃ、妊\n娠確定だな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0304201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ヘヘヘ……！　どうだ？　オンナに主導権握られて、無理やりパパにされた\n気分は……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0304202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「まだ妊娠したと決まったワケじゃない？　おいおい。こんな無責任に膣内出\nししといて、言い逃れできると思ってんのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0304203" ]},
		{"command":[ "SETIMAGE", "0", "still_00009703_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「私が無理やり膣内に出させただけって……イヤなら抵抗して、アソコからこ\nいつを抜けばよかっただろ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0304204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「抜こうとしたけど、抜けなかった？　へぇ……そうかい。なら、本当に抜く\n気があったか、もう１回確認してやるよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0304205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ！　あああぁん！　んっ、あひっ、くっ……おっ、んおおぉ……\n！？　あっ、あっ！　また、奥に当たってるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0304206" ]},
		{"command":[ "SETIMAGE", "0", "still_00009703_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「はぁ、ああっ！　くっ、あああぁん！　ほらっ！　こいつを抜こうとしてた\nんだろ！　だったら、私のアソコから抜いてみろよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0304207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「んくうううぅ……！　アソコの肉が入口に引っ張られて……あっ、あっ……\n！　ゆっくり、アソコから抜けて……！　あああっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0304208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ほら……頑張れ♪　頑張れ♪　もう少し……あと少しでアソコから抜けるぞ\n……！　あっ……あっ……！　本当に、抜けるっ……あんんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0304209" ]},
		{"command":[ "SETIMAGE", "0", "still_00009703_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「なーんて、抜かせるワケねぇだろ！　おまえのモンは私のモンだ！　こうや\nって一気に腰を落とせば……また奥まで逆戻りだっ！　はああああぁん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0304210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「はははっ！　おまえのモンも、私のアソコに包まれて嬉しいみたいだぞ！　\nその証拠に、さっきより激しく暴れ回ってるぜ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0304211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「こうやって……んっ、あっ！　ピストンすればするほど、震えも大きくなっ\nて……あっ、ああっ！　ふうっ、んっ、あはあああぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0304212" ]},
		{"command":[ "SETIMAGE", "0", "still_00009703_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「おまえの尿道に残ってた、搾りカスみたいなザーメンも……どんどん溢れて\nきて……んっ！　また、子宮の奥に入ってきてるぞ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0304213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「あははははっ！　悔しいかっ！？　気持ちいいかっ！？　だけどなぁ、おま\nえがどんだけ足掻いても、私からは逃げられないんだよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0304214" ]},
		{"command":[ "SETIMAGE", "0", "still_00009703_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「おまえは私のモンだっ！　私専用の肉バイブだっ！　私が発情したときに処\n理をするための、ただの道具だっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0304215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
