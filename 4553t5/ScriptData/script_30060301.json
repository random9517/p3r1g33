{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000603_01_02" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「んっ……？　こ、ここはどこぉ……？　それにあなたは……！　あっ！？　\nム、ムーンナイトくん……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0303101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「もしかして、あたし……あなたに倒されて、捕まっちゃったの？　ッあぁっ\n！？　拘束されて動けない……それに、んっ、んんっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0303102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「馬乗りになられて……ひぅうっ！　おっぱい……！　おっぱい揉まれちゃっ\nてる！？　なんでぇ？　やめて……やめてよぉ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0303103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「は、ぁ……っ！　あぁっ、あっ……んっ、ぁっ……！　あぁぁんっ……！　\nダメ、手の跡がついちゃう、乱暴に鷲掴みにしちゃダメ！　んっんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0303104" ]},
		{"command":[ "SETIMAGE", "0", "still_00000603_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「せっかくシルバスターの姿になって、パワーだって上がってたのに……負け\nちゃうなんて信じられない。こんなの、何かの間違いよ……いやぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0303105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「は、なして……！　離してよぉ！　すぐに解放してっ！　そしたら許してあ\nげないこともないんだから……って、ぁっ！　やんっ、やだっ、あぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0303106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「おっぱいっ……強く揉まないでぇ……！　あっ！　力が強いのよぉ、……は\nぁっ、んっ、んんっ、んぅっ！　んぁっ……あっ、あぁんんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0303107" ]},
		{"command":[ "SETIMAGE", "0", "still_00000603_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「おっぱいかき混ぜちゃいやぁ……♪　あ……、あんっ、あぁんっ……♪　そ\nこぉ……！　イジられると弱いの、やっ、やめてぇ……いやぁぁん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0303108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あっ……♪　あっぁっあっぁっ……！　はぁっ♪　んん……あぁん……♪　\nあんっ……！　ほ、本当にダメなんだったらぁ……！　っあぁあ……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0303109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「えっ？　な、なぁに？　あたしが感じた声を出してる？　甘い反応がかえっ\nてきてるぅ……？　そ、そんなのあなたの勘違いよ……！　っあぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0303110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あ、あたしは今正義の味方なんだからぁ……あなたの愛撫なんかに感じちゃ\nうわけな、ないじゃない……！　っぅっ♪　はぅっ♪　うぅん……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0303111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「……ちょ、ちょっと？　何をするつもりなの？　認めないなら乳首をしごき\n倒す？　……ま、待ってよ！　それは……！　あぁああんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0303112" ]},
		{"command":[ "SETIMAGE", "0", "still_00000603_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ふぁああっ♪　やだぁっ、いやぁんんっ！　あんっ、んんっ……やめてぇ…\n…♪　乳首ひっぱらないで、グリグリしないで……あっあっあっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0303113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「だ、めなの……！　そこぉ、乳首いじられると……んぁああっ！　お、お股\nが熱くなってきて……あぅんんっ！　全身が火照って……あっんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0303114" ]},
		{"command":[ "SETIMAGE", "0", "still_00000603_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「どうにもならなくなっちゃうのぉ……！　っひっ……！　ゆ、指先で先っち\nょこねこねしないでぇ……！　あんっ、そんなに刺激されたら……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0303115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あたし、あたし……！　ッぁっ……！　あっぁっはぁあっ♪　や、優しく撫\nでるのもだめぇ、つまむのも……卑怯よぉ、はぁんんっ、感じちゃうぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0303116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ふ、ぅっ♪　あぁうぅっ……！　スーツを着て強くなれたはずなのにぃ……\n！　素肌を直接いじられたら、なんの抵抗もできないぃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0303117" ]},
		{"command":[ "SETIMAGE", "0", "still_00000603_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あぁっ！　もっと、もっと乳首触ってぇ……！　じゃなかった、ち、乳首で\n遊ばないでぇ……！　これ以上されたら……あたし、あたし……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0303118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「敏感になりすぎてお漏らししちゃう……！　……ん！？　あ、あなた、何を\nしてるの？　やんっ、オ、オチンチンを出してあたしの胸に……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0303119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「んんんんっ！？　ふぁッ！　ああああっ……！　う、嘘でしょぉ……！　谷\n間にオチンチン挿入して、……あっ、無理やりパイズリぃ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0303120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「はぅぁあっ♪　んんぁっ！　やっ……！　あつぅい！　あなたのオチンチン\nっ、きょ、凶悪なカタチしてるぅ、尖ってて、長くて、おっきぃ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0303121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「はぅうっ！　んぁんんっ！　やぁんんっ！　ズボッ、ズボって亀頭をねじこ\nまないでぇ……！　あっ！？　あっ、あぁんっ、いやぁ、あっあっあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0303122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ダイヤナちゃんのおっぱいマンコ犯しちゃだめぇ！　あぁあ……っ♪　こ、\nこんなの耐えられるわけないじゃない！　おっきくなった乳首いじられて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0303123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「乱暴に股間っ……おっぱいに打ち付けられて！　あっ！　あぁ、あぁあっ…\n…！　おっぱいをオマンコ扱いしちゃだめぇ、はぁ、はぁ、はぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0303124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「……んぅうっ！　こ、こんな好き勝手なことされて……ありえないはずなの\nにぃ！　んっぁっ！　な、なんでこんなに気持ちいいの……っ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0303125" ]},
		{"command":[ "SETIMAGE", "0", "still_00000603_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ダ、ダイヤナちゃん……変身ヒロインになれたのに、良い子になったのに…\n…あぁっ！　おっぱいっ、オマンコにされるとすごく興奮しちゃう……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0303126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「硬いオチンチンでおっぱいの谷間……っ、おっぱいオマンコずりずりって…\n…！　ずぷずぷって犯されるだけで……あっあっあっ、んぃいいっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0303127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「すっごくいいっ……いいの……！　だめなのに感じるの……！　パンッ、パ\nンッて腰を打ち付ける音が響くの、力強く犯されるの好きなの……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0303128" ]},
		{"command":[ "SETIMAGE", "0", "still_00000603_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「んっ、やっ、あっ、あぁっ……！　ね、ねぇえっ……！　あなた、オチンチ\nンの先っちょからカウパー……！　我慢汁が溢れてきてるわよぉっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0303129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ダイヤナちゃんのおっぱいマンコがヌルヌルしてきちゃってるぅう……！　\nはぁんんっ、それに、クチュ、くちゅ、ってエッチな水音がして……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0303130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「震えちゃうほど気持ちいいのぉっ、おっぱいの芯にビリビリ響いちゃうぅっ\n……！　あぁっ、あああっ！　こんなおっきなオチンポ無理ぃいっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0303131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ダイヤナちゃんの爆乳が、あなたのエッチな先走り汁で汚れちゃうぅう……\n！　はぁんんんっ、お、お願いぃ、腰を止めて……エッチしないで！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0303132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ダイヤナちゃんのおっぱいマンコでセックスしちゃだめぇええ……っ！　あ\nんっ、あんっ、だ、ダメって言ってるのにどんどん激しくなってくるぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0303133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「やんっ！　も、もしかして……精液ピュッピュしたくなってきちゃったの！\n？　あっ！　そ、それはだめよ……いいわけないでしょっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0303134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「おっぱいマンコに出しちゃだめっ、射精しちゃだめ……！　オチンチン気持\nち良くなってビュルビュルなんて絶対だめぇえ……！　だめなのにぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0303135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「っあああああああっ♪　んぁああああんんんっ♪　やだぁああ♪　おっぱい\nマンコ、真っ白な精液でいっぱいぃい……！　あふぁあああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0303136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000603_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「い、や……っ♪　いやぁんんっ！　そんなに出されたらあたし、イッちゃう\n……！　あっ、お顔の近くで射精されてトんじゃううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0303137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「はぁっ……！　あぁあああああんっ！　イクッ……！　イクのっ！　おっぱ\nいマンコ犯されて、中出しされて絶頂しちゃうぅうう～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0303138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ああああっ♪　んああああっ……ああああ……！　ぶりゅぶりゅって濃い白\n濁液が注がれて……熱くて、ネバネバして、もどかしくてぇ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0303139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あああっ、ダイヤナちゃん、正義の味方なのにぃ……！　おっぱい受精させ\nられちゃってるぅ、なによぉ……！　気持ちいいっ、すっごくいいぃっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0303140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「もっと、もっとかけてぇ……！　これ、精液かけてぇ……！　ヌルヌルのド\nロドロにされると興奮するの、エッチなお汁で満たしてほしいのぉおっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0303201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「……あっ♪　ドクン、ドクンってオチンチン脈打って……。そ、そうなの？　\nそんなに、あたしのおっぱい良かったの？　たくさん出ちゃうくらい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0303202" ]},
		{"command":[ "SETIMAGE", "0", "still_00000603_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「それなら……んっ。つ、使わせてあげて良かったかも……。って、あ、あた\nしが精液で絶頂したからお仕置き？　えっ、ええっ、どうしてぇ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0303203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「精液浴びてうっとりしちゃう変態シルバスターなんて許可出来ない？　あっ\n♪　精液をローションがわりにして……またするつもりなの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0303204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「も……もちろんダイヤナちゃんは反対よ？　一度出したんだからスッキリし\nて、おっぱいいじりはもうおしまいに……。っあぅううんんっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0303205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あんっ！？　あんっ、あぁんんっ！？　ど、どうしてオチンチンをまたあた\nしのおっぱいになすりつけてくるのぉ……！　あっあっ、信じられないぃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0303206" ]},
		{"command":[ "SETIMAGE", "0", "still_00000603_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「オチンポ全然しなびてない、ガッチガチに硬いまま……！　はぁっ、んんっ\n……！　それに、ザーメンでよくすべるから……はぁんんっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0303207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「谷間に出入りするスピードも、長さも段違いになって……！　あっ！　あっ\nあっ……！　今度こそあたしのおっぱいマンコめちゃくちゃになっちゃうぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0303208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ああぁああ～っ！　あはぁっ♪　あンっ、ああああっ……！　なによこれぇ\n……！　ニュルニュルが、ヌルヌルがすごいぃい……！　あんっあっあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0303209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「すっごい勢いでっ、おっぱいオマンコどちゅどちゅ犯されてるぅう……！　\nひぃいんんっ！　力強すぎるのよぉっ、あっ、あっ顔まで届きそうぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0303210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あ、あなたのオチンチンっ……！　おっきいだけじゃなくて持久力もすごい\nのねぇえっ……！　はぁあっ、こんなの勝てるわけないぃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0303211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あんっ！　あんっあんっ！　あなた……本っ当にいやらしい腰の動かし方す\nるのよねぇ……っ！　んぁああっ、おっぱいをえぐる、みたいにぃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0303212" ]},
		{"command":[ "SETIMAGE", "0", "still_00000603_01_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「本物のオマンコみたいににゅぽにゅぽぐっぽぐっぽ出し入れして……！　っ\nんぅうう……こんなのヘンな気分になるの当たり前じゃないぃい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0303213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あああっ……ダイヤナちゃんのおっぱいマンコにザーメン塗りこんで、染み\nこませて……更に犯すなんて！　ゆ、ゆる、せないはず……なのにぃっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0303214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「う、上手すぎるのぉ……！　あああっ！　あたしのおっぱいの扱い方、いじ\nめ方……ぜんぶぜんぶ上手で、だから感じちゃってぇ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0303215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ん～～～～～っ！　こ、このままじゃまたおっぱいでイカされちゃうぅうう\n……！　こらえ、ないと……いけないのに、……あっ、む、無理ぃい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0303216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あたしっ、ダイヤナちゃん……！　自分からおっぱいマンコすり寄せちゃっ\nてるっ、あなたのチンポに合わせて揺らしちゃってる、ぅうう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0303217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「とっくにおっぱい陥落してる、オチンチンに媚びちゃってるぅうう……！　\nねえ……！　またオチンポがビクビクぅって痙攣してきたわぁ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0303218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「出したくなってきたんでしょ？　ダイヤナちゃんのおっぱいマンコに精子び\nゅるっびゅる放出するつもりなんでしょぉ！？　んぁあああああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0303219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「出して、出して出してぇ！　あなたのトロトロザーメン欲しいのっ！　あた\nし、精液欲しくなっちゃったのぉおおっ……！　あ～～～～～っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0303220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ひゃっ、あぁあああンンっ♪　んぁああんんんっ！　出たぁあ♪　出たわぁ\nああ、精子出たぁああ……！　あああああんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0303301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000603_01_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ダメ……あたしイクッ、またおっぱいでイカされちゃうっ！　んぁんんんっ\n！　気持ちいいっ、精子かけられるのとってもイイのぉおおっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0303302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あふぁああっ！　に、二回もおっぱいマンコに精液流しこんだ感想はど～お\nぉ……！　あふっ……とんでもない量ね、胸がドキドキしちゃうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0303303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「さっきあんなに出したのに、まぁだこんなに隠してたなんて……イジワルイ\nジワルぅう……！　はぁあっ、ザーメン熱くて気持ちいい……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0303304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「シルバスターのスーツでおっぱい犯されるの……クセになっちゃいそ……♪\n　この背徳感、快感……格別すぎよぉ♪　おかしくなっちゃうぅう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0303305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あ、あぁあああ……♪　だらだら流れてくる精液……♪　あたしの胸でも受\nけ止めきれないくらいに溢れて……♪　こんなの元気すぎるでしょぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0303306" ]},
		{"command":[ "SETIMAGE", "0", "still_00000603_01_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あぁんん……♪　すっかりあなたの色に染められちゃった……。そして、こ\nのザーメンのニオイ……♪　すっごくすっごくいい香り……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0303307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あぁ……せっかく正義の味方になれたのに、ダイヤナちゃんはダイヤナちゃ\nんのまま……エッチなことには抗えなかったわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0303308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「なぁんて、たまにはこういうプレイもいいわねぇ？　ムーンナイトくぅん…\n…？　囚われのシルバスター、快感のおっぱい責め！　なぁんて♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0303309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「……たまーになら、また、こういうシチュエーションプレイもいいかもぉ…\n…♪　ハマっちゃったらごめんなさいねぇ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0303310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「っんんっ！？　きゃっ……！　顔に、熱いお汁がかかって……あぁあんっ！\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0303401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000603_01_16" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「きゅ、急になあに……！？　あっ……！　んふっ、んんっ……やんんっ……\n！？　すっごい臭い……！　顔中にへばりついてくるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0303402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あああ……♪　こんな熱いお汁、のぼせちゃうぅ……♪　ひどいことばっか\nりされたはずなのに……♪　精液の匂いを嗅ぐとうっとりしちゃって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0303403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「もっと浴びせてほしいって思っちゃう……！　ねえっ、かけて……もっとか\nけてぇ！　ダイヤナちゃんのお顔を真っ白にしちゃって！　お願いっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0303404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「っあ～～～～♪　あぁああっ、あぁ……♪　いくらでも、美味しいお汁が飛\nび出してくるぅ……。ぺろっ、んん……！　にがぁい……濃いわ……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0303405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「だめぇ！　せっかくあたしがかけさせてあげてるんだから、かけるのやめち\nゃイヤ……！　あっ……♪　そうそう、ヌルヌルしたのちょうだぁい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0303406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「んはぁ……♪　そうねぇ……♪　これくらいたっぷり出してくれたなら合格\n点をあげてもいいかも……♪　私も途中から気持ち良くなっちゃったし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0303407" ]},
		{"command":[ "SETIMAGE", "0", "still_00000603_01_17" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「だけど、あなたほどの才能あるオチンチンなら……回数を重ねれば、もーっ\nともっとたくさんの精液を出せるようになると思うのぉ……。」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0303408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「もし、全力のあなたに無理やり使われちゃったら……♪　それを想像するだ\nけで、……ンッ……♪　どんどん濡れてきちゃう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0303409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「バトルでもエッチでも……私をがっかりさせないでね？　ムーンナイトちゃ\nん……♪　いつでも夢中にさせてくれなきゃイヤよぉ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0303410" ]},
