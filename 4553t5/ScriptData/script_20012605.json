{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0149" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふふふっ！　楽しかったですねっ、ご主人様！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022060001" ]},
		{"command":[ "SETCHARA", "0", "char_00015702_01", "4", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「たまにはこうやって、思いっきり遊ぶことも大切です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022060001" ]},
		{"command":[ "SETCHARA", "0", "char_00015802_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "再び俺の部屋に戻ってきた２人は、大層ご満悦の様子だった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「こんなに楽しかったのは、ご主人様に初めて出会った日以来でした！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022060002" ]},
		{"command":[ "SETCHARA", "0", "char_00015702_01", "4", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「うん。あの日も良かったけど……今日も良かったよ。今日がずっと続けばい\nいのにって思った」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022060002" ]},
		{"command":[ "SETCHARA", "0", "char_00015802_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そーかそーか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「これで満足してくれましたかね？　ウチも、引きずり回されて疲れました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010022060001" ]},
		{"command":[ "SETCHARA", "0", "char_00000512_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「オボロさん、ありがとうございました。すごく思い出に残るハロウィンがで\nきました！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022060003" ]},
		{"command":[ "SETCHARA", "0", "char_00015802_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あっ……、あ、ああそうですか。喜んでもらえたなら結構です……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010022060002" ]},
		{"command":[ "SETCHARA", "0", "char_00000512_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "いつものオボロの毒舌も、無邪気なメカ娘の輝く瞳には負けてしまうらしい。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「イベントがうまくいったのは、全部オボロさんが教えてくれたからです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022060004" ]},
		{"command":[ "SETCHARA", "0", "char_00015802_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「私達だけじゃ、絶対こんなに盛り上がりませんでした！　本当に感謝してま\nす、大好きです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022060003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「い……いくら褒めても、こんなことは今回限りです。いつも頼られても困り\nます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010022060003" ]},
		{"command":[ "SETCHARA", "0", "char_00000512_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ええっ！？　そんなぁ……私はもっともーっとオボロさんと色んなことをし\nたいです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022060004" ]},
		{"command":[ "SETCHARA", "0", "char_00015702_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「私も……オボロさんのことをたくさん知りたくなってきたかも。仲良くして\n欲しいです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022060005" ]},
		{"command":[ "SETCHARA", "0", "char_00015802_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ううっ！　……であれば、機会があれば……ということで。はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010022060004" ]},
		{"command":[ "SETCHARA", "0", "char_00000512_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「どうにも、調子が崩されますです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010022060005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「可愛い妹分が出来て良かったじゃねーか。めでたしめでたし」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「イベントも大成功だったんだし、そろそろ解散しよーぜ。いいよな？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ウチは構いませんが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010022060006" ]},
		{"command":[ "SETCHARA", "0", "char_00000512_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そそくさと帰り支度を始めるオボロから離れ、ロボっ娘２人はぐるんと俺の方\nを向いた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「……でも、まだやっていないことがありますよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022060005" ]},
		{"command":[ "SETCHARA", "0", "char_00015702_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんだそりゃ。それならもう一度本部に戻って……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「いいえ。外では出来ないことです。でも、一番大切なこと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022060006" ]},
		{"command":[ "SETCHARA", "0", "char_00015802_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「どういうことだ……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「それは、ご主人様へのトリック・オア・トリートです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022060006" ]},
		{"command":[ "SETCHARA", "0", "char_00015702_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お、俺にもやるつもりなのか、アレを！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ええ、そうです。いくよ、姉さん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022060007" ]},
		{"command":[ "SETCHARA", "0", "char_00015802_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「うんうん！　やろうやろう！　声を合わせて～……にゃふふふっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022060007" ]},
		{"command":[ "SETCHARA", "0", "char_00015702_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ご主人さま、『トリック・オア・トリート』です♪」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00015702_01", "4", "CENTER", "-400" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022060008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ご主人さま、『トリック・オア・トリート』です♪」", "NORMAL" ]},
		{"command":[ "SETCHARA", "1", "char_00015802_01", "8", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "PLAYVOICE", "v2_158_010022060008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「いたずらしてほしいですか～？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00015702_01", "9", "CENTER", "-400" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022060009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「……それとも、いたずらしますか？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "1", "char_00015802_01", "9", "CENTER", "400" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022060009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「俺には菓子を渡す選択肢は無いってか！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「正解。ご主人、黙ってイタズラされてください」", "NORMAL" ]},
		{"command":[ "SETCHARA", "1", "char_00015802_01", "8", "CENTER", "400" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022060010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「これが楽しみで、いっぱいいっぱいお洒落したんですよ～！　たっぷり甘え\nます～！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00015702_01", "4", "CENTER", "-400" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022060010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「それそれそれそれ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022060011" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふにゃふにゃふにゃふ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022060011" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「た、助けてくれっ、オボロ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「…………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010022060007" ]},
		{"command":[ "SETCHARA", "0", "char_00000512_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ロボ２匹はさすがに受け止めきれな……ぐえええええ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「モテて良かったじゃないですか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010022060008" ]},
		{"command":[ "SETCHARA", "0", "char_00000512_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "プイっとそっぽを向いたオボロは、それからじわじわとこちらに視線を送って\nきた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「……そ、そうですね。どうせそれだけモテているのなら……。私が１人増え\nてもさしたる影響はないでしょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010022060009" ]},
		{"command":[ "SETCHARA", "0", "char_00000512_01", "2", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「な、なんだって！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「せっかく、彼女たちがあなたを捕縛してくれているのです。あの質問をする\nには好機です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010022060010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「トリック・オア・トリート？　さあ、ウチに供物を捧げるか……それとも呪\n術の生贄となるか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010022060011" ]},
		{"command":[ "SETCHARA", "0", "char_00000512_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「２つに１つです。あなたは、どちらを選ぶのですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010022060012" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「それは……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「それは？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010022060013" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「それは、なんなのです。はっきりしませんね……。大きな声で言ってくださ\nい。さあ。さあさあさあ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010022060014" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "俺はじりじりとにじり寄って来るオボロに、生命の危機を感じた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ど、どっちもごめんだ～～～～！！　離せ、ロッテクララ！　俺は逃げーる\nっ！！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「クックッ、ここまで来て、獲物を逃がすウチではないですよ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010022060015" ]},
		{"command":[ "SETCHARA", "0", "char_00000512_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ひぃいいいいいっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ニンマリと、暗い微笑みを浮かべるオボロの魔の手から逃げる術は……無い。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ウチが今から本物の儀式というものを見せてあげますよ。ロボ姉妹」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010022060016" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「いいですねっ、興味津々です！　やりましょう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022060012" ]},
		{"command":[ "SETCHARA", "0", "char_00015702_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ロッテ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「大衆化されていない、本格的な儀式の始まり……。それを学ぶのも、またハ\nロウィンだよね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022060012" ]},
		{"command":[ "SETCHARA", "0", "char_00015802_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「クララ！　こいつの呪いはそんなハートフルなもんじゃないぞ！？　……ぐ\nえええっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ここからが、本当のハロウィン……。死霊と魔物による呪いの祭りです……\n♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010022060017" ]},
		{"command":[ "SETCHARA", "0", "char_00000512_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ぎゃー！　生きて明日の朝を迎えられる気がしねえーーっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「……闇の深淵に誘ってさしあげましょう。さあ、ロボ姉妹。こいつの腕を磔\nにするのです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010022060018" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ぎえええええ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「それから、死霊を集めるために……顔に、身体に、全身に呪いの呪文を書い\nていきますよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010022060019" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「へ～！　デンジャラスで素敵……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022060013" ]},
		{"command":[ "SETCHARA", "0", "char_00015802_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「く、くすぐったい！　筆が！　筆の先っちょが！　俺の身体を這いずり回る\nう！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「蝋燭も立てましょう。電気を消して……この世の災いを集めていきますよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010022060020" ]},
