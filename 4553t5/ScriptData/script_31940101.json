		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「んぁっ……！　貴方という者はぁっ……！　ワタクシの、ワタクシの高貴な\nる顔に好きなだけ汚濁を、精液を撒き散らして……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「でも……でも、本気で叱ることなぞできようもない……！　ワタクシが、こ\nの手で引きずり出した精液、これは愛しい子種汁なのだから……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0103303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「う、ぁ……♪　ああっ……こってりもったりとしたプルップルの白濁液……\n。そうか、そんなにもワタクシの顔にかけたかったのだな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0103304" ]},
		{"command":[ "SETIMAGE", "0", "still_00019401_01_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「貴方はなんと愚かな人間だ……。でも……。くぅうう……♪　ワタクシはそ\nんなところすら、見れば胸が疼く、ときめいてしまう……ああ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0103305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「この……この魔性め……！　悪いのはこのチンポか？　それとも貴方か？　\nはぁっ……はぁああ……♪　この、鼻につく臭い臭い、精液の香り……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0103306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「悪くない……♪　いや、悪くないどころではない……。うう♪　はっきりと\n好きになってしまった、貴方のこれが……子種が……♪　はぁああ♪」", "NORMAL" ]},
