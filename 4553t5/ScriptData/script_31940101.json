		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「んふっ……？　ンンッ……！？　な、なにっ……？　胸……身体にぃっ……\n！？」", "NORMAL" ]},
