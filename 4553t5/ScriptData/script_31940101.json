{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「……これだけ夜が更けても、まだ眠っていなかったのだな。少しいいか？　\n貴方に話しておきたいことがある。それはとても、大切なことだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0103101" ]},
		{"command":[ "SETCHARA", "0", "char_00019401_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「貴方と過ごし、ワタクシは１つ決めたことがある。それはワタクシが……貴\n方を篭絡し、虜にして自分のモノにするということ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0103102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「……ん？　まだよくわからないか？　今宵、ワタクシは貴方にこうして夜這\nいをして……既成事実を作り、結ばれる算段をつけたのだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0103103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「まさか、断るなどということはあるまい。さて……せっかくの記念の夜だ。\n貴方の好きなようにしてやるが、何かリクエストはあるか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0103104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「……ボニューデマクールで授乳手コキ？　な、なんだそれは……。何一つ単\n語が頭に入ってこない。うむ。母乳が出る薬を服用して、胸で……うむ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0103105" ]},
		{"command":[ "SETCHARA", "0", "char_00019401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「なるほど、そうやって、貴方のモノをシゴいて射精させればよいのだな？　\nわかった。ならば、飲もう。その不思議な薬とやらを……こちらによこせ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0103106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「ごくっ……。……ん……。本当に、こんなもので母乳が出るようになるのか\n？　まあ、いい。効き目が出る前に貴方も下半身をまろび出せ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0103107" ]},
		{"command":[ "SETCHARA", "0", "char_00019401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「……ああ、そうだ。下着は全て脱ぎ捨てて……。ワタクシの乳房に顔を包ま\nれるのだ。っん……その、なんだ……これは……少々滑稽な姿、だな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0103108" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00019401_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「ククク……♪　貴方はワタクシとこんなことがしたかったのか？　人間とは\n、なんと予想を覆す、不可解な生き物か……。んん？　これが嬉しいのか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「ワタクシの豊満な乳房に顔を覆われ、己の肉の棒を手で握られ……。そのポ\nーズでは、もうろくに抵抗することも叶わぬだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「ワタクシに主導権を譲り渡し……。まるで赤ん坊のように甘えたいと申すの\nか。そんなリクエストをして、まったく……恥ずかしいやつだ。ふふふふ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0103111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「それ……。好きなだけ吸えばいい……。なんだ、今更恥ずかしがるな。乳首\nを口に含んで……。ふぅっ……そうだ、音をたてて吸うんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0103112" ]},
		{"command":[ "SETIMAGE", "0", "still_00019401_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「ちゅぷ、ちゅぷ、くちゅ、くちゅ……。ンン……♪　弱く吸うな、くすぐっ\nたい……舌を絡めて、ひっぱるくらいに強く……。ああ、上手いぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「はぁ……うぅ……っ。んん……♪　ふふふ……。なんだか、おかしな感覚だ\n……。これが子に乳を与える母の感覚、なのだろうか……。んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「よしよしよし……。そんなに慌てるな。ワタクシの胸は逃げはしない……。\n貴方は乳吸いだけでなく、手コキも所望していただろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0103115" ]},
		{"command":[ "SETIMAGE", "0", "still_00019401_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「今からじっくりとチンポをいじってやるからな……。と、す、すごい大きさ\nだな……貴方のチンポは。想像していたモノより随分と硬く、重い……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「少し汗ばんでいるせいか、ピトピトとワタクシの手のひらにくっついて……\n離れようとしない。これを……握って……上下にシゴく……。ん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「あぁ……♪　ビクビク反応している……。そうか、そうか……そんなにもワ\nタクシの乳と手が好きか。それなら存分にサービスしてやろう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0103118" ]},
		{"command":[ "SETIMAGE", "0", "still_00019401_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「しかし、多少もたつくのは許せ……。ん、なにぶん、一度に掴みきれぬほど\nにチンポが立派で……手から逃げてしまいそうなのだ。強く握るぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「っふ……♪　硬いな……♪　この肉竿を……中身の詰まったチンポ全体を、\n手で愛撫して……リズミカルに刺激していく……。ふぅっ、ふ、ふぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「あ、ああ……なんとなくわかってきた……。この硬い芯のような部分を中心\nに、包皮を動かして……。あっ♪　またピクピクと反応して……フフ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「見た目は大層グロテスクなのに、チンポというものは素直でひょうきんなヤ\nツなのだなぁ。ワタクシの手の動き１つ１つに喜んでみせて……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「んん……？　この、裏筋も感じるのか？　フフ……いいぞ。すりすりと指の\n腹でなぞってやる……。はぁ、はぁ……それから竿の部分……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0103123" ]},
		{"command":[ "SETIMAGE", "0", "still_00019401_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「すごい弾力で、ワタクシの手を押し戻してくるチンポの力強さといったら…\n…♪　そうか、ここか……？　ここがいいのか……腰をあげよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「うむ……うむうむ♪　今度は亀頭に指を絡みつかせて……シコシコだ。フフ\nフ、この快楽に耐えられるか……？　くにゅくにゅと先端をもてあそび」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「同時に肉棒を翻弄する……♪　ああ……気持ちいいか。そうか……。チンポ\nも熱を帯びている。貴方は性感をこらえられないタイプのようだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「フフフ、様々な反応が見られて面白い。これなら永遠に、焦らして続けてや\nっても……。……ん？　むっ……？　む、胸が熱くなってきた……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「はぁっ……♪　んあぁああ……？　な、なんだこれは……！　も、もしやあ\nの薬……！　母乳が出るという表の効能の他に、裏で感度を操作して」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0103128" ]},
		{"command":[ "SETIMAGE", "0", "still_00019401_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「ワタ、クシの乳首と乳房……をぉ♪　感じやすくしているのではなかろうな\nぁっ……？　そ、そうでなければ説明がつかぬ……。あっ……こ、こんな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「たとえ貴方にむしゃぶりつかれているとはいえ……！　ワ、ワタクシが胸を\n舐められただけでここまで感じるのは、お、おかしい……。んぐぅうう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「んぉっ……！？　す、少し舌を……唇をゆるめよ！　こ、このままでは……\nワタクシは乳首だけで絶頂し……。っんぉおおおっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0103131" ]},
		{"command":[ "SETIMAGE", "0", "still_00019401_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「おぁふっ！？　あっ……！？　あああああっ……！　母乳っ……母乳はこう\nして溢れ出すのか！　圧倒的な快感と共に……！　んああああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0103132" ]},
		{"command":[ "SETIMAGE", "0", "still_00019401_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「にゅ、乳頭を母乳が通り過ぎる感覚ですら感じるッ……。んぁっ……！　う\nあっ……！　そんな……！　母乳の噴出が気持ち良いなどとぉ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「ンッ、おほっ……！？　んぉほっ……ふぁあっ！？　ま、マズい……っ！　\n想像よりも一段階快楽が強く……。んぉっ！？　ふぉおおっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0103134" ]},
		{"command":[ "SETIMAGE", "0", "still_00019401_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「んふっふぉおおっ……！　おおッ……♪　おっ……おおおぉ……！　あぁ…\n…！　ち、乳首が硬くなり、快感が倍増しになっていく、のに……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0103135" ]},
		{"command":[ "SETIMAGE", "0", "still_00019401_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「吸わせることがやめられぬ……！　んあっ！　そ、それに手を……！　チン\nポをこする手を止めることもできぬ、なぜ……なぜだ……。うぁああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0103136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「母乳っ……母乳吸われるとっ……飲まれると、貴方が愛しくてたまらなくな\nる！　おちんぽ可愛くてニギニギぎゅっぎゅしてやりたくなるぅうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0103137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「う……うぁあああ……！　すまぬ……っ、すまぬ……！　貴方のモノから精\n液をほとばしらせても、まだ足りぬ……まだ欲しい、快感が欲しい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0103138" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019401_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「あっあっあっ！　かわいそうに……！　ワタクシに無理やり射精させられて\n……！　でも、でも、ワタクシも母乳を撒き散らしているのだからっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「貴方と同じだ……っ。あっ♪　あっあっ……！　ワタクシは……ワタクシは\n、オチンポから出る精液のように、乳首、から母乳を射精しているぅう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「はぁああっ……♪　ああああっ！　ぴゅるぴゅる出したまま、止まらぬっ…\n…母乳が止まらぬ……！　貴方の精子と同じくらい出る、止められぬぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0103201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「っあああああ……！　ああ……！　き、気持ちがいい……！　あっあっあっ\n！　手のひらに熱いほとばしりを浴びながら、胸を貴方に押し当てて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「ぴゅっぴゅするのが大変に心地よいのだぁ……！　すまぬ……すまぬ、……\nあっ！　イク……っ、母乳でイ、く……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0103203" ]},
		{"command":[ "SETIMAGE", "0", "still_00019401_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「んふッ……♪　……ああああ……！　せ、せっかく既成事実として貴方がオ\nチンポミルクをびゅくびゅく排出してくれたというのに……すまない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0103204" ]},
		{"command":[ "SETIMAGE", "0", "still_00019401_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「ワ、ワタクシは自分の乳首母乳に夢中だった……。ンンっ……。立派な純白\nの子種汁を、これだけ出してくれたのに……ふがいない。許してくれ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0103205" ]},
		{"command":[ "SETIMAGE", "0", "still_00019401_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「詫びに、今度こそ……貴方を虜に出来るよう、努力して快楽を抑えて授乳手\nコキというものを頑張ろう。良いな？　もう一度……シゴいてゆくぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「はぁっ……。はぁ、はぁ……。うう……♪　ぬっちゃぬっちゃと、手のひら\n全体に……。指の股にまで絡みつく高濃度な粘液……愛おしい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0103207" ]},
		{"command":[ "SETIMAGE", "0", "still_00019401_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「ワ、ワタクシの母乳はどうだ……？　ほのかに甘い味がして、サラサラ……\n？　そ、そういうものなのか……いや、出すのは初めてだからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「ン……っ。い、言われてみればそうだな。母乳は赤子に与えるべきもの……\n。飲みやすく、美味でなければおかしい……。お……おいしいか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「そ、そう……か……。ンッ……♪　貴方の乳首の舐め方は……。はぁっ……\nはぁ、おしゃぶりを吸う子どもの、ようで……んぅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0103210" ]},
		{"command":[ "SETIMAGE", "0", "still_00019401_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「なぜだかなつかしく……。それっ、なのに……むずがゆくて、乳頭が熱くな\nってしまう……♪　はぁっ、はぁ……母乳、母乳が止まらない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「んん……！　こう、か……？　貴方はこうやって、苦しいくらいに乳房に押\nし潰されながら……っ。チンポをシコシコされるのが好きなのだな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「ふ……ぅっ……♪　いいぞ……。いくらでもシゴいてやる……！　胸だって\n、嫌というほど押し付けて……吸わせてやる、吸えっ……もっと強く！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「あぁっ……♪　あ、ぁ、あぁ……♪　はぁああ……♪　なんだ、この湧き出\nる愛おしさは……っ。あぁ……切ない、貴方が恋しい……っ」", "NORMAL" ]},
