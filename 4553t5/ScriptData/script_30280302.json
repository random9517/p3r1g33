{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002803_02_02" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「あ、あんたの言ってた、女幹部らしくなる特訓っていうのを実践してたら…\n…身体が火照って仕方ないんだけど……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0304101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「オマンコがずっと疼いて、オチンチン欲しくなってくるし……悪いけど、責\n任とってもらうわよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0304102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「なんでって……そりゃ、あんたのせいだからに決まってるでしょ！いいから\n、さっさとオチンチン出しなさい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0304103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「なによ……あんたも随分とやる気みたいね。オチンチン、すごく大きくなっ\nてるじゃない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0304104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「あんな風に誘われたら、誰だって勃起する……？ふーん……もしかして、あ\nんたって責められたり、迫られたりするのが好きなの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0304105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「そんなことないって顔してるけど、こんなにオチンチンカタくしてたら、説\n得力ないわよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0304106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「それにほら……軽くお尻で押してるだけなのに、さっきよりも大きくなって\nきてるし……んっ、あふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0304107" ]},
		{"command":[ "SETIMAGE", "0", "still_00002803_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「挿れずにスリスリするだけで……こんなにビクビクさせて……！責められる\nの、大好きって感じね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0304108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「はぁ……あっ、あふっ……！ほら……あたしにどうして欲しいのか、ちゃん\nと言いなさい……素直になれたら、ご褒美をあげるわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0304109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「どんなご褒美かって……そんなの、見ればわかるでしょ……！あたしのオマ\nンコに、挿れさせてあげるのよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0304110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「自分が挿れたいだけじゃないかって……そ、そんなことあるワケないでしょ\nう！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0304111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「あ、あんたがオチンチン挿れたそうにしてるから、挿れさせてあげるって言\nってるのよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0304112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「オマンコがトロトロになってるし、エッチな汁でベトベトになってるですっ\nて……？そ、それは、オチンチンのせいじゃなくて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0304113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「ああ、もう！いいから、さっさとどうして欲しいのか言いなさいよ！オチン\nチン挿れたいの！？挿れたくないの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0304114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「……最初から素直にそう言えばいいのよ……！それじゃ、挿れさせてあげる\nわ……あ、あたしのオマンコ、しっかり堪能しなさい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0304115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「あっ、はああぁ……！入って、きたぁ……！カタくて、熱いオチンチン……\n一気に、奥まで……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0304116" ]},
		{"command":[ "SETIMAGE", "0", "still_00002803_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「すごい……！子宮の入り口に先っぽが当たってるっ……！はぁ、ああっ……\n！挿れてるだけで、イッちゃいそう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0304117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「はあぁ、ああっ……な、なに……？動いて欲しいの……？そんなの、言われ\nなくてもわかってるわよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0304118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「あ、あたしの腰振りが気持ちいいからって……すぐにイッたら、許さないか\nら……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0304119" ]},
		{"command":[ "SETIMAGE", "0", "still_00002803_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「ちゃんと……お、オチンチン勃起させて……あ、あたしを満足させてよね…\n…！んっ、はああぁ……あっ、あっ……はあああぁん！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0304120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「ひっ、ああっ！やっ、あひゃあぁ……！？動き出したら、もっとカタくなっ\nて……お、奥にズンズン響くぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0304121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「こんなの、腰が勝手に動いちゃう……！お尻を叩きつけるみたいに、パンパ\nンしちゃうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0304122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「やっ、んひっ、ふぎゅううぅ……！か、カリでオマンコのヒダを引っ掻かな\nいでっ……！膣内のお肉がめくれて……んひぃ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0304123" ]},
		{"command":[ "SETIMAGE", "0", "still_00002803_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「ズルズルって、奥からお肉が引きずりだされてるみたいで……！あっ、ああ\nあぁ！気持ちいいっ！オマンコ気持ちいいぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0304124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「はあ、ああっ……！だ、ダメ……感じすぎて、身体にチカラが入らなくなっ\nちゃう……こんなに感じるなんて、聞いてない……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0304125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「女幹部らしくなる特訓っていうのは、性的に感じやすくなるモノですって…\n…？な、なによそれ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0304126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「じゃあ、こんなにオマンコが気持ちよくて……いっぱい動きたくなるのは、\nさっきの特訓のせいってこと……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0304127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「くううぅ……！あっ、はああぁ……！遠慮しないで動けって……動きたくて\nも、感じすぎて動きにくいのよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0304128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「あっ、んひっ！？ふっ、あああぁ……！？ちょ、ちょっと！勝手に腰を動か\nすなんて……ひぎいいいぃ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0304129" ]},
		{"command":[ "SETIMAGE", "0", "still_00002803_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「やああぁ！あんたの動きに合わせて、勝手に身体が動くぅ！オマンコの奥ま\nでオチンチンが届くように、腰を打ち付けちゃうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0304130" ]},
		{"command":[ "SETIMAGE", "0", "still_00002803_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「うあっ、あっ、はふっ！あっあっ！気持ちいいっ！オマンコパンパンするの\n、たまらないのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0304131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「こんなの、すぐにイッちゃうからぁ！あっ、あっ！やああっ、お、奥からす\nごいのきてるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0304132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「ふぎっ、はっ、んはぁあぁん！？オチンチンも震えてるっ……！あ、あんた\nもイキそうなのね……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0304133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「な、なら……あたしのタイミングに合わせて、あんたもイッて……！子宮に\n精子、流し込んでっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0304134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「あっ、あっ！イクッ、イクぅ！あっ、んんんっ！出してっ！精子出してっ！\nあたしイクから、今すぐ精子注ぎ込んでえええぇ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0304135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「くああああぁ……！あっ、あっ……！？奥に精液がドクドク流れ込んでくる\nぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0304136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002803_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「いつもの膣内出しより……気持ちいいっ……！あ、頭が変になりそうなぐら\nい感じるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0304137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「これも、さっきの特訓のせいなの……！？あっ、あひっ……！んぐっ、ふう\nううぅ……！あっ、あっ！また、イクぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0304138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「お、女幹部はエッチじゃないといけないって……！こ、このアクレイジョー\nの姿は、本当のあたしじゃなくて……ひぎっ、んひぃ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0304139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「やっ、ああああぁ……！ダメっ……！こんなの、あたしの心が本当に悪に染\nまっちゃう……！あっ、あっ……いああああぁ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0304140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「あ、あたしは正義のヒロインで……女幹部なんかじゃないのに……悪に染ま\nったら、ダメなのにぃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0304201" ]},
		{"command":[ "SETIMAGE", "0", "still_00002803_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「やっ、あひっ……！んんっ、もっと……欲しい……！もっと、エッチしたい\nっ……！セックス、我慢できないっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0304202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「オマンコの疼きが全然治まらないのっ……！あんなんじゃ、全然足りない…\n…！もっと激しく、オチンチンズポズポしたいぃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0304203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「ね、ねえ……！もっとしていい……！？膣内出しオマンコ、オチンチンでか\nき回していい……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0304204" ]},
		{"command":[ "SETIMAGE", "0", "still_00002803_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「好きにしていいのね……！？なら、さっきより激しく動くから……！いっぱ\nい、感じさせて……はああぁ、あっ、あっ！ああああぁん！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0304205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「ああああぁーーー！気持ちいいっ！気持ちいいぃ！膣内出しされてビンカン\nになってるオマンコ、オチンチンでほじるの気持ちよすぎるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0304206" ]},
		{"command":[ "SETIMAGE", "0", "still_00002803_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「さっきよりも深くオチンチンが届いて……！ああぁ、子宮の周り、どんどん\n突いてくるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0304207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「オチンチンと子宮口がキスするの、たまらないのっ！子宮に出された精子、\n逆流しないように蓋をしてるみたいで最高だわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0304208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「そ、それに……んっ、んんんっ……！こうやって、オチンチン締め付けると\n……オチンチンの感触が、もっと伝わってきて……ふぐぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0304209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「この状態でズポズポすると、オマンコのお肉がゴリゴリ抉られて、気が狂い\nそうになるのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0304210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「んはっ、あっ、ひぎぃ！おっ、おおおぉ……！？き、亀頭がＧスポットに当\nたるのも、たまらないわっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0304211" ]},
		{"command":[ "SETIMAGE", "0", "still_00002803_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「奥とＧスポットを交互にズリズリして、オチンチンを当てると……んんっ！\nえ、エッチなお汁が止まらなくなるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0304212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「あたしのオマンコ、あんたのザーメンと愛液でグチャグチャの、ドロドロに\nなってるのぉ！滑りまくって、気持ちいいのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0304213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「あ、あんたも気持ちいいでしょ！？こんなにいっぱい動いてもらえて、幸せ\nでしょ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0304214" ]},
		{"command":[ "SETIMAGE", "0", "still_00002803_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「ひぎっ、んんっ！あっ、ああぁあぁ……！？な、なんで……！？し、子宮口\nにオチンチン刺さってるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0304215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「おっ、んおおぉ……！ふっ、んぐっ……あああぁ……！く、口じゃなくて、\nオチンチンで返事するなんて卑怯だわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0304216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「こんなの……また、すぐにイッちゃうぅ……！あっ、あっ……！もうすぐそ\nこまで、気持ちいいのきてるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0304217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「ま、また一緒にイッて……！今度は膣内じゃなくて、好きなとこに出してい\nいから、あたしとイッてぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0304218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「膣内で出して孕ませてもいいし、膣外に出して穢してもいいからぁ！あんた\nの好きにしていいからぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0304219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「あっ、あっ！イクッ！イクッ！イクぅぅぅ！！出して、出してっ！ザーメン\n出してえええええぇぇぇーーーーー！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0304220" ]},
		{"command":[ "SETIMAGE", "0", "still_00002803_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「あ、熱いの出てるぅ！また膣内に出されて、子宮の奥に届いてるぅ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0304301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002803_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「やっ、んぐっ！だ、ダメッ！イッてるのに、また気持ちいいのどんどんきて\n……！あっ、ああああぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0304302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「な、なにこれっ！何回イけばいいのっ！？オマンコがあたたくて、イクの止\nめらないっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0304303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「怖いっ！怖いぃ！イキすぎて、変になっちゃうっ！あたしの身体、エッチに\nなりすぎちゃうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0304304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「やあああぁ！またイクッ！イクぅぅぅ！！ザーメン感じながら、イクううう\nううんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0304305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「あっ……あっ……あはあぁ……気が狂いそうになるぐらい……気持ちよかっ\nたわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0304306" ]},
		{"command":[ "SETIMAGE", "0", "still_00002803_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「あの特訓のせいで、こんなに感じるようになったなら……他の女幹部の人も\n、こんな感じでイキまくってるのね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0304307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「……え？あたしに教えた特訓は、別に女幹部らしくなるワケじゃない？単に\n性感を強めるだけの、エッチな特訓……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0304308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「それにイキまくったのは、あたしがエッチなだけ……？な、ななな、なによ\nそれっ！そんなの、あたしがエッチ大好きな変態みたいじゃない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0304309" ]},
		{"command":[ "SETIMAGE", "0", "still_00002803_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「……みたいじゃなくて、エッチ大好きな変態？そ、そんな適当なこと言う人\nには、罰として強制絶頂の刑よ！覚悟しなさい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0304310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「お、オチンチンが抜けて……ふあああぁ！？やっ、ああっ！オマンコからオ\nチンチンが抜ける感覚、すごく気持ちいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0304401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002803_02_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「それに……ひぐっ、んんっ！あっ、ひゃううぅ！？あ、熱いザーメンが身体\nにかかって……はああぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0304402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「身体の外から子宮に精液浴びせられてるみたいで……！あっ、あっ！か、身\n体が勝手に反応して、子宮が疼いてくるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0304403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「やああぁ！気持ちいいのとまらないっ！こんなの、またイッちゃうっ！あた\nしの身体、どんどんエッチになって……ひあああぁん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0304404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「あっ、あっ！？ダメっ！もうなにも考えられないっ！気持ちいいことしか、\n考えられなくなるぅ！あっ、んああぁ！んはあああぁぁぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0304405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「はあ、はあぁ……今までの価値観が変わるぐらい、すごく気持ちいいイキ方\nしたわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0304406" ]},
		{"command":[ "SETIMAGE", "0", "still_00002803_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「こんなにエッチになるなんて……なんだか、本当に悪のヒロインに染まって\nるみたいね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0304407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「ねえ……あんたは、正義のヒロインなあたしと、悪のヒロインなあたし……\nどっちが好き？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0304408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「どっちかなんて選べない……？ふーん。そういう逃げ方するのね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0304409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「なら、どっちか選ぶまで、もっと射精させてあげるっ！それがイヤなら、干\nからびる前にさっさと結論を出しなさいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0304410" ]},
		{"command":[ "SETIMAGE", "0", "still_00002803_02_12" ]},
