		{"command":[ "PLAYVOICE", "086_0103101" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「……エアルミン、参上しました。……うっ……なんですか、この部屋は……\n。不快な臭いがします……。嫌な感じです……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00008601_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "SPOTCHARA", "0" ] },
