		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0103102" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「ニンゲンと二人きりになることなど、本当はありえないのですが。貴方は例\n外です。少しは優しくしてあげようと思いましたが……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0103103" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「逢瀬の場所としては、ここは最悪ですね。それで？　ここで紅茶でも飲むの\nですか？　……え？　ご奉仕をしてもらう……？　奉仕……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0103104" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「私が貴方に奉仕させるのではなく、貴方に私が奉仕をするのですか！？　し\n、信じられない……。帰らせていただきます！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00008601_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0103105" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「……え？　これはただいやらしいだけの行為ではない……？　どういうこと\nです。この場で貴方に奉仕をすることで、秘められた力が解放される……？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00008601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0103106" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「ああ。魔術の類ですか。だから、こんなに陰気な雰囲気なのですね……。パ\nワーアップ……正直、私に必要ないとは思いますが……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00008601_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0103107" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「今は、世界の危機が目前に迫る有事。可能な限りの手段は全て試すべきでし\nょうね。……わかりました、やるだけやってみましょう」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0103108" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「ですが、私はニンゲンの奉仕とやらを知りません。わかりやすく説明なさい\n。……ええ。ええ、なるほど……私の胸を使って……って」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0103109" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「っああっ！？　こ、これはどういうことなのですっ！？　いやっ！　私の衣\nを剥ぎ取って……あまつさえ、乳房にペニッ、ペニスを挿入するなんて！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00008601_01_01" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0103110" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「い、いやっ、いやあああっ！　恥を知りなさい！！　やはり下賤なニンゲン\nなど信用するのではありませんでした！　あ、あああ、いや、いやぁ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0103111" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「早く抜きなさい！！　神聖なるハイエルフの胸に……ニ、ニンゲンのおぞま\nしいペニスを差し入れるなんて……貴方は獣にも劣る畜生ね！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0103112" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「う、ううう……！　気持ち悪い……！　こんなものを私の肌にくっつけるな\nんて！　信じられませんっ……早く抜きなさい！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0103113" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「……なん、ですって……？　そんなに私が言うのなら早く抜いてやる……？\n　えっ！？　ど、どういうことです！？　なぜ胸を揉むのですっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00008601_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0103114" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「ペニスを引き抜けと言っているのですっ！　あっ！　私の胸を自由にしてい\nいと言ったわけでは……んんんっ！　言葉が通じないの！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0103115" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「あっ、私の胸っ、乳房を寄せてペニスを包みこまないでっ……！　それにっ\n……んひっ！　谷間で動くのはおやめなさいっ、やめ、やめなさいぃっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00008601_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0103116" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「ああっ……あっあっあっ、い、いやぁ……いや……ッ、やめ、やめ……て…\n…ああ……！　んぐっ、んんん……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0103117" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「どうしてこんなわけのわからないことを、するの……っ！　男性器を豊穣の\n象徴である乳房に挟み、慰めるなんて……ああっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0103118" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「我が種族への……いいえっ、女性への冒涜ですっ……！　む、胸は赤ちゃん\nにお乳をあげるためのも、の……んんん！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0103119" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「貴方が劣情を癒す場所ではないのに……っ！　あふっ……ちょっと！　強く\n掴まないでぇ……ッ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0103120" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「あうっ……うっ、ううっ……ああ……！　だめ、そんなに左右に胸を揺らし\nたら……ああ……、んっ、ぁっ、ああっ、ああ……んん！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0103121" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「じょ、上下に動かすのもダメですっ……！　方向性の問題ではないのよっ！\n　ああッ……乱暴に、乱暴にたぷたぷ弾まされて……ンンっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0103122" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「あっんッ！　んっ、んん……！　乳房は敏感な肌なんですっ！　もっと優し\nく……ふぁああ、できないのですか……！　あっ、痛い、痛い……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0103123" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「ちぎれてしまうわ……っ！　あっ！　そんな、強引に動かしたこと、な、無\nいからっ……ああ……！　んんん、信じられないぃ……っ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0103124" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「はぅ！？　んっ、んんぁっ……はぁ、はぁっ、はぁ、はぁ……ああ……！　\nんもうっ……！　あっ！　はぁっ！　はぁっ、はぁ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0103125" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「どういうこと……？　胸が、だんだん熱を帯びて……はぁっ……！　貴方の\nペニスにまとわりついていくよう……。ああ、と、とろけて……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00008601_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0103126" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「とろけて柔らかく、なっているみたい……。それに……んんんっ！　貴方が\n手で触れているところが……疼いて……はぁっ、もどかしい……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0103127" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「胸全体を女性器に変えられているみたいで……！　ねえ、こ、これはパワー\nアップしているからそう感じるの！？　それとも……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0103128" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「あっ！　貴方の手で……こねられて、ほぐされて……。わ、私の高貴な乳房\nが、ニンゲンの性処理のために変質させられているの……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0103129" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「わからない、わからない……っ！　は、ぁ……ッ、理解不能ですっ……！　\nこんな用途に胸を使う、なんて、想像もしたことがなかったのに……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0103130" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「貴方は平然と……んぁあッ、当然のように胸にペニスをこすりつけて……！\n　はうっ！　ニ、ニンゲンは皆これをするのですか！？　それとも……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0103131" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「あ、貴方がとびきりの変態なのですか！？　っくぅうっ……はぅ、うう……\nうう……うううう……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0103132" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「あっ！？　あっ、そのっ……ズリズリするのっ、やめていただけませんか…\n…あっ、腰、動かさないで！　速いっ、速いですからぁっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00008601_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0103133" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「っあああっ！　な、なぜどんどん加速させるのです！　あっ！　いやっ！　\n待って！　なんだかペニスが肥大化してきて……あっあっいやっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0103134" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「で、出る！？　出るとはなんです！？　何が出るのです！？　あッ！　やめ\nなさい！　私の胸を寄せるのはやめて……やめっ、ああああっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00008601_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0103135" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「何も出さないでっ、わけのわからないことを言わない、でぇええ……！　あ\nッ！？　あっ！　私の胸、私の胸を変なことに使わないで、って、あっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0103136" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「んっ、んんんん！？　きゃあああ！？　何っ……なんですこれぇっ！　あ、\nああああ……何かが！　何かが私の胸の中にっ……！」", "NORMAL" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00008601_01_06" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0103137" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「いやっ、いや、いやあああああ！　えっ！？　体液！？　ニンゲンの体液を\n注がれているのですか！？　私の聖なる胸が！？　嘘でしょう！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0103138" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「う、ううう……！？　くさ、い……それにドロドロと……！　あ、ああ……\n許可もしていないのに、体液を流すなんて……ああああ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0103139" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「あ、貴方……これは魔術ではなく私の胸との疑似交尾ではないのっ！　昆虫\nか何かですか貴方はっ！　う、ううう……汚された……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0103140" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「もう許しません！　どきなさいっ！　貴方は私が粛清しま……って、いやあ\nああっ！　乳首っ、乳首をつまむのはやめなさい！！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00008601_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0103201" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「っ……ううう……、はぁ、はぁ、あ、あ、あ、あ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0103202" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「あひ……ひぅうっ、んひぃいい……！　乳首、乳首をコリコリするのはやめ\n、て……ぇええ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0103203" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「ち、乳房をもてあそばせてあげただけでもありがたく思ってほしいくらい、\nなのに……、んっ、ぁあ……突起までいじるとは何事です……ぅう……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0103204" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「そこ、そこは弱いのです！　あっ……敏感すぎて……自分でもほとんど触っ\nたことがない、のに……あっあっ、ニンゲンふぜいが……んぁああっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00008601_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0103205" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「だ……め……だめ……だめぇ……ッ！　これ以上されたら……されたらおか\nしくなっちゃ……んぐぅっ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0103206" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「くぅうう……！　うう、ううううーっ……！　こ、殺されたいのですかっ…\n…やめろと言っているのに……んんんんんーッ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0103207" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「んはぁああっ！　あっあああっ……！　あふっ……あっ、んんぅっ、んんー\nっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0103208" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「な、何？　腰が動いている？　ばっ……馬鹿っ！　そんなわけ、ないでしょ\nう……ニンゲンの、ニンゲンのオスのテクニックなんか、で……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00008601_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0103209" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「ハイエルフの私がぁっ……腰振りしているというのですかぁ！？　ペニスを\n欲しがって……あっ、む、胸だけでなくペニスを欲していると！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0103210" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「ざ……戯言……戯言です……！　んはぁっ！？　ああっ、ああ……！　急に\n乳首ひっぱらないでぇっ……！　あっ！　いやぁっ、いやぁあっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00008601_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0103211" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「素直になれないハイエルフへのお仕置き……？　お、愚かなぁっ！　私は感\nじてなんか……！　んぃいいっ！　だから乳首やめてぇええっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0103212" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「やめ……あっ！　あっ、やめ……んんんんぅっ！　そう、そうですっ！　乳\n首感じます！　感じるからもうつねらないでぇ……駄目なのですぅ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0103213" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「せ、世界っ、世界を救うっ、ためっ！　ここに来た、のに……！　あぅああ\nあっ！　乳首いじられて絶頂、なんて……乳房使われてイく、なんて……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0103214" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「絶対嫌ですっ！　いやっ……い、いやっ♪　なの、にっ♪　おおおひっ♪　\nニンゲンに乳首ぃっ♪　クニクニされてると思うと……あひあひぃっ♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0103215" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「現実離れした快感が、ぁっ♪　おおぉっ♪　胸とアソコの両方に蓄積されて\n……ああ！　ああ！　もっと嬲られたくなってしまうぅうっ♪」", "NORMAL" ]},
