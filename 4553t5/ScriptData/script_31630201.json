{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「来たか。忙しいところをわざわざ呼びつけて悪かったな。うむ、お前にしか \n頼めない用事があってな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0203101" ]},
		{"command":[ "SETCHARA", "0", "char_00016302_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「私が強化改造を受けたのは知っての通りだが、色々成長はしたものの、ちょ \nっと新たな悩みができてしまってな……肩が凝るのだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0203102" ]},
		{"command":[ "SETCHARA", "0", "char_00016302_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「そうだ。頼みというのは他でもない、お前にオッパイをマッサージして欲し \nいのだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0203103" ]},
		{"command":[ "SETCHARA", "0", "char_00016302_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「別に戸惑うこともないだろう？　手でもいいし、チンポを使ってもいいぞ。 \nつまり、お前の好きにしていいんだ……どうだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0203104" ]},
		{"command":[ "SETCHARA", "0", "char_00016302_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「ふふん……目の色が変わったな。さあ、善は急げというのだろう？　どんな \n風にしてくれるんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0203105" ]},
		{"command":[ "SETCHARA", "0", "char_00016302_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「んんっ……なるほど、こうやって……上から覆い被さるようにするのが好き \nということか。いいぞ……ここからどうする？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0203106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016302_01_01" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……鷲掴みにして……ぐいぐいと揉みしだく……どうだ、強化改 \n造を受けたオッパイは？　大きさも柔らかさも一味違うだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0203107" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「強く握れば……弾力を残しながら柔らかい感触を伝えて……その力加減は… \n…私の意識にもしっかりと快感として届く……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0203108" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「ぎゅっと挟まれたチンポの感触と……こうやって揉まれる感覚……全部伝わ \nって気持ちいいぞ……んっ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0203109" ]},
		{"command":[ "SETIMAGE", "0", "still_00016302_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「柔らかいか……つきたての餅のよう？　ふむ……食べ物に例えたのか……よ \nく分からんが、とにかく柔らかいということで間違いないんだな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0203110" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「うむ、悪い気はしないぞ……弾力を楽しむような動きをもっとしてみせてく \nれ……ああ、今の調子で悪くない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0203111" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「そのままもっと強く揉んで……チンポもいっぱい擦り付けて欲しい……私の \nオッパイを犯す気分でやってみたらどうだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0203112" ]},
		{"command":[ "SETIMAGE", "0", "still_00016302_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「あふっ……！　そうだ……少しくらい強くても……んんっ、この柔らかさで \n柔軟に力を吸収してしまうからな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0203113" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「お前の、いやらしい欲望を……このオッパイに遠慮なくぶつけてみせろ。も \nっと好きなように動かすんだ……はぁっ、んっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0203114" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「はぁっ……んっ、いいぞ……チンポのうねりを感じる……少し強くされる位 \nの方が……私の好みかも知れない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0203115" ]},
		{"command":[ "SETIMAGE", "0", "still_00016302_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「あっ、ふっ……今の言葉でまたそわそわしたのか？　チンポが落ち着かない \nぞ、いやらしいやつめ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0203116" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「もちろん褒めているんだぞ？　それくらい性に貪欲でないと、こんなことも \n頼めないからな……遠慮なく腰を振ってオッパイを犯すといい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0203117" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「あぁっ、んふっ、そうだ……こういう疑似セックスを思いつくのは、本当に \n地球人の面白いところだな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0203118" ]},
		{"command":[ "SETIMAGE", "0", "still_00016302_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「それとも、お前が特別なだけか……？　んっ、何にせよ……このパイズリマ \nッサージ、私の興奮を掻き立てるにはとてもいいやり方だ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0203119" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「はぁっ、んっ……あっ、乳首……んんっ……！　そこっ……あっ、ぎゅっと \n摘んでみてくれ……はぁぁんっ、そ、それっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0203120" ]},
		{"command":[ "SETIMAGE", "0", "still_00016302_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「感度は良くなっていると思ったが……お前にされると……思っている以上に \n……気持ち……いいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0203121" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「はぁっ、んふっ、効くっ……んんっ、膨らんだチンポのマッサージ……いい \nっ、具合だ……んぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0203122" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「んっ、乳首がぷっくり膨らんで……あぁっ、ぎゅっと引っ張られて……くい \nくい回されてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0203123" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「まるで、おもちゃのように……弄り回されると……切ない感覚が全身に広が \nっていくぅ……んふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0203124" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「肩こり……？　んんっ、そうだ……これは、一応肩こりの為のマッサージだ \nからな。だが、それでオッパイが気持ちよくなるのは仕方ないことだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0203125" ]},
		{"command":[ "SETIMAGE", "0", "still_00016302_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「そういうお前はどうなんだ？　私のオッパイの中にチンポを突っ込んで…… \nかなり気持ちよくなっているんじゃないか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0203126" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「心拍数の上昇、汗の浮き方、口から漏れる乱れた呼吸……お前の全身が興奮 \nに染まっていることを知らせて来ている……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0203127" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「よし……私も少しオッパイを動かしてやる……んんっ、お前の弱いところは \nどこだろうな……当然先端は敏感だが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0203128" ]},
		{"command":[ "SETIMAGE", "0", "still_00016302_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「おっ……この、根元の方も……少し声が出てくるじゃないか……何、金玉に \n当たるから……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0203129" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「そうか、確かにこれ以上分かりやすい弱点はないな。うむ、つまりここをも \nっとして欲しいと、そういうことだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0203130" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「ぎゅっと寄せて……どうした、腰が止まってしまったぞ？　力が抜けてしま \nうのか？　ほら、どうした？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0203131" ]},
		{"command":[ "SETIMAGE", "0", "still_00016302_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「んんっ……！？　あっ、ふっ……また、乳首……んっ、これがお返しという \n……訳か……面白い……どちらが弱い場所なのか……だなっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0203132" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「はっ、うんっ……！　あっ……爪がめり込むっ、食い込むぅっ……！　これ \nが……お前の本気の動き……んぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0203133" ]},
		{"command":[ "SETIMAGE", "0", "still_00016302_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「んっくっ……はぁ、んっ、だが……お前も我慢汁が出て……もう少しでっ… \n…出るんだなっ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0203134" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「はふっ、んんっ……いいぞっ……一気に出せっ……！　私のオッパイにっ… \n…熱いのっ……出せぇっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0203135" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「んんんんんんっ……！　はふぁっ……出たっ……熱いの……オッパイにいっ \nぱい出たぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0203136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016302_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「んんっ……はぁぁ……こんなにぃ……あっ、ふっ……止まらないでドプドプ \n……んうぅぅっ……あ、ひっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0203137" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「あぁ……んっ、イッた……イカされた……はぁぅ……んっ、乳首も良すぎて \n……オッパイでイカされた……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0203138" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「んふぅ……谷間が精液まみれでドロドロだ……はふぅ……んんっ、くぅ…… \nはぁぁ……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0203139" ]},
		{"command":[ "SETIMAGE", "0", "still_00016302_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「すごい勢いだったな……あぁ、最後は一気に持っていかれたような……そん \nな気分だったぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0203140" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……それにしても、一応私は強化改造を受けた筈なんだがな…… \nこのオッパイの感度は……前より弱くなったのではないか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0203201" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「いや、感度がよくなった……そう捉えれば、強化……なのか？　よりエッチ \nにされてしまったと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0203202" ]},
		{"command":[ "SETIMAGE", "0", "still_00016302_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「まあ、そうなってしまったものは仕方ない。受け入れるしかないからな。つ \nまり……もっとマッサージが必要だということだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0203203" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「お前のチンポも硬いままだしな。さあ、存分に続きを頼む。もっと私のオッ \nパイをこね回していいぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0203204" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「はっ、ふっ……！　んんっ、くぅっ……そうだ、もう力加減も十分把握した \nだろう。さっき出た精液で、滑りも申し分ないからな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0203205" ]},
		{"command":[ "SETIMAGE", "0", "still_00016302_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「オッパイの谷間を……んっ、ぎゅっと狭めて……チンポが通り抜けるだけで \nもよく感じるようにさせて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0203206" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「オマンコを犯すように……腰を振るっ……！　そうだっ、はぁんっ、不思議 \nな感覚だ……確かに私のオッパイなのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0203207" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「オッパイが……オマンコのようになってしまったような……心地よさが広が \nっていく……んくぅっ、はっ、んふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0203208" ]},
		{"command":[ "SETIMAGE", "0", "still_00016302_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、剥き出しのチンポが熱い……体温で言えばそこまででもない \n筈なのに……この熱はどういうことだ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0203209" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「私の興奮が……させていることなのか……？　そうかも知れない……身体を \n密着させることで体感温度も上がっているのか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0203210" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「はぁ……中でチンポがビクビクしている……気持ちいいんだな……その感覚 \nを共有出来ている感じが心地いいのか……あふっ……んくっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0203211" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「あぁ……また乳首もして欲しい……指で転がすようにして……時々、ぎゅっ \nと……強く摘んでっ……引っ張って、欲しいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0203212" ]},
		{"command":[ "SETIMAGE", "0", "still_00016302_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「はっ、んんんっ！　あっ、それだっ……んっ、ふっ……！　ビクビクしてし \nまうっ、このっ、気持ちいいのがっ、ビクってっ……なるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0203213" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「あっ……チンポが飛び出して……んんっ、乳首に擦れるぅ……亀頭で、あっ \n、ツンツン……突っついて……ひぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0203214" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「これ、はっ……偶然じゃないな？　わざと擦れるようにしてっ……んくぅっ \n、チンポで乳首を弄んで……はっ、んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0203215" ]},
		{"command":[ "SETIMAGE", "0", "still_00016302_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「だが……んっ、確かにこれは……気持ちいい……あぁっ、もう……私のオッ \nパイは、お前に完全にコントロールされてしまってる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0203216" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「いっぱい鷲掴みにされてっ……ぐにぐにこね回されてっ、チンポを押し付け \nられてっ……あぁっ、オッパイで……またイキそうになってしまうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0203217" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「んくぅっ、はっ、んんっ、お前のチンポも……震えてるのかっ？　はっ、ふ \nっ……また射精が近づいているんだなっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0203218" ]},
		{"command":[ "SETIMAGE", "0", "still_00016302_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「いいぞっ、あっ、ふっ……出してくれっ、またお前の濃厚なオスの体液をっ \n……私に思い切りぶち撒けてくれっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0203219" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「はぁんっ、乳首っ、またそこぉっ……！　くぅんっ、私もっ……絶頂するっ \n！　お前と一緒にイクぞっ、あっ、ひぁぁぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0203220" ]},
		{"command":[ "SETIMAGE", "0", "still_00016302_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「はぁぁぁっ……あぷっ……溢れ出してっ……またっ、オッパイの中が……熱 \nいので満たされていくぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0203301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016302_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「んぁぁ……オッパイが精液に浸されて……気持ちいい感覚が広がっていく… \n…ふぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0203302" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「ドプドプ出てくるな……んんっ、私のオッパイは、まんまとオナホールにさ \nれたという訳だ……は、ふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0203303" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「別に悪い意味ではないぞ。そうして欲しいと頼んだのは他ならぬ私だからな \n。肩こり……？　あぁ、そうだった肩こりマッサージだったな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0203304" ]},
		{"command":[ "SETIMAGE", "0", "still_00016302_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「あふっ……射精も落ち着いたか。うむ、たっぷり出してくれたお陰で、大分 \n肩凝りも解消されたような気がする」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0203305" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「因果関係が不明？　こういうのは気分の問題だ。それだけ、私のオッパイが \n欲求不満だったということだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0203306" ]},
		{"command":[ "SETIMAGE", "0", "still_00016302_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「お前のチンポも、たっぷり出して気持ちよかっただろう？　ならば細かいこ \nとはいいではないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0203307" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「それにしても、私を手籠めにするテクニック、さすがのものだったな。やは \nり、こういうことを頼むのはお前しかいない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0203308" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「また、肩が凝ることがあれば、頼むことになるかも知れん。その時は、好き \nなだけ私のオッパイを弄んでくれ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0203309" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「言い方？　ふむ……特に間違ったことは言ってないと思うが……お前のスケ \nベさを私は評価している。また楽しみにしているぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0203310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「んんんっ……あふっ！　顔に……んむぅっ……掛かってるっ……！　んぷっ \n、はふぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0203401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016302_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「んっ……あぁぁ……この匂いでまたイク……んんっ！　あぁ……私の興奮を \n増幅させるオスの匂いだ……はぁ、んちゅぷっ……あふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0203402" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「はぁぁ、んっ、もっと掛けてくれ……私の顔をドロドロにして……んっ、ち \nゅぱっ、この精液をもっと味わわせてくれ……ちゅぷぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0203403" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「そうだ、チンポを直接舌の上に置いてもいいぞ……そのまま舐めても……ん \nんっ、微妙に届かない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0203404" ]},
		{"command":[ "SETIMAGE", "0", "still_00016302_01_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「あっ……精液も終わってしまったか……まあ２回目だし、これだけ出せば流 \n石に落ち着くか……んちゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0203405" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「まあ、本来の目的は果たされたしな。これ以上ない位にオッパイをマッサー \nジしてくれて、大分凝りもほぐれた気がする」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0203406" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「これで、お前のチンポも射精して気持ちよくなったのだから、この世界で言 \nう一石二鳥というものだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0203407" ]},
		{"command":[ "SETIMAGE", "0", "still_00016302_01_11" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「改めて私のオッパイとお前のチンポとの相性の良さも再確認できた。やはり \nお前にしか頼めないことだったな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0203408" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「しかし、これだけ感度がよくなっていると、また早々に催すことがあるかも \n知れんな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0203409" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「うむ、その時はまたお前に頼むことにするからな。この先も、私のオッパイ \nをよろしく頼むぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_0203410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
