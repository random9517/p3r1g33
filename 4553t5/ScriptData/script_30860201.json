{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0046" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「あの……今少し、時間を取れますか。最近の貴方を見ていて、どうしても伝\nえたいことが、あって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0203101" ]},
		{"command":[ "SETCHARA", "0", "char_00008602_01", "2", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「いいのですか？　では……え、ええと。いつも、人が多い場所では言うこと\nができなかったけれど……この森の中でなら、い、言うことが出来ます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0203102" ]},
		{"command":[ "SETCHARA", "0", "char_00008602_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「貴方を初めに見た時には、なんと頼りない、弱い存在なのだろうと感じまし\nた。ですが……ですが、あの、そのですね……つまり！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0203103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「褒美を！　与えても良いとこの私が思うほどに貴方は頑張っていますね！　\nと、言いたかったのです！　そ、それで……とても疲れているようですし！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0203104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「たまには私が癒してさしあげたいのです。……きゅ、急にズボンを下ろして\n、こんなことをする私を……恥ずかしいエルフだと思わないでくださいね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0203105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「他の人にはこんなことはしません。本当です。貴方にだけ……。と、こ、言\n葉はもういいでしょう！　始めますよ！　貴方の好きな……パイズリです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0203106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「嫌だなどと言わせるつもりはありません。んっ……！　こ、こうしてほしか\nったのですよね？　ふぅっ、私の胸で、陰部を刺激してほしいと……あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0203107" ]},
		{"command":[ "SETCHARA", "0", "char_00008602_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「淫らな夢を見ていたのでしょう？　そ……その夢叶えてさしあげます。高貴\nなるハイエルフの私が……。はぁっ、はぁ、はぁ、はぁ……あっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0203108" ]},
		{"command":[ "SETCHARA", "0", "char_00008602_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「きゃっ！？　こ、これは……！　なんと猛々しい聖剣でしょうか。もうこん\nなに昂って……硬く、長く、そそり勃っていて……。ごくっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0203109" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00008602_01_02" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「あ……貴方と交わった過去のことを思い出してしまいました。そうですか。\nこのようなものが、わ、私の中に……それで、あんなに乱されて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0203110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「ですが、以前この肉棒にいかに翻弄されてしまったとはいえ……今は。今日\nは、こちらが攻める番です。森の中の私は手ごわいですよ、覚悟なさい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0203111" ]},
		{"command":[ "SETIMAGE", "0", "still_00008602_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「っはぁっ……。はぁっ、はぁ、ふぅうっ……！　ど、どうですか……？　私\nの胸は重い、でしょう？　これだけの乳圧があれば貴方なんて一撃です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0203112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「さあ、さあ、すぐにでも疲労の蓄積……つまり、溜まりに溜まった身体の毒\nである精液を吐き出してしまいなさい。全て受け止めてさしあげます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0203113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「私の胸はあたたかく、心地よく、深い穴になっているでしょう？　こうい\nうっ、だらしのない胸が好きですよね？　ですから、こう……こうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0203114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「こう、やってっ……上半身全てを揺らして奉仕すれば、男根を柔らかさで包\nみこみ、溶かすように甘やかすことが出来るのではないかと、思いますっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0203115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「存分に……んんっ、甘えなさい。この純白の乳房に……。はぁっ♪　してほ\nしいことがあれば言いなさい。可能な限り答えてあげましょう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0203116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「……んっ！　え？　な、なんです。私のおっぱいは縦に長い、ですって！？\n　た、縦！？　長いというのは長所ですか、欠点ですか！？　……っあっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0203117" ]},
		{"command":[ "SETIMAGE", "0", "still_00008602_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「長いからちんぽが丸ごと埋まって気持ちいい……？　あっ、そ、そうならい\nいのです。……おちんぽを全部、一度に愛されたいということですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0203118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「よろしい。それなら……こうです！　むにゅっ……むぎゅぅうっ♪　私の胸\nを、女性器に見立て、貴方のこの立派な男性器を挿入してもらいます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0203119" ]},
		{"command":[ "SETIMAGE", "0", "still_00008602_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「そし、てぇっ……♪　この穴で、疑似的な性行為……セ、セックスをするの\nです。私が胸を動かし、貴方の陰部に絡め……。っはぁっ、はぁ、はぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0203120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「密着度を高め、て♪　乳房をまとわりつかせてシゴきます。ですから、貴方\nも……っ、こ、腰を揺らしてこの穴を、突いてください。胸の、穴をぉ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0203121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「っんんっ！　そ、そうです！　本当の子作りの、ようにっ！　私の胸を……\n突き上げて、かきまわして……！　っぁっ♪　あぁ、そのまま……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0203122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「あっ♪　あっ、あっ♪　き、気持ち……いいですか？　んっ……わ、私の方\nはどうでもよいでしょうっ！　き、気持ち悪くは、ありません……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0203123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「んんっ！？　い、今何か言いましたか？　今、貴方のカウパーまみれになっ\nているこの乳房の穴？　この縦穴をニンゲンはおっぱいまんこと呼ぶ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0203124" ]},
		{"command":[ "SETIMAGE", "0", "still_00008602_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「くっ……！？　そ、そんな卑猥な言葉……私に聞かせないでください……っ\n。んっ！　え？　言って欲しい……ですか？　あっ……う、ウソでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0203125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「そんなはしたないことを言いながら、ニンゲンの肉棒を胸でシゴけと？　っ\nぁ……！　あ、あ、うぅ……！　そんな……そん、な……で、でも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0203126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「これは慰労、であれば貴方の望むままに……。は、はい……い、言います…\n…。私の……清らかなるハイエルフ、エアルミンの……。ううっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0203127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「聖なる正しきおっぱいおまんこに、ニンゲン様のおちんぽ、ちんぽっ、挿入\nしてくださって、使ってくださって、あ、ありがとうございます……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0203128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「おっぱいおまんこ、ちんぽに突かれて気持ち、いいですっ……んんっ、あぁ\nっ、気持ち、いいっ、気持ちいいです、おっぱいまんこいいですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0203129" ]},
		{"command":[ "SETIMAGE", "0", "still_00008602_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「私の胸まんこ、貴方のちんぽが大好きなんですっ！　だからっ、だからいっ\nぱい使って……！　あっぁっあっあっあっ！　い、いやぁ……もぉおっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0203130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「こんなことを言わされて、は、恥ずかしいのに……屈辱なのに、私、感じて\nしまっている……！　あっ、いやっ、乳首ジンジンしますっ、あああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0203131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「だめ……だめっ、慰労の奉仕で自分がイくだなんて、はしたない……情けな\nいっ！　んんっ、でも……でもイクっ、イ、イカせていただきますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0203132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「っあああああああっ！　あぁっ♪　ああああっ♪　絶頂と同時におっぱいお\nまんこにどぴゅどぴゅ精液がっ……！　あぁ、あああスゴいぃっ、すごいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0203133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「い、一番大きな突き上げと同時にっ！　胸まんこにびゅるっ！　びゅるびゅ\nるってヒトのっ！　ニンゲンの子種注がれてっ、ああああぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0203134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「あったかい……！　熱いぃいっ！　イっ……てしまいます！　何度も！　何\n度もっ！　パイズリご奉仕中におっぱいおまんこでイクぅうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0203135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「んっ！！　ん～～～～～っ！　んああああああああッ……♪　ごめ、んなさ\nい……！　ごめんなさい、胸が敏感すぎるエルフでごめんなさい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0203136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00008602_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「あっ♪　ご奉仕の名目で！　自分の胸を気持ち良くする変態ハイエルフで申\nし訳ありませんん……！　あぁイクっ、イっ……く♪　おぁああああ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0203137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「っくぅうううう……♪　ふ～～～～～っ♪　ふ～っ、ふ～……っ♪　す、凄\nまじい量の射精……あ、ありがとうございました……。んああああ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0203138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「森の中で浴びる精液……っ！　これが嫌いなエルフなんて存在しません、命\nのほとばしりを！　自然の中で感じることこそ最上の喜びです……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0203139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「あぁ、あああ……♪　貴方に精を注がれるたび……解放されていくのがわか\nります。私……私はいやらしいおっぱいまんこハイエルフです……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0203140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「んん……♪　あっ！　す、すみません。興奮のあまり、強くおちんぽを絞り\nすぎましたね。戦士の全力で締めつけるだなんて酷い事をしてしまいました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0203201" ]},
		{"command":[ "SETIMAGE", "0", "still_00008602_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「……そういうのも気持ちいい？　フフ。貴方は意外と順応性が高いのですね\n。それに……これだけの量を吐き出して、まだ全然萎えていない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0203202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「ニンゲンという種において、貴方ほどの豪傑はそうはいないでしょう。見て\nください。このドロドロに煮詰まった白濁液。この臭い子種……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0203203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「女を狂わせる毒薬です。ですが、私はこれを憎めない……。ですので、うま\nく利用します。んっ……おちんぽがまだ元気ならば……こうします」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0203204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「射精された精液を……、っふっ♪　潤滑油にして、このまま休まずおちんぽ\nを刺激するのです。この、濡れたおっぱいおまんこで……。はぁっはぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0203205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「んん……♪　ニュルニュルと、おちんぽが逃げ出してしまいそう……♪　逃\nがしませんよ。がっちりおっぱいまんこで掴んで、シゴいて……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0203206" ]},
		{"command":[ "SETIMAGE", "0", "still_00008602_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「あぁ♪　肉棒がピクピク震えて喜んでいる……っ♪　っふっ♪　そうですか\n、ぬめるパイズリがお好みですか……。私も……です、あぁっ♪　あっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0203207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「貴方の精液を乳房に塗りたくり、貴方の汁で谷間が満たされていくと……♪\n　感じます、胸だけでなく、全身がくまなく……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0203208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「あぁんっ！　あ、あまり見ないでくださいませっ……！　あっ♪　貴方に、\n卑猥なエルフだと思われるのだけは嫌なのっ……！　な、なのにぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0203209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「あああっ、おっぱいおまんこ突かれるのがクセにっ♪　なってっ……ううっ\n！　私の方からねだるように揺らして、動かすのがやめられない……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0203210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「はぁっ♪　あっぁっ、んんぁっ……あぁっ♪　誰にも……誰にも言わないで\nくださいっ、私がこんなに淫らなことを……あぁっ♪　む、胸に！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0203211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「貴方の精液を塗り広げて、摩擦して喜んでいるなんて……！　くぅうっ♪　\nどうか、どうか秘密にして……っ、んぁあっ、感じるぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0203212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「あぅっ……ううっ♪　貴方の臭い……ッ！　精液の香りが私を狂わせてしま\nうのですっ……！　あっぁっ、いやっ、胸、たぷたぷ揺れてっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0203213" ]},
		{"command":[ "SETIMAGE", "0", "still_00008602_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「貴方の硬いモノで、太いモノでズプズプ犯されて、いるぅ……っ♪　はぁっ\n♪　はぁっ、はぁ、も、もっと……もっとです、もっとぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0203214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「もっとソレで私のおっぱいまんこっ、ほじくってくださいませっ！　あぁっ\n！　あふぅっ♪　いいっ、おっぱいまんこに叩きつけてっ、あぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0203215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「んふぅうっ♪　だめっ……だめぇっ♪　もう……アソコがだだ濡れになって\n……あぁっ、モジモジしてしまいます……。んっ、き、気持ちいい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0203216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「もっと♪　もっとください……！　んぅうっ……私も精一杯、貴方のコレに\n尽くします！　ですから二人で……二人で一緒に、あっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0203217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「一緒に絶頂したい……っ♪　はぁっ♪　あっぁっ♪　あぁッ♪　今のすごい\nっ……！　あぁんっ、あっぁっ、どれだけ押し潰しても跳ね返されて！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0203218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「なんと強く優れたおちんぽでしょうか……！　あぁっ♪　摩擦するごとに湯\n気がたつような熱気と、蒸れた臭い……こんなの好きになってしまいます♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0203219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「あっ♪　あぁ♪　もう……胸が限界です、絶頂します！　どうか、貴方も一\n緒に……一緒に！　あぁ、来て……来てください、早くぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0203220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「くぅううううっ……♪　あぁ♪　あぁああっ……！　だめ♪　絶頂しながら\n精液を受け止めていると……胸が痺れてっ、こぼしてしまいそ、うぅ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0203301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00008602_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「びゅくびゅくと絶え間なく注がれる精液……！　あっ！　あっ、一滴たりと\nも無駄にしたくないのに……っ、イくのが止まりません……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0203302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「ああっ、ヌルヌルが、トロトロとした精液が谷間から溢れ出して……！　乳\n房をつたって垂れてしまいます……！　だめ、だめ、全部私のものなのに！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0203303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「ンンンンッ……♪　私が絶頂し続けて、こぼしてしまっても……更に精子を\n届けてくれると言うのですか？　あっ♪　うれしいっ……ありがとうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0203304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「くださいっ……！　んんんっ！　びゅぶっ、びゅぶっと……！　ああああっ\n♪　すごい……この量ならば安心です♪　私の胸が白く染まっていく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0203305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「ふぁ……♪　あぁああ、あり、がとうございました……♪　見てください、\n胸の中にたっぷり。乳房を揺らすとたぷたぷと音がするほどです♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0203306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「あの……なんだか今回も、私ばかり気持ち良くなって、理性を失ってしまい\nましたけれど……。貴方は、ど、どうでしたか。私……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0203307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「きちんと貴方を喜ばせて、褒めたたえることが出来ていたでしょうか。もし\n、うまく出来ていなかったとしたら、その時は言ってください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0203308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「……はい。今日続けては、乳房がもちませんので無理ですが。改めてパイズ\nリの機会をもうけます。そうして、何度も試行を重ねれば……いつか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0203309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「貴方を一方的に感じさせることも出来るのではないかと思うのです。その時\nを楽しみにしていてくださいね……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0203310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「ひぁああんっ！？　ちょっ……！　あっ！？　ど、どこを狙っているのです\nかぁっ……！　あぁっ♪　いやっ、顔にかけられて絶頂なんて！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0203401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00008602_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「ッあぁあああああっ♪　や、やめなさいい……っ！　くぅううっ！　胸も、\n顔も、もうなにもかも貴方の精液でベトベト……！　んんんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0203402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「どれだけ元気なのですか！　あぁあっ♪　な、情けないのは……っ、こんな\nことをされてなお感じて……イってしまう私、ですけど……！　あぁんんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0203403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「見ないでぇ！　顔に出されて絶頂する私を見ない、で……！　んぁああああ\nあっ……♪　あ～っ♪　あっ、ああああ……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0203404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「ん、う……っ！　顔中にへばりつく精液の感触……っ。貴方、胸だけでは足\nりずに顔にまでかけるなんて、良い度胸をしています……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0203405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「……ふーっ♪　ふぅーっ、フー……♪　い、いいのです。いつもであればこ\nのまましかりつける粗相かもしれません。ですが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0203406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「今日は貴方を褒めたたえるための慰労、ですから……。多少のはしゃぎっぷ\nりは大目に見ましょう。精液の飛距離が伸びたということは、その……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0203407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「いつもより気持ちが良かった、気持ち良く射精出来た……ということで間違\nいありませんね？　私の胸と奉仕の心が正しかった、と認めなさい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0203408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「……そ、そう、ですか。本当に良かった、ですか。……ん……。その言葉は\n、想像していたよりは……ええと、響きました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0203409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……♪　たまには、こういった時間も有意義かもしれませんね。\nまた褒められたくなったら必ず教えてください。いいですね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_0203410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}