		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「はいはい、それじゃ例のパターンで回避して～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_010116230001" ]},
		{"command":[ "SETCHARA", "0", "char_00019001_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「はい！　全弾回避しました！　敵の癖が読めてきましたね……あれからどう\nやら、無傷で済んでます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_010116230001" ]},
		{"command":[ "SETCHARA", "0", "char_00019201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「それにどうやら、敵さんも疲れてきたみたい。狙いが雑になってきた感じね\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_010116230001" ]},
		{"command":[ "SETCHARA", "0", "char_00019101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「このまま、援軍が来るまで回避し続けられればいいんですけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_010116230002" ]},
		{"command":[ "SETCHARA", "0", "char_00019201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「この調子なら、どうにかなるでしょ！　っていうわけで、皆さんに艦長から\n問題でーす！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_010116230002" ]},
		{"command":[ "SETCHARA", "0", "char_00019001_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「問題って？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_010116230002" ]},
		{"command":[ "SETCHARA", "0", "char_00019301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「冴島長官が援軍を送ってくれるまで、あと何時間ぐらいかかるでしょうか！\n　正解した人には、豪華粗品をプレゼント！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_010116230003" ]},
		{"command":[ "SETCHARA", "0", "char_00019001_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「って、艦長！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_010116230003" ]},
		{"command":[ "SETCHARA", "0", "char_00019201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「私は……そうねえ～……あと３時間！　スイレンちゃんは？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_010116230004" ]},
		{"command":[ "SETCHARA", "0", "char_00019001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「え？　私？　それじゃ、えーと……７時間……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_010116230002" ]},
		{"command":[ "SETCHARA", "0", "char_00019101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「あらあら、かなり悲観的。それじゃリリアちゃん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_010116230005" ]},
		{"command":[ "SETCHARA", "0", "char_00019001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「うーん……だったら、大穴狙い！　３０分後！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_010116230003" ]},
		{"command":[ "SETCHARA", "0", "char_00019301_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「あらあら！　リリアちゃん、大胆！　それじゃ、スミレちゃんは――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_010116230006" ]},
