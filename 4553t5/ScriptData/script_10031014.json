{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0043" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_019" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「あらあら～、それじゃお二人、今日会ったばっかりなのね～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010116100001" ]},
		{"command":[ "SETCHARA", "0", "char_00021202_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「そうなんだよ、さっきまでバイト先に飲みに来てたお客さんなんだけどさ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020116100001" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「いやぁ～！　たまたま長官に聞いて飲みに行った店で、こんな熱いスケバン\n魂を持ったヤツに会えるなんてなぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_010116100001" ]},
		{"command":[ "SETCHARA", "0", "char_00022901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「そりゃあたしのセリフだぜ！　まさかあの店に、こんな気合いの入ったお客\nさんが来るなんてなあ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020116100002" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら＆スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「わははははははは！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020116100003" ]},
		{"command":[ "SETCHARA", "1", "char_00003402_01", "8", "CENTER", "400" ]},
		{"command":[ "SETCHARA", "0", "char_00022901_01", "8", "CENTER", "-400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「あらあら。そうだったのね～。それにしても、二人ともずいぶん飲んだわね\nえ。ホントにお酒強いのねえ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010116100002" ]},
		{"command":[ "SETCHARA", "0", "char_00021202_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「はははは、これぐれぇだったら、屁でもねえぜ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_010116100003" ]},
		{"command":[ "SETCHARA", "0", "char_00022901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「おう！　『正義（まさよし）』でも仕事そっちのけで、けっこう二人で飲ん\nでたけどな！　ははははは！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020116100004" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「あらあら、やるわねえ。でも、二人で飲み比べしたらどっちのほうが強いの\nかしら～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010116100003" ]},
		{"command":[ "SETCHARA", "0", "char_00021202_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「はははははは！　飲み比べかぁ！　面白ぇけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_010116100004" ]},
		{"command":[ "SETCHARA", "0", "char_00022901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「どっちが勝つかなんて、そんなの決まってんじゃんかなあ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020116100005" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら＆スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「おれ（アタシ）だよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020116100006" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "SETCHARA", "1", "char_00003402_01", "8", "CENTER", "400" ]},
		{"command":[ "SETCHARA", "0", "char_00022901_01", "8", "CENTER", "-400" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「……んだと、ゴラ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_010116100006" ]},
		{"command":[ "SETCHARA", "0", "char_00022901_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「んだぁ……？　てめぇが勝つだとぉ？　なに抜かしてんだコラ、タココラ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020116100007" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「んだとぉ？　オレがてめぇに負けるって言いてえのかぁ？　寝言は寝て言え\nやこのタコスケ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_010116100007" ]},
		{"command":[ "SETCHARA", "0", "char_00022901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら＆スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「やんのかゴラアアアア！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020116100008" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "SETCHARA", "1", "char_00003402_01", "7", "CENTER", "400" ]},
		{"command":[ "SETCHARA", "0", "char_00022901_01", "7", "CENTER", "-400" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「だったらここでカタつけてやらぁ！　Ｍ.Ａ.Ｍ.Ａ！　とりあえずテキー\nラだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_010116100009" ]},
		{"command":[ "SETCHARA", "0", "char_00022901_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ボトルでくれ、ボトルで！　いいか、『いっせーの、せ！』で始めんぞ！　\nフライングすんなよ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020116100009" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「上等だオラ！　かかってこいやぁああ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_010116100010" ]},
		{"command":[ "SETCHARA", "0", "char_00022901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「おーっす、Ｍ.Ａ.Ｍ.Ａ～。いつものちょうだい……って、なにこの雰囲\n気！？　なにが始まるの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020116100001" ]},
		{"command":[ "SETCHARA", "0", "char_00002202_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「宇宙ヤンキー大戦争かしら～……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010116100004" ]},
		{"command":[ "SETCHARA", "0", "char_00021202_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら＆スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「いっせーの、せ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020116100010" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "SETCHARA", "1", "char_00003402_01", "7", "CENTER", "400" ]},
		{"command":[ "SETCHARA", "0", "char_00022901_01", "7", "CENTER", "-400" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}