{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0188" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「喰らうがいい！　はぁぁぁぁぁぁーーーっ、ブライダル・エンプレス！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100022530001" ]},
		{"command":[ "SETCHARA", "0", "char_00000313_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「当たらないわっ！　月影流忍術っ、月光閃撃！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010022530001" ]},
		{"command":[ "SETCHARA", "0", "char_00000214_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "目まぐるしい速さで攻撃が飛び交い、キンキンという何かがぶつかる音が聞こ\nえてくる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "アナザー・エファナティカとカグヤの凄まじい一騎打ちに、他の幹部たちも迂\n闊に手が出せずにいた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「くっ……以前の私なら、もう少し割り込めただろうに……歯がゆいぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022530001" ]},
		{"command":[ "SETCHARA", "0", "char_00000118_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「分かります、ルナテミス様……アタシだって、全盛期はもう少し力が出せた\n筈なのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022530001" ]},
		{"command":[ "SETCHARA", "0", "char_00000309_01", "6", "CENTER", "0" ]},		
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「余り言うと、老いを意識してるみたいで自分の首を絞めるぞ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090022530001" ]},
		{"command":[ "SETCHARA", "0", "char_00000122_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「くくっ、負け犬どもが互いの傷を舐め合っておるわ。じゃが……お主は、も\nう少し余を楽しませてくれそうだのう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100022530002" ]},
		{"command":[ "SETCHARA", "0", "char_00000313_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「私は、貴方と遊ぶつもりはないわ。さっさと決めてあげる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010022530002" ]},
		{"command":[ "SETCHARA", "0", "char_00000214_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「小癪な。やってみるがいい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100022530003" ]},
		{"command":[ "SETCHARA", "0", "char_00000313_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「言われなくともっ、やぁぁぁぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010022530003" ]},
		{"command":[ "SETCHARA", "0", "char_00000214_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「また速くなった……！　くっ、目で追いかけるのがやっとだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090022530002" ]},
		{"command":[ "SETCHARA", "0", "char_00000122_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「この戦いはどうなってしまうのでしょうか……あら……あれは？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_020022530001" ]},
		{"command":[ "SETCHARA", "0", "char_00003004_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「やれやれ……随分と眠たい戦いを繰り広げているようですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110022530001" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「……何じゃ？　お主は……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100022530004" ]},
		{"command":[ "SETCHARA", "0", "char_00000313_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「力任せに技を振り回して、人気の心得というものが分かっていない証です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110022530002" ]},
		{"command":[ "SETCHARA", "0", "char_00000514_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……ハルノブ……！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "激しい火花を散らしていた二人の戦いにスッと紛れ込んできたハルノブの姿は\n、よく見るとやはり普段の出で立ちとは異なっている。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あいつも白いドレスのようなものを……」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「人気の力を使いこなしているようで、その実……振り回されている……そん\nな小競り合いに見えてしまいますね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110022530003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「……知った風な口をっ、邪魔をしないでっ、はぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010022530004" ]},
		{"command":[ "SETCHARA", "0", "char_00000214_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「それが貴方の最速ですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110022530004" ]},
		{"command":[ "SETCHARA", "0", "char_00000514_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「なっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010022530005" ]},
		{"command":[ "SETCHARA", "0", "char_00000214_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「速さで勝負をするというならば、これ位はしていただきませんと……ふっ…\n…！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110022530005" ]},
		{"command":[ "SETCHARA", "0", "char_00000514_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「きゃぁぁぁぁぁぁぁっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010022530006" ]},
		{"command":[ "SETCHARA", "0", "char_00000214_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「まさか……カグヤが一瞬で……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022530002" ]},
		{"command":[ "SETCHARA", "0", "char_00000118_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ブライド時空の戦いは、このようにして行うのです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110022530006" ]},
		{"command":[ "SETCHARA", "0", "char_00000514_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ほう……どうやら、お主は他の奴らとは違うようだね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100022530005" ]},
		{"command":[ "SETCHARA", "0", "char_00000313_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「そうですね……もっと言うならば、貴方とも違うということでしょうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110022530007" ]},
		{"command":[ "SETCHARA", "0", "char_00000514_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「何……？　ぐぁっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100022530006" ]},
		{"command":[ "SETCHARA", "0", "char_00000313_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「既に式神の結界の中に入り込んでいることに気づきませんでしたか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110022530008" ]},
		{"command":[ "SETCHARA", "0", "char_00000514_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「おのれ……いつの間に……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100022530007" ]},
		{"command":[ "SETCHARA", "0", "char_00000313_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「まだまだ上には上がいるということを、教えてあげましょう。味わうですっ\n……春の雷（スプリングサンダー）！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110022530009" ]},
		{"command":[ "SETCHARA", "0", "char_00000514_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「うぁぁぁぁぁぁぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100022530008" ]},
		{"command":[ "SETCHARA", "0", "char_00000313_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「なっ……奴も一撃でっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090022530003" ]},
		{"command":[ "SETCHARA", "0", "char_00000122_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「人気の強さがこの世の理……貴方の言った通りになったまでのことです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110022530010" ]},
		{"command":[ "SETCHARA", "0", "char_00000514_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そんな……あの二人よりも更に人気の強い奴がいたというのか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022530003" ]},
		{"command":[ "SETCHARA", "0", "char_00000118_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「この世は並べて栄枯盛衰。自分の人気に慢心することは命取りになりますよ\n。もちろんウチ自身にも言えることでしょうが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110022530011" ]},
		{"command":[ "SETCHARA", "0", "char_00000514_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「うぬ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022530002" ]},
		{"command":[ "SETCHARA", "0", "char_00000309_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「さて……そんな訳で、ウチとしてもこの機会を逃すわけには行きません。と\nいう訳で、旦那様はウチのものです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110022530012" ]},
		{"command":[ "SETCHARA", "0", "char_00000514_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「は？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「さあ、参りましょう旦那様。めくるめく法悦の世界へ、ウチと一緒に旅立つ\nのです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110022530013" ]},
		{"command":[ "SETCHARA", "0", "char_00000514_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「でぇぇっ！？　お前もそうなのかよ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ま、待て待て！　お前、勝手に……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090022530004" ]},
		{"command":[ "SETCHARA", "0", "char_00000122_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「邪魔です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110022530014" ]},
		{"command":[ "SETCHARA", "0", "char_00000514_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ふひゃぁぁぁぁぁっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090022530005" ]},
		{"command":[ "SETCHARA", "0", "char_00000122_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あ、あの……あまり乱暴なことは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_020022530002" ]},
		{"command":[ "SETCHARA", "0", "char_00003004_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「お呼びでないです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110022530015" ]},
		{"command":[ "SETCHARA", "0", "char_00000514_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あらぁぁぁぁぁぁぁぁっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_020022530003" ]},
		{"command":[ "SETCHARA", "0", "char_00003004_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「う、うわっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ほら捕まえましたよ。あぁ……お会いしたかったですぅ……旦那様……んん\nーーっ、すりすりすり～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110022530016" ]},
		{"command":[ "SETCHARA", "0", "char_00000514_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ちょっ、お、おい……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「もう邪魔者はいなくなりました。これからは、ウチと旦那様との蜜月が始ま\nるのです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110022530017" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お、おいっ、ハルノブ……落ち着け！　は、鼻をそんなにくっつけるな！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「そうは行きません。このように魅力的で鮮烈なフェロモンを芬々とさせてい\nる旦那様がいけないのです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110022530018" ]},
		{"command":[ "SETCHARA", "0", "char_00000514_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「あぁ、もう待ちきれません。すぅぅぅぅぅーっ……んはぁっ……あぁ、素敵\nです……旦那様の男臭い匂い……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110022530019" ]},
		{"command":[ "SETCHARA", "0", "char_00000514_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「こ、こらっ、匂いを嗅ぐなっ！　目がやべぇってっ、おいっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「すぐにでも子作りをしたいところです……旦那様、子供は何人欲しいですか\n？　ウチはまず２人、そこからは計画を……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110022530020" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「何人生設計始めてんの！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「……だ、旦那様……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010022530007" ]},
		{"command":[ "SETCHARA", "0", "char_00000214_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「チッ、もう戻ってきましたか……思ったよりしぶといですね。仕方ありませ\nん、このまま二人きりになれる所に行きますよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110022530021" ]},
		{"command":[ "SETCHARA", "0", "char_00000514_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うぉわっ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

