{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0195" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「ん……隊長さま、どうしたんです？　ああ、お仕事終わったんですね。それ\nじゃ確認しますね……はい、完璧です。いいですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0404101" ]},
		{"command":[ "SETCHARA", "0", "char_00003304_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「私の方もちょうど一区切りつきました……ふふ、隊長さま、今このオフィス\nに二人っきりなの、気づきました？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0404102" ]},
		{"command":[ "SETCHARA", "0", "char_00003304_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「ねえ？　隊長さま、サキュバスになった私に、隊長さまの精気、いただけま\nせん？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0404103" ]},
		{"command":[ "SETCHARA", "0", "char_00003304_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「しばらく誰も帰ってきませんし……それに、ねえ？　オフィスで上司を抱く\nっていうの、男の人にとって興奮するシチュエーションじゃないんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0404104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「だから……ね？　私の身体、ここで好きにしていいですよ？　ほら、この胸\nも、このお尻も、マンコも……隊長さまの好きなようにしてください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0404105" ]},
		{"command":[ "SETCHARA", "0", "char_00003304_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「あんっ……きゃっ！？　ふふ、隊長さまもやる気じゃないですか……んっ、\nはっ、こんな窓際で……あんっ、強引なんですから、んっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0404106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003304_02_01" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「やあ、あんっ、あっ、こんな、窓際で胸を丸出しで……後ろからなんて、あ\nんっ、ふうっ、誰かから見られちゃう……んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0404107" ]},
		{"command":[ "SETIMAGE", "0", "still_00003304_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「あうっ、んっ、むしろ愛しあう私たちを見せつけるって……そんなっ、あっ\n、素敵……やっぱり隊長さまは男らしい、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0404108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「んんっ、あっ、ふうっ、私の中に隊長さまのチンポが……んんっ、ふう、暴\nれて、逞しくて……あんっ、締めつけちゃいます……んっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0404109" ]},
		{"command":[ "SETIMAGE", "0", "still_00003304_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「んふうっ、ふっ、やっぱり、ふふっ、あっ、伴侶にするなら、隊長さまみた\nいな人がいいですね……んっ、あっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0404110" ]},
		{"command":[ "SETIMAGE", "0", "still_00003304_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「あっ、今の言葉でチンポがまた、あっ、んんっ、うっ、隊長さまも、興奮し\nたんですね、嬉しい……んんっ、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0404111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「あんっ、あっ、奥に、奥にごつごつって、ふうっ、あっ、もっと、もっと激\nしくしてっ！！　隊長さまのチンポで、もっと虐めてっ！！　あああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0404112" ]},
		{"command":[ "SETIMAGE", "0", "still_00003304_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「んっ、ああっ、それ、それっ、強くするの、好き……ふううっ、あっ、んん\nっ、あんっ、隊長さまのチンポ、好きぃっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0404113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「やあっ、あっ、そんな、んんっ、隊長さまのことも好きに決まってるじゃな\nいですか……あんっ、ああっ、あふうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0404114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「だったらもっと見せつけてやりたいなんて……んんっ、見せつけなくても、\nもう私は隊長さまの女です……ふううっ、うっ、あっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0404115" ]},
		{"command":[ "SETIMAGE", "0", "still_00003304_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「んんんっ、分かります？　隊長さまのチンポ、私の中がぎゅっぎゅって締め\nつけてるの……絡みついて、離したがらないの……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0404116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「隊長さまのこと、大好きって、愛してるって私の中が言ってるの、分かりま\nす？　ふあああっ、あっ、またそんなに責めて、あうううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0404117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「ああっ、口でもっと言えって、愛してます、隊長さま、好き、大好きっ！！\n　サキュバスになってても、なってなくても、好きぃっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0404118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「あううううっ！！　中でチンポがまた……ふふ、隊長さまも私のこと、愛し\nてくれてるんですね、あんっ、ああっ、あくうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0404119" ]},
		{"command":[ "SETIMAGE", "0", "still_00003304_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「んんんっ、この感触も愛しくて、ふうううっ、オフィスで、誰かから見られ\nるかも知れないのに、んんっ、あうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0404120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「隊長さまに愛してもらえてるってだけで、身体が熱くなって……んんんっ！\n！　ふうっ、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0404121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「隊長さまのチンポが中で動くたびに、頭の中が……んんっ、身体も……ふあ\nあっ、気持ちよくなって、ああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0404122" ]},
		{"command":[ "SETIMAGE", "0", "still_00003304_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「んうっ、もう隊長さまなしじゃいられない……あんっ、あっ、あくうっ、奥\nゴリゴリってされるの、好きっ、ふああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0404123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「全部、全部好きっ！！　隊長さまのチンポ、なにをされても、どう動いても\n、全部好きぃっ！！　あふうううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0404124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「あっあっあっ、その速いピストンも、んんっ、あっ、あくうっ、この強いピ\nストンも、全部……気持ちいい……あんっ、あああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0404125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「隊長さま、隊長さまは気持ちいいですか……？　んんっ、あっ、あくうっ、\nあっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0404126" ]},
		{"command":[ "SETIMAGE", "0", "still_00003304_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「んんうっ、気持ちいい、愛してるって……そんな、そんなこと言われたら、\nふあっ、ふああああああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0404127" ]},
		{"command":[ "SETIMAGE", "0", "still_00003304_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「あっ、んっ、軽くイってしまいました……んんっ、隊長さま、もっと、もっ\nと動いて……私をめちゃくちゃにして、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0404128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「チンポが動くたび、ごりごりって擦れて、奥がちゅうちゅうキスして……ん\nんっ、私の中が、隊長さまから離れたくないって、んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0404129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「ふうっ、ああっ、んんっ、中が、熱くなって……もう、溶けちゃいそう……\nんんっ、ふうっ、あああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0404130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「あんっ、また動きが強く……んんっ、でも、もういいです、見られたって、\nんんっ、見られても構わない……ふああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0404131" ]},
		{"command":[ "SETIMAGE", "0", "still_00003304_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「私が隊長さまの女だって、分かるんですから……んっ、ああっ、あふうっ、\n中、マンコの中、溶けるっ、あくうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0404132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「隊長さまのチンポで溶かされちゃう、んううっ！！　溶かされて、かき混ぜ\nられて……ひあああっ、あっ、ああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0404133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「んっ、あうっ、ふっ、隊長さま、隊長さまもイきそうなんですね？　ふふ、\nサキュバスですから、分かります、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0404134" ]},
		{"command":[ "SETIMAGE", "0", "still_00003304_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「いいですよ、隊長さまの気持ちいいの、全部私の中に出して、いっぱい出し\nて、お腹いっぱいにしてください、隊長さま、んんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0404135" ]},
		{"command":[ "SETIMAGE", "0", "still_00003304_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「ふうううっ！！　出してっ！！　中に出してっ！！　私も、イく、イっく、\nイっくうううううううううううううううううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0404136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「ああああっ！！　出てるっ、出てるうっ！！　隊長さまの精液、私の中にど\nくどく出てるうっ！！　ふあああああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0404137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003304_02_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「奥っ！！　一番奥にどろどろの精液が、びゅびゅって出てるっ！！　んんう\nっ、マンコの奥に、どぷどぷ注ぎこまれてるっ！！　ひうううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0404138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「あんっ、お腹がきゅうきゅう啼いて悦んでる……隊長さまの精液、おいしい\nおいしいって、んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0404139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「満たされてる……私、今隊長さまの精液で満たされてる……お腹も、心も…\n…んっ、うっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0404140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「んふっ、まだ……まだできますよね隊長さま？　隊長さまのチンポ、中でま\nだガチガチですし……もう一回、ね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0404201" ]},
		{"command":[ "SETIMAGE", "0", "still_00003304_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「私、今ので身体中が燃えたみたいに熱くなってて……もっと欲しいんです。\nわがままな女に、隊長さまのチンポでお仕置きしてください……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0404202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「あっ、んっ、ふうっ、あんっ！！　また、そんな激しく、ひううっ、んっ、\nじゅぷじゅぷって、いやらしい音が、んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0404203" ]},
		{"command":[ "SETIMAGE", "0", "still_00003304_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「あんっ、あっあっあっ！！　部下に好きにされて、悔しくないかって……そ\nんなの隊長さまならなにをされてもいいっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0404204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「上司と部下とか、サキュバスだからとか関係ない、んっ、隊長さまだから、\n隊長さまにだったら、なにをされたって、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0404205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「なにをされたっていいっ！！　ふうううっ！！　好きっ！！　それほど好き\nっ！！　隊長さまの全部、好きですっ！！　あうううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0404206" ]},
		{"command":[ "SETIMAGE", "0", "still_00003304_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「んくううっ、好きって言ったら、隊長さまのチンポ、またびくびくって、ん\nんっ、好きっ、好きっ！！　隊長さま、大好きぃっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0404207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「あくううううっ！！　そんな、お返しみたいに強く責めたら、んんんっ、マ\nンコの中、ぐじゅぐじゅになって、あふうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0404208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「蕩けて、絡みついて、もう隊長さまのこと離さなくなっちゃう、んんっ！！\n　こんな素敵なチンポ、離せなくなっちゃうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0404209" ]},
		{"command":[ "SETIMAGE", "0", "still_00003304_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「隊長さまも、私のマンコから離れないで……ずっとずっと側にいて、抱き続\nけてっ！！　んんっ、あっ、そんなっ、返事代わりにピストンって！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0404210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「ああああっ、そんなに連続して突かれたら、奥っ、潰れちゃうっ、ふううう\nっ、あくうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0404211" ]},
		{"command":[ "SETIMAGE", "0", "still_00003304_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「あくうっ、硬くて太いチンポが私の中をごりごりって……ふああああっ、も\nう、もうだめっ、また、またイきそう、隊長さま、私イきそうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0404212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「ふあああっ、いつでもイけって、そんなこと言われたら、んんっ、隊長さま\nと一緒にイきたいのにいっ！！　あふううううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0404213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「隊長さま、隊長さま、隊長さまもイって、お願い、一緒にイって！！　チン\nポから、濃い精液どくどく出してっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0404214" ]},
		{"command":[ "SETIMAGE", "0", "still_00003304_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「ひあああっ、だったらもう少し我慢しろって、んんっ、こんな、ぎりぎりな\nのに、ひっ、あっ、あふうっ、んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0404215" ]},
		{"command":[ "SETIMAGE", "0", "still_00003304_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「マンコが、私の中が、チンポきゅうきゅう締めつけて、んくううっ！！　あ\nっ、ああっ、もうなにも考えられなくなっちゃうううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0404216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「隊長さまのチンポで、考えられなくなっちゃう！！　上司なのに、バカにな\nっちゃうっ、あくうううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0404217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「あああああっ、出して、隊長さまの精液、出してっ！！　私の中にいっぱい\n出して、お願い、んんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0404218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「ああっ、あっ、あんっ、もう、もうダメっ！！　もう、今度こそ、イく、イ\nっちゃう、んんんんっ、我慢、できないっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0404219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「隊長さま、隊長さまももう限界なの、分かるから、一緒に、一緒に、大好き\nな隊長さまと一緒にイっく、んんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0404220" ]},
		{"command":[ "SETIMAGE", "0", "still_00003304_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「あふううううっ！！　二回目の、精液、来たああああっ！！　んんっ、あっ\n、熱い……溶ける、マンコの中、溶けちゃうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0404301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003304_02_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「ふうっ、ふっ、お腹の中がいっぱいに……んんんっ、私の女の部屋がいっぱ\nいになって……あふうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0404302" ]},
		{"command":[ "SETIMAGE", "0", "still_00003304_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「んんっ、二回目なのに、濃くて、多くて……んんんっ、サキュバスのお腹が\n悦んでる、隊長さまの精液できゅんきゅん悦んでるっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0404303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「あんっ、そんな暴れさせたら、中がぎゅっぎゅって締めつけちゃう……あふ\nっ、うっ、んんっ、残りの精液が出てきてる……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0404304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「んっ、こうして、腰で奥に押しこんで……んんっ、残りも全部、私の中に…\n…んんっ、あっ、ふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0404305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「最初の力強い射精も好きだけど、この撫でるような射精も好き……隊長さま\nのなら、全部、なんでも好き……んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0404306" ]},
		{"command":[ "SETIMAGE", "0", "still_00003304_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「凄い量と精気……サキュバスになったから、そういうのも分かる……ふうう\nっ、んっ、ふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0404307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「こんなに出されたら、確実に妊娠しちゃいますねえ……ふふっ、隊長さまと\nの子供なら、さぞかし可愛らしい子供になるんでしょうね……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0404308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「ふふ、一人だけじゃなくてたくさん、賑やかな家庭を作りたいですねえ。隊\n長さまとなら、ずっと幸せに過ごせます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0404309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「だから隊長さま……これからも一緒に、よろしくお願いしますね。ふふふ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0404310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「ふあああっ！！　どうして、抜いて……ああっ、あんっ、あふうっ！！　精\n液が身体に……んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0404401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003304_02_16" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「あんっ、あっ、熱い……んっ、身体にこんなに……あっ、ふうっ、シャワー\nみたい……あふうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0404402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「こんなドロドロのが私の中に出されてたって思うと、外に出してるのに、お\n腹がきゅうきゅう啼いて……ふうううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0404403" ]},
		{"command":[ "SETIMAGE", "0", "still_00003304_02_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「んんっ、精液浴びせられるの、気持ちいい、んっ、もっと、隊長さま、もっ\nとかけて……あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0404404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「ふふ、私の身体中全部、隊長さまの精液で染められて……んふっ、隊長さま\nのものって感じがします……んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0404405" ]},
		{"command":[ "SETIMAGE", "0", "still_00003304_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「中もよかったけど、身体にかけられるのも……んっ、嫌いじゃないかも……\nあんっ、ふっ、まだ出てる……んうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0404406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「ねえ、隊長さま、私にかけたいなら、もっともっと、いっぱいかけてくださ\nい……私の身体が、隊長さまで染め上げられるように、もっと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0404407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「そうすれば、誰がどこで見ても私が隊長さまのものだって分かるでしょう？\n　こうして誰かに見せつけなくても、いるだけで隊長さまの女だって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0404408" ]},
		{"command":[ "SETIMAGE", "0", "still_00003304_02_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「会社では私は上司ですけれど、女としてはあなたのものですから……どこで\n抱こうと、どう抱こうと自由ですよ。隊長さまの思いのままに……ね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0404409" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「んふふ、だから、これからも、中でも外でも、たっぷり私に出してください\nね。期待してますよ、隊長さま？」", "NORMAL" ]},
