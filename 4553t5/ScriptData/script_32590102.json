		{"command":[ "SETIMAGE", "0", "still_00025901_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「あああああ……♪　普通の男の子の何人分！？　栄養豊富で臭くって、すご\nいぃいい！　わかるっ？　子宮がゴクゴク飲んでる、吸い上げてるぅうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0104137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「あ～～～～っ♪　嬉しいぃい♪　淫魔主婦の欲張りおまんこに不倫生射精ぃ\nい……♪　やっぱりコレが一番効果的なサキュバスのごはんだわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「もっと……♪　もっと飲ませて、あなたの精を食べさせてぇ……♪　ふぁあ\nあ♪　コクがあって痺れるくらい美味しい♪　射精の天才ね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0104139" ]},
		{"command":[ "SETIMAGE", "0", "still_00025901_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「サキュバスですら完璧に満足させてくる特別な精子ぃいい……♪　やだぁ、\nこれを覚えちゃったら、もう他の子じゃ物足りなくなっちゃうわぁああ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「っあ……♪　あぁ……、んあああ……♪　あなたほど、私の母乳を勢い良く\n出させてくれる人も初めてだし、うっとりしちゃう射精もしてくれて♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0104201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「……元々好きだったのに、だ～い好きになってきちゃったかも……♪　この\nままおちんちんを抜いておしまいなんてイヤ。続けちゃっていい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0104202" ]},
		{"command":[ "SETIMAGE", "0", "still_00025901_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「いいわよねぇ……♪　んふふふ、あなた相手なら本気を出しても大丈夫そう\n……♪　淫魔主婦の全力、受け止めてね♪　いくわよぉ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「んっはぁあああっ♪　あぁっ♪　ああっ、あっあっあっあっあぁんっ♪　…\n…えぇ！？　私の腰づかいにも負けてない！？　すごいおちんちん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0104204" ]},
		{"command":[ "SETIMAGE", "0", "still_00025901_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「感動、しちゃうなぁ……っ♪　一度射精してもず～っと元気いっぱいだし♪\n　まるでおかわりしてほしいっておねだりしてるみたい♪　可愛いぃっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0104205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「はぁっ♪　はぁ♪　いいのよ♪　何度だってしましょ？　んふっ♪　んっ！\n　んんっ！　んぁああっ♪　あぁんっ♪　不倫エッチ気持ちい～い？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0104206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「私は気持ちいいなぁ……♪　んぁんっ♪　おまんこの中で、あなたの精液と\n私の愛液が混ざってヌルヌルがすっごいんですものぉお♪　たまらない♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「それにズンッ、ズンッて力強くおちんちんがおまんこを突いてくれる♪　そ\nのたびに全身が快感でヒクヒクして、身体中粘膜になっちゃったみたい♪」", "NORMAL" ]},
