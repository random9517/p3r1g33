		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「淫魔主婦はぁ……♪　本気で感じてイクとおっぱいから母乳が出ちゃうのぉ\nっ……！　あっ！？　あっ、イクイクっ、なんなのこのおちんちんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0104127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「今までの誰とも違うぅう……！　理想的な形、重さっ……！　はぁんっ♪　\n私のおまんこの形とぴったり合ってる♪　強くて健康的で……イイっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「私……っ、人妻なのにいけないわ！　はぁっ、はぁ、夫のより……あぁんっ\n♪　あの人のおちんちんより相性のいいおちんちん、知っちゃうなんてぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0104129" ]},
		{"command":[ "SETIMAGE", "0", "still_00025901_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「裏切りよぉ……♪　なのに全然やめたくないのぉ♪　はぁっ、あぁっ、自分\nでおっぱい揉みながら、どんどん母乳を出すと気持ちいいっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁ♪　好きになっちゃう♪　あなたのおちんちん愛しちゃうぅ…\n…！　だめ、だめよ♪　おまんこ暴走して締めつけちゃう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「淫魔主婦の膣圧でおちんちん絞り取るなんて困っちゃうわよね♪　でも……\n止められないの、おちんちん、い～っぱい絞りたい♪　精子欲しいのぉ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「あぁあああんっ♪　あッあっあっ♪　またイクわ、見てて……イクところ見\nてて♪　乳首からぴゅーって母乳出すの見てて、舐めて……飲んでぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0104133" ]},
		{"command":[ "SETIMAGE", "0", "still_00025901_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「二人でどこまでも堕ちていきましょっ！　ね？　ねっ？　あああっ、私、腰\nの振り方わかってきちゃった♪　あなたに一番効く動き……こうねっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「あん♪　あん♪　降参しちゃいなさい♪　サキュバスおまんこに射精しちゃ\nってぇ♪　いいの、浮気エッチいいの、不倫中出ししてぇっ、早くぅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0104135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETTEXT", "「ンッ♪　あああああああああっ……！　美味しいぃいっ♪　美味しいわっ、\nあなたの精子……極上すぎるっ！　何！？　なんて濃くて粘るのぉおっ♪」", "NORMAL" ]},
