		{"command":[ "SETTEXT", "「はしたないわ、恥ずかしいぃい……！　でも、それがイイのっ♪　あぁああ\nっ、サキュバスに生まれてよかったぁ♪　こんなにすごいおちんちん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0104211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「ただの人間の女の子だったら気絶しちゃってる♪　絶対おしっこ漏らしてイ\nキっぱなしになっちゃう♪　それくらい……素敵な大きさよ、好きぃい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0104212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「あ～～～～っ♪　全身に快感が駆け巡って……力がみなぎってくるぅ♪　あ\nなたのおちんちんって淫魔主婦の大好物よ、スペシャルディナーだわっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0104213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「ん～～～～っ♪　もうコレしか食べたくなぁいい♪　これ好きぃっ♪　この\nおちんちんず～っとおまんこに入れてたいの♪　いいでしょぉ～っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0104214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「好きなだけズボズボしていいのよ♪　ね？　腰を突き上げて♪　……あッ♪\n　いいわ、一方的に絞り取るのもいいけど、協力して動くのもイイ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0104215" ]},
		{"command":[ "SETIMAGE", "0", "still_00025901_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「ふぁあっ♪　やだもぉ、愛液も母乳も垂れ流し状態よぉ♪　危険なおちんち\nん♪　はぁっ、あぁ、ダメ、これ……もしかしちゃうわ、妊娠しちゃう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0104216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「次に生で中出しされたら♪　淫魔主婦だって孕まされちゃう♪　それくらい\n強い遺伝子ドクドク注がれちゃう♪　はぁ、はぁ、はぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0104217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「それでもいいの……ちょうだいっ♪　私がエッチな淫魔主婦なのがぜぇんぶ\n悪いんだからっ♪　精液大好きなのっ、お腹い～っぱい飲みたいの♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0104218" ]},
		{"command":[ "SETIMAGE", "0", "still_00025901_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「私も母乳出すからっ♪　好きなだけ母乳を浴びて、飲んじゃっていいから…\n…精液おねがぁいい♪　もう待てないわ、ずうっと欲しいのぉ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0104219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「あああっ♪　一緒に♪　一緒にびゅるびゅるしましょうねっ……♪　あっぁ\nっ、イっちゃおうっ♪　二人で思いっきりぃ……！　ああああんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0104220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETTEXT", "「んあ～～～っ♪　あぁんっ♪　はぁんんっ♪　あつぅうういいいい～～～～\nっ♪　極上精液また来たわぁあ♪　ごちそうよ、いただきまぁすうう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0104301" ]},
		{"command":[ "SETIMAGE", "0", "still_00025901_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「あっ♪　あっ♪　どうして二回目の射精の方が量が多いの……！？　私が無\n理やり絞り上げているからっ♪　ああっ、粘膜に貼りついて……イイのぉっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「好きっ♪　好きよぉ……あなたの精子♪　おちんちんから次々に発射されて\nくる……っ♪　うふふふっ♪　私の母乳とおんなじ……♪　あ～～～～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0104303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「もうなにもかも、どうでもよくなってきちゃう……♪　あなたも淫乱な人妻\nおまんこに、気持ちよく射精することしか頭にないでしょ？　私もよぉっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0104304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「あなたのっ♪　精液で子宮とおまんこをたっぷたぷに満たすことしか興味が\nもてないわっ……！　それだけでいいの、あああ、妊娠間違いなし……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0104305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「お互いにどぴゅどぴゅしあって、体液まみれになりながら絶頂するの、気持\nちいいわね……っ♪　ありがとう、美味しい精子出してくれてぇっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0104306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「ん～～～～……♪　お腹いっぱぁいい……♪　うふふふ、もらったぶんだけ\n乳首から母乳としてまた発射しちゃって、トントンかと思ったけれど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0104307" ]},
		{"command":[ "SETIMAGE", "0", "still_00025901_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「あなたの精液の量の方が、私の母乳よりず～っと量が多かったみたい。すご\nいねぇ……♪　サキュバスを上回る精力なんて聞いたことないわ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0104308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「ねえ、あなた……♪　エッチをする前から、私、あなたのことを大好きだっ\nたけど……こうしてあなたのおちんちんを味わっちゃったらもうダメだわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「隊長さんなんてやめて、私専用のおちんちんミルクポッド、精液供給係にな\nってほしいなぁ♪　ね……考えておいて。良いお返事を待ってるわよぉ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETTEXT", "「イクぅううっ♪　イクッ……あ、あらっ？　ダメよ、ちゃんと中に出してく\nれないと……サキュバスの栄養にならな……。あっ♪　やぁんん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0104401" ]},
		{"command":[ "SETIMAGE", "0", "still_00025901_02_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「もう、やんちゃさんなんだからぁ……♪　うふふっ、そうなの？　私に精液\nかけてみたかったのねぇ♪　もぉ～栄養摂取できないけど、いいわよお♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0104402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「どうせなら、い～っぱいか・け・て……♪　あっ♪　あぁん♪　元気元気ぃ\n……♪　ねばねばしたあなたの精液が、私の身体中に降り注いで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0104403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「とぉってもあったかいわ……♪　あんっ♪　この極上の精液を、直接おまん\nこでちゅうちゅう吸い上げたかったけど、かけられるのも好きよ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0104404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「あなたがっ♪　どれだけ興奮してくれたのか、目で見てわかるし臭いに酔え\nるもの……♪　ああ～……♪　イカくさくて、真っ白で……うっとりよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0104405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「かけて♪　かけて……っ♪　んぁんん♪　人間の男の子なのに、インキュバ\nスよりたくさん発射してくれるなんて……千年に一人の逸材だわぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0104406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「は～～～♪　ふふふ、どうだった？　淫魔主婦に精液ぶっかけ♪　私の肌…\n…色が濃いから純白の色がよく映えるでしょ？　お気に入りなのよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0104407" ]},
		{"command":[ "SETIMAGE", "0", "still_00025901_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「うん……。そうね、やっぱり膣内で受け止める方が、精液のエネルギーは吸\n収できるんだけど、肌からだってパワーを感じることはできるわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0104408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「だから、好きなようにしていいの。だぁって、出すところを決められて窮屈\nに出すより、あなたにはのびのび自由に射精してほしいし……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0104409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「あぁ♪　あなたの精液のおかげでお肌がツヤツヤになっていく……♪　本当\nにありがとう。また、これからも定期的によろしくねぇ♪　いいかなあ？」", "NORMAL" ]},
