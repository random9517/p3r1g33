		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「うん。そうなの……ほら。私ったら淫魔主婦でしょう？　精液を定期的に摂\n取しなければいけないし……性欲の発散も大事だし。それで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「大好きなあなたの寝込みを襲いにきちゃったの。ねえ？　私の食事に付き合\nってくれる？　大人の……夜のお食事よ。そのお顔は、ОＫってことかしら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0104103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETTEXT", "「えぇい♪　あは……♪　こうして馬乗りになるとよ～くわかるわぁ……♪　\nあ・な・たのおちんちん、私に食べて欲しがってるぅ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0104104" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00025901_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「んふふふ、同意ならいいわよね？　おちんちん、取り出して可愛がっても…\n…♪　はぁ、はぁ……素敵。こんなに勃起して。なんて大きいの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0104105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「こんな美味しそうなおちんちんをぶらさげて生活したりなんかするから、わ\nる～い人妻サキュバスに狙われちゃうのよお？　自覚しなさぁい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0104106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「……ん……♪　ふふ、私のアソコから……。おまんこからクチュ、チュクっ\nて水音がするの、聞こえる？　これ、愛液の音なのよ。っんん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0104107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「あなたを襲って犯しちゃおうって考えた瞬間からね？　こうやって、ずーっ\nとずーっと濡れてたの。それでぇ、おまんこがほかほかになっちゃって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0104108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「とろっとろの愛液が溢れて止まらなくなっちゃって……。んん♪　うふ、お\nちんちんにね、腰をこすりつけておツユ染みこませたくて大変だったわ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0104109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「どう？　ちゃぁんとおまんこで愛液、ぬりぬりできてるかしらぁ？　んぁっ\n♪　ああああっ♪　もうだめ、興奮しすぎてわけがわからないの♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0104110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「ねえ……？　私のおまんこ、充血してもう真っ赤。でも、あなたのおちんち\nんもすぅ～っごく硬くなってるわ……。こんなにおっきいと苦しいわよね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0104111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「だからママの……私のサキュバスおまんこに精子、吐き出しちゃいましょう\n？　ね？　ね？　優しくするわ、ぜーんぶ委ねてくれていいのよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0104112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「んふふふ♪　どうしたの？　お返事も出来ないくらいドキドキしてるのかし\nら。そんなに無防備だと、おちんちん咥えこまれちゃうんだからねぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0104113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「ほ、ら……っ♪　ほらぁあ♪　簡単ににゅるんって入っちゃったぁあ……っ\n♪　私の淫魔主婦おまんこが、淫乱サキュバスおまんこが食べちゃった♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0104114" ]},
		{"command":[ "SETIMAGE", "0", "still_00025901_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「えぇ……？　そんなに気持ちいいの？　とろ～っととろけたお顔して……だ\nらしないんだから♪　でもそうね、淫魔主婦のおまんこはスゴいのよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0104115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「愛液たっぷりで、中が蜜で満たされてるのに……キツさは減らずにヒダヒダ\nがぎゅーって密着してくるの。ユルくなったりしないのよ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0104116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「挿入してるあなたにだけはわかるわよね♪　そう、全員が名器なの♪　その\n中でも私のおまんこは、ヌルヌル感が強くて……あぁんっ♪　奥、がぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0104117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「小さなツブツブいっぱいの数の子天井なのぉおおお♪　だから、太い亀頭を\n入れるとこすれて……。あっ♪　最高の快楽が味わえる……はぁんん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0104118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「ここよ……♪　ここ♪　おまんこの一番奥をぐっちゅぐちゅっておちんちん\nでこすりたいの♪　柔らかくなった子宮口、その先端でえぐられたくて♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「あっ、ああああ♪　もう我慢できないわ！　んふっ♪　勝手に動いちゃうわ\nね？　淫魔主婦に食べられちゃう、警戒心のないあなたが悪いのよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0104120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「はぁっ♪　あぁあぁっ♪　あんっ♪　あんっ、あんっ♪　ああああ……！　\nカッチカチのおちんちん、気持ちいいぃい……！　もっとちょうだい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0104121" ]},
		{"command":[ "SETIMAGE", "0", "still_00025901_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「ごりゅ♪　ごりゅ♪　っておまんこ全部突き上げられてる♪　んぁああっ♪\n　いいわ、色んな角度から楽しめる♪　おちんちん、すっごく太いのぉっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「あん♪　あんっ、いやぁ♪　あぁんん♪　ごめんなさいねぇ♪　夢中で腰を\n振っちゃって、快感に酔いしれちゃう♪　ああああっ、欲望全開よ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0104123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「おちんちん♪　おちんちん好きぃ♪　美味しいっ♪　あなたのおちんちん、\n誰のよりも一番美味しいのっ！　私のおまんこが喜んでるぅうっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0104124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「あっあっ♪　私達、性器の相性がいいのかしらね？　すぐにイッちゃいそう\n……♪　あぁっ、淫魔主婦をイかせるなんてすごいのねぇっ、あぁんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETTEXT", "「ふぁあああっ♪　気持ち良すぎておっぱいミルクっ……！　母乳が漏れちゃ\nった♪　んぁっ♪　ああッ、私がイッてるの、嘘じゃないって証拠よぉ♪」", "NORMAL" ]},
