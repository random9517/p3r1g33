		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「んふんんんっ♪　あなたのおちんちんって、本当にサキュバスからすれば最\n高級品よぉお……！　んぁっ、母乳がどんどん溢れるぅ、分泌されるっ」", "NORMAL" ]},
