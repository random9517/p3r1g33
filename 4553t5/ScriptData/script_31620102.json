		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「あぁっ……してくれっ、遠慮することはないっ……お前のしたいようにっ、\nもっと強くっ、激しくっ……オチンポッ、してくれっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0104218" ]},
		{"command":[ "SETIMAGE", "0", "still_00016201_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「私もっ……あぁっ、もうっ……何も分からないっ……けどっ、気持ちいいか\nらっ……あっ、はっ、あぁっ、んぁぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0104219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「だからっ……出してっ……射精っ、また……してっ、はっ、あっ、あぁぁぁ\nんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0104220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「うんっ、またっ、中がいいっ……中に出してっ……このままっ、オマンコの\n中ぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0104301" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「んぁぁぁぁぁぁぁーっ！　出て……るっ……また……入って来るの……わ、\n分かるぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0104302" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016201_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「はぁぁ……気持ちいい感覚が……弾けて……こ、これが……イクと……いう\nことなのか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0104303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「あっ……今、また……出たっ……敏感になってるオマンコに……熱いのっ…\n…当たるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0104304" ]},
		{"command":[ "SETIMAGE", "0", "still_00016201_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「はぁっ……はぁ……あっ、ふっ……終わった……のか……？　はぁ……そう\nか……ご、ご苦労……だったな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0104305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「これで……受精して……着床して……その、上手くいけば……私は妊娠する\n……ということになるのか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0104306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「ふふっ……どうした、神妙な顔をして。今更怖気づいたのか？　何、心配す\nるな……お前の思うようなことにはならんさ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0104307" ]},
		{"command":[ "SETIMAGE", "0", "still_00016201_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「だが、確かにお前の生命力を身体に宿す……この感覚は、実際に味わってみ\nないと分からないものだった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0104308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「それに……ま、まぁ……気持ちよかったしな……その、お前のニヤつき顔さ\nえなければもっと良かったが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「も、もし……次があるなら、今度は私も……もっと工夫してみようと、思う\n……その時は……また、よろしく……頼む……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「んんっ……な、何っ……身体にっ……掛けたいっ？　何でもっ……何でもい\nいからっ、出してっ……しまえっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0104401" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「ひぁぁぁぁぁぁぁんっ！　あふっ、あぁっ……熱いのっ……掛かってるっ、\n胸にも……あぷっ、か、顔にまでっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0104402" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016201_02_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「んぁっ……またネバネバのドロドロが……はぁぁ……何て量だ……あぁ……\n私の身体に染み込んでいくぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0104403" ]},
		{"command":[ "SETIMAGE", "0", "still_00016201_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「はぁぁ……気持ちいい感覚が……ずっと続いている……これは……イクと…\n…いうことなのか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0104404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「んっ……ふ……あ……射精も……終わるのか……そうか……んっ、はぁ、は\nぁ……はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0104405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「これが……せっくす……一発目より、はっきり分かるぞ……確かに、これは\n……気持ちいい……特別な感じがする……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0104406" ]},
		{"command":[ "SETIMAGE", "0", "still_00016201_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「しかも、これで私の力を引き出すと……全く……本当に呆れた力を持ってい\nるんだな……お前は……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0104407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「うぅ……まだ、オマンコに何か挟まっているような感じがする……んっ……\n不快ではないが……慣れぬものだな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0104408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「そ、それでどうだった……？　お前は……ちゃんと、気持ちよく……なれた\nのか？　そ、そうかっ、感じたから……射精したんだなっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0104409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「も、もし……次があるなら、今度は私も……もっと工夫してみようと、思う\n……その時は……また、よろしく……頼む……」", "NORMAL" ]},
