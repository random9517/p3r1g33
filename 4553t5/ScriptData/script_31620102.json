		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「今日は、ちゃんと覚悟も決めて来た。お前達のやり方で、私と……交尾……\nまぐわいをしてくれ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0104103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「とりあえず、こうして……足を開けばいいんだろう？　あ、あまりジロジロ\nとは見るんじゃないぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0104104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「っ……だから……ジロジロ見るなと言ってるのにっ！　どうして、そんなに\nじっと見るのだっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0104105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
