		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「ま、まぁ……お前の気持ちは分からんでもない。だが……それよりも、今は\n役目を果たせ。私の……準備は済んでいるんだからな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0104107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
