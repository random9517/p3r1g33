		{"command":[ "FADEINIMAGE", "0", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0204302" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「精液がオマンコの奥に当たって、んひぃいいっ、子宮口から中まで、びゅー\nびゅー入ってきてるよぉ、あぁあああんっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0204303" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「んあぁっ、あぁっ、あっ、あっ、子宮が溺れちゃう、あぁあんっ、ザーメン\nタンクになっちゃうぅっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0204304" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、あっ、中出し精液、気持ちいいっ、またイっちゃうぅ、恥ずか\nしい格好で種付けされて、またイっちゃうぅ……んあぁっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0204305" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「あぁ……オチンポ気持ちいいよぉ……正義のヒーローなのに、あなたの悪者\nオチンポに、負けちゃったぁ……あふぅ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001302_02_11" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0204306" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……もー……ひどいよぉ……こんなＨな格好で、あんなに乱暴に\nするなんてぇ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0204307" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「そりゃあ、あなたが喜んでくれたなら嬉しいんだけど……うぅ、でもやっぱ\nり、ちょっと複雑だよ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001302_02_10" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0204308" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「あのね、私は意地悪されて気持ちよくなったんじゃなくって、大好きなあな\nたが喜んでくれたから、嬉しくて気持ちよくなったんだからね？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0204309" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「だから次はもうちょっとフツーにしてほしいなぁ……。……うん。ならいい\nよ。許してあげる」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0204310" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「えへへ……ヒーローだって女の子だもん、好きな人とはもっとちゃんとＨし\nたいんだからね？」", "NORMAL" ]},
