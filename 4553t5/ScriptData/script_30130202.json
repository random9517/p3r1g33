		{"command":[ "PLAYVOICE", "013_0204402" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「んあぁ、身体にかかっちゃうよぉ、ザーメンがいっぱい、スーツにもびちゃ\nびちゃかかってるぅ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0204403" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「ダメだよぉ、んあぁ、あっ、あっ、精液まみれになっちゃうぅ、んあぁっ、\n匂いが染み付いて、取れなくなっちゃうよぉ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001302_02_14" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0204404" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「あぁんっ、あんっ、また出てるぅ、オチンポが跳ねる度に、どぴゅ、どぴゅ\nって、たくさんかかっちゃうぅ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0204405" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「もうかけないでぇ……やぁんっ、ザーメン臭いＨなヒーローになっちゃうぅ\n……恥ずかしくて変身できなくなっちゃうよぉ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0204406" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「うぅ……どろどろのザーメンでＨなマーキングされちゃったよぉ……ヒーロ\nーなのに、悪者のオチンポに負けちゃったぁ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0204407" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「精液の匂いも染み付いて……はうぅ、スーツがザーメン臭くなったら、チビ\nっ子たちの前で戦えなくなっちゃうのにぃ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0204408" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「困るよぉ、精液まみれの正義の味方なんて……そんなＨなの……うぅ、本当\nはダメなのにぃ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0204409" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「……でも……ヒーローとしてはダメなんだけど……あなたのものにされたみ\nたいで、本当はちょっと嬉しいかも……」", "NORMAL" ]},
