{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001302_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "PLAYVOICE", "013_0204101" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「きゃあっ！？　どうしてこんな格好に……！？　こんなの恥ずかしいよぉ、\nやだぁ、下ろしてぇ……！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0204102" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「ちっちゃい子がおしっこしーしーするみたいなこんなの……ヒーローがしち\nゃダメだよぉ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0204103" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「……もしかして、このままするの？　でも……恥ずかしいよぉ。アソコだっ\nて、丸見えになっちゃうし……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0204104" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「え、それが良いの……？　シルバスターを辱めて犯すのに興奮する……？　\nんもう……未だに悪者根性が抜けないんだから……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0204105" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「そりゃあ、あなたの為ならなんでもシてあげたいけど……でも、シルバスタ\nーは正義の戦士で……みんなのヒーローだから……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0204106" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「や、やっぱり、これはダメっ。今日はフツウの格好でしよう？　ね？　だか\nら下ろして、おねがい？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0204107" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「他の時なら、この格好でもどんな格好でもしてあげるから……ちょっと恥ず\nかしいけど、あなたの為なら……ね？　だから……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0204108" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「……え？　あのね、ちょっと待って……ナニをしてるの……？　ちょちょち\nょ、まさか、本当にこのまま……！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0204109" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「やぁあああんっ！　オチンポ入ってきてるよぉっ……！　ダメって言ってる\nのにぃ、あぁあんっ、こんな格好のままぁ……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001302_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0204110" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「んあぁっ、あっ、あっ、オチンポバキバキに勃起してるぅ、いつもより太く\nて、固くて……ひぅうっ、興奮しすぎだよぉ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0204111" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「ガチガチのオチンポがオマンコの中に入ってきちゃう、んあぁっ、あっ、あ\nっ、固いのがぐりぐり、奥まで入ってくるよぉ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0204112" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「こんな恥ずかしいポーズで、あぁんっ、アソコむき出しのまま、オチンポ挿\nれられちゃってるぅ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0204113" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「……あひんっ！？　あ、あ……奥のところ、ぐいって押し上げられて……ん\nあぁ……オチンポが全部、入っちゃった……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0204114" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「オマンコがオチンポでみちみちになってる……やぁあんっ、根本までずっぽ\nり入ってるところが、丸見えになってるよぉ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0204115" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「こんなＨな格好、ヒーローが見せちゃいけないのにぃ……うぅ、恥ずかしす\nぎるよぉ！　お願い、抜いてぇ……っ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0204116" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「んあぁっ、あっ、あっ……！　身体が持ち上げられて、んあぁぁっ、オチン\nポがオマンコから抜けてくぅ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0204117" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「やあぁ、私のＨなおつゆで濡れたオチンポが見えてるよぉ、んふぅっ、こん\nなの恥ずかしすぎるぅ、見ないでぇ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0204118" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、あっ……亀頭のところまで抜けて……もうすぐ……んあぁっ、\nあっ、あっ、あっ……あれ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0204119" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「えっと、どうしてここで止めるの……？　……え、待って。もしかして……\nだ、ダメだよ！　今、手を離したら、一気に奥まで……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001302_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0204120" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「あひゅううううんっ！？　んぉぉっ、おっ、奥に、ずんって……んひゅうぅ\nぅっ……お腹の奥、じんじん、痺れてりゅ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001302_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0204121" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「んぁぁ……ひどいよぉ、オチンポがオマンコの中をずりゅりゅって引っ掻い\nて、んふぁぁ、頭の中がビリビリ電気が通ったみたいに……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001302_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0204122" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、身体がまた持ち上げられて……あはぁああんっ、雁首のでっぱ\nりがオマンコの中をずりずり引っ掻いてるぅ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0204123" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「んあぁっ、あぁっ、また亀頭まで……今度こそ手を離しちゃダメだよ……？\n　このまま抜いて、おねがいだから……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0204124" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「あひぃいいいいんっ！？　あ、あひ……ひゅ、ひゅごいよぉ……子宮にずち\nゅうってぇ……あひぃ、強すぎるよぉ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001302_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0204125" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「こんな格好で、身動きできないのを良いことに、あふぅぅ、本当に犯してる\nみたいにしてぇ、んひぃぃっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0204126" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「卑怯者ぉ、正々堂々、Ｈしなさいっ……！　あ、あ、待って、そんなに持ち\n上げないで……あぁんっ、あ、あ、ダメ、手を離したら……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001302_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0204127" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「あふぅうううんっ！？　オマンコのナカを一気に奥まで、ブリュリュリュっ\nてしてぇ……赤ちゃんのお部屋、どちゅんってぇ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001302_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0204128" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「んあぁっ、オチンポの先っぽが、子宮を無理やり突き上げて、んひぅううっ\n、こんなの気持ちよすぎて、頭おかしくなっちゃうぅ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0204129" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「んあぁっ、あっ、あっ、シルバスターの時は身体が丈夫だからって……あ\nひぃいいんっ！　こんな乱暴なセックスをするなんてぇ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0204130" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「うぅ、あなたにいっぱいＨな改造をされちゃったからぁ、んひぃいいいっ、\n簡単に気持ちよくなっちゃうぅ、あひゅううううっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0204131" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「こんな、ヒーローのオマンコを、あふぅうううんっ、オチンポをシゴくため\nの、道具みたいに、ぃひいいいんっ、くぅ、くやしい……っ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001302_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0204132" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「私は正義の戦士『シルバスター』だから、あひぃいいんっ！　卑怯なＨに負\nけちゃダメなのに、あひゅううううっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0204133" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「んあぁっ、オチンポ太いぃっ、風船みたいにふくれた亀頭がオマンコのお肉\nをぷりぷりかき分けて、あひぃいいいんっ、もうダメぇっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0204134" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「悪者オチンポでイっちゃうっ、んひぃぃっ！　正義のオマンコが負けちゃう\nよぉっ！　あっ、あっ、もうだめぇっ、イくイくっ……イくうううっ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0204135" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「あはぁああああんっ！！　中にいっぱい出てるぅっ！　ザーメンたっぷり注\nぎ込まれちゃってるよぉっ！　んひぅうううっ！」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001302_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0204136" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「んあっ、あっ、あっ、オマンコの奥に、悪者の精液がびちゃびちゃかかって\n、んひぅぅっ、熱いぃっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0204137" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「悪者オチンポに犯されて、あふぅううんっ、ヒーローのオマンコの奥までマ\nーキングされちゃってるよぉ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0204138" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「恥ずかしい格好で、こんなＨなことされて、んあぁっ、あっ、あっ、こんな\nに感じちゃダメなのにぃ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0204139" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「んあっ、あっ、あっ、今動かしちゃダメぇっ、まだイってるからぁっ、タマ\nタマに残った精液を気持ちよく出すために、オマンコを使わないでぇっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0204140" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「あぁああんっ、あっ、あっ、もっとイっちゃうっ、オチンポ気持ちいいっ、\n子宮にびゅくびゅく精液当たってる、あっ、あっ、あっ……イくぅっ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0204201" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……おなか、あったかい……精液いっぱい出されてパンパンにな\nっちゃった……んふぅ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001302_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0204202" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「んあぁっ、オチンポまだカチカチで、奥を押し上げてるよ……んふぅっ、こ\nの格好だと挿れてるだけでも気持ちよくて、んあぁ、またイっちゃいそう」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0204203" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、あっ……！？　オチンポがオマンコの中をずりずり擦ってく…\n…んふぅっ！　また、身体をもちあげられちゃうぅっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0204204" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「もしかして、このまま続けてするの……？　はうぅ、これ以上されたら、お\nかしくなっちゃうよぉ……お願い、せめて優しく……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001302_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0204205" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「あひぃいいいんっ！？　子宮、つぶれちゃうぅ……頭のてっぺんまで気持ち\nいいのがズンって響いちゃうよぉ……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001302_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0204206" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「んあぁぁっ、あっ、あっ、ダメぇ、持ち上げないでぇ……オマンコもオチン\nポに絡みついちゃダメぇ、いっぱいこすれちゃうからぁ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0204207" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「あ、あ、オチンポ抜けちゃいそう、高すぎるぅ、こんなところから落とされ\nたら、変な声出ちゃうからぁ……ダメェ……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001302_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0204208" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「んほぉおおおっ！　おぐっ、どちゅってぇ、つよすぎるよぉ……あひぃいっ\n、ヒーローのオマンコをおもちゃにしないでぇ……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001302_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0204209" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「んあぁっ、あっ、あっ、また持ち上げられて……あひぃいいいっ！　んひゅ\nうううっ、連続はダメェっ……おほぉおおおんっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0204210" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「激しすぎるよぉ……あひゅうううんっ！　あっ、あっ、ダメだってばぁ、バ\nカぁ……んほぉおおおおっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0204211" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「こんなにされたらぁ……あひゅうううっ！　気持ちよすぎておかしくなっち\nゃうぅ……んひぃいいいっ！　私の頭、もっとバカになっちゃうよぉ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0204212" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「んあぁっ、ガチガチのオチンポがオマンコのお肉をぶりゅぶりゅかき分けて\nぇ……あひぃいいいっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0204213" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「バキバキになった雁首にオマンコの中ぐちゅぐちゅ回されて、んおぉぉっ、\nカチカチの奥までどちゅどちゅ突き上げられたら、おほぉおおんっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0204214" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「オチンポの形をオマンコに覚え込まされちゃうっ、んひぅうううっ、この形\nにされちゃうよぉ、あひぃいいいっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0204215" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「オマンコどちゅどちゅ、気持ちよすぎるよぉ、ぉひぃいいいっ！　こんなＨ\nな格好で悪者オチンポに犯されて、あはぁああんっ、おかしくなっちゃうぅ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001302_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0204216" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「んあっ、あっ、あっ、ヒーローのオマンコがしつけられちゃってる、あひぃ\nいいんっ、悪者オチンポをシゴくためのＨな道具にされちゃってるぅ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0204217" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「もうやめてぇっ、私の負けだからぁ、んひゅうううっ、私のオマンコ、あな\nたのオチンポに負けちゃったのぉ、あひぃんっ、だからもう許してぇ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0204218" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「今の私、ヒーローがしちゃいけない顔してるよぉ、あぁあああんっ、オンナ\nの顔をしちゃってるからぁ、あふぅうううんっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0204219" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「んぁあああっ、あっ、あぁっ、またイっちゃうっ、ヒーローオマンコ、イっ\nちゃうっ、奥までずんずんされて、また負けちゃうぅっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0204220" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「悪者オチンポにたっぷり躾けられて、またイっちゃうよぉっ！　あはぁああ\nんっ！　イくイくイくぅっ！　もうダメぇっ！　イっぐううううっ！！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},
		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "PLAYVOICE", "013_0204301" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「あひぃいいいんっ！　いっぱい出てるっ、オマンコの中にまたどぴゅどぴゅ\n出てるぅっ！　オマンコパンパンになっちゃうっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001302_02_12" ]},
