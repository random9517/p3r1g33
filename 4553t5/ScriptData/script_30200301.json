{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002003_01_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「別にそなたのオチンポを咥えるのは構わないのだが、この恰好はどういうこ\nとであるか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0303101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「ふむ……？　このモード・アヌビスが犬っぽいから、おすわりして欲しくな\nったのであるか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0303102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「どんな理由であれ、王である我を跪かせるなどあってはならないことである\n。その罪、万死に値するのである」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0303103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「……だが今日は特別に、そなたの罪を許してやろう。人間に対して寛容な我\nに感謝するがいい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0303104" ]},
		{"command":[ "SETIMAGE", "0", "still_00002003_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「なぜ許すのか、であるか……？　それは、その……い、言えないのである…\n…！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0303105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「そなたのオチンポを見て興奮したなどと、言えるワケないのである……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0303106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「と、とにかく、今日はフェラチオをして欲しいのであろう？　ならさっさと\n、オチンポをクチに近づけるのである！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0303107" ]},
		{"command":[ "SETIMAGE", "0", "still_00002003_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「んっ……少し蒸れたようなニオイがするのである……ちゃんと洗っているの\nであるか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0303108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「すうぅ……はあぁ……オチンポの香りで、頭がクラクラするのである……で\nもニオイは嫌いじゃないのである……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0303109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「くっ、あふっ……！　香りだけじゃなくて、もっとオチンポを堪能したいの\nである……んっ、ちゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0303110" ]},
		{"command":[ "SETIMAGE", "0", "still_00002003_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「ちゅぷっ……ちゅ、じゅるっ……！　ぐちゅ、ずりゅ……れろっ、ぴちゅ…\n…ちゅぱっ、じゅ……ちゅぷっ、ちゅぢゅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0303111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「んぷっ、ずちゅ……！　オチンポの味が、クチいっぴゃいに広がりゅのであ\nりゅ……んぶっ、ちゅぴっ……ぢゅ、ずぷぷっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0303112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「ぢゅ、ぴちゃ……ちゅぴっ、ずずっ……しょなたは確か、こにょカリのとこ\nりょが好きだったであるな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0303113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「くぷぷっ……れろっ、ぺろっ……！　ぴちゃ、にちゅ……くちゅ、ずりゅ…\n…！　れりゅ、ずりゅ……ずっ、ぢゅぢゅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0303114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「んぶっ……んぷっ……！　はぁ、はぁ……もっと犬が人間を舐めるように、\n激しくペロペロして欲しいのであるか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0303115" ]},
		{"command":[ "SETIMAGE", "0", "still_00002003_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「王である我を犬扱いとは……！　フェラチオが終わったら、憶えておくので\nある……！　んっ、あむっ……ちゅ、くちゅるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0303116" ]},
		{"command":[ "SETIMAGE", "0", "still_00002003_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「ずぷっ、ぐぷっ……！　ぺろっ、ぴちゃ……くぢゅ、にちゅるっ……！　こ\nんら感ひれ、いいでありゅか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0303117" ]},
		{"command":[ "SETIMAGE", "0", "still_00002003_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「ぐぷっ、ちゅぷぷっ……！　もっひょ亀頭のあひゃりをペロペロひて欲しい\nでありゅか……？　いいひゃろう……んっ、んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0303118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「ずっ、ちゅぱっ、ちゅぴっ……！　ぐむっ、んむっ……れりょ、ぴちゃ、く\nちゅるっ……！　にちゅ、ぐちゅ……ずずっ、ちゅぴぃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0303119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「んんっ……！　オチンポが大きしゅぎて、顎が外りぇひょうでありゅ……！\n　ちゅ、くぷっ……ぷちゅ、ぢゅちゅうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0303120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「ぷはっ……！　はぁ、んっ……オチンポが我の唾液でヌルヌルであるな……\nそれに、咥える前より太くて、カタくなっているのである……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0303121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「こんなのを味わわされたら、身体が勝手に反応してしまうのである……！　\nんっ、んちゅるっ……くぷっ、ちゅぷるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0303122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「んっ、んっ……！　ずちゅ、れろっ、ぴちゃ……！　ちゅぱっ、ずちゅ、ぴ\nちゅるぅ……！　にちゅ、くちゅるっ、ぐぷぷっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0303123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「裏スジやオチンポにょ先端も……ペロペロすりぇばいいのれありゅか……？\n　まっひゃく、注文が多いでありゅな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0303124" ]},
		{"command":[ "SETIMAGE", "0", "still_00002003_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「じゅるっ、じゅじゅっ……！　ぴちゃ、ぺりゅ、くちゅるぅ……！　れろれ\nろっ、にちゃ、ちゅちゅ……ずっ、じゅるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0303125" ]},
		{"command":[ "SETIMAGE", "0", "still_00002003_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「んっ、んぷっ……！　オチンポにょ先っぽを舌でグリグリすりゅと……いや\nらひい汁がどんどん溢りぇてくりゅのである……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0303126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「ちゅ、ちゅちゅるっ……！　んっ、こくんっ……！　少ひ塩気があっひぇ…\n…変な味であるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0303127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「だが……しょなたの体内で生成しゃれた汁だと思うと……嫌いじゃないので\nありゅ……んぷっ、ちゅぱっ……れろっ、ずりゅうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0303128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「あむっ、んむっ……！　くぱっ、ちゅぷっ……！　ずっ、じゅじゅっ……！\n　ぢゅぞっ、じゅぢゅ……！　ぴちゃ、ぷちゅうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0303129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「んふっ、ぢゅぷっ……！　はぁ、んふっ……！　オチンポペロペロすりゅの\n、クセになりひょうでありゅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0303130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「そなたにょオチンポ……もっと感じたいのでありゅ……！　ちゅぱっ、ちゅ\nちゅ……！　ぐちゅ、ずっ、じゅるるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0303131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「んんんっ……！　オチンポにょ動きが激ひくなってきひゃのでありゅ……！\n　確かこりぇは、ザーメンが出りゅ合図であっひゃな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0303132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「あぶっ、ちゅぷっ……！　こにょままクチの中に出ひたいのか……！？　い\nっ、いいだりょう……我のクチに出しゅことを許可ひてやる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0303133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ、じゅるっ、ぢゅぷっ……！　んちゅ、くちゅ、ずぷっ、じゅぱっ\n……ずずっ、ぢゅぴっ、ぢゅぱっ、れろぉ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0303134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「じゅっ、ちゅちゅるっ……！　遠慮しぇずに、出すといいのれありゅ……！\n　んっ、んむっ……！　んむううぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0303135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「うぶっ……！　んじゅ、ぢゅるるっ……！　喉の奥まりぇ、ザーメンが届い\nていりゅのであるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0303136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002003_01_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「しゅごい勢いでありゅ……！　んんっ、ずっ、じゅるるっ……！　ちゅ、ち\nゅぢゅ……！　喉が焼けてしまいそうれありゅな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0303137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「ちゅずっ……！　こくっ、ごくんっ……！　んぷっ、じゅるっ……！　はあ\nぁ……味も我慢汁より濃いのでありゅうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0303138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「こんらにも濃厚にゃザーメンをオマンコに出さりぇたりゃ……我の身体はお\nかしくなってひまいそうだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0303139" ]},
		{"command":[ "SETIMAGE", "0", "still_00002003_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「んちゅ……ちゅぱっ、じゅるっ……！　ずずっ、ちゅ、くちゅるっ……んん\nっ、ごくんっ……ごっくんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0303140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「んっ……ちゅ……しゅごい量でありゅな……クチの中が未だにザーメンまみ\nれでありゅぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0303201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「こりぇだけ出せば、そなたも満足でありょう……これで終わりに……んっ、\nんぶっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0303202" ]},
		{"command":[ "SETIMAGE", "0", "still_00002003_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「オチンポがまたクチの中れ大きく……！？　んなっ……！？　わ、我が物足\nりなさそうな顔をひていりゅだと……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0303203" ]},
		{"command":[ "SETIMAGE", "0", "still_00002003_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「しょんなことはないのでありゅ……！　我が……満足してないなど……！　\nんっ、んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0303204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「だ、だが……そなたがどうひてもと言うにゃら……もう１回くりゃいなら、\n付き合ってやりゅのであるっ……か、感謝すりゅがいい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0303205" ]},
		{"command":[ "SETIMAGE", "0", "still_00002003_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「んちゅ、くちゅるっ……！　ずっ、じゅぞっ……ちゅぱっ、れろっ、ぴちゅ\nるっ……！　ちゅぱっ、ずずっ、ちゅるるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0303206" ]},
		{"command":[ "SETIMAGE", "0", "still_00002003_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「あんんっ……！　オチンポの奥かりゃ、ザーメンの残りが出てくりゅのであ\nるっ……！　ずっ、じゅぞっ……ちゅずっ、じゅぷるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0303207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「奥の方にまら残ってりゅから、吸い出して欲しいらと……？　そなたは我を\nなんらと思っていりゅのだ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0303208" ]},
		{"command":[ "SETIMAGE", "0", "still_00002003_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「んちゅ、ちゅちゅ……！　べ、別にやらにゃいとは言ってないのれありゅ…\n…！　ずっ、じゅぞぞっ……！　ちゅぱっ、じゅぱぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0303209" ]},
		{"command":[ "SETIMAGE", "0", "still_00002003_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「くちゅ、ずずっ……！　れろっ、ぴちゅるっ……！　はぁ、んっ……！　吸\nえば吸うほろ……クチの中に味が広がるのでありゅうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0303210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「はぁ、んっ、あはぁ……！ダメでありゅっ……！　こんにゃの味わい続けた\nりゃ、勝手にクチと舌が動くのであるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0303211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「ずぷっ、じゅぷっ！　ちゅぱっ、ちゅ、ずずっ！　じゅるっ、にちゅ、くぢ\nゅ！　れろっ、ぴちゃっ、ぷちゅるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0303212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「んっ、んんっ！　オチンポペロペロがとまりゃないのでありゅっ……！　皮\nの隙間にも、舌が入りこむのであるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0303213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「れりゅ、ずずっ、ぴちゅ、ぷちゅうぅ！　ぢゅ、じゅぞっ、んじゅるっ！　\nはぁ、んんっ！　オチンポ舐めるにょ、たまらないのであるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0303214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ、じゅぴっ、ぢゅぱぁ！　んっ、じゅるるっ！　じゅぞっ、れろっ\n、ぴぢゅ、ぷじゅるっ！　ちゅぱっ、ぢゅぷっ、ちゅぽぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0303215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「じゅぞっ、ちゅるっ！　はぁ、んんっ！　オチンポをずっと舐めていひゃい\nと思うなんて、王としてはしたないのであるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0303216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「だが舌がとまりゃないのでありゅっ！　しょなたのオチンポは、我を気持ひ\nよくさせてくるのであるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0303217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「んむっ、じゅずっ！　んっ、んんっ！　んふうぅ！　オチンポが膨りゃんで\nきたのれあるっ！　またイキそうなのであるな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0303218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「またクチの中に出すのでありゅ！　そなたのザーメンをたくしゃん味わわせ\nて欲しいのでありゅうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0303219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「んぶっ、ちゅちゅ！　ちゅぱっ、ぴちゅるっ！　は、早く出すのであるっ！\n　あっ、んちゅ、ちゅぱっ、ちゅちゅ、ちゅるうううぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0303220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「んんっ！　じゅるっ、ちゅぱっ！　あふっ、んぶうぅ！　まひゃザーメン注\nがりぇているのであるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0303301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002003_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「２回目にゃのに、しゅごい量であるっ！　そりぇにさっきよりも、勢いがあ\nりゅのであるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0303302" ]},
		{"command":[ "SETIMAGE", "0", "still_00002003_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「クチの中がザーメンでいっぱいになりゅ……！　んじゅるっ、ちゅぱっ、じ\nゅぞぞっ！　んぶっ、んぐっ、んぐっ、ごくんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0303303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「ぢゅるるっ！　じゅぞっ、んじゅるぅ！　んぶっ……ま、まだ出るのである\nか！？　さすがに出しすぎなのでありゅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0303304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「じゅぞぞっ、じゅぞっ！　んふっ、んんんっ！　こんらに出さりぇるのは、\n予想外であるぅ！　んぐっ、んぶっ、んじゅるうううぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0303305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、ちゅぞっ……じゅぞっ……！やっひょ、射精がおさまったよ\nうでありゅな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0303306" ]},
		{"command":[ "SETIMAGE", "0", "still_00002003_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「くちゅ、ちゅぷっ……こんらに出すということは……我のクチは相当気持ひ\nよかったということであるな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0303307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「ほりゃ、もう終わりでありゅ……早くクチからオチンポを離ひて……んっ、\nんむっ……！？　な、なんれまだ大きくなるでありゅか……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0303308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「もっひょ我のクチマンコを味わいたい……？　いっぱい出して、お腹の中\nまでマーキングひたいだと……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0303309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「だ、ダメでありゅっ！　これ以上は、クチが壊りぇて……んぶっ、んんっ！\n　んちゅ、ちゅるっ！　んんんんんっ～～～！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0303310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「んぷっ！？　あっ、あぶっ！？　ど、どうして顔にかけるのであるかっ！？\n　んふっ、あっ、あっ！　あはあぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0303401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002003_01_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「我はクチに出せと言ったであろう！　なのに、なぜ……！　あっ、あひっ、\nんんんっ！　ひうっ、あっ、あっ！　ザーメン熱いのであるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0303402" ]},
		{"command":[ "SETIMAGE", "0", "still_00002003_01_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「これではまるでマーキングであるっ！　我をペットのように扱うなど、あっ\nてはならないのであるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0303403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「あああぁ！　顔がザーメンまみれにされていくのであるっ！　変なニオイも\n、鼻の奥に届いて……ひぐっ、あっ、んはあぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0303404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「ダメであるぅ！　こんなの味わわされたら、イッてしまうのであるっ！　あ\nっ、あっ！　イクのであるっ！　んっ、あっ、ああああぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0303405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「はあぁ……んっ、くうぅ……！　イッてしまったのである……！　王である\n我が、人間のザーメンを浴びてイクなど……んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0303406" ]},
		{"command":[ "SETIMAGE", "0", "still_00002003_01_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「そなた……我の命令に背いただけでなく、許可なく顔を汚すとは……！　冥\n府に落ちる覚悟はできているであるか……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0303407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「我のこの姿が可愛いから、つい顔にかけたくなった……？　自分のモノにし\nたくて、たまらなくなっただと……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0303408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「わ、我が人間のモノになるワケないのである！　むしろそなたたち人間は、\nマシンファラオによって管理される存在である！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0303409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「だが……我を欲するそなたの心意気だけは買ってやらなくもないのである…\n…感謝するといい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0303410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}