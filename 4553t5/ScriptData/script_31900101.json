{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「はいはーい♪　艦長……セリカ・ミヤシタ！　隊長ちゃんの呼び出しに応じ\n、着任しましたよ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0103101" ]},
	{"command":[ "SETCHARA", "0", "char_00019001_01", "8", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPTEXT", "TRUE" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「……こんな夜更けにどーしたの？　ははーん。ふるさとが恋しくなって、寂\nしくて泣いちゃった？　あるある、宇宙ではよくある！　って違うのお？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0103102" ]},
	{"command":[ "SETCHARA", "0", "char_00019001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「うん。戦力増強のために、幹部クラスにパワーアップ講習を義務付けている\n……。それで、今日は私の番……。へえっ、そうだったんだ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0103103" ]},
	{"command":[ "SETCHARA", "0", "char_00019001_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「夜遅くまでほんっとご苦労だね～！　で、何をしたらいいのかな？　外は暗\nいし……室内で筋トレとか？　……ん？　パイズリ……？　脂肪トレ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0103104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「おっぱいなんて、いくら使っても強くならないよ？　あはは、大きくはなる\nかもだけど……って、あれ？　もしかして真剣に言ってる？　えーと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0103105" ]},
	{"command":[ "SETCHARA", "0", "char_00019001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「んー……よくわかんないけど……わかった！　でも、パイズリなんて……正\n直、したことないからどーなんだろ。ま、案ずるより産むがやすし！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0103106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「ん、しょ！　こうやって床にしゃがんでー……どぉだ！　おっぱいボロンッ\n、だよ♪　あははは、今のすっごい勢いでまろび出ちゃったねっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0103107" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00019001_01_02" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「……そんでー……。おっぱいの谷間、に隊長ちゃんのを受け入れる……んだ\nよね。って、あっ……な、なんかすっごい大きいんですけどーーー！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「えーっ！？　そーなんだ！？　男の人のって……えーっ！！　スッゴっ……\n！　これってフツーのサイズ？　違うよね？　あわわわ、おっとっと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「私の胸、結構おっきーのになかなか捕まえらんないんだけど！　わー……ん\nはははっ♪　なんかぴとぴとしてる、ぺたぺた？　少し汗かいてるー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「いいよ、いいよ。そのままで……私は全然気にしないから。んで、それ、こ\nっちにちょーだい……そうそう。よーしよし、おっぱいは怖くないよぉ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0103111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「ぱふ、ぱふ、ぱふ、ぱふ……くにくにくに……♪　んっ……こいつぅ♪　元\n気一杯じゃない♪　だーめっ、逃がさないから！　ぎゅむーむぎゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「あはっ……めちゃくちゃ逆らってくるよー♪　あっ、硬いのに……不思議に\n弾力があって、おもしろーい……これ、私にも欲しいなー♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「だって、こんな楽しいコがさぁ、いっつも股間にぶら下がってたら……一生\n飽きずに遊べそうじゃない？　おっきくなったりちっちゃくなったり♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「形や太さや大きさまで変わるなんて……。情報だけじゃあ、にわかに信じが\nたかったけど……実物を見たらしっくりきたかも。本当なんだーって♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0103115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「んっ……。ねえ？　これ……上半身を揺さぶったり、隊長ちゃんの股間、に\nすり寄せたりするだけでいいの？　ん、胸全体でシゴいてほしい？　へー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0103116" ]},
		{"command":[ "SETIMAGE", "0", "still_00019001_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「シゴく！？　そうなんだ、そういうもんなんだ……。りょーかいです！　旗\n艦、ダイサンサス艦長……のおっぱい、発進しまーす！　えいえいえい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0103117" ]},
		{"command":[ "SETIMAGE", "0", "still_00019001_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「んーーーっ……ンン♪　んんんーーーーっ、んン♪　っふぅぅ……っ、ふぅ\nっ、ふぅ、ふぅ……♪　んーーーーーーーっ、んんんっ、んんー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0103118" ]},
		{"command":[ "SETIMAGE", "0", "still_00019001_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「あー♪　なんっかコレ……。ヘンな気分になってきちゃうね？　おっぱいっ\nて一応、性感帯だし、そ、それをほら、ち、ち、ちんこ？　に押し当てて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0103119" ]},
		{"command":[ "SETIMAGE", "0", "still_00019001_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「絡ませながらシコ、シコ、シコ、ってシゴいてるとー……。改めて、なんか\nピンクな雰囲気……出ちゃうっていうか。あっ、ちょっと感じる♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「これはおねーさんも……んっ♪　本気を見せなくっちゃじゃない？　あっ…\n…！　いいじゃない、パイズリ……やる気になってきたぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「んっ……あっ♪　はぁっ……はぁっ、は、ぁ……はぁあ♪　胸の間から……\nおちんちんの先っちょが頭を出して……かわい♪　んっ、あっ、あっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「は、ぁ……ンン♪　見えるぅ？　こう、やってぇ持ち上げるとぉ……あっ♪\n　おちんぽ、ぬるぅっておっぱいの中に入ってーぇ……あっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「ずるぅーって引き下ろすとぉ……あっ♪　きゃっ♪　ほら……ね？　谷間か\nら顔出すの……あっ♪　すっごく……すっごくエッチ♪　やらしいね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「私のおっぱい……心地いい？　ふわふわぱふぱふ、くにゅくにゅされてると\n……すっごい甘やかされてる感じするでしょ。うん、うん、甘やかす♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「セリカおねーさんの、超デカ艦長おっぱいでぇ……ダイナミックに隊長ちゃ\nんを甘やかしまくっちゃうんだから♪　っはぁっ、はぁっ、はぁ、はぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「たーぷたぷ♪　たーぷたぷ……えっ？　笑っちゃうからもっと真剣に？　や\nーだ♪　私のパイズリは、私らしくするんだもん……えい♪　えーい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「おっぱいをおちんぽに絡みつかせて……あっ♪　あくまで清く、明るく、正\nしく……楽しく、ね♪　あっ……、ぁっ、あっ、あっ、はぁっ、はぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「お馬鹿みたいなパイズリで、なーに感じまくってくれちゃってるのかなー？\n　神妙にしてないと笑っちゃうって言ってたくせにぃー……ガッチガチ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「たまにはいいでしょ？　明るいパイズリも……あっ♪　ねぇ……なんか♪　\nおちんちん、怒ってるみたいに膨らんで、血管ビキビキなんだけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「あっ♪　これって気持ちいいってことなのかな？　んっふふっ……今にもバ\nーンってはじけちゃいそーなくらいに腫れて、こわーいくらい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「先っちょの穴も、ヌルヌル濡れながら穴がくぱくぱ開いてきちゃって……。\nんっ、これ感じてるでしょ♪　めちゃくちゃ好きなんだよね、おっぱい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「んーいいよいいよー♪　ヌルヌルでおねーさんのおっぱい汚していいし……\n。ゴツゴツの硬くて太くてデカすぎちんぽ、もっと膨張させていいよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「……はぁぁ♪　あぁあ♪　ああっ……あぁ、あぁ……♪　やっぱ、楽しい…\n…っ、おもし、ろーい……♪　おちんぽちゃん、必死すぎてカワイイ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「うん♪　うん♪　セリカおねーさんの艦長おっぱい、おちんぽくんで独占し\nていーよ……♪　隊長ちゃんの隊長ちんぽでぐちゃぐちゃにして、いーよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0103135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「は、ぁ……はぁっ、はぁ、はぁ……♪　スゴいね……♪　二人の熱、が……\n体温が混ざって……超エロい感じ……。あっ♪　あっ、はぁっ、はぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0103136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「ん？　『出る』？　出るって何が？　んー……？　エッチな声？　だったら\nもうだいぶ出てるよ？　あんっ♪　こら、おちんぽ押しつけないで～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0103137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「あっ♪　あっ♪　『出る』？　『出そう』？　うんっ♪　なんだかよくわか\nんないけど出しちゃえ！　そんなのノリでオーケーオーケー♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「隊長ちゃんの本気出してよ♪　おねーさんがどーんと受け止めてあげ……っ\nて、あっ！？　嘘！　ここからまだおっきくなるのっ、えっ、きゃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「何これぇ♪　あっ、あっ、すっごい♪　すっごいすっごいぃい……あっ♪　\n出る？　いいよっ、いいよ、出して♪　何でも出して……あーっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「んんんぷっ！？　んーっぷぁっ！？　んぷーっ……！？　えっ！？　あっ…\n…あはははっ、すっごーい♪　すっごーい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0103201" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019001_01_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「花火みたいにぶしゃーって炸裂して……打ち上がって♪　あはっ……えーっ\n……コレ、隊長ちゃんのお汁？　精液……あっ、精子！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「あ……こ、これ……♪　これが精子……精液なんだ？　そりゃあお勉強で、\n知識としては習ってたけど……すごい♪　本物見たのはじめて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0103203" ]},
		{"command":[ "SETIMAGE", "0", "still_00019001_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「あ……あぁ、透明なお汁よりずーっとずっとエッチな粘り気……♪　ドロド\nロしてて、肌にへばりつく感じがして……なまめかしい……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0103204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「それに、勢いすっごかったし……。ね？　私……もっと見たいな。精子、隊\n長ちゃんの精液……ぶしゃーって溢れ出すの、もう一度見たい……いい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0103205" ]},
		{"command":[ "SETIMAGE", "0", "still_00019001_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「そんなに連発出来るものかわかんないけど……あっ♪　ちょっとおっぱいで\n試してみるね……♪　あ……、あ、あ……あっ、あぁ……ああ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0103206" ]},
		{"command":[ "SETIMAGE", "0", "still_00019001_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「あっんっ、これっ……これ……いきなりスゴいねっ……♪　精液でヌルグチ\nャだから……水音も派手だし、なにより……んぅうう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「ぬめ、るぅ……すべる、すっごいエッチぃいいい……♪　あっ♪　こんなの\n、乳液と変わらないかと思った、けど……全然違うよー……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「この精子っ……精子出た後の方が気持ち……いいよね？　あぁ……何コレ何\nコレぇ……おっぱい動かすのやめらんなくなっちゃうよ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「にゅるにゅるして……ゾクゾクしちゃう♪　ふんんっ……胸だけなのにこん\nなに気持ち良くなっちゃうの？　あっ……私まで……すごい……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0103210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「っなあに？　え……乳首？　乳首が勃起しちゃってる？　うん……うん、だ\nって、素直に気持ち良くてエッチくて、……私、興奮してるから♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「それで、もっともっともっと……隊長ちゃんと気持ちよくなって、隊長ちゃ\nん、のっ……精液ぶしゃってなるとこ、もっかい見たくてたまんないから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「だから……あっ、あっ、本気だよ、真剣にされちゃった……♪　は、ぁ、あ\nっ、ぁっ……ヌルヌルするぅ、にゅるにゅるして……ふあああ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「だめ、だめ……どんどん、どんどん感じちゃう……！　隊長ちゃんも気持ち\nいい……？　おねーさんのおっぱい気持ちいい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0103214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「あは……うれしぃ……♪　うん、うん、どんどん良くなって……♪　二人で\nいっぱい感じちゃお♪　……っあぁん♪　ああっ、あぁあんっ、ああんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0103215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「おっ……ぱい♪　バカになっちゃう♪　あっ……気持ち、いい……気持ちい\nいよぉ……！　パイズ、リ♪　感じるぅ……好きになっちゃうぅ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0103216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「っあぁ♪　隊長ちゃぁん……隊長ちゃんのおちんちんも、かーなーり追い詰\nめられてきちゃってるねぇ♪　いいよ、おねーさんと気持ちよくなろ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「おねーさんのおっぱいに、たーっぷり精液かけていいからね♪　だからまた\n見せて♪　あの白い花火……おねーさん最前線かぶりつきで見てるから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0103218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「んっ……あぁ……あぁっ、ああ……♪　んふふふっ♪　おちんぽ力強くなっ\n、て……膨らんで……あはっ♪　二度目のびゅー出来そう～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「あっんっ出して♪　出して出して♪　おねーさん見守ってるっ、お目目をこ\nらして見てるから……出して、二発目欲しいの……ちょうだいぃ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「あはっ♪　出たっ……出たねっ♪　いいよっ……もっと♪　もっと思いっき\nり出して……出して……！　ンッ……んんん～～～～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0103301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019001_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「大丈夫っ……全部絞り出してあげ……る♪　んんっ……んー……どうっ？　\n根元から先っちょまで絞り上げて……あーっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「強烈なニオイぃ……それに、んぅ……ネバネバ、増してるよぉ……♪　さっ\nきのより濃いのが出てる、出てくる……今回のが本番だったのかなっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0103303" ]},
		{"command":[ "SETIMAGE", "0", "still_00019001_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「あっ♪　あっ……胸に、首に顔にぃ……やったらめったらブビュブビュ出て\nくるぅ～～♪　そうっ、そうコレっ……コレが見たかったんだぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0103304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「んっ、……えぅ～。ちょびっとお口に入っちゃった～。なにこれ、めっちゃ\nくちゃ苦ぁいい……！　でも、なーんかクセになるし、イヤじゃない～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0103305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「んっ……んー……！　んんー……！　な、なんか……身体、すっごくアツい\nよお……。内側から火照っちゃって……私……私……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0103306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「おっぱい、信じらんないくらい燃えちゃってる……。火がついたみたいに…\n…。どうしよ、パイズリの才能に目覚めさせられちゃったかも～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0103307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「……なんて、もしそうなったら隊長ちゃん……嬉しいでしょ？　ふふふっ、\n私がパイズリ大好きなパイズリ艦長になっちゃったらさぁ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0103308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「いつでもどこでも、このおっぱいでズリズリ♪　出来るもんね♪　……あー\n、期待したぁ？　いーよっ、最大限期待してて♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0103309" ]},
		{"command":[ "SETIMAGE", "0", "still_00019001_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「私もっ……パイズリと、隊長ちゃんのおちんぽと精液に……すっごい前向き\nになっちゃった♪　溜まったらすぐに教えてね。また……させて♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「んんんぁっ！？　きゃっ……んむぅっ！？　か、顔にかかってるよぉ！？　\nあっ……んぷぁっ！　あぷっ、んぷぅっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0103401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019001_01_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「あ、ばれんぼうだねーっ……。んぁっ……ぷぁ、ま、まだ出てる……！　二\n回目なのにこんな、ドパドパ出しちゃって平気なのぉ～～！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「っはッ……♪　はぁっ、はぁ……んぇえ……♪　こってりした精液が顔の上\nでプルプル～って……ゼリーみたい……。んっ……そ、それに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0103403" ]},
		{"command":[ "SETIMAGE", "0", "still_00019001_01_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「意識がもうろうとするくらい、濃くて主張の強いニオイ……ぃ♪　そうなん\nだ……これが、赤ちゃん作るお汁なんだ……。熱くて臭くて……好き♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0103404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「んぅ……♪　どろぉ～って、顔をつたいおちてくるのってちょっと、征服さ\nれちゃったみたいでドキドキするかも……。真っ白に染め上げられて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0103405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「セリカおねーさんのお顔とおっぱい、隊長ちゃんに染められちゃった……♪\n　まったくぅ……やんちゃなんだから、そこが可愛いんだけど……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0103406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「あはっ……このドロドロ、絶対洗ってもとれないし……。どーしよ♪　みん\nなに、エッチなことしてたの……バレちゃうかもぉ♪　……どーお？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0103407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「みんなにも教えちゃおっか？　隊長ちゃんは～、パイズリするとおちんちん\nからとんでもない量ほとばしらせちゃうんだよーって。そしたらね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0103408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「ぜーったいみんな、見てみたい！　やってみたいって興味津々になると思う\nんだよね～？　ダイアンサスの女の子って、好奇心旺盛だからさぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0103409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「隊長ちゃん、奪い合いになっちゃうかもよ～？　んふふふ、そーゆーのって\n興味ある～？　あ、でも私にも、またさせてくれなきゃヤだからね～？」", "NORMAL" ]},
