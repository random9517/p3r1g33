		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ルナテミスはともかく、カグヤがこんな反応をするのは……。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "俺がカグヤに対してなにかやらかしたとき？　いや、そんな心当たり\nはないが……", "NORMAL" ]},
