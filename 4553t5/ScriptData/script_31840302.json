		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「……シャワーも浴びずに、すぐにエッチでいいんですか？　ふふ、この衣装\nのまましたいのはわかりますけど……少し、気恥ずかしいですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0304101" ]},
		{"command":[ "SETCHARA", "0", "char_00018403_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「ここに来るまでの間に、私……かなり濡れてしまっていますから。愛液の甘\n酸っぱい香りと、汗の香りがするかも……それでもいいのですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0304102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「……わかりました。いいのなら、このままベッドで……しましょう♪　強く\nぎゅーってしてください。そう、一緒にシーツまで……。あっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0304103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「……どーん……♪　うふふ、いつもはおとなしめな私が、こんなに大胆にあ\nなたを押し倒したのに驚きましたか？　今夜は、特別な夜ですから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0304104" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00018403_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「私も限界までエッチになってみようって思ったんです。……だって、どう言\nい訳したって、身体を持て余したいけない人妻なんですもの……。んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0304105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「出来れば、軽蔑だけはしないでくださいね？　家に夫と子どもを残して……\nこうやって、いやらしい格好で不倫エッチを催促する私を……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0304106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、はぁ……。早く帰らなくちゃいけないってわかっているんです\n。だけど……どうしても疼くんです。全身が……あっ♪　はぁ、はぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0304107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「あなたに何度か種付けしてもらえないと、帰れないって……言ってるんです\n。んっ……。見えちゃってますよね？　私の乳首。もうビンビンで」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0304108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「オマンコも、ずーっとヒクヒクしっぱなしです……。……こんなにぐちょぐ\nちょに濡らしてしまって、本当に……私ったら……。で、でも」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0304109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「この穴に栓、してくれるんですよね？　ラブホテルについてきたんですから\n……。私に誘われて、ノコノコ食べられにきちゃったんですから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0304110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「んっ♪　ふふふ……。チンポ、もうすっかり準備が出来てます。いいんです\nか？　コレ……私の穴に入れたら共犯、ですよ。不倫なんですよ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0304111" ]},
		{"command":[ "SETIMAGE", "0", "still_00018403_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「なんて。冗談です。ここでやめられたら、困るのはこっちです。……あああ\n、このチンポ、見てると理性がどんどん失われていく……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0304112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、触ってください。……あんっ♪　おっぱいを力いっぱい揉みし\nだいて……！　あっ、き、キスもして……！　っちゅっ、ちゅぷ、くちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0304113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「あんっ♪　あん、あんっ♪　……私の腰、動いちゃってますよね。あなたの\nチンポにオマンコあてがって、すりすりってくっつけて……あっあっあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0304114" ]},
		{"command":[ "SETIMAGE", "0", "still_00018403_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「いやらしいお汁、人妻の愛液、チンポになすりつけて誘っちゃってる……。\nあんんっ♪　ごめん、なさい……でもどきたくない、したい、したいです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0304115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「エッチしたい♪　クリスマスの不倫エッチしたいですっ……♪　あっ♪　あ\nっあっ♪　前戯や素股じゃダメです、奥の奥にまでチンポが欲しいです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0304116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「入れて……挿入してぇ……！　……んんんっ、焦らさないでくださいぃ……\n！　あっ♪　あっ、オチンポ相手に盛って、夢中で腰振ってっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0304117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「私、エッチな腰振りダンスさせられてる……♪　恥ずかしいです、あんっ、\nお願いします……！　来年はきっと良い子にしますからっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0304118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「貞淑な妻に、素晴らしい奥さんになりますからぁっ、だから今夜だけはオチ\nンポください♪　浮気チンポ欲しいの、ゴムなんかつけずに生でっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0304119" ]},
		{"command":[ "SETIMAGE", "0", "still_00018403_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「入れて……チンポ、チンポ入れて……！　っ……も、もう、我慢できません\n。私が勝手に、腰を動かして挿入しちゃいます……。ん……んんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0304120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「はぁああぁああ～♪　ああああっ、んぁああああっ♪　ふあぁあああ～～♪\n　デカチンポっ、チンポきたっ、入ってきた……奥までキタぁあ……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0304121" ]},
		{"command":[ "SETIMAGE", "0", "still_00018403_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「はぁううう♪　なんですかコレぇ♪　美味しすぎますっ、あっ♪　クリスマ\nスの不倫生ハメ最高ですっ……背徳感で、膣内が喜んでしまって……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0304122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「はぁっ♪　あっぁっあっ♪　自動でチンポに絡みついちゃってる♪　私のオ\nマンコ……夫のモノなのに♪　あなたのチンポにまとわりついてますぅう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0304123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「んっ！　あっ！　あっ、ぁッ……！　気持ちいい……っ！　ふぁああ♪　動\nきたい♪　もっとチンポ、オチンポ全体堪能したいっ……な、のに♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0304124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「あなたのチンポデカすぎてっ……長くて腰が上手に振れないじゃないですか\nぁあ♪　ずっぷり奥までハマってて……あっあっ、動け、ないぃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0304125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「ふぅ♪　ふぅっ♪　つ……突いて、突いてくだひゃい……♪　もう浮気エッ\nチ、成立しちゃってますから！　私のマンコで始まってますからっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0304126" ]},
		{"command":[ "SETIMAGE", "0", "still_00018403_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「責任は私が全部取りますから動いてぇ！　……はぁんんんんっ♪　あふっ！\n　ズプッ！　ズプッ、て……！　あっあっ、そ、そうです、それですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0304127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「がむしゃらに突き上げて……！　あはぁっ！　私の、私の人妻子宮口に容赦\nなく亀頭でキスしてくださ、い♪　あっあっ、先走り汁塗りたくってっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0304128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「はぁンっ♪　んんっ！　チンポっ♪　あなたのチンポ力強くて……夫とまる\nで違う♪　はいっ、そうです、こっちがいいです、こっちの方がっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0304129" ]},
		{"command":[ "SETIMAGE", "0", "still_00018403_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「浮気チンポの方がすごいです！　あっああああっ……頭がトロけます……！\n　んぁああああ♪　ピストンだってすごく上手くてぇえ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0304130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「あ、ぁあああ……すぐイッちゃいます……。恥ずかしいっ、み、見ないでく\nださ……い、あっ♪　イッちゃう……！　あ～～～～っ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0304131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「んぅううううう……！　ううううっ、う～……っ♪　……はぁっ♪　す、す\nみません。私ばっかり……。ん！？　なんでしょう、今オチンポが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0304132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「太くなって……。あっ？　も、もしかして、私がさっき締め付けたから、イ\nキそうになってくれたんですか？　わ、わかりました、もっと締め付けます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0304133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「んッ……♪　こ、こうですかぁ……？　あぁっ♪　ど、どんどん硬くなって\n……あっ♪　あっぁっあっ♪　イ、イクんですね？　ふぁあああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0304134" ]},
		{"command":[ "SETIMAGE", "0", "still_00018403_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「んぁあああっ……♪　中に、膣内にドピュドピュって……っ♪　あぁんんっ\n♪　んんっ！　いいですっ、子宮の中に注いでかまいません……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0304135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018403_02_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「あふっ♪　人妻子宮にこれでもかって量の生精液……流しこんでください、\nあっあっ♪　熱い……♪　熱いのでタプタプになるまでぇ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0304136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「っあぁああ……っ♪　すごいです……！　私が上になってるのに、真下から\nオマンコの奥の奥にまで精液が上がってきて……っ！　んっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0304137" ]},
		{"command":[ "SETIMAGE", "0", "still_00018403_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「とてつもないパワーを感じますよぉ……！　ッふ……♪　子宮も子宮口も、\n浮気ザーメンの味を覚えちゃいました……こんな、取り返しのつかない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0304138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「気持ち良すぎるエッチを知っちゃったら……♪　夫と二度と出来なくなっち\nゃうかも。いいえ、したって、絶対にあなたを思い出してしまう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0304139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「ふふふ……♪　ふしだらな奥さんで本当に申し訳なくなってしまいますね。\n……あ。まだ、オチンポを抜いてはだめですよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0304140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「せっかく注いでもらった精液がこぼれてしまうのも嫌ですし……。それに。\n私、まだ一回の射精では満足しきってません。物足りないんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0304201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「ですから……ねぇ？　いいですか？　続けても……。ふふふふっ……。ホテ\nルの制限時間が気になりますか？　延長しちゃいましょうよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0304202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「その分のお金は私が払います。だから、身体で払ってください♪　ドスケベ\nな人妻サンタさんに……真っ白なご褒美をくださいな……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0304203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「……返事はオチンポに聞いてみます。……ふむふむ。まだ、オマンコの中で\n大きなままですね。それにピクピクして、刺激を求めているようです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0304204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「このままエッチし続けたいみたいですよ？　あなたのチンポ。そんなに人妻\nのオマンコの居心地はいいですか？　はい。あったかくて、ヌルヌルで？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0304205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「……優しくて、そのくせ貪欲で……。ふふふ♪　あなたがオマンコの中が好\nきなように……私もチンポのことを愛しているんです。だから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0304206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「はぁっ♪　はぁ、腰……振っちゃいますね♪　あっ……♪　あっ♪　あンっ\n……んん、ん～っ……んん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0304207" ]},
		{"command":[ "SETIMAGE", "0", "still_00018403_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「す、すっごいです♪　精液のニュルニュルと、オチンポのゴリゴリ感が合わ\nさって……ああああっ！？　さ、さっきよりもっと気持ち良くて！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0304208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「ぐちゅぐちゅするのがクセになってしまいます、あっ……♪　夢中で腰を揺\nらしているところ、見ないでくださ……い♪　あんっぁっあっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0304209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「はしたない水音をたてながら♪　エッチに集中してしまっている私を……あ\nなたに見られているって思うと、それだけで達してしまいそう、です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0304210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「んんっ……！　あ、ごめんなさい……キツく締めすぎていますか？　っぅ…\n…♪　気持ち良すぎて、か、勝手にそうなっちゃうんです……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0304211" ]},
		{"command":[ "SETIMAGE", "0", "still_00018403_02_06" ]},
