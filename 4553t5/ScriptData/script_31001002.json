{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010010_02_01" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふふ……さて、ばれんたいんというのは、一方的に贈るだけで終わるのでは\nないということは知っているぞ。当然、お返しもあるとな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1004101" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「という訳で、私のアソコにたっぷりとお返しをしてもらおう。ほら……見て\nくれ……もう準備万端に濡れているだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1004102" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「見たところ、隊長どののペニスもすっかり臨戦態勢になっている筈……今日\nは立ったままでまぐわうというのをやってみたいのだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1004103" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んふ……少し恥ずかしいが……くぱっと中を広げて……そう、ここだ……こ\nのままぶっすりと挿し込んで欲しい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1004104" ]},
		{"command":[ "SETIMAGE", "0", "still_00010010_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あっ、んんんっ……！　うくんっ……！　あぁっ、入って……来るっ……隊\n長どののペニスが……ずぶりと埋め込まれていくぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1004105" ]},
		{"command":[ "SETIMAGE", "0", "still_00010010_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「くぅぅぅ……あぁ……いっぱいにさせられる……んんっ、これを待っていた\n……ずっと欲しかったモノだ……熱い……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1004106" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふふ……本当はほわいとでーに、お返しをもらうようなのだが……細かいこ\nとはいいだろう……遠慮なく動いてくれ……あっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1004107" ]},
		{"command":[ "SETIMAGE", "0", "still_00010010_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「はっ、んふっ、あぁっ……そうだ……くぅぅ……んっ、この感触……あっ、\nいつでも……私の弱い所を……擦ってくれるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1004108" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「もう、すっかりこのペニスの形も覚えてしまった……だが、何度味わっても\n飽きることのない、複雑な妙味のある快感だ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1004109" ]},
		{"command":[ "SETIMAGE", "0", "still_00010010_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んっ……あぁ……もちろん、おっぱいも隊長どのの好きにしていいぞ。ふふ\n……隊長どのはおっぱいが大好きだからな……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1004110" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「この揉み方一つでも……どれだけ、いやらしく……ねちっこいのか……んっ\n、何度も何度も揉みしだかれて……乳首も吸われて……はぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1004111" ]},
		{"command":[ "SETIMAGE", "0", "still_00010010_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んんっ、すれば……するほどに……感度が上がってしまっているんだ……は\nぁう……んっ、くぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1004112" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あぁ……もっと強くても大丈夫だから……そう、そこ……乳首……んんっ！\n　ぎゅっと……摘まれてぇっ……くぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1004113" ]},
		{"command":[ "SETIMAGE", "0", "still_00010010_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「更にっ……ずりずりとっ、ペニスが……出入りを繰り返すっ……はぁぁうん\nっ、あぁっ、火照りが増していくっ……そこっ、気持ちいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1004114" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「はっ、ふっ、んぁっ、はぁぁっ……この一定間隔の……突き込みが落ち着く\n……んんっ、くぅっ……あっ、ぉっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1004115" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「密着して……おっぱいの感度を高められながら……同時に、アソコもどんど\nん敏感にさせられて……全部、隊長どのにされるまま……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1004116" ]},
		{"command":[ "SETIMAGE", "0", "still_00010010_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「私の身体の奥まで何もかも知られてしまっている……そして、着実に開発さ\nれ……手中で弄ばれて……はぁ……んんっ、堕とされる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1004117" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「人聞きが悪い……？　ふふっ、なぁに悪い意味ではない。私が望んでいるこ\nとでもあるしな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1004118" ]},
		{"command":[ "SETIMAGE", "0", "still_00010010_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「だから、隊長どのは気にせずに、もっと遠慮なく腰を振って……、あぁっ、\nそうだ……私も昂って……勝手に腰が動いてしまうぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1004119" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、あぁっ、発情して……しまっている……くぅんっ、淫乱の汁\nが……次から次へと溢れて……んんっ、足元に垂れてしまう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1004120" ]},
		{"command":[ "SETIMAGE", "0", "still_00010010_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「はっ、ふっ、んふっ……格好……のことは大丈夫だ……忍びは、多少のこと\nでは動じぬように姿勢を維持する鍛錬を積んでいるからな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1004121" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「だが、んっ、このペニスの気持ちよさ自体は……なかなか、どうして……一\n向に慣れることはない……心地よい悦びだっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1004122" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んぁっ……くぅぅぅっ！　あぁ……また、気持ちいいところに当たって……\n何とか、身体を支えなくては……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1004123" ]},
		{"command":[ "SETIMAGE", "0", "still_00010010_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あ……ふっ、かたじけない……体幹は問題ない筈なのだが……身体が、気持\nちよすぎて……ふらついてしまうんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1004124" ]},
		{"command":[ "SETIMAGE", "0", "still_00010010_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んんっ、例え……おっぱいを揉みながらでも……身体を支えてくれるのは、\n助かる……んふっ……隊長どの自重しろというのは無理だしな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1004125" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「構わないから……そのままで、奥を突いて……もっとぐりぐりと……中をか\nき混ぜて欲しいっ、あぁっ、それだぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1004126" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「はんっ、あうんっ、あぁっ……どうしても声が出るっ、我慢できない……恥\nずかしい音が……漏れるぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1004127" ]},
		{"command":[ "SETIMAGE", "0", "still_00010010_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んふぅっ、乳首も……切なくなっている……くうっ、そこぉ……転がしてぇ\nっ、くりくりしながらっ……んひぁっ、ひぃんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1004128" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「うんっ、はぅんっ、あっ、あぁっ……硬いのが、ずっと……粘膜を擦ってい\nる……くぅぅ……そこ好きだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1004129" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「もう、わざわざ言わなくても……全部してくれるからな……はぁ、んっ、ど\nんどん……隊長どののメスに仕上げられていく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1004130" ]},
		{"command":[ "SETIMAGE", "0", "still_00010010_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んんっ……！　はぁ……んっ、私も……その期待に応えなくてはな……あっ\n、ふっ、んうぅっ……！　自分の柔肉をまとわりつかせて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1004131" ]},
		{"command":[ "SETIMAGE", "0", "still_00010010_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「幾重にも……きゅっと締め付けるっ……んっ！　んふっ、今の……感じてく\nれたか……？　ふふ、嬉しいぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1004132" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あっ、あぉっ……すぐ……反撃が来たな……んっ、んくっ、心配しなくても\n、主導権は……隊長どのにあるからな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1004133" ]},
		{"command":[ "SETIMAGE", "0", "still_00010010_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「私は……どのような責めでも、されるままに受け止めるのみ……だが、私を\nこのようにした責任は果たしてもらわないとな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1004134" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んふっ、そうだ……このまま中に出して……孕ませてもらうしかないぞ？　\nそうだっ、あぁっ……もっと激しくぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1004135" ]},
		{"command":[ "SETIMAGE", "0", "still_00010010_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「私も……イクからっ、はぁっ、んんっ……中にっ……あるだけ……全部っ、\n出してっ……くれぇぇっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1004136" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んはぁぁぁぁぁぁっ……は、ふっ……！　あぁ……出てる……あぁ……中に\n……隊長どのの精液が出されてる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1004137" ]},
		{"command":[ "SETIMAGE", "0", "still_00010010_02_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あふぅ……んんっ、ずっと待ち焦がれていたモノだ……んんっ、最高の快感\nと共に……また、身体が隊長どののモノにされていくぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1004138" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「はぁ、はふ……残さず出し切ってくれ……余らせるなんてもってのほかだか\nらな……しっかり腰を振って……そうだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1004139" ]},
		{"command":[ "SETIMAGE", "0", "still_00010010_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んんっ、はぁ……あぁ……種付けされた……一足先に、アソコがホワイトに\n満たされてしまったな……はふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1004140" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んっく……精液がしっかりと中に入ったが……まだ、ペニスはこれでは足り\nないと自己主張をしているな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1004201" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「私も、まだこれで終わるつもりはない。お返しは、心行くまでありったけし\nてもらわなければ……あっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1004202" ]},
		{"command":[ "SETIMAGE", "0", "still_00010010_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んふっ、早速……続きのピストンが始まったな……あふっ、あぉっ、んっ、\nくぅっ……今度はもっと勢いを強めに……はぁぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1004203" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「そ、そこぉ……あぁっ、ジーンと痺れるぅ……まだ絶頂の余韻が引いてない\n場所だ……く、はっ……あっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1004204" ]},
		{"command":[ "SETIMAGE", "0", "still_00010010_02_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「中で……精液がかき回されている……あぁ……こんなにもぐちゅぐちゅと、\n下品な音がするんだな……んふぅっ、はぉっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1004205" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あぁ……ゾクゾクする……んっふ、種付けされた上に……それをしっかりと\n刷り込まれる悦びに、身体が震えてしまうのだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1004206" ]},
		{"command":[ "SETIMAGE", "0", "still_00010010_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「はひっ！　そ、そうだ……乳首も、しこり切って……摘まれる度に、声が出\nてしまう……ぎゅっとおっぱいを握り締められて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1004207" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ひぁぅっ……あぁっ、う、うなじまで舐められてる……はぁぁ、全身どこま\nでも……隊長どのに侵食されてしまう……気持ちよすぎるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1004208" ]},
		{"command":[ "SETIMAGE", "0", "still_00010010_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あっ、んふっ、あぁっ……恥ずかしい……大股開きで……何度もペニスが出\n入りしているところを……見せつけているかと思うと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1004209" ]},
		{"command":[ "SETIMAGE", "0", "still_00010010_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「自然にいやらしく、ヒクヒク蠢いてしまうのが止められない……浅ましいメ\nスの本性がどんどん暴かれていく……はぁぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1004210" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んんっ……わ、分かっている……私は隊長どののメスなのだからな……こう\nある姿が正しいのだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1004211" ]},
		{"command":[ "SETIMAGE", "0", "still_00010010_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「恥ずかしいが……この姿を見せることも……私の役目……そして、もっと興\n奮してもらえるように……全身で応えるのみ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1004212" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あっ、あひっ、はひぁっ！　あぁっ……気持ちいい……んっ、ちゅぷっ、あ\nふぅ……キスまで不意打ちにぃ……れろ、んちゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_1004213" ]},
		{"command":[ "SETIMAGE", "0", "still_00010010_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		
