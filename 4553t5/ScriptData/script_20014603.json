{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0144" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「さあ、ご主人……カツマ殿も、どうにか息を吹き返したところで、次の競技\nですぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023110001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「次のテーマは一体なんでしょうね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110023110001" ]},
		{"command":[ "SETCHARA", "0", "char_00000514_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「はい、只今発表致しますぞ。題して、誰が頭脳派？　インテリ花嫁対決！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023110002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「さっきクイズをしたのに、また頭脳勝負ですか……つくづくバランスが悪い\nですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110023110002" ]},
		{"command":[ "SETCHARA", "0", "char_00000514_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「まぁまぁ、とにかくメンバーはこちらの皆様です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023110003" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「知性を要求する勝負ならば、私にも十分勝機があるということだからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010023110001" ]},
		{"command":[ "SETCHARA", "0", "char_00004908_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ふ……他の誰にも任せることはありません。ウチが勝利するに決まっていま\nすから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010023110001" ]},
		{"command":[ "SETCHARA", "0", "char_00000518_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「そうやすやすと勝ちを譲るつもりはない。無論、油断することもな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090023110001" ]},
		{"command":[ "SETCHARA", "0", "char_00000122_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おお……何だか、結構まともな勝負になりそうだ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「それでは皆様には場所を移動して頂きます！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023110004" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「場所を……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090023110002" ]},
		{"command":[ "SETCHARA", "0", "char_00000122_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「何でしょう、今……そこはかとなく嫌な予感がしたのですが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010023110002" ]},
		{"command":[ "SETCHARA", "0", "char_00000518_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「ああ……私も近いことを感じた……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010023110002" ]},
		{"command":[ "SETCHARA", "0", "char_00004908_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0119" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「という訳で、皆様にはこちらのコースで１５００ｍ走をしていただき、最初\nにゴールした花嫁が勝者となります！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010023110003" ]},
		{"command":[ "SETCHARA", "0", "char_00000514_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「ちょっと待て！　頭脳勝負はどこへ行ったんだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010023110003" ]},
		{"command":[ "SETCHARA", "0", "char_00004908_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「提示したテーマと、やらせることが全く合ってないです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010023110004" ]},
		{"command":[ "SETCHARA", "0", "char_00000518_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「いや、そこはそれ。インテリと目される皆様が汗を流して競うところを見た\nいという視聴者の方々のために……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023110005" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「前回のクイズの時点からしておかしかったですからね。まともなコトになる\nと思う方が馬鹿ですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110023110003" ]},
		{"command":[ "SETCHARA", "0", "char_00000514_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「何をごちゃごちゃ言っている。とにかく速く走った者が勝つんだろう？　シ\nンプルで分かりやすいルールだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090023110003" ]},
		{"command":[ "SETCHARA", "0", "char_00000122_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「チッ……自分は体力に覚えがあるからと……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010023110005" ]},
		{"command":[ "SETCHARA", "0", "char_00000518_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「……どの道、選択の余地はないということか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010023110004" ]},
		{"command":[ "SETCHARA", "0", "char_00004908_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「いずれにしましても、参加しませんと不戦敗ということになりますが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023110006" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「誰も参加しないとは言ってねーです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010023110006" ]},
		{"command":[ "SETCHARA", "0", "char_00000518_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「いいだろう、私の底力を見せてやる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010023110005" ]},
		{"command":[ "SETCHARA", "0", "char_00004908_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「それでは、皆様改めてスタートラインにお並び下さい。カウントダウンと共\nに、スタートの合図を掛けさせていただきます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023110007" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ここでいいんだな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090023110004" ]},
		{"command":[ "SETCHARA", "0", "char_00000122_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「すぅぅーっ……はーーっ……よしっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010023110006" ]},
		{"command":[ "SETCHARA", "0", "char_00004908_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010023110007" ]},
		{"command":[ "SETCHARA", "0", "char_00000518_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「では、カウントダウンです。５、４、３、２……１！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023110008" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「式神発動っ！　呪縛の陣っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010023110008" ]},
		{"command":[ "SETCHARA", "0", "char_00000518_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ぐぅっ、貴様！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090023110005" ]},
		{"command":[ "SETCHARA", "0", "char_00000122_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「足にっ……何かがっ……う、動けないっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010023110007" ]},
		{"command":[ "SETCHARA", "0", "char_00004908_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「スタートっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023110009" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「さて、いきなりスタート直後から波乱の展開になりましたね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110023110004" ]},
		{"command":[ "SETCHARA", "0", "char_00000514_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「おいっ、最速のランナーを決める勝負じゃないのかっ！　卑怯だろうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090023110006" ]},
		{"command":[ "SETCHARA", "0", "char_00000122_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「えー、特に相手を妨害してはならない等のルールはございません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023110010" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「この手のレースものでは、ごく定番の展開ですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110023110005" ]},
		{"command":[ "SETCHARA", "0", "char_00000514_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「フン……フィジカルで勝てなくとも、頭を使えばということなのでしょう。\n最終的に、一番にゴールすればよかろうなのですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010023110009" ]},
		{"command":[ "SETCHARA", "0", "char_00000518_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「流石は小賢しい月兎族。例え禁止ルールでも、何かしら企んでいたでしょう\nね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110023110006" ]},
		{"command":[ "SETCHARA", "0", "char_00000514_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ええいっ、外野はゴチャゴチャ言いやがるなですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010023110010" ]},
		{"command":[ "SETCHARA", "0", "char_00000518_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「さあ、とにかくスタートの混乱に乗じて一歩先を行ったのはオボロ選手！　\nこのまま一気にゴールしてしまうのか～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023110011" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「ふん、何でもありでいいのだな……！　それなら、もう私も容赦はせんぞっ\n、ふんぬぅぅぅぅぅぅぅーーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010023110008" ]},
		{"command":[ "SETCHARA", "0", "char_00004908_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「あっと……これは冴島長官の凄まじい気合が膨れ上がって……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023110012" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「こんな枷で私を止められると思うなぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010023110009" ]},
		{"command":[ "SETCHARA", "0", "char_00004908_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「うわーっ！　気合だけでオボロ選手の式神を吹き飛ばしました！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023110013" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「レベルを上げて物理で殴る……クソゲーの攻略法そのままですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110023110007" ]},
		{"command":[ "SETCHARA", "0", "char_00000514_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「バレーで鍛えた走りをなめるなぁぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010023110010" ]},
		{"command":[ "SETCHARA", "0", "char_00004908_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「そして、砂煙を上げながら一気にオボロ選手を猛追しております！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023110014" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「うぅぅぅぅっ！　何なんですかっ！　本当に一体何者なんですかっ、あの人\nはっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010023110011" ]},
		{"command":[ "SETCHARA", "0", "char_00000518_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ＥＤＯの長官です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023110015" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「むっ……少し拘束が緩んだっ……ふんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090023110007" ]},
		{"command":[ "SETCHARA", "0", "char_00000122_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「オボロ選手が動揺した隙にアナザールナテミス選手も、式神を払いましたね\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110023110008" ]},
		{"command":[ "SETCHARA", "0", "char_00000514_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「しかし、ライバル両名は遥か前方！　ちょっと出遅れたかっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023110016" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「なんのっ……短距離走じゃないっ。まだまだこれからだっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090023110008" ]},
		{"command":[ "SETCHARA", "0", "char_00000122_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「おぉっとー！　後ろから素晴らしいスピードで迫ってくるのは、流石のフィ\nジカルモンスター、アナザールナテミス！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023110017" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「素晴らしい追い上げですね。これは、先行の二人もうかうかしていられませ\nんよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110023110009" ]},
		{"command":[ "SETCHARA", "0", "char_00000514_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ええいっ、小癪なっ……それならこれならどうですっ！　式神っ……烈風の\n陣っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010023110012" ]},
		{"command":[ "SETCHARA", "0", "char_00000518_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「ぬぅっ……！　強烈な向かい風がっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010023110011" ]},
		{"command":[ "SETCHARA", "0", "char_00004908_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「くっ……これは……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090023110009" ]},
		{"command":[ "SETCHARA", "0", "char_00000122_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「再びオボロ選手の妨害工作が炸裂っ！　二人の周囲に突風を起こす向かい風\nを発生させているーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023110018" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「つくづく正攻法のできない女ですね。人の足を引っ張ることに必死です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110023110010" ]},
		{"command":[ "SETCHARA", "0", "char_00000514_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「何とでもいいやがれですっ、後は……もう少しっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010023110013" ]},
		{"command":[ "SETCHARA", "0", "char_00000518_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「さあ、風の力を使って、このままオボロ選手が逃げ切るのかー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023110019" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「この風圧……もっと空気抵抗が小さくなってくれれば……むっ、そうか……\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090023110010" ]},
		{"command":[ "SETCHARA", "0", "char_00000122_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「さて、依然としてオボロ選手が先頭、その後を追う冴島長官がやや遅れたか\n？　最後尾のアナザールナテミス選手は……おおっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023110020" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「フォームチェンジっ！　換装っ、水着バージョンっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090023110011" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000111_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「これはっ！　アナザールナテミス選手が水着姿にっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023110021" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁぁぁぁーっ！　エネルギー集中っ！　スーパーダッシュだっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090023110012" ]},
		{"command":[ "SETCHARA", "0", "char_00000111_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「おぉぉっ、物凄く低い姿勢のまま凄まじい勢いでルナテミス選手が追い上げ\nていきます！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023110022" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「水着によって空気抵抗を減らし、軽量化もした上で前傾姿勢でのダッシュ。\n風をものともしない走法ですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110023110011" ]},
		{"command":[ "SETCHARA", "0", "char_00000514_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「みるみる距離が縮まっていきますっ！　あと５０メートル！　４０、３０っ\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023110023" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「くっ……！　何だあれはっ、私の水着ではあの走り方は真似できん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010023110012" ]},
		{"command":[ "SETCHARA", "0", "char_00004908_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「確かに、冴島長官の水着は大胆であるが故に、いろいろはみ出してしまうか\nも知れません！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023110024" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「年甲斐もないものを選んだことが仇になりましたね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110023110012" ]},
		{"command":[ "SETCHARA", "0", "char_00000514_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「歳のことはいいだろうっ！　あぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010023110013" ]},
		{"command":[ "SETCHARA", "0", "char_00004908_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「そう言っている間に、アナザールナテミス選手っ、冴島選手を抜き去ったー\nっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023110025" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「なっ、何ですかっ、あのスピードっ！　くっ……ウチも獣人形態になればっ\nて……も、もう間に合いませんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010023110014" ]},
		{"command":[ "SETCHARA", "0", "char_00000518_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「うぉぉぉぉぉぉぉぉーーーーーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090023110013" ]},
		{"command":[ "SETCHARA", "0", "char_00000111_01", "7", "CENTER", "-1200" ]},
		{"command":[ "MOVECHARA", "0", "4", "1400", "SLOW" ]},
		{"command":[ "WAITTIME", "2" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「これはっ、更にすごい勢いのままっ、オボロ選手もまくったぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023110026" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「そらぁぁぁぁーーーーーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090023110014" ]},
		{"command":[ "SETCHARA", "0", "char_00000111_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「そのまま一気にゴールッ！　勝者はアナザールナテミス選手だぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023110027" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「終わってみれば圧倒的でしたね。と言うか、結局フィジカルお化けが勝つと\nいう、身も蓋もない結果になりました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110023110013" ]},
		{"command":[ "SETCHARA", "0", "char_00000514_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「若干、企画倒れになった感は否めませんが、ともあれ素晴らしいレースをし\nて下さった３選手に盛大な拍手を！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023110028" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……今回、俺……何にもすることなかったな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}