{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000702_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「何、心配することはない。ちゃーんと優しくする……また、お主のママにな\nってみせるからな……ふふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0204102" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「さ、まずは、このビンビンオチンチン……優しく撫でてあげましょうねぇ…\n…んっ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0204103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「ほら……ママのオマンコがどんな風になってるか……入り口を擦るだけで分\nかるでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0204104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「そう……あなたの立派なオチンチンを入れて欲しくて、じゅくじゅくって濡\nれちゃってるの……はんっ……この辺っ……ね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0204105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「どう？　ちゃんとハメられそう？　ママのオマンコにオチンチンずぶって埋\nめるの……ここよ……位置を合わせて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0204106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「はぁい……オチンチン、全部ハマっちゃったぁ……よく出来たわねぇ……い\nい子、いい子……あふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0204108" ]},
		{"command":[ "SETIMAGE", "0", "still_00000702_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「あぁ……一気に根元まで届いちゃったわね……どうかしら、ママのオマンコ\n……ユルユルじゃない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0204109" ]},
		{"command":[ "SETIMAGE", "0", "still_00000702_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「そう、よかった……ふふっ、せっかくハメてくれたのに、お好みじゃないオ\nマンコだったら、申し訳ないもの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0204110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「それじゃ、あなたのオチンチンがいっぱいミルクを出せるように……ママ、\n一生懸命頑張るわね……ほら、手をぎゅっとして……行くわよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0204111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「うんっ、ふっ、はっ、あっ……あぁ……硬ぁい……オマンコのヒダを……オ\nチンチンがゴリゴリして来るわ……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0204112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「まだゆっくりだけど……んっ、擦れる時の感じ……すごくイイっ……はんっ\n、あっ、んふんっ……あっと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0204113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「ふふっ、ごめんなさい。ママばっかり楽しんで、肝心のあなたがどうなのか\n分からなかったわね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0204114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「うんっ、んくっ……それで、どう？　まだ、これ位の動きじゃ物足りなかっ\nたりするかしら……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0204115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「すぐに射精しちゃったら勿体ないから……まずはじっくりとオマンコ肉の感\nじを味わって欲しいの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0204116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「んっ、ほら……特に奥の方……くぅぅ……んっ、オチンチンの先がキュンっ\nてなるでしょう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0204117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「んくぅっ……オマンコを締め付けると、ちょうどいい所で……カリが当たる\nの……だから、ママもすごく感じるのよ……あんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0204118" ]},
		{"command":[ "SETIMAGE", "0", "still_00000702_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「あぁ、ここに当たったまま……グリグリ、回すとぉっ……はんっ、あっ、あ\nひぁっ、あぅっ、はぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0204119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、ダメね……普通に私が楽しんじゃってる。もっと、あなたを\n感じさせてあげないとね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0204120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「なら、今度は……前後に身体を揺らしてっ……ほらっ、いっち、にっ、いっ\nち、にっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0204121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「はんっ、大きく動かすとっ……オッパイがぷるぷるしちゃうっ、はんっ、あ\nんっ、あっ、はぁっ、あぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0204122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「んふふっ……やっぱりじっと見ちゃってる。オッパイが気になるんでしょう\n？　いいのよ、後でたっぷり吸わせてあげるから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0204123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「でも、今はもうちょっとだけ、オマンコの方に集中してね……もっともっと\n蕩けさせてあげるから……はぁんっ、あっ、うんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0204124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「ほら……気持ちいいでしょう？　一生懸命、唇を引き締めちゃって……我慢\nしてる顔……可愛いわ……あんっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0204125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「あっ、どうしたの……んっ、急にっ……あっ、オチンチン……激しくしてっ\n、あひっ、あっ、あぁっ、これっ、あぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0204126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「んっ、されてるばっかりじゃ……待てなくなっちゃったのね。いいのよ、元\n気があって何よりだわ、頑張ってオチンチン突き上げて？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0204127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「はんっ、あぁっ、そこぉっ、いいわっ、硬いオチンチンっ……めり込んで来\nるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0204128" ]},
		{"command":[ "SETIMAGE", "0", "still_00000702_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「今の場所っ……あっ、オマンコ感じるとこよっ、ほらっ、もっと……うんっ\n、頑張ってっ、オチンチン……ガンバよっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0204129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「はぁんっ！　あっ、んふっ……張り切っちゃってる……！　そうよっ、リズ\nミカルにっ……ぐぐってっ、いいわっ、とっても素敵……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0204130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「んふっ、私もっ……負けてられないわねっ……うんっ、はふっ、あんっ、ち\nょっとだけ……本気出しちゃうんだから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0204131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「んくっ、んふぅっ……どう？　さっきより、キュンってオマンコが締まるの\n……分かるでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0204132" ]},
		{"command":[ "SETIMAGE", "0", "still_00000702_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「あっ……ふっ、先走りが……びゅるって出てるわね……もう、そろそろオチ\nンチンミルク、我慢出来ないんじゃない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0204133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「ふふ、いいのよ……このままピュッピュして。ママのオマンコ……中出しし\nて欲しいって待ってるんだから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0204134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「このまま、もっと激しく動いてっ、そうよっ、下からオマンコズンズン突く\nのっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0204135" ]},
		{"command":[ "SETIMAGE", "0", "still_00000702_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「あんっ！　あぁっ、いいわっ……膨らんで来てるっ……このままっ、出して\nっ……ドピュってっ……してぇぇぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0204136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「んぁぁぁぁぁぁぁぁぁんっ！　出てるっ……熱いのとぷんって……中出しさ\nれてるぅぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0204137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000702_02_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「あぁ……息子のオチンチンミルクでイクのっ……お腹、熱い……はぁぁ……\nオマンコッ……あっ、イクぅぅぅぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0204138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「はふ……んふふ……いっぱい出したわね。自分ばっかりじゃなく、ママもち\nゃんとイカせるなんて……本当にいい子……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0204139" ]},
		{"command":[ "SETIMAGE", "0", "still_00000702_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「んっ、あぁ……ドロっとしたのが溢れて来ちゃいそう……いっぱい出したん\nだから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0204140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「さ……ちょっとだけ一息ついて……ふふ、このまま続きしちゃいましょっか\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0204201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「だって、オマンコの中でオチンチン……全然小さくなってないじゃない？　\nむしろ……もっと中でおっきくなって来てる感じ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0204202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「これって、要するに……まだキンタマの中にたぁーっぷり精液が残ってるっ\nてことでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0204203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「ダメよ、こんな状態のオチンチン……放っておける筈ないもの。ちゃーんと\n最後まで、面倒見てあげなくちゃ……ね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0204204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「んっ、はぁんっ、さっきよりぐちゅぐちゅって、いやらしい音……派手にな\nって来てる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0204205" ]},
		{"command":[ "SETIMAGE", "0", "still_00000702_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「そうよね、オマンコの中……オチンチンミルク、いっぱい出してくれたんだ\nもの……いい音しちゃうのも当然よね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0204206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「ふふっ、んっ、もっと……腰を回していくわね。はんっ……あっ、あぁ……\n割れ目のとこぉ……広がっちゃいそう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0204207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「ほら……よく見えるでしょう？　あなたのオチンチン……ママのオマンコが\n、パクってしちゃってるとこぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0204208" ]},
		{"command":[ "SETIMAGE", "0", "still_00000702_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「ママのオマンコ……あなたのオチンチンと、オチンチンミルクが大好物で、\nどうしてもお行儀悪くなっちゃうの……んふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0204209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「さ……手をぎゅっとして……こうしてると、繋がってるって感じ……よく\n分かるわよね。さあ……あなたは、これからどうしたい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0204210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「んぁっ！？　うんっ、はっ、うんっ、あぉっ……おんっ、はぉっ、おっ、お\nぉぉぉぉぉんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0204211" ]},
		{"command":[ "SETIMAGE", "0", "still_00000702_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「はぁんっ、そうなのねっ、ママのオマンコっ……いっぱい味わいたいのねっ\n？　嬉しいわっ……もっと、あっ、かき回してぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0204212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「あぁっ、その調子よっ、オチンチン頑張ってっ、ガンバっ、オチンチンガン\nバよっ！　あぁっ、オマンコッ……燃えちゃう、あっ、んぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0204213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「ダメっ……イッちゃうわっ、我慢できなくなってっ……あひんっ、オマンコ\nっ……はぁぁぁぁんっ、イクぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0204214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「はぁぁ……んふぁ……子宮までオチンチン届いてイカされちゃったわ……ん\nっ、待っててね……今度はあなたのオチンチンをイカせてあげるから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0204215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「いっぱい頑張ってくれたから、もうすぐでしょう？　奥に溜まってる残り…\n…全部出しちゃいましょうね……んふっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0204216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「はんっ、あっ、んはっ……あぁっ、いいわっ！　んんっ……グチョグチョの\nオマンコっ……いっぱいかき混ぜてっ、奥っ……突いて！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0204217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「あんっ、はぁんっ、中で……震えてるわ……また出るのねっ……どうしたい\nのっ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0204218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「ママはどこでも大丈夫よ……また中に出してもっ……ママのオッパイに掛け\nてもっ、全部受け止めるからっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0204219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「オチンチン頑張って出してっ！　ドピュドピュって……たっぷりのオチンチ\nンミルクっ……いっぱい出してぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0204220" ]},
		{"command":[ "SETIMAGE", "0", "still_00000702_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「んはぁぁぁぁぁぁぁんっ！　あっ……また中にっ、熱いのビュクビュク出さ\nれてるぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0204301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000702_02_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「はぁぁぁん……あぁ、ドロドロでオマンコいっぱいにされてぇ……ママもっ\n、あひんっ、また……イ、イクぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0204302" ]},
		{"command":[ "SETIMAGE", "0", "still_00000702_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「んふっ、はぁ……はぁ……はぁ……あぁ……ちゃんと全部出すのよ。残した\nら勿体ないでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0204303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「あふっ！　そう……最後までオチンチン頑張って……んっ、今ので……全部\nかしら？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0204304" ]},
		{"command":[ "SETIMAGE", "0", "still_00000702_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「はい、よく出来ました。いい子いい子……ふふっ、はい……これでおしまい\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0204305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「んふふふっ、どうだ……堪能できたか？　いやー、少し気恥ずかしい所もあ\nったが、やはりママプレイは色々と燃えるものがあるな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0204306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「おっと……まだチンポがハマったままなのに、素に戻るのは興醒めか？　ス\nマンな、スイッチのオンオフが極端でな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0204307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「何なら普段の時ももう少し甘やかしてやってもいいのだが……そこはほれ、\n厳しくしないと強くなれないからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0204308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「まあ、もしお望みならば、また次にする時も存分に甘やかしてやるが……ど\nうする？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0204309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「ふふっ、そうかそうか。では、またその時は……いっぱい楽しんでね、ボク\nちゃん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0204310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「んあぁぁぁぁぁんっ！　掛かってるっ……オッパイにっ……熱いのビュクビ\nュク飛んできてるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0204401" ]},
