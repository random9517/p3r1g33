		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「あふっ！　んんっ……偉いわ……ピュッピュしちゃいましょう……ふふ、オ\nッパイどころか……顔にまで届いて……本当に元気……」", "NORMAL" ]},
