		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「はぁぁんっ、濃いのが……ねっとり絡みついて……はふぅ……ゾクゾクする\nぅ……逞しいわ……素敵よ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0204402" ]},
		{"command":[ "SETIMAGE", "0", "still_00000702_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「どう……まだ出せそう？　オチンチンの奥に残ってるの……もうちょっとだ\nけ頑張って……出し切っちゃいましょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0204403" ]},
