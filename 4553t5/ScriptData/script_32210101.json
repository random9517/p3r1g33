{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「えへへ……旦那さま、わたくしを呼んでくださって、ありがとうございます\n……。ずっと、ずっと待っていましたの♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0103101" ]},
		{"command":[ "SETCHARA", "0", "char_00022101_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「なぜ、ですか？　うぅん……それは……。将来結婚するふたりは、床を……\nベッドを１つにするべきだからです。今夜は一緒に寝れますよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0103102" ]},
		{"command":[ "SETCHARA", "0", "char_00022101_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「はい。わたくしは、あなたさまの妻。あなたさまはわたくしの旦那さまです\n。だって、ここに来てからずっと……たくさん触ってくれましたよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0103103" ]},
		{"command":[ "SETCHARA", "0", "char_00022101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「わたくしの星……祖国では、巫女が異性に素顔を見られることも、触れられ\nることも禁止ですの。それなのに……旦那さまは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0103104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「わたくしを捕まえた時に、お、お、お姫様だっこで運んでくれました。あれ\nはきっとプロポーズ……だったのですよね。だから、だから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0103105" ]},
		{"command":[ "SETCHARA", "0", "char_00022101_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「……責任をとってもらおうって思ったんです。そのかわり、最高の妻になろ\nうって……。えっ？　最高の妻にはするべきことがある？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0103106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「っ……こ、これは……？　い、いけません……いけません……！　と、殿方\nの前で脚を広げて……お、おぱんつを見せるなんて……恥ずかしいです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0103107" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00022101_01_04" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「これが旦那さまの星のご夫婦ではふつう？　そ、そうなのですか……？　で\nも……！　ふぅううっ……なんだかとてもいけないことをしている気がして…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0103108" ]},
		{"command":[ "SETIMAGE", "0", "still_00022101_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「も、もちろんわたくしは旦那さまの言うことを聞きますの。いずれは、その\n……赤ちゃんだってほしいです。でも、でもこれは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0103109" ]},
		{"command":[ "SETIMAGE", "0", "still_00022101_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「どういった意味のある行為……なのでしょうか。はい……りっぱな妻は、旦\n那さまを興奮させてこそ……。はぁ、そうなのですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「それで……ええと。ぱんつの上に指をのせて……動かすのですか？　この星\nのご夫婦は、不思議なことをするんですね……。ん、ん、ん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0103111" ]},
		{"command":[ "SETIMAGE", "0", "still_00022101_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「こう……ですか？　はい。割れ目……。ショーツの中心にあるくぼみ……？\n　スリットを指や手のひらで撫でていく……？　スリット……スリット？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「スリットとはここで合っているのでしょうか。はい。縦筋……んっ。ここ、\nかとは思うのですが……。ここを指先で上下にしゅにしゅにと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「……ふ、ぅ……っ。ふぅ、ふぅ……ふう……。もっと？　もっとですか？　\nもう少し力をこめて……？　こんなことろ、触るのははじめてですの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「なんだかおもしろい形をしているんですね。ほんとうに……んっ、筋になっ\nてます。確かに割れていて……。んっ、なんだかくすぐったい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0103115" ]},
		{"command":[ "SETIMAGE", "0", "still_00022101_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「はい。この筋を、ゆっくりスルスルなぞりながら……。指を動かすと、旦那\nさまが喜ぶのですね？　原理はまったくわかりませんが……頑張ります」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0103116" ]},
		{"command":[ "SETIMAGE", "0", "still_00022101_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「わたくしは、隊長さまに……旦那さまに喜んでほしいです。もっとわたくし\nで興奮してもらいたいし、好きになってほしいんですの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「っふぅっ……、ん、ふ……ぅ、ふぅっ……ふ、ぅ……。もっと脚を開くので\nすか？　そして……指を止めずに、往復させて……んっ。ん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0103118" ]},
		{"command":[ "SETIMAGE", "0", "still_00022101_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あ……はい。今、旦那さまがおっしゃったように……縦筋の上の方、に何か\nあります……？　小さな突起……豆のようなものが……んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「旦那さまにも見えますよね。これ、は……なんでしょう。んッ！？　つんつ\nんすると、両脚がビクビクするような……。くりとりす？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「くりとりすというのですね、この子のおなまえは……。ぅ……は、い……。\nんん……！　こ、この子、この子は刺激がすき、みたいで……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「優しくさわさわこするだけで……んぁっ！　あふっ……！　へんなこえがで\nちゃいます……。とびきり敏感というか……とても弱くてっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「な、なのに、コシコシすると……。いっ……イイっ、で、す……！　あぁ…\n…！　あぁっ、あっ、あっ、……んんんっ？　んん～……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0103123" ]},
		{"command":[ "SETIMAGE", "0", "still_00022101_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「いじりつづけると……。なんだかおっきくなってきました。ピンって立って\nきて……。……あ！？　さ、さっきより気持ちいい、もっといいですっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「このお豆さんは剥けるのですか？　……ん……。んん？　ご、ごめんなさい\n……。なんだかうまくできません。まだ未熟だから？　んぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「そ、そうかもしれません。くりとりすさんのことはさっき初めて知りました\nし……。まだ、わたくしと同じで幼いのかも……。んぁっ、あぁ、あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「つ、次は穴？　穴……ですか？　あな……？　んう……？　あ、あの……わ\nたくしのおまたに穴なんて開いていませんよね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0103127" ]},
		{"command":[ "SETIMAGE", "0", "still_00022101_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「何の穴に指を入れるのですか……？　……あっ！　だ、旦那さまが手でみち\nびいてくれるのですか？　こっち？　もっと下……？　……っわぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あ、穴……！　本当に穴があいています！　ちっちゃいですけど、……ぁ…\n…。人差し指の先がくぷって入る穴……。す、すごい……すごい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ここはおまんこ、というんですか？　……あっ♪　この穴っ……穴、なんか\n、なんかおかしいです……。腰がもじもじしてしまいますの……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0103130" ]},
		{"command":[ "SETIMAGE", "0", "still_00022101_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「身体がおちつかないですの……！　ふぁっ、ぁっ……あっ♪　何か、ヌルヌ\nルしたものがにじみだしてきて……！　それを塗るとますます……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あ、愛液……ですか。愛液さんをおまんこさんにくっつけて、ぬりぬりする\nと……全身が火照ります、ンぁっ……！？　あっあっあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「えっ、ええっ！？　おまんこさんとお豆さん……。く、くりとりすさんを同\n時に？　そんな……！　そ、そんなえっちなことしたら……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ふぁあああっ！？　ああああっ！？　ああっ、ああああっ……！　すっごく\nっ……すっごくいやらしい気持ちになってきちゃいました、あっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「だ、旦那さま……♪　旦那ひゃま、旦那しゃまぁああ♪　なぜだか旦那さま\nから目が離せなくて……あっ、あっ、もじもじして……んん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0103135" ]},
		{"command":[ "SETIMAGE", "0", "still_00022101_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「愛液さんが溢れてきます……！　あぁ……！　わたくし……わたくし、はし\nたない格好をしているんじゃないですか？　これ、いやらしいです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0103136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あぁ……！　旦那さまがほしくなっちゃいます！　んっ、んんっ、旦那さま\nのなにがほしいかはわかりません、けど、欲しい……欲しいですのっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0103137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あふ……っ、あああああっ♪　んああああ♪　旦那さまのすべてがほしいで\nすっ、ほしい……旦那さまがここにほしい、ほしい……！　あ～っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0103138" ]},
		{"command":[ "SETIMAGE", "0", "still_00022101_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あっ……！？　あっ、これ……これっ！　これ、なんですか……！？　あっ\n……！？　あっぁっあっあっあっ、ゆび、指止まりません！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「お豆さん……ンンっ、それに縦筋が気持ち良く、なって……ああっ！　やめ\nられませんっ、これ、おまたいじるのやめられないですぅうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「んっ！！　ふぁああああっ……！　ふぁっ、ふぁあああっ、ふぁああんっ！\n　ああんっ、あああああん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0103201" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022101_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「やっ……、お汁、お汁がおまたからピュッピュッて出ちゃいました！　あっ\n、ぁっ、や、やぁ……なんで……いっぱい出ちゃって……ああ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「わたくし……っ、お漏らしをしてしまったのですか！？　おっ、お嫁さん、\n立派な妻にならなくちゃいけない、のに、漏らしちゃって……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0103203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ごめん、なさい……ごめんなさい！　お豆さんクリクリするのに夢中になっ\nて、おしっこぴゅーって漏らしました……。き、きらいにならないで！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0103204" ]},
		{"command":[ "SETIMAGE", "0", "still_00022101_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ほんの少し気持ち良くなってしまっただけなんです！　わたくしっ、もうと\nっくにお漏らしする年じゃ……！　……え？　そうじゃありませんの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「これは……おしっこじゃなくて、お潮という名前？　尿ではなく愛液……。\nあの、先程は聞きそびれていて……あ、あいえきってなんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0103206" ]},
		{"command":[ "SETIMAGE", "0", "still_00022101_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「お漏らしじゃなかったなら嬉しいです……。はい。お嫁さんがえっちな気持\nちになった時に出るあいえきは悪いものじゃなくて、良いもの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0103207" ]},
		{"command":[ "SETIMAGE", "0", "still_00022101_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「自分のお潮でぱんつを……ショーツをヌルヌルねとねとにしちゃうのが、え\nっちで素晴らしい妻なのですね。さ、最高のおよめさん……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「だったら嬉しいです……。んっ……。旦那さま……よく見えますか？　わた\nくし、たくさんお潮をふきました。ショーツはべとべとです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「いっぱい上手に気持ち良くなれました……。次は……、ちゅぎはどうしたら\nいいですか？　パンツを脱いで……旦那さまにお渡しして……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0103210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「濡れたおまたを直接指でいじるんですね。わかりました。んっ……パンツを\n脱いで……おまたをいじくる……。……ぱんつ、脱ぎました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0103211" ]},
		{"command":[ "SETIMAGE", "0", "still_00022101_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、はぁ……。そうしたら……パンツを脱いで、今度は直接……っ\n。んぅううううう！？　んん～～～～！　んんん……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あっ！？　ぜんぜん……全然ちがいます、おぱんつの上からこするのと……\n！　ふぁっ……♪　あぁ、何倍も、何倍も気持ちいい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0103213" ]},
		{"command":[ "SETIMAGE", "0", "still_00022101_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ん～……っ！　んんん……！　やぁ……♪　指が、指がにゅるにゅるします\n……お潮ですべって……。ビリビリします……。あっ、ぁっ、あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0103214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ん、はぁっ……はぁっ、はぁ……あぁ……。ぷちゅぷちゅ愛液の感覚が手に\n伝わって……っ、ん……！　ん、ん……んんっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0103215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あっ♪　あんまり見ちゃだめです……ぅ♪　あう……、うぅ……♪　んんっ\n……んーっ、んー……♪　あぁ♪　旦那さま……旦那さまぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0103216" ]},
		{"command":[ "SETIMAGE", "0", "still_00022101_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「すればするほど、……ひんっ♪　おまた、おまたがウズウズして……熱くな\nって……！　あっ♪　あっ♪　もっと、もっと深くしたいです♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「りゃめ、りゃめ、らめ、だめれす……っ！　おまた！　おまたいじりがやめ\nられないですの……！　これすき、好き、気持ちいい、気持ちいい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0103218" ]},
		{"command":[ "SETIMAGE", "0", "still_00022101_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「くちゅ、くちゅって音……聞こえますか？　これ……これ、わたくしが、わ\nたくひがおまたをいじって出している音です……お水の音」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「わたくしはっ……わたくしはおまたを自分でクニクニしながら、ひとりで気\n持ち良くなっちゃう悪い妻です……！　んぁっ、んぁ、見てください！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「んあああああっ……！　またですぅうっ！　またお潮ぴゅーって……！　あ\nーーーっ！　すっごくおっきい『気持ちいい』が襲ってきて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0103301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022101_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「もうクチュクチュがやめられないんですの……あっ！　あっ！　あっ！　旦\n那ひゃま……旦那ひゃまが見てる、見てりゅのにぃい……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0103302" ]},
		{"command":[ "SETIMAGE", "0", "still_00022101_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「この感覚をイく、というんですか……？　いく……。ぁっ……あっ！　確か\nに、わたくし……さっきから何度も何度もイきました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0103303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「イってもイってもくちゅくちゅ終わらせたくなくて……！　だ、旦那さまが\n見てくれているって思うといっぱいイキたくなって……んんん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0103304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ごめんなひゃい……！　えっちなおよめさんでごめんなひゃい……！　すぐ\nにおまたでぴゅっぴゅしちゃうなんて、しんじられないです……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0103305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「わたくし……っ。旦那さまに見られるだけでしゅぐイッてしまいましゅ……\n！　……あぁ……まだ、まだずっと……ずっとイッていて……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0103306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「はぁ……っ、はぁっ、はぁ、はぁああ……！　や、やっと……やっとおさま\nり、ました……でも。ベッドを汚しちゃって……。うう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0103307" ]},
		{"command":[ "SETIMAGE", "0", "still_00022101_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「は、はい？　アンが可愛かったから許す？　……ほ、ほんとうですか？　わ\nたくし、たくさんイッたのに……。なんて優しいお方でしょう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0103308" ]},
		{"command":[ "SETIMAGE", "0", "still_00022101_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「わたくしは……あなたさまを、旦那さまを好きになることができてよかった\nです。この、広い宇宙で二度と二人が離れ離れにならないように」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0103309" ]},
		{"command":[ "SETIMAGE", "0", "still_00022101_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「こうして……ずっとそばにいてくださいね。ふつうのときも……。そ、その\n……えっちなことを教えてくれるときも。約束ですよ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ふぁっ！？　あっ……あっ、旦那さま、旦那ひゃま……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0103401" ]},
		{"command":[ "SETIMAGE", "0", "still_00022101_01_16" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「な、なにをしているんですか！？　クンニ！？　くんにとは……？　あッ！\n？　そんなところ、舐めちゃ……舐めちゃだめれふっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あっ♪　あっ♪　どうしてぇ……？　旦那ひゃまがわたくしのおまたをぺろ\nぺろレロレロして……んんんっ！　き、きもちい……きもちいいです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0103403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「んぁああ……！　らめっ、らめれす、お豆を吸っちゃ……！　やぁああっ…\n…ああっ！　こんなのっ、こんなの知りません！　うぁああんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0103404" ]},
		{"command":[ "SETIMAGE", "0", "still_00022101_01_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「えっ……！？　んぁんんっ！　おまたをベロベロするだけじゃなくて……あ\nっ♪　穴の中にもベロが入ってきて……！　あっ、や、やぁああ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0103405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ぐちゅぐちゅっ、音たっちゃってますよぉ……！　あっ！　あっ！　中……\n中、舐め回したら……舐め回したら身体が全部ゾクゾクビクビクしてっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0103406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「頭が真っ白になっひゃいます……！　あーっ！　あーっあーっ！　なんです\nぅっ、なんですのこれぇえっ、気持ち良すぎますぅううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0103407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「う～～～～っ、ううう～っ！　また出ひゃうぅっ、お潮ふいちゃうぅうう～\n～～！　う～！　ううっ、んうううっ、ううう～！」", "NORMAL" ]},
