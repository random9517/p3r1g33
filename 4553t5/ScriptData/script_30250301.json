{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002503_01_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「フフ……♪　恥ずかしい格好だねぇ……？　みっともなくて、情けなくて…\n…いいザマだよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0303101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「せっかくこの私が！　クィン・テイル様がお前にご褒美をあげようっていう\nのに……お前ときたら、こんな変態的な事を望んでいたなんて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0303102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「えぇ？　どんな気持ちなんだい？　女に……こんな風にちんぐり返しにされ\nて、だーいじなところは全部丸見えさ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0303103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「スケベを期待してパンパンに勃起したチンポだけじゃないよ？　汚いケツの\n穴まで晒して、私の責めを待っている……。とんだドM野郎じゃないかい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0303104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「お前は私にこうして辱めて欲しくて、媚びて、従順なふりをして……。裏じ\nゃあ興奮してたってわけだ。望みが叶って幸せだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0303105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「怖い女に見下されて、男根丸出しで息を荒げているなんて……。部下が見た\nらどう思うだろうね？　ビンッビンに亀頭は上を向きっぱなしで」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0303106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「竿には血管が浮くくらい膨張しているね……？　裏筋なんて、ホラ、少しつ\nついたら破裂しそうなくらい張りつめている」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0303107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「ンッ……ふ……♪　睾丸が上がって、精子が今にも飛び出しそうだってアピ\nールしてるよ……。まだ、私は何もしてないのにはしたないヤツだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0303108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「さぁて……どう料理してやろうかね……。フフフ……。こら、見られている\nだけで喜ぶのはやめな。チンポがビクビク痙攣してるじゃないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0303109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「いやだねぇ……若いってのは……♪　私に恐怖を感じるよりも、先にチンポ\nが勃っちまうってんだから……。性欲の権化だよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0303110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「……と、苛めてばかりいても仕方ない。それに……ククククッ……フフフッ\n、チンポがもう我慢できないって泣いているしね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0303111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「あぁあぁ……見てごらん。カウパーだらだら垂れ流しちまって、まるでお漏\nらししたみたいじゃないか。えぇ？　ぼうや。この変態が」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0303112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「んっ……。今日は、特別に、この私が胸でお前に奉仕してあげるよ。最近お\n前が頑張っていたことは、一応わかっているつもりだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0303113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「ほぉら……！　乳房を与えてやるよ。ズッシリ重くて最高だろう？　クク…\n…やわなチンポなら、折れるかもしれないくらいの重量を」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0303114" ]},
		{"command":[ "SETIMAGE", "0", "still_00002503_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「こうしてねぇ……むにゅうううって押し付けて前後に動かす、のさ……。は\nぁ、はぁ……視覚的にもスゴいだろ？　胸の肉が波打って……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0303115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「お前のチンポを丸ごと呑みこんで……。はぁっ、絡みつく……。っはぁっ、\n爆乳でズリュズリュ絞られる感覚は天国だろ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0303116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「……フフ……、昇天しそうな顔して……面白いねぇ。もっとその顔をだらし\nなくしてやろう。……っふ……ふぅっ……ふぅうっ、ふぅ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0303117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「おやおや……ますますチンポが硬くなってきた……。んっ……そんなに喜ん\nで、どうしようもない男だね……って、まだ大きくなるのかい！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0303118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「んっ、あっ、あ……！　お前のチンポが無駄にデカいからっ……、胸を動か\nしづらくてしょうがないよ！　なんなんだい、このサイズ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0303119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「このっ……！　調子に乗った形だよ……！　普段は周りの女達に、好き勝手\nにやりこめられているくせに……こんなところばかり優秀で！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0303120" ]},
		{"command":[ "SETIMAGE", "0", "still_00002503_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「んっ……、拳くらいあるんじゃないか？　この亀頭……、んっ、肉棒だって\n腕、みたいだ……。はぁ、はぁ、何を食べて育ったんだか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0303121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「っはぁっ……は、ぁ……はぁああっ……もう……！　こっちの胸に負けじと\nはねっ返してくる……！　なんて力強いチンポなんだろうね……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0303122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「くっ……！　こっちも負けてなんかいられないよ……！　クィン・テイル様\nの名にかけて……！　っふぅっ……押し潰して……こすりあげる……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0303123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「ンッ……ふぅっ……ふぅうっ……！　あはッ……。ボリュームのある乳房が\n、ダイナミックに上下に揺れる様は美しいだろう……？　んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0303124" ]},
		{"command":[ "SETIMAGE", "0", "still_00002503_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「男は視覚で感じるって言うけどねぇ……。これなら文句なんてあるはずもな\nい、そうだろっ……！　特大バストがチンポに襲い、かかって……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0303125" ]},
		{"command":[ "SETIMAGE", "0", "still_00002503_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「粘膜という粘膜をもみくちゃにしてくれるんだから……眼福ってやつだろう\nさ……！　フフフ、好きなだけ目で犯してみればいいじゃないか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0303126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「私にチンポを苛めてもらえるなんて、そうそうあることじゃあない……。ん\nっ……、股間で弾む、肉の塊……っ。なめらかで重い乳房っ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0303127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「はぁっ……はぁっ！　腰をモゾモゾさせるんじゃないよっ……！　お前に攻\nめるターンなんて与えない……ずーっと私のターンだよ！　んっ、ぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0303128" ]},
		{"command":[ "SETIMAGE", "0", "still_00002503_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「お前は、私に責められてなすがままになっていればいいんだよっ……！　ん\nんっ？　もっとアンアン言ったらどうだい、我慢なんてせず……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0303129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「パイズリしてくださってありがとうございますって言いながら、射精を管理\nされればいいんだ……。ははっ、もどかしいかい？　出したいかい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0303130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「さぁ～てどうしようかねぇ……？　私は全然本気を出しちゃいないってのに\n、お前のチンポはもう限界かい？　非常に感じやすいぼうやだねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0303131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「んっ……？　出したいぃ？　出すってどこにだい……。はぁっ♪　はぁ、は\nぁっ……！　まさかこの胸に射精させてもらえると思ったかい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0303132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「ふむ……。どうっしても胸がいいのかい。……ハハッ！　じゃあ……私に忠\n誠を誓いながら出しな。クィンテイル様が一番ですってさぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0303133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「叫びながら出すんだよ！　いいね！？　……そら……！　出しな！　私を讃\nえながら射精しな！　そら、そら、そらそら……トんじまえっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0303134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「んっ……！？　おっ、ぉっ……おぉっ！？　ちょっと！　どんだけ溜めこん\nでいたんだい！　んっ……んっぷ、精子が溢れ出してるよっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0303135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002503_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「なんて恐れ知らずのチンポだいっ……！　ああっ……！　わ、私の胸が……\n！　乳房がお前の肉汁でビタビタに染め上げられていく……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0303136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「礼儀知らずのチンポから、ドピュドピュ精液発射してくれちゃって……！　\nっうぷ……！　臭いよっ……お前のタマはどうなってるんだい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0303137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「こんな臭い精液作って！　撒き散らして！　……うううっ……！　少しは遠\n慮ってものを覚えるんだね！　私はクィン・テイルだよっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0303138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「クィン・テイルの……っ、うっ♪　尊い乳房に……。あっ♪　全力でマーキ\nングして、細胞まで精子の臭いに浸すだなんて……普通許されない所業だ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0303139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「だ……だけど、んんっ。今日は……！　こ、今回だけは許してあげようじゃ\nないか。ご褒美だからね。つ、次はないよ。今日だけさ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0303140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「ふ、ふはぁあああ……♪　ようやくビュルビュル出すのが終わったかい……\n。お前、射精が長ったらしいんだよ。女を孕ます気しかないだろう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0303201" ]},
		{"command":[ "SETIMAGE", "0", "still_00002503_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「まったく……とんでもないチンポだよ。ただ……この私に怯えずに、射精し\nきったことは褒めてやる。度胸のある男は好きだよ。でもねぇ～……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0303202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「これだけなじられている最中に、まーた勃起するっていうのはどうなのかね\n？　何？　まだして欲しい？　ちょ、調子に乗るんじゃない！　でも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0303203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「そんなに……私のパイズリが良かったのかい。ふぅん……。おかわりを要求\nするくらいに……。へえ……まあ、悪い気は……しないかもね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0303204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「ああ、そうだ♪　どれだけ責めても『もっともっと』とねだる悪い子には…\n…もっとキッツい責めをくれてやろうか。こういうのはどうだい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0303205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「っフフフっ♪　そうだよ……わかるだろう！　私の手でお前のモノをシゴき\nながら、同時にパイズリで鳴かせてやろうって魂胆さ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0303206" ]},
		{"command":[ "SETIMAGE", "0", "still_00002503_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「胸だけで、あんだけヒィヒィよがっていたんだからね。その上指で、敏感な\n部分をまさぐられ、いじられ、搾り取られるなんて耐えられないだろう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0303207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「っハハハ……！　これなら私も楽しめそうだ。さあ、喜びな。お前の望んだ\n二回戦だ……。んん？　どうだい。気持ちいいかい？　フッフフフ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0303208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「……ん？　私の手が冷たい？　ああ、そうかもね……。時々言われるよ。で\nも、それがまたスパイスだろ？　ひんやりした氷の手でさぁ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0303209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「熱いチンポを刺激されると……。ほら♪　ほら♪　脳が蕩けるほどイイだろ\nう……！　他じゃ味わえない快楽さ。たっぷり楽しみな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0303210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「あはっ、ははははっ、あははは……！　お前、こんだけ強くシゴいても逆に\n喜ぶドMなのかい？　結構な力で揉んでいるんだけどねぇ～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0303211" ]},
		{"command":[ "SETIMAGE", "0", "still_00002503_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「下半身をビクビクさせて跳ねてるじゃないか！　あははっ……そうかい。こ\nうやって……手首をひねってシコシコするのがいいのかい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0303212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「ああ、いいよ……好きなだけやってやる。こうだね？　こうやって……。チ\nンポ全体をまんべんなく、シコシコ、シコシコってさぁ……あはははっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0303213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「シゴきまくりながら、胸も同時に合わせると……♪　あはぁ、イイねぇ～…\n…！　泣き出しそうな声を漏らして、女みたいに喘ぐんだよ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0303214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「そしたらクィン・テイル様が……お前を必ずイかせてやるからね……！　っ\nククク……♪　若い男の射精管理が、こ～んなに楽しい事だなんてねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0303215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「これからも、私がしてやってもいいよ？　……っふぅっ……♪　胸と手で、\n射精ギリギリまで追い詰めて……。ははっ、イキかけたら止めるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0303216" ]},
		{"command":[ "SETIMAGE", "0", "still_00002503_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「ん～♪　苦しいかい？　苦しいねぇ？　精子を出す寸前で止めて……また、\nすこ～し落ち着きそうになったらこうして動かすんだ。っはぁ、はぁぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0303217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「イカせる寸前まで高めて昂らせて……止めるっ！　少し焦らして……また再\n開して。落ち着きそうになったら、またギリギリまで責めたてて……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0303218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「ふっふふふ♪　頭がバカになってきただろう？　我慢させて、解放して、我\n慢させて、またいじくりまわして……だんだん、お前は夢中になる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0303219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「私に運命を、チンポを握られていることを意識して……限界を迎えるんだ。\nそれ……今度はどこに出すんだい。せめて場所は選ばせてやろうねぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0303220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「おぁああああっ……♪　そうだ、そうだよ……！　胸に、胸に出しな……！\n　よーく狙って……ありったけの子種を吐き出しな……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0303301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002503_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「ああ……上手だよ。フフッ……最後の一滴まで、私が搾り出してやるからね\n……！　私の手で、胸で、お前はどこまでもよがり狂うんだ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0303302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「っんんんん……！　こんなもんかい？　まだ出せるだろうっ……！　そうだ\n、ビュクビュク精液を垂れ流しな……！　あぁ♪　あぁ、いいよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0303303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「んふぅうう……♪　臭くてネットリした良い精液だ……♪　二度目の発射だ\nっていうのに、この勢い……。お前は射精が得意なんだねぇ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0303304" ]},
		{"command":[ "SETIMAGE", "0", "still_00002503_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「フフフ……。目で見て覚えておくんだね。二度も汚されても、私の胸にはま\nだまだ余裕がある……。三度、四度出されたってそれは変わらないよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0303305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「だから……。たまにはね？　こうして精子を搾ってやってもいい。私の気が\n向いたら、お前が良い子にしていたら……褒美を与える事も考えてやる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0303306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「私が手伝うと、うんと気持ちのいい射精が出来ただろう？　お前は、もう誰\nに従うべきか理解した。そうだね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0303307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「クククク……♪　暴れん坊のオチンポだけじゃなく、心と身体と頭でよ～く\n今のことを刻み込んでおくんだよ。」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0303308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「誰がお前を一番、満足できる幸せに導いてくれるのか……。その立場をわき\nまえていればね、絶対に損はさせない。悪いようにもしない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0303309" ]},
		{"command":[ "SETIMAGE", "0", "still_00002503_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「お前は私に、クィン・テイルにもてあそばれて……ずうっと幸福に暮らすん\nだ。それが、お前にとって最高のメルヘンなんだからねぇ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0303310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「おやおやおやっ……！　顔っ……顔に出すのかい！？　なんて男だ……！　\nあっ……♪　ぁっ、あっ……！　やめないかぁっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0303401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002503_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「んぷぅううっ……♪　ち、ちんぐり返しの体勢で……！　私の顔に精子を浴\nびせようだなんて……とんでもない発想をしてくれるじゃあないか……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0303402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「あっ……♪　こ、こんな量をかけられたら……臭いが移って取れなくなるだ\nろうっ……！　臭い精液が、私の美しい顔にぶちまけ、られて……あぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0303403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「熱い……熱いぃ……っ！　お、愚か者……！　子犬のくせに、私にマーキン\nグするなんて……！　あっ……末恐ろしい男だよ……っ！　あああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0303404" ]},
		{"command":[ "SETIMAGE", "0", "still_00002503_01_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「二度目の射精だと思ってすっかり油断しちまった……！　お前、一度目に出\nした時は本気じゃなかったってのかい！　今回の方が凄いじゃないか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0303405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「あぷ……！　んぷっ、んん……！　んぷぅっ……！　口の中に……、あっ、\nは、鼻の中にまでドロリと粘液が入り込んできた……。ふぁあああ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0303406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「とびっきりの男の臭い……♪　くぅうっ……！　ザーメンシャワーなんて、\nこの年になって食らうと誰が思ってるっていうんだ……！　ぷぁあっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0303407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「……は～っ♪　はぁああ♪　はぁあああ……♪　ま、まあね……元気、なの\nはわかったよ。勢いがあるってことは素晴らしいことさ……でも」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0303408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「私相手にここまでやってのけるのは……大物なのか、何も考えてないだけな\nのか……。それはいずれ、確かめなくちゃいけないねぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0303409" ]},
		{"command":[ "SETIMAGE", "0", "still_00002503_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「はぁっ……。見なよ、髪も肌もベタベタだ。こんなことを許されるのは、お\n前だけなんだからね。しっかり感謝し励むんだよ！　わかったね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0303410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}