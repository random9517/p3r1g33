{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000514_01_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「その……えぇと……そこに横になっていただけますか……？　はい、それで\nいいです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1403101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「……今日は、何と言いますか……ウチも、そのご奉仕というものをしてみよ\nうと思いまして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1403102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「色々と調べてみましたが……その、パ、パイズリというものをしてみようか\nと……あ、あー、何も言わないでいいですっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1403103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「分かっていますっ。ウチの胸が……恐らくは、世の平均……組織の中でも小\nさいであろうことは分かっているのですっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1403104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ですが、それでも出来ないということはないとっ、ちゃんと男の人のオ、オ\nチンポを満足させることが出来るのだと証明したくっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1403105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「す、すみません。ウチらしくもなく、取り乱してしまいました。それで……\nその、いかがでしょうか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1403106" ]},
		{"command":[ "SETIMAGE", "0", "still_00000514_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「は、はい……！　確かに……ちゃんと、勃起されているようですっ。ではっ\n、始めさせていただきます……んっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1403107" ]},
		{"command":[ "SETIMAGE", "0", "still_00000514_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はっ、ふっ……んっ……あっ、と……待って下さい……分かっています。そ\nんなに簡単にオチンポを包み込める訳ではありませんから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1403108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ちゃんと、身を乗り出して……しっかりとくっつけて……こうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1403109" ]},
		{"command":[ "SETIMAGE", "0", "still_00000514_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んっ、大丈夫でしょうか……？　一応……間に挟まったと思います……あっ\n、そうです……えろ……んっ、れろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1403110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「先に、全体を唾液で濡らしておけば……滑りやすくなって気持ちよくなりや\nすいですよね？　はい、それはしっかりと予習済みですから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1403111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「では、今度こそ……しっかりと……んっ、ふっ、うんっ、はっ、んっ、あっ\n……ふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1403112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ど、どうでしょうか……んっ、一応……ちゃんと、オチンポに……お、おっ\nぱいが……擦れているような感じはします……はっ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1403113" ]},
		{"command":[ "SETIMAGE", "0", "still_00000514_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はい、ウチの方も……しっかりと貴方の……熱を、直接……感じています…\n…んっ、ふっ……んくっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1403114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「この、皮が……行き来して、亀頭を……擦るように動くと……気持ちよくな\nるんですよね……？　今の……この、感じ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1403115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はぁっ、んくぅっ……はい……それを、もっと、ですね……承知しました…\n…んんっ、あっ、あふぅっ、あくっ……んっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1403116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「いかが、ですか……んんっ、あぁ……ちょっと先端が……におってきました\n……はぁっ、んふっ、んっ、く……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1403117" ]},
		{"command":[ "SETIMAGE", "0", "still_00000514_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「いえ、その……不快なにおいではありませんです……これは、オスの人の…\n…興奮してきた時に出てくるにおい……んっ、すぅぅぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1403118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んはぁ……これぇ……これ、なのです……ウチは……あっ、んっ、このにお\nいを嗅いでしまうと……はぁ、クラクラして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1403119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んっ、身体全体が……疼きを抱いて……止まらなくなる……んっ、すぅぅぅ\nっ、んっ、もっと……嗅ぎたくなってしまうのです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1403120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「くん……くんっ……んんっ、あふぁ……っと……いけません……夢中になり\nすぎては。ちゃんとウチはご奉仕を致しますから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1403121" ]},
		{"command":[ "SETIMAGE", "0", "still_00000514_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んんっ……！　ここまで寄せれば……ほら、多少なりとも膨らみを感じてく\nれるのではありませんか？　ゴツゴツと骨ばってはいませんよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1403122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ちゃんと柔らかい……はい、ありがとうございます。ウチの柔らかさを、オ\nチンポで感じてくれたら、とても奉仕のやりがいがあります」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1403123" ]},
		{"command":[ "SETIMAGE", "0", "still_00000514_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「こうして……んっ、ぎゅっと押し付けて……身体を大きく……スライドさせ\nるっ……はぁっ、んふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1403124" ]},
		{"command":[ "SETIMAGE", "0", "still_00000514_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「あっ……乳首……当たりますか……んっ、横に揺らすと……どうしても、先\n端が……擦れます……んっ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1403125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「は、はい……硬くなって、ます……しっかり粒を感じるって……そ、それは\n、褒められているんでしょうか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1403126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ま、まぁ、いいです……んっ、ウチも……こうして、オチンポが動く瞬間を\n、感じますから……はっ、ふっ……あっ、んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1403127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「今のは、いい気持ち……でしたか？　はい、貴方の腰にぐっと力が入ったの\nで……恐らく痛みではなかったと思いますし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1403128" ]},
		{"command":[ "SETIMAGE", "0", "still_00000514_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「分かりました。それでは……んっ、この辺りが……より、感じやすいのでは\nないかと……んっ、ふっ、んんっ……はぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1403129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「く……んっ、あぁ……ウチも……今……何だか、乳首から……全身に……心\n地いい感じが……広がっていってます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1403130" ]},
		{"command":[ "SETIMAGE", "0", "still_00000514_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、はい……お互いに気持ちが高まっているんですよね……んふ\nぅ……嬉しいです……あっ、んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1403131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「もっと、頑張って……おっぱい……くっつけますね……んっ、柔らかさは足\nりないかも知れませんが……出来るだけのことはしますから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1403132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「とっても気持ちいい……そ、そうですか……んっ、嬉しい、です……んふっ\n、ウチも……貴方のオチンポを感じて……同じ気持ちです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1403133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はぁっ、んっ、あっ……亀頭から、じわって……滲んで……はい、もう少し\n……ですね？　ではっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1403134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ、はっ、あっ、んぁっ、んくぅっ……はい……どうか、ご遠慮な\nく……おっぱいの中に出して下さいっ……んふぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1403135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「いっぱい……グリグリっ……しますからっ、このままっ……オチンポっ、び\nゅくってぇっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1403136" ]},
		{"command":[ "SETIMAGE", "0", "still_00000514_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んぁふっ……！　はいっ……んっ、出てます……今、正に……びゅくびゅく\nって……おっぱいの中に……沢山……出て……ますっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1403137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000514_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「あぁ……ウチのパイズリで、こんなに射精してくれて……はぁぁ……すごい\n、まだ溢れてくる……こ、こんなにぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1403138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んんっ……ねっとりと……固まってるのが……あぁ、へばりついて……貴方\nの精子……嬉しいです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1403139" ]},
		{"command":[ "SETIMAGE", "0", "still_00000514_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はぁ、んっ……オチンポ、やっと……収まりましたか。こんなに沢山出して\n頂いて……ウチもして、よかったです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1403140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んっ……あぁ……オチンポ、まだ……ビクビクして、勃起も全然……硬いま\nまです……たくましい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1403201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「あの……このまま、パイズリ……続けてもいいですか？　んっ、もっと……\nウチのご奉仕で……気持ちよくなって欲しいです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1403202" ]},
		{"command":[ "SETIMAGE", "0", "still_00000514_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「いえ……させて下さい……んんっ、ウチは……この滲み出るオスのにおいを\n嗅いでるだけで……はぁぁ……んっ、もう、堪らなくて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1403203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んっ、まず……この出してもらった精液で……オチンポをヌルヌルにしてし\nまいます……あ……不快だったりは、しませんか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1403204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「大丈夫ですか……はい、それでは……んっ、は……ふっ……あっ、うんっ…\n…く……んふっ、ぬるぬるしてます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1403205" ]},
		{"command":[ "SETIMAGE", "0", "still_00000514_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「おっぱいにも……こんなに精液が絡んで……すごく、滑りやすくなってます\n……んっ、擦れるだけで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1403206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「貴方のにおいも、どんどん強くなって来て……あぁ……んっ、いけません…\n…けどっ……我慢出来ない……はぁっ、んっ、あっ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1403207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「は、はい……今……ウチは、自分の指で……オ、オマンコを……弄っていま\nす……あっ、んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1403208" ]},
		{"command":[ "SETIMAGE", "0", "still_00000514_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「もちろん……その、パイズリはちゃんと……していますっ……んんっ、全身\nを使って……谷間を滑らせてっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1403209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「な、なだらかでもっ……傾斜はっ……ちょっと、ありますからっ……少しで\nも、柔らかさを……感じて、欲しいですっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1403210" ]},
		{"command":[ "SETIMAGE", "0", "still_00000514_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はぁっ、んっ、あぁ……カウパー、また滲んでます……乳首に……くちゅん\nって……ついて……このまま、あっ、塗り込めて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1403211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「あひぁっ……つるんって滑る感じ……すごく、いいっ……あっ、んんっ……\nはぁっ……ウチのおっぱいも感じてますっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1403212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「顔は……お見せ出来ませんが……んっ、それでも……この呼吸が……んっ、\nふっ……快感を伝えていると思います……あっ、んふぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1403213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「貴方のオチンポもっ、はぁっ、んっ、今……悦んでくれていることっ……分\nかりますからっ……もっとおっぱい重ねてっ……んぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1403214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「あっ、あひぁっ……もっともっと感じて欲しいですっ、んぁっ……オチンポ\nの先と……乳首のキス……ちょんって……何回もしてぇっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1403215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んはぁっ……ビクビクしてますっ、オチンポっ……また、射精したがってる\nのっ……伝わってきますっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1403216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はぁっ、止まらない……ウチの指も……オマンコ、くちゅくちゅして……あ\nぁ、イキそう……んっ、くぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1403217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はふっ、貴方も……出して下さいっ……また射精……したくなってるの、分\nかりますっ……からっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1403218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「貴方の……濃くてっ、熱いのっ……いっぱいっ、出して……下さいっ……ど\nこでも、お好きなところにっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1403219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ウチの身体にっ……ドロドロの、全部……出してぇぇっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1403220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ひぁぁぁんっ……熱いの……びゅるって……おっぱい……来てます……んん\nんっ……はぁぁぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1403301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000514_01_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「すごい量です……んんっ、さっきあれだけ出したのに、全然勢いが収まらな\nいなんて……はぁぁ……んっ、いっぱい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1403302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ちゅぷっ……あぁ、えろ……精液の味……やっぱり濃厚です……ちゅぷっ、\nんふぅっ……男の人のにおい……んはぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1403303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「あ……まだ、もう少し残ってますか……？　はい、待ってて下さい。ちゃん\nと搾り出してしまいますから……んっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1403304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「こういう時は……おっぱいも、大きい方が……出しやすいんでしょうけど、\n一生懸命しますので……待ってて下さい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1403305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「大丈夫ですか……？　それならよかった……んっ、こうして……んぁっ、ぴ\nゅるって……出て来ました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1403306" ]},
		{"command":[ "SETIMAGE", "0", "still_00000514_01_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「落ち着きましたね……では、ちょっと後始末で……オチンポ綺麗にしますね\n……ぴちゃ……んちゅ、ちゅぱ……ぴちゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1403307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んっ、ダメですよ……逃げないで下さい。ほんの少しの我慢ですから……ぴ\nちゃ……んちゅぷ……はい、これでいいです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1403308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「お疲れさまでした。その、どうしても至らないところもあったと思いますが\n……いっぱい射精してくださって嬉しいです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1403309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「えっ、あ……また、次も……？　は、はい……ウチでよければ……また、さ\nせて頂きたいです……んふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1403310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んぁぅぅっ！　あぷっ……顔にっ、あっ……精液いっぱい出てっ……はぁん\nっ、掛かって……来ますっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1403401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000514_01_16" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「あぁっ……んぷっ、ウチも……あっ、イクっ！　あふぁっ……精液……どぷ\nって浴びて……あふぁ……イッてますぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1403402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んりゅぷっ……ちゅぱ……あぁ、精液ぃ……れろ……ちゅぱ……このクセの\nある味……はぁぁ……ハマってしまいます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1403403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んっ、ふぁっ、あっ、まだ溢れてくる……んんっ、全部……搾り出しちゃい\nますから……もう少しおっぱいで扱きますね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1403404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んっしょ……んっ、乳首で……くにくにって……亀頭のところ……気持ちい\nいですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1403405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んふ……また滲んで来ました……はい、くりくりって……触れ合うの……ウ\nチも、すごく気持ちいいです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1403406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、収まりましたね。それじゃあ……後は、オチンポについてる\n精液……綺麗にします……ぴちゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1403407" ]},
		{"command":[ "SETIMAGE", "0", "still_00000514_01_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「あっ、腰を引かないで下さい……上手く出来ませんから……れろ、ぴちゃ…\n…んちゅぷっ、はい、これでいいですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1403408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「いっぱい射精してくれましたね……はい、自分でも少し心配でしたけど、楽\nしんでもらえたなら何よりです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1403409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「また次も……？　んふ……はい、ウチでよければ……また……ご奉仕させて\n下さいです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1403410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
