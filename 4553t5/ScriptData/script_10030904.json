{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0138" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「というわけで、あの塾に通うことに決めたわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070115840001" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「とても素晴らしいところだったわよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020115840001" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "一夜明け、ルルーナとマーガレットは昨日教えてもらった塾の生徒となってい\nた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「大丈夫ですか？　その……塾の教室で暴れたりしませんでしたか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020115840001" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「そんなことしないわよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070115840002" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ええ、大人しく勉強したわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020115840002" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「それができるなら普段からそうして欲しいんだけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020115840001" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「まあどうあれ、まじめに勉強するようになったのはいいことです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020115840001" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「夜日楽さん、ちょっとこの問題集から問題をだしてみて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070115840003" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「昨日の勉強の成果を見せてあげるわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020115840003" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「ここからですか？　……って、この問題集は！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020115840002" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「どうした？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「この問題集……うちの特別進学コースの生徒が使用している超難関校対策の\nものですよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020115840003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「ふたりとも、こんな難しい問題を解けるようになったの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020115840002" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「もちろんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070115840004" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「昨日までのわたしたちと思わないでよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020115840004" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "それから、問題集からいくつか出題してみたが、ふたりは見事に正解した。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "正解するだけではなく、それに関する雑学まで披露する始末。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "いや、明らかにおかしい。塾でなにかあったに違いない。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そもそもこいつらみたいな問題児がなにも起こさず帰ってくるなんてことの方\nがあり得ないだろう。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "……と、以前の俺なら見境なくツッコミをいれていただろう。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "でも余計なことをいうと、また仕事が増えそうだ。なにもないなら、なにもな\nいほうがいいんだ。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「ふたりともすごーい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010115840001" ]},
		{"command":[ "SETCHARA", "0", "char_00001205_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「あんなに勉強ができるようになるなら、つきみも行ってみたらどうかしら？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010115840001" ]},
		{"command":[ "SETCHARA", "0", "char_00001406_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「わたしも！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010115840002" ]},
		{"command":[ "SETCHARA", "0", "char_00001205_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「いいですわね。つきみさんも一緒に」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070115840005" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「一緒に勉強しましょうよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020115840005" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「そうだなぁ……。じゃあ、そうしてみる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010115840003" ]},
		{"command":[ "SETCHARA", "0", "char_00001205_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "俺がツッコミを呑みこんでいる間に、どうやらつきみまであの塾に通うことに\n決めたようだ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「ああ……これで問題児たちの勉強をみなくてすむ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020115840003" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「ゲーム三昧の日常がもどってくるのね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020115840004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「……こんなにすぐ勉強ができるようになることなんて、あるんでしょうか？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020115840004" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}