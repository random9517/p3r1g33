		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「まずは問題の、３つ派閥について説明させてもらいます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010023160001" ]},
		{"command":[ "SETCHARA", "0", "char_00016501_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「つっても、あーしが口でゴチャゴチャ言うのは超わかりにくいと思いますん\nで、実際会いにいきましょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010023160002" ]},
		{"command":[ "SETCHARA", "0", "char_00016501_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まあ、可能ならそれが無難か？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「まったく気負うことないっスから。１つ目の派閥は、センパイもお馴染みの\nあのヒトっス」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010023160003" ]},
		{"command":[ "SETCHARA", "0", "char_00016501_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああ、アヌビスだな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「ピンポーン！　冴えてるっスねぇ、センパーイ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010023160004" ]},
		{"command":[ "SETCHARA", "0", "char_00016501_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「アーマーンといえば……だからなあ。さすがに俺も慣れてきたぞ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「さっそく行くっス、即断即決っス～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010023160005" ]},
		{"command":[ "SETCHARA", "0", "char_00016501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……と、会いにきてみたが……。なんなんだ？　あの格好は……」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0025" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「…………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_010023160001" ]},
		{"command":[ "SETCHARA", "0", "char_00008105_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「う……うう、恥ずかしい……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00008105_01", "5", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_081_010023160002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "アヌビスはまだ、遠目から見ている俺達に気が付いていないらしい。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "それを良いことに、俺達はヒソヒソとアヌビスの犬コスチュームについて語り\n合った。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「どうしてあんな衣装を着せたんだ？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「そりゃ、もちろんあーしのアイデアっスよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010023160006" ]},
		{"command":[ "SETCHARA", "0", "char_00016501_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「自慢げに言うな！　……が、グッジョブだ。最高に似合ってるな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「んふふふ！　センパイならそう言ってくれると信じてたっス！　お褒めにあ\nずかり光栄っス～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010023160007" ]},
		{"command":[ "SETCHARA", "0", "char_00016501_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「……あ！　だ、誰か……そこに、いるの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_010023160003" ]},
		{"command":[ "SETCHARA", "0", "char_00008105_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「お、気づかれてしまったようですな。逃げますか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023160001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「ま、待って。待って……！　二人とも、そこにいて……っ。はぁ、はぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_010023160004" ]},
		{"command":[ "SETCHARA", "0", "char_00008105_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "俺達に気づいたアヌビスが、慌てて駆け寄ってきた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「ね、ねぇ……？　この衣装……恥ずかしいから着替えても、いい……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_010023160005" ]},
		{"command":[ "SETCHARA", "0", "char_00008105_01", "2", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「ダメっス」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010023160008" ]},
		{"command":[ "SETCHARA", "0", "char_00016501_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「そ、そんなぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_010023160006" ]},
		{"command":[ "SETCHARA", "0", "char_00008105_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「アヌビスパイセンは、エジプト女神の中では犬代表っス」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010023160009" ]},
		{"command":[ "SETCHARA", "0", "char_00016501_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「その威厳、威光を示すためにもわんわんコスチュームを着ていた方がいいと\n思うんです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010023160010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「そ……そうなの、かな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_010023160007" ]},
		{"command":[ "SETCHARA", "0", "char_00008105_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「でも……でも……。うう、うう……。恥ずかしい、よぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_010023160008" ]},
		{"command":[ "SETCHARA", "0", "char_00008105_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "（うーん、これはハロウィンの時の仕返しっぽいなぁ）", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「と思いつつも、止めないあたり……ご主人はご主人で、被害を受けた記憶を\n忘れていないようですな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023160002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ジュンジロー、俺の心を勝手に読むな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「読まなくっても顔に全部書いてありますゆえ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023160003" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「アヌビス様の素晴らしさを、この写真におさめるっス！　ハイ、ピース！　\n笑って笑って～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010023160011" ]},
		{"command":[ "SETCHARA", "0", "char_00016501_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「んんぅ……！　だめ、だめ……恥ずかしいよ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_010023160009" ]},
		{"command":[ "SETCHARA", "0", "char_00008105_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "恥じらうアヌビスが自らの姿を隠すより先に、カシャカシャカシャ、とアーマ\nーンがカメラのシャッターを押す。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「あ～♪　いいっスよ～！　めっちゃ盛れてるっス～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010023160012" ]},
		{"command":[ "SETCHARA", "0", "char_00016501_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「しゃ……写真なんて、だめ……。この姿……記録に残すのは、だめ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_010023160010" ]},
		{"command":[ "SETCHARA", "0", "char_00008105_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「これは必要なことなんスよ！　それに、とーってもとーってもカワイイっス\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010023160013" ]},
		{"command":[ "SETCHARA", "0", "char_00016501_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「か、かわっ……！　そ……そんなことない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_010023160011" ]},
		{"command":[ "SETCHARA", "0", "char_00008105_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「元々カワイイアヌビス様の、可愛すぎる犬アピで全世界がもうメロメロっス\n！　ガチ情報っス！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010023160014" ]},
		{"command":[ "SETCHARA", "0", "char_00016501_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「ほ、本当に恥ずかしいからっ……。あぅうううう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_010023160012" ]},
		{"command":[ "SETCHARA", "0", "char_00008105_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "アヌビス様の威厳をこの写真に納めるっす～、と言いながらアヌビスにカメラ\nを向けて、褒め続けるアーマーン。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "アーマーンは何百枚か写真を撮影し終えると、ようやく気が済んだらしく俺の\n方に向き直った。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「……と、いうわけで。センパイ。お察しの通り、１つめの派閥は犬女神、ア\nヌビス様の犬陣営っス」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010023160015" ]},
		{"command":[ "SETCHARA", "0", "char_00016501_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「モフモフで大変良い派閥だと俺は思う」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「もふもふっ、て……！　さ、触ってないのに、わかるの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_010023160013" ]},
		{"command":[ "SETCHARA", "0", "char_00008105_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「見てれば大体……わかる」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「んんっ……。そ、そうなの……？　うん。そうかも……。結構、モフモフ…\n…かも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_010023160014" ]},
		{"command":[ "SETCHARA", "0", "char_00008105_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "自分の身体を触って、えへへへ、とはにかんで笑うアヌビス。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そんな彼女にアーマーンは、ずばりと本題を告げてみせた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「んでもってアヌビス様。カツマパイセンは、この派閥争い……エジプト神大\n戦を止めたいって言ってくれてるんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010023160016" ]},
		{"command":[ "SETCHARA", "0", "char_00016501_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「そうな、の……？　それならすごく嬉しい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_010023160015" ]},
		{"command":[ "SETCHARA", "0", "char_00008105_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「なんで、とりあえず争ってる３つの派閥を巡っているといいますか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010023160017" ]},
		{"command":[ "SETCHARA", "0", "char_00016501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「そうだったんだね。じゃ、じゃあ……隊長さん。１つだけ伝えたいことが、\nある」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_010023160016" ]},
		{"command":[ "SETCHARA", "0", "char_00008105_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "アヌビスに手招きされ、近づくとモフッ、と犬の衣装が俺を包みこんだ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おおぉお……。あったかい……」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "アーマーンに聞かれたくない話なのか、アヌビスは俺に耳打ちしながらぼそぼ\nそと囁いてくる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「あ、あの。……私も……本当は他のみんなと戦いたくないの……。それでね\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_010023160017" ]},
		{"command":[ "SETCHARA", "0", "char_00008105_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「お願いが、あって……それを聞いてほしくてこうしてる……。あ、あのね？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_010023160018" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「他の２つの陣営……バステトさん、とメジェドさん、に私の作ったエジプト\nのお菓子……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_010023160019" ]},
		{"command":[ "SETCHARA", "0", "char_00008105_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「エジプト銘菓、ハッピーコナーファ……を贈って、戦いたくないってこっそ\nり伝えて、ほしい……。いい……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_010023160020" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「昨日、暇だったからたくさん作ったの。それを２人にも食べてほしい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_010023160021" ]},
		{"command":[ "SETCHARA", "0", "char_00008105_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なるほどなぁ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "どうやらこの争いを、アヌビスが望んでいないことは本当らしい。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

