{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
       {"command":[ "SETIMAGE", "0", "bg_0004" ]},
        {"command":[ "DISPIMAGE", "0", "true" ] },
        {"command":[ "FADEOUT", "NORMAL" ]},
        {"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "PLAYVOICE", "059_0103101" ]},
		{"command":[ "SETNAME", "筒井隊員" ]},
		{"command":[ "SETTEXT", "「ひっ！？　い、一体どういうつもりですか、隊長殿！？　そんなものを、い\n、いきなり！？　いきなり、取り出すなんて！？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00005901_01", "9", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "059_0103102" ]},
		{"command":[ "SETNAME", "筒井隊員" ]},
		{"command":[ "SETTEXT", "「は、早くしまってください！　そんな汚らわしいもの、一秒だってみたくあ\nりません！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00005901_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "059_0103103" ]},
		{"command":[ "SETNAME", "筒井隊員" ]},
		{"command":[ "SETTEXT", "「え？　しょ、正気ですか、隊長！？　これを……こんなものを、小官に、舐\nめろと？　そう仰るのですか！？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00005901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "059_0103104" ]},
		{"command":[ "SETNAME", "筒井隊員" ]},
		{"command":[ "SETTEXT", "「この上ない屈辱です。そんなことを命令されるなんて、小官には耐えられま\nせん。セクハラで訴えて、軍法会議に……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00005901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "059_0103105" ]},
		{"command":[ "SETNAME", "筒井隊員" ]},
		{"command":[ "SETTEXT", "「え？　隊長のパワーアップのために、必要なこと……そんな、まさか。その\nようなこと……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00005901_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "059_0103106" ]},
		{"command":[ "SETNAME", "筒井隊員" ]},
		{"command":[ "SETTEXT", "「ほ、本当に、そうなのですか？　上の方も、承知している、と。そんな馬鹿\nなこと、本当にあるなんて……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "059_0103107" ]},
		{"command":[ "SETNAME", "筒井隊員" ]},
		{"command":[ "SETTEXT", "「それで、今回は小官がその任を任せられたというわけですか。は、ははは。\n呆れて、笑いしか出てきません」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "059_0103108" ]},
		{"command":[ "SETNAME", "筒井隊員" ]},
		{"command":[ "SETTEXT", "「い、嫌に決まってます、こんなこと……うぅ。ですが、命令とあらば、死地\nにすら赴くのが軍人の務め」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "059_0103109" ]},
		{"command":[ "SETNAME", "筒井隊員" ]},
		{"command":[ "SETTEXT", "「覚悟を決めて、お相手させていただきます……ん？　すんすん。この匂いは\n……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00005901_01_01" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "059_0103110" ]},
		{"command":[ "SETNAME", "筒井隊員" ]},
		{"command":[ "SETTEXT", "「ふあぁぁ……さ、さっきまで気づきませんでしたが、隊長の、あそこ……い\nえ、身体全体から、良い匂いが……すんすん」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "059_0103111" ]},
		{"command":[ "SETNAME", "筒井隊員" ]},
		{"command":[ "SETTEXT", "「これは……血と、硝煙の匂い。戦場の、匂い、です。あぁ、お腹の奥に響く\n匂い、ですぅ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00005901_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "059_0103112" ]},
		{"command":[ "SETNAME", "筒井隊員" ]},
		{"command":[ "SETTEXT", "「は、恥ずかしながら、小官は、硝煙の匂いを嗅ぐと、興奮してしまうらしく\n……駄目です、我慢、できません。早速ご奉仕させていただきます」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "059_0103113" ]},
		{"command":[ "SETNAME", "筒井隊員" ]},
		{"command":[ "SETTEXT", "「あーむっ。ん、むう、ん、じゅるる、んぶう、ん、むぅ。じゅる、じゅぶ、\nん、じゅるぅぅぅぅ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "059_0103114" ]},
		{"command":[ "SETNAME", "筒井隊員" ]},
		{"command":[ "SETTEXT", "「んぶ、んぶ、んぶ、んぶ、んぶぅぅ……ぷあっ。はぁ、はぁ、はぁ……あぁ\nぁぁ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "059_0103115" ]},
		{"command":[ "SETNAME", "筒井隊員" ]},
		{"command":[ "SETTEXT", "「ふあぁぁぁ。匂いが……硝煙の匂いが、口の中から、頭に伝わってぇ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "059_0103116" ]},
		{"command":[ "SETNAME", "筒井隊員" ]},
		{"command":[ "SETTEXT", "「いえ、それだけではなく、男の……オスの、青臭くて力強い匂いも、一緒に\n、感じられて……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "059_0103117" ]},
		{"command":[ "SETNAME", "筒井隊員" ]},
		{"command":[ "SETTEXT", "「脳が、痺れるような快感が、あります、これぇ……あーむっ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00005901_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "059_0103118" ]},
		{"command":[ "SETNAME", "筒井隊員" ]},
		{"command":[ "SETTEXT", "「んぶぅ、じゅる、じゅるぅ。あむぅ、ん、むぅ、ん、ぶぅぅ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "059_0103119" ]},
		{"command":[ "SETNAME", "筒井隊員" ]},
		{"command":[ "SETTEXT", "「あはっ。たいひょーのペニス、びくびくっれ震え始めまひらよ？　血管も、\nぴくぴくっれ、浮き上がっれきへまふぅ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "059_0103120" ]},
		{"command":[ "SETNAME", "筒井隊員" ]},
		{"command":[ "SETTEXT", "「もっろ、奥まれ、咥えて、あげまふね。んぶぅぅ、ん、んんんっ。ぶぅ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "059_0103121" ]},
		{"command":[ "SETNAME", "筒井隊員" ]},
		{"command":[ "SETTEXT", "「んふぅ、ん。におい、しゅご、い……もっろ、つよい、におい、くらさい。\nんぶぅ、ん、じゅるぅ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "059_0103122" ]},
		{"command":[ "SETNAME", "筒井隊員" ]},
		{"command":[ "SETTEXT", "「んむうう！？　んふっ。ぺにふぅ、びくっれ、跳ねまひらぁ。きもひ、良か\nっら、れふか？　んふふ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "059_0103123" ]},
		{"command":[ "SETNAME", "筒井隊員" ]},
		{"command":[ "SETTEXT", "「ごまかしれも、無駄、れふよ。におい、また、強くなりまひたぁ。おひっこ\nの穴から、エッチなおつゆ、出てきて、まふぅ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "059_0103124" ]},
		{"command":[ "SETNAME", "筒井隊員" ]},
		{"command":[ "SETTEXT", "「んっく、ん、むぅ、じゅるうぅ。んぶぅ、ん、ぐぼっ、ん、ぶぅ、んんぶぅ\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "059_0103125" ]},
		{"command":[ "SETNAME", "筒井隊員" ]},
		{"command":[ "SETTEXT", "「あぁ。くひのなかぁ……匂いれ、いっぱい、れふぅ。硝煙と、エッチな、匂\nいぃ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "059_0103126" ]},
		{"command":[ "SETNAME", "筒井隊員" ]},
		{"command":[ "SETTEXT", "「んんん！？　おえっ、う、えほ！　えほえほえほ！　ペニスが、喉を……ん\nぐ！？　ん、ぶぅ、お！？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00005901_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "059_0103127" ]},
		{"command":[ "SETNAME", "筒井隊員" ]},
		{"command":[ "SETTEXT", "「へ、平気、れす。それよりも、もっと、匂いを……隊長の、硝煙と精液の匂\nい、もっろ、くら、さいっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "059_0103128" ]},
		{"command":[ "SETNAME", "筒井隊員" ]},
		{"command":[ "SETTEXT", "「じゅるるるるぅ。んぐ、おぶぅ、ん、じゅるぅ。あぁ、えっひな、におい、\nしゅご、い、れふぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "059_0103129" ]},
		{"command":[ "SETNAME", "筒井隊員" ]},
		{"command":[ "SETTEXT", "「んご！？　また、ペニス、跳ねたぁ。それに、びく、びくって。隊長、ひょ\nっろして、イキそうなんれす、か？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00005901_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "059_0103130" ]},
		{"command":[ "SETNAME", "筒井隊員" ]},
		{"command":[ "SETTEXT", "「であれば、ど、どうぞ、小官のおくひに。もっろ、濃厚な匂い、くらさい！\n　んぶ！　んじゅる、んぶぅ、ん、ん、んんぶぅうぅ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "059_0103131" ]},
		{"command":[ "SETNAME", "筒井隊員" ]},
		{"command":[ "SETTEXT", "「んぶうううぅ！？　あっ！？　来る！　ペニスぅ、びくびくっれ、震えなが\nら、暴れてぇ……ん！？　んんんんんん！？", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "059_0103132" ]},
		{"command":[ "SETNAME", "筒井隊員" ]},
		{"command":[ "SETTEXT", "「んぶ！？　ん、むぅううぅぅううぅ！？　んぶぅぅぅぅ！」", "NORMAL" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00005901_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "059_0103133" ]},
		{"command":[ "SETNAME", "筒井隊員" ]},
		{"command":[ "SETTEXT", "「んあ、あっ、ぶぁぁ……くひのなかに、どろどろしたの、たくさん……あぶ\nぅ、んん、ぶぅ……ん、ごく、ごくっ。んくっ……んっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "059_0103134" ]},
		{"command":[ "SETNAME", "筒井隊員" ]},
		{"command":[ "SETTEXT", "「んんん、んぶぅ……ごくんっ。はぁ、はぁ、はぁ……の、飲んでしまいまし\nたぁ。隊長の、精液……思わず、飲んで……あふぅ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00005901_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "059_0103135" ]},
		{"command":[ "SETNAME", "筒井隊員" ]},
		{"command":[ "SETTEXT", "「勢いとは言え、こんなことまで、してしまうなんて……匂いにやられて、ど\nうかしていたとしか、思えません」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "059_0103136" ]},
		{"command":[ "SETNAME", "筒井隊員" ]},
		{"command":[ "SETTEXT", "「でなければ、ご奉仕で、こんなに興奮するはずが……そうです。小官は、決\nしてそんな淫らな女ではありません」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00005901_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "059_0103137" ]},
		{"command":[ "SETNAME", "筒井隊員" ]},
		{"command":[ "SETTEXT", "「それにしても、精液を飲んでしまったせいか、喉の奥から、まだ隊長の匂い\nがしています」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "059_0103138" ]},
		{"command":[ "SETNAME", "筒井隊員" ]},
		{"command":[ "SETTEXT", "「おかげで、お腹の疼きがおさまりません。一体どうしてくれるんですか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "059_0103139" ]},
		{"command":[ "SETNAME", "筒井隊員" ]},
		{"command":[ "SETTEXT", "「はあ！？　このまま最後まで！？　ば、馬鹿なことを仰らないでください！\n　今回のは、あくまで作戦の一環で、そこまで命令はされていません！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "059_0103140" ]},
		{"command":[ "SETNAME", "筒井隊員" ]},
		{"command":[ "SETTEXT", "「ですので、自分で慰めて処理します！　隊長の手はお借りしません！　とい\nうわけで、これ以上用がなければ、これで失礼させていただきます！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}