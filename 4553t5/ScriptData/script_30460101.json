{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "PLAYVOICE", "046_0103101" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「むむ……？　なんじゃ、この湿ってジメジメとした部屋は……。せっかくそ\nなたがわらわを呼び出してくれたかと思えば……はぁ……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00004601_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0103102" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「『ろまん』も『むぅど』もない……。こんな場所で『でぇと』とは……。そ\nなた、一度女心というものを学び直し……。んむ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0103103" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「ここでするのはパワーアップのための儀式？　ほぉ……。初耳じゃな。うむ\n……そなたと深く接触することで、秘められし力を解放する……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00004601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0103104" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「……。あやしいことこの上ないが、まあ、よかろ。わらわのそなたの願いと\nあらば。で、何をすればよい？　……『ぱいずり』……ぱいずり？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00004601_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0103105" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「すまぬ。わらわの知らぬ行為じゃ。わらわの胸でそなたのイチモツを……息\n子をしごく？　そして精を絞り出す……。うーむ……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00004601_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0103106" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「思ったより面倒くさいことを要求してくるのぉ。わらわはもっと、チュッチ\nュしたりイチャイチャしたいのじゃが……『パイズリの儀式』とな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0103107" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「……ものは試しか。よし、良い良い。やってみるゆえ、そなたのモノを取り\n出すがよい。……おお……。なかなかの強面（こわもて）じゃな」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00004601_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0103108" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「これを……んっ……。こうか？　乳房で挟み……。おお……。こうして見る\nと、面妖なものじゃな……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004601_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0103109" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「これを、ぐにぐに乳肉で刺激すればよいのじゃな。……うっ、少し臭い……\n。そなた……風呂に入ったのはいつじゃ……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0103110" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「うっすらと尿の臭いがするぞ。それに……うう、この、むわっとくるオスの\n臭い……。それに、なんだかぺとぺとしておる……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0103111" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「ん？　文句を言うな？　な、何を……！　ナマイキな……！　わらわがいく\nらそなたをえこひいきして、特別可愛がっておるからといって……っ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0103112" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「男根までを愛でると約束した覚えはないぞ！？　こんなことを、わらわに要\n求するなぞ……なんという恥辱……！　そなたでなければ殺しておるわ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0103113" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「ううう……。なんというか……柔らかい乳房で揉むには、あまりに硬くての\n……。ザリザリゴリゴリと肌が削られそうで怖いのじゃ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0103114" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「……のう。やめて良いか？　ダメか……。なら……ぱっぱと終わらせてしま\nうとしよう。んっ……んっ、ん……ん……んん……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0103115" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「どう、じゃ……わらわの乳肉はずっしり重かろう……？　んっ……これをた\nぷっ、たぷっと波打たせ……容赦なく肉の棒になすりつけ……んんっ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004601_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0103116" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「っはぁっ……はぁ、はぁ……重労働じゃ……。わ、わかっておるのだろうな\n！？　わらわは……わらわはこんなことしたくないのじゃ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0103117" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「他でもないそなたの願いゆえ……って、うひぃっ！　先っちょが、先っちょ\nがはみだしてきて……おえっ、くっさい臭いが鼻に直接……っ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0103118" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「あう、ううう……！　胸でこすればこするほど……臭いが強くなってきてお\nるぞ……嫌じゃ……嫌じゃぁ……。こびりついてしまう……っ、ぁっ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004601_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0103119" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「そなたのイチモツの臭いを……胸につけて生活などしとうないぃ……。なの\nに……なのに……！　ああっ、もう！　喜ぶでないっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0103120" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「わらわが嫌々、モノを扱くのがそんなに面白いのか……っ！？　見よ！　肉\nの茎がビクビク脈打って、嬉しい嬉しいと言うておる……うううっ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004601_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0103121" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「暴れるなっ……おとなしくしておれ！　それっ！　乳圧で押し潰してやるっ\n……！　静かに！　良い子にしておれっ……あっ、んんんっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0103122" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「おおおっ……！？　モノで乳房を弾き、返すのか……！　あっ！　反り返る\n力だけで……脂肪を持ち上げて……。なんというやんちゃな男根か！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0103123" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「こ、このガルグイユをやすやすと陥落させられると思うな……！　ま、負け\nぬ……負けぬぞ……。っ……ふぅっ……！　ふんっ、ふんっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0103124" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「んっ……！　ンッ、んっんっ……！　それっ……それ、それっ……くくく、\nどうじゃ……そなたの分身は全てわらわの胸の中……ほれっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0103125" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「むにむにとまんべんなく……。はぁっ、男の弱点を一方的に絞り……めちゃ\nくちゃに感じさせてやる……。ほれ、ほれ、良いか？　良いか……っ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0103126" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「存分に、わらわの胸の重み……肌のなめらかさ……。ぬくもりを堪能するが\nよい……。っ……んん……！　んっ、んっ、んっ、ん……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0103127" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「むふふ……。強いのは見た目ばかりか？　されるがままではないか……。そ\nれに……ズられる度に、情けなくヒクつきおって……ふふふ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0103128" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「そう、そうじゃよ……。そなたはそうして、わらわに責められ甘い声を上げ\nておればよいのじゃ……って、お、おおっ！？　なんじゃ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0103129" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「に、肉茎の先端からたらたらと……透明な液が出てきた！？　あっ……これ\nっ、これ、どうするのじゃ……このままでよいのか……！？　あっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004601_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0103130" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「う、うひぃっ……！　胸の谷間に……乳房にネバネバと絡みついて……。え\nっ？　その汁を使ってもっと、激しくズれ……！？　わ、わかった」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0103131" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「このぬめりで……そなたを天上世界へ連れていってやるとしよう。んッ……\n！　あっ！？　こ、このヌルヌルちょっとわらわも気持ちよいのじゃ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004601_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0103132" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「な、なにっ……あっ！　ヌルヌル……ヌルヌルで胸が……胸が疼く……。あ\nっ！　乳肉が揺れ、るたび……男根にぶつかる、たび……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0103133" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「あああぁあ……ビリビリと電流が走るように、き、気持ちよい……！　あぅ\n……！　知らぬ、知らぬ……このような快感……あっ！　あっあっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0103134" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「そなたも、そなたも良いのじゃな！？　このニュルニュルで分身を愛撫され\nると……辛抱たまらぬのじゃな、あっ、ならば良いっ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004601_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0103135" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「二人で共に……共に高まろうではないか……あっ！　んん！？　今度は肉の\n棒が……はぁっ、熱さを増して……ああ、膨れ、あがって……うひぃっ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0103136" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「えっ！？　えっ！？　あっ！？　あっ、やっ、やぁああっ！？　なんか出た\nっ！　なんか、なんかわらわの胸に出たのじゃがぁ！？」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004601_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0103137" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「なんじゃこの白い汁っ……！　さ、さっきのとはまるで違う……！　ネバつ\nきが半端ない……。それに……んおおおおおっ、くさっ、臭いぃ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0103138" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「鼻っ、鼻がもげてしまう！！　なんじゃこの白い臭い汁はぁああっ！　男根\nの臭いを百倍ひどくしたかのような……うぷ、そなたなぁああ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0103139" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「ゆ、許さんぞ……。すこぉし甘やかしておれば、このような仕打ち……。何\n？　これが絞り出すべき汁？　名前は精液？　ほぉ～～～～」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004601_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0103140" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「ならば、もう、このガルグイユ容赦せん。その精液とやら……後悔するまで\n徹底的に！　絞りまくって泣かせてやろうではないか、……ぱくっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0103201" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「れろっ、れろれろれろ……ちゅぱちゅぱちゅぱちゅぱ！　ぷちゅっ、ぷちゅ\n、れろっ、れろれろれろ……れろぉおおお……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004601_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0103202" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「む、ふふふ……♪　どうじゃ……まさか乳だけではなく、口で絞られるとは\n思ってもおらんかったじゃろ。んぶ……か、覚悟せいよ……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004601_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0103203" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「舌で、頬で、口で喉で……。泣きを入れるまでにゅぽにゅぽしてやる……。\nそーれ……ぱくっ！　ん！！　おえっ、苦い……まずい……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004601_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0103204" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「じゃ、じゃが……やられっぱなしというわけにはゆかぬ！　ゆくぞ！　……\nべろべろべろべろっ……ぢゅっぷっぢゅっぷっれろれろれろっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0103205" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「ちゅぷっ、ちゅぷちゅぷっ！　れろぉ……れろっれろっ！　ぶっちゅっぶっ\nちゅっれろれろれろ……うえええ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0103206" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「口のにゃかに……独特のえぐみが広がりゅ……。えふっ……！　んんんっ…\n…ぢゅぷっ、ぢゅるるっ、ぢゅる、ぢゅ、ぢゅ、ぢゅ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0103207" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「あふ、んん……んぅ……。臭い……くひゃい……っ。れろっ、れろ、ぴちゃ\n……ぴちゃっ……ちゅるっ、ちゅるる……んむ、んむ、んぐ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0103208" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「あ、ああ……。汚い、のに……臭いのに……なぜじゃあ……。そなたのモノ\nだと思うと……もっと舐めてやらねばと思うてしまう……ぺろっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0103209" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「ほれ……、ほれぇ……。べろで先端を……れろっ、舐めしゃぶりながらぁ…\n…。乳肉に小さな穴、をちゅくり……。んっ、んんっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0103210" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「胸の穴でズポズポさせてやりゅぞ……。あっ！　口と胸との同時攻撃……。\nあっ、うぅ……しかと楽しめ……。れろ、れろ、れろぉ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0103211" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「ぢゅっ！　ぢゅるっぢゅるぢゅるぢゅるっ……！　ぴちゃっ、ぴちゃ、ぴち\nゃっぴちゃれろっ、れろれろ……ちゅっぷっちゅっぷっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0103212" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「っちゅうううううぅ……♪　むふ……♪　腰が浮いておりゅぞ……。ヘコヘ\nコさせて、そんなに良いか……？　ふふ、ふふ……感じてしまえ♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0103213" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「そなたのイチモツは既にわらわの支配下に入った……。それ、それ……ちゅ\nっ♪　チュッちゅっ♪　ぺろ……れろれろれろれろっ……ぢゅっ♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0103214" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「嵐のごときキスの乱打に……重厚で濃密な乳肉の責め……。これではひとた\nまりもなかろ？　ほれ、ほれ、精をたんと吐き出せぇ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0103215" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「ちゅ、ぺろ……ちゅるっ、ちゅるっ、ちゅるっくちゅっ、ふふ……。じゅぷ\nぷっ、ぢゅぷっ、ぬぷっぬぷっぬちゅっぬちゅっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0103216" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「そなたの性感は、全てわらわのもの……。捧げよ、崇めよ……っ、は、ンン\n……！　ぢゅるんっ、ぢゅるっぢゅぽっ！　じゅっぽじゅっぽじゅぽっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0103217" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「あぁあーん♪　かぷっ！　ぬっちゅっぬっちゅっぬっちゅっぬっちゅっ……\nうむ、しゅこひコツがちゅかめてきたぁ……ぬちゅっぬちゅっぬっぷっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0103218" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「にゅるっ、にゅるぬちゅっ……れろれろれろ……。むふふ、限界か？　よい\nぞ……わらわを汚す許可を与える……ぢゅるっ、ぢゅるぢゅるっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0103219" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「わらわに感謝しながら精を……放て、ほらっ……ほら、今一度……あの臭い\nネバネバを出せっ……これはとくべちゅ扱いじゃからな……っ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0103220" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「そなたの精を、ぶちまけるのじゃ……！　んんんんっ！　ぢゅーっ！　ぢゅ\nっぢゅっぢゅっ！　ぺろっ、れろれろれろっ……さあっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},
		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "PLAYVOICE", "046_0103301" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「ふむぐっ！？　んんんんん……！？　口に、喉奥にイチモツを差し込んで…\n…んぐぅううっ！？　にゃ、にゃんだ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0103302" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「んーーーーーーーーーーッ！？　んんんんーーーーー！？　んぷっ！？　ん\nぶぅっ！？　んーっ！　んんんんんーーーーーーっ！？」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004601_01_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0103303" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「ごぷっ……！　う、嘘じゃろぉっ……！　口っ、口のにゃかに……！？　お\nえっ、えふっ！？　ごぷっ、おぼれりゅっ、おぼれりゅぅっ、死ぬぅっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0103304" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「出ひゅなぁああっ！　く、口の中に出すにゃど……あっ！？　おふっ！？　\nんぶぅっ！　んーっ！　死ぬっ、死ぬ死ぬぅうっ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0103305" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「ん、んんんんぶぅうう……。んっ……こ、こんな、こんな暴虐を……ゆるひ\nたわけでは……。んぁああ……喉に張り付いて、満足に喋れぬぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0103306" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「……の、飲め？　飲めと言ったのか？　この濁り汁をぉ……！？　とても飲\nみ物とは思えぬひどい味なのじゃがぁ……えふっ、おえっ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004601_01_13" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0103307" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「飲む……飲む……。ううう、な、納得いかぬが……それも含めて儀式なのじ\nゃな？　であれば……！　んぐ……んぐ、むぐ……おえっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0103308" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「ごく……ごく、ごく……。かっはっ……！　の、飲んでも飲んでも終わらぬ\nぅ……。けふっ、ううう……。ごくっ……ごくん……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004601_01_14" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0103309" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「……こ、これでよいか……？　あああ……。これではケダモノの『まぁきん\nぐ』ではないかぁ……。そなたの臭いをつけられてしもうたぁ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004601_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0103310" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「胸と口だけではなく、胃や……もっと深い場所まで……。なんと不遜な……\n。この臭い、味、絶対に一日では消えぬぞぉ……！　ううう……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},
		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "PLAYVOICE", "046_0103401" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「あっ……ああ、よいぞ、良いぞ、よいぞ……ああっ……！　わらわの胸に…\n…胸にたんとかけるがよい……っ」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004601_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0103402" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「なんと元気で、量の多い精液か……。うっかり惚れ惚れしてしまいそうじゃ\nわ……。んっ、びちゃびちゃとよく跳ねる……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0103403" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「くく……。やはり、こう、臭すぎるのが問題じゃが……。こうまで素直に飛\nび出してくると……少し愛しくも思えるのぉ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0103404" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「あっ！　くふふふ、まだ出るのか。んっ？　もっとかけたい？　本当に困っ\nたやつじゃな……。もうこれだけひっかけておるのだ。最後まで出せ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004601_01_10" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0103405" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「最後の一滴まで、わらわの……。あっ♪　わらわの胸に、ビチビチと……。\nあ、ああ……ああ……そうじゃ、そうじゃ、よいぞ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0103406" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「っすううううう……！　ああ……これが、この悪臭がそなたの生命の臭いな\nのじゃな……。今は無理じゃが……くふふふ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004601_01_12" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0103407" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「少しずつでも、慣れてゆかねば……。それにしても、ここまで粘つき、純白\nに染まったそなたの体液……目の当たりにしていると、その……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0103408" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「少し、どきどきする……。どうやら、わらわは……そなたの感じる姿を、顔\nを見るのが面白いタチのようじゃな」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004601_01_11" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0103409" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「次の機会までに、色々と学んでおこう。そうすれば……もっともっとそなた\nを可愛がってやれるかもしれぬものな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0103410" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「せいぜい、覚悟しておくがよい。次は……次こそは、そなたを歓喜の涙にむ\nせるまで、攻めたてわらわの虜にしてやるでの……♪」", "NORMAL" ]},
