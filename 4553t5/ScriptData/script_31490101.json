		{"command":[ "PLAYVOICE", "149_0103101" ]},
		{"command":[ "SETNAME", "戦闘員Ｂ" ]},
		{"command":[ "SETTEXT", "「はぁ……まったく、あなたは本当に困った人ですわ」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "149_0103102" ]},
		{"command":[ "SETNAME", "戦闘員Ｂ" ]},
		{"command":[ "SETTEXT", "「このわたくしを呼び出しておいて、こっ……こんなことをさせるだなんて…\n…もぅ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "149_0103103" ]},
		{"command":[ "SETNAME", "戦闘員Ｂ" ]},
		{"command":[ "SETTEXT", "「わたくしの技量を高める為だとか言っていましたけれど、本当ですの？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "149_0103104" ]},
		{"command":[ "SETNAME", "戦闘員Ｂ" ]},
		{"command":[ "SETTEXT", "「分かっていますのよ、それがウソだってことぐらいは」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "149_0103105" ]},
		{"command":[ "SETNAME", "戦闘員Ｂ" ]},
		{"command":[ "SETTEXT", "「こんな……その、エッチなことをしても強くならないことぐらい、わたくし\nにだって分かってますわ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "149_0103106" ]},
		{"command":[ "SETNAME", "戦闘員Ｂ" ]},
		{"command":[ "SETTEXT", "「でも、まあ……いいですわ。こ、こうすればいいんですのね？　おっぱいを\n揉んで……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "149_0103107" ]},
		{"command":[ "SETNAME", "戦闘員Ｂ" ]},
		{"command":[ "SETTEXT", "「寄せて、挟んで、あなたのオチンポをしごいて……う、うぅっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "149_0103108" ]},
		{"command":[ "SETNAME", "戦闘員Ｂ" ]},
		{"command":[ "SETTEXT", "「殿方のモノをこんな間近で見るなんて初めてですわ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "149_0103109" ]},
		{"command":[ "SETNAME", "戦闘員Ｂ" ]},
		{"command":[ "SETTEXT", "「えっ？　なっ……何を驚いていますのよ。そ、そうですわ。エッチしたこと\nなんてありませんのよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "149_0103110" ]},
		{"command":[ "SETNAME", "戦闘員Ｂ" ]},
		{"command":[ "SETTEXT", "「それがいけませんの？　え……？　嬉しい？　自分がわたくしの初めてにな\nれて……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "149_0103111" ]},
		{"command":[ "SETNAME", "戦闘員Ｂ" ]},
		{"command":[ "SETTEXT", "「あ、あなたねえ、そんなこと真顔で言われたら……はあぁ、もぅ。惚れた弱\nみですわね……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014901_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "149_0103112" ]},
		{"command":[ "SETNAME", "戦闘員Ｂ" ]},
		{"command":[ "SETTEXT", "「んんっ、おっぱいでオチンポ挟んでしごくだなんて……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014901_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "149_0103113" ]},
		{"command":[ "SETNAME", "戦闘員Ｂ" ]},
		{"command":[ "SETTEXT", "「こんないやらしいことする日が来るとは思いませんでしたわ……んっ、んっ\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "149_0103114" ]},
		{"command":[ "SETNAME", "戦闘員Ｂ" ]},
		{"command":[ "SETTEXT", "「あぁっ、やあぁ……オチンポがプルプルって震えて……んんぅ、先っぽから\n汁が出てますのよ……？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014901_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "149_0103115" ]},
		{"command":[ "SETNAME", "戦闘員Ｂ" ]},
		{"command":[ "SETTEXT", "「ど、どこかケガさせてしまいましたの？　違う？　気持ちいい証拠ですの？\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "149_0103116" ]},
		{"command":[ "SETNAME", "戦闘員Ｂ" ]},
		{"command":[ "SETTEXT", "「そ……そう。あなたが悦んでくれるなら、わたくしも嬉しいですわ……はぁ\n、はあぁっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "149_0103117" ]},
		{"command":[ "SETNAME", "戦闘員Ｂ" ]},
		{"command":[ "SETTEXT", "「んんっ、あなたのオチンポとっても大きくてたくましくて……それに、すご\nい匂いをさせてますの……あぁっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "149_0103118" ]},
		{"command":[ "SETNAME", "戦闘員Ｂ" ]},
		{"command":[ "SETTEXT", "「この匂いを嗅いでるだけで、頭がボーッとしてきちゃいますわ……！　んっ\n！　んっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "149_0103119" ]},
		{"command":[ "SETNAME", "戦闘員Ｂ" ]},
		{"command":[ "SETTEXT", "「やぅん！　おっぱい触るの禁止ですわ、んんっ！？　んんん……！！？　乳\n首、ダメですのに……っ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "149_0103120" ]},
		{"command":[ "SETNAME", "戦闘員Ｂ" ]},
		{"command":[ "SETTEXT", "「はぁぁー、はあぁっ、興奮して、もう立ってしまってますの……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "149_0103121" ]},
		{"command":[ "SETNAME", "戦闘員Ｂ" ]},
		{"command":[ "SETTEXT", "「え？　何を白状しろというのですの？　うう……そ、そうですわ。あなたの\n言う通り、もうアソコも濡れてますの……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014901_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "149_0103122" ]},
		{"command":[ "SETNAME", "戦闘員Ｂ" ]},
		{"command":[ "SETTEXT", "「ちゃんと言え？　バカぁ……お、オマンコも興奮して愛液でぬめってますの\n、これで満足？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "149_0103123" ]},
		{"command":[ "SETNAME", "戦闘員Ｂ" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁ、もう……底抜けにド変態なんですから……あぁ、オチンポが\nビクビクしてますの……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014901_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "149_0103124" ]},
		{"command":[ "SETNAME", "戦闘員Ｂ" ]},
		{"command":[ "SETTEXT", "「えっ、え……？　おっぱいでゴシゴシしごかれて、もうイキそう？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014901_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "149_0103125" ]},
		{"command":[ "SETNAME", "戦闘員Ｂ" ]},
		{"command":[ "SETTEXT", "「あ……あっ！　射精しますの？　せ、せーえき出ちゃいますのね？　でも、\nこういう時はどうすれば……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "149_0103126" ]},
		{"command":[ "SETNAME", "戦闘員Ｂ" ]},
		{"command":[ "SETTEXT", "「ええっ！？　わたくしの胸と顔で受け止めろ……？　うぅ、もう分かりまし\nたわ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014901_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "149_0103127" ]},
		{"command":[ "SETNAME", "戦闘員Ｂ" ]},
		{"command":[ "SETTEXT", "「ど、どうぞ来て下さいまし……あっ、ああぁ、んんぅ！？　あっ……ああぁ\n、来る……来るぅぅ！」", "NORMAL" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014901_01_05" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "149_0103128" ]},
		{"command":[ "SETNAME", "戦闘員Ｂ" ]},
		{"command":[ "SETTEXT", "「ひゃううぅん！！？　んあぁー！！　はぁ！　はぁぁっ！　あぁ……熱いで\nすの……っ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "149_0103129" ]},
		{"command":[ "SETNAME", "戦闘員Ｂ" ]},
		{"command":[ "SETTEXT", "「子種汁、こんなにドロドロして、ベトベトするものだなんて……んんぅ、多\nすぎですわ……あふぅ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "149_0103130" ]},
		{"command":[ "SETNAME", "戦闘員Ｂ" ]},
		{"command":[ "SETTEXT", "「カラダ中、ベトベトですわよ……はぁ、はあぁっ、なんて匂い……凶暴で、\n野性的な……んああっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "149_0103131" ]},
		{"command":[ "SETNAME", "戦闘員Ｂ" ]},
		{"command":[ "SETTEXT", "「え？　おっぱいについたスペルマを舐めて飲んで欲しい、ですって？　むぅ\nぅ……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014901_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "149_0103132" ]},
		{"command":[ "SETNAME", "戦闘員Ｂ" ]},
		{"command":[ "SETTEXT", "「やればいいんでしょう？　やれば！　ごくっ……い、いきますわよ。ちゅる\n……ちゅるるっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "149_0103133" ]},
		{"command":[ "SETNAME", "戦闘員Ｂ" ]},
		{"command":[ "SETTEXT", "「んあぁ、すごい味……っ。苦くて、しょっぱくて、ネトネトして飲み込めな\nいですの……っ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "149_0103134" ]},
		{"command":[ "SETNAME", "戦闘員Ｂ" ]},
		{"command":[ "SETTEXT", "「じゅぷぷ、じゅる、ちゅっ……ちゅうぅ、ごきゅっ。ごっ……くぅん、んは\nあぁ、はあぁん……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "149_0103135" ]},
		{"command":[ "SETNAME", "戦闘員Ｂ" ]},
		{"command":[ "SETTEXT", "「え、え……？　ちょっ。オチンポ汁を飲むわたくしの顔が可愛いだなんて…\n…」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014901_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "149_0103136" ]},
		{"command":[ "SETNAME", "戦闘員Ｂ" ]},
		{"command":[ "SETTEXT", "「そ、それは確かにすごい匂いで、アソコの奥まできゅんきゅんしてしまいま\nしたけれど……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "149_0103137" ]},
		{"command":[ "SETNAME", "戦闘員Ｂ" ]},
		{"command":[ "SETTEXT", "「ひゃあっ！？　我慢できない、って……まさか続きをしますの？　今から、\nここで？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "149_0103138" ]},
		{"command":[ "SETNAME", "戦闘員Ｂ" ]},
		{"command":[ "SETTEXT", "「そんな……でも、あなたに、なら……あげてもいい、ですわ……さ、さあ来\nて下さいまし」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014901_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "149_0103139" ]},
		{"command":[ "SETNAME", "戦闘員Ｂ" ]},
		{"command":[ "SETTEXT", "「わたくしの純潔、あなたに貰って欲し……いっ、んあああぁぁ～～～っ！！\n？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014901_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "149_0103140" ]},
		{"command":[ "SETNAME", "戦闘員Ｂ" ]},
		{"command":[ "SETTEXT", "「あぁっ、ああ……！　大好きですわ、あなたの子種汁、たっぷり子宮に注い\nで下さいませね……？」", "NORMAL" ]},
