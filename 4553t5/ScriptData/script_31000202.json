{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010002_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「隊長どの……日焼け止めを塗っていただけるのは嬉しいのだが、少々手つき\nがいやらしいと言うか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0204101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ひゃんんっ！　ビキニの中まで塗る必要などないと思うぞ……んっ、んんっ\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0204102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「やっ、そんな……乳首やクリトリスをグリグリするなんて……はぅ、んっ、\nくふうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0204103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「はぁ、んっ、あはああぁ……アソコが切なくなって、トロトロの蜜が溢れて\nきている……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0204104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「お、お願いだ、隊長どの……！　隊長どのの熱くて硬いペニスを、私のアソ\nコに突き入れて、身体の疼きを鎮めてくれ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0204105" ]},
		{"command":[ "SETIMAGE", "0", "still_00010002_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「やっ、ああっ……そんな……この期に及んで焦らすだなんて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0204106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ひっ、んぐっ、うううぅ……！　ペニスの傘の部分が、何度も私のクリトリ\nスを擦って来る……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0204107" ]},
		{"command":[ "SETIMAGE", "0", "still_00010002_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「私の赤ちゃんの部屋がペニスを欲しがってるのに、どうして挿れてくれない\nんだ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0204108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「私の反応が可愛くて、もっとイジメたくなるだと……！？　隊長どの、悪ふ\nざけもほどほどにして……あはあぁん！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0204109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ああっ！　あっ、あひいぃ！？　クリトリスをペニスの先端でツンツンしな\nいでくれ……！　感じすぎてしまう……！」」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0204110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ぐううぅ……！　隊長どの……私のアソコは、隊長どののペニスを欲して疼\nいている……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0204111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ワレメから溢れ出ている、トロトロの蜜がその証拠だ……隊長どのに犯して\n欲しいと訴えているのがわかるだろう……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0204112" ]},
		{"command":[ "SETIMAGE", "0", "still_00010002_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「これは房中術ではなく、私の本心だ……！　仕えるべき主君と、一つになり\nたいと思っているんだ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0204113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「だから……早くそのたくましいペニスを私のアソコに挿れて、思い切りズポ\nズポしてくれ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0204114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あっ……んんっ！　ペニスの先端が、ワレメとくっついて……！　ヌルヌル\nのアソコに、ペニスが入って……んんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0204115" ]},
		{"command":[ "SETIMAGE", "0", "still_00010002_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あっ、ふああぁ……！　い、一気に奥まで突き入れるだなんて……！　気持\nちよすぎて、イッてしまったじゃないか……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0204116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んくっ……すまない、隊長どの……！　これだけキツく締め付けたら、動き\nにくいだろう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0204117" ]},
		{"command":[ "SETIMAGE", "0", "still_00010002_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「すぐに力を抜くから、少しだけ待って……はぁ、あぐっ！　あはああぁん！\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0204118" ]},
		{"command":[ "SETIMAGE", "0", "still_00010002_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「そんな……！　ペニスを思い切り締め付けてるのに、無理矢理動くなんて…\n…！？　あああっ！　す、すごい！　感じすぎるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0204119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「傘の部分が何度も私の膣内を抉って、ぐちゅぐちゅといやらしい音が鳴って\nいる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0204120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「はああっ、あっ、ああっ、んひゃあぁっ！？　そこは私の赤ちゃんの部屋…\n…！　そんなとこまで突かないでくれ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0204121" ]},
		{"command":[ "SETIMAGE", "0", "still_00010002_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「やっ、んんっ、ぐっ、ううぅ……！　突くなと言った矢先に、子宮の入り口\nをペニスでグリグリするなんてぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0204122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あああっ……そんなに刺激されたら、赤ちゃんの部屋の入り口が開いてしま\nうじゃないか……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0204123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「それだけは許してくれ……！　好きなだけ私のアソコをほじくり回していい\nから、どうかそこだけは……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0204124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「おっ、んぐっ、うぅんんっ！　隊長どののペニスが動いて……！　アソコの\n肉がめくれるぐらい、じゅぽじゅぽされているぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0204125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ま、またイクぅ！　隊長どのが一度もイッていないのに、私だけ……イッ、\nイクうううぅ～～～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0204126" ]},
		{"command":[ "SETIMAGE", "0", "still_00010002_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あっ、あはあぁあっ……！　そんな……イッたばかりなのに、アソコの浅い\nところをゴシゴシされたら……んきゅうぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0204127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「Ｇスポットがペニスで押し潰されるぅ！　ビクビク跳ねながら、ペニスの傘\nが何度も気持ちいいところを叩いてくるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0204128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「おっ、んぐっ、おほぉ……！　頭ではダメだと理解できるのに、身体が隊長\nどのを求めている……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0204129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「そのたくましいペニスで、私のアソコをメチャクチャにして欲しいと思って\nしまうじゃないか……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0204130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ううっ、あっ、んぐううぅ！　奥はダメなのに……！　赤ちゃんの部屋にペ\nニスを突き入れて欲しいと、本能が訴えてくる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0204131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ああああぁ～～～！　ま、また奥を突かれてるぅ！　これ以上私のして欲し\nいことをされたら、隊長どのから離れられなくなってしまう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0204132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あっ、はぐっ、ひいぃんっ！？　ペニスが子宮の入り口でビクビク震えて…\n…！？　赤ちゃんの部屋に精子を出そうというのか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0204133" ]},
		{"command":[ "SETIMAGE", "0", "still_00010002_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「そんなことされたら、隊長どのの子を孕んでしまう……！　うううぅ……！\n　ダメなのに、イヤだと感じない私がいるなんて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0204134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あっ、あっ！　ペニスの奥から精子が昇ってきてる……！？　やっ、やああ\nあっ！　あっ、ひああぁあぁ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0204135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あああああっ！　びゅるびゅる出されているっ！　発情しきったメスの子宮\nに、濃厚精子が流れ込んでくるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0204136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010002_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「本当に奥で出すなんて……！　どうしてこんなことを……んっ、あああっ、\nやああぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0204137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「自分の女に種付けするのは、男として当然だと……！？　そ、そんな……隊\n長どのの女だなんて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0204138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「そんなことを言われたら、嬉しくて……イッ、イクううううぅ～～～～～！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0204139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あっ、ひっ、ああぁ……！？　感じすぎて、潮を吹きながらイッてしまった\n……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0204140" ]},
		{"command":[ "SETIMAGE", "0", "still_00010002_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふああぁ……マタタビと同じぐらい、クセになるまぐわいだった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0204201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「身体も心も満たされて……ヘソの下あたりから、言葉に出来ないほどの幸福\n感が押し寄せてきているぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0204202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「これがオスを受け入れた、メスの感覚なのだな……ふふっ。これはどれだけ\n修行をしても、知ることができない感覚だな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0204203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「さて、隊長どの。私はもう十分に満足したから、ペニスを抜いてくれないか\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0204204" ]},
		{"command":[ "SETIMAGE", "0", "still_00010002_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んんっ……そんなにゆっくり腰を引かなくても……！　もう射精したのだか\nら、早く抜いて……んほおおおぉ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0204205" ]},
		{"command":[ "SETIMAGE", "0", "still_00010002_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「な、なん……で……！？　また奥までペニスを突き入れて……ふあああぁん\n！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0204206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「やっ、あっ！　さっきよりも激しっ……！　あああっ！　イッたばかりだか\nら、余計に感じてしまうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0204207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「隊長どの！　もう堪忍してくれ！　私の身体の疼きは、先ほどの絶頂で治ま\nったから……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0204208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んなっ……！？　そんな……また隊長どのは満足されていないというのか…\n…！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0204209" ]},
		{"command":[ "SETIMAGE", "0", "still_00010002_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「確かに先ほど、私は隊長どの女だと言われたが……意中の者を娼婦のように\n扱うなど……おっ、あんっ、んぐうぅんっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0204210" ]},
		{"command":[ "SETIMAGE", "0", "still_00010002_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「アソコをペニスでほじられると、逆らえなくなってしまう……！　また子種\nを出して欲しいと、膣奥が疼いてくる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0204211" ]},
		{"command":[ "SETIMAGE", "0", "still_00010002_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「おっ、おおおぉ……！　隊長どのが動くたびに、精子と私の本気汁がペニス\nに絡みついて、アソコの肉を抉られる感触が……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0204212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ネバついた汁がアソコからぶちゅぶちゅ飛び出て、こんなにも卑猥な音が鳴\nるなんて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0204213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んっ、あっ、はあぁあ！　またイカされてしまうぅ！　この太くて硬いペニ\nスで、何度でもイカされるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0204214" ]},
		{"command":[ "SETIMAGE", "0", "still_00010002_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ああっ！　ダメっ、ダメだっ！　イクっ！　イクうううぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0204215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あひっ、ふっ、ぐうぅ、んんんっ！　イッている最中なのに、そんなに激し\nくアソコをズポズポされたら……あひぃ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0204216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「イッたばかりなのに、さらにイッてしまいそうだ……！　こんなの、本当に\nダメになってしまうじゃないか……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0204217" ]},
		{"command":[ "SETIMAGE", "0", "still_00010002_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「はああっ、あっ、ひゃふっ！？　このペニスの震え……！　隊長どのも、イ\nキそうなんだな……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0204218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あああっ！　来るっ！　また精子来るぅ！　オスの欲望に塗れた、真っ白な\n子種が私に……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0204219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、ああっ、んああぁっ！　イクッ！　イクイクッ！　イグううう\nぅ～～～～～！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0204220" ]},
		{"command":[ "SETIMAGE", "0", "still_00010002_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あああっ！　熱いの出てるっ！　隊長どのの子種が、容赦なく私の赤ちゃん\nの部屋に……はひぃ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0204301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010002_02_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「こんなに出されたら、本当に孕んでしまいそうだ……！　そうなったら、お\n腹が大きくなって任務に支障が……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0204302" ]},
		{"command":[ "SETIMAGE", "0", "still_00010002_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「そうなったら困るのに、どうしてこんなにも母親になりたいと思ってしまう\nんだ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0204303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「隊長どの……！　はしたい私を許してくれ……！　隊長どのの子を孕みたい\nと思う、未熟なニンジャを見捨てないでくれ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0204304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あっ、はっ、はひいぃん！？　ペニスがひときわ大きくビクビク動いて、子\n種を全部出し切って……んんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0204305" ]},
		{"command":[ "SETIMAGE", "0", "still_00010002_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……収まりきらなかった精子が、アソコから溢れてくる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0204306" ]},
		{"command":[ "SETIMAGE", "0", "still_00010002_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ううぅ……こんな姿を見せるなんて、私はニンジャ失格だ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0204307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「……どんな姿を晒すことになっても、ずっと隊長どのの側に居ていいのか…\n…？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0204308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふふっ。そんなこと素直に言えるとは、隊長どのの器は本当に大きいな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0204309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「それじゃあ、私の身体に新たな命が宿って、ぽっこりした腹になったとして\nも……ずっと側に居させてもらうとしよう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0204310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あっ、ぐっ、んんんっ！？　どうしてペニスを引き抜いて……あひいいぃ！\n？", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0204401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010002_02_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あっ、熱いっ！？　身体に精液がかかって……！　ううっ、アソコに入って\nいるときよりニオイが伝わってくるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0204402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「はあ、はあぁ……エッチと混ざった精液のニオイ……なんていやらしいんだ\n……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0204403" ]},
		{"command":[ "SETIMAGE", "0", "still_00010002_02_16" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「嗅いでいると、頭がクラクラしてくるのに……もっと嗅いでいたいとすら思\nってしまうな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0204404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「このニオイだけで、イッて……んっ、ふああぁ、んひゃああぁ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0204405" ]},
		{"command":[ "SETIMAGE", "0", "still_00010002_02_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……精液のニオイでイクだなんて、私も相当な変態だな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0204406" ]},
		{"command":[ "SETIMAGE", "0", "still_00010002_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「だがこんなことになるのは、隊長どのだけだ……私の身も心も、隊長どのの\nモノだからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0204407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「だから……もっとシてもいいんだぞ……？　ガチガチに勃起したままのペニ\nスを、また私に突き入れても……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0204408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「アソコの奥に子種を出され、身体中に精子をぶっかけられているのだ。遠慮\nなんてしなくていい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0204409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「隊長どのが満足するまで、いつまでも付き合ってやるからな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0204410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}