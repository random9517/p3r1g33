{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00025702_02_01" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「あっ、んんっ……湯舟に浸かった瞬間、このようなことを……はっ、あぁっ\n……熱くてカタいチンポが、オマンコに当たっているっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0204101" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「そんなに擦りつけられたら、濡れてきてしまうっ……だ、ダメだ。これ以上\nは……ひゃ、あひっ！　んっ、んくぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0204102" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「あぁぁっ！　クリトリスをスリスリされると、勃起してしまうぅっ……やっ\n、ああぁんっ！　乳首も、勝手に大きくなってっ……あはぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0204103" ]},
		{"command":[ "SETIMAGE", "0", "still_00025702_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「やっ、あっ！　挿れるのは、さすがにまずいぞ！　ここは公共の施設だ。お\n湯を汚したりしたら、皆に迷惑がかかってしまう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0204104" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「そ、そんなの関係ないだなんて……どうしても、私のオマンコにチンポを挿\nれたいのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0204105" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「私も、その気になっているだと……？　そ、そんなことは……ひゃ、あんん\nっ！　やっ、あっ！　オマンコにチンポの先っぽが添えられてっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0204106" ]},
		{"command":[ "SETIMAGE", "0", "still_00025702_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「お湯とは違う、ヌルヌルした感触がするだなんてっ……そ、それはぁ……ん\nんっ！　そんなに刺激されたら、ガマンできなくなってくるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0204107" ]},
		{"command":[ "SETIMAGE", "0", "still_00025702_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「もう、無理だっ……認める。ご主人様のチンポで、オマンコがぐちゃぐちゃ\nになっているから……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0204108" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「このぶっといチンポが欲しくて、たまらないんだ……！　奥まで突き挿れて\n、ズンズン突きまくって欲しい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0204109" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「入口やクリトリスをスリスリされるだけだと、頭がおかしくなってしまう！\n　は、早くチンポを挿れてくれ！　めちゃくちゃに、犯してくれぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0204110" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「んひぃぃんっ！？　はっ、あっ、あぁぁっ……い、いきなり奥まで、チンポ\nが挿ってきているぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0204111" ]},
		{"command":[ "SETIMAGE", "0", "still_00025702_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「子宮口のところに、カタいのが当たって……ほっ、んひっ！　オマンコ締ま\nるぅ！　チンポを求めて、ぎゅーってしてしまうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0204112" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「はぁぁっ、やはりご主人様のチンポは最高だっ……！　ずっとこうして、繋\nがっていたくなるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0204113" ]},
		{"command":[ "SETIMAGE", "0", "still_00025702_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「そろそろ動くって……そんな、まだオマンコがチンポに馴染んでいないのに\nっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0204114" ]},
		{"command":[ "SETIMAGE", "0", "still_00025702_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「あっ、あっ！？　も、もう少しだけ待ってくれ！　せめて、このオマンコの\n締まりが、少し緩むまで……ひっ、あっひぃぃぃっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0204115" ]},
		{"command":[ "SETIMAGE", "0", "still_00025702_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「ふあぁぁぁ～っ！？　んっ、あっ！　ひっ、あぎひぃっ！？　ほっ、おぉっ\n、んおっ、おぉ～！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0204116" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「奥にズンズンくるぅ！　そんな乱暴に突くなんて……あっ、んぅ！　ふっ、\nぐぐっ、あっあっあっ！　んはぁっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0204117" ]},
		{"command":[ "SETIMAGE", "0", "still_00025702_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「いつもと同じくらいの速度で突いてるって……そんなのウソだっ！　だって\n、こんなに感じるなんておかしい……あひっ、んぎひぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0204118" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「も、もしかして、湯舟に浸かりながらエッチしているから、いつもより感じ\nるのか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0204119" ]},
		{"command":[ "SETIMAGE", "0", "still_00025702_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「だとしたら、これ……クセになりそうだ！　奥をえぐられる感覚が強すぎて\n、頭がおかしくっ……んぅっ！　ぐっ、んほっ！　おほぉ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0204120" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「はひっ、ふひぃ！　ご主人様のチンポが、さらに太くなっているぅ！？　突\nかれるたびに、カタく、大きくなってぇ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0204121" ]},
		{"command":[ "SETIMAGE", "0", "still_00025702_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「あはぁぁぁぁんっ！　浅いところも感じるっ！　奥もいいけど、Ｇスポット\nのあたりも気持ちいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0204122" ]},
		{"command":[ "SETIMAGE", "0", "still_00025702_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「くっ、んくぅっ！　そんな、入口のところまで引き抜かれたらっ……あっ、\n抜けるっ！　ご主人様のチンポ、抜けちゃうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0204123" ]},
		{"command":[ "SETIMAGE", "0", "still_00025702_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「んっくぅぅぅ～～～っ！？　ま、また奥までぇっ！？　いつもより深くまで\nチンポ刺さるぅ！　あぁっ、気持ちいいの止まらないっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0204124" ]},
		{"command":[ "SETIMAGE", "0", "still_00025702_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「あっあっ、んっ、あっ！？　お湯がオマンコのナカに入ってくるぅ！　私の\nエッチなお汁と混ざって、オマンコ、ぐちゃぐちゃになっているぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0204125" ]},
		{"command":[ "SETIMAGE", "0", "still_00025702_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「ただでさえ、擦られてオマンコ熱いのにっ……お湯の感覚までしてくると、\nもっと熱くなってっ……んぅっ！　ふっ、ひうぅっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0204126" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「勝手にぎゅっ～って締まるぅ！　ご主人様のチンポ、オマンコで締め付けて\n、咥え込んでるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0204127" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「ふひっ、あっ、あひっ！？　子宮にお湯が流れ込んできてっ……あっ、あっ\n！　これ、ヘンな感じがするっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0204128" ]},
		{"command":[ "SETIMAGE", "0", "still_00025702_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「ヘソの下あたりが温かくなって、満たされる感じがっ……んっ、ひぎっ！？\n　く、くるっ！　気持ちいいの、溢れてしまうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0204129" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「はひっ、ふひっ！　んひぃっ！？　ご、ご主人様のチンポも、ビクビクして\nぇっ！？　イ、イキそうなんだな！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0204130" ]},
		{"command":[ "SETIMAGE", "0", "still_00025702_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「遠慮せずに出してくれっ！　私の家系は後継ぎがいなくて、困っているんだ\n！　だから、このまま孕ませてくれぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0204131" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「ご主人様の子供なら、何人だって産みたいんだっ！　だから……おっ、んお\nぉっ！？　ほっ、おっ！？　んぉぉぉ～～！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0204132" ]},
		{"command":[ "SETIMAGE", "0", "still_00025702_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「チ、チンポがオマンコで暴れているぅ！？　激しく突かれまくって、子宮が\n悦んで……んほぉっ！？　ほっ、ふひっ！？　おほひぃっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0204133" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「イグッ！　イグイグぅぅっ！　ご主人様のチンポ、ギチギチに締め付けなが\nらイクぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0204134" ]},
		{"command":[ "SETIMAGE", "0", "still_00025702_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「あっあっ！　んっ、ほぉっ！？　おっ、んおぉっ、おぉっ！　うぎっ、んぎ\nぎっ……あっはぁぁぁぁんっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0204135" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「はひっ！　あっ、おっ！　おぉ～！？　びゅーびゅー出てるぅ！　アツアツ\nのドロドロザーメン、子宮にどぴゅどぴゅされているぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0204136" ]},
		{"command":[ "SETIMAGE", "0", "still_00025702_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「子宮の奥まで、注がれている感じがするっ！　あっ、あぁぁっ、気持ちいい\nっ！　こんなの、またイッてしまうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0204137" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「ひゃ、んひっ！　イクッ！　オマンコにナカ出しされながら、イクぅぅぅっ\n！　あっ、あっ、んっ！　あはぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0204138" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「はぁ、ああぁっ！　ぜんぶ、流し込んでくれっ！　ご主人様の精子で、種付\nけしてくれぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0204139" ]},
		{"command":[ "SETIMAGE", "0", "still_00025702_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「一滴残らず、子宮で受け止めるからぁ！　んんんっ！　くっ、はぁぁっ！　\nはひっ、んぎひっ！　ひっ、あっ！？　おっ、おほぉぉぉっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0204140" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、あはぁぁっ……こんなに注いでくれるなんて……さすがは、\nご主人様だ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0204201" ]},
		{"command":[ "SETIMAGE", "0", "still_00025702_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「私のオマンコ、精子とお湯でいっぱいだ……すごく温かくて、幸せな感じが\nするぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0204202" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「んんっ……このまま抜いたら、湯舟を汚してしまうな……申し訳ないが、繋\nがったまま出るとしよう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0204203" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「えっ？　まだチンポが治まらない？　これだけ出したのに、まだ身体が火照\nっているのか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0204204" ]},
		{"command":[ "SETIMAGE", "0", "still_00025702_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「頭もぼーっとするって……それはもしかして、『ユアタリ』と呼ばれるもの\nでは……あっ、ちょ、ちょっと！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0204205" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「んぅぅぅ～～～っ！？　ま、またチンポがズポズポ動いて、オマンコをホジ\nってくるぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0204206" ]},
		{"command":[ "SETIMAGE", "0", "still_00025702_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「ご、ご主人様っ！　頭がぼーっとしているのに、そんなに動いたら……ひぎ\nっ！？　おっおっ、んおぉぉぉっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0204207" ]},
		{"command":[ "SETIMAGE", "0", "still_00025702_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「おっ、あっ！？　さっきよりも、深くチンポが刺さって……！？　そんな、\nどうして……んぎっ！？　おごっ、ふんごぉっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0204208" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「あぁぁっ！　ひっ、んっ、あはぁぁんっ！　ご、ご主人様ぁ、少し落ち着い\nてくれぇ！　そんなにされたら、私までヘンになるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0204209" ]},
		{"command":[ "SETIMAGE", "0", "still_00025702_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「頭がぼーっとしてきてっ……あっ、あぁぁっ！　気持ちよくて、ふわふわす\nるっ！　目の前が真っ白になってしまうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0204210" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「んっ、んぅぅっ！　ふっ、はっ、あっあっ、ひゃ、あひっ！　おっ、んおぉ\nっ、おぉっ、おほぉぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0204211" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「ご主人様の動きに合わせて、自分から腰を振ってぇっ！？　あっ、これっ、\nすごいぃ！　湯舟だと、動きやすくて……んひぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0204212" ]},
		{"command":[ "SETIMAGE", "0", "still_00025702_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「ズボズボするたびに、お湯が波打ってきて気持ちいいっ！　オマンコも身体\nも、どんどん熱くなってくるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0204213" ]},
		{"command":[ "SETIMAGE", "0", "still_00025702_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「湯舟でエッチするの、最高だっ！　意識が飛んでしまいそうになるっ！　脳\nの奥がクラクラするっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0204214" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「んっ、ひぎっ！　ふっ、んぐぐっ！　ご主人様の身体が、ビクビク震えてっ\n……あぁぁっ！　チンポもオマンコの奥で、跳ねまくっているっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0204215" ]},
		{"command":[ "SETIMAGE", "0", "still_00025702_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「また、イキそうなんだな！？　射精したくて、たまらないんだなっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0204216" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「ぐっ、おぉっ！　おっ、おぉぉっ……だ、出すなら、またナカにっ……子宮\nにびゅーびゅーしてくれっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0204217" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「そうじゃないと、湯舟に精液がっ……あっ、あっ！　絶対だぞっ！　絶対に\n、ナカに出してっ……はひぃっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0204218" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「あっ、イクッ！　私もまた、イクぅ！　頭クラクラしながら、イッてしまう\nぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0204219" ]},
		{"command":[ "SETIMAGE", "0", "still_00025702_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「ひっ、んぎっ！　あっ、あっあっあっ！　チンポの疼きが強くなってぇっ！\n？　くるっ！　精子くるぅ！　あっあっ、んぁぁぁぁ～っ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0204220" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「くぅぅぅ～！　あっ、はぁぁぁっ！　熱いぃっ！　チンポから、すごい勢い\nで精子が飛び出ているぅ！", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0204301" ]},
		{"command":[ "SETIMAGE", "0", "still_00025702_02_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「また子宮に注がれてっ……これ、絶対に孕むっ！　ご主人様の赤ちゃん、身\n籠るぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0204302" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「あぁぁっ！　種付けされるの、すごく嬉しいぞっ！　もっと出して……んっ\n、んぐぐっ！　ふっ、ほっ！　おっ、んぎひぃっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0204303" ]},
		{"command":[ "SETIMAGE", "0", "still_00025702_02_11" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「あっ、あっ！　本当に意識が飛びそうだ！　オマンコだけでなく、顔や身体\nも熱くなってっ……んひっ、ふひっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0204304" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「んぎぎっ、ぐっ、んっはぁっ！　あっ、んぁっ、はぁぁっ！　身体中の血液\nが、沸騰しているみたいに熱くっ……ふっ、んふっ！　んくぅ～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0204305" ]},
		{"command":[ "SETIMAGE", "0", "still_00025702_02_12" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「あっ……んっ、あぁぁっ……お腹が、熱いっ……お湯と精子で、オマンコが\nいっぱいだっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0204306" ]},
		{"command":[ "SETIMAGE", "0", "still_00025702_02_11" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「もう、気持ちいいことしか考えられない……脳に酸素が行きわたっていない\n感じがする……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0204307" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「私まで『ユアタリ』になってしまったのでは……んっ、あふっ……これは、\n非常にまずいぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0204308" ]},
		{"command":[ "SETIMAGE", "0", "still_00025702_02_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「ご主人様……早く湯舟から出て、身体を冷やそう……じゃないと、大変なこ\nとになるかも知れない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0204309" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「でも、ここでチンポを抜いたら、湯舟を汚すことに……！　くぅっ……いっ\nたい、どうすればいいんだぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0204310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「んひゃぁっ！？　あっ、んひっ！　はっ、んぅぅ～！　精子が身体にかかっ\nてくるぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0204401" ]},
		{"command":[ "SETIMAGE", "0", "still_00025702_02_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「あ、熱いのがびちゃびちゃ飛んできてっ……あぁぁっ！　お湯と一緒に、ぶ\nっかけられているぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0204402" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「ひっ、あっあっ！　んはぁぁっ！　ご主人様のザーメンの香りがするっ！　\nこれを嗅ぐと、もっと頭がふわふわしてぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0204403" ]},
		{"command":[ "SETIMAGE", "0", "still_00025702_02_14" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「んふっ、んんっ！　はぁぁっ、濃厚なオスの香りがぁっ……あっ、あっ、ん\nぁぁっ！　匂いで、またイクッ！　んっ、んぐぐっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0204404" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「うっ、んぎっ！　あっ、あひっ！　あっあっ、イクッ！　イクイクッ！　私\nのイキ汁が、湯舟に出てっ……んぅぅぅぅぅ～～～！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0204405" ]},
		{"command":[ "SETIMAGE", "0", "still_00025702_02_15" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「はぁぁっ……ふっ、ぐっ……んはぁぁぁっ……ナカに出してくれと、言った\nのにぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0204406" ]},
		{"command":[ "SETIMAGE", "0", "still_00025702_02_13" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「湯舟が精子で汚れてしまったじゃないか……早く掃除をしないと、大変なこ\nとになってしまう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0204407" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「それに、せっかく綺麗にした身体も、ザーメンで汚れてっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0204408" ]},
		{"command":[ "SETIMAGE", "0", "still_00025702_02_14" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「あっ、いや、精子で汚されるのは、嫌いじゃないというか……むしろ、ご主\n人様の所有物という感じがして、すごく嬉しいというか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0204409" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「と、とにかく、今はこの湯舟を何とかしないと……あぁっ、でも、もう頭が\nぼーっとして……んっ、はぁっ……これは本当に『ユアタリ』の状態だな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0204410" ]},
		{"command":[ "SETIMAGE", "0", "still_00025702_02_13" ]},
