{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0187" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そもそも……何で俺、裸なんだ……？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "普段寝る時に真っ裸になる習慣はない。前を隠しながら、慌ててベッドに潜り\n込む。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「それは……昨日の夜は、とっても凄かったし……その、貴方も疲れていたみ\nたいだから、そのままで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010022510001" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "5", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「素敵だったわ……思い出すだけで、胸の奥がどうにかなってしまいそうな位\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010022510002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "何だそれ！　俺の記憶のない中で、そんな美味しい出来事があったってのか？", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "しかも、カグヤがそんな赤裸々なことを言う？　こいつ、そんなタイプだった\nか……？", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「うぬぅ……いくら順番とは言え、ストレートに惚気を聞かされると穏やかで\nはいられんぞ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090022510001" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はい、とても羨ましいですわ……次の夜が待ちきれません……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_020022510001" ]},
		{"command":[ "SETCHARA", "0", "char_00003002_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「確かに……いっそ、このまま私達にもお情けをいただくというのは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090022510002" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ま、待て待て、服を脱ぐな！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "どうなってるんだ……そもそも、そんな記憶は全くねぇし、皆の態度\nも違いすぎるし……", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あ、あー、取り込み中のところ悪いが……敵が来ているんだが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022510001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "2", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そ、そうだった！　とにかく服を着るから離れてくれ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「服……？　それなら、私が……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010022510003" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「待ってくれ、服を着せるのは私に任せてもらおう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090022510003" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「着付けの心得でしたら、私にもございます。どうか、お申し付けを……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_020022510002" ]},
		{"command":[ "SETCHARA", "0", "char_00003002_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「一人で出来るから！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0188" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETTEXT", "「うぉっ……なんか、もうドンパチ始まってやがる……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "外へ飛び出すと、そこでは瓜二つの二人が激しい火花を散らしていた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「うりゃぁぁぁぁぁぁぁぁぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022510001" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「くくっ、鳴き声だけは一人前よ！　そうらっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100022510001" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ちぃっ……このっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022510002" ]},
		{"command":[ "SETTEXT", "「うりゃぁぁぁぁぁぁぁぁぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「どうしたんじゃ？　こちら側の余は、随分と歯ごたえがないのう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100022510002" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ほざいてなっ！　まだまだ、こんなもんじゃないよっ、はぁぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022510003" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ふん、遅いのう。攻撃というのは、こうするんじゃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100022510003" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ぐぅっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022510004" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「エファナティカっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「やれやれ……口ほどにもない……んっ、おおっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100022510004" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「な……何だ……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「やっと見つけたぞ、麗しの我が君よ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100022510005" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「は、はぁっ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「あぁ……ずっと余の愛しき婿殿を探し求めていたが、やはりここに隠してい\nたか、小癪な奴らめ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100022510006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「だが、その苦労も素敵なお顔を見せてもらえば全て吹き飛ぶ。さあ、我が君\n。迎えに来たのじゃ、余と共に参ろうぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100022510007" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ま、参ろうぞって……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「そうは行かんぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090022510004" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「旦那様は絶対に渡さないわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010022510004" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「私達の全てを賭してでも、旦那様はお守り致します」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_020022510003" ]},
		{"command":[ "SETCHARA", "0", "char_00003002_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「え……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「その通りだ！　愛する人は、必ず守る！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022510002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「……やられっぱなしじゃいられないよ。あたしだって、この人の前なら百人\n力のパワーが湧いてくるのさ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022510005" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「え……えぇぇ……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "俺の前に盾になるようにして、幹部達がアナザーエファナティカの前に立ちは\nだかる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ルナテミスやエファナティカまで……愛する人って……", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "何が何だか分からないが、どうやらこの場にいる全員が、俺を旦那……恐らく\nは夫という体で捉えている。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "しかも、誰か一人のということではなく、さながら一夫多妻制のように、それ\nぞれが妻であるという認識でいるかのようだ。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「お主らのような木っ端が束になったところで、余の敵じゃないよ。命が惜し\nければそこをどくがいい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100022510008" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "アナザーエファナティカの威圧がより一層強さを増していく。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うくっ……圧が……やべぇ……！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「カツマ！　お願いっ、私達に『ザ・ブライド』の変身許可を！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010022510005" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「え……？　ザ……ブライド……変身許可？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そうだ、頼む！　新たな力を開放させてくれ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022510003" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「どうしたっ、早くしてくれっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022510006" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、どうしたって言われても……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「カグヤ達に薬指の指輪を向けるんだ、旦那様！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090022510005" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「薬指の……あっ……い、いつの間に……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "気づいていなかったが、確かに俺の薬指には小さなリングが嵌められていた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「それをこっちに向けてっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010022510006" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「こうかっ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "言われるままに、薬指をかざした途端――", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0188" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "PLAYBGM", "BGM_007" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おぉ……」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「愛しい人を守るため……カグヤ・ザ・ブライド……ここに見参！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010022510007" ]},
		{"command":[ "SETCHARA", "0", "char_00000211_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「真実の愛が、内側から光を灯す……ルナテミス・ザ・ブライド！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022510004" ]},
		{"command":[ "SETCHARA", "0", "char_00000118_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「我が身の全てを貴方に捧ぐ……エファナティカ・ザ・ブライド！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022510007" ]},
		{"command":[ "SETCHARA", "0", "char_00000309_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そこには、白く華やかなドレスに身を包んだ幹部たちの眩しい姿があった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "それは、まるで花嫁のような……それでいて凛々しさや強さを感じさせるよう\nな、そんな姿だった。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「旦那様、私達にも変身許可を！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090022510006" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「私も旦那様のお役に立ちたく思います」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_020022510004" ]},
		{"command":[ "SETCHARA", "0", "char_00003002_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
