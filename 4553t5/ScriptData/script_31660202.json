{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016602_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、ふっ……はぁ、はぁ……んっ、あぁ……ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0204101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「んっ、くぅ……まだ……こうしてなきゃ……ダメ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0204102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「はふっ、んんっ、くぅ……ずっと……こうして勃起オチンポぉ……オマンコ\nでスリスリするだけなんてぇ……生殺しだよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0204103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「んぁぁ……はぁぁん……ほら、分かるでしょ？　もう、オマンコの割れ目ぇ\n……ぐちゅぐちゅになってるんだからぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0204104" ]},
		{"command":[ "SETIMAGE", "0", "still_00016602_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「まだ、入れちゃダメなの……？　んっ、もう、ずっと素股でズリズリしてる\nのにぃ……ちゃんと気持ちよくしてるでしょぉ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0204105" ]},
		{"command":[ "SETIMAGE", "0", "still_00016602_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「そうやって……私が悶々としてるトコを見るのが好きなんてぇ……結構、隊\n長さんもＳっぽいのかなぁ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0204106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「あんっ、そんなオチンポ震わせて返事しなくてもいいからぁ……それより、\nまだ……？　早くこのオチンポ、オマンコにハメさせてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0204107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「するっ、ちゃんとおねだりするからぁ……あぁんっ、お、お願いしますぅ…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0204108" ]},
		{"command":[ "SETIMAGE", "0", "still_00016602_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「私の……淫乱オマンコはぁ……さっきから、ずっと……オチンポが欲しくて\n疼いてますぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0204109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「どうか……隊長さんの太くてかたぁーい、ガチガチの勃起オチンポぉっ……\n私のスケベな穴にハメてっ……ズボズボ突き回して……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0204110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「アルマのことぉっ、ヒィヒィ泣かせてっ……いっぱいイカせてくださいぃっ\nっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0204111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「言ったよっ、ちゃんとおねだりしたからぁっ……あぁんっ、そう、そこっ、\nオチンポ……そのまま前にずぶってっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0204112" ]},
		{"command":[ "SETIMAGE", "0", "still_00016602_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「んっ、あぁっ、入る……んんぅっ……はひっ、あっ、あぁぁぁっ、入って…\n…来るぅぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0204113" ]},
		{"command":[ "SETIMAGE", "0", "still_00016602_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「んんんんんんっ！　くぅぅぅんっ……あぁぁぁ……ハマったぁ……あっふっ\n、隊長さんのオチンポ……みっちり届いてるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0204114" ]},
		{"command":[ "SETIMAGE", "0", "still_00016602_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「はぉぉっ……そうなの、んっ、これがずっと欲しかったの……オチンポ……\nあぁっ、太い……熱い……ビクビクしてるぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0204115" ]},
		{"command":[ "SETIMAGE", "0", "still_00016602_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「ふふぅ……やっとオマンコみっちり来たぁ……もぉ、たっぷり焦らしてくれ\nちゃってぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0204116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「これは、しっかりオチンポにお返しをしてあげないとねぇ……動かすよぉ…\n…んっ、はっ、あっ、んふんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0204117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「はぁぁ……硬いのっ、ごりごり……オマンコ肉に当たってるぅ……んっ、ヌ\nルヌルのヒダに、しっかり擦れて来てるよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0204118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「腰……本気で振るからねぇ……行くよぉ……はっ、うんっ、あっ、ふっ、ん\nんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0204119" ]},
		{"command":[ "SETIMAGE", "0", "still_00016602_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「あぁんっ……気持ちいい……じゅぽっ、じゅぽって……恥ずかしい音……ど\nんどん響いて来ちゃってるぅ……あっ、ひぃんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0204120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「ふっ、んんっ、かき混ぜてるぅ……んっ、あぁっ、チンポっ、オチンポっ…\n…んっ、しっかりシコシコするのぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0204121" ]},
		{"command":[ "SETIMAGE", "0", "still_00016602_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「んふっ、まーたオッパイガン見してるぅ……そだねぇ、ぷるんぷるんって揺\nれるから……どうしても見ちゃうよねぇ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0204122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「いいよぉ……触ってもぉ、下から遠慮なく……モミモミしてぇ……はっ、ふ\nっ、うんっ、んふっ、あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0204123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「あぁっ……そう、そこもいい感じぃ……んっ、乳首も……ぎゅって潰して…\n…あひんっ！　あぁんっ、痺れるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0204124" ]},
		{"command":[ "SETIMAGE", "0", "still_00016602_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「私も……負けてられないよねぇ……うんっ、ふっ、んくんっ……本気で隊長\nさんのオチンポ……蕩けさせちゃうからぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0204125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「腰を……んっ、突き出してぇ……ぐるぐるってぇ、回してぇ……あぁんっ、\n違うトコ当たってっ……今のっ、いいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0204126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「もっとしちゃお……んんっ、おふっ、あひっ、んっ、ねっ……これっ……す\nっごく……気持ちいいよねっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0204127" ]},
		{"command":[ "SETIMAGE", "0", "still_00016602_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「んふっ、隊長さんも動いちゃう？　いいよぉ……オチンポ……ズコズコピス\nトンさせてぇっ……もっとオマンコ蕩けさせてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0204128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「あっ、はぁぁんっ！　あぁっ、いいよぉっ、一番感じるとこぉっ、ちゃんと\n……いっぱいグリグリされてるぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0204129" ]},
		{"command":[ "SETIMAGE", "0", "still_00016602_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「はぁんっ、リズムっ……合わせてぇっ、一緒に……かき回すのっ、ふんっ、\nうんっ、ふぐっ、んぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0204130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「ほらぁっ、いい顔してるぅ……ふふっ、気持ちいいのに、やせ我慢しちゃっ\nてぇ……でも、オチンポの方が余裕なくなってるしぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0204131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「もう出したくなってるんでしょ？　バレてるよぉ……ドピュってしたいって\n、オマンコに教えてくれてるんだもん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0204132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「さあ、我慢しないで……このまま中に出しちゃおっか……勢い任せで、私を\n孕ませちゃうの♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0204133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「気持ちいいよぉ？　満タン魔力で満たされたオマンコに……いっぱい出すの\n……どうせ、もう限界なんだし……ね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0204134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「そう……一生懸命腰振ってぇ……欲望に身を任せてぇ……そのままぁ……あ\nっ、そうっ、ドピュってぇ……えいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0204135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「んふぁぁぁぁんっ！　出て来たっ、中出し来てるっ……！　あぁっ、チンポ\nザーメン入ってっ……あぁっ、オマンコイクぅぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0204136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016602_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「んんっ、すごい……活きのいいのが……とぷんって……んくぅ……気持ちい\nい……はぁぁ……私……ずっとイッてるぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0204137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「ふふ……まだ少し漏れてるね……待ってね、中途半端に残ってる分、吸い上\nげちゃうからぁ……んんっ！　ほら……出たぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0204138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「はふ……すごいオチンポよかったぁ……ふふ、隊長さんのエネルギー、チン\nポミルクからいっぱい貰っちゃった♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0204139" ]},
		{"command":[ "SETIMAGE", "0", "still_00016602_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「身体中に力が漲ってく感じ……んんっ……やっぱり、隊長さんが私のご主人\n様って……再認識しちゃったかな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0204140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「さて……それじゃ、このまま続き……しちゃお。まだまだ、オチンポは元気\nでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0204201" ]},
		{"command":[ "SETIMAGE", "0", "still_00016602_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「少し休みたい？　そんなつれないこと言わないでぇ……元気の出るおまじな\nいしてあげるからぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0204202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「そう、おまじない。きっと気に入ってくれると思うよぉ？　ここを……こう\nしてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0204203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「はーい、ずぷって……隊長さんのお尻の穴ぁ……ぐりぐりって指でほぐして\nあげてまぁーす♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0204204" ]},
		{"command":[ "SETIMAGE", "0", "still_00016602_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「あはっ、すごいすごい、どんどんオチンポ硬くなって来てる。さっきよりも\nっとギチギチに勃起しちゃってるじゃない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0204205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「ふふっ、どこがおまじないだって？　でもぉ、ちゃんとオチンポ元気になっ\nたでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0204206" ]},
		{"command":[ "SETIMAGE", "0", "still_00016602_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「もちろん、本番はこれからだから……覚悟してねぇ、隊長さん？　んっ、く\nふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0204207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「はぁっ、んっ、うんっ、おっ、んっ、おぉっ……くぅぅぅん……オマンコ…\n…グチョグチョ……はしたない音しちゃってるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0204208" ]},
		{"command":[ "SETIMAGE", "0", "still_00016602_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「ふんっ、んぐっ、んんっ！　そぉっ……奥のＧスポットぉ……亀頭でぐりっ\nて……んっ、すり潰してぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0204209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「あぁんっ、いい、感じぃ……ほら……見えるぅ……？　淫紋が……キラキラ\nしてるでしょぉ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0204210" ]},
		{"command":[ "SETIMAGE", "0", "still_00016602_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「隊長さんのこと……ご主人様って認めてるからぁ……こんな風になっちゃう\nの……あぁ……オマンコ幸せになっちゃうのぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0204211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「だからぁ……隊長さんにも、もっと感じてほしいからぁ……またお尻にぃ…\n…えいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0204212" ]},
		{"command":[ "SETIMAGE", "0", "still_00016602_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「ふふっ、どぉ？　オマンコでガッチリオチンポロックされたまま、おケツの\n穴っ……ほじられちゃってる気分は？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0204213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「だらしない顔しちゃってぇ……んふふっ、ご主人様だけど……そーいう顔見\nてるとゾクゾクしちゃうっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0204214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「んっ、はっ、ひんっ、またオチンポ上がって来てるでしょ……私も……ずっ\nとオマンコジンジンしっぱなしなのぉっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0204215" ]},
		{"command":[ "SETIMAGE", "0", "still_00016602_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「また、一緒にイッたら……すっごい気持ちいいよぉ？　だからぁ……ぎゅっ\nて締め付けちゃうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0204216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「おふっ、んっ、おぉっ！　そうっ、頑張ってぇっ……オチンポっ、ラストス\nパートでっ、いっぱい突いてぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0204217" ]},
		{"command":[ "SETIMAGE", "0", "still_00016602_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
