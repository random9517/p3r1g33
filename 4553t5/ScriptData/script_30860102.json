		{"command":[ "PLAYVOICE", "086_0104101" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「っ……はぁっ……はぁ、はぁ……。み、見て……？　貴方のために、全て脱\nいだわ……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0104102" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「もう、我慢できません。今夜こそ……貴方はこの私と、エアルミン・ウェン\nドーウルと結ばれるの。二度と離れられないくらいに……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0104103" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「ふふ……ケダモノの交尾を模して、このように卑猥な格好をとらせたのです\n。今宵は、ハイエルフであることすら忘れて……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0104104" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「貴方だけの愛しい獣に成り下がってあげましょう。さあ、いらっしゃい……\n。私の高貴な肉体を、処女を、芸術のごとき肌をあげます」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0104105" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「せいぜい、がっついて……はしゃいで凌辱するといいわ。ねえ……欲しいの\nでしょう？　ニンゲンの女ではとても勝ち目のない……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0104106" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「ハイエルフの美しい花弁……。たっぷりと蜜を含んだこの花びらを、散らす\n栄誉を与えます……来なさい」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0104107" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「あっ……！　ああああっ……そうっ……そうですっ……！　この野蛮な挿入\n……ぅう♪　それでこそ、私の認めたニンゲンのありか、た……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00008601_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0104108" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「あ……はぁああっ♪　凄い……凄い……っ！　処女だと、初めてだと告げて\nあげたのに……一切気にせず、一突きで奥まで……あっ！　あああっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0104109" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「貫いてっ、えぐり倒してくるぅうっ♪　なんて情け容赦のない馬鹿ペニスな\nのっ……あっ！　そうね、これが、これが欲しかったのですよねっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0104110" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「私の……狭くてキツい蜜壺を……んぁああ♪　ニンゲンペニスでこじあけ、\nて……その獣欲のまま、に……あーっ♪　劣情にかりたて、られて♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0104111" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「ズッポズッポと出し入れしたくてたまらなかったのですよねっ！　いいので\nすよ……あっ！　好きに、好きにすればいいのですっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0104112" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「ハイエルフのピンク色のおまんこを……ニンゲンペニスで掻き回して……！\n　はぁっ、あっぁっ！　アッ！　あっ、あっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0104113" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「す、ご……いっ、すごい……！　んぁあああ♪　入っちゃいけないくらい奥\nにまでずっぷり入っていますぅう♪　なんて下品な太さなのぉおお♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0104114" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「ふふっ……うふふふっ……♪　こんなに禍々しいペニスなんて……あっ！　\nわ、私くらいしか受け入れて、愛してくれる者はいませんよ……っ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0104115" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「ですから、私にだけ入れておきなさい……私っ♪　はっ♪　私はいつでも受\nけ入れてあげますか……らぁああっ♪　あっあっあっ♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0104116" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「あぁっ！？　は、ぁ……っ、はぁ、ああ……！　いやぁ……♪　急に動かな\nいで……ぇ♪　いいえ、嘘です……動いて、もっと動いてっ♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0104117" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「ハイエルフとニンゲンの子を産んであげますっ♪　ですからぁ……突きまく\nりなさいっ……ずっと、ずっと待っていたのですからっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0104118" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「っ……ひぁああ♪　あっあぁ♪　あっおっ♪　おっおっ♪　おっおふっ……\n♪　ああ♪　あぁ♪　おっおぉっおぉ♪」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00008601_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0104119" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「犬のような体勢で……ぇえ♪　ニンゲンに犯されるのがこんなにも……こん\nなにも気持ちいいなんて……どうかしてるっ、どうかしてるぅ♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0104120" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「ご先祖様に、一族に二度と顔向け出来ないぃ……♪　なのに、ああああああ\nー……やめたく、ないですっ、もっとしたい、したいぃいっ♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0104121" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「あっひっあひぃっ♪　どんどんペニス、力強くなってっ……ああっ、私の処\n女おまんこを自分の形にしようとしてきます、んぁああ♪　野蛮、野蛮ん♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0104122" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「好き、です……この野蛮なペニスのことが……！　ああ、ああ、ああ……お\n許しください、森よ、世界よ……私はもう駄目……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0104123" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「たった一匹のニンゲンのオスに、自ら喜んで股を広げ……好きなように犯し\nてもらうのがたまらなく快感なのです、もう、もう戻れませんんっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0104124" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「んっああっ、ああっああっ！　ペニスっ、ペニス、ペニス……！　あーっ…\n…好きっ、好き、好き……おいしいのっ、ペニスがぁああ……♪」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00008601_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0104125" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「少し痛い、のに……無理やり入れられているのにぃ♪　容赦なく蜜壺を犯さ\nれるのが、んっ、んぃいいい……大好きなのぉ♪　あっ、あああっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0104126" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「あぁ……あぁっあぁ……♪　え……？　だらしない顔、して……自分からお\n尻を揺らして、る……？　い、いけませんか……？　んんんっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0104127" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「だって、もっと欲しいのですっ……粘膜と粘膜がとろけあって！　一つにな\nってしまうまでしたいの……続けたいの……んあああっもっと……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0104128" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「っ……んんんんっ……！　角度が少し変わる、だけで……重い快楽がおまん\nこの中……下腹部をかけめぐって……全身が痺れます……っ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0104129" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「私は今、凌辱されている……恥辱を与えられている……そう想像しながら尻\nをゆすること、で……それがどんどん大きく、膨らんでいくのです……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0104130" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「ああっ……ニンゲンとはいえ、貴方っ……貴方のことは好き、なのに……脳\nが蹂躙を望んでしまう……合意で交尾をしていながら……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0104131" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「はぁううっ！？　ああっ！？　これが無理やりされていること、だったら…\n…と考えるだけで……んあああっ、イくっ！　イくぅっ、イクぅうっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00008601_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0104132" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「んんんんーっ……！！　ッはぁああっ……ああ……い、今……軽く達してし\nまいました……わ、私……おかしくなってしまいました……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0104133" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「あまりにもペニスが気持ち、よくて……んん、脳みそが、ぐちゃぐちゃにな\nって……はぁうう♪　貴方も、貴方もそうですかっ……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0104134" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「貴方も同じくらい……あぁ、私くらい感じているのなら……一緒に、一緒に\nイッてください……イッて……体液を射出して……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0104135" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「強引に種付けをして私をもう一度イかせて……！　ッ……ええ、ええ、いい\nからっ！　中に出していいからぁっ、出して、出して出してぇ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0104136" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「ッあああああ……っ！　やっああああっ……！　本当に、本当に体液を出し\nたのねっ……なんてだらしのない、はしたないペニスなのぉおっ……」", "NORMAL" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00008601_02_09" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0104137" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「嬉しいっ、嬉しいうれしいっ……！　堪え性の無いニンゲンペニスに種付け\nされてるぅ……♪　避妊無しでドプドプ出されてるぅうう♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0104138" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「おっ♪　おぉおっ♪　その事実だけでイキま……す♪　こんなの、イかない\nハイエルフがいますかっ♪　無慈悲な種付けで、蹂躙でイクぅううっ♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0104139" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「あーっ♪　あっあっあっ♪　ニンゲンの、ニンゲンの子を孕まされてイクの\nぉおお♪　エアルミンは、私はハイエルフ失格ですううう♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0104140" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「ニンゲンにっ、犯されるのが好きなのですっ！　一番恥ずかしいのは私っ…\n…私ぃいい♪　ああああ、イクイクっ！　イキっぱなしですぅうっ♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0104201" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「はーーー……♪　はーーーーー♪　はぁあああ……ああ……♪　すっごい…\n…すっごいぃいい……♪」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00008601_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0104202" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「中出しの余韻だけで、何度でも達することが出来そうぅ……♪　よ、よくや\nりました。貴方は立派な私の……って、あんっ！？　や、やめなさいっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0104203" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「あああっ！　ま、まだ私の胸を揉んでいない……？　乳首をいじりながらピ\nストンすれば……も、もっとヤバい快感に溺れられる……ですって？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0104204" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「あ……あ……あ……！　ニンゲンとは、なんと罪深い生き物なのでしょう…\n…！　たっぷりとハイエルフおまんこに種付けしておきながら！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0104205" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「おまんこだけでは飽き足らず……む、胸を……乳首までを強欲な性で汚そう\nというのね……。そんなこと……そんなこと……。……ごくっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0104206" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「ふ、普段は絶対に許されませんが……きょ、今日は特別に許可します。私の\n初めての夜なのですから……少々乱れてしまってもかまわないでしょう」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00008601_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0104207" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「さ……。さ、触りなさい……。私の胸を……。貴方の両手からはみだし、こ\nぼれる豊満な乳房を……れ、劣情のままに、嬲りなさい……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0104208" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「んっ……！　は、ぁ……ああああ……なんといやらしい触り方でしょう……\n。そっと乳房を撫でまわし……んんんん……あぁあんっ♪」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00008601_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0104209" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「力いっぱい鷲掴みに、して……っ！　んぃいいいっ……！　ぎゅむぎゅむと\n揉みながら……！　ァアアッ！？　ペニスを再び突き立てて、くる……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0104210" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「あっ……！　前から後ろからっ……！　胸とおまんこを同時に攻めたてるな\nんて……んぃいい♪　ひぐぅうっ！　さ、さすがですね、淫猥な……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0104211" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「あっ……あっあっ！　あっんんんっ、んぐぅっ♪　んぐぅっ♪　何……なん\nです……？　おまんこが締まって気持ちいい？　い、言わないでください」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0104212" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「言わずともこちらにもわかり、ます……あああっ！　ペニスに勝手にヒダヒ\nダが絡みついて……じ、自制が効かない……体液をねだってしまうぅ♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0104213" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「んぁっ♪　胸、胸をこれでもかといじり倒しながら……んひぃいいっ♪　そ\nこっ、そこですっ♪　ち、くび……ちくびをグニグニ、グニグニぃっ♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0104214" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「グリグリしながら……あぁ♪　突いて、突いて突いてください……！　あっ\n♪　おぉっ、おぉほ♪　そこです、そこ、そこ……そこ、ああああっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "086_0104215" ]},
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「ッ……！！　っ～……！！　あひっ！　あひぃっ、はひぃっ、あひっ……！\n　ああっ、蹂躙っ、蹂躙されています、凌辱されて……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00008601_02_08" ]},
		{"command":[ "WAITINPUT" ]},
