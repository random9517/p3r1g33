{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001401_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "PLAYVOICE", "014_0104101" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「あぁ……こんな格好でしちゃうんですね……恥ずかしいです……あんっ、あ\nぁんっ……あぁっ、おっぱい、そんなに揉まないでぇ……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "014_0104102" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「んあぁぁっ……アソコにオチンチンが当たってます……あんっ、あぁんっ、\nあんっ、そんなに擦りつけちゃダメですぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "014_0104103" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「あっあっあっ、オチンチンの出っ張りに、クリトリスが引っかかって……あ\nひぃんっ！　いやっ、エッチな音を立てないでください……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "014_0104104" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「だって、しょうがないんです……あんっあぁんっ、夢にまで見た、あなたの\nオチンチンを挿れてもらえると思ったら、勝手に濡れてきちゃうんです」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "014_0104105" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「あなたのことを考えると、すぐに身体が熱くなってしまって……ふああぁん\nっ、勝手に手がエッチなところに伸びちゃうんです……あぁぁんっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "014_0104106" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「あなたにされたことを思い出しながら、ひとりでなんども、なんども……あ\nぁぁっ、あぁっ、我慢できなかったんです」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "014_0104107" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「全部、あなたのせいですよ……あなたが私をイヤらしい身体に開発しちゃう\nから……あぁんっ、エッチなことが癖になっちゃったんです」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "014_0104108" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「だから、お願いです……あっあっあっ、もう意地悪しないでぇ……んああぁ\nぁっ、あぁっ、エッチなこと、してくださいっ…！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "014_0104109" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「うぅ、ひどいです……あぁんっ、オチンチンでオマンコを擦って焦らしなが\nら……んふぅぅっ、そんなイヤらしいことを言わせるなんてぇ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "014_0104110" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「あぁ……どうか、スケベに調教された私のイヤらしいオマンコに、あなたの\nオチンポを奥までズッポリ、ハメハメしてください……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "014_0104111" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「……あっ、あぁっ……オチンポがオマンコの入り口に当たって……あっあっ\nあっ……あぁっ、入ってくるっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "014_0104112" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「んぐぅううううっ……！　ま、待ってぇっ……んぉっあっあっあっ……！　\nカリが太すぎるぅっ、オマンコの入り口が広がって……んふぅぅ～～っ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001401_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "014_0104113" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「はひっ、あひっ、オチンポおっきすぎますっ、んふううううっ、太くて、長\nくてぇっ、あっあっあっ、オマンコぎちぎちになっちゃってます……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "014_0104114" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「んはあぁぁぁっ、オマンコがオチンポの形に押し広げられて、あふぅぅぅ～\nんっ、戻らなくなっちゃうぅっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "014_0104115" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ひぎゅうっ！？　お、オチンポが、奥に当たってぇっ……子宮の入り口を押\nし上げてるぅっ、ひいぃぃんっ、もう入りませんからぁ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "014_0104116" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「あふぅぅぅっ……オチンポすごすぎますぅっ……あっあっあっ、刺激が強す\nぎるので、もう少しだけこのままで……あぉおおんっ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "014_0104117" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ひぁああああんっ！　ま、まってぇっ！　オチンポ、動かないでぇっ、おっ\nきすぎるのぉっ……！　あひぃぃいんっ……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001401_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "014_0104118" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「あひぃぃ～～っ！　カリが太すぎるぅっ、ひぁああああんっ、オマンコごり\nごり、えぐれちゃうぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "014_0104119" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「あぁぁぁんっ、あぁんっ……、おっぱいもそんなにもみもみされたらぁ……\nふあぁぁぁんっ、気持ちよくなっちゃいますぅ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "014_0104120" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「んあぁぁぁっ、乳首もイジっちゃだめぇっ、ひぁぁっ、あぁぁんっ！　ビン\nカンだから、こねこねされたら、おかしくなっちゃうっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "014_0104121" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「あひんっ、あぁんっ！　お尻にあなたの腰がぱんぱんぶつかって、ひぃんっ\n！　激しすぎるっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "014_0104122" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「子宮がオチンポにどちゅどちゅ突き上げられてぇ、あっあっあっ、ぉひぃん\nっ！　頭の中、真っ白になっちゃうよぉっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "014_0104123" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「もうダメぇっ！　気持ちよすぎますぅっ！　んひぃぃぃっ！　セックスのこ\nとしか考えられなくなっちゃうっ！　おかしなスイッチ入っちゃうぅっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "014_0104124" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「あぁっあああああっ！　しゅごいっ！　勃起オチンポしゅごいですっ！　オ\nマンコハメハメ気持ちいいのぉ～～～っ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "014_0104125" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「オマンコほじほじ、ほじくられてぇっ！　んふぅぅんっ、ぉふうっ、ぉおお\nおんっ！　頭、バカになっちゃいましたぁっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "014_0104126" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「あひっあひっあひっ！　もっとしてぇっ！　おっきなオチンポで、オマンコ\nが戻らなくなるくらい、激しくしてくださいぃぃ～～～！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001401_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "014_0104127" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「私のエッチなオマンコに、オチンポの形を教えてぇっ！　あぁあああああん\nっ！　あなたのオチンポ専用マンコにしてぇぃっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "014_0104128" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「あひぃぃぃんっ！　そうですぅっ！　私はオチンポで激しく責められると感\nじちゃうっ、イヤらしいマゾマンコ女なんですぅっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001401_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "014_0104129" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「いつも生意気なこと言ってごめんなさいぃ～っ！　あはぁああああんっ！　\nあなたのおっきなオチンポで、私のイヤらしいオマンコを躾けてぇっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "014_0104130" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「あぁぁんっ、あぉぉぉんっ！　奥すごいぃぃっ！　オチンポ、ぐりぐりっ、\n子宮いっぱい擦れてるぅっ、気持ちいぃぃ～～～っ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "014_0104131" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「はしたないエロマンコをオチンポで調教してくださいぃっ！　オマンコもっ\nと開発してぇっ！　あなたのオチンポでイヤらしくしてぇっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "014_0104132" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「あぁぁんっ、オチンポまたおっきくなってるぅっ！　カリがパンパンに膨ら\nんで、オマンコずりずり擦られちゃうぅっ！」", "NORMAL" ]},

		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "014_0104133" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「射精してくださいぃっ！　オマンコの奥にどろどろのエッチなザーメン、い\nっぱい注いで欲しいですぅっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "014_0104134" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「オマンコの中をあなたの精液でパンパンにしてぇっ！　子宮の中までびゅう\nびゅう射精して、私のオマンコを妊娠させてぇ～～～っ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "014_0104135" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「私もイきましゅっ！　イっちゃいましゅっ！　あぉおおおおおおんっ！　イ\nくぅっ、イくイくイぐっ、イっぐうううううううっ！！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "014_0104136" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ぃひぃいっ！？　あっあひっ！　出てるっ、オマンコの奥に熱い精液が、び\nゅうっ、びゅうってぇ、んひぃっ！　子宮にもいっぱい、あひぃんっ！」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001401_02_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "014_0104137" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「あっあっあっあっ、またイぐっ、イぐっ……子宮に精液かけられて、イっち\nゃうっ……あぁぁ～～～っ、イぐイぐイぐっ、イぐぅぅ～～～っ……！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "014_0104138" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「……はぁっ、はぁっ、はぁっ……しゅごい……んあぁぁっ、あひぃっ……男\nの人のオチンポ、しゅごいですぅ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001401_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "014_0104139" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「あぁっ、私……もうあなたとのエッチなしには、生きていけない身体にされ\nちゃいましたぁ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "014_0104140" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「あなたについていきます……私はあなたのために生きます……だから、お願\nい……もっと、オマンコしてぇっ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001401_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}