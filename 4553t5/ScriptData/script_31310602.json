	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ふふっ……こんな格好させて、私を恥ずかしがらせようなんて……趣味が悪\nいですね。ええ、まあ恥ずかしいですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0604101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「んっ、んんっ……でも、それより楽しみ、でもありますね……あなたが、ど\nう責めてくるのか……するんでしょう？　セックス」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0604102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あぁ、そんなにチンポを大きくして……動けない私のアソコにハメてしまう\nんですね？　ほら……どうしたんですか、ヤらないんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0604103" ]},
		{"command":[ "SETIMAGE", "0", "still_00013106_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「んあっ……熱くなってる……？　あなたのだって……んぅ、擦り合わせて…\n…焦らして……それでいいんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0604104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「早く、挿入れたくて堪らないって……顔、してますよ……ワレメにそって、\nチンポ擦りつけてるだけで、満足ですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0604105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あっ、あんっ……やる気になりました？　いいですよ、私はもうとっくに準\n備……できてますから……ほら、アソコ濡れてるでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0604106" ]},
		{"command":[ "SETIMAGE", "0", "still_00013106_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「んんっ……！　ひぃううっ……あっあっ、ズブズブ挿入って……くるっ……\nあっ……あぁはぁぁぁぁぁ～～～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0604107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「はっあっ……んふぅっ！　相変わらず……大きなチンポ、ですね……オマン\nコが広がっちゃいます……んぅふうっ……はぁはぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0604108" ]},
		{"command":[ "SETIMAGE", "0", "still_00013106_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「んあっ、あっ……お、奥まで……届いてる……ンンっ……そ、そうですね…\n…この体勢だと、余計に圧迫感が……あります……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0604109" ]},
		{"command":[ "SETIMAGE", "0", "still_00013106_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「はふぅ……気持ちいい、か……って、野暮なこと聞きますね……これだけオ\nマンコ濡らして、悦んでるんです……気持ちいいに決まってます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0604110" ]},
		{"command":[ "SETIMAGE", "0", "still_00013106_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あなたの方こそ……私のオマンコはどうですか？　ハメて……欲望のまま犯\nしてヤリたくなる……オマンコ、ですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0604111" ]},
		{"command":[ "SETIMAGE", "0", "still_00013106_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「んっ、んんっ……名器、ですか……嬉しい、です……じゃあ、その名器……\n好きなだけ味わってください……あっ、あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0604112" ]},
		{"command":[ "SETIMAGE", "0", "still_00013106_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「なんですか、そんな……んっ……ワザとらしく、ゆっくり……動かして……\nあ、ふぅ……焦れったい、ですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0604113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あ、あぁ……カリが、引っかかって……中と擦れてるの、わかります……ン\nンっ、あなたも感じてるんじゃないですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0604114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「出っ張ってるとこだけじゃなくて、チンポ全体が……オマンコと、擦れて…\n…包まれてるって、感覚……そうですよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0604115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あはぁ、あっ……あまり激しくすると、射精しちゃいますか？　ふふっ、そ\nれなら仕方ないですよね……あんっ、んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0604116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「わ、私のオマンコ……じっくり楽しんでくださいね……あっ、あふぅっ……\nええ、私は激しくされても、構いませんよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0604117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ひっ、はひぃっ！　んんっ！　い、いきなり……ですね……はっ、はあっ…\n…！　んっ、んっ、んっ……はぁあんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0604118" ]},
		{"command":[ "SETIMAGE", "0", "still_00013106_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「はんっ、あっあんっ……！　お、音……すごい……やっ、あぁ……グチュグ\nチュいってる……ああ、あぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0604119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ンっ、はっ……！　子宮、に……届いてるっ……奥ぅ、チンポでノックされ\nて……はっ、あんっ……は、激しいぃぃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0604120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「んっああっ！　はっ、はぁあっ！　しきゅ、うっ……揺れてるっ……あぁあ\nっ！　そんな……飛ばして、大丈夫ですか……んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0604121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「チンポ、ガチガチになってるのに……こんな激しく、ピストンしてぇ……は\nっ、あんっ……すぐ、出ちゃいますよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0604122" ]},
		{"command":[ "SETIMAGE", "0", "still_00013106_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あっ、あんっ……私は、もう……イキそう、ですよ……あふうっ……だって\n、チンポ……よすぎてぇ……あん、あぁんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0604123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「中に……ですか？　はい、欲しいです……んっ、ザーメン……欲しいっ……\nあなたの濃くて、熱々の……ザーメン欲しいですっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0604124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「オマンコに、注いでくださいっ……！　ザーメン……ドクドクって、いっぱ\nい……いっぱいぃぃ……あっ、はぁぁぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0604125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「孕んでも、いい……！　妊娠しても、いいです……あなたの子供なら、いく\nらでも……んんっ、孕み、ますぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0604126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「はぁ、はひっ、んっ……チンポ、すごいっ……孕ませたがってるっ……！　\nオマンコ、孕ませようとしてぇ……暴れまわってるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0604127" ]},
		{"command":[ "SETIMAGE", "0", "still_00013106_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ぜ、絶対に……このまま出されたら、絶対に妊娠、しちゃうっ……くっ、ひ\nああぁ！　イ、イク……イッちゃうっ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0604128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ああっ、あっああっ！　アクメ、くるっ……中出しアクメしちゃうっ……ん\nひぃっ！　ひぐっ！　はひっ、ひぃぃぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0604129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「イクッ！　イクっ、イ、イクッ……ああぁあッ！！　あッ、あっあっ……イ\n、イクう、イクイクイクううう～～～！！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0604130" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00013106_02_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ひぃいいっ！　はっはひっ、んっ……んはぁぁぁぁっ！　出てるっ……ザー\nメン……オマンコに流れ込んできてるぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0604131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「くっ、はっあぁぁ……！　はひぃっ……ひぃんっ！　あっ、ふうっ……まだ\n、出てるッ……んぅ……射精、すごいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0604132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「子宮、注ぎ込まれて……んんぅ……孕む……絶対に……妊娠しちゃう……ん\nぅ……はぁ……あっ、はぁぁぁ……は、あぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0604133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「んっ……ンンっ……あ、あ……あは……はぁん……ザーメンが、ドクドクっ\nて……いいながら、子宮……溺れちゃう……んんッ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0604134" ]},
		{"command":[ "SETIMAGE", "0", "still_00013106_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「はぁ……はーっ、はぁ……あんっ……いっぱい、出て……んっ……ちんぽ…\n…やっと、落ち着きましたね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0604135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「……はい……なんですか……？　私、雰囲気変わりました……？　そう言わ\nれても、よくわからないですけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0604136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「エッチな気分になると、ちょっと……変になっちゃう……けど……んっ、は\nぁあ……まって、ください……動かさないで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0604137" ]},
		{"command":[ "SETIMAGE", "0", "still_00013106_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ちんぽ……大きくなったまま、だから……くひっ……あっ、あぁ……抜いて\n、欲しい、わけじゃない……ですけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0604138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「は、ああぁ……い、言わなきゃ、ダメですか……？　んぅんっ……もっと、\nしたいです……あなたと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0604139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「で、ですから……セックス……このまま、続けてください……あなたのちん\nぽで……気持ちよく、してください……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0604140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あっ、あんっ……んんっ……な、なか、動いてる……ちんぽ……ああっ……\nくひっ、ひっあっ……あふぅう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0604201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「おまんこ、イッたばかりで……敏感だから、ゆっくり……んあっ！　ゆ、ゆ\nっくり……お願い、しますぅ……んぅンっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0604202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「だって、感じすぎてっ……あっ、あはぁ……あんっ！　あんっ！　くひっ、\nひぃいっ……あぁ、ちんぽ……すご、いぃいっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0604203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「んんッ！　さっき中出しされたザーメンが……かき出されてぇ、あふっ……\nた、垂れちゃう……んぅんっ、おまんこ……溢れちゃう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0604204" ]},
		{"command":[ "SETIMAGE", "0", "still_00013106_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あぁあっ、ザーメンまみれのおまんこ……かきまわされて、るっ……イヤら\nしい、音が……聞こえてきて……はぁ、あぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0604205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「は、恥ずかしい……ンぅっ！　恥ずかしい、ですよぉ……こんなえっちな、\n音……あっ、あっ……あんっ……いやぁぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0604206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「絶対、ワザとやってますよね？　あぁっ……まって、くださいっ……んんっ\n！　そんな強く……ひっ、ひぐっ！　んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0604207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ンっ、あっ！　あふぅっ！　お、おくっ……キてるっ……ちんぽ……奥まで\nぇ……届いてぇ、あぁぁ……あんっ、あはぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0604208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あぁあっ、はっ、んうっ……！　気持ちいい、です……あなたは、どうです\nか……？　感じて、くれてますか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0604209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「んんぅっ……そうですね、ちんぽ……大きくなってて……んあっ……硬くっ\nて……ゴリゴリ、擦れてまぅす……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0604210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「興奮、してくれてるんですね……嬉しい、です……あっ、あんっ……ちんぽ\n、んぅんっ……どんどん、熱く……う、ううっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0604211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ちんぽぉ……はぁ、はっ、あっ……おまんこ、いっぱいになってて……あん\nっ、あぁあっ！　す、ごぃ……イイっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0604212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「はぁあっ！　ま、まって……くださいっ……！　このままじゃ、私だけ……\nイク……またイッちゃう……はぁ、うぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0604213" ]},
		{"command":[ "SETIMAGE", "0", "still_00013106_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ひぃいっ、ひぃんっ！　ちんぽ、ちんぽぉ……！　あぁんっ……！　おっ、\nおくぅぅっ……！　ちんぽぉっ！　おっ、おおっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0604214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あなた、もっ……イッて、い、いいっ……ひぃんっ！　一緒に……イッて、\nお願い、ですからぁ……あっ、あんっ！　あっはぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0604215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「欲しい、ザーメン欲しいですっ……あなたの、いっぱい……欲しいっ……あ\nぁんっ！　ひっ、ひあっ……ああッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0604216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「イ、イクっ！　イクうっ……んぅっ、おまんこ……とろけちゃうっ！　あっ\n、はぁぁぁぁ！　はっ、はぁぁぁんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0604217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「中でも、いいっ！　どっちでもいいですから……出してっ！　熱いの……ザ\nーメン、いっぱい出してぇえぇッ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0604218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あっ、あっあっ……！　ちんぽ、きてっ……！　ちんぽっ……ひぃいいっ、\nちんぽっ、ちんぽっ……すごいっ、ちんぽすごいぃっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0604219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ひぃいいいいっ！　イクぅっ！　イ、イクイクっ！　イクッ……イッ、イク\nイクうううぅぅぅぅぅ～～～～～っ！！！！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0604220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「んっあぁぁぁぁっ！　なかっ……中で出てるッ！　ひっ、ひぃいっ……はぁ\nぁっ……あっ、んはぁぁぁ～～～ッ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0604301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00013106_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「で、出てるっ……奥で、ザーメン……いっぱい……んんっ！　いっぱい出て\nるぅぅ……はぁ、ああっ……あっあはっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0604302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「はあっ、は、孕むぅ……んぅっ、こんなに……しゃせぇ……されたらぁ……\n絶対、孕んじゃうっ……赤ちゃん、できちゃうぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0604303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「んっひっ！　んひっ……ちんぽ、が……私を妊娠させようと、してるっ……\nンぁっ、あぁあっ……ドクドクいってる……んはあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0604304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あ、あぁっ……今さっき、あれだけ出したのに……んんっ、しゃせえ、した\nのにぃ……はぁ、はぁ……まだ、出てるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0604305" ]},
		{"command":[ "SETIMAGE", "0", "still_00013106_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「はっあっ、あふぅ……ンぅっ……はぁ～……ああんっ……や、やっと……終\nわりましたか……？　んんっ……あぁ、ふうっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0604306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「そう、ですね……思いっきりイッちゃいました……あなたも、すごく興奮し\nたみたいですけど……こんなに射精して……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0604307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「中に出してって、言いましたけど……ちょっと出しすぎじゃないですか？　\n本当に妊娠したらどうするつもりなんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0604308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「せ、責任……取ってくれるんですか？　責任取って……私を、その……お、\nお嫁さんに……いえ、なんでもないです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0604309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「もういいです！　そんなことより……この体勢、大変なんですから……早く\n起こしてください……だから、き、気のせいです……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0604310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、あひっ！　ぬけ、ちゃうっ……！　ちんぽ……ンンっ！　ちん\nぽ、抜けちゃうぅっ！　あっ、あぁぁぁっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0604401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00013106_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ひぃいいいいっ！　はひっ、ひぃいっ！　くっ、ひぃんっ……あっ、あふっ\n、かかって……ンンっ！　ザーメンかかっちゃうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0604402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ひゃっ！　あんっ、ああっ！　あふっ、ん、んぶっ……か、顔に……ンうっ\n……ザーメン浴びながら、イクぅぅぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0604403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「はぁあんっ、あっ……あひぃいっ……あぁ、すごい……さっき、あれだけ中\nに出したのに……まだ、こんなにぃ……は、あぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0604404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あ、ふぅ……身体中が精液で、ドロドロになってるぅ……こ、こんな……あ\nぁ、匂いが……ザーメンの匂い……んぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0604405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁあ……な、中に欲しかった……のに……あなたが、したかった\nのなら……いいですけど……はふう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0604406" ]},
		{"command":[ "SETIMAGE", "0", "still_00013106_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「……妊娠？　もうたっぷり中に出してるんですから、今さら気にしてどうす\nるんですか……もう……孕んでますよ、きっと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0604407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「そもそも、おまんこの中も……身体もザーメンまみれで、すっかりマーキン\nグされちゃいましたし……ンぅっ……あなたのものだって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0604408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「これだけ、射精したんですから……満足、してくれましたよね……？　ふぅ\n……私は、まだふわふわしてます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0604409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あなたが悦んでくれたなら、私も嬉しい……です……またしたいですか？　\nええ、私も、また抱いて欲しいです……ふふっ」", "NORMAL" ]},
