{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0176" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "アナザー・セレーナと、時間帝国の兵士たちに挑んだＧ・ルナリアムの面々だ\nったが……。", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「くそっ……！　こいつ、やっぱり私のアナザーだ！　ムッチャクチャ強ぇぞ\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010114410001" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「っていうか、セレーナちゃんより強いんじゃなーい！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010114410001" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「そんなヤツと比べるとは、オレをなめてるのか？　そっちがその気なら――\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080114410001" ]},
		{"command":[ "SETCHARA", "0", "char_00000408_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「おっとっと！　はーい、セレーナくん――っていうか、ボクのお友だちの方\nのセレーナくんは、そこまでー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010114410001" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「なぜだ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080114410002" ]},
		{"command":[ "SETCHARA", "0", "char_00000408_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「今日はただの顔見せだし、キミもボクも他に仕事があるでしょ？　\nそれになにより、これ以上はただの弱いものイジメだからねー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010114410002" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「ちっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080114410003" ]},
		{"command":[ "SETCHARA", "0", "char_00000408_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「なにが弱い者いじめだ！　私たちはまだ、負けてなどいないっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114410001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「あー、はいはい。そういうのいいから。今日は他にも回らなきゃいけない\nところがあってね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010114410003" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ジェスタはそう言うと、目の前にワームホールを開く。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「そういうわけで、本日のところはここまで。次の回までごきげんよう！　\n歯、磨いてね！　お風呂入ってね！　それじゃ、また～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010114410004" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「次は、完全に叩き潰す！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080114410004" ]},
		{"command":[ "SETCHARA", "0", "char_00000408_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そして、ジェスタとアナザー・セレーナはワームホールの中へと消えていった\n……。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「待て！　貴様ら、さんざん煽っておいて逃げる気か！　待てぇーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114410002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ルナテミス！　あいつらは放っておけ！　せっかく先頭車両まで来たんだ。\nひとまず列車を止めたほうがいい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090114410001" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「そうね～。もう、襲来者（インベーダー）ちゃんたちもいないみたいだし～\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010114410002" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「よし！　そうしよう。みんな！　運転席に行くぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114410003" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「もう入ろうとしてるよ！　だけど……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_020114410001" ]},
		{"command":[ "SETCHARA", "0", "char_00001302_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「だけど？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114410004" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「入れないんだよー！　なんか、魔法陣みたいなので封印されてるーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_020114410002" ]},
		{"command":[ "SETCHARA", "0", "char_00001302_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「魔法陣だぁ！？　あああっ！　ホントだぁ！　誰がこんなことをー！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114410005" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「あれ！？　なんかこの模様、見たことがあるな……オボロが、よく部屋に\n閉じこもるときに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010114410002" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「あ！　そうだよ！　間違いない！　これ、オボロの術じゃないか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010114410003" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「オボロの！？　じゃあ、運転席に入れないようにしたのはオボロだって言う\nのか！？　おい、オボロ！　いったいどういう――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114410006" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「そういえば、オボロはどこ？　さっきから、オボロを見ていないような……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010114410001" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「やぁあ～ん！　そうだった！　オボロちゃんいないじゃないの！　どこ行っ\nちゃったのよぉ～～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010114410003" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「なにぃっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114410007" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「オボロ……！　あいつまさか……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010114410001" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「どうしたエファ！　なにか心当たりでもあるのか！？　オボロは、どうして\n急にいなくなった！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114410008" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「っ！　まずいぞルナテミス！　オボロのことより、前を見てみろ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090114410002" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「前って……？　あ！　あああああああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114410009" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「またまた嫌ぁああああ～～～ん！　おっきな宇宙船ちゃんが、前の方にいっ\nぱいいるぅ～～～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010114410004" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あれは、時間帝国の宇宙艦隊……！　このままじゃ、列車はあの砲列の中に\n突っ込むことになるぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090114410003" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「って、それは……つまり？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114410010" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「絶好の的、ってことだよ～！　とにかくなんとかして、この列車を止めない\nとーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_020114410003" ]},
		{"command":[ "SETCHARA", "0", "char_00001302_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}