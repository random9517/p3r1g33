		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「……アマルガメイト、ブリキ２。轟琴葉金、参上いたしました。どうなさい\nました、火急の用でもございましたか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_0103101" ]},
		{"command":[ "SETCHARA", "0", "char_00011701_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「この身体……。変身している間は、鈴の体力も使用しておりますので、出来\nれば早く眠りにつかせてやりたいのですが……、って、あ！　ああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_0103102" ]},
		{"command":[ "SETCHARA", "0", "char_00011701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「な、なぜ、いきなり陰部を露出したのです！？　わ、わたくしは大切なお話\nを……！　はい！？　これもまた重要なこと！？　そうでしょうか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_0103103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「あ、あ、あ、あの、ソレをしまっていただかないと！　おはなっ、お話が続\nけられないのですが……。えっ！　今夜私を呼んだのは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_0103104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「ソレ……に奉仕をさせるため？　ぁ……に、肉棒に……ですか？　いえっ、\n嫌だとかそういうわけではありませんけれど……。驚いて……。ええ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_0103105" ]},
		{"command":[ "SETCHARA", "0", "char_00011701_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「は、はい……。鈴の意識をスリープさせて休ませたまま……。わ、わたくし\nに口奉仕をさせたいということですね。わ、わかり……ました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_0103106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「んっ……ええと、こういった体勢で本当によろしいのですか？　あの……わ\nたくしがお口でするのはかまわないのですが、あの、隊長さまのお顔に」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_0103107" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00011701_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「わたくしの股間……が触れてしまっているのですけれど……。これは、隊長\nさまが苦しいのでは？　重くありませんか？　大丈夫……ですか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_0103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「甘酸っぱいいい匂いがする？　葉金のアソコはふにふにすべすべで柔らかい\n？　……ん、んもう！　それ以上何も言わないでくださいませ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_0103109" ]},
		{"command":[ "SETIMAGE", "0", "still_00011701_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「ん……こ、これを口で愛撫……する……。何ですって？　胸も使って？　む\n……胸って……こ、こうですか？　挟むくらいしかできませんけれど？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_0103110" ]},
		{"command":[ "SETIMAGE", "0", "still_00011701_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「胸で両側から挟んで、谷間でペニスを揉みながら……。な、舐め……るので\nすわよね。だ、男性器……を……。お小水を出すところ、を……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_0103111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「い、いきなりは勇気がいりますから……最初は唇でキ、キス、から……。…\n…ちゅ……。んぁっ！？　胸の中でペニスが震えましてよ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「あっ……い、いやぁ……。殿方の股間を、大切なところを胸に、肌にくっつ\nけるなんて……口で愛するだなんて……いや……いやだけど……。ちゅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_0103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「はぁっ、た、隊長さまのご命令に背くわけにはいきません、から……。ん…\n…。え、えぇと……舌を伸ばして……。ぴちゃっ……！　うぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_0103114" ]},
		{"command":[ "SETIMAGE", "0", "still_00011701_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「さしたる味はいたしませんが……！　さっきから、隊長さまの性器が私の動\nきに合わせてピクピクと跳ねるのです。しょ、小動物のように……怖い」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_0103115" ]},
		{"command":[ "SETIMAGE", "0", "still_00011701_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「でも……なぜだか気になって……。め、目が離せないのです……。舐めると\n喜ぶだなんて……。であれば親猫が子猫にするように……っちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_0103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「ちろ……ちろ、ちろ……。っはぁっ……ン……。んふ……。ぺろっ……ぺろ\nっ、ぺろ……。あ、あぁ……吐息がかかってくすぐったいですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_0103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「も、もっと激しく？　は、はい……。では、胸を揺すりながら……お舐めし\nます。っはぁっ……♪　はぁ……ぴちゃっ、ぴちゃ、ピチャ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_0103118" ]},
		{"command":[ "SETIMAGE", "0", "still_00011701_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「はむっ……んちゅっ……れろ……れろっ、れろ……れるっ……。んふ……。\nンッ……んっ、んっ、ん……れろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_0103119" ]},
		{"command":[ "SETIMAGE", "0", "still_00011701_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「ぴちゃ……っ、それにしても、恐ろしいほど太い肉棒ですのね……っ。舌先\nだけではとても舐めきれない……。ぴちゃっ、ぴちゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_0103120" ]},
		{"command":[ "SETIMAGE", "0", "still_00011701_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「く、口にも入らなさそうなサイズのもので、子作りなどできるのかしら……\n。っはぁっ、子どもを作るためだけならこんなサイズはいらないはず」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_0103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「……んっ？　コレが大きく、硬いと女性が喜ぶ？　はぁ……なるほど、快楽\nを目的とした形をしているというわけですね、って、あっ！？　ンッ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_0103122" ]},
		{"command":[ "SETIMAGE", "0", "still_00011701_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「こ、こらっ！　何をしているのです！　わ、わたくしの股間を……！　っ、\nあ、アソコに触れたでしょう！？　あっ……あっ、あっ、いやっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_0103123" ]},
		{"command":[ "SETIMAGE", "0", "still_00011701_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「ゆ、指……？　んぁっ……！　舌……あッ！？　お、おやめなさい！　そこ\n、そこは……っ、子どもを作る大切な場所……。っぁっ！　いやぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「鈴にも触らせたことがない、のに……あっ！　あぁっ！　やめっ……やめろ\nというのが聞こえないのですかっ！　べちゃべちゃと……！　んっあぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「やめて欲しければ熱心にイチモツを……。だ、男性器を舐めろ？　口淫がう\nまくいくまでし続ける……ですって！？　くぅっ……仕方ありませんわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_0103126" ]},
		{"command":[ "SETIMAGE", "0", "still_00011701_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「い、一気に終わらせます……っ！　ん、あむっ……れろっ、れろ……れろっ\n、れろ……。……ッふっ……、はぁっ、ぁ……ッ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_0103127" ]},
		{"command":[ "SETIMAGE", "0", "still_00011701_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「わ、わざといやらしい動きを、するのはおやめなさ……んんぅっ！　あっ、\nもうっ……！　ンチュッ……ぐちゅっ、ぐちゅっ、ぬちゅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_0103128" ]},
		{"command":[ "SETIMAGE", "0", "still_00011701_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「ぬりゅ……ちゅぷ……くっちゅっちゅぷっ……！　ちゅくっ、ちゅっくっ、\nクチュっ、ちゅっぷっ……んんん！　んぅっ！？　ンンッ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「か、花弁の中に舌が……あぁ……、ヌルヌルして……っ。は、ぁ……っ、は\nぁっ……！　ま、負けませんから……！　れろっ、れろ、れろ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「ぢゅぷっ……ぢゅぷっぢゅぷっ、ぢゅる……んっ、んん……！　れろ……れ\nろぉっ、れろっ、れろ……ぴっちゃっ、ぴちゃ、ぴちゃ……どうです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「イタズラをやめる気になりま……あぁんっ！？　くぅっ……！　ひ、卑怯で\nすわよ！　ク、クリトリスを責めるだなんて……！　こ、こちらも！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_0103132" ]},
		{"command":[ "SETIMAGE", "0", "still_00011701_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「攻めて攻めて攻めまくりますわっ……れろっ、れろ……れろ……フフフ、裏\n筋がいいんですの？　弱点を見つけましたわよ……っぢゅるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_0103133" ]},
		{"command":[ "SETIMAGE", "0", "still_00011701_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「れろぉおおおおお♪　れろ、れろぉおお……っ、れ……冷静になれば、貴方\nをイかせることなど、わ、わたくしには容易ですわ……ほら、胸で搾って！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「これ以上ないほどにイカへてあげまひゅわ……！　ぢゅるっ！　ジュルッ…\n…じゅるっ！　くっぷっ！　くっぽっ、くぽっ、くぽっ……れるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_0103135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「フフ、情けなく喘いでおイキなさいっ……あっ！　で、でないと、そろそろ\n……わ、わたくしも……！　ッ……わたくしがここまでしているのですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_0103136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「イ……きなひゃい……！　イって……！　っぐちゅっ……ぐちゅっ、ぐちゅ\nっ、ぐちゅっ！　ンっ……！　んっ……！　んっんっ……んっぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_0103137" ]},
		{"command":[ "SETIMAGE", "0", "still_00011701_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「おね、がい……っ。イッれぇ……！　ちゅぷっ！　ちゅぷっ、ちゅぷっ、く\nくちゅ……んれるっ、れろっ、れる、れる、れるん……ぢゅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「あ、あぁ、あぁあ……！　わたくひっ……わたくし、そんなところ……！　\nおまんこを舐められるだなんて初めてで……んんんっんぁんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_0103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「一人でイクのこわ、い……のです……！　出して……出してっ、どこに出し\nてもいいから……！　ぐっちゅっ！　ぐっちゅっぐちゅぐっちゅっ、あっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「んあっ！！　あああっ！　あーっ！　ああああああっ……！　あああああ…\n…ッ！　だめっ、だめ、だめぇええ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_0103201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「っああっ、ああっ……ああ……！　え……！？　あっ！？　貴方も……隊長\nさまも同時に射精なさって……！　ッあっ！　あっぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「きゃんっ……んぁあっ！　わたくしの胸に……胸に白濁液をぶちまけるだな\nんて……なんて躾のなっていない肉棒なのですか……っ、んぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_0103203" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00011701_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「やぁっ……ま、まだ出すのですかっ！？　わ、……わたくしが恥ずかしそう\nなのが興奮した！？　んもうっ……どうしようもない方ですわねっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_0103204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「……あの……。これだけ大量に射精していただいてなんなのですが……。わ\nたくし、最後の瞬間に、じ、自分の絶頂で口を離してしまいましたわよね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_0103205" ]},
		{"command":[ "SETIMAGE", "0", "still_00011701_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「ああいう時に唇を離されると……その、殿方は満足しきれないのではありま\nせんか？　そ、それで……よかったら、ですけれど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_0103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「あまりわたくしにイタズラをしないのであれば、今度は最後まで、口で……\nご奉仕しますわ。よろしくて？　へ？　イタズラはやめられない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「そ、それは困ります！　とにかくっ……ん……！　せっかく胸に大量に精が\n溢れているのですから……これを使って……。んんっ、ん、はぁ、はぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_0103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「乳房で尽くしながら……んぁっ、き、亀頭を舐めさせていただきます。……\nイタズラは勝手にしてください！　い、いきますよ……。っれちゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「ふんん……っ、ぁ……まだ出しきれていない精液が残って……。吸い出しま\nすね……。胸で絞りあげて……。ッぢゅっ……ぢゅっ、ぢゅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_0103210" ]},
		{"command":[ "SETIMAGE", "0", "still_00011701_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「んん……ごく……。あっ……あっ！　アソ、コに執着しないでくださ……い\nませっ……さきほどイッたばかりですのに……っんっ！　舐め、ああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_0103211" ]},
		{"command":[ "SETIMAGE", "0", "still_00011701_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「舐め、られるとこちらがうまくご奉仕できませんのにっ……。んぁっ！　し\n、舌が震えてしまって……！　ペニスが逃げてしまいます……あっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「んぁ……あふ、んん、んんんっ……！　ちゅ……ちゅ、れろ……れろ、れろ\n……。んぷ、ぺろ……。こ、これではまた攻め負けてしまいますわね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_0103213" ]},
		{"command":[ "SETIMAGE", "0", "still_00011701_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「大きく口をあけて……はむっ！　ちゅ、ちゅかまえまひたわ……！　これで\nもう逃がひはひまへん……んぐちゅっ！　ぐちゅっ、ぐちゅっ、ぐちゅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_0103214" ]},
		{"command":[ "SETIMAGE", "0", "still_00011701_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「んっ、んぅっ、れろっ……ちゅくっ、ぷっちゅっ、ちゅく……！　ぢゅるっ\n、ぢゅるるっ……ぢゅる……ぢゅるっ、んぁっ、あぁ、ふぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_0103215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「んーんぅ……はぷ……ぢゅっ♪　ぢゅっ♪　ぢゅる……ぴちゃっ！　ぺちゃ\nっ、ぴちゃっ、ぺちゃ……んっ……んっん、ん……れるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_0103216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「っフフ……♪　ここまでねぶっても音を上げないとは……隊長ひゃまも根性\nがひゅわってまふわね……！　よろひくてよ……気に入りまひたわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_0103217" ]},
		{"command":[ "SETIMAGE", "0", "still_00011701_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「気持ちをこめておひゃぶりひてさしあげまふ……。んんーっ、んんっ……れ\nろれろれろ……れろれろれろっ……ぢゅるぢゅるっ、ぢゅるぢゅるぢゅる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_0103218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「はぁっ♪　ンッ……んっ、今度こそ……今度こそ、わたくひが先にイく前に\nぃ……出ひてもらいまふわよっ、ほら、ほら……胸と口同時ですわ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_0103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「んぢゅるぢゅるっ！　ぢゅるっ、ぢゅるぢゅるぢゅるぅうう♪　ぐっちゅっ\n！　ぐっちゅっぐっちゅっ！　観念してお出しなひゃい！　さあ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「んぁんんっ！　ぅんっ……！　あ、あら……っ！　いいのですか、二度目も\n胸で……っ！　あっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_0103301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00011701_01_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「い、いきなりペニスを引き抜くものですから驚いてしまいましたよ……！　\nあっ！　あふっ……あっ！　またこんなに出して……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「す、好きなのですか？　わたくしの胸が……！　あぁっ……！　んん……！\n　こうも執拗に胸にばかり出されてしまうと……。っぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_0103303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「隊長さまの精の臭いがこびりついてとれなくなってしまいそう……っ。あぁ\n……！　せ、精液は本来胸に出すものではないのに……破廉恥な……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_0103304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「あ、赤ん坊を宿すための聖なる体液を……んぁっ、ぼ、母性の象徴たる乳房\nにひっかけるだなんて、罪作りもいいところですっ……本当にもうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_0103305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「……で……でも……それほどまでにわたくしの胸が気に入ったのなら……。\n悪い気は、いたしませんけれど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_0103306" ]},
		{"command":[ "SETIMAGE", "0", "still_00011701_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「で、ですがっ……何がきっかけで鈴にバレてしまうかわかりません。次から\nは……すぐに洗い落とせる場所に出してくださいまし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_0103307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「それか……。く、口の中にそのまま、だとか……。い、いえっ……別にわた\nくしが口寂しいわけでは……。た、ただ……せっかくの射精です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_0103308" ]},
		{"command":[ "SETIMAGE", "0", "still_00011701_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「最後まであたたかな口の中にいらっしゃってもよかったのに……と思っただ\nけです！　で、でもそうですわね。ここまで濃くて臭いの強い精子です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_0103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「口の中に入りきらないどころか、溢れてこぼれてしまっていたかもしれませ\nんものね……。こ、今回は胸で……けっこうですわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「ふふふ、出そうでひょう……って、あっ！？　い、今突然引き抜いたら……\n！　きゃっ……！　あっ、あっ、いやぁっ、顔に……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_0103401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00011701_01_16" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「んッ……なぜ顔に精液を……！　あっ……あっ、止まりませんわ、精液……\n止まらない……ッ！　濁ったドロドロの白い液がわたくしに……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_0103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「あぁ……あぁ……こんなこと……！　一生誰かにさせるつもりもなかったの\nに……っ。お、お父様……鈴……ごめんなさい……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_0103403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「え、ま、まだ出るのですか！？　あ……、あ、あっ……！　んぁああっ！　\nもうっ……人の顔を、キャンバスのように塗り汚して……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_0103404" ]},
		{"command":[ "SETIMAGE", "0", "still_00011701_01_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁ……ぜ、全部出ましたか……？　あ、貴方ねぇ！　わたくしが\n顔にかけられて困惑しているのを見て、また出しましたでしょう！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_0103405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「なんというヘンタイ趣味なのですか！　……轟琴財閥の令嬢が、精液で顔を\nぐちゅぐちゅに濡らしている姿に興奮した……ですって！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_0103406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「と、と、倒錯するのも大概にしてくださいませ……！　ほら、髪にも顎にも\nべったりと……！　ああ、さっき出された胸もひどい臭い……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_0103407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「……隊長さま……。まさかとは思いますが、戸惑っているわたくしを見て、\n更に興奮していらっしゃるのでは……？　違う？　何が違うのです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_0103408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「美しい令嬢を、自分の体液で汚せた達成感と背徳感……？　あ、あやしい官\n能小説のようなことをおっしゃらないでください！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_0103409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「まったく……。でも……隊長さまがそれでご満悦なら、わたくしに文句はあ\nりませんわ。よ、良かったですわね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_0103410" ]},
		{"command":[ "SETIMAGE", "0", "still_00011701_01_15" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}