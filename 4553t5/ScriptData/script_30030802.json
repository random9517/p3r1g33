{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000308_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「あんっ！　も、もう……荒っぽいんだから……んっ、ホテルまで来て逃げた\nりしないわよ……んっ、んふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0804101" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「ホントに……手際よく脱がしてくれちゃって……あ、こら……いきなりおっ\nぱい鷲掴みにしないの……んっ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0804102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「あ……んんっ、な、何よ……そりゃあ、私だって……ちゃんとその気になっ\nてたわよ。今日はずっと貴方とするって……んっ、あ、んふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0804103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「朝から、色々……どんな雰囲気になるかとかシミュレーションもして……ム\nードとか、色々考えて……な、なのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0804104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「あんっ、もう……そんなにオチ○ポ押し付けて……ビンビンにさせてるじゃ\nないの……んぁっ、乳首と同じなんて……そんな、ことっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0804105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「はっ、んっ、あっ……やん……入り口撫でてるぅ……んんっ、濡れてるとか\nっ……そ、そんなの分かってるでしょうっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0804106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「はんっ、あぁっ……そうよっ……今日……デートしている時から、ずっと…\n…そのオチ○ポが入ることばっかり考えていたわっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0804107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「だから、こんなに濡れてるのよっ、分かってるクセにっ……私がして欲しい\nことだってっ……ちゃんと知ってるでしょっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0804108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「そうよっ……チ○ポよっ、オチ○ポが欲しいのっ。ほらっ、ここよっ……じ\nゅくじゅくになって……涎を垂らしてるオマ○コにぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0804109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「貴方のっ……たくましいオチ○ポっ……早く入れてっ、奥までずぶってっ…\n…突っ込んでぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0804110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「んあぁっ……入ってるっ！　んくぅぅぅっ、熱いオチ○ポっ……あっ、あぁ\nぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0804111" ]},
		{"command":[ "SETIMAGE", "0", "still_00000308_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「あぁっ……も、もう一番奥まで入っちゃったの……？　やだ、私……本当に\nお漏らしみたいに濡れてたのね……んくぅ……みっちりしてるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0804112" ]},
		{"command":[ "SETIMAGE", "0", "still_00000308_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「んっふ……あぁ、すごい存在感……はぁ……んっ、広げられちゃう感じ……\nは、恥ずかしいわ……あ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0804113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「あぁ……んっ、ふっ……やっぱり、ミニスカートって……それだけ男を獣に\nさせちゃうのね……こんなにギラギラがっつかれるなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0804114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「んっ……あぁ……太もも、そんなに撫で回して……やだ、こんな場所まで敏\n感になってるじゃない……あ、ひぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0804115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「ね、ねぇ……そろそろ動いて。オチ○ポ……しっかり味わいたいの……はっ\n、んんっ、あっ、あぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0804116" ]},
		{"command":[ "SETIMAGE", "0", "still_00000308_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「うんっ、あっ、はっ、あぁっ、そうよっ……いいわっ、それっ、いいっ……\n感じよっ、あひっ、あっ、はぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0804117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「んんっ……あぁ……逞しいわ……もっとぐっと伸し掛かって……貴方の体温\nを感じさせて……んんっ、そう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0804118" ]},
		{"command":[ "SETIMAGE", "0", "still_00000308_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「あふっ……やっぱり、こんな格好で対外業務をこなしていると、どうしても\nいやらしい視線を感じるのよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0804119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「まあ、つまらない男の視線で気分を高めた訳じゃないけど……少し、人恋し\nさみたいなものは感じちゃって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0804120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「そこら辺……一応は、貴方に期待してるのよ……あぉっ！　あぁっ、そっ、\nそうっ、この激しいのっ……あっ、ひっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0804121" ]},
		{"command":[ "SETIMAGE", "0", "still_00000308_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「ああっ、いいわっ……んんっ、ずっと悶々とした状態が続いて……欲求不満\nになっていたオ、オマ○コにっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0804122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「やっと……んんっ、熱くて逞しいオチ○ポが埋まってるのっ……最高のクリ\nスマスプレゼントよぉっ、はっ、あぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0804123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「あん……いいわ、おっぱいも好きなように揉んで頂戴……んふっ、またこの\n……いやらしい手付きぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0804124" ]},
		{"command":[ "SETIMAGE", "0", "still_00000308_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「大丈夫……少し強い位でいいのよっ……はぁんっ！　それっ、乳首っ……ぎ\nゅってされるのいいわぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0804125" ]},
		{"command":[ "SETIMAGE", "0", "still_00000308_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「あぁっ、コリコリしてるとこっ……あっ、ピンって弾かれてぇっ……こ、今\n度はオチ○ポっ……ズンズン来てっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0804126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「いいわっ、あんっ、こんなにされたらっ……すぐイッちゃうっ！　はぁうん\nっ、も、もうイクぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0804127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「はぁぁぁ……やだ……もうイッちゃった……全然我慢出来なかったの……オ\nチ○ポが気持ちいい所に当たり過ぎ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0804128" ]},
		{"command":[ "SETIMAGE", "0", "still_00000308_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……わ、分かってるわ。まだまだ、続けていいのよ……何度でも\nイカせて欲しいもの……気にせずオチ○ポを動かして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0804129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「んんぅっ！　あぁっ……一回イッた後だと……余計に感じちゃうっ……はぁ\nんっ……オチ○ポの形がすごく分かるの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0804130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「んっ、んふっ、んくぅ……私も……んっ、ぎゅうって……して、あげないと\n……く……ぅぅぅんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0804131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「どう、かしら……ちゃんとオチ○ポ、感じてる……？　オマ○コ……ゆるゆ\nるじゃない、わよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0804132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「歳とかっ……そりゃあ……全く気にしないでいるのは無理よっ。でも、これ\nでもまだまだ普通に若いんですからねっ、はっ、んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0804133" ]},
		{"command":[ "SETIMAGE", "0", "still_00000308_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「あんっ、はぁんっ、ほらっ、オチ○ポ……そろそろ出したいんでしょうっ、\nお見通しよっ……このビクビクさせてるのっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0804134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「んふぅっ……！　キュンって締めるからっ、このままっ……中にっ……オマ\n○コに出しちゃいなさいっ、命令よっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0804135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「んぁぁぁぁぁぁっ！　あぁっ……出てるっ……熱いザーメンっ……びゅくび\nゅくっ……出てるぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0804136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000308_02_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「あっ、やぁんっ……で、出ちゃうっ……ダメェ……潮吹きなんてぇ……はぁ\nんっ、も、漏れちゃうのぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0804137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「はぁ……あっ……はぁ……あふっ……あぁ……良かったわ……オチ○ポ……\n思ってた以上にワイルドだった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0804138" ]},
		{"command":[ "SETIMAGE", "0", "still_00000308_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「んっ、私のオマ○コは……どう？　良かった……？　も、もう、こんなこと\n……聞く前に自分から言うものでしょう？　気を利かせなさい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0804139" ]},
		{"command":[ "SETIMAGE", "0", "still_00000308_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「んふ……そう、良かったのね。ちょっとだけ安心したわ……こういうの……\n例えお世辞でも、女はとっても嬉しいものなのよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0804140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「ところで……まだまだ時間はたっぷりあるし……貴方のオチ○ポも、すごく\n元気そのものよね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0804201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「ということは……当然、それ以上言わなくても、どういうことか……分かる\nわよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0804202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「はぁんっ！　あっ……んふっ、そうっ……抜かずに、続けてしちゃいましょ\nう……今度は、私もリードするわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0804203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「ふっ、んんっ、んくんっ、ほらっ……あっ、うんっ、どうっ……？　んむっ\n、くぅんっ……はんっ、あぁんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0804204" ]},
		{"command":[ "SETIMAGE", "0", "still_00000308_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「あぁっ……私の恥ずかしい動き……見られちゃってる……自分からお尻をく\nねらせて……オチ○ポ貪っちゃってるの……んくぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0804205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「止まらない……あぁ……だって、気持ちいいんだもの……こんな太いオチ○\nポでされてたら……誰だって病みつきになるわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0804206" ]},
		{"command":[ "SETIMAGE", "0", "still_00000308_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「うんっ、んふっ……あぁ……腰が砕けちゃいそう……足がガクガクして……\nあぁっ、身体……支えられなくなっちゃう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0804207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「んんっ！　あぁ……おっぱい捕まえて……んふっ、支えてくれてるのね……\nでも、んっ、あ……先っぽ、指でくにくにしちゃ……あ、あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0804208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「あぁ……乳首ももっと敏感になってるみたい……んっ……今の……ぎゅって\nされると……んふっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0804209" ]},
		{"command":[ "SETIMAGE", "0", "still_00000308_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「勝手に身体に力が入って……んっ、オマ○コにも響いちゃう……あんっ！　\nまたっ……あんっ、はんっ、あひんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0804210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「あぁ……自分の身体なのに……完全に支配されちゃってる感じ……で、でも\n……そんな感じがドキドキして……堪らないの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0804211" ]},
		{"command":[ "SETIMAGE", "0", "still_00000308_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「んっ、ねぇ……もっと強くして……おっぱいも強く絞って……オチ○ポも、\nもっと……もっと激しく……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0804212" ]},
		{"command":[ "SETIMAGE", "0", "still_00000308_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「はぁぁんっ！　あぁっ、それよっ……その逞しいオチ○ポでっ、グリグリし\nてっ！　私のオマ○コっ……全部征服しちゃってぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0804213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「あんっ、あぁんっ、そうよっ、私は……仕事中でも、ずっとオチ○ポのこと\nばかり考えていた、いやらしいメス犬サンタなのぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0804214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「クリスマスに浮かれるカップルを見てっ、私だってって……ずっと思ってて\nっ、だけど……甘い関係よりっ、こういうのがっ……あひっ、好きなのぉっ！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0804215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「あひんっ、オチ○ポいいっ、オチ○ポいいのっ！　またイクっ、オマ○コイ\nキそうになっちゃってるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0804216" ]},
		{"command":[ "SETIMAGE", "0", "still_00000308_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「ねっ……こ、今度は一緒にっ……！　後ちょっとっ、我慢するわっ……だか\nらっ、貴方も出してっ、また射精っ……すぐよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0804217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「うんっ、くぅんっ、あぉうっ、いいっ……あぁっ、そうっ……最後のスパー\nトっ……ぐりぐりっ、オマ○コ肉っ……か、かき回してぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0804218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「あぁっ、もうダメっ……わらひっ、イクっ！　スケベサンタがっ、オチ○ポ\n気持ちよすぎてっ、もうイッちゃうからぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0804219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「出してっ、貴方も出してっ、熱い精液っ……ドピュドピュっ……射精してぇ\nぇぇぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0804220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「んぁぁぁぁぁぁんっ！　あっ、中っ……来たわっ……また熱いの出てるっ…\n…オマ○コ中出しっ……されてるぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0804301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000308_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「はぁぁんっ……ま、まだオチ○ポ動いてる……射精してるのに……ピストン\n終わらない……嘘ぉ……あ、ひぁぁぁぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0804302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「や、やぁ……またお漏らししちゃう……からだ……力抜けて……潮が飛んじ\nゃってる……あひっ、オチ○ポまだ止まらない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0804303" ]},
		{"command":[ "SETIMAGE", "0", "still_00000308_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「あっ、はぁ……も、もうすぐ終わるの……？　んっ、あぁ……本当？　あと\n、一回出したら……？　あ、ひっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0804304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「あぁ……また、来たわ……びゅくって熱いの……出てきたの……や、あぁ…\n…すごい……こ、腰……本当に抜けちゃう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0804305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……あ、お、終わり……？　あぁ……オチ○ポ……止まった…\n…？　んっ、まだウネウネしてて……感覚が分からなくなっちゃってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0804306" ]},
		{"command":[ "SETIMAGE", "0", "still_00000308_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「はぁ、あふ……あぁ……こんなの初めてだったわ……思ってたよりもずっと\n良かった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0804307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「んふ……やけに素直って……何よ、私がいつもひねくれてるみたいな言い方\nはやめてもらえるかしら？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0804308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「素晴らしいものはちゃんと素晴らしいって……そう言うわ。私……貴方のオ\nチ○ポの虜になったかも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0804309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「そうね、今日は特別な夜だったけど……でも、特別じゃない時でも……また\n、したい……かもね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0804310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「ひぁぁんっ！　あっ……オチ○ポ抜けてっ……！　あっ、お、お尻にぃっ…\n…出てる……あぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0804401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000308_02_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「か、掛けたかったって……ま、また、そういう……あぁ……どんどん出てる\n……あぁ……太ももにも……衣装にまでぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0804402" ]},
		{"command":[ "SETIMAGE", "0", "still_00000308_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「んふぁ……あ……や、やだ……私も…また潮吹きしちゃってる……？　あぁ\n……もう何もかも汚れちゃうわ……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0804403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「まだ……後もう一回……出るの？　いいわ……今更、中途半端に残されても\n困るだけだもの……全部出しなさい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0804404" ]},
		{"command":[ "SETIMAGE", "0", "still_00000308_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「んんっ……あぁ……すごくヌルヌルしてるの……お尻に感じるぅ……はぁ…\n…はぁ……あぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0804405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「これで終わり……ね？　はぁ……こんなにいっぱい出して……本当に逞しい\nんだから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0804406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「んふ……まだ、少し余韻が残ってる……でも、本当に凄かったわ……思った\n以上に良かった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0804407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「んふ……やけに素直って……何よ、私がいつもひねくれてるみたいな言い方\nはやめてもらえるかしら？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0804408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「素晴らしいものはちゃんと素晴らしいって……そう言うわ。私……貴方のオ\nチ○ポの虜になったかも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0804409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「そうね、今日は特別な夜だったけど……でも、特別じゃない時でも……また\n、したい……かもね」", "NORMAL" ]},
