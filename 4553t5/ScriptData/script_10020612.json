{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0147" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "なんとか長官とエファを鎮圧し、審査が再開された。ただ、問題が発生してい\nた。", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「さっきの戦闘で、トッピング用のフルーツがみんなダメになってしまったわ\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113670001" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "5", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「くそ、これじゃあ炎のパンケーキが作れねえ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「そんな、ここまで頑張ったのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010113670001" ]},
		{"command":[ "SETCHARA", "0", "char_00001205_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "審査に出す料理が作れなければ、もはやリタイアするほかない。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "クラスにあきらめの空気が漂う。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「大丈夫。パンケーキなら、作れますから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130113670001" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「流々那？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そんな中で、流々那はパンケーキを焼きはじめた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「最後は地球防衛科ですが、用意はできそうです？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_050113670001" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「はい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130113670002" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "結果、俺たちが提出したのは簡素なパンケーキだ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FA_SE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「流々那さん、それじゃあ勝てないわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113670002" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「でも、リタイアするよりはいいですから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130113670003" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そして、審査開始。といっても、審査員はエファだけだ。長官は医務室だし、\n学園長たちはグレーテルにお説教している。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「あら、パンケーキですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060113670001" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「子供のころ、教育係からレシピを習ったんです。思い出しながら焼いてみま\nした」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130113670004" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「いただきます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060113670002" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "一口サイズに切ったパンケーキを口へ運ぶエファ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「……っ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060113670003" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "4", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "今度はなんだっ！　エファが……泣き出した……！", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "PLAYBGM", "BGM_011" ]},
		{"command":[ "SETTEXT", "「なんちゅうものを食べさせてくれるんや……。この料理に比べたら、ほかの\n料理はクズや……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060113670004" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "4", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「どうなってるんだ？　あいつ、まだラリッてるのか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「もっとコメントを引き出してみましょうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_050113670002" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "兎子がステージに上がり、エファにマイクを向けた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「ええ、ちょっと昔を思い出してしまって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060113670005" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "4", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「ルルーナが料理をしたいと言い出したときに、パンケーキの作り方を教えた\nんです。その味と同じで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060113670006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「え……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113670003" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「どういうこと？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130113670005" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "流々那とルルーナ。お互いに同じような思い出があるということか。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "いくら『アナザー』だからって、こんなことがあるのか。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「なるほど、記憶と同じ味ということですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_050113670003" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「ええ、まさしくそうです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060113670007" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "どうなってるんだ。ルルーナと流々那は、小さい頃はそれぞれの次元で暮らし\nていたはずなのに……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「ああ、もうこのチームが優勝です。いいですよね？　ほかの審査員もいませ\nんし独断で決めても」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060113670008" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0160" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
		{"command":[ "SETTEXT", "そんな流れで、グルメコンテストの優勝は俺たちに決まった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「思い出補正のかかった料理は最強ってことか」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "グルメコンテストも終わり、学園祭も終盤。俺は校舎裏で一息ついていた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「カツマ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130113670006" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そこに流々那がやってきた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「流々那か。どうしたんだ？　後夜祭があるとか聞いていたが」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「ええ。でも、カツマにお礼を言いたくて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130113670007" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「私たちが優勝できたのはカツマのおかげです。ありがとう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130113670008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、俺はなにもしてないって。頑張ったのは流々那の方だ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「最後の審査だって、決め手になったのはお前の作ったパンケーキだしな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「ううん、やっぱりカツマのおかげだと思います。この次元で、カツマを見つ\nけて本当によかった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130113670009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「どういうことだ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「私がこの次元に来る前に、手を差し伸べてくれた人。その人にカツマを見つ\nけろって言われたんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130113670010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「へえ、そんな奴に会っていたのか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「私に襲来者（インベーダー）に対する戦い方を教えてくれた、年老いた賢者\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130113670011" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「賢者ねぇ。すごい奴だったんだな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「その人の言う通りにしてよかったって思ってます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130113670012" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "いろんな次元を渡り歩いていれば、賢者と呼べるような人物にもめぐり合って\nいるのだろうな。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「それにしても、どうして今その話を？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「ふふふ……どうしてでしょうね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130113670013" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「カツマに、もっと私のことを知って欲しいからかもしれません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130113670014" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "流々那が小さく笑った。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「下僕っ、こんなところにいたんですね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113670004" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ルルーナ、どうしたんだ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「どうしたもこうしたも、後夜祭なんですから、下僕も参加なさい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113670005" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ええー、準備も含めてずっと休みなしだったんだが……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「つべこべ言わずに！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113670006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ぐいっと腕を引くルルーナ。相変わらず強引に……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "sbg_0138" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「カツマ、後夜祭を一緒に回りましょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130113670015" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "流々那にまで腕を引っ張られる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああもう、しょうがないなあ！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "両腕を同じ力で引っ張られながら、俺は後夜祭で盛り上がる校庭へ繰り出して\nいった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "STOPBGM" ]},
	    {"command":[ "DISPTEXT", "FALSE" ]},
	    {"command":[ "DISPNAME", "FALSE" ]},
 		{"command":[ "DISPCHARA", "0", "FALSE" ]},
 		{"command":[ "DISPIMAGE", "0", "FALSE" ] },
	    {"command":[ "PLAYMOVIE", "ED_2_006.mp4" ]},
	    {"command":[ "WAITMOVE" ]},
	    {"command":[ "WAITINPUT" ]},

		{"command":[ "EXIT" ]}
	]
}