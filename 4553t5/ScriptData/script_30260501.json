		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「こんなオチンポにご奉仕できるなんて、ママはとっても幸せよ……あぁ……\nずっとこうしていたい位……むにむに……しこしこ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0503214" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「あぁっ……またお汁が滲んでる……どう？　またオチンポ……出したくなっ\nてきちゃったの？　お漏らししちゃいそう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0503215" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「ふふっ、そうなのね……じゃあ、ママも一生懸命頑張って……次のお射精が\n、いーっぱい気持ちよくなれるように頑張るわ……」", "NORMAL" ]},
