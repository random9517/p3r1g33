		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「でも、されてる時は素直に甘えてくれてましたね……貴方にもあんな一面が\nあったなんて……とっても可愛かったですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0503308" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「別にからかっているわけじゃありませんよ。たまにはこういうのも悪くない\nって……私も燃えましたから……」", "NORMAL" ]},
