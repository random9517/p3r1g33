		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「あら、いらっしゃい……ふふ、よく来て下さいましたわね。さあ、リラック\nスなさって、ほらベッドにどうぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0503101" ]},
		{"command":[ "SETCHARA", "0", "char_00002605_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「服も邪魔ですし、脱がしてしまいましょうね。えっ、お話が見えない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0503102" ]},
		{"command":[ "SETCHARA", "0", "char_00002605_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「あらあら、この部屋でサキュバスに呼ばれて来るってことは……当然、もう\nそういうものと分かっていると思っていましたが……違いましたか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0503103" ]},
		{"command":[ "SETCHARA", "0", "char_00002605_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「ふふ……どうやら、薄々そういうことだという認識はお持ちだったようです\nね。では、遠慮なく押し倒させて頂きます……えいっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0503104" ]},
		{"command":[ "SETCHARA", "0", "char_00002605_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「ほぉら、もうオチンポも、こんなに立派……おっぱいの中でムクムク大きく\nなっていきますね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0503105" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00002605_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「エッチな目が、じぃっとおっぱいを見つめて……んふ、可愛らしいこと……\nまるでママになったような気分です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0503106" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「ほら……おっぱいを動かしますよ。ママのおっぱいはどうでちゅか？　んっ\n、ふっ、あっ、あんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0503107" ]},
		{"command":[ "SETIMAGE", "0", "still_00002605_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「んふっ、あらあら……このオチンポの反応……もしかして、赤ちゃん言葉で\nシコシコされるのが好きだったのかしら？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0503108" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「ふふ……それなら、今日は完全にママになっちゃいましょうね……さあ、僕\nちゃんのオチンポ……いっぱい扱いてあげましょう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0503109" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「は、んんっ、んふっ……ぐにゅぐにゅ……皮を捲るようにして……ここがお\nっぱいに食い込むと……気持ちいいのね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0503110" ]},
		{"command":[ "SETIMAGE", "0", "still_00002605_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「んんっ、先端がぴくぴくしちゃって……本当に可愛いわ……食べちゃいたい\n位に……でも、今日はキスだけ……ちゅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0503111" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「まぁ、今のキスも刺激が強かったの？　大丈夫よ……怖くないわ……ママの\nおっぱいがやさーしく包んであげまちゅからね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0503112" ]},
		{"command":[ "SETIMAGE", "0", "still_00002605_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「ふふ、あったかいでちゅか？　僕ちゃんの、オチンポがおっぱいに埋もれて\n見えなくなっちゃったわね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0503113" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「剥けてる頭のところだけ……ちょこんと顔を出して……乳首でツンツンして\nあげちゃおうかしら……んふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0503114" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「ほら……ママの乳首……どんな感じ？　硬くてコリコリしてる……？　そう\nね、ママもすごくドキドキしちゃってるの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0503115" ]},
		{"command":[ "SETIMAGE", "0", "still_00002605_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「もっともっとオチンポを愛してあげたいって……そう思うと、自然にエッチ\nな乳首がビンビンになっちゃうのよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0503116" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「今日は……この乳首とオチンポを……いっぱいくっつけながらパイズリして\nあげまちゅからね……ほーら、しこしこ、くにゅくにゅー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0503117" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「はんっ、あぁ……んふっ……あらあら……オチンポ、もっと大きくなっちゃ\nったわね……苦しくなっちゃったのかしら？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0503118" ]},
		{"command":[ "SETIMAGE", "0", "still_00002605_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「待っててね……今、中のイケナイものを出してあげるために、ママのおっぱ\nい頑張るから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0503119" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「うんっ、はっ、あんっ、あぁっ……どう？　きもちいい？　オチンポ……ム\nズムズしちゃうかしら？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0503120" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「ふふっ、いい子ね。ちゃんとうんうん頷いて、ママにもよーく伝わったわ。\nじゃあ、正直なオチンポにごほうびよ……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0503121" ]},
		{"command":[ "SETIMAGE", "0", "still_00002605_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「ほら……おっぱいの中に包まれちゃったわ……よしよし……おっぱいでのオ\nチンポ撫で撫で……気持ちいい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0503122" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「あらぁ、気持ちよさそうなお顔……ふふっ、可愛いわね。そんな顔をされち\nゃったら、もっとよしよししてあげたくなっちゃうわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0503123" ]},
		{"command":[ "SETIMAGE", "0", "still_00002605_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「いい子ねぇ……はーい、ママのおっぱいでちゅよ～？　オチンポ……モミモ\nミしちゃいますからねぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0503124" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「あぁ……んんっ、気持ちいいわ……ママも……んっ、オチンポのにおいで興\n奮してきちゃったみたい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0503125" ]},
		{"command":[ "SETIMAGE", "0", "still_00002605_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「はぁっ、んんっ、ぷくんって膨らんだ乳首……もっともっと押し付けてあげ\nるわ……あんっ、オチンポがビクビクしてるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0503126" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「もうちょっと我慢できるわよね？　うんうん、いい子いい子……はーい、横\nのところをズリズリしますよー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0503127" ]},
		{"command":[ "SETIMAGE", "0", "still_00002605_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「んふぅっ、はぁっ、んっ……あぁっ……オチンポの先から……エッチなお汁\n……出てきちゃったわね……んちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0503128" ]},
		{"command":[ "SETIMAGE", "0", "still_00002605_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「ちゅぷっ……少ししょっぱい……あとちょっとで、本番のお汁がドピュって\n出ちゃう準備が進んでるってことね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0503129" ]},
		{"command":[ "SETIMAGE", "0", "still_00002605_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「もうお漏らししちゃいそう？　いいのよ……赤ちゃんなんだから、我慢でき\nなくなっても仕方ないことなの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0503130" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「気にしないでおっぱいに出しちゃいましょうね。えっ……まだ、もうちょっ\nと我慢したいの？　ふふっ、男の子って逞しいわね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0503131" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「いいわ……一生懸命我慢してみましょうか。でも、いつ出してもママは平気\nよ……僕ちゃんの射精……楽しみにしているわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0503132" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「あふっ……柔らかいおっぱい……感じて欲しいの……はぁ……んっ、くちゅ\nくちゅ……音がしてるわ……いやらしい音ぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0503133" ]},
		{"command":[ "SETIMAGE", "0", "still_00002605_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「んくぅっ……はぁぁっ……あぁっ、おっぱいの中でオチンポが、プルプル震\nえてるのっ……もう出ちゃいそう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0503134" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「ええ、ママのおっぱいに出しましょう？　はーい、オチンポ、ピュッピュし\nてっ……あっ、んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0503135" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「はぁぁんっ！　あふぁっ……いっぱい出てるわっ……おっぱいの中に……僕\nちゃんの元気なミルク……ドピュドピュしてるのっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0503136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002605_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「んふぅ……熱い……溜まってたのね……いいのよ、全部出しちゃいましょう\n？　ほら、シコシコ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0503137" ]},
		{"command":[ "SETIMAGE", "0", "still_00002605_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「はふぅっ……まだ、飛び散ってくるわ……おっぱいがドロドロになってるの\n……あぁ……すごく逞しい……はぁん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0503138" ]},
		{"command":[ "SETIMAGE", "0", "still_00002605_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「あ……止まったわね……いっぱいオチンポからミルクを出せてえらかったわ\nね……よしよし……頭を撫でてあげますよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0503139" ]},
		{"command":[ "SETIMAGE", "0", "still_00002605_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「しばらくゆっくりするといいわ。ママのおっぱいの中、好きなだけいていい\nのよ……ママも、オチンポを感じていたいから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0503140" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「んっ……どうかしら、オチンポ落ち着いた？　まだ、おっぱいの中でしっか\nり硬いままみたいだけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0503201" ]},
		{"command":[ "SETIMAGE", "0", "still_00002605_01_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「なぁに、もじもじしちゃって……いいのよ、怒ったりしないから、ママに言\nってご覧なさい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0503202" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「もうちょっとして欲しいの？　ふふっ、そうね……実はママも、してあげた\nいなって思ってたの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0503203" ]},
		{"command":[ "SETIMAGE", "0", "still_00002605_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「だって、あんなに出したのに……オチンポ、収まるどころかもっと元気に反\nり返っているんだもの……本当に素敵よ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0503204" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「んふ……ちゅぷっ、だから……ママのおっぱい……もっともっとオチンポで\n感じてね……また、動かすわよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0503205" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「あっ、んんっ、はぁっ……あぁ……聞こえる……？　僕ちゃんのザーメンミ\nルクが、おっぱいの中でエッチな音をさせてるわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0503206" ]},
		{"command":[ "SETIMAGE", "0", "still_00002605_01_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「ヌルヌルで……お肌が滑ると、とっても気持ちいいの……んっ、それに、こ\nの男の子のニオイ……ママもとっても興奮しちゃうわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0503207" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「あぁ……んちゅぷっ、大丈夫よ……怖くないわ……優しく柔らかく……オチ\nンポをメロメロにしてあげますからね……んふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0503208" ]},
		{"command":[ "SETIMAGE", "0", "still_00002605_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「谷間も……トロトロになってるけど……もう少しママのよだれを足しましょ\nうね……ん、えろぉぉ……れるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0503209" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「はっ、んっ、あふっ……見て……ママのおっぱいが、こんなにエッチに形が\n変わっちゃうの……よく見えるかしら……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0503210" ]},
		{"command":[ "SETIMAGE", "0", "still_00002605_01_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「あぁん……おっぱいにすごく視線を感じるわ……待ってね……先っぽ、して\nあげるから……ふぅぅぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0503211" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「ふふっ、くすぐったかったかしら？　ちょっと息を吹きかけただけで、オチ\nンポがビクビク波打っちゃってるのね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0503212" ]},
		{"command":[ "SETIMAGE", "0", "still_00002605_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「本当に可愛いオチンポ……でも、それだけじゃなくて、ちゃんと雄々しくて\n、カッコいいの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0503213" ]},
