		{"command":[ "SETIMAGE", "0", "still_00002605_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「はぁんっ、あふぁっ……ほぉら……少し強めのおっぱいプレス……んんっ、\nオチンポが……中でヌチュヌチュ……いやらしい音してぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0503217" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「はっ、んぁっ、あぁっ……おっきいオチンポ震えてるわっ……このまま、最\n後までしちゃうからっ……好きなだけ出しちゃいなさいっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0503218" ]},
		{"command":[ "SETIMAGE", "0", "still_00002605_01_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「またおっぱいに中出ししたい？　ママのお顔に掛けちゃってもいいのよ？　\n僕ちゃんのしたいようにしていいんだから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0503219" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
