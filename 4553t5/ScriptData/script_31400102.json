{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「あっ、あああんっ……！　やっぱ、オナニーって最高……！　あっ、すごっ\nっ！　イッ、イク……イッ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0104101" ]},
		{"command":[ "SETCHARA", "0", "char_00014001_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「……って！　あ、あんた！？　あ、あんたなんでうちの部屋に無断で入って\nきてるの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0104102" ]},
		{"command":[ "SETCHARA", "0", "char_00014001_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「ちゃんとノックしたけど返事がないし、変な声がしてたから気になって入っ\nてきた……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0104103" ]},
		{"command":[ "SETCHARA", "0", "char_00014001_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「はああぁ……そりゃノックに気づかないうちもうちだけどさ……よりにもよ\nって、このタイミングで入ってくる？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0104104" ]},
		{"command":[ "SETCHARA", "0", "char_00014001_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「しかも結局イケなかったし……あー、もう！　こうなったらあんたに責任取\nってもらうからね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0104105" ]},
		{"command":[ "SETCHARA", "0", "char_00014001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「あんたのチンポ、バッキバキになってんね。すごいそそり立って……うちの\nオナニー見て、そんなに興奮したの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0104106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00014001_02_02" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「あはっ！　実はうちもあんたにオナニー見られてたって思ったら、マン汁止\nまらなくてねー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0104107" ]},
		{"command":[ "SETIMAGE", "0", "still_00014001_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「そんな状態でこの勃起チンポ見せられたら、誰だってエッチしたくなるって\n思わない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0104108" ]},
		{"command":[ "SETIMAGE", "0", "still_00014001_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「ほら……オマンコとチンポが擦れて、ぐちゅぐちゅって音が鳴ってるの聞こ\nえる……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0104109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「今からこのぐちょ濡れオマンコに、あんたのチンポが入ってくの……めっち\nゃエロくない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0104110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「あぁん！　チンポがビラのところでビクビクって震えて……！　そ、そんな\nに焦らなくてもいいじゃん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0104111" ]},
		{"command":[ "SETIMAGE", "0", "still_00014001_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「こんだけ濡れてても……ゆっくり挿れないと、ちょっと不安っていうか……\nとにかく、うちに任せておいて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0104112" ]},
		{"command":[ "SETIMAGE", "0", "still_00014001_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「んっ、あはああぁ……！　オマンコが、ゆっくり広がって……んっ、くうう\nぅ……！　徐々に入ってるの、わかるー……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0104113" ]},
		{"command":[ "SETIMAGE", "0", "still_00014001_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「ぐっ、あうぅ……あっ、ああぁ……！　ちょっとこれ、大きすぎない……！\n？　チンポって、こんなにデカいの……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0104114" ]},
		{"command":[ "SETIMAGE", "0", "still_00014001_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「んあっ、ふあああぁ……！　極太チンポの先端が、うちのトロトロのオマン\nコ掻き分けて……あぐううぅ……！　膣内に、入って……ああぁん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0104115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「チンポ、入っちゃった……オマンコの膣内に、ずりゅうぅって……！　あふ\nっ、うんっ、あぅんっ……！　あっ、あっ、あぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0104116" ]},
		{"command":[ "SETIMAGE", "0", "still_00014001_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「あっ、あぐっ、はうぅっ……んはあぁっ！　オマンコの奥、コンコンって叩\nかれて……！　チンポの先が、いいとこに当たってるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0104117" ]},
		{"command":[ "SETIMAGE", "0", "still_00014001_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「あうううぅっ……そこ、ダメぇ……！　はあぁんっ！　赤ちゃんの部屋、グ\nリグリって……！　すっごく感じるし……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0104118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……うちが動くから……あんたはチンポ硬くさせてて……！　ん\nっ、ふああぁ……あっ、んぐうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0104119" ]},
		{"command":[ "SETIMAGE", "0", "still_00014001_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「って……ちょっと……！？　あ、あんた……！　なんで腰を浮かして……！\n　はうううううぅ～～～～～！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0104120" ]},
		{"command":[ "SETIMAGE", "0", "still_00014001_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「し、下から突き上げるとかありえないんですけどぉ！　これ、マジでヤバい\nって！　足がガクガクして、力が入んなくなるからぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0104121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、あはああぁ！　ズンズンってチンポがオマンコ突きまくってる\nぅ！　そんなにされたら、子宮口開いちゃうしぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0104122" ]},
		{"command":[ "SETIMAGE", "0", "still_00014001_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「んくうううぅ……！　ぬ、抜けるときに、おっきなカリがオマンコ引っ掻い\nて……ずりゅずりゅって、抉られる感じが……んひいぃ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0104123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「ダメっ！　本当にやめてぇ！　うちのペースでオマンコパンパンしないと、\n頭おかしくなるからぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0104124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「あぁんっ、あんっあぁん！　ズボズボされるの気持ちいいっ！　気持ちよす\nぎて、オマンコぐちゃぐちゃになるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0104125" ]},
		{"command":[ "SETIMAGE", "0", "still_00014001_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「んあああぁ……！　ずっと、出たり入ったりしてるぅ！　ううぅ……！　犯\nしてるのに犯されてるみたいで、変な気持ちになっちゃうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「うちの腰も勝手に動いちゃうっ！　あんたの腰使いに……チンポの動きに合\nわせて、パンパンしたてたまらないしぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0104127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「あんっあっあっ！　ふあああぁ！　オマンコから本気汁溢れて止まらないよ\nぉ！　じゅぷじゅぷってイヤらしい音が鳴るの、止められないのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0104128" ]},
		{"command":[ "SETIMAGE", "0", "still_00014001_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「奥もぐちょぐちょになってて、すごいのぉ！　子宮口とチンポがちゅっちゅ\nっってずっとキスしてるっ！　チンポキスすごすぎるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「やああぁ！　グリグリしながら押し付けるの反則ぅ！　うちの子宮があんた\nのチンポに吸い付いて、我慢汁飲んでるのわかるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0104130" ]},
		{"command":[ "SETIMAGE", "0", "still_00014001_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「あ、あっ、ああぁ……！　ダメっ！　イッちゃうぅ！　すごいのキちゃうう\nうぅ～～～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「んひいいぃ！？　ち、チンポ跳ねて、オマンコのお肉かき乱してるっ！　あ\nんたもイキそうなんだね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「お願いっ！　イクなら、あんたも一緒にっ！　あんっ、ああぁあんっ！　オ\nマンコにどぷどぷっ、精液出してぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「もっ、限界だしっ！　ねっ、オマンコの膣内がパンパンになるぐらい、ザー\nメン出して！　赤ちゃんの部屋、真っ白に染め上げてぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0104134" ]},
		{"command":[ "SETIMAGE", "0", "still_00014001_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「あっあっあぐうぅ！　もっ、もうダメぇっ！　オマンコズポズポされるの見\nられながら、イクッ！　イッちゃうっ！　イックううううぅ～～～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0104135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「あはぁああああんっ！　あっ、あっ、あぁっ！　オマンコの奥にザーメン感\nじるぅ！　熱々のチンポミルク、びゅるびゅる出てるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0104136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00014001_02_08" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「精子出されるの気持ちいいっ！　ああぁ、あっあっ！　んほおおぉ！　また\n、イクッ！　ザーメン出されてイクううううぅ～～～～～！！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0104137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「あっ……あああぁ……！　こんなに出して……！　に、妊娠したら、どうす\nるつもりなのかな……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0104138" ]},
		{"command":[ "SETIMAGE", "0", "still_00014001_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「っ！？　ちょ、ちょっと……！　なんでまたチンポ硬くして……！　もしか\nして、本当に妊娠させる気じゃ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0104139" ]},
		{"command":[ "SETIMAGE", "0", "still_00014001_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「あああぁん！　ま、まだお母さんになるのは早いっていうか……！　やっ、\nやあああぁん！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「んほおおおぉ！？　ち、チンポ……さっきよりも大きくなってるっ！　なん\nで！？　今さっき、精子出したばっかりじゃん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0104201" ]},
		{"command":[ "SETIMAGE", "0", "still_00014001_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「うちのボテ腹姿を想像したら、チンポが肥大化した……！？　なっ、なに言\nってんのさ！　意味わかんないしぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「う、うちはまだ妊娠しない……あひいいぃ！？　だ、ダメ……！　出したザ\nーメン、子宮に押し込めないでぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0104203" ]},
		{"command":[ "SETIMAGE", "0", "still_00014001_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「そんなにねちっこくチンポグリグリされたら、子宮の外にある精子、奥に入\nっちゃう！　受精しちゃうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0104204" ]},
		{"command":[ "SETIMAGE", "0", "still_00014001_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「イヤならチンポシゴくのをやめればいいって……そ、それが出来ないから、\n困ってんじゃん！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0104205" ]},
		{"command":[ "SETIMAGE", "0", "still_00014001_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「このデカチンをオマンコに挿れてると、どうしても動きたくなるの！　動物\nみたいに腰を打ち付けて、パンパンしたくなるのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0104206" ]},
		{"command":[ "SETIMAGE", "0", "still_00014001_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「あひっ、あぐっ、らっ、らめぇっ！　このチンポ、本当にすごすぎるぅ！　\n女を虜にする、魔性のチンポだよぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0104207" ]},
		{"command":[ "SETIMAGE", "0", "still_00014001_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「どんだけぎゅ～～って強く締め付けても、カリがオマンコ引っ掻いて、気持\nちいいとこを突いてくるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「膣内出しされて敏感になったオマンコ、容赦なく責めてきて……んひっ、あ\nっ、ぐっ、んおおおぉ～～～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「セックス気持ちいいっ！　チンポ気持ちいいぃ～～～！　ずっとオマンコし\nたくなるぐらい、感じてるよぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0104210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「あ、あ、あひっ！　うち、こんなの初めてっ！　ずっとチンポ挿れてたい！\n　ず～～～っと、セックスしたいよぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0104211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「はぎいいぃ！？　チンポがまたビクビクってしてるぅ！　んっ、ひいいぃ！\n？　少しずつ膨らんでるの、オマンコで感じるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0104212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「精子出そうとする準備、してるんだね！？　またうちに、びゅるびゅるって\nザーメン出したいんだね！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0104213" ]},
		{"command":[ "SETIMAGE", "0", "still_00014001_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「あふっ、んひっ、おっ、んほおおぉ！？　だ、出して欲しいって、オマンコ\nが訴えてるっ！　ザーメン頂戴って、おねだりしてるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0104214" ]},
		{"command":[ "SETIMAGE", "0", "still_00014001_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「あんたのチンポミルク、欲しい欲しいって本能が叫んでるのぉ！　こんなの\n、止められるわけないしぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0104215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「あ～～～っ！　あああぁ～～～！！　チンポの先端、ビクンってしたぁ！　\n出るのっ！？　こくまろミルク、出るのぉ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0104216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「いいっ！　いいよっ！　いつでもいいよぉ！　あんたの好きなとこに、子種\nをどぴゅどぴゅしてっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0104217" ]},
		{"command":[ "SETIMAGE", "0", "still_00014001_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「ドロドロ濃厚なくっさいザーメンっ！　あっ、あひっ、あっ！　いっぱい発\n射してぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0104218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「あああぁ！　あっ、んおおぉ、おほおおおおぉ！？　うちもイクッ！　イッ\nちゃう！　大きくて深いイキ、きちゃううううぅ～～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0104219" ]},
		{"command":[ "SETIMAGE", "0", "still_00014001_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「あんたのチンポとこくまろミルクで、うちをあんたの女にしてえええぇ～～\n～～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0104220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「あっひいいいいいぃ～～～～～！？　ザー汁出てるぅ！　オマンコイクッ！\n　ザーメンぶっかけられてイックううううぅ～～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0104301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00014001_02_16" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「あへっ、あひっ、んひいいいぃ！　イクの止まらないっ！　射精に合わせて\n、何度もイッてるしいいいぃ～～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「あっ、あっあっ、んあああぁっ！　オマンコ壊れちゃうっ！　子宮の中、精\n子でいっぱいになってて破裂しちゃいそうだよおおおぉ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0104303" ]},
		{"command":[ "SETIMAGE", "0", "still_00014001_02_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「うううぅ！　もう入らないのに、オマンコがチンポ汁求めてるっ！　子宮が\nあんたのザーメンごくごくしたいって、言ってくるのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0104304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁはぁああぁ……！　もっ、ダメ……！　イキすぎて、力が入んな\nい……！　んっ、ふああぁ……んくううぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0104305" ]},
		{"command":[ "SETIMAGE", "0", "still_00014001_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「あああぁ……お、お腹の奥、ぽかぽかするぅ……あんたの精子で満たされて\nるって、実感してるよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0104306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「こんだけ出されたら、絶対に妊娠確定だよぉ……どうすんのさぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0104307" ]},
		{"command":[ "SETIMAGE", "0", "still_00014001_02_17" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「チンポ抜けばよかったって……それが出来なかったから、言ってんですけど\n……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0104308" ]},
		{"command":[ "SETIMAGE", "0", "still_00014001_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「あっ、そうだ！　ヤリまくって、常にオマンコをザーメンで満たしとけば、\n逆に赤ちゃん出来づらくなると思わない！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0104309" ]},
		{"command":[ "SETIMAGE", "0", "still_00014001_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「そうと決まれば……さっそく続きしよ！　あんたのキンタマにある精子がカ\nラになるまで、付き合ってもらうかんね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「おほおおぉんぃ！？　ち、チンポがオマンコから抜けてぇ！？　せ、精液が\n飛び散って……あひいいいぃ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0104401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00014001_02_21" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「あっ、熱っ！？　すごっ！　ザーメンびゅるびゅる出てるっ！　顔にまで飛\nんでくるとか、どんだけだしっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0104402" ]},
		{"command":[ "SETIMAGE", "0", "still_00014001_02_20" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「ああぁ……チンポ汁のニオイがするぅ！　こんなクサイの間近で感じたら、\nまたイクッ！　イッちゃうううぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0104403" ]},
		{"command":[ "SETIMAGE", "0", "still_00014001_02_21" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「へぁ、あっ、ああっ、はああぁ……！　あっ、あぁあっ……あんたの精子、\nあったかくて気持ちいい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0104404" ]},
		{"command":[ "SETIMAGE", "0", "still_00014001_02_20" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「ずっと感じていたいって思っちゃうし……！　うち、このニオイに包まれて\nたら、もっとバカになりそ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0104405" ]},
		{"command":[ "SETIMAGE", "0", "still_00014001_02_22" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「っていうか……こんなに出してもまだ勃起してるとか、マジやばくない……\n？　あんた、どんだけ発情してんの……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0104406" ]},
		{"command":[ "SETIMAGE", "0", "still_00014001_02_19" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「う、うちが可愛いから、自然と勃起する……？　もっと、うちとエッチした\nい……？　な、なに言ってんの……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0104407" ]},
		{"command":[ "SETIMAGE", "0", "still_00014001_02_22" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「そりゃ、うちだって……あんたとエッチするの、すっごいハマったっていう\nか……ず～～～っとエッチしたいっていうか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0104408" ]},
		{"command":[ "SETIMAGE", "0", "still_00014001_02_19" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「あ～～～、もう！　細かいこと考えるのやめよ！　お互いエッチしたいなら\nエッチする！　これでいいよね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0104409" ]},
		{"command":[ "SETIMAGE", "0", "still_00014001_02_18" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "岩下環" ]},
		{"command":[ "SETTEXT", "「それじゃ、もっといっぱい気持ちよくなろ！　今度はうちが責める番だから\n！　覚悟してね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_0104410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}