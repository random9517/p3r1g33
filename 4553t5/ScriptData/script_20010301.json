{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0000" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "――西欧魔女協会・マジックフォックス。", "NORMAL" ]},
	{"command":[ "DISPTEXT", "TRUE" ]},
	{"command":[ "SPOTCHARA", "0","1","2" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "それは類い稀な魔法の力を持つ、魔女の中の魔女――『魔女王』を長として活\n動する、秘密組織である。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},


		{"command":[ "SETTEXT", "今代の『魔女王』バサリアの指揮の元、活動を続けている組織内で、近年、特\nにその名を広く知られるようになった、３人の愛くるしい魔女たちがいた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "『幻炎のトリック・クラウン』こと、ピコ。", "NORMAL" ]},
	{"command":[ "SETCHARA", "0", "char_00004001_01", "0", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "『氷結のセレニティ・クラウン』こと、ティア。", "NORMAL" ]},
	{"command":[ "SETCHARA", "0", "char_00004101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "『深淵のワンダー・クラウン』こと、ミラン。", "NORMAL" ]},
	{"command":[ "SETCHARA", "0", "char_00004201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "まだ若いながらそれぞれ卓越した魔術の力を持つ３人――\nその名を『三王冠（トリプル・クラウン）』。", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
	{"command":[ "SETCHARA", "0", "char_00004001_01", "0", "LEFT", "-250" ]},
	{"command":[ "SETCHARA", "1", "char_00004101_01", "0", "CENTER", "50" ]},
	{"command":[ "SETCHARA", "2", "char_00004201_01", "0", "RIGHT", "300" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
	{"command":[ "DISPCHARA", "1", "TRUE" ]},
	{"command":[ "DISPCHARA", "2", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "彼女たちは自分たちこそが次世代の魔女王候補であると自称し、魔女としての\n腕を高めるという口実の元、下克上を狙って暗躍している。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "……そう、本人たちはあくまで『暗躍』しているつもりなのだが……。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "まあ、実際にその現場を見ていただくほうが早いだろう。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "今日もまた、彼女たちはどこからか仕入れてきた情報に誘われるまま、大きな\nトラブルを巻き起こそうとしていた――。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},


		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPIMAGE","0", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "………………", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
	{"command":[ "DISPCHARA", "1", "FALSE" ]},
	{"command":[ "DISPCHARA", "2", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "…………", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "……", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0027" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "隊員" ]},
		{"command":[ "SETTEXT", "「やらせはしない！　この秘宝、魔法石は、来たるべき戦いのために必要なも\nの！　悪党どもの私利私欲のために使わせてたまるか！！」", "NORMAL" ]},
	{"command":[ "DISPTEXT", "TRUE" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員" ]},
		{"command":[ "SETTEXT", "「はははっ、無駄な抵抗はやめな！　その宝は私たちの組織がいただくよ！」", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "市街地の一角。厳重な警備の中、運搬中だった秘宝――巨大な魔力を持つ宝石\nを巡り、激しい戦闘が繰り広げられている。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "それを少し離れた路地裏から監視している、３人の影があった。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「あははっ、みーつけた！　やってる、やってるねぇ～。情報どおりじゃない\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_010021020001" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "SETCHARA", "0", "char_00004001_01", "0", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「ふふん、論理的に無駄なことです。こんな街中で、正面衝突なんて……まっ\nたく知的ではありませんね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_010021020001" ]},
	{"command":[ "SETCHARA", "0", "char_00004101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「……お腹すいた」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_010021020001" ]},
	{"command":[ "SETCHARA", "0", "char_00004201_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「ちょーっとだけ、我慢しなさいって。くふふっ、あのお宝がピコさまたちの\nモノになれば、いよいよ下克上よ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_010021020002" ]},
	{"command":[ "SETCHARA", "0", "char_00004001_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「そうなれば、マジックフォックスの全権力がピコさまたちの思うまま、どん\nなご馳走も毎日食べ放題になるしー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_010021020003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「ふぅ、即物的で私の趣味ではありません。あの宝は、魔法の新たな可能性を\n模索する研究において、とても貴重なもの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_010021020002" ]},
	{"command":[ "SETCHARA", "0", "char_00004101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「私のような超越的な魔女の元にあってこそ、その真価を発揮できるというも\nの。なんとしても手に入れましょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_010021020003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「んー……私は今すぐ、ご馳走食べたい。甘いのー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_010021020002" ]},
	{"command":[ "SETCHARA", "0", "char_00004201_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「まー、いいやー。盗むなら、早くしよー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_010021020003" ]},
	{"command":[ "SETCHARA", "0", "char_00004201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「盗むって人聞き悪いわよ、ミラン！　貴重なお宝を、それを持つのにふさわ\nしいピコさまたちが有効活用してあげるだけだしー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_010021020004" ]},
	{"command":[ "SETCHARA", "0", "char_00004001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「というわけでー、ティア、計画どおり、さくっとやっちゃお」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_010021020005" ]},
	{"command":[ "SETCHARA", "0", "char_00004001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「ええ。私がこの数週間、研究に研究を重ねて開発した、画期的な新魔術、お\n見せしましょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_010021020004" ]},
	{"command":[ "SETCHARA", "0", "char_00004101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「おーっ、すごーい、本当に消えてるし！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_010021020006" ]},
	{"command":[ "SETCHARA", "0", "char_00004001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「ふふっ、いかがですか？　神秘的と言ってもいい、完全な透明化魔術。これ\nなら気づかれずに宝を奪うことも難しくありません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_010021020005" ]},
	{"command":[ "SETCHARA", "0", "char_00004101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「ただ、あまり大声を出したり、余計な行動をすると魔法が解ける場合もあり\nますので、気をつけてください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_010021020006" ]},
	{"command":[ "SETCHARA", "0", "char_00004101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「大丈夫、だいじょーぶ！　サクッとお目当てのお宝奪って、戻ればいいだけ\nでしょ？　よゆー、よゆー♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_010021020007" ]},
	{"command":[ "SETCHARA", "0", "char_00004001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「んー……本当にお腹すいてやる気起きないけど……まー、がんばろー……お\nー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_010021020004" ]},
	{"command":[ "SETCHARA", "0", "char_00004201_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "こうして姿を消したまま、秘宝、魔法石が積まれているであろうワゴン車へ近\nづいていく３人。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「くふふっ、マジ、誰も気づかない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_010021020008" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "SETCHARA", "0", "char_00004001_01", "0", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「しっ、余計なお喋りは論理的ではありません。それより……この箱の中がそ\nうでは？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_010021020007" ]},
	{"command":[ "SETCHARA", "0", "char_00004101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「どれどれ？　うん、この魔力、間違いない！　ふふーんっ、やりーっ、お宝\nもーらいっ！」", "NORMAL" ]},
	{"command":[ "SETCHARA", "0", "char_00004001_01", "0", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_040_010021020009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ピコはワゴンの荷台から、魔法石が収納された小箱を盗み出し、意気揚々とそ\nれを掲げる。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「さあ、長居は無用です。悲劇的なほど愚かな方々が戦闘を続けている間に、\n撤退を……」", "NORMAL" ]},
	{"command":[ "SETCHARA", "0", "char_00004101_01", "0", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_041_010021020008" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「わかってるって。いこっ、ティア、ミラン……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_010021020010" ]},
	{"command":[ "SETCHARA", "0", "char_00004001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「……って、ミラン……？」", "NORMAL" ]},
	{"command":[ "SETCHARA", "0", "char_00004001_01", "0", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_040_010021020011" ]},
	{"command":[ "SETCHARA", "0", "char_00004001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そこでピコは、さっきまですぐ後ろに感じていた仲間の気配がなくなっている\nことに気づいた。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「もぐ、もぐ……うーん……いまいちだけど、もうひと口～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_010021020005" ]},
	{"command":[ "SETCHARA", "0", "char_00004201_01", "2", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「って、こらー、何を食べてるのよ、ミラン！　というか、そのお菓子、どこ\nから持ってきたの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_010021020012" ]},
	{"command":[ "SETCHARA", "0", "char_00004001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「んー、運転席に置いてたからもらったー。もぐもぐっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_010021020006" ]},
	{"command":[ "SETCHARA", "0", "char_00004201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「今、そんなしょぼいお菓子食べてる場合じゃないって！　ほら、早く帰らな\nいと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_010021020013" ]},
	{"command":[ "SETCHARA", "0", "char_00004001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「ちょ、ちょっと待ちなさい！　そんな大声を出すと魔法が……」", "NORMAL" ]},
	{"command":[ "SETCHARA", "0", "char_00004101_01", "3", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_041_010021020009" ]},

		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "血相を変えたティアが注意したときには、もう彼女自慢の透明化魔法が見事な\nまでに解けてしまったあとだった。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "隊員" ]},
		{"command":[ "SETTEXT", "「だ、誰だ、お前たち！　どこから現れた！？」", "NORMAL" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員" ]},
		{"command":[ "SETTEXT", "「悪の組織からお宝を横取りしようなんて、とんでもないやつらだね。何者だ\nい！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "戦いを続けていたそれぞれの勢力が、突如姿を見せた３人のちん入者を取り囲\nんでしまっている。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「ああ、もう、こんな初歩的なミスで私の魔法が台無しになってしまうなんて\n、知的ではありません！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_010021020010" ]},
	{"command":[ "SETCHARA", "0", "char_00004101_01", "7", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「もぐもぐ……ごめん。でも、お腹、すいてたから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_010021020007" ]},
	{"command":[ "SETCHARA", "0", "char_00004201_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "隊員" ]},
		{"command":[ "SETTEXT", "「待て、お前たち……手配書で顔を見たことがあるぞ！　西欧魔女協会・マジ\nックフォックスの……」", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "隊員" ]},
		{"command":[ "SETTEXT", "「トリプルクラウン、トラブルばかり起こす、道化師娘たちか！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「はぁっ？　ピコさまたちは王冠（クラウン）、道化師（クラウン）じゃない\nしっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_010021020014" ]},
	{"command":[ "SETCHARA", "0", "char_00004001_01", "7", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「……客観的に考えて、そう言われることが多いのも納得できなくはありませ\nん。こんな初歩的なミスばかり、いつもいつも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_010021020011" ]},
	{"command":[ "SETCHARA", "0", "char_00004101_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「……どんまい、ティア」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_010021020008" ]},
	{"command":[ "SETCHARA", "0", "char_00004201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
