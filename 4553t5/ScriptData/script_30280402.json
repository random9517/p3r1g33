		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「んふぁ……あぁ……はぁ、んっ、漏れちゃった……お尻の穴から精液漏れる\nの……恥ずかしすぎる……うぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0404408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……んっ、うぅぅうーっ、こんな筈じゃなかったのにっ。もっと\nあたしが色々リードするつもりだったのにっ！」", "NORMAL" ]},
