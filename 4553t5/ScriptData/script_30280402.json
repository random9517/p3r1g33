		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「や、やだ……びゅるって……出ちゃっ……あっ、お尻……閉じきれないっ、\n精液……出てきちゃう……と、止まってぇ……！」", "NORMAL" ]},
