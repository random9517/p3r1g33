		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「ホントに舐めてるだけっ……？　もっと、なにかしてるんじゃないのっ！？\n　じゃなきゃっ……こんなっ、気持ちよくなるはずっ……！」", "NORMAL" ]},
