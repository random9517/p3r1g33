		{"command":[ "SETIMAGE", "0", "still_00002804_02_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ、んっ、あぁ……お尻、まだムズムズする……あっ、だ、ダメ\n……あっ、んんんっ！」", "NORMAL" ]},
