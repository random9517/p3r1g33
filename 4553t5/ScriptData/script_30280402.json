		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「あっ……ふっ、止まった……？　射精……終わったの……ホントに……終わ\nり？」", "NORMAL" ]},
