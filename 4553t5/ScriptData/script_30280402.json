		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「何も考えなくて……いいっ……って……一方的にっ、あっ、言うなぁっ……\nはひっ、あっ、あぁんっ！」", "NORMAL" ]},
