		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「んあああぁぁっ……粘膜っ……こしゅれるっ！　オチンチンっ……かき混ぜ\nられるのっ、止まらないっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0404216" ]},
		{"command":[ "SETIMAGE", "0", "still_00002804_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「うぁぁっ、そこ、いいっ！　あっ、もっと……！　そうっ、あぁっ、それよ\nぉっ、お尻の穴……捲れちゃうのが、たまらないのっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0404217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「またっ……あっ、イキそっ……なのっ？　んっ、イッてっ……！　このまま\nっ、ズリズリオチンチン動かしてっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0404218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「あたしも、もうっ……飛ぶからっ！　アナルセックスっ……気持ちよすぎて\nっ、お尻っ……いっぱいイクからぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0404219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「はぁんっ、あぁっ、来てるっ……すごい波っ……来ちゃうのっ、あひぃぃぃ\nぃんっ、お尻っ……イクぅぅぅぅぅぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0404220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「くぅぅんっ……！　出てるっ……またっ、お尻っ……あちゅいのっ……びゅ\nくって……されてるぅぅぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0404301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002804_02_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「あぁぁ……らめっ……またイクっ……んんっ！　お尻……敏感なままぁ……\n何回もイッてるぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0404302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「あふっ、もう入り切らないから……んっ、まだ流れて来てるの……溢れちゃ\nうからぁ……あ……ふぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0404303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「んんっ……んはぁ……あっ、今……ぴゅるってした……ダメだって……これ\n以上はぁ……最後……ほ、ホントに……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0404304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……はぁ……終わった……？　う……っく……イッたかって…\n…み、見たら……分かるでしょ……イッた、わよっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0404305" ]},
		{"command":[ "SETIMAGE", "0", "still_00002804_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「んっ、あぁ……やだ、まだお尻の感覚おかしい……終わったんだから、オチ\nンチン……抜いてよ……あ、ゆ、ゆっくりだからね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0404306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「んふぅぅっ……あっ、あぉぉっ……！　あぁ……ダメっ、やっぱり待って…\n…！　いっぺんに抜いたらっ、も、漏れちゃうかもっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0404307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「んっく……だから、も、もうちょっとこのまま……んっ、うんっ、ごめん…\n…心の準備……するから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0404308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「あっ……んぅっ、オチンチンが、まだちょっとピクピクしてる……そんなこ\nとまで分かっちゃうなんて……お尻敏感過ぎる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0404309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「もう……マジで変態じゃんか……あたしをこんな風にさせて……これからも\n、ちゃんと面倒見なきゃ……承知しないからね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0404310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「ひぁぅぅぅんっ！　オチンチン……抜けてっ……あぁっ、精液っ……んぁぅ\nっ……いっぱい……掛かってるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0404401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002804_02_16" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「んぁぷっ……あたしもイクっ……ひぁんっ、イッてるのっ……熱いの掛けら\nれながらっ……お尻イキしてるぅぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0404402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「んぁぁ……顔にも……おっぱいにもぉ……んふぁ……べっとり……出てるの\n……あぁ、このネトネト……とろけるからぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0404403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「あっ、ふっ……またびゅるって……んぁぷっ……やだ、オチンチンで直接塗\nりつけるのダメだからぁ……んぁ……ふぁ……」", "NORMAL" ]},
