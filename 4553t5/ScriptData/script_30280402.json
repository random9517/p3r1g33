		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「それでもっ、恥ずかしいものは恥ずかしいんだからぁっ……はぁぁぁんっ…\n…じっと見られたらっ、もっとドキドキしちゃうっ！」", "NORMAL" ]},
