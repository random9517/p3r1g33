		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「あっ、はへぁっ……ま、まだ……いいって言ってないのにっ、オチンチン…\n…もう、動かしてるじゃないのっ……あ、あぉっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0404204" ]},
		{"command":[ "WAITINPUT" ]},

