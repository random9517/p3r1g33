{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024902_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「私ったら、またこのような恰好で……カツマ様を想いながらオナニーをする\nなど……んっ、ああっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0204101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「あんんっ……！　カツマ様のことばかり考えているせいか、カツマ様の声が\n聞こえてきますわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0204102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「まるですぐそこにカツマ様がいらっしゃるよう……なっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0204103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「か、かかっ……カツマ様っ！？　どうしてここにいらっしゃるのですっ！？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0204104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「いえ、そんなことよりも……！　もしかして今の今まで、ずっと私の痴態を\nご覧になられていたのですかっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0204105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「っ！？　こ、これは違うんですのっ！　これは、その……！　カツマ様のこ\nとを想っていましたら、オマンコが疼いてしまいまして……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0204106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「あああっ……！　やっ、ダメですわっ……！　カツマ様に見られていたら、\n接続プラグからエッチなお汁がどんどん溢れてきますわっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0204107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「カツマ様に見られているのに……指が止まりませんのぉ……！　あっ、あん\nっ！　私のオマンコ、いつも以上に感じておりますのぉ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0204108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「ああっ……！　カツマ様のオチンチンがズボンの中であんなにも大きくなっ\nて……！　とても苦しそうですわっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0204109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「あっ、あの……カツマ様っ……！　もしよろしければ、ズボンの中からオチ\nンチンを取り出してくださいませっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0204110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「そ、それから……その……！　カツマ様のたくましいオチンチンを、オマン\nコに突き挿れていただけないでしょうか……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0204111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「私……もう我慢ができませんのっ……！　カツマ様のオチンチンが欲しいと\n、子宮が訴えてきておりますのぉ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0204112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「こうしてお話してる最中でも指が止まらなくて……！　あっ、あっ……！　\n全身がビクビク震えてきますぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0204113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「お願いいたします……！　カツマ様……どうかお慈悲を……！　私のヌルヌ\nルオマンコに、オチンチンをお恵みくださいませっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0204114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「どうかこのふしだらな私と……セックスしてくださいませっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0204115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「あぁぁぁぁんっ！　オマンコに太くて硬いモノが入ってきておりますわっ！\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0204116" ]},
		{"command":[ "SETIMAGE", "0", "still_00024902_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「か、カツマ様っ……！　本当にオチンチンをお恵みくださるなんて……！　\nとても嬉しいですわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0204117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「ええ……お好きなだけ動いていただいて構いません……！　そのたくましい\nオチンチンで、思い切りオマンコをかき回してくださいませっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0204118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ！　ひっ、あはぁっ！？　最初から全力でピストンをされるなん\nてぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0204119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「カリのデコボコしたところがオマンコのヒダに引っかかって、ズリズリ擦れ\nておりますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0204120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「グッと力強くオチンチンが押し込まれると、オマンコが悦びのあまり自然と\n締まって……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0204121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「逆に引き抜かれますと、オチンチンを離したくないと言わんばかりに吸い付\nいておりますわっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0204122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「ひっ、あっ！　んはぁっ！？　私のオマンコから、さらにエッチなお汁が溢\nれてきますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0204123" ]},
		{"command":[ "SETIMAGE", "0", "still_00024902_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「オチンチンでズンズンと突かれるたびに、結合部の隙間からお汁が垂れてき\nて……！　ヌルヌルの感触がさらに強くなっておりますのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0204124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「このような快感、オナニーでは味わったことありませんわっ！　カツマ様と\nのセックスだからこその気持ちよさですのっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0204125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「あああっ！　もっと激しく突いてくださいませっ！　卑しい私のオマンコを\n、オチンチンで躾けてくださいませぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0204126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「ひぎっ！？　あっ、おおぉっ……！？　さらに奥までオチンチンが入ってき\nておりますわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0204127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「接続プラグに備え付けられた私の子宮口に、オチンチンの先端が当たるくら\nいにまで深く入って……！　んっ、あっ！　あひぃんっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0204128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「オチンチンをぐっぽりと咥え込むような悪い子にはオシオキが必要……！？\n　は、はい……！　いっぱい、オシオキしてくださいませっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0204129" ]},
		{"command":[ "SETIMAGE", "0", "still_00024902_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「あっ、んひっ……！　車両基地でこのように激しく乱れ、淫らな声を上げる\nなど……本来あってはならないことですっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0204130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「カツマ様のオチンチンで、しっかりと反省させていただきますっ……！　で\nすからどうか、もっと奥まで突いて……あんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0204131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「あっ！　んっ！　あっ！　は、はいっ！　本当に反省しておりますっ！　オ\nチンチンでしっかりと躾けられておりますぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0204132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「ですからどうか、反省の証をこの身に刻んでくださいっ！　カツマ様の濃厚\nなミルク、たっぷりと子宮に出してくださいませっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0204133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「ひっ、んひっ！？　あっ、あっ！　あはぁぁぁっ！？　オチンチンの動きが\nさらに速くなってきておりますわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0204134" ]},
		{"command":[ "SETIMAGE", "0", "still_00024902_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「それにビクビクと膣内で激しく暴れて……！　出してっ！　出してください\nっ！　私に膣内出ししてくださいーーーっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0204135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「あはぁぁぁんっ！　熱くて濃いミルクが、どぴゅどぴゅ出てますわぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0204136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024902_02_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「オマンコの奥にまでしっかりと届いて……！　子宮の方へと流れ込んできて\nおりますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0204137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「あっ、やっ、あっ！　こんなにも激しく反省の証を刻んでくださるなんて…\n…！　感激でオマンコイッてしまいますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0204138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「んんっ、ひぐっ、あっ！　んっ！　イッ、イキますわっ！　膣内出しされな\nがら、アクメを決めてしまいますのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0204139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「あああっ！　イクッ！　イキますぅ！　カツマ様に種付けされながら、イッ\nてしまいますぅぅぅっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0204140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「んっ……あっ、あふっ……！　たくさん出していただき、ありがとうござい\nました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0204201" ]},
		{"command":[ "SETIMAGE", "0", "still_00024902_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「あら……気分が乗って、強い口調になってしまったことを反省してらっしゃ\nるのですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0204202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「うふふっ……私、別に怒ってませんわ。それにカツマ様にオシオキされたり\n、躾けられたりするのは……イヤじゃありませんから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0204203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「あんっ……！　オチンチンがまた大きくなってきておりますわ……！　ひょ\nっとして、私の言葉に興奮してくださったんですの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0204204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「でしたら……もう１度オシオキしてください……この卑しく火照る身体を、\nオチンチンで躾けてくださいませ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0204205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「んぐっ、がっ、あああぁ……！　オチンチンが激しく出し入れを繰り返して\nおりますわっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0204206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「オマンコがめくれるような勢いでズンズン突かれて……！　今度は最初から\n全力でピストンされるのですねっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0204207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「は、はいっ……！　これはオシオキであり躾ですので……！　私に気を遣う\n必要はございませんわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0204208" ]},
		{"command":[ "SETIMAGE", "0", "still_00024902_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「カツマ様の好きなように動いて、私を犯してください……！　ヌルヌルのい\nやらしいオマンコを、思い切りズポズポしてくださいませっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0204209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「んひっ！　はぁ、あっ！　んっ、あああっ！　オチンチンの先端が子宮口を\n無理やりこじ開けようとしておりますわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0204210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「そんな風に突かれたら、接続プラグが破損してしまいますっ……！　そんな\nのダメなのに、先ほどよりも気持ちよくなってしまいますのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0204211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「精液のおかげで滑りもよくなっていますから……オマンコのヒダがズリズリ\nされる感覚が、さらに感じ取れますわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0204212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「カツマ様のたくましいオチンチンで犯され、躾られているのだと、超人工知\n能が学習しておりますのっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0204213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「やあああっ！　申し訳ございませんっ！　本来であればこのような学習は必\n要ありませんのにっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0204214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「ですがカツマ様のことを想うと、自然とエッチなことが身についてしまいま\nすのっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0204215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「もっといっぱいオマンコを突いてもらったり、お口でご奉仕したりして、気\n持ちよくして差し上げたくなるんですのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0204216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「あっ、んっ、ひぐっ……！？　ま、またオチンチンが大きく膨らんでますわ\nっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0204217" ]},
		{"command":[ "SETIMAGE", "0", "still_00024902_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「もう１度、射精していただけるのですね……！　この卑しい私に、反省の証\nを注いでくれるのですねっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0204218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「私の準備はできておりますわっ！　いつでも、お好きなときに精液を出して\nくださいませっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0204219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「オマンコでもお尻でも……カツマ様が望むところに、びゅるびゅる射精して\nくださいませぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0204220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「あっはぁぁぁっ！？　またオマンコの奥にザーメンが注ぎ込まれております\nわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0204301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024902_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「先ほどと違って、オチンチンが子宮口とキスをしながら射精されて……！　\nカツマ様の子種が、直接子宮に注がれておりますわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0204302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「お腹の奥が満ちていく感覚がたまりませんのぉ！　幸せな感じがオマンコか\nらどんどん溢れてきて……！　あああぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0204303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「か、カツマ様ぁ！　どうか溜め込んでおります精子を、全て私の子宮に出し\nてくださいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0204304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「反省を促すと共に、私がカツマ様のモノであることを、しっかりと刻み込ん\nでくださいませぇっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0204305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「あっ……んっ、あっ……！　はぁ、くっ……あふっ……たくさん出ましたわ\nね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0204306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「うふふっ……オマンコに収まりきらなかった精子が、どんどん溢れてきてい\nますわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0204307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「カツマ様……私のお願いを聞いてくださり、本当にありがとうございます…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0204308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「こうして肉体的な繋がりを持てたおかげで、私の心も身体も、カツマ様のモ\nノになれた気がいたします……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0204309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「これからも誠心誠意お仕えいたしますので……どうぞ、よろしくお願いいた\nしますわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0204310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「あっ、んひっ！？　熱いのがお尻にかかっておりますわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0204401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024902_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「カツマ様の真っ白なミルクが、今度は私の身体にかかって……！　装甲の隙\n間に入り込んでいきますのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0204402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「オマンコと身体の両方に精子を注がれるなんて、とても光栄ですわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0204403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「くっ、んっ！　あっ、あんんっ！　そのまま、カツマ様の精子で私のボディ\nを真っ白に染め上げてくださいませっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0204404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「私がカツマ様のモノであると、超人工知能にしっかりと学習させてください\nーーーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0204405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……濃厚な香りが……こちらにまで漂ってきておりますわ……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0204406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「うふふっ……カツマ様が謝る必要なんて一切ございませんわ。これは全て、\n私が望んだことですので……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0204407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「こうしてカツマ様と結ばれ、精液で染め上げられるなんて、ロボット冥利に\n尽きるというものですわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0204408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「あ、あら……あれだけ出されたのに、まだオチンチンが大きいままなんです\nの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0204409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「うふふっ。勿論お付き合いさせていただきますわ。カツマ様が望むことは、\nどんなことでも叶えて差し上げたいので……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0204410" ]},
