		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「ひぃうっ、あはぁぁっ……いいっ、気持ちいいわ……この圧迫感、堪んない\nのぉ……んっ、んんぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0204102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「隊長のチンポが……私のマンコを貫いてぇ……奥をゴツゴツ突いてきて、子\n宮揺らされちゃう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0204103" ]},
		{"command":[ "SETIMAGE", "0", "still_00006702_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「あはっ、んぁぁっ！　こ、こんなの知らない……！　こんな感覚、初めてで\n……はっあっ、身体がおかしくなっちゃいそうっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0204104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「あぁ、隊長っ……隊長のチンポ、本当に素敵よ……私の中にぴったりハマっ\nて、とろけて一つになってるわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0204105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「もう、この感じだけでイキそう……！　んっ……というか、もう何回か、軽\nくイってるわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0204106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「た、隊長は……どう？　私のマンコの具合は？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0204107" ]},
		{"command":[ "SETIMAGE", "0", "still_00006702_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「ふふ、よかった……楽しんでもらえてるみたいね……確かに、そうじゃなか\nったら、こんなに勃起してないわね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0204108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「あぁっ……それにしても、本当に硬くて、大きくって……女泣かせのチンポ\nね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0204109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「あっ、あんっ……！　ダメよ、私が動くから……隊長は、おとなしくしてて\nちょうだい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0204110" ]},
		{"command":[ "SETIMAGE", "0", "still_00006702_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「だって、こんなエロチンポで好き勝手に突きまくられたら……すぐにイっち\nゃうわ……だから、私に任せて……ね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0204111" ]},
		{"command":[ "SETIMAGE", "0", "still_00006702_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「大丈夫よ、ちゃんと気持ちよくしてあげるから……はっ、はっ……んっ、ほ\nら……どう、かしら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0204112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「あっ、あふぅっ、んっくっ……！　あぁっ……すごいっ、まだ軽く動いてる\nだけなのにぃ……チンポが擦れるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0204113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「はっはあっ！　あんっ！　え、えぐ、られるっ……ぶっといカリで、マンコ\nかき回されて……感じちゃうぅぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0204114" ]},
		{"command":[ "SETIMAGE", "0", "still_00006702_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「んっ、んっ、んんっ……勝手に腰が、跳ねて……チンポ咥え込んで、悦んで\nるっ……あっ、あぁぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0204115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「はぁ、あぁっ！　圧迫感すごいっ……よすぎて、マンコがヒクヒク震えて…\n…んっ、ンあぁあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0204116" ]},
		{"command":[ "SETIMAGE", "0", "still_00006702_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「なん、ですか……？　水着だから……おっぱい揺れてるのが、丸見えで……\nエロい……？　も、もぉ……隊長ったら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0204117" ]},
		{"command":[ "SETIMAGE", "0", "still_00006702_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「隊長が着てこいって言うからぁ……あっ、あんっ……！　こんな恥ずかしい\n恰好で……はひっ……ひぃいっ、あぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0204118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「は、裸になるより……なんか恥ずかしいの……そういうもの、で……あんっ\n！　あぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0204119" ]},
		{"command":[ "SETIMAGE", "0", "still_00006702_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「もうっ……ニヤニヤしながら、こっちを見つめないで……んっ、んんっ……\n本当にスケベなんだからぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0204120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「あんっ！　ひぃっ、ああっ！　急にどうしたのっ……んあっ！　突き上げな\nいでっ……はっあっあぁっぁあっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0204121" ]},
		{"command":[ "SETIMAGE", "0", "still_00006702_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「……ひっ、ひぃううっ！　あっ、あはっ！　い、今、動いちゃダメって……\n言ってるのにぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0204122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「ひぐっ！　んっ、んひぃいっ！　あぁあっ！　も、もう我慢できない？　そ\nんなっ……だめ、だめぇぇっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0204123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「あぁぁっ！　はっああっ！　し、下から突き上げられてぇっ……奥に亀頭が\n、ガンガン当たってるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0204124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「あんっ、はぁあんっ！　も、もうイクっ……イっちゃうっ……！　た、隊長\n……お願いだから、もう少し……優しくっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0204125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「このまま？　イっていい？　隊長も、もうすぐだから……？　あっ、あはぁ\nっ……わ、わかったわ……んぁぁあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0204126" ]},
		{"command":[ "SETIMAGE", "0", "still_00006702_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「はっはひっ！　ひぃいっ、ひぃぃんっ！　激しいっ……！　チンポが、奥に\nくるぅっ……子宮まで届いてるのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0204127" ]},
		{"command":[ "SETIMAGE", "0", "still_00006702_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「た、隊長、まだ？　まだ出ないの？　早くしないと……私もう我慢が……あ\nっ、あぁっ……はぁぁぁぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0204128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「ひっ、はひぃいっ！　お、おくっ……押し上げられてぇっ！　んっ、ああっ\n！　堪んないのっ……あっ、あぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0204129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「イ、イクっ……イクイクイクぅっ！　隊長も出してっ！　な、なかっ……私\nのマンコに思いっきり中出ししてぇぇぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0204130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「んあぁぁぁぁぁあぁ～～～っ！　はっ、はひっ！　いいっ、いいのっ……い\nっ、いいぃぃっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0204131" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00006702_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「ひぃあっ、ああぁっ……！　ザーメンが、ドクドク流れ込んでくるぅっ……\n！　あ、熱いのっ……すごい勢いでぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0204132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「はっ、はあっ！　あひっ……チンポが脈打って……んっあぁっ……！　マン\nコが、いっぱいになって……ひっ、ひぃうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0204133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「子宮に当たってる……ザーメンぶっかけられてるっ！　マンコの中で、隊長\nのザーメンがっ……たくさん……んんぅっ、んはぁあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0204134" ]},
		{"command":[ "SETIMAGE", "0", "still_00006702_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「気持ちいい……中出しアクメ気持ちいいっ……！　あっあっ、あくっ……あ\nひっ、いぃぃっ……！　あっ……あはぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0204135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「はぁはぁ……はーっ……は、あふっ……んぁ……す、すごい量ね……お腹が\nパンパンになってるわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0204136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「んっ、あぁっ……イキすぎて、ちょっと動けない……かも……ふぅ、はふぅ\n……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0204137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「隊長は……なんか、チンポ……まだ全然硬いままね……ひぃうっ……中で、\n元気に動いてるわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0204138" ]},
		{"command":[ "SETIMAGE", "0", "still_00006702_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「んあっ！　わかってるわ……一回で終わる、つもりはないわよ……隊長が満\n足するまで、付き合うから……ちょっと休憩させて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0204139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「ひゃうっ！　ま、待って……てばっ！　ええっ……ま、待てない？　そんな\nこと言われても……んっ、あぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0204140" ]},
		{"command":[ "SETIMAGE", "0", "still_00006702_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「あっ、あんっ……！　ちょ、ちょっと……ひぐっ！　はっ、はひぃいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0204201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「あぁんっ！　抜かずに連続で、なんて……すごいっ……んっ、はぁぁっ！　\nひっ、はあっ！　あふぅっ……んんっぅぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0204202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「い、いまさっき……イったばかりで……その感触が残ってるのにぃ……あぁ\nっ！　痺れてるマンコかき回すのダメぇっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0204203" ]},
		{"command":[ "SETIMAGE", "0", "still_00006702_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「はぁあっ、あぁんっ！　か、感じすぎちゃうっ！　はっ、はっ、あっはぁっ\n……！　ひっ、ひいぃぃっ！　チンポすごぃいっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0204204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「た、隊長ぉ……あっ、あんっ！　激しい、激しすぎるっ……んぅうぅぅっ！\n　ひぃ、ひぃいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0204205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「あぁ、もう好きにしてっ！　隊長の思うように……動いてっ……ひぃいっ！\n　んっ、んはっ！　あっ、あっあぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0204206" ]},
		{"command":[ "SETIMAGE", "0", "still_00006702_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「んあぁぁぁっ！　す、すごいっ！　腰が浮いちゃうっ……んっ、おっおおっ\n……！　はっ、んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0204207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「チンポぉ……チンポいいっ！　隊長のチンポで……ガンガン突き上げられて\nぇっ！　マンコいくぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0204208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「は、はひっ……わかる、マンコぐちょ濡れになってるのわかるわっ……！　\nチンポが気持ちよすぎて、ヨダレ止まんないのぉっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0204209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「恥ずかしいっ、音っ……いっぱい鳴ってる……！　スケベな音がっ……あん\nっ！　あっ、あぁぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0204210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「あひぃっ！　あっあひっ！　チンポぉっ！　チンポ好きっ！　も、もっとっ\n……もっと欲しいっ！　恥ずかしいのに……気持ちいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0204211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「た、隊長は？　私だけ感じても意味ないの……一緒にイキたいっ！　んっ、\nんはっ！　ああっ！　お、お願いっ……だからぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0204212" ]},
		{"command":[ "SETIMAGE", "0", "still_00006702_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「激しくしていいから、イって！　一緒にイってぇっ！　またザーメンを……\nどぴゅどぴゅって、出して一緒にアクメしてぇぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0204213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「んっ、ンンっ！　はっ！　あんっ！　ひっ、ひぃっ！　い、いいっ！　チン\nポいいっ！　チンポでイかせてぇっ！！」", "NORMAL" ]},
