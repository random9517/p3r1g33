		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「あぁあぁっ！　く、くるぅっ！　きちゃうっ！　はっ、はひっ……また大き\nいの……きちゃうぅぅぅっ！」", "NORMAL" ]},
