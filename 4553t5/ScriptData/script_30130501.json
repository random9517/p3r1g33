		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「あ、あの……ちょっと、待って下さい……そんなに慌てなくても……身体の\n制御がっ……っく……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0503101" ]},
		{"command":[ "SETCHARA", "0", "char_00001305_01", "5", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「きゃっ……！　もう、どうしたんですか……融合変身してまで、お仕置き部\n屋に来て……えっ、色々我慢できなくなって……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0503102" ]},
		{"command":[ "SETCHARA", "0", "char_00001305_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「もう……それならそうとちゃんと言って下さい。いきなりでしたから、何事\nかと思いましたけど……とにかく分かりました、それでは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0503103" ]},
		{"command":[ "SETCHARA", "0", "char_00001305_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……こ、こんな感じで……いいですか？　普通に言ってくれたら\n、びっくりしなかったのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0503104" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001305_01_01" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「あ、いえ……でもいいんです。その、合体している時って相手の感覚も伝わ\nってきて……つまり、その私も、実は……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0503105" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「は、はい……正直、ムラムラしてたと言いますか……一歩間違えたら、私の\n方が貴方を押し倒していたかも知れません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0503106" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「そんなわけですから……えっと、パイズリで……オ、オチンポ……気持ちよ\nくして……いきますね？　んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0503107" ]},
		{"command":[ "SETIMAGE", "0", "still_00001305_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「はふっ、んんっ……んくっ……あっ、やっぱり……んっ、ビクって……ちょ\nっと震えるんですね……あふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0503108" ]},
		{"command":[ "SETIMAGE", "0", "still_00001305_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「合体してる時に……その、大きくなったらどうなるのかなって……股間の感\n覚が少しだけ気になって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0503109" ]},
		{"command":[ "SETIMAGE", "0", "still_00001305_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「い、いえ、そこまで強く意識していたわけではっ……とにかくっ、あの……\n舐めていきますからっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0503110" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「んっ、ぴちゃ……ちゅぱ……れろ、んちゅっ、ちゅぷ……ぴちゃ……んちゅ\n……ん、ふっ……れる、れりゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0503111" ]},
		{"command":[ "SETIMAGE", "0", "still_00001305_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「はぁ……谷間の中で、ずっと動いています……こんなに腫れてるみたいに…\n…苦しくないんですか？　れろ……ちゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0503112" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「敏感で……落ち着かないけど……苦しくはない……とにかく、気持ちいい…\n…そ、そうなんですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0503113" ]},
		{"command":[ "SETIMAGE", "0", "still_00001305_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「もし合体してる時に試したら……って、それはできないんでした……いえっ\n、貴方以外のオチンポをするなんて絶対考えられませんから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0503114" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「だから、それは貴方の反応で推測することにします。ちゅぱ……ぴちゃ、ん\nちゅっ……れろ、この辺……いかがですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0503115" ]},
		{"command":[ "SETIMAGE", "0", "still_00001305_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「よかった……ちゃんと感じてくれてるみたいですね……んふっ、私も嬉しい\nです……もっとオチンポに喜んで欲しいですから……ちゅぱ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0503116" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「んふっ、先端……亀頭のところ……キスしちゃいますね……ちゅっ……あん\nっ、ふふっ、こんなに跳ねて……すごく可愛い……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0503117" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「真ん中の部分も……もっと感じて欲しいです……いやらしく、おっぱいを動\nかして……あっ、ふっ……やん、乳首が……擦れちゃう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0503118" ]},
		{"command":[ "SETIMAGE", "0", "still_00001305_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「うんっ、んんっ……もしかして、貴方にも……私がドキドキしていたこと…\n…伝わっていましたか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0503119" ]},
		{"command":[ "SETIMAGE", "0", "still_00001305_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「その、こっそりエッチなことを考えていたりとか……身体……もじもじさせ\nていたりとか……だとしたら、は、恥ずかしいですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0503120" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「よく分からなかった……そ、そうですか。え……？　でも、元々好きそうっ\nて……も、もうっ、私のことをそんな風に思ってたんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0503121" ]},
		{"command":[ "SETIMAGE", "0", "still_00001305_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「それなら……こ、こうですっ。ちゅぱっ、ぴちゅっ……んっちゅ……れる、\nれろぉんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0503122" ]},
		{"command":[ "SETIMAGE", "0", "still_00001305_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「だって、私はスケベなんですから……貴方のオチンポをこうして……舐め回\nしたくて仕方ないんです……れる、れろ、んちゅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0503123" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「おっぱいだって、こうして……んっ、ふっ……形が変わる位に、大胆に……\n動かしちゃうんですから……はぁっ、んふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0503124" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「あぁっ……オチンポ、谷間の中でずっと震えてます……！　熱くて……んっ\n……汗が滲んで……んっ、滑りがよくなって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0503125" ]},
		{"command":[ "SETIMAGE", "0", "still_00001305_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「はぁっ、んくっ、すごい……あふっ、あぁ……私のおっぱいも、ずっと気持\nちいい感じが続いてます……あっ、くうんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0503126" ]},
		{"command":[ "SETIMAGE", "0", "still_00001305_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「はぅ……んっ、止まらない……んんっ、乳首も、あぁ……コリコリって……\nやっ、擦れると……頭……蕩けちゃいそうで……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0503127" ]},
		{"command":[ "SETIMAGE", "0", "still_00001305_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「んっ、ちゅっ、はぷっ、んぁ……りゅぷっ、れろ……んりゅっ……あぁ、エ\nッチな顔なんて……い、言わないで下さい……恥ずかしいです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0503128" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「でも、自分でも分かります……こんなに舌を伸ばして……オチンポを一生懸\n命舐めて……絶対いやらしい顔しちゃってます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0503129" ]},
		{"command":[ "SETIMAGE", "0", "still_00001305_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「んっ、ちゅぱっ……あぁ……でも、こんな大きくて立派なオチンポを見せら\nれたら、そうなるのは仕方ないんです……ちゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0503130" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「じゅるる……涎も、溢れて……あぁ、おっぱいの中が……色んな汁でいっぱ\nいになって……んぁ……亀頭からカウパーまで滲んで来ました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0503131" ]},
		{"command":[ "SETIMAGE", "0", "still_00001305_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「はっ、ふっ、これ……もう少しで出そうですか……？　はぁ、んっ……そろ\nそろ射精……しちゃいますよね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0503132" ]},
		{"command":[ "SETIMAGE", "0", "still_00001305_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「んっ、ちゅぷっ、だったら……の、飲ませてもらえますか……？　私が……\nそうしたいんです……りゅぱっ、じゅるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0503133" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「もっと、おっぱい……激しくしますからっ……亀頭にまたキスもしますっ、\nちゅぷっ、はいっ、出して下さい……口にっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0503134" ]},
		{"command":[ "SETIMAGE", "0", "still_00001305_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「はむぅっ、このままれふっ……！　貴方の……濃いのっ、直接っ……くらひ\nゃいっ、精液っ……飲ませへぇぇっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0503135" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「んんんんんーっ！　んぐっ、んっ、んくっ、んっ……ふっ！　れてっ……ん\nっ、ま、ひゅっ……んくぅんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0503136" ]},
		{"command":[ "SETIMAGE", "0", "still_00001305_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「こくっ、んくんっ……ふごい……勢い……んんっ、口の中……溢れひゃいそ\nうれふ……んんっ、んっく……ん、くんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0503137" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「はぁぁ……はひ、ありがとうごらいまひた……んっ、何とか……飲めたと思\nいます……まだ、少し喉に残ってますけど……けふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0503138" ]},
		{"command":[ "SETIMAGE", "0", "still_00001305_01_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「ふぁぁ……もう、エッチな気持ちが収まらなくて……図々しいおねだりしち\nゃいました……んふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0503139" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ、でも、美味しかったです……んふっ、貴方の精液の味……私、も\nうクセになっちゃってるみたいです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0503140" ]},
		{"command":[ "SETIMAGE", "0", "still_00001305_01_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「はぁ……はふ……あぁ、これで火照りが収まってくれるかと思ったんですけ\nど……まだ、ダメみたいです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0503201" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「だって、おっぱいの中でまだこんなにオチンポが熱いままで……もっと、こ\nの熱を感じたいって……続けても、いいですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0503202" ]},
		{"command":[ "SETIMAGE", "0", "still_00001305_01_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「はい……ありがとうございます。んっ、じゃあ……もっと唾液……垂らしち\nゃいますね……んっ、れろぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0503203" ]},
		{"command":[ "SETIMAGE", "0", "still_00001305_01_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「ぴちゃ……んちゅっ、さっきより、もっと積極的におっぱいの方を動かして\nいきますね……こうして、んっ、縦に……ずりずりって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0503204" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「はっ、あぁっ、あふっ……精液のぬめりが……あっ、手伝ってくれてます…\n…はぁんっ、肌が擦れると……気持ちよくて……あっ、んぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0503205" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「うんっ、ふっ、オチンポの脈動を……すぐ近くで感じます……ドキドキして\n……ごくっ……んっ、また……キスしますから……ん、ちゅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0503206" ]},
		{"command":[ "SETIMAGE", "0", "still_00001305_01_11" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「れろ……あむ、ぴちゃ……我慢できないです……もっと欲しい……れろ、ち\nゅぷっ……んふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0503207" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「んんっ、精液の味……してます……れろ、りゅぷっ……ダメ、これを味わっ\nちゃうと……私まで濡れて来ちゃうの……んっ、りゅぷっ、んふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0503208" ]},
		{"command":[ "SETIMAGE", "0", "still_00001305_01_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「でも、今はご奉仕の方が先……んっ、もっとオチンポペロペロして……また\n、いっぱい出してもらいたいですから……ちゅぷ、んりゅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0503209" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「んふっ、ビクってしましたね……ここ、かなり感じやすい場所なんですか？\n　ちゅぷっ、んちゅっ……ぴちゃ……んちゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0503210" ]},
		{"command":[ "SETIMAGE", "0", "still_00001305_01_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「あっ……腰が浮き上がっちゃいますね……そしたら……金玉の方も……柔ら\nかく握ってあげますね……ぎゅうっと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0503211" ]},
		{"command":[ "SETIMAGE", "0", "still_00001305_01_11" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「ふふ、どうですか？　力が抜けてちゃうでしょう？　ちゅぱっ、くぷっ、ん\nちゅぷっ……可愛らしい反応れふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0503212" ]},
		{"command":[ "SETIMAGE", "0", "still_00001305_01_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「たっぷり精液を出したばかりですから……新しい分を作ろうと、一生懸命働\nいているんですよね……れろ、もご……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0503213" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「そんな活発な金玉を……今度は……もごっ、くぽっ、口の中れ……転がしち\nゃいまふよぉ……むぐぅ……くぷっ、りゅぽっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0503214" ]},
		{"command":[ "SETIMAGE", "0", "still_00001305_01_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「ふぉら……ガクガクして……んふっ、気持ちいいですね……れろ、ちゅぱっ\n……じゃあ、改めて……先端のして欲しいところ……れろっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0503215" ]},
		{"command":[ "SETIMAGE", "0", "still_00001305_01_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「はい……焦らないで、じっくりとオチンポ全体を痺れさせるように……ちゅ\nぷっ、じわじわ気持ちいい感覚を広げていきますよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0503216" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「すぐ出したいのをちょっとだけ我慢したら……ドピュって……すごく気持ち\nいいと思いますよ……じゅぷっ、んちゅぷっ、りゅぷぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0503217" ]},
		{"command":[ "SETIMAGE", "0", "still_00001305_01_11" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「はぁ……ぴちゃ、またカウパーが浮いてます……後もう少し……んっ、おっ\nぱいを強く寄せて……はぁっ、んっ、ふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0503218" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「限界ですか……？　はい、どうぞ……出して下さい……お好きなところに、\n貴方の濃いのをっ……また思いっきり出してっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0503219" ]},
		{"command":[ "SETIMAGE", "0", "still_00001305_01_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「ちゅぷっ、はぅんっ、私も……あっ、おっぱい……気持ちよくてっ……この\nままっ、んんっ、イキそうですっ、んっ、ふぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0503220" ]},
		{"command":[ "SETIMAGE", "0", "still_00001305_01_12" ]},
		{"command":[ "WAITINPUT" ]},

