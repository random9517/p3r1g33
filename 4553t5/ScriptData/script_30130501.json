		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「ふぐっ……！　んふぅぅっ……！　んぐっ、あぷっ……まら、たくさん……\nれてっ……んっ、んくんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0503301" ]},
		{"command":[ "SETIMAGE", "0", "still_00001305_01_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「溢れて……んんっ、飲みきれない位……トロっとしたのが……んっ、じゅる\nっ、ちゅぷっ、こくんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0503302" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「大丈夫です……んっ、ちゃんと全部飲めそうです……ゆっくり味わって……\nはふぁ……ちゅぱっ、んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0503303" ]},
		{"command":[ "SETIMAGE", "0", "still_00001305_01_14" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「ふはっ、ほら……全部飲めました……私の為に出してくれたんです、残すな\nんて失礼でもったいないこと、できませんから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0503304" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「んっ……まだおっぱいの中でオチンポが小さく震えてます……今、お掃除も\nしちゃいますね？　ぴちゃ、れろ、ちゅぱ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0503305" ]},
		{"command":[ "SETIMAGE", "0", "still_00001305_01_13" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「後少しだけ奥に残ってる分も、吸い上げちゃいますから……んちゅぅぅぅ…\n…ぴちゃ、んちゅぷ、ちゅぱ……はふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0503306" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「はい、奥にある分まで頂いてしまいました……ふふっ、私、案外欲張りだっ\nたみたいです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0503307" ]},
		{"command":[ "SETIMAGE", "0", "still_00001305_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「でも、やっぱり感覚を共有していると、このムラムラした感じも分かっちゃ\nうんですね……これからは気をつけておかないと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0503308" ]},
		{"command":[ "SETIMAGE", "0", "still_00001305_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「えっ……すぐ分かるから、いつでも呼んで……いい……あ、は、はい……そ\nう、ですね……それは、確かに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0503309" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「では、そうなったら……今度は私からお願いしてしまうかも、知れません。\nその時は……えと、よろしくお願いします……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0503310" ]},
		{"command":[ "SETIMAGE", "0", "still_00001305_01_02" ]},
		{"command":[ "WAITINPUT" ]},
