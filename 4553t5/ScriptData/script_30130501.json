		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「もう知ってる癖に……私……貴方が思っている以上にエロいんですよ……？\n　だから、これからもしっかり気をつけていて下さいね」", "NORMAL" ]},
