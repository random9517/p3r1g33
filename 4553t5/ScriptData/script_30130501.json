		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「ふぁっ……！　はぁんっ……オチンポっ、顔に……はぷっ、精液っ……掛か\nって……ますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0503401" ]},
		{"command":[ "SETIMAGE", "0", "still_00001305_01_17" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「あぁ……鼻の頭のところに……んっ、頬にもヌルヌルが来て……ちゅぷっ、\nんちゅぅ……すごい勢い……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0503402" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「はひ……もっと掛けて下さい……んっ、いっぱい浴びたいです……貴方の精\n液……直接……んふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0503403" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「んっ……口の中でも感じましたけど……本当にねっとりして、糸をすごく引\nいて……密度があるんだろうなって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0503404" ]},
		{"command":[ "SETIMAGE", "0", "still_00001305_01_16" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「ちゅぷっ……喉に絡まるような感じで、飲み込むのもちょっと大変な位です\n……んふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0503405" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「あ……落ち着きましたね。じゃあ、後はお掃除させて下さい……ぴちゃ、綺\n麗にしてあげないと……ちゅぷ、んちゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0503406" ]},
		{"command":[ "SETIMAGE", "0", "still_00001305_01_18" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「んふ……オチンポ震えてます……やっぱり出した直後は敏感ですよね……ん\nちゅっ、ちょっと可愛いです……ぴちゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0503407" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「はい、いいですよ。後は、私の顔についた分も……綺麗にしないと……れろ\n、ちゅぱ……」", "NORMAL" ]},
