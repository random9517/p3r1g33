{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0138" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "……そして俺達一同は、祭りの当日に明日楽に改めて呼び出された。", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「それで、前に言ってた提案したいこと……っていうのがコレなのか？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「ええ。ヤムさん、イルルさんに浴衣を着せてあげたかったんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020022710001" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "と見せられた浴衣にイルルが歓声をあげる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「わぁ……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010022710001" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おお、ありがとな。ほら、二人ともちゃんとお礼を言うんだぞ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「あ、ありがとうございます、明日楽おねーさん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010022710002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「いいえ。この程度、さしたる労力でもありませんでしたから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020022710002" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「あ……ありがと」　", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010022710002" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「二人にそこまで喜んでもらえたら、私も準備したかいがありますね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020022710003" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「これは私のおさがりですけど……衣装部の生徒たちに声をかけてアレンジし\nてもらったものです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020022710004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「わぁ……とってもきれい。これがゆかた……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010022710003" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「あのね……イルル、とってもとってもうれしいです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010022710004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ヤムもヤムもっ！　祭りだけじゃなくてユカタまで貸してくれるなんて……\n明日楽ってホンット～にイイ人！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010022710003" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「そ……そうですか。気に入ってくれたのなら嬉しいです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020022710005" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「それで、明日楽のユカタはどこ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010022710004" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「えっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020022710006" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ヤム達だけユカタで明日楽はこのままとかありえなくない？　どこにあるの\n？　明日楽センセーのユカタ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010022710005" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「いや、私は……あくまで監督者で、祭りの参加者ではありませんし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020022710007" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "と、すかさず断ろうとした明日楽だが……ヤムとイルルは期待の目をやめず、\n容赦なく明日楽に詰め寄った。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「明日楽もユカタ着て！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010022710006" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「うっ……で、でも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020022710008" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「びじんさんだから、ゆかた……よく似合うとおもう。……だめですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010022710005" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「どーっしても皆でいっしょがいいの！　おねがぁい……。今日だけワガママ\nきいてほしい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010022710007" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「……仕方がないですね。そこまで言うのならば、こ……今回だけですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020022710009" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「やぁーったぁ！　これでみーんなオソロだね！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010022710008" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「うん、うん。それがいいよ。みんなでおそろいで、しあわせ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010022710006" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0138" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ってことで～！　じゃっじゃぁ～ん♪　どーお？　パーパ♪　イケてるでし\nょ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010022710009" ]},
		{"command":[ "SETCHARA", "0", "char_00017503_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「だいすきなおとーさんといっしょにおまつり……イルル、とってもとーって\nもうれしい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010022710007" ]},
		{"command":[ "SETCHARA", "0", "char_00016404_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "浴衣をお披露目してテンションが上がったのか、ドラゴン娘たちは嬉しそうに\nはしゃいでいる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「フフ……。あなた達は本当に無垢で、純粋で……清楚な浴衣が良く似合いま\nすよ。それに比べて私は……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020022710010" ]},
		{"command":[ "SETCHARA", "0", "char_00001603_01", "2", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「浴衣を美しく着こなすには邪魔な、胸の膨らみが大きくて……みっともない\nというかなんというか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020022710011" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "困ったように微笑む明日楽に、俺は率直な感想を述べた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そんなことないって。似合ってると思う」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「い、いきなり何を言うのよ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020022710012" ]},
		{"command":[ "SETCHARA", "0", "char_00001603_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや……そう思ったから口に出しただけだけど」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「わ、私なんて……そんな……。んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020022710013" ]},
		{"command":[ "SETCHARA", "0", "char_00001603_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "目をそらし、頬を赤らめて恥じらいはじめた明日楽と俺のただならぬ雰囲気を\n感じ取ったのだろう。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ヤムとイルルが、同時に俺の両腕をそれぞれ右、左に引っぱった。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「……イルルのゆかたは、どうですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010022710008" ]},
		{"command":[ "SETCHARA", "0", "char_00016404_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「もっとヤムの浴衣もよく見てよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010022710010" ]},
		{"command":[ "SETCHARA", "0", "char_00017503_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「待て待て待て。そんなに全員一度に見られないから」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「じゃあヤムから見て！　これ、めっちゃカワイイでしょ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010022710011" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「うん。すごくかわいい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010022710009" ]},
		{"command":[ "SETCHARA", "0", "char_00016404_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「へ！？　ば、バッカじゃないの？　アンタだってカワイーし……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010022710012" ]},
		{"command":[ "SETCHARA", "0", "char_00017503_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「でも……。うん。そーね、ヤムが一番だってパパが言ってくれたら……それ\nって最高に嬉しい……かも」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010022710014" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「どうしたら、おとーさん好みになれる？　おしえて！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010022710011" ]},
		{"command":[ "SETCHARA", "0", "char_00016404_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「そんなことより、パパぁ！　ヤムが一番でしょ！？　そーでしょ！？　うん\nって言って……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010022710015" ]},
		{"command":[ "SETCHARA", "0", "char_00017503_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「一度に喋るな！　もう、どっちがどっちだか……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "二人のドラゴンに奪い合われ、いつしかその手の力が増していく。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お、おいっ！　裂ける裂ける裂ける！　俺の腕がああああああ！！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「いやはや、アオハルですなぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022710001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「アオハルですねぇ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_020022710001" ]},
		{"command":[ "SETCHARA", "0", "char_00003002_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "うんうんと満足気にうなずくジュンジローと牛神様を俺はギロリと睨みつけた\n。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「浸ってないで助けてくれええええっ！　肩が外れるぅうううう！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}