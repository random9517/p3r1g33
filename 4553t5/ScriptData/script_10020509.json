		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「いくわよっ、ゴレイジョーボール！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113500001" ]},
