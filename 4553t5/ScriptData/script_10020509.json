		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「はいっ、ゴレイジョーボール！　モモイロ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020113500001" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「受け取ったっ！　ラベンダー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130113500001" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「まかせてっ！　ローズ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010113500001" ]},
		{"command":[ "SETCHARA", "0", "char_00001205_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「決めなさいっ！　ピンクッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020113500001" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「はぁぁっ！　ゴレイジョーアターック！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113500002" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「ぐわぁぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020113500001" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「……って、本番だと煙幕？　スモークが炊かれてあたしが退場する、と」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020113500002" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「やったね、決まったよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010113500002" ]},
		{"command":[ "SETCHARA", "0", "char_00001205_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「うん、タイミングもばっちり」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130113500002" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「やりましたね、ルルーナさん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020113500002" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「本当、なんていうか、初日に比べたら別人みたいよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020113500002" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「ふふ。ありがとうございます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113500003" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「それにしても驚きました。まさか台本やセリフの改変が許されるなんて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020113500003" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「そうだよね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010113500003" ]},
		{"command":[ "SETCHARA", "0", "char_00001205_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「ルルーナさん、ここの部分は台詞が違いますよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020113500001" ]},
		{"command":[ "SETCHARA", "0", "char_00002602_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「はい。でも、レイジョーピンクならこのような台詞になると思いました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113500004" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「だから、勝手に台詞を変えたと？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020113500002" ]},
		{"command":[ "SETCHARA", "0", "char_00002602_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「私は気づいたんです。レイジョーピンクは台本の中にいない。ステージにい\nるんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113500005" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「いまステージにいるのは私です。レイジョーピンクは私であり、私がレイジ\nョーピンクなんです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113500006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「なるほど……それがあなたの見つけてきた答えなのですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020113500003" ]},
		{"command":[ "SETCHARA", "0", "char_00002602_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「いいでしょう。ほかの皆さんも、自分のやりやすいように台詞や演出を変え\nていってください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020113500004" ]},
		{"command":[ "SETCHARA", "0", "char_00002602_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「この台本に縛られず、劇をいいものにしていきましょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020113500005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「でも、真のヒロインの座は渡さないわ。ラストの投票で選ばれるのは私なん\nだからっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020113500003" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「わたしも負けないよっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010113500004" ]},
		{"command":[ "SETCHARA", "0", "char_00001205_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「ええ、望むところです。私だって負けません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113500007" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "「そして、時は一気に学園祭当日へと飛ぶのだァッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_999_010113500003" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "sbg_0000" ]},
