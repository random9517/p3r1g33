{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「……隊長さぁん？　うちのこと……この部屋に呼んでくれてありがとう♪　\nうん、ちょうど歌の練習終わったところやったから、暇やったよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0204101" ]},
		{"command":[ "SETCHARA", "0", "char_00019802_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「それに……うちね。こうして呼んでもらうん、本当はずーっと待ってたん。\nなんでかわかる？　そや。あんさんが、うちのこと開発し続けるもんやから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0204102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「……こんなになってもぉた♪　はぁ、はぁ……♪　ヘンタイだって思わんと\nいて。あんさんが悪いんよ♪　うちのこと誘惑し続けるから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0204103" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00019802_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「どうしても子作りしたくてたまらなくなってしもたんよ。っぁ……♪　見え\nるぅ？　もうな、呼ばれた瞬間からずっと濡れとって……危険やの♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0204104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「愛液が糸引いて、たらたら下着に溢れてくるし……。アソコがウズウズして\n我慢できへん。あっ♪　こうやって、視線を感じるだけで……あかん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0204105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「も、もぉ、欲しくて欲しくて身体中がかーっと燃え上がってしまうん。毎日\n考えてたんよ、隊長さぁんのこと、……逞しいチンポのこと……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0204106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「な、なぁ……。悪いようにはせぇへんから、うちのこと思いっきり犯してく\nれへん？　ええやろ？　な？　そっちに損なんか一つもないやん～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0204107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「うち、もう辛抱たまらへん……♪　このまま焦らされたら、頭おかしくなっ\nてまうぅ……♪　赤ちゃん……欲しいんよ。絶対迷惑かけへんからぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0204108" ]},
		{"command":[ "SETIMAGE", "0", "still_00019802_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、そのチンポ、ちょこーっと貸してくれるだけでええの♪　な？\n　うちのオマンコ……今最高に仕上がってるし、気持ちええと思うわぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0204109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「ヌルヌルに濡れて、肉棒ぜーんぶあったかく包みこむ粘膜……♪　うちのア\nツアツの体温感じながら、たくさんのヒダヒダに締めつけられる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0204110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「全力でチンポにご奉仕するからぁ♪　うちのオマンコはあんさん専用なんや\nから……使ってくれないとややわぁ♪　お願い……入れて、犯してぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0204111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「……あうッ♪　んぁうううううぅ……！？　あっ♪　一気、にぃいい♪　先\nっちょから根元まで強引に挿入ぅううっ♪　んぁああああああ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0204112" ]},
		{"command":[ "SETIMAGE", "0", "still_00019802_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「すごっ、すごいぃいいい♪　チンポ♪　隊長さぁんのチンポひゅごいぃいい\n♪　んあっ♪　う、ウソやろぉ♪　想像の何倍も硬い、おっきぃい～っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0204113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「ッああ♪　入れられただけで一瞬気ぃ失いそうになってもぉた……♪　なん\nって威力やのん……♪　頭の中、チンポ一色になったやないのぉ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0204114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「んっあああっ♪　前戯もナシでいきなりピストン始めますのん……？　あは\nっ♪　さすがは隊長さぁんやわ……その荒々しさ、たまらへん……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0204115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「あっ♪　ええよ♪　うちの中……うちのオマンコめちゃくちゃに掻き回して\n……！　あっ♪　ふぁあ♪　そうや、突くのもええわ、力任せになぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0204116" ]},
		{"command":[ "SETIMAGE", "0", "still_00019802_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「ああぁああっ♪　あっぁっあっ♪　んあああっ♪　あぁ、ああああっ♪　あ\n、あかんん♪　もう何も考えられへん、好きぃ、チンポ好きぃ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0204117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「隊長、さぁん♪　このまま孕ませてくださいぃ♪　うち、今日危険日なんで\nす……♪　受精する準備、ばっちり澄ませてきましたからぁ♪　あぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0204118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「精液♪　無防備なうちのオマンコにたっぷり流しこんで♪　……あっ♪　一\n番奥ぅ……♪　子宮口に、亀頭をぴったりくっつけて射精してぇ♪　あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0204119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「……んん！？　あんっ♪　あぁんっ♪　うちが孕ませおねだりしたら、ピス\nトンむっちゃ早くなってきたぁ♪　あんさんも興奮してくれてますのん？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0204120" ]},
		{"command":[ "SETIMAGE", "0", "still_00019802_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「あぁっ！？　あはぁっ♪　ああっ……あっあぁんっ！　好きな人のぉ♪　隊\n長さぁんの子孕みたいのは当然のことやろぉ♪　あっ♪　わかります？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0204121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「うち、のっ♪　オマンコ♪　ずっと気持ちよすぎてキュウキュウ痙攣してま\nすっ♪　精子欲しがって、うねって……やらしい動き繰り返してるっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0204122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「っんんんっ♪　そないに腰を打ちつけてきて……♪　隊長さぁんもうちに種\n付けする気まんまんやね♪　あぁっ、両想いで嬉しいわぁ～っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0204123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「いっちばん濃い精子、欲しいから……限界まで溜めに溜めて凝縮してなぁっ\n♪　あっ♪　最高にドロドロになった精子がええの♪　んぁっあんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0204124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「……え？　締めすぎですぐに出てまいそう？　あっ♪　ご、ごめんなぁ♪　\nオマンコが言うこと聞いてくれへんの、隊長さぁんのチンポデカすぎて♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0204125" ]},
		{"command":[ "SETIMAGE", "0", "still_00019802_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「うちのオマンコ♪　おかしくなってもうた♪　……あっ♪　奥の奥まで突き\nあげられて♪　嬉しすぎてヒクついてまう♪　あっあっあんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0204126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「幸せぇ……♪　ねえ、本気出してください♪　うちのオマンコ丈夫やから、\n全力で突いて平気です♪　あぁっ、二人のいやらしい匂いが広がるように♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0204127" ]},
		{"command":[ "SETIMAGE", "0", "still_00019802_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「オマンコでチンポ出し入れしてくださいっ♪　ッあぁ～っ♪　そうですっ♪\n　うちの愛液掻き出すみたいに♪　チンポ入れたり出したりして♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0204128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「オマンコ全体で……そのふっといチンポシゴいてください♪　んぁあっ♪　\nき、気持ちいい……♪　隊長さぁん、足がガクガクしますぅう……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0204129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「もう、精液煮詰まってきましたぁ？　一番濃く、なりましたあ？　……あっ\n♪　うちは、うちは準備できました、妊娠する準備できましたぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0204130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「……ふふふっ♪　最後にうち、踏んばってオマンコ締めて……精液濃くする\n準備、手伝いますから……そうしたらいっぱい出してくださいねぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0204131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「ふ、ンンンッ……♪　どうですぅ？　キツくなりましたぁ？　……あっ♪　\nヤバいです、これ、うちも感じるぅ……♪　っあぁ、気持ちいい……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0204132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「そろそろ……ええですか？　うちの中に特別に濃い精液発射して、受精させ\nる準備できました？　……あ♪　あっ、楽しみ、やわ……。んぁあ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0204133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「もう、子宮口ヒクヒクヒクついて、精子欲しがりすぎてて限界です……！　\nうちも、すぐにイキますから……生で膣内射精されてイキますからっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0204134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「くださ……い♪　くださぁい♪　あんさんの精液っ、うちの赤ちゃんのお部\n屋にちょうだい♪　もう絶対出すまで離さへん！　……出してぇええっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0204135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「んんんんああっぁあああっ♪　あああああっ……♪　イッく……ぅっ♪　オ\nマンコに生で種付けされながらイクぅっ♪　好きっ、精子好きぃっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0204136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019802_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「隊長さぁん……♪　精液、もっともっとうちの奥に注ぎ込んでぇ……♪　ふ\nぁあっ♪　あっついの届いてます♪　子宮にかかってるのわかりますぅ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0204137" ]},
		{"command":[ "SETIMAGE", "0", "still_00019802_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「あぁ……美味し♪　目で見なくても、今出てる精液が真っ白でドロッドロに\n濁ってるのわかります……♪　粘り気のあるゼリーみたいな精液ぃ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0204138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「あああ、想像するだけでまた勝手にイッてまう♪　ごめんなぁ……♪　あぁ\nっ、うち、やらしすぎて大変やろぉ♪　あっ♪　あっ、イク、イクぅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0204139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「あは……♪　隊長さぁんのチンポも同時に汁出しましたねぇ♪　あぁああ…\n…♪　あったかい……♪　こんなありがたいこと、他にないわぁ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0204140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「……ふーっ♪　ふぅうっ♪　ふー……♪　ご、ごちそうさまでした……♪　\nあぁ……♪　あんさんも、うちもたくさんイッて疲れたわぁ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0204201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「でも、こんだけ大量に出してくれはったから、これで妊娠確定やろ……。後\nは……そやねぇ。まったりとピロートークとかせえへん？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0204202" ]},
		{"command":[ "SETIMAGE", "0", "still_00019802_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「二人のこれからについてしっぽり語り合って……って、ひゃん！？　な、な\nんやの！？　えっ！？　ま、まだギンギンに勃起しとる！？　なんで？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0204203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「あっ！　ゆ、油断しとった……！　あンンっ♪　何を勘違いしてるんだ……\nやて！？　えっ？　お互い気持ち良く受精出来て良かったなぁって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0204204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「思ったんや、けど、……んぁ！？　ま、まだ全ッ然終わってへんってこと！\n？　ややわぁ、普通そんなん無理やろ、出したばっかやのに！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0204205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「……んふぅっ！？　あふっ♪　さ、さっきより強いピストン……っ！　ま、\n待って！　ま、まだイッたばっかで身体、敏感なままやのにぃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0204206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「こんな！　こんなに荒々しく犯されたら……うち壊れてまうぅ！　あんっ♪\n　あん、あんっ！　卑猥な喘ぎ声、止められへんんん～～～っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0204207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「……な、なに？　本気で孕ませにきてはるん？　完全に？　絶対にうちを妊\n娠させるつもり……？　そ……そんなんありえへん、あかんよ……ぉっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0204208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「嬉しすぎるぅうう♪　うん、うんっ……わかったぁ♪　あんさんのチンポに\nわからされてしもた♪　うちらは本当に相思相愛だったんやねっ♪　あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0204209" ]},
		{"command":[ "SETIMAGE", "0", "still_00019802_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「わかりました♪　産みますっ♪　あんさんの赤ちゃん産みますぅっ♪　……\nんふぅううっ♪　うちの喜びが伝わったんやろか……っ♪　くふぅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0204210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「子宮降りてきとるぅう……♪　んもぉ♪　我ながらはしたなすぎるわ……\n！　完全チン媚びモード入ってしもた……♪　はぁ、はぁ、はぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0204211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「何度でも孕ませて♪　うんっ♪　うち……あんさんのこと大好きやし、チン\nポも好きぃ♪　あっ♪　ライブは妊婦で出るから気にせんといてぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0204212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「……んんんんん♪　これが……あんさんの本気の孕ませなんやね♪　うちが\nお願いして、リードしてた時と全然違う♪　ケダモノやん♪　素敵♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0204213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「ええよ、ガッついて♪　うちのオマンコ、あんさんのモノにして♪　あんさ\nんの遺伝子にしか反応でけへんようにしてぇ♪　支配しておくれやすぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0204214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「……んぅっ♪　すごい……！　返事を口じゃなく、チンポでするなんてぇ…\n…♪　あぁ……♪　あっぁっ♪　うちの気持ち、伝わってうれし……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0204215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「そうやぁ、無理やり子宮口突いて、開かせて、また新鮮で元気な精液っ……\n♪　ビュルビュル出してくださいねぇ♪　ぜんぶ受け止めますっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0204216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「……んっ♪　ややもぉ、激しすぎ、ますぅう♪　でもうちも乱暴にされるん\n好きっ♪　強いオスに種付けされてる気ぃして興奮するぅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0204217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「んぁああっ♪　あぁっ♪　あッあっぁっあっ♪　どうやのっ♪　精子……上\nがってきたぁ？　うちのオマンコはもう、吸い上げる気満々や……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0204218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「なぁ……♪　欲しいっ……♪　ちょうだい、あんさんの精液ちょうだいっ…\n…♪　早く……んぁあっ♪　早く一番奥ぅ……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0204219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「あんさんの限界チンポから放たれる、特濃精液でうちのことママにしてぇっ\n♪　あっ♪　おっぉっおっ♪　もうダメぇ、うちイクっ、イクぅうっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0204220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「ッあああああああぁあ～～っ♪　あはっ♪　あはぁああっ♪　中出しぃいっ\n♪　二度目の中出し精液ではしたなくイクぅっ、イク～～～～っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0204301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019802_02_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「あっ、ぁっ♪　なんで二回目の射精やのにこんなにたくさん出るんっ……♪\n　うれし……っ♪　嬉しすぎるぅ♪　あっぁっあっあぁんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0204302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「うちのオマンコの中、あんさんの精液で満たされてく……♪　栄養たっぷり\nのドロドロ精子ぃ……♪　こんなん注入されてイかへんの無理やでぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0204303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「っあぁあああっ♪　イクっ、イクぅうっ♪　無限にイケてまう……！　膣内\n射精♪　オマンコに中出し♪　……あああっ、最高や、気持ちええ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0204304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「隊長さぁんも、一滴も残さず出してくださいね♪　うち……チンポ絞ります\nからっ♪　はぁああっ……♪　あっついの出てる、出てるぅう……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0204305" ]},
		{"command":[ "SETIMAGE", "0", "still_00019802_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「これ、で妊娠確定やと思うとゾクゾクするわぁあ♪　ああああっ♪　隊長さ\nぁんの赤ちゃんできてるぅ、こんな幸せな絶頂他にないわぁあ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0204306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「……ぁ……♪　ごめんなぁ、うちばっかり……♪　我を忘れてイキまくって\nしもたわぁ……♪　だって、ものすごい量出してくれるんやもん……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0204307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「こんなん、感謝の即イキ必至やわって思って、豪快にキメさせてもろたけど\n……フフ♪　なんや、今頃恥ずかしくなってきたわ……。えへへ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0204308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「うん……♪　最高の受精体験やったよ？　うちは本物のJKやないけどぉ、\nJK姿の女の子に射精するの、心底気持ち良かったやろ～♪　んふふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0204309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「たまにはこういう、変化球のエッチもええねぇ……♪　これだけオマンコに\n出されたら、絶対妊娠しとるわ♪　ふふふ、これからが楽しみぃ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0204310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「あああああっ♪　イクぅっ！　イカせてもらいますぅうっ……♪　ああああ\nっ♪　んあああああっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0204401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019802_02_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「あ、あら……っ？　あらら、チンポが抜けて……うちのお尻にびゅるびゅる\n精液かかってしもてるぅ……♪　なんで……？　……あぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0204402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「あかん、あかんてぇ♪　お尻にたくさんかけるのダメやぁ♪　あっつ……♪\n　すっごい気持ちええ……♪　なんやの、びゅるびゅるドクドクってぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0204403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「っはぁっ♪　はぁあああっ♪　オマンコ♪　オマンコに射精する約束やった\nのにぃ♪　自分がかけたいところにかけて……♪　しょうがない人ぉ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0204404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「でもっ……♪　んぅっ♪　身体に精液かけられた方が……感触も、熱も、匂\nいもよぉわかる……！　興奮すんのは確かやわ♪　っふぁああああ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0204405" ]},
		{"command":[ "SETIMAGE", "0", "still_00019802_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「ええよ……♪　隊長さぁんの欲望……劣情、うちがぜーんぶお尻で受け止め\nるから……ゆ～っくりかけてや♪　はあ、はぁ、ほんまあったかい……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0204406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「……これで、全部出せた？　っふぅう……♪　すっごい量やね……。うちの\nお尻、真っ白になってもぉた……。こんなに溜めてくれてたん……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0204407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「……ん。そやね。本当は二度目もオマンコの中にビュービュー注入してほし\nかった。けど……一度目は中にもろたし、これで最後やないわけで♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0204408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「また次の機会に連続中出し射精してくれはったら許します……♪　えぇ～？\n　イヤとは言わせませんよぉ。さ、次はいつします？　どこでします？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0204409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「……JK姿で下品なこと言うな、やて？　ややわぁ、そういう女やって知っ\nてていっぱいシとるんやろ？　これからも、下品におねだりさせてなぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0204410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
