{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0098" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「さて、ようやく邪魔の入らない場所に落ち着けたのう。うむ、悪くない部屋\nではないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0903101" ]},
		{"command":[ "SETCHARA", "0", "char_00000709_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ふふ……期待しておるか？　余も、楽しみで仕方がない。お主のギラギラし\nた欲望が間近で伝わってくるからのう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0903102" ]},
		{"command":[ "SETCHARA", "0", "char_00000709_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「せっかくのクリスマスイブじゃ……今日はたくさん甘えさせてやらねばのぉ\n？　どうじゃ、お主の気持ちは？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0903103" ]},
		{"command":[ "SETCHARA", "0", "char_00000709_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「無論、お主が徹底的にリードしたいと言うのならば、それに乗ってやっても\nよいぞ？　好きな方を選ぶがよい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0903104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「なるほど、なるほど……ふふ、やはりお主は甘えたいのじゃな。全く、立派\nななりをしても、まだまだ気持ちは幼いのう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0903105" ]},
		{"command":[ "SETCHARA", "0", "char_00000709_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ほれ……お主の大好きなおっぱいじゃ。少し薄いかも知れんが、乳首に問題\nはない。好きなだけ吸うがよいぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0903106" ]},
		{"command":[ "SETIMAGE", "0", "still_00000709_01_01" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「んふっ、ふふぅ……んんっ、そうじゃ……遠慮はいらぬ。お主を甘やかすの\nは余の楽しみでもあるのじゃからな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0903107" ]},
		{"command":[ "SETIMAGE", "0", "still_00000709_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「おうおう、これはこれは……あっという間にオチンポがむくむく反り返って\n、実に素直なものじゃな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0903108" ]},
		{"command":[ "SETIMAGE", "0", "still_00000709_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「さて、となれば、この甘えん坊のきかん坊を、しっかりとあやしてやらねば\nなるまいな……まずはギュッと握りしめて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0903109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ふふっ、もうピクピクさせておる。敏感で結構なことじゃ……このまま、力\nを込めていくぞ？　そうら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0903110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「んふぅ……熱くなって震えておる……まずは、ムケたところを柔らかく撫で\nてやろうな……すりすり……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0903111" ]},
		{"command":[ "SETIMAGE", "0", "still_00000709_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「おうおう、オチンポが揺れておる。ふふ……一番敏感な場所はまだお預けに\nしておこう。とりあえず、ここからじゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0903112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「どうじゃ、少しくすぐったいかも知れんが……大丈夫か。まずは慌てず騒が\nず……じっくりと余の手コキを味わうといいぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0903113" ]},
		{"command":[ "SETIMAGE", "0", "still_00000709_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「こうして皮を捕まえて……上にっ、下にっ……ふふっ、一人でするのとは微\n妙に感覚が違うじゃろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0903114" ]},
		{"command":[ "SETIMAGE", "0", "still_00000709_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「多少もどかしい位のずれた感じが……少しずつ気持ちいい感覚に変わってい\nく……それを楽しんでもらうのがいいのじゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0903115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「んっ、ふふっ……ほーれ、シコシコ……ぐりぐり……皮がズリズリよじれて\n、気持ちよかろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0903116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「あまり身体に力を入れすぎんようにな。リラックスして、オチンポの感じる\nままに身を任せるのじゃ……そうそう、いい感じじゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0903117" ]},
		{"command":[ "SETIMAGE", "0", "still_00000709_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ふふ……その切なげな表情……庇護欲と嗜虐欲を同時にそそらせるではない\nか。全く可愛い奴め……うんっ、く……ふっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0903118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「んっ、おっぱいに甘えたいか？　よいよい、たっぷりと好きなだけ吸うがよ\nいぞ……生憎と今は母乳を出すのは難しいがな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0903119" ]},
		{"command":[ "SETIMAGE", "0", "still_00000709_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「それでも、吸い心地に関してはそれなりに若さを保っているつもりじゃから\nな。多少なりとも楽しめるのではないか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0903120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ふふっ、んっ！　舌がつんつんとイタズラをしておる……余を少しでも感じ\nさせようという心づもりか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0903121" ]},
		{"command":[ "SETIMAGE", "0", "still_00000709_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「あぁ……確かに、お主の舌の感触……乳首にピリピリ気持ちいいのが伝わっ\nておる……おぅっ……チュウっと吸ってきたな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0903122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「はぁん……ならば、余もお返しじゃ……気持ちいいのには、気持ちいいのを\n返してやらんとな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0903123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ほれほれ、オチンポの根元から先端まで余すところなくじゃ……ちょっと皮\nを引っ張って……また戻す……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0903124" ]},
		{"command":[ "SETIMAGE", "0", "still_00000709_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「うむ、少しくちゅくちゅと音がしてきたな……ふふ、どうじゃ……気持ちい\nいか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0903125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「そうかそうか、可愛いのう。そうやって正直にうなずかれると、余も俄然や\nる気が出てくるというものじゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0903126" ]},
		{"command":[ "SETIMAGE", "0", "still_00000709_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「とにかく、敏感な場所じゃからな……指の一つ一つを丁寧に絡ませて……こ\nのカリ首のところ……裏筋のところ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0903127" ]},
		{"command":[ "SETIMAGE", "0", "still_00000709_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「痛くしないように……しかし、物足りないようでは意味がないからな……絶\n妙な加減で……オチンポを愛でていく……んふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0903128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「よーしよーし、ほれ、もっとおっぱいを吸うか？　んっ……！　よいぞ……\nんふっ、反対側も触りたいか……全く甘えん坊め……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0903129" ]},
		{"command":[ "SETIMAGE", "0", "still_00000709_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「あっ、ふっ……あぁ……指でコリコリとされると、余も乳首がしこってしま\nう……んんっ、女を喜ばせる指使いじゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0903130" ]},
		{"command":[ "SETIMAGE", "0", "still_00000709_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ふふ……唇も夢中で先端に吸い付いておる……はぁ……んっ、まるで赤ちゃ\nんじゃな……いや、赤ちゃんはこんないやらしい吸い方はせぬか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0903131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「おっと……そんなことを言ってるうちに、チンポの先からそろそろの汁が浮\nいてきたぞ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0903132" ]},
		{"command":[ "SETIMAGE", "0", "still_00000709_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「どれ、少し味見を……んちゅっ……ふふっ、先走りなのにもう、濃さを感じ\nる……これは凄い噴水が期待できそうじゃな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0903133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ほれ……もっと本気で行くぞ？　ずりずり……ぐちゅぐちゅ……興奮する音\nがどんどん大きくなっていく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0903134" ]},
		{"command":[ "SETIMAGE", "0", "still_00000709_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「腰もガクガクして……堪らんじゃろう？　ほれ、やせ我慢せずにさっさと出\nしてしまえ。思いっきりドピュっとな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0903135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「んっ……！　おぉ、出ておる、出ておる……ふふっ、思った以上の素晴らし\nい噴水じゃのう……元気で何よりじゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0903136" ]},
		{"command":[ "SETIMAGE", "0", "still_00000709_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ドプドプ溢れて……指にたっぷり絡みついて来るぞ……んー、ちゅぷっ、や\nはり先走りとは比べ物にならんな……この粘りじゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0903137" ]},
		{"command":[ "SETIMAGE", "0", "still_00000709_01_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「どうじゃ、気持ちいいか？　ふふっ、それは何よりじゃ。これだけ元気な射\n精を見せられれば、余も自然と嬉しくなってしまうな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0903138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ほぉれ、ビュクッと……んふ……ひとまず落ち着いたか。うむ、派手に出し\nたな、よいよい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0903139" ]},
		{"command":[ "SETIMAGE", "0", "still_00000709_01_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「まだオチンポがピクピク震えておる。まだ出し足りないと言ってるみたいじ\nゃな……全く元気なことじゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0903140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「さて……少し休むのもいいかと思ったが、どうやらオチンポはそんな悠長な\n気分ではないと見えるな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0903201" ]},
		{"command":[ "SETIMAGE", "0", "still_00000709_01_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ぎゅっと絞ると……おぉ、またムクムク力を取り戻して……またビンビンに\n反り返っておる……大したものじゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0903202" ]},
		{"command":[ "SETIMAGE", "0", "still_00000709_01_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「よし……続けて扱いてやるからな？　今は出したばかりで感じやすいじゃろ\nうし……ゆっくりとしてやろう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0903203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「おふっ、出した精液がグチュグチュいっておる……これは、さっきよりぬめ\nりも増して……かなりいやらしいことになっておるな……んふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0903204" ]},
		{"command":[ "SETIMAGE", "0", "still_00000709_01_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「んっ……！　おっと、またおっぱいも恋しくなったか？　ふふっ、こうして\nおっぱいを吸わせながらオチンポをあやしていると昔を思い出す……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0903205" ]},
		{"command":[ "SETIMAGE", "0", "still_00000709_01_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「そう、それこそルナを育てた時のことじゃな。無論、ルナは女じゃからこう\nしてオチンポをさすってやる訳ではなかったがのう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0903206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「それでも……こうして、夢中になっておっぱいを吸ってきたものよ……ふふ\nっ、いいぞ、今はお主の母と思って吸うがよい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0903207" ]},
		{"command":[ "SETIMAGE", "0", "still_00000709_01_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「んふぅ……んっ……余も、乳首の刺激が気持ちいい……一緒に、気持ちよく\nなっていくのは……実にいいものじゃな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0903208" ]},
		{"command":[ "SETIMAGE", "0", "still_00000709_01_16" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「もう、これくらいの強さだと物足りなくなってきたか？　よし……では、ま\nた……むんずと……ふっ、はっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0903209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「んっ、いい音が響いてくる……余の指マンコ……完全にオナホールになって\nしまったな♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0903210" ]},
		{"command":[ "SETIMAGE", "0", "still_00000709_01_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「じゃが、余の指は意志を持ったオナホールじゃ。お主の気持ちよさそうなと\nころを全て見越して力加減も変わる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0903211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「んふっ……お主の乳首の吸い方でも、何となく今の様子は伝わるからな。今\nは、この辺をくすぐられるのがいいのではないか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0903212" ]},
		{"command":[ "SETIMAGE", "0", "still_00000709_01_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ふふっ、図星じゃろ？　お主のオチンポのことは、ある意味お主以上に分か\nっておるからな。次は……ここ……亀頭に少しめり込むくらいに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0903213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「おぉ、また腰が浮いたな。強すぎたか？　それとも、ここからもっとして欲\nしいのか？　どちらでもよいぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0903214" ]},
		{"command":[ "SETIMAGE", "0", "still_00000709_01_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「もっとして欲しい……ふふっ、つくづくお主も好きよのう。よいよい、たっ\nぷり気持ちよくさせてやるからな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0903215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「んっ……！　ふふっ、舌で返事をしてくるとはな……コリコリの乳首を咥え\nて……巧みに、んふっ、転がして……来ておる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0903216" ]},
		{"command":[ "SETIMAGE", "0", "still_00000709_01_16" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「はっ、んんっ……あぁ、もっともっと甘やかしてやりたいと思ってしまう…\n…これが、授乳手コキの魔力というものか……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0903217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「オチンポのくちゅくちゅという音も激しくなってきた……またオチンポから\nミルクが出そうなんじゃな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0903218" ]},
		{"command":[ "SETIMAGE", "0", "still_00000709_01_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ふふっ……もちろん、我慢しなくてよいぞ……？　思いっきりイッて、また\nたっぷりとザーメンミルクを飛ばすといい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0903219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「んふっ……全部余が受け止めてやるからの……最後にギュッと絞り込んでっ\n……ほぉれっ、出せっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0903220" ]},
		{"command":[ "SETIMAGE", "0", "still_00000709_01_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「おぉっ……また、元気よく飛ばして来たなっ……ふふっ、よいぞ……このま\nま扱き続けてやるからな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0903301" ]},
		{"command":[ "SETIMAGE", "0", "still_00000709_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「出てくる、出てくる……これはすごい量じゃな……全く、さっきもたっぷり\n出したと思っていたが、まるで足りなかったということか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0903302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「あぁ、実に気持ちよさそうな顔をしておるな……そのうっとりと快感に蕩け\nた顔を見るのが、余の一番の楽しみと言ってもいいかも知れん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0903303" ]},
		{"command":[ "SETIMAGE", "0", "still_00000709_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「そうじゃ……余の手を汚すことなど何も気にすることはない。たっぷりとぶ\nち撒けて、スッキリするがいいぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0903304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「んっ……ようやくちょっと落ち着いてきたか……まだ、チンポはビンビンの\nままじゃが……強引に搾りだすこともあるまい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0903305" ]},
		{"command":[ "SETIMAGE", "0", "still_00000709_01_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「どうじゃ、多少なりとも甘えることができたかのう？　まだ、おっぱいに吸\nい付いているところを見ると、物足りなかったか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0903306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「十分堪能している？　ただ吸い心地がいいから口を離したくないと……くく\nっ、本当に正直なヤツじゃのう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0903307" ]},
		{"command":[ "SETIMAGE", "0", "still_00000709_01_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「うむ……それならば、もう少し吸っておるといい。多少乳首はふやけるかも\n知れんが、お主の幸せそうな顔を見ればどうということもない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0903308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「じゃが、ずっと甘えっぱなしにさせておくつもりはないぞ？　この後は、余\nをたっぷりと満足させてもらわなければならんからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0903309" ]},
		{"command":[ "SETIMAGE", "0", "still_00000709_01_16" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ふふ……たっぷりと、男らしいところを見せてもらおうではないか。夜はま\nだまだこれからじゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0903310" ]},
		{"command":[ "SETIMAGE", "0", "still_00000709_01_14" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ひゃふっ！　んっ……オチンポがこっちを向いて……あふっ、余に直接ザー\nメンが飛んで来るっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0903401" ]},
		{"command":[ "SETIMAGE", "0", "still_00000709_01_20" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ふふっ、甘えながらも、しっかりぶっ掛けたかったという訳か。ああ、もち\nろんよいぞ……ほれ、顔はここじゃ、頑張って飛ばしてみせい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0903402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「んふっ、ちゅぷっ……２発目でも、十分過ぎる程に元気じゃな……後から後\nからザーメンが溢れてくる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0903403" ]},
		{"command":[ "SETIMAGE", "0", "still_00000709_01_19" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「うむ、下手な遠慮などすることはないからな？　お主の欲望のまま、遠慮な\nくドピュッと出してしまえ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0903404" ]},
		{"command":[ "SETIMAGE", "0", "still_00000709_01_18" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「と……今ので、ひとまず射精も落ち着いたようじゃな。ふふ……たっぷり出\nせて偉かったのう……よしよしじゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0903405" ]},
		{"command":[ "SETIMAGE", "0", "still_00000709_01_21" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「見よ、こんなに糸を引いて……生命力に満ち溢れたところをこれでもかと見\nせつけられている気分じゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0903406" ]},
		{"command":[ "SETIMAGE", "0", "still_00000709_01_22" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ちゅぷっ、んむ……本当に濃厚じゃ。こんなに出したのに、まだオチンポが\n硬いままなのも頼もしい限りじゃな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0903407" ]},
		{"command":[ "SETIMAGE", "0", "still_00000709_01_23" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ぴちゃ……ふふっ、うむ……美味い。じゃが、やはり口で味わうだけのザー\nメンは、完璧という訳ではないからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0903408" ]},
		{"command":[ "SETIMAGE", "0", "still_00000709_01_24" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「もう、大体の察しはついておるじゃろう？　存分に甘えた後は、お主の男気\nというのを見せてもらいたいということじゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0903409" ]},
		{"command":[ "SETIMAGE", "0", "still_00000709_01_21" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「夜はまだまだこれからじゃからな……余をたっぷりと可愛がってもらうぞ？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0903410" ]},
		{"command":[ "SETIMAGE", "0", "still_00000709_01_24" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
