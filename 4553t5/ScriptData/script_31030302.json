		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……水着だけじゃなく、どこもかしこも精液まみれだよぉ……\nあ、ああ……精液が、滴ってる……気持ちいい……」", "NORMAL" ]},
