		{"command":[ "SETIMAGE", "0", "still_00010303_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「ほら見てぇ……スク水が精液でビチャビチャ……水着が妊娠しちゃいそう…\n…」", "NORMAL" ]},
