{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「ふぅ……たっぷり泳いだし、砂でお城も作ったり、スイカ割りも潮干狩りも\n魚釣りも、全部やり尽くしちゃった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0304101" ]},
		{"command":[ "SETCHARA", "0", "char_00010303_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「ねえ、隊長さん……遊びすぎて、ボクもうクタクタだよぉ……ちょっとダラ\nダラしたいなぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0304102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「そうそう、甲羅干しってヤツ。ちょっとゆっくりしようよぉ……それにして\nも喉が乾いちゃった。甘くて、冷たいもの、欲しいなー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0304103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「ふえ？　ソフトクリームがあるの？　食べる食べる！　わぁ、ありがとー…\n…いただきま～す……え？　隊長さんも食べるの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0304104" ]},
		{"command":[ "SETCHARA", "0", "char_00010303_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「ひゃうぅ！？　や、何？　どうするつもり……？　やだっ、冷たい……ソフ\nトクリーム、ボクのおっぱいに乗っけないでぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0304105" ]},
		{"command":[ "SETCHARA", "0", "char_00010303_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「うぅぅ……冷たいよぉ……ねえ、隊長さん……ソフトクリームって、こんな\n食べ方するものじゃないでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0304106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「せっかくの美味しそうなソフトクリームなのに……食べ物で遊んじゃいけな\nいんだよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0304107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「え？　ちゃんと食べるから許して……？　う～ん、まあいいけどさぁ……で\nも、ボクをちゃーんと気持ちよくしてよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0304108" ]},
		{"command":[ "SETCHARA", "0", "char_00010303_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「あっ……ああ、やだ、ホントに、このまま食べるんだね。ん、はぁ……その\n舐め方……すごくエッチぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0304109" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00010303_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「きゃうぅっ、駄目ぇ……おっぱいペロペロしながら、アソコ触られたら、あ\nあん、おちんちん、欲しくなっちゃうよぉ……はぁ、あぁぁん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0304110" ]},
		{"command":[ "SETIMAGE", "0", "still_00010303_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「ひゃぁぁぁ！？　あはぁぁん……気持ちいい……おちんちん、入ってくるぅ\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0304111" ]},
		{"command":[ "SETIMAGE", "0", "still_00010303_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「んぐぅ、ふぎぃぃ……お、お腹の隙間が、無理やりこじ開けられていく……\nああ、この感触、すごく、いい～～……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0304112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「はぁ、あぁぁん……水着のまま、エッチするだなんて……隊長さんのヘンタ\nイ……エッチ……あ、ああ……んっ、はぁああん……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0304113" ]},
		{"command":[ "SETIMAGE", "0", "still_00010303_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「でもいいのかなぁ……？　この水着、お亥さまにもらったものなんだけど…\n…え？　もらった理由……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0304114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「んー……話、あんまり聞いてなかったから、よくわかんない……でも、お姉\nちゃんたち、綺麗で可愛いビキニなんだよ？　ボクも着たかったなぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0304115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「まあ、そんなこと、どーでもいいやぁ……んっ、はぁ……あぁああん、おち\nんちんが、一番深いところに届いてる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0304116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「下から、アソコが持ち上がっちゃうぅ……あぁん、お腹にめり込んでる……\nはぁ、んん、苦しい……でも、気持ちいいよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0304117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「はへぇ？　よく締まる……？　はぁ……んふぅ……アソコが、勝手におちん\nちん、抱きしめちゃうみたい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0304118" ]},
		{"command":[ "SETIMAGE", "0", "still_00010303_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「んっ、んっ、んぁっ、あひぃぃ……お、お腹の深いところ、えぐってる……\nあ、ああ、身体弾んじゃうぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0304119" ]},
		{"command":[ "SETIMAGE", "0", "still_00010303_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「あはぁ……おっぱいがゆさゆさ揺れてるのに、乳首の感覚がないよぉ……冷\nたすぎて、痺れちゃったみたい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0304120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁぁん……ボク、もっと、気持ちよくなりたい……はぁ、はぁ…\n…あはぁ、駄目ぇ、身体が勝手に動いちゃうよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0304121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「ん、はぁ……身体を動かすと、ドロドロに溶けたソフトクリームが、肌と水\n着にベットリ張り付いて……ああ、ニチャニチャする……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0304122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「これ、変な感触だね……日常でこんなの、絶対嫌なのに、エッチしてる時だ\nとヘンタイっぽくて気持ちいい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0304123" ]},
		{"command":[ "SETIMAGE", "0", "still_00010303_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「くんくん……はへぇ、バニラとミルクの甘い香り……はぁん、ウットリしち\nゃう……はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0304124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「潮風と、波の音と、突き刺すような日差し……ああ、すごぉい……こーいう\nセックスも楽しいねぇ……はぁ、はぁ……はぁぁあん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0304125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「ああ、駄目ぇ……アソコが、イキたがってる、みたい……身体がグイグイ動\nいちゃうよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0304126" ]},
		{"command":[ "SETIMAGE", "0", "still_00010303_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「あはぁ、隊長さんを、お腹の一番深いところで感じちゃうぅ……ひぐぅ、き\nゃうぅぅ……はへぇぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0304127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「んぐぅ！　あはぁ、はぁ、あぁああん！　ゴツゴツぶつかってくる……おち\nんちんが、あ、ああ、ボクの中いっぱいに膨らんでる、みたい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0304128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「ひゃくぅ、あはぁぁ……おっぱいがユサユサ揺れる……水着の中で、暴れて\nるよぉ……はぁ、はぁ……ん、あぁぁあん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0304129" ]},
		{"command":[ "SETIMAGE", "0", "still_00010303_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……身体全部が、気持ちいい……あ、あ、イクッ、ねえ、隊長さ\nんも一緒に……はぁ、んんっ！　ひぅぅ！　あはぁぁぁあん！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0304130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「ひやぁぁぁぁぁ……あっ、あっ、ああぁぁん……出てるぅ……こんなに、い\nっぱぁい……はぁ、ふぅ……んんぅん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0304131" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010303_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「ボクのアソコと、おちんちんから……すごい勢いで、ビュルビュル、ドピュ\nドピュ……はへぇぇ……気持ち、いい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0304132" ]},
		{"command":[ "SETIMAGE", "0", "still_00010303_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、あはぁぁ……精液が、子宮にぶつかってる……はぁ、あああ…\n…お潮が、気持ちいいのに押し出されていく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0304133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「はぁ……はへぇぇ……気持ちいい……んん、ビクンビクン、してる……アソ\nコの奥で、おちんちんが暴れてる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0304134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「はへぇぇ……イクのが、止まらない……ずーっと、子宮が震えてる……はぁ\n、ふぅ……ひゃふぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0304135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「はー……はぁ……あふぅ……イクのが、治まってきちゃったぁ……ふぅ……\nすごかった～～……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0304136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「もう、ボク、疲れたって言ったのに……こんなことさせるだなんて、ほーん\nと酷いんだからぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0304137" ]},
		{"command":[ "SETIMAGE", "0", "still_00010303_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「けど……いっぱいイッちゃったぁ……あはぁ、気持ちよかったから、許して\nあげるね……はぁ、はぁ……ふう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0304138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「え？　もし許さなかったらどうなったのか……だって？　そんなのきまって\nるじゃない……刀のサビにしてあげたよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0304139" ]},
		{"command":[ "SETIMAGE", "0", "still_00010303_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「あはは、なーんちゃってぇ……はぁ、あふぅ……で、どーするの？　まだお\nちんちんこんなに硬いみたいだけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0304140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「続き、する？　あはぁ……そう言うって思ってたぁ……あはぁ、嬉しいなぁ\n……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0304201" ]},
		{"command":[ "SETIMAGE", "0", "still_00010303_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「はぁ……うふぅ……ボク、もちろん隊長さんが満足するまで、お付き合いす\nるよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0304202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「だってぇ、ソフトクリーム、すっごく美味しかったんだもん……その御礼だ\nよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0304203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「それで……隊長さんは、どうだった？　ボクのおっぱいで食べるソフトクリ\nーム、美味しかったぁ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0304204" ]},
		{"command":[ "SETIMAGE", "0", "still_00010303_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「そう、美味しかったんだね～、よかったぁ。はぁ、ふぅ……こんなにドロド\nロ汚されたんだもん、ちゃんと味わってもらわなきゃね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0304205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「ん、あはぁ……乳首が熱い……冷たくて、感覚がなかったんだけど、だんだ\nん隊長さんの舌が気持ちよくなって、きちゃったぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0304206" ]},
		{"command":[ "SETIMAGE", "0", "still_00010303_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「やぁん……いやらしい……水着からこぼれたおっぱいが、隊長さんの舌先で\n、弄ばれちゃうぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0304207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「赤黒い舌先がニチャニチャ音を立てて、ボクの乳首をこね回してる……ああ\n、子宮と乳首が繋がったみたいに、気持ちいい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0304208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「ん、んあ、はぁ……ああぁあん……アソコの中で、精液がかき混ぜられて\n……グチュグチュ音を立ててるよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0304209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……はぁあ、精液の匂いが、微かに漂ってる……はぁ、この匂い\n、エッチ過ぎぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0304210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「あはぁぁ……熱いぃ……身体が燃え上がっちゃいそうだよぉ……はぁ、んふ\nぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0304211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「夏の日差しを、ん、んん、こんなにいっぱい味わったの、初めてかも……あ\nふぅ、日焼け止めローション、持ってくればよかったかも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0304212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「はぁ……はへぇ、頭がぼーっとして、来ちゃったぁ……はふぅ、身体が溶け\nて、隊長さんと絡み合うみたい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0304213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「気持ちよすぎて、ん、んんぁ、はぁはぁしすぎちゃったの、かも……ん、あ\nふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0304214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「お腹の中で、おちんちんがグチュグチュ立ててる……精液が、泡立って……\n中でネットリしてる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0304215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「ひゃうぅ、おちんちんが震えてる……隊長さん、また気持ちよくなってきた\nの？　えへへ……嬉しい……またいーっぱい、出してね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0304216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「ボク、精液の味と匂いって、変だけど……ん、うぅ、でも興奮、しちゃうん\nだよね……はぁ、ん、あっ、あっ、あぁぁぁ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0304217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「ひやぁぁん、おちんちん、膨らんでる……さっきより、子宮に刺さる……ぐ\nぅ、はぁ……ああ、ボクも、イキそう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0304218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「あはぁ、隊長さん、気持ちよさそうな顔してる……んふふ、ねえ、いつでも\nいいんだよ……はぁ、はぁ……さあ、出してぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0304219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「ボクもイクからさ、一緒に……ん、んん、はぁ……ああっ、イクッ、イッ、\nイクイクイク……イッグッんんんんっ！！！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0304220" ]},
		{"command":[ "SETIMAGE", "0", "still_00010303_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「んぎぃぃぃぃぃぃ！！　あはぁ、はぁ……あぁぁ、また出てる……はぁ、ひ\nやあ……こんなに、いっぱい……ふぐぅ、はへぇぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0304301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010303_02_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「はぁ、あはぁぁ……イッてる……ボクも、隊長さんも……一緒に、ん、んん\n、あはぁ……あふぅぅぅ……いい……すごくいい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0304302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「はー……はぁ、あぁあん……お腹の中で、ん、ふぅ……精液が、溢れかえっ\nて……ああぁ、すごぉい……まだ出てる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0304303" ]},
		{"command":[ "SETIMAGE", "0", "still_00010303_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「あったかいのが、お腹の隅々にまで行き渡ってる……はぁ、ふぅ……気持ち\nいいのが、止まらない……ずーっとイッちゃうぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0304304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「はぁ、はへぇぇ……頭が変になっちゃいそうだよぉ……はぁ……あぁぁん、\nひうぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0304305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「あ……射精、治まったみたいだね……はー……はふぅ……すごかったー……\nほんと、どうにかなっちゃいそうだったよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0304306" ]},
		{"command":[ "SETIMAGE", "0", "still_00010303_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「うわぁ……全身汗だく……水着が水から上がった直後みたいに、シットリし\nてる……ふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0304307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「あー……疲れたぁ～～……ねえ、隊長さん……ボク、お腹すいたんだけど…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0304308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「え？　何か食べにいく？　うん、それいいね！　でも……精液で、お腹いっ\nぱいになるのもいいかなーって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0304309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「え～？　駄目ぇ……？　うん、たしかにそろそろ帰らなきゃね。今日は楽し\nかったー♪　だから、また誘ってね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0304310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「ひゃうぅぅぅぅ……！？　ひあぁ、あぁぁあん！　出てる……おちんちんか\nら、ビュクビュク飛び出てくる……！」", "NORMAL" ]},
