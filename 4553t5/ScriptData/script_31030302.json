		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……あはぁぁ……ボクも、いっぱい出てる……おしっこみたい\nに溢れてる……はぁぁん、すごぉい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0304402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「んっ、んぐぅ、ひやぁぁ……止まらない……ああん、こんなの脱水症状にな\nっちゃうよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0304403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「あぁぁ……精液出てる……さっき中に出された精液が、アソコの奥から滴っ\nてくる……はへぇ……トロトロが溢れてる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0304404" ]},
		{"command":[ "SETIMAGE", "0", "still_00010303_02_16" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「気持ちよすぎて、あそこが溶け出したみたい……はー……ふぅ……駄目ぇ、\n身体に力が入らないよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0304405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「ひうぅ……あはぁ……やっと射精が止まったみたい……はぁ、ふう……すご\nかったねぇ……」", "NORMAL" ]},
