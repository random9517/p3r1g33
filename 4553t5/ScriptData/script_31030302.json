		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「ふぅ……なんだか、疲れちゃったぁ……頭がクラクラしちゃう……はぁ、ふ\nぅ……」", "NORMAL" ]},
