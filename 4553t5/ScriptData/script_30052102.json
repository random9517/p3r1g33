{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「はぁ……。またこの部屋ですか。こんなところに呼び出すとは……何事なの\nです。ウチも暇ではないのですが？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2104101" ]},
		{"command":[ "SETCHARA", "0", "char_00000521_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「……記憶を無くす前は、何度も激しく愛し合った仲だったじゃないか……？\n　フン。貴方の甘言には乗りませんよ。そんな訳ないじゃないですか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2104102" ]},
		{"command":[ "SETCHARA", "0", "char_00000521_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「帰ります。……まったく。ウチをアホかバカだと思ってます？　記憶が無く\nても、相手の言うことが真実かどうかくらいは見抜けます……って」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2104103" ]},
		{"command":[ "SETCHARA", "0", "char_00000521_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ちょっ……！　ちょっと何してるんですか！　は、離してください！　急に\n襲いかかってくるなんて！　ぶ、ぶ、ぶっ飛ばしますよ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2104104" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_02_01" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「うっ！？　なぜ罵られてそんなにオチンチンを大きくしてるんですか！　ま\n……待ってくださいっ、ダメです！　そんな凶悪なモノを近づけてはっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2104105" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「じょ……常識で考えて、入るわけないじゃないですか！　ウチの体格でそん\nなもの受け入れられるワケが……！　っうぅっ、前は入っていた！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2104106" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_02_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「そ、そんなの知りません！　下ろしてください！　こんな屈辱的な格好をさ\nせるだなんて……昔のウチだって許すはずありません、あ、あ、待って」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2104107" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「本当に！　心の準備も何もできていませんからっ……。あっ……！　や、や\nめるのです！　このままではオチンチンが中に入って……あうぅっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2104108" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_02_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「……あッ！？　あっぁっあっううううううっ！　んうううううっ！　う～～\n～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2104109" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「こ、こんな体勢で、ギンギンに勃起したオチンチンを無理やり挿入するなん\nて……！　貴方はゲスです、外道です、ありえないです、あっあっあっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2104110" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ダメですっ！　うっ、うぅうっ！　イクッ……！　イクのですぅううっ！？\n　あっ……！　あっぁっああああああぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2104111" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「うぁっ……♪　はぁ、はぁ、はぁはぁっ……！　な、なんということですか\n……っ。身体が勝手に反応して、絶頂を晒してしまいました……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2104112" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ウチの身体は……こ、このオチンチンのことを好いているとでもっ？　あっ\n……！　ち、違います、狭いところにいきなりねじこまれたからで！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2104113" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「っ……んぅううっ！　な、なんですか！？　なんっ、で、人がイッている時\nに……。あぁっ、うぁあっ、無許可で腰を動かして……！　あっぁっうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2104114" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「や、やめっ……♪　んぁっ、よ、喜んでませんからっ……！　あっ♪　ぬ、\n濡れてる……？　わ、わざわざ口に出さないでくださ、い、あっあっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2104115" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「……んひぃっ！？　クタクタになっているウチをさらに攻めてくる、なんて\nっ……！　貴方は昔からとんでもないワルだったのですかっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2104116" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あっ、うぁっ、あぁっ、あぁああっ……！　あっ！　あっ、イ、イッても休\nませてもらえるどころかっ……あっ、小刻みに子宮口をノックしてきてっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2104117" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「……っひっ♪　な、なんで弱点を熟知しているのです、ま、まさか本当に…\n…っ！　あぅっ、う、ウチと貴方は……？　あっ、そ、そんなぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2104118" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んんっ！？　あっ、あっ、うううっ……！　はぁっ、あっ……！？　そんな\nにがっくんがっくん揺らさないで、欲しいのです、あっ、揺らしすぎです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2104119" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「奥っ……に突き刺さって……ああああっ♪　っくぅううっ……！　だ、だか\nら感じてなんか、いまっ、せんっ……！　図に乗るなですっ……ひっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2104120" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んぁっ、あぁっ、ああ……やぁあ……ッ！　ウ、ウチだって好きで腰をくね\nらせているわけではっ……、あっ、い、一度休ませてくださいぃいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2104121" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「……んんんぅっ♪　あひぃっ、そこっ……！　そこ、ダメなのです……！　\n奥っ……亀頭でズリズリされると、し、子宮口が疼いて……あああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2104122" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んんんっ！　やっ……あぁっ、あっ、あうううっ！　ウ、ウチが困れば困る\nほど……た、楽しそうに……！　許せないです……！　っあぁっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2104123" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「強くねじこむの、ダメっ……。んぁあっ！　突き上げないで、くださ……あ\nぁっ！？　も、もう、こっちが逃げられないと思って……！　ふぁあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2104124" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「……っん……！？　ど、どうしてオチンチンをそんなにヒクつかせているの\nですか……？　あっ、腰を打ちつける速度が、どんどん速くっ……あああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2104125" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「もしや射精が近い、と……！？　あっ……。悪いですけど！　今日はっ……\n！　あっぁっ、今日は本当にダメです、ダメな日なのですっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2104126" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んんんんんっ……！　ダメだと言えば言うほど股間が密着してきて……くぅ\nううっ……！　な、なぜすんなりと退いてくれないのですか！　ああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2104127" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「き、危険日、ですのでっ……。あっ、このまま中に出されたら、に、妊娠し\nてしまいます！　……あっ！？　ウ、ウチのアソコが吸いついてきている？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2104128" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「オチンチンを絞り上げて離してくれない！？　う、嘘です、そんなこと……\n！　ああああっ、て、適当なことを言ってこのまま出す気ですね！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2104129" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「っあっ……！　ほ、本気ですか！？　本気で……っ、んぁあああっ……！　\n本当に赤ちゃんができたらっ、せ、責任取ってもらいますからぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2104130" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「……んぅううっ！？　い、いい……？　責任を取る？　ま、またその場限り\nの言葉を……、んっ、ぁああああっ！？　やっ、ウチに脅されて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2104131" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「なんで逆に興奮してる、んですかっ……！　はぁっ♪　んふぁああっ♪　あ\nっ……！　どんどんオチンチンが熱くなって、太く……！　っあっあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2104132" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「激し、すぎて……！　も、もうワケがわかりませんんっ……！　あぁああっ\n……そんなに中をかき混ぜられたら、ウチも、ウチも……んぅうっ、うぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2104133" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ダメです、ウチもイキそうに……っ、あぁああああ……！　嫌、です、貴方\nと一緒にイクなんて……っ、あぁっ、同時に絶頂なんてしたらっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2104134" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「絶対妊娠してしまいます……！　我慢、我慢しないと……、ぉ、んぉおっ♪\n　やだ……、やだぁああっ、イクっ、イクですっ、イッてしまいますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2104135" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んひぁああああああぁああっ……！　あっ♪　ああッ……！　全部、全部出\nちゃいました……！　あっ……！　ウチがイクのと同時に……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2104136" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_02_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「貴方の精液がドクドクと奥に注がれて……ううううっ♪　子宮の中に侵入し\nてきましたっ……！　あっ……な、なんです、なんですこれぇえっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2104137" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「我慢していたものが全て噴き出して……恥ずかしいですっ……！　や、やぁ\n……止まらない、どんどん溢れ出して……！　あっあっあっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2104138" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「こんな……っ、無理やり犯されて、ウチ、ウチ、イキまくって潮吹いて……\nううううっ、お、おしっこもちょっと漏らしちゃいましたぁああ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2104139" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_02_14" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あっ♪　あっ♪　精液もしつこく中に出されて……もうめちゃくちゃです、\n部屋の中にいやらしい臭いが充満しているです……っ、イクぅううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2104140" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ふぁあああああ……っ♪　はぁ、はぁ……イキ果てさせられて、しまいまし\nた……。はぁ、はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2104201" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_02_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ウチの意見も聞かずに無理やり種付けするなんて……。貴方は本当に考えな\nしですね……。で、ですが責任を取るとは言ってくれましたし……その」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2104202" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ウチも……気持ち良くなくはなかったので、今回ばかりは見逃してやります\n。さあ、やりたい放題し終えたらさっさとどいて……って、うぅ……っ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2104203" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ありとあらゆる卑猥な臭いが……！　こ、この臭いを嗅いでしまうと……。\nはぁっ、身体が火照って、疼いて……強制的に発情させられてしまいます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2104204" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「……くぅ……！　うううう……っ。こんな状態では帰れません……！　それ\nに、ど……どうせ貴方も、まだ出し足りないに決まっています」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2104205" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「もう、中出しでも生挿入でも、なんでも好きにすれば良いのです……！　そ\nのかわり、絶対に責任取ってもらうですよ……いいですね……っ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2104206" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「……あっ……♪　あぁ、ああ、ま、マズいです……！　ウチ……自分から腰\nを揺らして、オチンチンを貪ってしまっています……！　あっあっあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2104207" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「さ、さっき出された精液で、オチンチンがヌラついて……あううぅっ、滑り\nが良くなって……あっ♪　き、気持ちいい……！　気持ち良すぎます！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2104208" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んぁっ、ああああっ……♪　あ、貴方も何をジッとしているんですかっ……\n。ウチばっかりっ♪　動くのは理不尽です、不公平です、動いてください！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2104209" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_02_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「はぁっ……あぁ、熱い……熱いです……！　んんんっ、あっ！　そうです、\nウチの動きに合わせて……あっ！　オマンコを突き上げて……んくっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2104210" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_02_12" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「こ、この体勢……非常にまずいのです……っ、んぁああっ！　ふぁっ、うぁ\nっ♪　あぅああああっ！　深く、思いっきり奥に入って……！　あっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2104211" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_02_11" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「えっ！？　ウチのオマンコ、いつも以上にキツくなって……オチンチンにし\nゃぶりついてる、ですか！？　し、知りません、そんなことっ、あっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2104212" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「それはウチが操作しているわけではなくてっ、……んふぁああっ♪　オマン\nコが勝手にしていることです！　あっ、……うっ♪　うっ、うぅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2104213" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「最高に気持ちいい……ですか、……んぁっ！　そ、それはっ、良かったです\nねっ……！　あっ！　ウチも……！　っぅ、な、なんでもありません！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2104214" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_02_12" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あぁっ、んぁあああっ……！　身体を丸ごとオチンチンが突き刺してっ……\nあっ！　意識がトんでしまいそうです、んっ♪　うっ、ヤバいですっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2104215" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「こんなに凄まじく愛されたらっ……あっ、オマンコが……！　身体が勘違い\nします、貴方のことを好きになってしまいます、あっ、も、もうダメっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2104216" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ダメです、ズポズポ上下されるたびにっ……！　くぅううう～～～っ♪　イ\nキ、そうに……！　あっぁっあっあぁっ、なぜこんなに上手いのですかっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2104217" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_02_11" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「貴方がっ、上手いのか、オチンチンとの相性が良すぎる、のかっ……！　そ\nれとも……あっあっあっ♪　ウチのオマンコが貴方を好き、なのかっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2104218" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_02_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「もう……どれでもいいです、その全てかもしれません！　イクぅっ……あう\nううっ……！　貴方も、責任を取ると決めたのですから、存分に……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2104219" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「好きなだけウチの中に出していいですっ……！　あっ♪　あぁっ、ください\n……！　ウチの一番奥に、貴方の精液を注入してくださいぃっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2104220" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_02_12" ]},
		{"command":[ "WAITINPUT" ]},
						
		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「は、ぁ……っ♪　んああああああっ、出てますっ！　すごい勢いで！　ウチ\nの中に貴方の精子が出てますっ……！　もっと、もっとくださいぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2104301" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_02_17" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んっ、ふぁああっ♪　あぁっ……！　２回目の射精なのに勢いが衰えるどこ\nろか……さっきよりずっと……っ！　あっ♪　あっ、イキますぅうっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2104302" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ひぃっ♪　んんっ、あっ、あああああああ……！　お腹の一番奥……っ、自\n分でも触ったことのないところに貴方の子種が……！　っあああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2104303" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_02_16" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「い、いいですかっ……！？　ウチがこんなことを許すのは、あ、貴方にだけ\nですからっ……！　勘違いしないでくださいね！　っうっ♪　んぅうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2104304" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_02_15" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ま、だ入ってくるぅう……♪　内側から身体が火照って……あっ♪　貴方の\n精液でお腹がいっぱいに……！　重たくてずっしりした精液です……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2104305" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_02_17" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ドロドロと粘り気の強い精液に満たされて……っ。ウチ、ウチ、もう……♪\n　何も考えられなくなってしまいました……♪　あっ、最後までください！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2104306" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「はぁっ……、はぁ、はぁっ……♪　フフ……ふふふふふっ……♪　これでウ\nチと貴方は、一蓮托生……もう絶対に逃がしませんですよ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2104307" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_02_15" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「最初はかなり強引に、でしたが……。今は、今日、ここで貴方に襲われてし\nまって良かったのかも、と思っています。過去の記憶は戻りませんでしたが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2104308" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「それよりも大事な未来を……はぁっ♪　貴方に誓わせることができた、これ\nは大きな大きな成果です……。赤ちゃんと、ウチと、貴方と……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2104309" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_02_17" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「三人で、楽しく過ごしていくのなら……ウチもこの人生で良かったと言える\nかもしれません。これから、期待してますから……わかってますですよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ッああああぁっ！？　しゃ、射精を焦って的を外すなんて……っ、最後の最\n後で貴方は本当にダメダメですねっ……！　んふぁっ、ち、違う？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2104401" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_02_19" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ウチに精子をブッかけて、自分のモノだとアピールしたかった……！？　そ\n、そんなことのために、ウチをほったらかしにして……んんんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2104402" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ヌ、ヌルヌルしたものが大量に……！　お、己の欲望を最優先するなんてと\nんでもない男ですねっ、呆れました……でも……でもっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2104403" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_02_18" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ウチに降りかかるこの精液……っ、あっ♪　不思議とイヤな気持ちがしませ\nん！　もっと、もっとかけてください、真っ白に染めてくださいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2104404" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「っあぁっ……！　んああああっ……！　むせ返るようなこの臭い……ニオイ\n……っ、たまらなく興奮しますです……！　もっと……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2104405" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_02_20" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「っあぁ、濃くて新鮮なこの臭いを堪能できたと思えば……♪　身体に精液を\nかけられるのも、そんなに悪くないのかもしれません……！　んんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2104406" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ふぅううう……♪　あ……、もしかして、ウチの意識……。かなり遠くまで\n飛んでいってしまってましたか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2104407" ]},
		{"command":[ "SETIMAGE", "0", "still_00000521_02_18" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「うう……。ウチとしたことが、我を忘れて欲望に溺れてしまうなんて……。\n今日見たことは全て忘れてください……。え？　忘れるつもりはない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2104408" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「っくぅうう……♪　悔しいですが、まだ快感の余韻が身体から抜けてくれま\nせん……♪　はぁ……はぁっ、も、もし過去のウチがこんな凄いことを……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2104409" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「経験していたのだとしたら、貴方に感じていた謎の親近感の理由が少しだけ\n……わかった気がします。す、少しですけど……♪」", "NORMAL" ]},
