		{"command":[ "PLAYVOICE", "001_0703218" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「あっ、あっ、オチンポ、ビクビクしてる……！　もう出ちゃいそうなの……\n！？　濃くて臭い精子を、ドプドプ、射精しちゃうの……！？」　", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0703219" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「あぁんっ、待って、私も、なんか、キちゃうっ……！　オチンポでおっぱい\nヌリュヌリュされて、んふぅぅっ、変なの、キちゃうぅっ……！」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
