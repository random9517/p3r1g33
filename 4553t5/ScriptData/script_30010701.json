{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},		{"command":[ "WAITMOVE" ]},		{"command":[ "PLAYVOICE", "001_0703101" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「一応、来てあげたけど、要件は何かしら？　下僕のくせに、この私を呼びつ\nけるだなんて……ほら、さっさとしてくださる？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00000107_01", "0", "CENTER", "0" ]},
        {"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "DISPNAME", "TRUE" ]},		{"command":[ "DISPTEXT", "TRUE" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0703102" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「あなたのような下賎な男と同じ空気を吸っていると思うだけで、吐き気がす\nるわ。おぞましい」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0703103" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「きゃっ！　ち、近寄らないで！　妊娠してしまうでしょう！？　私のような\n美少女がこのような姿だからって、これ幸いにとイヤラシイ目で見て……！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000107_01", "3", "CENTER", "0" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0703104" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「どうせこの部屋に呼び出したのだって、また何かイヤらしいことをするつも\nりなのでしょう？　この変態！　スケベ！　強姦魔！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000107_01", "7", "CENTER", "0" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0703105" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「……なによ、違うというの？　ふんっ。それなら、何の用だって言うのかし\nら？　ほら、早く言ってみなさい」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000107_01", "0", "CENTER", "0" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0703106" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「なになに、あなたのその大きくなったモノを私の胸で挟んで擦って精液を…\n…って、やっぱりイヤらしいことじゃないの！　シバくわよ！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000107_01", "7", "CENTER", "0" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0703107" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「だから水着を着るなんてイヤだったのよ。それをあの子が無理やり誘うから\n……どうしてこんなハレンチな姿になりたがるのかしら、理解不能だわ」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000107_01", "5", "CENTER", "0" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0703108" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「え……な、なんですってぇっ！？　地球の海では、水着姿の女の子たちが行\nきずりの男を誘惑してひと夏の思い出を作るのが流行っていると言うの！？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000107_01", "3", "CENTER", "0" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0703109" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「そ、それじゃあ、まさか、つきみやまりあさんも、そのために水着を……！\n？　ハ、ハレンチだわ……！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000107_01", "5", "CENTER", "0" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0703110" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「くぅぅ、わかりました……これも地球の文化を知るため、この私が流行に乗\nり遅れるなどあってはならない……どうすればいいのか、教えなさい！」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0703111" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「ううぅ、男の熱くて固いものが、私の胸の間に……ビクビクしてて気持ち悪\nいですわ……汚らしい……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000107_01_02" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0703112" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「本当に地球の女の子たちは、みんなこのようなことをしていると言うの……\n？　風紀が乱れていますわ……ハレンチな……！」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0703113" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「わ、わかってるわよ、コレを擦ればいいんでしょう……！　下僕のくせに、\nいちいち私に指図をしないでちょうだい……！」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0703114" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「両側からむぎゅっと挟み込んで、押し付けながら上下に擦る……ひぅぅっ、\n醜い塊が、私の胸の間でビクビクと震えてるぅ……！」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0703115" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「くぅぅ、だらしない顔をして……こんなのが気持ちいいだなんて、男という\nのは本当に理解に苦しみますわ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000107_01_01" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0703116" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「だいたいあなた、どうしてこんなに、オ、オチンポを、大きくしてますの？\n　どうせ最初から、私の水着姿を見て興奮してたのでしょう？」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0703117" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「いつもチラチラと、私の胸やお尻にイヤらしい目を向けて、舐め回すように\n見ていたでしょう！？　女の子はそういう視線に敏感なのよ！」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0703118" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「私の水着姿を見ながら興奮して、いつもこんなふうにしてたかと思うと、ん\nんっ、気持ち悪くて、怖気がするわね……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000107_01_02" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0703119" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「パーフェクトな私の肌が、あなたのような醜い男たちの視線に晒されて、汚\nされていたなんて……んふぅっ、肌がぞわぞわしますわ……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0703120" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「はぁ、はぁ、なんて不快な……んふぅっ、私をこんな気分にさせて、その上\nさらに、こんなイヤらしいことまでさせるなんて……！」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0703121" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「今もイヤらしい目で、オチンポを挟んでシゴく私の胸をじっと見つめて……\nふぅぅっ、おぞましくて、落ち着かない気分になるわね……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000107_01_01" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0703122" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「きゃっ！　なんですの、オチンポをはしたなく跳ねさせて……ココがいいの\nかしら？　この段差のところをグリグリと擦られるのが好きなのね……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000107_01_02" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0703123" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「ん、ふぅ、それにしても男のモノというのは、どうしてこうも醜悪な形をし\nているのかしら……こんなにゴツゴツとして、反り返っていて……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0703124" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「こんなモノが女の子のナカに挿れられて……んんっ、出たり入ったりしたら\n、んふぅっ、ナカがゴリゴリと擦れてしまうじゃないっ……！」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0703125" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「なんてイヤらしい……ふぅ、ふぅ、そんなの、犯罪ですわ……！　こんな凶\n悪なモノは、こうしてさしあげますわ……えい、えいっ……！」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0703126" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「きゃあっ！　オチンポがビクビクと震えて、先っぽの割れ目のところが、イ\nヤらしく開いたり閉じたり……あ、あ、透明なお汁が溢れて……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0703127" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「もしかして、気持ちよくてもうイってしまいそうですの？　こんなにもオチ\nンポを膨らませて……いいでしょう、ほら、出してしまいなさい？」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0703128" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「水着姿の女の子に、オチンポをおっぱいでシゴかれて、んっ、んふぅっ、み\nっともなく、射精してしまいなさい……！」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0703129" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「ほら、ここがいいんでしょう？　ほら、ほら……さっさとイってしまいなさ\nい、んっ、ふっ、臭い精液を、ぴゅっぴゅと吐き出してしまいなさい」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0703130" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「オチンポの気持ちいいところを、おっぱいで念入りにシコシコされて、無様\nに精液を漏らしなさい、ほら、イって、イきなさい……射精しなさい！」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0703131" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「きゃあああっ！？　こんなにっ……！？　やあぁんっ！　おっぱいの間で、\nびゅくびゅくっ……！　オチンチンが跳ねて、精液がいっぱい……！」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000107_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0703132" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「あんっ、あっ、あぁっ……！　ドロドロのザーメンが、ベチャベチャ、かか\nって……やあっ、なにこれ、熱いっ……おっぱいが焼けちゃうっ……！」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0703133" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「うぅぅっ、それに、このニオイ……！　んぅぅっ、青臭くて、生臭くて、鼻\nが曲がりそう……頭がくらくらしてくるわ……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000107_01_05" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0703134" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「やあっ、まだ出るなんて……どれだけ出せば気が済むのよ、早く出し尽くし\nてしまいなさい！　ほら、ほらっ……やぁんっ、また出たぁっ……！」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0703135" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「くぅぅっ、いい加減にしないと、おっぱいがベタベタに汚れちゃうじゃない\n！　早く止まりなさい、この、このっ……きゃあっ！？　またあっ！？」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0703136" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「ふぅ、ふぅ、ふぅぅ……さすがに、もう終わりかしら……？　まったく、ど\nれだけ出すのよ……くぅぅ、結局、ドロドロじゃない……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000107_01_04" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0703137" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「好き放題に射精して、私のおっぱいをこんなにしておきながら……なによ、\nその満足そうな顔は！　ムカつくわね……！」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0703138" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「くうぅぅっ、おっぱいがベタベタして、気持ち悪い……サイテイだわ、こん\nなの……ナニよりも、ニオイがヒドいわね……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000107_01_05" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0703139" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「このニオイを嗅いでいると、はぁ、はぁ、だんだん身体が熱くなってきて…\n…くぅぅっ、頭がぼうっとしてきて……んふぅぅっ……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0703140" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「こ、興奮なんかしてないわよっ！　あなたの汚らしい精液を浴びて興奮する\nなんて、そんなわけないでしょう！　あ、ありえないわっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000107_01_06" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0703201" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「そういうあなたこそ、なんなのよこのオチンポは！？　どうしてまだこんな\nに固いままなのよ！　あれだけ出して、まだ出し足りないって言うの！？」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0703202" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「な、なんですって！？　私の水着姿に興奮しすぎて収まらないだなんて……\nふ、ふんっ！　そんなことを言われて、私が喜ぶとでも思っているの！？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000107_01_04" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0703203" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「……でも、しかたないわね。もう一回だけ、してあげてもいいわ！　だって\n、オチンポが満足するまでするのが、ひと夏の思い出なのでしょう？」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0703204" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「まったく、なんてただれた流行なのかしら……ハレンチだわ……！　本当に\n地球の女の子たちは、みんなこんなことをしているのかしら……？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000107_01_05" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0703205" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「わ、わかっているわよ、すればいいんでしょ！　んくぅぅっ、オチンポが精\n液で濡れて、おっぱいの間でヌルヌル滑る……んふぅっ、変な感じね……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0703206" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「んっ、ふぅっ、ヤだ、オチンポがこすれる度に、精液がネチャネチャいって\n、んふぅぅっ、なんてイヤらしい音なのかしら……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0703207" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「それに、私のおっぱいの間を、精液まみれのオチンポが、出たり入ったりし\nて、んふぅぅっ、すごくエッチなことをしてる気分だわ……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0703208" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「あぁあっ、精液がぐちゃぐちゃに泡立って……すん、すん……はぁぁっ……\n！　イヤらしいニオイが、余計にひどくなってる……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0703209" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「ふぅ、ふぅ、頭がだんだん、ぼうっとしてきて……んふぅぅっ……身体がど\nんどん、熱くなってきてる……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0703210" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「アソコがなんだかジンジンしてきて……はぁぁっ、エッチな気分になっちゃ\nう……なんてイヤらしいの……ハレンチだわ……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0703211" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「え？　もっと強く……？　こう、かしら……？　やぁぁんっ……！　オチン\nポがおっぱいに強く擦れて……あふぅぅんっ……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000107_01_04" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0703212" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「オチンポのデコボコが、おっぱいのナカで、ヌリュヌリュ、擦れて、あんっ\n、やぁんっ、オチンポの形が、ハッキリと分かっちゃう……！」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0703213" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「こんなに精液まみれのオチンポで、おっぱいの間をごりゅごりゅ擦られたら\n、あぁんっ、ニオイが染み付いて、とれなくなっちゃいそう……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
