		{"command":[ "PLAYVOICE", "v2_001_2603303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁ……勢いが弱まっていく……んっ、まだ奥に残ってないか……？　ちゃ\nんと全部出し切るまで搾り出すからな……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2603304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
