		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「あふ……我ながら、変態的なことを言っている気がする……だが、もう自分\nを取り繕うことはするまい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2603408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「そうだ……今や私は貴様のオチンポの虜だ。この、黒光りする逞しいシンボ\nルに、ずっと目が離せないんだ……」", "NORMAL" ]},
