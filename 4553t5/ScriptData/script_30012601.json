		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁぁ……もっと出してくれ……あぁ、谷間を浸して……身体中……ザーメ\nンまみれにさせてくれぇ……あふぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2603302" ]},
