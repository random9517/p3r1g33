		{"command":[ "PLAYVOICE", "v2_001_2603305" ]},
		{"command":[ "SETIMAGE", "0", "still_00000126_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
