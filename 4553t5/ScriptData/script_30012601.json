		{"command":[ "PLAYVOICE", "v2_001_2603402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「んちゅぷっ、ベトベトする……肌に染み込んでくる……強烈なにおいが私を\n支配する……オチンポの奴隷になってしまうぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2603403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
