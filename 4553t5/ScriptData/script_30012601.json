		{"command":[ "PLAYVOICE", "v2_001_2603309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「ま、まぁ……そこまで言うなら考えてやらなくもない。本当に、特別の特別\nだからなっ、そこのところを忘れるなよっ！」", "NORMAL" ]},
