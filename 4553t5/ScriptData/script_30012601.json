{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「あー、急に呼び出して悪かったな。ちょっと、うむ、まぁ……その大した理\n由という程でもないのだが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2603101" ]},
		{"command":[ "SETCHARA", "0", "char_00000126_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「ほら、貴様は最近よく頑張っているだろう？　それで、少しはねぎらいがあ\nってもいいのではと……そう思ったのだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2603102" ]},
		{"command":[ "SETCHARA", "0", "char_00000126_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「だから、つまりは……そのご奉仕というか……な？　私の……胸……お、お\nっぱいでしてやらなくもないと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2603103" ]},
		{"command":[ "SETCHARA", "0", "char_00000126_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「なっ……ち、違うぞっ、別に私がパイズリしたいわけではっ！　う……い、\nいや、その……したい、かも知れん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2603104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「貴様のお陰で、私の身体もそんな風にさせられたから……え、えぇいっ、と\nにかくするぞっ……ほらっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2603105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ……な、何だ……最初から、もうこんなにさせて……貴様も期待してい\nたのではないか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2603106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00000126_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「どうだ、柔らかいだろう？　ふふ……なんなら、少し位触っても構わ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2603107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「んんっ！　あっ、あふっ、んくっ、はぅっ……ほ、本当に遠慮なく……触っ\nてくるな……貴様というやつは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2603108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「あふっ、だが……その図太さは、私が求めていたあるべき男の姿かも知れん\n……くふぅ……はっ、んむっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2603109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「んふっ……それにしても熱いな……谷間の中で……勃起が擦れて……んっ、\n汗が出てきた……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2603110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「うむ、滑りやすくなるしな……私の方からも動かしていくぞ……こう、して\nっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2603111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「んむ……あぁ……どうだ……？　やり方も把握しているからな……しっかり\n密着させて擦る感じがいいんだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2603112" ]},
		{"command":[ "SETIMAGE", "0", "still_00000126_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「はふ、んむ……顔が物語ってるぞ。んふっ……こら、腰を引くな。私のパイ\nズリから逃げるんじゃない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2603113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「んふっ、あふっ、んくっ、んむっ……それにしても、いつ見ても……立派な\nオチンポだ……あふ、んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2603114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「私が見初めただけのことはある……いや、その、オチンポを見初めたワケで\nはないのだが……パイズリのしがいがあるな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2603115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ、ふぅ……あぁ……そうだな、乳首も……硬くなってきてる……当たり\n前だ……こんな近くにオチンポがあるんだぞ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2603116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「興奮するなという方が無理だ……あぁ……こんな強烈なオスのシンボルを前\nに、冷静でいられるわけがない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2603117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁ……たまらない……動かしていくからな……私のおっぱいを存分に感じ\nて欲しい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2603118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……はっ、んふっ、はぁっ……あっ、んんっ……熱い……オチン\nポの太さをいっぱいに感じるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2603119" ]},
		{"command":[ "SETIMAGE", "0", "still_00000126_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、立ち込めるこの匂いもすごい……んっふ……メスの本能が刺\n激されて……身体が発情していくんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2603120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「もっともっと、おっぱいを動かすからな……いっぱいオチンポ……気持ちよ\nくなってくれ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2603121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「はっ、んっ、あふっ、はっ……んはっ……ふふっ、いい表情だ……中でぐに\nぐにオチンポが転がされると、口元が緩んでいくじゃないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2603122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「ほら、ほら……もっとおっぱいを味わいたいんだろう？　はふっ、んっ……\n情けなく腰を突き出して、全く可愛いオチンポめ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2603123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「んんっ！　あっ、くぅっ……また、おっぱい揉みたいのかっ？　仕方ないや\nつめ……んっ、あぁんっ……は……あふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2603124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁ、私のおっぱいが……オチンポを悦ばせるいやらしい道具に成り下がっ\nてしまっている……乳首もさっきよりしこって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2603125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「くぅっ！　痺れるっ……あっ、はぅっ……あぁ、そんな腰を振るなんて……\nんっ、私のおっぱいをオマンコにする気か……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2603126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「いや……ダメじゃない……貴様のオチンポが一番だからな……どんなことで\nもしてくれていい……あぁぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2603127" ]},
		{"command":[ "SETIMAGE", "0", "still_00000126_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ、あぁ……乳首を引っ張られながら……まだパイズリするぅ……んふっ\n、あっ、はっ、あぁっ……んっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2603128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁ、んふっ……いやらしい……オチンポと擦れ合う度に……乳首が……ん\nんっ、ジンジンする……はぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2603129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁ……んふぁっ……おっぱいもめちゃくちゃにされて……本当にオマンコ\nにされてるみたいな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2603130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「んくんっ、はぁぁっ……オチンポが、出入りする感覚が……気持ち……よす\nぎて……あっ、ふっ、はぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2603131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、エロ顔をしている……？　あふっ、そんなこと……こんな風\nにおっぱいを使われて、普通の顔でいられるかっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2603132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……私の……おっぱいの弱いところを全部知り尽くしているよう\nに……オチンポを動かしてっ、トロ顔になるに決まってる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2603133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「くぅんっ……あぁっ、んふっ、中でビクビクし始めてる……そろそろ、んっ\n……我慢出来なくなってるんじゃないか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2603134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「ほら、もう我慢汁もいっぱい滲んで……限界が近いんだろう……鈴口が……\nビクビクしているぞ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2603135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「いいぞ……そのまま、思いっきり出して……私のおっぱいの中っ……ドロド\nロにさせてくれっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2603136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「ふぁっ！　あふっ……出たっ……！　新鮮ザーメンっ……こんなにぃっ……\nんぁっ、熱いっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2603137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000126_01_04" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「あふっ……はぁ……あぁ、中出しされてる……おっぱいの中……精液でいっ\nぱいになってるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2603138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁ……ドクドク脈打って……こんな風に出るんだな……んっく……すごい\n迫力だ……オチンポに圧倒されてしまう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2603139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ、落ち着いたか……たっぷり出したな……。私のおっぱいで感じてくれ\nたんだな……嬉しいぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2603140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「だが……んっ、ふ……だが、その表情は、まだまだ足りないと言っているな\n……いや、分かるぞ……私もまだし足りないからな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2603201" ]},
		{"command":[ "SETIMAGE", "0", "still_00000126_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「オチンポもそう言ってるようだしな……このまま続けて大丈夫だな？　んっ\n、任せてくれ……もっと気持ちよくなってもらうからな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2603202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁ……亀頭から……残り汁が垂れて来てる……んふっ、後でたっぷり味わ\nわせてもらおう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2603203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「さて、続けてするぞ……オチンポの方は、出したばかりで敏感になっている\nようだな。最初は優しくしてやらないとな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2603204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ、はっ、おっぱいの中が精液のお陰でオマンコになったみたいだ……ふ\nふっ、このヌルヌルの中でオチンポ……感じてくれ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2603205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「はっ、んっ、あぁ……こうして……おっぱい……押し潰すぅ……私のおっぱ\nいが……いやらしい形に歪んでいくぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2603206" ]},
		{"command":[ "SETIMAGE", "0", "still_00000126_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「うんっ、んっ、ふっ……はっ、あぁっ……よく滑るな……オチンポが擦れ合\nうだけで……私のおっぱいも気持ちよくなっていく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2603207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ、はぁっ、オチンポがビクビク震えてる……気持ちいいのか？　ふふっ\n、なるほどな……オチンポが頷いてるみたいだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2603208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「こんなに分かりやすく喜んでくれると……私も、奉仕のしがいがあるという\nものだ……んっ、ふっ、はぁ……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2603209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁ、もちろん貴様が触ってくれても構わない……私のおっぱいは、もう貴\n様のモノと言っても過言ではない……あぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2603210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「はっ、んふっ……そうっ、乳首……いいっ！　あっ、オチンポ擦りながらっ\n、気持ちよくなるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2603211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁ……もっとご奉仕しなきゃいけないのに……私のおっぱい……敏感にな\nりすぎてっ……はぁうっ、感じ……すぎるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2603212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁっ、いやらしい顔を見せてしまう……んんっ、そ、そんなニヤニヤする\nなぁ……はぁ、私だって悦んでしまうんだっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2603213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「だいたい……貴様だって……同じくらいだらしない顔をしているんだからな\nっ……こうしてっ、オチンポの鈴口のところをギュッと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2603214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「ほら見ろ……弱いんだろうっ？　また先端から新しい汁が滲んできている…\n…出したがりのオチンポめ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2603215" ]},
		{"command":[ "SETIMAGE", "0", "still_00000126_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ、はぁっ、んふっ、まだだ……もう少し我慢だぞ……おっぱい……ぎゅ\nっと重ねて……皮をめくって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2603216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁ……んんっ、ビクビクしてるっ……んんっ、可愛いやつめ……必死に踏\nん張っているのが丸わかりだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2603217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ、限界が近いな？　よし、もういいぞ……ちゃんと全部吐き出す\nんだ……貴様の欲望の塊を……全部私にぶちまけて……」", "NORMAL" ]},
