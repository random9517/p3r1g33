		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁぁぁ……いっぱい流し込んでぇ……ずっとイッてるからぁっ、私のイキ\nマンコにっ……種付け……し続けてぇっ……！」", "NORMAL" ]},
