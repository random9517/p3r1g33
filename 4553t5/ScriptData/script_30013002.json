		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「だ、だがっ……あっ、この……嬉しい感じは……と、止められないっ……は\nふぁっ、顔が緩んで……だらしない表情になってるう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3004209" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
