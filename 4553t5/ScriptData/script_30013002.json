		{"command":[ "SETIMAGE", "0", "still_00000130_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「それなら、お願いしても……いいか？　私も……まだ続き……したいって思\nっているんだ……」", "NORMAL" ]},
