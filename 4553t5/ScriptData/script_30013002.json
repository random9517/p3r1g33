		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「くぅぅんっ……それも好きっ、あぁっ、貴方のチンポが好きっ、大好きぃっ\n……はひっ、気持ちいいっ！」", "NORMAL" ]},
