		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んふぁぁぁぁぁぁっ！　またっ、中っ……出てっ……熱いのっ……あっ、ひ\nぃぃぃぃぃぃっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3004301" ]},
		{"command":[ "SETIMAGE", "0", "still_00000130_02_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ふぁぁ……もう、いっぱいだが……それでも、まだオマンコは欲しがってる\n……新しいザーメンで上書きされたがってるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3004302" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んんっ、はぁぁぁ……気持ちよすぎる……オマンコ……ずっとイッたまま、\n降りられなくなってる……すご、すぎぃぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3004303" ]},
		{"command":[ "SETIMAGE", "0", "still_00000130_02_11" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あっ、ふっ……後、少し……？　んっ……ちゃんと、出し切って……全部…\n…オマンコに飲ませてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3004304" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はっ、はぁっ、んっ、はぁぁぁぁぁぁぁ……終わった……？　全部……流し\n込まれた……？　種付け……できた……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3004305" ]},
		{"command":[ "SETIMAGE", "0", "still_00000130_02_12" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ、あぁ……ありがとう……ふふ、私は幸せだ……赤ちゃんを宿していな\nくても……これだけ愛されたんだからな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3004306" ]},
		{"command":[ "SETIMAGE", "0", "still_00000130_02_11" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「それにしても、本当に最後の最後まで……絶倫チンポだったな……私なんて\n、もう腰が抜けそうだと言うのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3004307" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「つくづく、オスの欲望の凄まじさを思い知った……いや、貴方が特別なだけ\nかも知れないがな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3004308" ]},
		{"command":[ "SETIMAGE", "0", "still_00000130_02_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「だが、一人の女……メスとして……こんなにも愛される喜び……この聖夜に\n、最高のひとときを過ごせたこと……幸せに感じている……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3004309" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁ……後もう少し休んだら……もう一回しよう……ふふっ、今夜は本当に\n寝られないかも知れないな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3004310" ]},
