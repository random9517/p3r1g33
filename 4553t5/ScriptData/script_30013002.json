		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んんっ、貴方も……あっ、ちゃんと……私のオマンコ……楽しんでくれてる\nかっ？　はっ、ふっ……私ばっかりになってないか？」", "NORMAL" ]},
