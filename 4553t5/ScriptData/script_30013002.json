		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ……ふ……やはり、この夜は特別だ……お互いに気持ちが高ぶって仕方\nがない……そうだろう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3004101" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そうでなければ、こんな発情状態になる筈がない……はぁ、はぁ……そうだ\n、何より私がもう待ちきれないんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3004102" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ほ、ほら……見てくれ……このサンタの姿の奥に……私の浅ましい欲望が…\n…どれだけ隠れているのか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3004103" ]},
		{"command":[ "SETIMAGE", "0", "still_00000130_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁ……見せてしまってる……は、恥ずかしいに決まっている……！　こん\nな、興奮しきったオマンコを見られているなんて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3004104" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「濡れて……そうだ……貴様のお陰で……もう、すっかり蕩けきっているオマ\nンコだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3004105" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「早く……そのビンビンに勃起したチンポを奥までハメて……私のオマンコを\n芯からあたためて欲しい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3004106" ]},
		{"command":[ "SETIMAGE", "0", "still_00000130_02_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「もう、待ちきれない……チンポを欲しがって……このオマンコはずっと涎を\n垂らし続けているんだ……お願いだから……早くぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3004107" ]},
		{"command":[ "SETIMAGE", "0", "still_00000130_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あっ、はっ、ふぁひぃっ……！　あぁぁぉっ……は、入るっ……チンポっ、\nあぉぉ……入って……来るぅぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3004108" ]},
		{"command":[ "SETIMAGE", "0", "still_00000130_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んんんっ……！　あぁ、分かる……ぶっといのが……私のオマンコをみっち\nりと広げて……どんどんめり込んでいくのを……感じるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3004109" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁ……痛くない……というか、最初から……ずっと気持ちよくて……どう\nにかなってしまいそうだ……は、ふぁっ……んっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3004110" ]},
		{"command":[ "SETIMAGE", "0", "still_00000130_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「いいぞ……遠慮することはない。このまま、奥深くまでチンポを押し込んで\n……ズ、ズボズボ……いやらしくかき回して欲しい……あ、あぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3004111" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はっ、んんっ、あぁっ、そこっ、あっ、一番好きなとこからぁしてくれるな\nんてぇ……あひっ、私の感じやすいところぉっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3004112" ]},
		{"command":[ "SETIMAGE", "0", "still_00000130_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「もう、全部……知られてるからぁ……あっ、んくぅっ、あひっ、ゆっくりで\nも……すごく、気持ちよくしてくれるぅ……んっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3004113" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あんっ、んぁっ、あぁっ、グポグポしてるっ♪　チンポがっ、リズミカルに\nオマンコの中っ、出入りしてぇっ……はっ、ひゅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3004114" ]},
		{"command":[ "SETIMAGE", "0", "still_00000130_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「私の……エッチな汁が、いっぱいかき混ぜられてっ、いやらしい響きっ……\n止まらないのぉっ、んぁぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3004115" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んくぁぁっ……チンポ熱いっ……！　あぁっ、そうだ……ずっとこうして欲\nしかったんだ……もっと身体くっつけて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3004116" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁ……嬉しい……温もりを感じる……んふぅ……この熱を感じながら……\nあっ、オマンコかき回されるのっ……好きぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3004117" ]},
		{"command":[ "SETIMAGE", "0", "still_00000130_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はんっ、あんっ、そうだっ、あんっ、いつも……強気でっ、侮られないよう\nにっ……高飛車に振る舞っている私だがっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3004118" ]},
		{"command":[ "SETIMAGE", "0", "still_00000130_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「本当は……貴様……い、いや……貴方に……こうしてっ、征服されるように\n……オマンコされたいって、ずっと思っていたんだっ……んぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3004119" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁっ、好きっ……貴方のことが好きぃっ！　だからっ、もっと突いてっ！\n　奥のとこぉっ、もっといっぱいチンポで突いてぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3004120" ]},
		{"command":[ "SETIMAGE", "0", "still_00000130_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んひぁっ！　あぁっ……と、届いてる……今のとこっ、あっ、オ、オマンコ\n……弱いからっ、はっ、ひっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3004121" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「うぅっ……んぁっ、全部……分かってるんだな……あっ、おぉっ、だが、も\nう……私も素直に声を出す……だけだ……はんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3004122" ]},
		{"command":[ "SETIMAGE", "0", "still_00000130_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あっ、おぉっ、そうっ、そのグリグリが好きぃっ♪　チンポで……オマンコ\nの肉……擦り上げられるの……気持ちよすぎるぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3004123" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んぁっ、あぁんっ、は、はしたない声が止まらないっ、だが、貴方の前でな\nら……どんなに恥ずかしいことでもしてしまうからっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3004124" ]},
		{"command":[ "SETIMAGE", "0", "still_00000130_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あんっ、だからっ、オマンコしてっ！　私もっ、んんっ……精一杯に、オマ\nンコ締め付けるからっ、んんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3004125" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んふっ……今の、チンポがいいのか？　ふふっ、それは何よりだ……私も、\n貴方の乱れた声を聞きたいからな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3004126" ]},
		{"command":[ "SETIMAGE", "0", "still_00000130_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はっ、ふっ、一緒に……人に聞かせられないような、エッチな声を出してい\nこうっ、あひぉっ！　ま、またチンポ、そこぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3004127" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁっ、あふぁっ、やっ、今……隙間から……ぽたぽたっ、汁が垂れてしま\nった……あぁ、恥ずかしいシミができてしまうっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3004128" ]},
		{"command":[ "SETIMAGE", "0", "still_00000130_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「き、気にせずもっと垂らせっ？　そんなっ、別に出そうと思って出してる訳\nじゃ……ふひぃんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3004129" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「けどっ、そうやってっ、あっ、ズボズボされたらっ、奥からっ……どんどん\n漏れて来るぅっ、ま、またお汁……出るぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3004130" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁ……嘘だ……こんな、あっ、気持ちよすぎる……全身が敏感になりすぎ\nて……どこを触られても、電気が流れるみたいに痺れてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3004131" ]},
		{"command":[ "SETIMAGE", "0", "still_00000130_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「でも、その痺れが……嬉しくて……幸せで……あぁ、そうだ……私は今幸せ\nなんだ……好きな人と繋がって……子宮が降りてきているぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3004132" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
