		{"command":[ "PLAYVOICE", "v2_001_3004133" ]},
		{"command":[ "SETIMAGE", "0", "still_00000130_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はっ、ふっ……チンポも……止まらなくなってる……んっ、出したくなった\nら……中がいい……オマンコの奥に……中出し……射精して欲しい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3004134" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そうだ……このまま、熱いザーメン……オマンコに直接出してっ……あぁっ\n、わ、私も……もう待ちきれないっ、イキそうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3004135" ]},
		{"command":[ "SETIMAGE", "0", "still_00000130_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ、あぁっ、イクっ……オマンコッ……イクのっ！　チンポッ、ズボズボ\nされてっ、来てっ、私もっ……イクからっ、あっ、んぁぁぁぁっ！」", "NORMAL" ]},
