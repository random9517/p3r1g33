		{"command":[ "SETIMAGE", "0", "still_00000130_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あんっ、んふ……休憩時間……あれだけで大丈夫だったのか？　わ、私が疲\nれてないか心配だったのか？」", "NORMAL" ]},
