		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁ、そこされるの好きぃ……んっ、もっと乱暴でもいい……ぎゅって抱き\nしめて……腰……打ち付けてぇ……」", "NORMAL" ]},
