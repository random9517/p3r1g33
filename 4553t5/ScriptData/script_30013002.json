		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はんっ、あっ、そうだ……これでも鍛えているんだからな……多少のピスト\nンは、受け止められる……はっ、あひっ、んぁぉ！」", "NORMAL" ]},
