		{"command":[ "SETIMAGE", "0", "still_00000130_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「チンポ……抜かないで、このまま……もっとオマンコ……続けて、またザー\nメン……出しまくって……完全に貴方のメスにして欲しい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3004204" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ほら……このヒクヒクしてるオマンコぉ……このままぶっすりって……んん\nんんっ！　くっ、ふぁぁぁぁぁんっ！」", "NORMAL" ]},
