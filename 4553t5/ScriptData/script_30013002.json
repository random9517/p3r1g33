		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「中だけじゃなく……んっ、身体も……染める……んんっ、構わない……全部\n、貴方の思う通りにして欲しい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3004402" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はっ、ふっ……あぁっ、あったかいのが気持ちいい……私もイッて……身体\n、プルプルしてしまってるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3004403" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ……お尻に……チンポが当たってる……ヌルヌル……もっと、しっかり\n塗りつけてぇ……はふぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3004404" ]},
		{"command":[ "SETIMAGE", "0", "still_00000130_02_14" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……あっ……止まった……ちゃんと出したんだな……すごい……\nお尻が……ザーメンでドロドロだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3004405" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「確かにこれだけのマーキング……私が、貴方のメスにさせられた、何よりの\n証と言えるだろうな……ふふ……嬉しいな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3004406" ]},
		{"command":[ "SETIMAGE", "0", "still_00000130_02_13" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「本当に、ずっと衰えないままだったな……だが、それでこそ私の求めた男の\n理想かも知れない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3004407" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ふふ、最初はサンタの姿も、ちょっと複雑に思うこともあったが……今とな\nっては、この姿でよかったと思えるな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3004408" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「さすがにくたびれただろう？　あぁ……一休みしようか。だが……チンポは\nまだ半勃起だ……これは、本当に出し切ってないということだな？」", "NORMAL" ]},
