		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んんっ……いや、だが、まだ……簡単にはイカない……一緒がいいっ、また\n……貴方と一緒に……オマンコ、イキたいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3004215" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はふっ、そうだ……私は欲張りなんだ……イッて欲しいしっ……イキたいし\nっ……でも、ずっとこうしていたいしっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3004216" ]},
		{"command":[ "SETIMAGE", "0", "still_00000130_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁっ……あんっ、色々あり過ぎて……もう、頭が真っ白になっていくっ！\n　はひっ、んぁんっ、チンポっ……もうすぐなのかっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3004217" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「うんっ、んんっ……どんな形でもいいっ……貴方のしたいようにしてっ……\nでも、私のオマンコを使ってイッて欲しいからぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3004218" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「いっぱいお尻を振ってっ、メスになるっ！　んぁぁっ、も、もうイクっ！　\n私のオマンコっ、イッちゃうからぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3004219" ]},
		{"command":[ "SETIMAGE", "0", "still_00000130_02_09" ]},	
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「来てっ、出してっ！　熱くて濃いのをっ、もう一回っ……びゅくびゅくっ！\n　いっぱいっ、出してぇぇぇぇっ！」", "NORMAL" ]},
