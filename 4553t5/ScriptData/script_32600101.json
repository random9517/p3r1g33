{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「な……なんなのです、一体。突然こんなところに呼び出して……。今が何時\nだと思っていらっしゃるの？　夜も夜、真・夜・中ですのよっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0103101" ]},
		{"command":[ "SETCHARA", "0", "char_00026001_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「……はぁ？　今日の任務で私が敗北したことへのお仕置き？　しつけ……？\n　何の権限があって貴方にそんなことをしていただかなくてはならないの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0103102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「言われなくても私はとっくに深く反省して……。って、ウソ！？　や、やだ\nぁっ！　な、なぜ真面目な話の途中でズボンをお脱ぎに！？　やめなさい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0103103" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00026001_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「う、く……っ！　ど……どういうつもりですの……。こ、これは……ええと\n、確かオチンポとかいうモノでしょう。男の股間にぶらさがっている……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0103104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「ん？　ぶらさがって？　……おかしいですわね。目の前のコレは、ギンギン\nに上を向いているような……。なんですって？　初めて見たのかって！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0103105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「そ、そ、そ、そんなわけがないでしょう！　私は宇宙帝国の貴族であり気高\nき軍人！　准将の位を持つこの私がオチンポごときを見たことがない？」　", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0103106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「ふ……ふざけないで！　ありますッ、何万回も見た事がありますっ！　……\nな、なによ。そういう反応が処女っぽい？　キ、キィイ！　黙りなさい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0103107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「オチンポ、くらい……知っていますとも……。うう……ですから早くしまっ\nてください！　やっ！？　顔に近づけないでっ、んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「私の尊いお鼻にぴとぴとさきっちょをくっつけないでぇ！　へ、変な透明な\nお汁がついちゃったじゃありませんの！　最悪ぅ……最低ですわぁあ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「……そ、そうです。私はオチンポを見るのは初めてです！　これでいいでし\nょうっ、認めたのですからもう、およしになって！　離れなさいよっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「な……なんですか。そんな高慢な態度をとっていいのか？　え……も、もし\nかして怒っているの？　どうして！？　負けたから！？　っう、うう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0103111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「……敗北したことは……反省しています。償いはなんでもしますっ！　で、\nですから怒らないで！　あ、あぁ……冷たい目をやめてください……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「許してほしければオチンポを咥えてみろ？　な、なぜ！？　あっ……！　ご\n、ごめんなさい。そうです。なんでもすると言ったのは私でした……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「……あ、の……。どうか、誰にも言わないでくださいませね？　オチンポは\nおしゃぶりしますから、そのぉ……。って、あっ！？　いきなりっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「んぅううううっ！？　んむ～～～～っ！　んぁ……♪　お、おひんぽがぁ…\n…わたくひの純粋無垢なる至高のお口にねじこまれてぇ……！　んぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0103115" ]},
		{"command":[ "SETIMAGE", "0", "still_00026001_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「ま、待っれくらひゃい！　舐めまひゅっ、咥えまひゅから乱暴はしないれ…\n…！　こ、こうでしょう？　……っれろ……ちゅぷ、ぺろ、ぺろっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「な、なんだか生臭い臭い？　しょっぱい……？　ぴちゃ……れろ、ちゅぷ…\n…くちゅ、ちゅ……ちゅむ……。これでいいでひゅか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「えっ！？　全然ダメ！？　んぁうううっ！？　ふぁああっ！　腰を突き出さ\nないれくだひゃいまへぇえっ！　今喉に、喉奥にぶっ刺さって！　あうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0103118" ]},
		{"command":[ "SETIMAGE", "0", "still_00026001_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「息が苦ひぃい……！　ぷぁううっ！？　たどたどしすぎてまったく気持ちよ\nくない？　あっ……で、でもそれは……！　初めてだからで……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「んゃうっ！？　言い訳をするな？　軍人のくせにぐちゃぐちゃうるさい！？\n　……そ、それを言われると……。でも、私、オチンポなんて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「……ふぁああ！？　ま、また腰を動かして！　わ、わかりまひた！　も、も\nう少しらけ頑張ってみまひゅ！　ですからちょっと待ってくだひゃいい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0103121" ]},
		{"command":[ "SETIMAGE", "0", "still_00026001_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「……ちゅぷっ！　ぷちゅ、くちゅ、ちゅむっ、ちゅぷっ！　んぁああ……♪\n　唇で何度も先っちょにキスひて……。それで、次は、咥えれ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「あむっ！　じゅぷっ！　ぐちゅっじゅぷ！　……んっ！？　い、今なんだか\n口の中で、オチンポがビクンと震えたような……？　こ、こうですの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「……じゅぷっ！　じゅぷっ、ぐちゅ！　ん、ん、ん……！　れろっ！　れる\n……ぐちゅっ！　大きく口を開けれ、オチンポを深く咥えれ……ぐちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「んんんぁう……！　やっぱり呼吸が……！　は、はい……。鼻で息をして、\n口はオチンポに集中ですか。や、やってみまひゅ。……ぢゅるるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「ぐちゅぷっ！　じゅるっ！　ぢゅぷぷぷっ！　じゅるぅっ！　んふっ、こ、\nこれでいいのですわよねぇ？　……ぴちゃっ、じゅるっ、ぐっちゅっじゅる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「……ん♪　……んん♪　な……何……？　この感情、は……？　んむっ♪　\n酸素が足りなくれ、オチンポが暴れていて、苦しいのに、つらいのにぃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0103127" ]},
		{"command":[ "SETIMAGE", "0", "still_00026001_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「心臓がドキドキして鼓動が高鳴りまひゅわ……！　……んぁっ！？　ぐちゅ\nっ！　オチンポ♪　オチンポしゃぶらされると、こ、興奮ひまひゅ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「じゅぷっ！　ぐちゅっ！　じゅるっ、じゅっぷっ……！　はぁっ♪　ぢゅる\n……じゅるっ！　じゅるっ、じゅぷぷぷっ！　ゾクゾク、ワクワクぅう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「わたくひをマゾだとおっしゃるの？　ち……違いまひゅ、でも……んむぅう\nっ♪　命令されて、見下されて……オチンポ無理やり咥えさせられれ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「それで、……あっ、お股が熱くなっているのは事実、れひゅ……じゅぷっ！\n　わたくひ、私、強制おしゃぶりで感じている？　ああああ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「み、見ないれ……！　見ないれくだひゃい！　あうううっ、わたくひぃ……\n！　もう自分でも何がなんらか……！　あう♪　あふ、ふぅううっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0103132" ]},
		{"command":[ "SETIMAGE", "0", "still_00026001_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「れろ、れろ、れろ、オチンポ……オチンポ、オチンポぉ……♪　もっと舐め\nたい……！　っぐちゅっ！　変な透明なお汁、どんどん出てくるのにぃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0103133" ]},
		{"command":[ "SETIMAGE", "0", "still_00026001_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「それをちゅーちゅー吸うのが、飲むのがやめられにゃいですぅう……！　ぴ\nちゃっ！　ちゅぷ、ぐちゅっ、じゅぷっ！　あ、あの！　あのぉおっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「わたくひの素晴らしきお口れ、貴方も感じてくだひゃい！　わたくひも感じ\nていますから！　……じゅっぷっ！　じゅるっ、ぢゅるるるっ、じゅぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0103135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「無知なわたくひでも知っていまひゅ！　オチンポをナメナメし続けると真っ\n白な精液がここから出るのでひゅよね？　それをく、くだひゃい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0103136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「出ひてほしいれひゅ！　……じゅるっ！　精液っ♪　精液欲しいれひゅ♪　\nご褒美っ、くだひゃい！　お願いひまひゅ！　じゅっぷっじゅぷっじゅぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0103137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「ッんんんんんんん～～～～～～っ♪　ぷぁううっ！　んぷ♪　んむぅううう\n～～～♪　むっ♪　んん！　んん～～～～んんっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0103138" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00026001_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「えっ？　にっがっ！　超絶苦いですわ！？　……えっ！？　あっ！　それに\n次々出てくる！　んえぇっ！　こ、こんなに大量に！？　んーーーー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「わたくひの小さなお口から溢れ出しそうなほどにぃいい！　……んうううう\n！　にがいぃ、熱い！　多いぃいい！　精液苦すぎますううう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「ん！　ん！　これっ！　ぺってお外に吐き出したら……。……あ！？　だ、\nダメでひゅよね！　は、はい！　ただ、想像よりなんかすごくてっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0103201" ]},
		{"command":[ "SETIMAGE", "0", "still_00026001_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「びっくりして！　……飲め？　……の、飲む！？　わたくひが！？　……え\n、えぇと……飲む……精液を……。わ……わかりました……んんん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「あ、あれ……全然うまく飲めない。んん、んん……お口の中でベトベトして\nる、舌に絡みつくぅ……飲みにくい……。でも、飲まなきゃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0103203" ]},
		{"command":[ "SETIMAGE", "0", "still_00026001_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「っごくっ……。ん～～～～！　やっぱり苦いぃいい！　でも、ギリギリ飲め\nなくは……。……ごく。ごきゅ……。うううう、んはぁああ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0103204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「飲み干したら綺麗にお掃除しろ、ですか？　お掃除とは？　……あっ、舌で\nオチンポを舐めて、付着したままの、残った精液を飲むのですね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「も……もちろん知っております！　いきますよ！　……っちゅ……。ぴちゃ\n……ぴちゃ……。ん！　ちょっとくさい……ぴちゃ、ぴちゃ、ちゅっぷ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「こ、これくらいでいかがでしょうか……。え、もっと丁寧に素早く、ちゃん\nとやれ？　うう……そうはおっしゃいますけれど、オ、オチンポが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0103207" ]},
		{"command":[ "SETIMAGE", "0", "still_00026001_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「舐めれば舐めるほどぉ！　長く太く大きくなって、わたっ、わたくひのお口\nに再び侵入してきているのですけれど！？　あっ！　なにこれ硬いぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「え？　え？　むぅっ？　んむむっ！？　……お掃除失敗ですか？　射精させ\nて、精液を全て舐め取るまで終わらない？　と、いうことはぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「あっ！？　も、もう一度咥えろということですの！？　そんなぁっ……！　\nんむっ！　オチンポ、さっきよりあきらかに太くなっておりますのよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0103210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「それなのに、続けて二回もおしゃぶりをだなんて……ああっ、私、一族に叱\nられます！　き、貴族なのですよ！？　ですから……ですからぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「おしゃぶりしますから出来るだけ早く、もう一度出してくだひゃい……。ぺ\nろ……っ、ちゅぷ、ぷちゅ……一刻も早く終わらせてぇ……！　っぷちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0103212" ]},
		{"command":[ "SETIMAGE", "0", "still_00026001_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「ん、む、宇宙帝国のお父様お母様、申し訳ありまひぇん……！　私、今、お\n仕置きでオチンポおしゃぶりさせられておりまひゅうう……！　っじゅるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「熱心にご奉仕しろと、言われてぇ……自分からオチンポ舐め舐めひていまひ\nゅぅ……！　んれろぉおおっ♪　レロレロレロっ、れるぅうっ、れろぉっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0103214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「うっうっ、一族の恥ぃ、軍人失格ぅう……！　なのにやっぱり興奮して……\nっ。ん、む、んむっ！　ぢゅるっ、じゅるっ、じゅるるるっ、じゅううう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0103215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「れろっ、れろ、れろ……れろっ♪　はぁ、はぁ、はぁ……お股が濡れてきま\nひた。っぢゅる……！　じゅるっ、じゅるっ、じゅるるるっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0103216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「淫らな娘でごめんなひゃいぃい……！　ぐちゅっ！　ずっちゅっ、ぬちゅ…\n…ちゅっぽっ！　ちゅぷっ、ぷちゅ、じゅっぷっ、じゅるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「あぁ、もう一度……もう一度わたくひにお情けをくだひゃいませぇ、この生\n意気なお口に、今度こそ最後の一滴まで精液注いでくださいませぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0103218" ]},
		{"command":[ "SETIMAGE", "0", "still_00026001_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「上手に飲みます、から……どうかお慈悲を、淫乱貴族、淫乱軍人のわたくひ\nに精液をおめぐみくだひゃいぃ……！　っれろっ、れろっ、くちゅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「あ、あああ……っ♪　お口の中いっぱいにぃい……♪　オチンポが膨らんで\n、……っあっ♪　く、くるひい♪　出すのでひゅね♪　んんんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「むぅっ♪　んむぅうううんんんんっ♪　んむっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0103301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00026001_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「で、でまひたぁあ♪　出ひてくだひゃいまひたねぇっ♪　ごくっ！　ごくっ\n……！　同じ手を二度食らうわたくひではございまひぇんことよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「二回目の精液は見事に一滴残らず飲み干ひて……って、ぷぁううっ！？　量\nがっ……♪　あっ、ふ、増えているぅっ、飲みきれませんわぁっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0103303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「んんんんん－ーーーっ！　んんんぅ～～～～っ♪　っごくっ……！　ゴクッ\n……！　ぷぁあぁっ、飲んでも飲んでもお口の中に……ゴクッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0103304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「も、もう充分ですぅう……♪　頭の中にまで精液広がってきそうですわぁ…\n…！　んくっ、お掃除しますからもう出さないれぇ……♪　れろっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0103305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「綺麗に……飲み干す……。ごくっ♪　精液は全て舐め取るぅ……♪　ぴちゃ\nっ、ちゅぷ、れろっ……れろっ、ごくっ、ごくっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0103306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「あ、あああ……♪　この苦味、頭がバカになる禁断の味ぃ……♪　あああ、\nいけませんわぁ……少しでもお残ししたら、またやり直し……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0103307" ]},
		{"command":[ "SETIMAGE", "0", "still_00026001_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「でも……それも悪くはないのかも、と思ってしまう私がおります……。うう\nう、貴方の精液には私をおかしくする何かがある……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0103308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「……え？　しつけをされてそんなに嬉しそうにしているのはマゾだ、ですっ\nて？　あっ……。そ、それは……ううう……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「それは単なるお仕置きの成果、ということにしておいてくださいまし。少し\nだけ従順になったのですから、それでいいではありませんかぁ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「んひゃぁああっ！？　そんなっ、お顔に！？　私の大切なお顔にぃ、射精な\nさるだなんて……予想外ですわぁっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0103401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00026001_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「ひぁああっ……！？　あうううっ♪　ん～～っ、んッんっんううう～～～っ\n♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「これがっ……これがしつけ！　これが貴方流のお仕置きというわけですのね\nぇえっ！　高慢な私を屈服させる強烈な一撃……、んんっ、一撃ぃ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0103403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「あっ！　ち、違いますわ！　何度も何度もかかってます！　ひゃううっ！　\nあふっ！　んふっ……♪　こ、こんなにほとばしらせるほど感じて！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0103404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「もしそうだったら少しうれし……って、きゃぁあっ！　ドロドロがぁっ、ど\nぷどぷお顔に当たって、弾けて……ダラダラ垂れてきてますわぁあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0103405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「んぁあっ、熱いです……っ♪　ん、ぅ、口の中にも入ってくるぅ……！　ん\nん！　苦いっ……あっ！　一度目よりも濃厚さが増しているようなっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0103406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「はひぃいい……♪　こんなにいっぱい、顔に精液塗りたくられて……んんっ\n♪　息をするたびに、精液の臭いが鼻に入ってきますぅう……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0103407" ]},
		{"command":[ "SETIMAGE", "0", "still_00026001_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「……いくら貴族軍人といえども、敗北してしまえばこのようなお仕置きを受\nける……♪　はぁ、はぁ……♪　あの、一つお聞きしたいのですけれど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0103408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「私が本当は、これを嫌だと思っていないとしたら……お仕置きは無効となっ\nて、もっとキツぅいしつけが待っている、ということはございます？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0103409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「もしそうであれば……、私、私……♪　はっ！　い、いえ、なんでもござい\nませんわ。今の言葉はどうかお忘れになってくださいませぇ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_0103410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
