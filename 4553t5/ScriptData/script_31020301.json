{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「あは～～～……空は青いし、海は綺麗だし、雲はモックモクだし……ああ、\nビーチって最高ですね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0303101" ]},
		{"command":[ "SETCHARA", "0", "char_00010203_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「その上、姉さんも妹もいなければ、テストも赤点も補習も落第も留年もない\n……ストレスがないって、本当に嬉しいです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0303102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「さあ、それじゃ豪快に楽しんでしまいましょう！　ふっふっふ……あたしは\n水着女子ですからね、恰好通りリゾートを満喫しなきゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0303103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「え？　その前に日焼け止めローションを使うべき？　な～にを意識高い系乙\n女みたいなこと言ってるんですか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0303104" ]},
		{"command":[ "SETCHARA", "0", "char_00010203_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「って、ひえええええ……い、いきなりパンツ降ろして、おちんちん、突き出\nさないで下さいよぉ～～……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0303105" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00010203_01_02" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「……はぁ、もう……最初っから、こんなことするつもりであたしを誘ったん\nでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0303106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「ええ、丸わかりですとも。策士のあたしを出し抜こうだなんて、百億年ぐら\nい早いんじゃないですかね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0303107" ]},
		{"command":[ "SETIMAGE", "0", "still_00010203_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「古人いわく、転ばぬ先の杖……つまり転ばないよう杖の先端をしっかり持て\nってことです。あたしは用心深い性格ですからね、警戒は怠りません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0303108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「はぁ……それにしても、ん、ふぅ……ローション、いい匂い。トロトロして\n、気持ちいい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0303109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「おちんちんが谷間の中で、気持ちよさそうにしています。ローションとおっ\nぱい……最強の組み合わせですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0303110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「ん……ふぅ、それじゃ、動かしますよ……まずはゆっくりと……ん、んん…\n…ふぅ、どうです？　柔らかくて気持ちいいでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0303111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「言わなくても表情でわかります。ふふ、最近恥ずかしい恰好してるから、男\n性の視線や表情に敏感になっちゃってるんですよねー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0303112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「その中でも、隊長さんって常にエッチな視線、送り続けてますもん……マジ\nで、ずーっとエッチな顔してます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0303113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「けど、喜んでくれてよかったです……この恰好、姉妹でお揃いってことで仕\n方なく着てたんです。まあ、姉は大喜びしてますけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0303114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「それにしても、ん、んふぅ……こんなに硬く、大きくなってる……先っちょ\nがまんまるに膨らんで、傘がこんなに開いて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0303115" ]},
		{"command":[ "SETIMAGE", "0", "still_00010203_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「はぁ……ふぅ、ローションのヌルヌルと、おっぱいのすべすべした感触が混\nじり合って……ああん、あたしも、気持ちいい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0303116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「はぁ、あふぅ……おちんちんの匂いが濃くなってる……くんくん……あふぅ\n、隊長さんの匂いがする……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0303117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「はぁ……んん、だんだん気持ちよくなってきちゃったんでしょ？　ふふ、ちゃ\nーんとわかってるんですから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0303118" ]},
		{"command":[ "SETIMAGE", "0", "still_00010203_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……フワフワの膨らみの中で、硬く大きく膨らんだおちんちんが\n気持ちよさそうに震えてる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0303119" ]},
		{"command":[ "SETIMAGE", "0", "still_00010203_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「はぁ、ふぅ……え？　もっと気持ちよくなりたい……？　わかりました、も\nっと激しく動かしますね……んんんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0303120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「はぁ……ふぅ……ん、んんぁぁ、あふぅ……これで、どうです、か？　はぁ\n……あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0303121" ]},
		{"command":[ "SETIMAGE", "0", "still_00010203_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「おっぱいからちゃぷちゃぷ音が聞こえます……おちんちん挟みながら、波打\nってる……この光景、すっごくエッチ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0303122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「ん、んん、はぁ……汗が、溢れてきました……はぁ、はふぅ……水着姿でよ\nかった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0303123" ]},
		{"command":[ "SETIMAGE", "0", "still_00010203_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「はぁ、汗とローションで、谷間がヌルンヌルンしています……気持ちいいで\nすか？　そう……よかったぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0303124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……それで？　どんな感じ、ですか？　そろそろイキそう……\nですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0303125" ]},
		{"command":[ "SETIMAGE", "0", "still_00010203_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「え？　もうちょっと……はぁ……はぁ……もう、じれったくなって、きちゃ\nった……これから、本気のガチで動きます、から、ね……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0303126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「ん、ん、んしょっ、よっこらしょっと……え？　あたしがキツそう……？　\nええ、キツいです……でも、頑張りますっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0303127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「え？　さすがはサムライ……？　もう～……こんなことでサムライ認定しな\nいで下さいよぉ……はぁ、ふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0303128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「あはぁぁ……おちんちんが、ヒクヒクしてきました……ほら、こんなに先っ\nちょが膨らんで……あはぁ、すごぉい……ん、んん、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0303129" ]},
		{"command":[ "SETIMAGE", "0", "still_00010203_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「え？　そろそろ出したい？　ええ、どうぞ……いっぱい、出して下さいね…\n………ん、んぁ、はぁ……あぁぁぁぁあん……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0303130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「あはぁぁぁぁぁ……出てる……いっぱい、白いのビュクビュク飛び出してく\nるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0303131" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010203_01_05" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「おちんちん、ビクンビクン震えて……谷間の中が白いのでいっぱいになって\nいく……あはぁ、精液が爆発したみたい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0303132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「あ、あっ、やだ……まだ出てる……ん、はぁ……ドロドロが谷間の中から溢\nれ出していく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0303133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「ひやぁん……止まらない……精液が、後から後から溢れ出してくる……はー\n……はー……精液の匂いで、窒息しちゃいそう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0303134" ]},
		{"command":[ "SETIMAGE", "0", "still_00010203_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「あ……あ…………あぁぁん、ビュクビュクが治まっていく……はー……あふ\nぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0303135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「あはぁぁ……すごぉい……♪　こんなに出すだなんて……ああ、水着がビチ\nャビチャ……精液でズッシリしてる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0303136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「見て下さい……谷間が精液で埋まっちゃってる……はぁ、ネットリして、変\nな感じぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0303137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「クンクン……ふんふん……はへぇぇ……精液の匂い、すごぉい……頭がクラ\nクラしちゃいます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0303138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「うわぁ、まだ硬いまま……あのー、これって……エッチの続き、確定の流れ\nですかね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0303139" ]},
		{"command":[ "SETIMAGE", "0", "still_00010203_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「あ、やっぱり……わかりました。それじゃ、もう一回、気持ちよくなっちゃ\nいましょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0303140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「んしょっと……はぁ、すごぉい……ドロドロが、谷間の中でこね回されてる\n……んん、ふぅ、精液すごぉい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0303201" ]},
		{"command":[ "SETIMAGE", "0", "still_00010203_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「日焼け止めローションと混ざり合って、トロトロ感がすごいことになってる\n……はぁ、はぁ……あぁぁあん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0303202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「肌とおちんちんが擦れ合う感触……これ、気持ちいい……ん、はぁ……やだ\n、ちょっと感じちゃいますぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0303203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「それにしても、今あたし、とんでもない状況にいますよねー……こんなだだ\nっ広い、お日様の下でこんなことをするだなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0303204" ]},
		{"command":[ "SETIMAGE", "0", "still_00010203_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「ふふ、姉さんや、急（いそぐ）にバレたら……どうなっちゃいますかねー。\nあはは、きっと怒られるだろうなー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0303205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「ん、んん……はぁ、汗が噴き出してくる……ん、んん、はぁ……熱中病にな\nっちゃうかも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0303206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「隊長さん……いかがですか？　え？　いや、熱中症の心配じゃなく、イキそ\nうですかってことです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0303207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「え？　まだまだ平気……？　そ、そうですか……うう、グズグズしてたらあ\nたしが先に熱中症になっちゃう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0303208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「古人いわく『求めよさらば与えられん』。求めすぎると『さらば』ってお別\nれされてしまうってことですからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0303209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「自分だけ求めるんじゃなく、しっかり隊長さんを気持ちよくしてさしあげな\nきゃ……はぁ、ふう……せぇのっ……とぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0303210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……ん、はぁ……あぁぁあん……谷間が、ヌルヌルトロトロし\nて、気持ちいい……汗と、精液と、ローションでいっぱい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0303211" ]},
		{"command":[ "SETIMAGE", "0", "still_00010203_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「はぁ……ふぅ……隊長さん、気持ちよさそうにしてる……けど、まだまだ頑\n張ら、なきゃ……はぁ、あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0303212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「ん、ふぅ……ああ、水着に染み込んでぐちゃぐちゃしてる……替えの水着が\nないから、なかなか洗濯できないのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0303213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「え？　常に水着姿なのか……って、ええ、もちろんです。だって、これはサ\nムライテールの新フォームなので……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0303214" ]},
		{"command":[ "SETIMAGE", "0", "still_00010203_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「まあ、姉さんが気に入ってて、ずーっと着っぱなしってだけで、あたしもそ\nうする理由は全然ないってこと、わかってるんですけどねー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0303215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「まあ、万事適当なんです……我が若苗家って。ま、そんなことより……よい\nしょ、こらしょっと……おちんちん、いかがですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0303216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「もう少しでイキそう……ですか？　はぁ、はぁ……あはぁ、わかり、ました\n……ん、んん、頑張り、ます……んんんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0303217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「はぁ……はあ……あああ、おっぱいが気持ちいい……乳首が水着の下で擦れ\nて……あっ、あっ、はぁ……んんぅん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0303218" ]},
		{"command":[ "SETIMAGE", "0", "still_00010203_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「え？　そろそろ、イキそう……？　よかったぁ……はぁ、ふぅ……んじゃ、\n豪快にイッて、下さい、ね……はぁ、はぁ……んくうぅぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0303219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……ふええ？　どこに出されたい？　そ、そんなの、そっちで決\nめて下さいってばぁ……ぐぅ、んはぁ、あぁぁぁぁあん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0303220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「ひゃうぅぅん！？　あ、あ、すごぉい……熱いの、溢れてる……っ！　あ、\nはぁ……二度目なのに、こんなにぃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0303301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010203_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「あ、はぁ……おっぱいの中で、おちんちん、暴れてる……ひうぅ、精液が谷\n間から湧き出してる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0303302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「熱いぃぃ……はぁ、んふぅ……精液が、日差しより、熱い……。隊長さんの\n体温、どーなってるんですかぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0303303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「はふぅ……あはぁ、精液が、肌に染み込んでくる……おっぱいで妊娠しちゃ\nいそう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0303304" ]},
		{"command":[ "SETIMAGE", "0", "still_00010203_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「はー……ふぅ、あぁ……潮風と精液の匂いが入り混じって……ああ、すごく\nエッチな香り……くんくん……あはぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0303305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「ふふ、や～っとおちんちん、治まってきましたね……ふぅ、よかったぁ……\nこれ以上続けたら、ホントに熱中症になっちゃいます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0303306" ]},
		{"command":[ "SETIMAGE", "0", "still_00010203_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「でも、ちょっと柔らかくなってきたおちんちんって可愛いですねー……あは\nは、ちょっと名残惜しいような気がします」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0303307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「ああ……精液が滴ってる……ん、ふう……このたれてくる感じ、気持ちいい\nです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0303308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「ふう……ともかく、これで日焼け対策がバッチリですね。ええっと、これか\nらどうします？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0303309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「じゃ、おれから本格的にビーチリゾートしましょうか。ふふ……エッチの方\nがよかったですか？　それはまた今度にしましょうね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0303310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「ひゃん！？　あぁぁあん……精液、勢い強すぎぃ……顔にぶつかってくる…\n…二度目なのに……こんなにいっぱい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0303401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010203_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「あ、あ、はぁ……あぁぁあん……精液で、目の前が、真っ白……鼻も、口も\n、埋まっちゃう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0303402" ]},
		{"command":[ "SETIMAGE", "0", "still_00010203_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「ん、んぐっ、ごほっ……げほっ……はぁ、ふぅ……精液で溺れちゃうよぉ…\n…。海で泳ぐより先に、精液で溺死しちゃう、かも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0303403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「ん、ふぅ……はあ、はぁ……あはぁ、やっと射精が止まった……。はぁ……\nふぅ……それにしても、いっぱい、出しましたねー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0303404" ]},
		{"command":[ "SETIMAGE", "0", "still_00010203_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「あはぁ、おちんちん、フニャフニャしてきました！　はぁ……ふぅ……これ\nで満足してくれたみたいですねー……よかったー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0303405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「ん、ふぅ……身体中、精液がこびり付いてる……。精液ローションで、日焼\nけ対策ばっちりですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0303406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「はぁ……谷間の中で、おちんちんが小さくなっていく……あぁん、なんだか\n愛おしいです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0303407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「んふふ……顔から精液が滴り落ちていく……。あぁん、アソコが……おまん\nこがジンジンしてきちゃいました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0303408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「え？　セックスをしたいか、ですって？　あはは、せっかくビーチに来たん\nだもん、海で遊びましょうよー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0303409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「せっかくこんな恰好なんだもん……ときには正しい使い方してあげなきゃ、\n水着が可哀想です。さっ、隊長さん！　一緒に泳ぎましょ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_0303410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
