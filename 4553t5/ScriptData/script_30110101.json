{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「ええと、呼んでいるって聞いて来たんですけど、なんでしょうか？　え？　\n奉仕……？　奉仕活動ですか？　おそうじとか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0103101" ]},
		{"command":[ "SETCHARA", "0", "char_00001101_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「そうじゃない？　え、えっちな奉仕ですか！？　そ、そんないきなり言われ\nても……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0103102" ]},
		{"command":[ "SETCHARA", "0", "char_00001101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「く、訓練なんですか！？　積極的になるための、ですか！？　ううん……確\nかにそう言われると……言い返せないですけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0103103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「……分かりました、上手く出来るか分かりませんけど、やってみます。変な\nことしちゃったら、言って下さいね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0103104" ]},
		{"command":[ "SETCHARA", "0", "char_00001101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「ええと、ほ、本に書いてあった通りにやってみているんですけど、これで合\nってるんです……よね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0103105" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001101_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「お、男のひとはこうされると嬉しいって書いてあったんですけど、なんだか\nちょっと違うような……？　え？　大きさが足りない……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0103106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「でも、えっと、こうすれば……一応、気持ち良く……ないですか？　し、舌\nも使うんですか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0103107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「い、嫌じゃないですけど、舐めたりしたらにいさまの方が嫌かと……え？\n　嫌じゃないから是非やって欲しい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「そ、それじゃあ失礼します……ね？　んちゅ、ちゅ……れろ……っ　ぁ、す\nごく熱いです……ふしぎな感触で……んっ、ちゅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0103109" ]},
		{"command":[ "SETIMAGE", "0", "still_00001101_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「あっ、今、ぴくんってして……気持ち……いいんですか？　おっぱいも一緒\nに……こうしながら……れろ、ちゅむっ、ぷぁ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「え？　乳首で……刺激するんですか？　でも、そうするとわたしも　こすれ\nて……あ、はい、分かりました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0103111" ]},
		{"command":[ "SETIMAGE", "0", "still_00001101_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「んぅっ、ああ、熱いのに乳首が当たって、ふぁっ、んきゅ……っ　あ、また\nオチンチンぴくってして、嬉しがってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「可愛いかも、です……ちゅっ、んむ、れろれろ……、はむ、んっ、じゅぷ…\n…んふっ、ふーっ、ちゅぅ……っ、ぷは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0103113" ]},
		{"command":[ "SETIMAGE", "0", "still_00001101_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「ぬるぬるしたの……出てきて……あっ、胸がぬちゃぬちゃって音が　して…\n…すごくえっちです……やぁ、乳首固くなって……ふぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0103114" ]},
		{"command":[ "SETIMAGE", "0", "still_00001101_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「先を……口に含んで欲しい、ですか？　ええと……おっきいから、歯が当た\nらないように……ぷぁ……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0103115" ]},
		{"command":[ "SETIMAGE", "0", "still_00001101_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「さきっほから、おつゆ……れてきれ、ちゅっ、じゅぷ……っ、んふっ、ふひ\nぎにゃあじ、ひまひゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「んっ、ぷぁっ、じゅる……っ、ちゅぱぁっ、いき、するの、忘れちゃってま\nした……えへへ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「んー、れろ……ちゅっ、んむ……っ　このおつゆ、面白い味がします……す\nごくえっちな気持ちです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「これがもっと出てくれば、精液が出てくるんですか？　じゃあがんばります\n……ちゅっ、じゅぷ……っ、れろ……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「ちゅうぅっ、んぷぁっ、んむ……じゅぷ……っ、じゅちゅぅっ、ぷはぁっ、\nれろ……んふっ、ちゅぷっ、はぁっ、んぷ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「つば、たれちゃって……おっぱい、ぬるぬるで、熱くって……ふぁっ、オチ\nンチンもぴくぴくして……気持ち良く出来てますか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「もう少し強くしてもいい、ですか？　ええっと、じゃあ……ちゅうぅっ、ん\nぷっ、れろろっ、じゅぷ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「んふっ、んむ……っ、れろろ……ちゅぷっ、じゅぷ……ぷぁっ、んっ、ちゅ\nぅ……っ、じゅぷっ、じゅちゅっ、んぷ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「ふぁっ、あたま、撫でられると……、だめです、おなかの奥、きゅうってし\nちゃって、ぽーってしちゃいますからあ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「ちゅっ、んふっ、れろ……っ、じゅぷ……っ、ぁ、なんだか、さきっぽがぷ\nくってしてきました……んふっ！？　ひゃめっ、耳っ、触っちゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「じゅぷぷっ、じゅちゅっ、んふっ、んんーっ、ぷはぁっ、んんっ、むっ、れ\nりゅっ、れろろっ、じゅぷ……っ、ちゅうぅ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「あごっ、ちゅかれてっ、んふっ、じゅぷ……っ、あたま、ぼーって、んふっ\n、れろっ、じゅぷっ、じゅぽっ、じゅぶ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「びくびくって、して、熱くて、固くなってっ、じゅぷぷっ、んぷぁっ、おっ\nぱいで、ちゃんと、こすってっ、はぁっ、んふっ、あぁっ、ああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「おっぱいのさきっぽ、でんきはしったみたいに、ぴりぴりってしてっ、んき\nゅっ、んんっ、ひぅ、あっ。ああ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「ふぁあっ、熱いの、びちゃびちゃって、顔にかかってっ、んふっ、んんむっ\n！？　んっ、じゅぷ……っ、んぷっ、んんん～っ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0103130" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001101_01_05" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「ひゅごい……これ、せいえき……にいさまのにおいして、あたまくらくらし\nひゃいまふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「ふしぎなにおい……嫌じゃないですけど、なぜかおなかの奥がきゅうってし\nて、足に力が入らなくなっちゃって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「すごく……攻撃的な味がします……苦くて、おまえは俺のものだって　宣言\nしてるみたいな……そんな風に思うの、変でしょうか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0103133" ]},
		{"command":[ "SETIMAGE", "0", "still_00001101_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「あっ、髪の毛の方まで飛んじゃってます……。こんなに勢いあるんですね…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「おっぱいの間にも、たくさん垂れて……ぬちゅぬちゅっていやらしい　音し\nちゃってます……においもすごくして……はぁ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0103135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「こんなにたくさん出してくれたのは、気持ち良くなってくれたって　ことな\nんでしょうか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0103136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「……よかったです、ちゃんと出来るか、不安だったので……。えっと、その\n……ひとつ聞いてもいいですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0103137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「……まだ、すごくおっきいままですね……？　なんだか切なそうな顔してま\nす……大丈夫ですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「ちゅ、んっ、れろ……っ、なんだか、こうして欲しいって言ってるような　\n気がして……合ってます、か……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「もう１回ですか……？　わたしはいいですけど、にいさまは大丈夫なん　で\nすか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「ええと、おっぱいで……ですか？　こうやって、やさしくこすって……んっ\n……ちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0103201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「わあ、本当にまたおっきくなってきました……！　はあっ、さきっぽからま\nだ精液が……ちゅ、ちゅう……っ、ふぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0103202" ]},
		{"command":[ "SETIMAGE", "0", "still_00001101_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「にいさまのにおい……なんだか好きになっちゃいました……。もっと、わた\nしのこと、にいさまのにおいでいっぱいにして下さい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0103203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「れろろっ、ちゅっ、ん……っ、ちゅう……っ、わあ……また元気に　なって\nきました……。疲れたりしないんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0103204" ]},
		{"command":[ "SETIMAGE", "0", "still_00001101_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「大丈夫だから続けて欲しい、ですか？　分かりました、じゃあ……ちゅっ、\nはむ……れろ……ちゅぅっ、れろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0103205" ]},
		{"command":[ "SETIMAGE", "0", "still_00001101_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「気持ちいいところがあったら、教えて下さいね？　まだよく分からないので\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0103206" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETIMAGE", "0", "still_00001101_01_03" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「おっぱいでこするのも、もう少し強く……ですか？　えっと、ん……っ、ふ\nぅっ、ふぁ……っ、こう、です……か？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「ひめさまみたいに大きかったら、全部包み込めたかもしれませんけど、わた\nしだとこれくらいで……ごめんなさい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「え？　これはこれでいい……ですか？　ふふっ、慰めてくれて嬉しいです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「その分、いっしょうけんめいやりますから……ちゅっ、れろれろ……っ、じ\nゅぷっ、んぷっ、ぷぁっ、んぁ……っ、ちゅう……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0103210" ]},
		{"command":[ "SETIMAGE", "0", "still_00001101_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「またさきっぽからっ、ちゅっ、おつゆが出てきました……れろっ、気持ちい\nいってことで……れろ……っ、いいんですよね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「ぁ……、頭、撫でてくれるの、嬉しいです……。ふふっ、んっ、れろろ……\nっ、じゅぷっ、じゅぷぷ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「どんどん熱く……おっきくなって……口が疲れちゃいます……。じゅぷっ、\nちゅぷっ、ぷぁっ、んっ、れろ……ちゅぅ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「わたしもっ、身体、熱くなって……おっぱいのさきっぽ、切なくって、きゃ\nっ、ぅんっ！　さ、触っちゃ……だめっ、ひきゅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0103214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「ふぁあっ、さきっぽ、いじっちゃ、やあです……っ！　引っ張るのもだめえ\n……っ！　くっ、ぅうんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0103215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「ちゃ、ちゃんとできなくなっちゃいますから、いたずらしないで下さいっ！\n　え？　反応が面白い？　も、もお……っ！　恥ずかしいです……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0103216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「そんな悪いにいさまにはこうです……！　はむっ、ちゅっ、じゅぷぷっ！　\nれろっ、ちゅっ、じゅぷっ、ちゅるる……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「びくんってしましたね……？　じゃあ……れろっ、ちゅっ、れろろっ、おっ\nぱいももう少し、こうして……ふぁっ、んんっ、はぁ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0103218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「あっ、びくびくってしてきてる……。れろっ、じゅぷっ、じゅぷぷっ、ちゅ\nうっ、ぷはぁっ、れろろっ、ちゅぷ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「さきっぽふくらんで……ふぁっ、跳ねてっ、もうすぐ……っ！　た、にいさ\nま、何をするんですか……っ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「んぷっ！？　んんん～っ、んむっ、んぐ……っ！？　じゅぷっ、んくっ、ん\nんん……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0103301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001101_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「んむっ、んぐ……っ、くちのにゃか、いっぱいれっ、のみきれにゃ……っ！？\nじゅぷっ、んぐっ、んぐぐ……こくっ、こくん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「けほっ、けほんっ！　ご、ごめんなさい、口の中に入りきらなくて、だいぶ\nこぼしちゃいました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0103303" ]},
		{"command":[ "SETIMAGE", "0", "still_00001101_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「はぁ……胸までこぼれてどろどろ……。え？　なんで親指立ててるんですか\n……？　エロくていい……？　え？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0103304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「最初の時よりたくさん出てる気がします……。匂いもすごくて……頭がくら\nくらしそうです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0103305" ]},
		{"command":[ "SETIMAGE", "0", "still_00001101_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「口の中も……にいさまの匂いでいっぱいです……。おっぱいも……しばらく\n取れないかもです……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0103306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「ちゅぅっ、じゅる……ちゅ……ずずっ、んんっ、こくっ、こくん……っ。え\n？　あ、あの、何だかもったいない気がしちゃって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0103307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「ええっ？　え、えっちなことなんですか？　やだあ、は、恥ずかしいです…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0103308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「あの、にいさま……わたし、上手く出来ましたか？　ふふっ、頭撫でてくれ\nる……♪　嬉しい……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「次があったら、もっと気持ち良くしてあげられるように頑張ります。だから\nえっと……また、お願いしますね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「じゅぷっ、じゅぷぽっ、じゅぷぷ……ぷはぁっ、んっ、ちゅっ、ふえっ？　\n抜いちゃっていいんで……きゃあっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0103401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001101_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「きゃんっ！？　あ、熱いの……たくさん出て……っ、あぁっ、ビシャ　ビシ\nャって当たってます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0103402" ]},
		{"command":[ "SETIMAGE", "0", "still_00001101_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「ふわ……すごい……たくさん出ましたね……。全身にいさまので……いっぱ\nいです……ふふっ、気持ち良かったですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0103403" ]},
		{"command":[ "SETIMAGE", "0", "still_00001101_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「こんなにたくさん出るものなんですね……。匂いもすごくて、全身がにいさ\nまの匂いです……くんくん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0103404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「何だかすごくえっちな姿になってる気がします……。にいさま、興奮した顔\nしてますから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0103405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「このままだと部屋まで戻れませんね……。にいさまのお部屋のシャワー借り\nた方がいいかな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0103406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「ええっ！？　い、一緒に入りたい、ですかっ！？　へ、へんなことしないな\nら、いいですよ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0103407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「がまんできるか自信ない、ですか？　だ、だめですよ！？　ホントにだめで\nすからね！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0103408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「分かりました、そんなに必死にお願いしないで下さいっ。あ、洗いっこまで\nはしてもいいですから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0103409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「もう、にいさまがこんなにえっちだなんて、知りませんでした。ええっ！？\n　か、可愛いからしたい？　もう、冗談ばっかり！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0103410" ]},
