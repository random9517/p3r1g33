{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0031" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「えへへへっ……。今日は旦那さまとおでかけ、しあわせです……！　はやく\n、はやく！　こっちですの！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0204101" ]},
		{"command":[ "SETCHARA", "0", "char_00022102_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あれ……？　突然立ち止まって……どうなさったのですか？　はい……そち\nらの木陰へ？　わかりました。それで……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0204102" ]},
		{"command":[ "SETCHARA", "0", "char_00022102_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「きゃっ！？　わ、わたくしがあまりに無防備で、危なっかしいからつかまえ\nたのですか？　ええと、わたくしには恥じらいが……羞恥が足りないと？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0204103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「しゅうち……。たしかに、前にいた星でも聞いたことのない言葉です。それ\nに、愛する旦那さまといて恥ずかしいことなんて……。あっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0204104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「んん……？　これは一体どういうじょうきょうなのでしょうか……？　ぱん\nつを下ろして、おようふくの胸をずりあげて……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0204105" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022102_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ふつうはこうされたら、きゃーって悲鳴をあげてにげる……ですか？　でも\n……わたくしは旦那さまを信頼していますから……。んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0204106" ]},
		{"command":[ "SETIMAGE", "0", "still_00022102_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「そんな風だとだれかにいたずらされてしまうかもしれない？　……んん……\nよくわかりませんけれど、わかりました……？　いたずら……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0204107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「いたずらとはどういうことですの？　あの、旦那さま……。無知なわたくし\nにおしえていただくことはできますか？　おねがいします……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0204108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「さわさわと……手でわたくしの太ももや、むね……おなか、などなどをさす\nったり、触ったりするのが……いたずら？　うぅん、よくわかりません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0204109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「んっ……ふふふっ。く、くすぐったいですう……。あはっ、あはは……っ。\nこ、これがいたずらなのですか？　へっ？　もっとすごいこともする？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0204110" ]},
		{"command":[ "SETIMAGE", "0", "still_00022102_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「きゃっ……！　あっ……。おっぱい……おっぱいをふにふに揉むのもいたず\nらなんですね。ん……、でも、旦那さまの手はいつも優しいですし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0204111" ]},
		{"command":[ "SETIMAGE", "0", "still_00022102_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「っふ……っ。き、きもちいいですけど……。恥ずかしいのとは違うかもしれ\nません。どきどきして、えっちな気持ちにはなっちゃいます……。ん、んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0204112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あっ。お尻……今度はお尻をむにむにですか？　撫でまわして……。わたく\nしが、されるがままなのがおそろしいと？　ん、ん、そうです、か」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0204113" ]},
		{"command":[ "SETIMAGE", "0", "still_00022102_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「緊張感がないと……？　で、ですがわたくしにこんなことをするのは旦那さ\nまだけですし……。旦那さま以外には絶対ぜったいさせませんし……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0204114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「旦那さまがしてくれるのなら、嬉しくて……。って、ふぁっ！　お、おまん\nこも指ですりすりするんですね？　ゆっくり、入り口をなぞって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0204115" ]},
		{"command":[ "SETIMAGE", "0", "still_00022102_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ぁ……、こ、これは……すこし……なんだか……。ん……っ。お、おまたを\n指でくにゅくにゅされると、声が……出ます。あっ……。ん、んん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0204116" ]},
		{"command":[ "SETIMAGE", "0", "still_00022102_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「声を出してはいけないのですか……？　お外でこういうことをするのは悪い\n子だから……？　そ、そうなんですね。ぜんぜん知りませんでした」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0204117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「えっち、なことだから……。隠れてしないと恥ずかしい子になってしまう…\n…？　んっ、では、では、今……わたくしはわるいことを？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0204118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「いたずらされて、胸やあそこや、人に見せてはいけない場所をくちゅくちゅ\nされて、いるのですか？　あ……あ、旦那さまの指を濡らして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0204119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「そういうのも、えっちでわるいこで……？　ううう……？　んっ？　だ、旦\n那さま？　おちんちんを出してわたくしに向けて……な、なにを……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0204120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「はううぅう……っ！　うしろから、うしろからいきなり……！　あっ！　声\n……！　声を出したら恥ずかしい子なんですよね……っ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0204121" ]},
		{"command":[ "SETIMAGE", "0", "still_00022102_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「こえ、声をがまんしないと……！　んく……、おててでお口をふさいで……\n。あっ♪　だ、旦那さま、動いたら気持ちいいので、うごいちゃだめですのっ\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0204122" ]},
		{"command":[ "SETIMAGE", "0", "still_00022102_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ぅ……うぅ……っ？　うごい、たら……！　くふ……、自然に声が……！　\nんっ……。んぅうう……！　んむぅう……！　むぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0204123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「んぅんぅうう……！！　んむぅううーーっ……！　むー！　むぅー……！　\nむー……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0204124" ]},
		{"command":[ "SETIMAGE", "0", "still_00022102_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あっ……人が、人が来ます……旦那さま！　おちんちん、おちんちんさんを\n抜いてください……！　えっ、あっ、だめ？　だめなのですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0204125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「んむぅっ！　ふ、深く入れないでくださいぃ……！　あう……！　ふぅうう\nっ……！　あっ……ぅ……？　動かすのですか……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0204126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あっ……ぅ……っ、うぅ……っ？　んむぅう……！？　はふっ……、ふぅっ\n……ふぅう……！？　うー……！　うぅー、うー……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0204127" ]},
		{"command":[ "SETIMAGE", "0", "still_00022102_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ちょ……ちょっとだけ、わかりました……っ。はう……！？　これがいたず\nら、なら……えっちすぎて、いけないことなのはわかる気がします……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0204128" ]},
		{"command":[ "SETIMAGE", "0", "still_00022102_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「だって、だって、おちんちんさんが……すっごくえっちな動きでわたくしの\n中をぬぽぬぽ出たり入ったりしていますから……。はぁ、はぁ、はぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0204129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「これは……、あう、秘密にしないといけないです……っ。ふ、ぅ……っ、い\n、いままで……こんなにすごいこと、へいきでずっとしてました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0204130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「だけど、よく考えましたら……。んむ……っ、むぅ……！　むー……！　ふ\nぅうう……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0204131" ]},
		{"command":[ "SETIMAGE", "0", "still_00022102_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ずんずん、ずんずんってお腹の奥を……、おまんこさんの行き止まりをつき\nあげられているのがわかります……。旦那さまの力が強くて……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0204132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、足が……足が浮いちゃって……。んん……！　お、落ち着きま\nせん……ぬいぐるみさんみたいに持ち上げられて、ずぷずぷされて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0204133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「このまま……このままびゅーってせいえきを注がれてしまったら、わたくし\n……その威力で飛んでしまいそう、です、あっあっ、こわいです……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0204134" ]},
		{"command":[ "SETIMAGE", "0", "still_00022102_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「良い子にします……っ、んぅ、んん、いいこにします、おとなしくします…\n…！　だから、しゃせい……しゃせい待ってください、絶対むりですっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0204135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「今しゃせいされたら……えっちな声、皆様に聞かれてしまうので……！　え\nっ？　出る？　出ちゃうのですか？　あっ、お、おまちくださいぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0204136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「んはぅううっ……！？　はぁああ……！？　んむぅううう……！　ひゃめ…\n…、らめ、だめです、声、声でちゃいます……ぅう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0204137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022102_02_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「はぅっ……あううう……くぅうぅん……！　あ、あのぉっ！　とても……と\nてもお腹の中にひびいて……どぴゅどぴゅすごい音が聞こえます！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0204138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「それに……。うぅ！？　んふぅうっ！？　んぁうう……！　わたくし、わた\nくし、膝がガクガクして……あぁっ、おまんこがミチミチになって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0204139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「せいえきの量が多すぎて……、うぅっ。ごぽっ、て外にあふれでちゃいそう\nです……。あっ！？　でちゃう、でちゃうぅ……。んみゅぅう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0204140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「はぁっ！？　あぁ……あぅ、出てる、足にたらたらーってつたいおちていき\nます……！　っひぅ……ドロドロで、べちゃべちゃで……。んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0204201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「だめ、だめ……おとなの人に見られたらすぐわかっちゃいます、わたくし、\n今、せいしをおまんこにそそがれていたんだって……そんなの……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0204202" ]},
		{"command":[ "SETIMAGE", "0", "still_00022102_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あぁ……地面に白いみずたまりが……。やっぱり……やっぱりあふれちゃい\nましたよね……。どろって出たのわかりましたから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0204203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「入りきらなかったですよね……。わたくしのおまんこさんがちっちゃすぎて\n……たくさんたくさん溢れて、流れ出てしまいました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0204204" ]},
		{"command":[ "SETIMAGE", "0", "still_00022102_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「それに……やっぱり声が……っ。はい……、だれもちかくにこなかっただけ\nで……。わたくし、しっぱいしてしまって……大きな声で……ううう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0204205" ]},
		{"command":[ "SETIMAGE", "0", "still_00022102_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ごめんなさい……。……ふぅっ？　あ、あれ……？　だ、旦那さま？　これ\nでえっちは終わりなのですよね？　せいえき、ぴゅっぴゅしてもらって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0204206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「……ええっ？　し、失敗したからもう一度ですか？　これは大切なお勉強だ\nから……？　あ……、おっしゃることはわかります、でも、でも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0204207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「さっきのいっぱい気持ちいいのが、まだおまんこに残っていて……！　指先\nも腕もしびれていて、今……今、またこのままえっちされたら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0204208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あっ！？　ぬぷぬぷ、だめです！　あぁ……！　音っ……、せいえきがぐち\nょぐちょってすごい音、してます、こんなのばればれすぎますですのっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0204209" ]},
		{"command":[ "SETIMAGE", "0", "still_00022102_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「っくぅうう……！　えっち……！　えっちしていること、色んな人に気づか\nれます、声っ……声おさえても、がまんしても……おまんこさんがっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0204210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「おちんちんさんにドチュッドチュッてかきまわされて……すごい音がしてい\nるんです！　ぬっちゃぬっちゃって、ひどくいやらしい音です、だから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0204211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「……んーーーー！　だめです……！　ぜったい見られちゃいます、聞かれち\nゃいます……わたくしたちのえっち、たいせつなえっち……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0204212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あっあっあっあっ……！　は、はい……！　声……、声はがまんします、で\nも……。うう……！　おまんこさんでぎゅーってしめつけても」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0204213" ]},
		{"command":[ "SETIMAGE", "0", "still_00022102_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「おちんちんさんの方が何倍も、何十倍も強くて……ぜんぜんつかまえておけ\nません……。あっ……あぁ、おねがいです、おねがいします、皆様ぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0204214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「わたくしと旦那さまの神聖なえっちを、み、みないでください……聞いちゃ\nだめです……！　っふっ……気づかないで、とおりすぎてくださいぃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0204215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「……んーーー……っ！　こんな声だして、おちんちんをおまんこでにゅぷに\nゅぷしてたら……１００％えっちしてるってわかっちゃいます……なのに」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0204216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「旦那さまがすることはよいこと、だから、気持ちいいから……。わたくし、\nわたくし……本気でやめてって言えないです……気持ちいい……うううっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0204217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あっ……あっあっ♪　からだが……！　身体がふわふわしてきまし、た……\n！　ちゃんと立っていられません……また、また気持ちいいです……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0204218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「わたくし、わたくしもうだめですの……！　旦那さまぁ……ゆ、ゆるしてく\nださい……！　もう、もう、わたくし……どうにかなりますぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0204219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あぁあ……ッ。おちんちんさん、おちんちんさんにずこずこされて、ずぽず\nぽされて……わたくし……とんじゃいます！　あああぁああ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0204220" ]},
		{"command":[ "SETIMAGE", "0", "still_00022102_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あふぅうう……♪　きてますぅ……！　きてますの、わたくしのいちばんお\nくに……奥にぃ……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0204301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022102_02_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あ……っ。あぅ……あふぅ……！　さ、さきほどのせいえきが、あたらしい\nせいえきに押し出されて……あふれてきてしまいました……！　ん～～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0204302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「白いおしっこを、お外でおもらししているみたいで……！　は、はずかしい\n……はずかしいです、旦那さまぁ……。も、もうはいりません……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0204303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「んっ、んく……っ。ふぅうう……！　ふーっ、ふーっ……♪　いけないこと\nしてます、お外で、お外で二回もなか出し……しゃせい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0204304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「うぅ……！　顔があつくなってきました……。それにお腹も、ぽんぽんにな\nって……。あぁ……せいえきがいっぱい入っているのがばれちゃいます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0204305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「おそと、で無防備にしていると……こうやって赤ちゃん、赤ちゃん作ること\nになるのですね……！　わたくし、デートがうれしくて、油断していて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0204306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「こんなえっちなこと……！　あああ、あぁああっ……あぁあ……！　ドク、\nドクっておまんこの奥でおちんちんさんが跳ねてます……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0204307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「こんなえっちなこと、ほ、ほかのひとに見られてしまったら……はずかしい\nです、かああって全身が火照って、泣いちゃいそうになります……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0204308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「うう……♪　ふぅ、ふぅ、んん、んん～～～……っ。しゅ、羞恥、というも\nのがほんのすこしだけわかった気がしますの……旦那さま……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0204309" ]},
		{"command":[ "SETIMAGE", "0", "still_00022102_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「これからはもっと気を付けて良い子にしますの、ですから……どうか、わた\nくしのことを、これからもずっと教育してくださいねぇ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0204310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「んう……！　ぁう……っ、くぅうううんっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0204401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022102_02_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あ……っ。だ、旦那さま……！　いいのですか、おなかの中にださなくて…\n…！　ンッ……。あふっ……せいえき、せいえきお外に出てますよぉ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0204402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あっ♪　お、お尻や身体……髪まで旦那さまのお汁でベトベトです……。あ\nったかくて、……はぁっ♪　えっちな臭いがして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0204403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「……ぼーっとしているみたい、ですか……？　す、すみません……必死に声\nをおさえていたので、すこし空気が足りなくなってしまいました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0204404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「旦那さまはお気になさらず、どうかさいごまでわたくしにせいしをぴゅっぴ\nゅしてください……。んぅう♪　まるでシャワーのように降りそそいで」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0204405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「っふぅっ♪　ふぅ、ふぅ、ふぅぅ……っ♪　だ、旦那さまのおたまじゃくし\nさんたちは元気いっぱいですね……わたくし、おぼれてしまいそうです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0204406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「はぁっ……はぁっ……。んん……♪　わたくし……ちゃんと声をがまんでき\nましたか……？　途中ですごくきもちよくなってしまって……。はぁ、はぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0204407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「旦那さまを困らせてしまったような……。……んん……あの、とても身体が\nあつくて……おちんちんさんが入っていたところがまだじんじんします」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0204408" ]},
		{"command":[ "SETIMAGE", "0", "still_00022102_02_16" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「おちんちんさん……すごく、すごく太かったです……。はぁっ……♪　お外\nでするのは恥ずかしくて、胸がせつなくて……たくさん勉強になりました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0204409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ま……また、わたくしにいたらない点があれば……。はぁ、はぁ……やさし\nくおしえてくださいね、旦那さま……♪」", "NORMAL" ]},
