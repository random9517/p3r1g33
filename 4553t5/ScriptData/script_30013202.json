		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ちょ、ちょっと待て。こんなところで私と……しようというのか？　ンッ、\nさっそく胸を……はうぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3204101" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「おっぱいをそんなに、あんっ、強く揉むな……ああっ、こ、声が出てしまう\nではないか……ぁ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3204102" ]},
		{"command":[ "SETIMAGE", "0", "still_00000132_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「お前、自分がなにをしているのかわかっているのか？　こんなに日が高いう\nちから、私に、破廉恥なことを……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3204103" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「別にいまでなくてもいいだろう。いまは……こ、心の準備が、できていない\nのだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3204104" ]},
		{"command":[ "SETIMAGE", "0", "still_00000132_02_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「だから、そんなふうにおっぱいを揉まれても……あんっ、乳首を、くりくり\nと責められても……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3204105" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「お前の、ガチガチの勃起オチンポを、股間にすりすりとされたって……んく\nっ、いやらしい雰囲気に流されたり、しないんだからな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3204106" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はぅ、んっ、んくぅ……。そんなこと、お、オマンコ濡れてなんか……。は\nぁんっ、お前が胸を、揉むからだろうがぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3204107" ]},
		{"command":[ "SETIMAGE", "0", "still_00000132_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「破廉恥な手つきで、おっぱいを……。ああっ、ンッ、だから反応して、腰も\nくねってしまって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3204108" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「身体の準備は十分だろうって、なにを言ってるんだ。わ、私は、準備など…\n…！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3204109" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んぁああっ、あっ、んふぅううう～～～～っ。は、入って、きて……るぅ…\n…っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3204110" ]},
		{"command":[ "SETIMAGE", "0", "still_00000132_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「な、なに勝手に挿入を……んっ、くぅっ、どんどん奥に……オチンポがにゅ\nるる～っと……な、中にぃ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3204111" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ああっ、アツアツのオチンポが、私のオマンコをおしひろげて……オマンコ\nをじっくり味わうように……くるぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3204112" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ああぁ……。い、一番奥まで、きた……！　先っぽが、私の子宮の入り口に\n、当たっている……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3204113" ]},
		{"command":[ "SETIMAGE", "0", "still_00000132_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、熱い……。お腹の奥が、ジンジンとするような……。んぁっ、\nこの状態で、おっぱいをぉ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3204114" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あっ、ああっ、おっぱい……んはぁっ、オチンポ、動かさないのか？　挿入\nしただけで、おっぱいばかりぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3204115" ]},
		{"command":[ "SETIMAGE", "0", "still_00000132_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「おっぱい揉まれたら、腰、くねって……。あはぁっ、オチンポが勝手に、オ\nマンコにぐりって、当たってしまって……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3204116" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「お、お前、わかっているだろう？　こうしているうちに、私のオマンコがう\nねって、オチンポをぎゅっとしめつけて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3204117" ]},
		{"command":[ "SETIMAGE", "0", "still_00000132_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「お尻も、ぐいって突きだして、お前の腰に押しつけて……。おねだりするみ\nたいに、揺らしてしまっているのだからぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3204118" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「心の準備ができたのかって？　お、お前、挿入を許した時点で察しろ！　と\n、とっくに……できている……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3204119" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「だ、だから……お前のオチンポで、私のオマンコも気持ちよくしてくれ……\n。後ろからオマンコをいっぱい突いて欲しいぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3204120" ]},
		{"command":[ "SETIMAGE", "0", "still_00000132_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ああぁっ、あっ、ああっ、きたっ、きたきたっ、あはぁんっ！　オチンポが\nっ、んっ、奥……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3204121" ]},
		{"command":[ "SETIMAGE", "0", "still_00000132_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「か、感じるっ、オチンポが出入りして、カリが中を、ごりごりってこすって\nいくの、気持ちよすぎるぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3204122" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、ああっ、突いてっ、もっともっと、んっ、いっぱい突いて、あ\nっ、ああっ、気持ちいいっ、オチンポ気持ちいいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3204123" ]},
		{"command":[ "SETIMAGE", "0", "still_00000132_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「先っぽがぐりぃって、オマンコえぐっていく……っ！　ああっ、その動きだ\nめだっ、腰がっ、腰が抜ける……あぅうんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3204124" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「どんどんオマンコが濡れる……。お前が動くと、オマンコから汁が、かきだ\nされて……んぁあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3204125" ]},
		{"command":[ "SETIMAGE", "0", "still_00000132_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「いやらしい音が、ばちゅばちゅってしてしまっている……っ！　んくっ、は\nふぅ……こんなに、濡れるなんて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3204126" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ああぁっ、とまらないっ、愛液溢れてくる……っ！　オチンポ気持ちよすぎ\nて、ああっ、どんどん、でてしまう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3204127" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「もっと溢れさせてやるって……あぁんっ！　お、おっぱい、あっ、あっ、も\nみくちゃにするな……あっ、ああぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3204128" ]},
		{"command":[ "SETIMAGE", "0", "still_00000132_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「オマンコじゅぷじゅぷしながら、おっぱいもみもみするなっ、んはぁっ、両\n方いっぺんに気持ちよくされたら、お、おかしくなるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3204129" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「くひぃんっ！　イクッ、イッてしまうからっ！　そんないやらしく責められ\nたら、我慢できなくなるからぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3204130" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「い……イク……ッ！　イキそうだ……もう、もう我慢できない……！　お、\nお前も……お前も一緒にぃ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3204131" ]},
		{"command":[ "SETIMAGE", "0", "still_00000132_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「オマンコをぎゅっと、締めて、オチンポを気持ちよくするから……ああっ、\nお前もピストンが……激しくぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3204132" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、オチンポくるっ、子宮口に、ぶちゅっと先っぽが当たるぅっ！\n　ああっ、ああっ、ビクビクしてるっ、んっ、ああぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3204133" ]},
		{"command":[ "SETIMAGE", "0", "still_00000132_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「イクッ、イクッ、子宮キスでイク……ッ！　あぁんっ、あっ、ああっ、んっ\n、んっ、んくぅ……っ！　はぁっ、はぁあ～～～～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3204134" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あああぁぁぁああぁぁ～～～～っ！！　き、きたっ、きたぁあああぁぁぁ～\n～～～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3204135" ]},
		{"command":[ "SETIMAGE", "0", "still_00000132_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「精液っ、いっぱいぃ……っ！　あっ、ああっ、私のオマンコに、どぷどぷ注\nがれる……ぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3204136" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「すごい……熱い……オマンコから溢れそうなくらいたくさん……っ！　あっ\n、ああ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3204137" ]},
		{"command":[ "SETIMAGE", "0", "still_00000132_02_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「たっぷり中出しされて……はぁ……はぁ……気持ちよくて、腰が抜けてしま\nったではないか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3204138" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「オチンポ抜かずに、しっかり私のことを支えていろよ？　オチンポも硬いま\nまだし、まだまだできるだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3204139" ]},
		{"command":[ "SETIMAGE", "0", "still_00000132_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「なにを驚いた顔をしている。お前のせいで、気持ちが昂ってしまった……。\n収まるまで、つきあってもらうからな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3204140" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「元はといえば、お前が半ば強引にエッチしようとしたせいなのだからな。し\nっかり責任をとるのだぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3204201" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んくっ、ふぅ……。こうして、ぐりぐりっと……ンッ、腰を……な……？　\nはぁ、はぁ……オチンポが深くに……ささって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3204202" ]},
		{"command":[ "SETIMAGE", "0", "still_00000132_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「亀頭が子宮に……ンッ、子宮口にちゅっちゅしてる……はぁ……はぁ……こ\nれが、いい……ぃ……♥」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3204203" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「なあ……もっと……。お前のオチンポで、子宮にキス……いっぱいちゅーし\nてくれぇ……♥」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3204204" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んはぁっ！　そ、そう……それぇ……っ！　お、オチンポきたっ、あっ、あ\nあ……オチンポぉ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3204205" ]},
		{"command":[ "SETIMAGE", "0", "still_00000132_02_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んひっ、いっ、オチンポ感じるっ。まだまだガチガチの勃起オチンポが、ぷ\nっくり膨らんでる亀頭が、子宮にぃ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3204206" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ああっ、気持ちいいっ。オマンコ、すごく気持ちよくなってる……！　んは\nぁっ、突かれるたびに、汁を飛ばしてしまうぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3204207" ]},
		{"command":[ "SETIMAGE", "0", "still_00000132_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「イッてるんだ。オマンコ敏感になってるから、弱いところ、オチンポでぐり\nってされただけで、軽くイク……ッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3204208" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「敏感になっているのはオマンコだけかって？　そんなことない、おっぱいも\n、おっぱいの感度だって……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3204209" ]},
		{"command":[ "SETIMAGE", "0", "still_00000132_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「お前に揉まれると、それだけで痺れて、い、イキそうになってしまうくらい\nになってるんだからぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3204210" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んひぃっ、そ、そうやってまた、おっぱいとオマンコ……あっ、ああっ、一\n緒に……ぃっ、くひぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3204211" ]},
		{"command":[ "SETIMAGE", "0", "still_00000132_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「おっぱい、ああっ、めちゃくちゃにされて……！　あっ、ああっ、気持ちい\nい……乳首もいじめて、ぐりぐりってしてぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3204212" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あはぁあっ、オマンコもいいのぉっ！　あひっ、ピストン、思いっきり奥ま\nでオチンポが届くような……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3204213" ]},
		{"command":[ "SETIMAGE", "0", "still_00000132_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あっ、ああっ、激しいのっ、オチンポ何度もキスしてるっ！　オチンポどち\nゅどちゅくるっ、子宮蕩けるぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3204214" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「イクッ、イクッ、さっきから何回も、お前にイかされてるっ！　ああっ、あ\nあっ、ほらまたイッた、オマンコイッた、んぁっ、ああっ！」", "NORMAL" ]},
