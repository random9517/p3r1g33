		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「気持ちよかったからもっとヤらせろ？　まったく、２回もしたのにまだ満足\nできていないのか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3204308" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「やれやれ、しかたのないやつだ。だが、奇遇にも私もまだまだ昂りがおさま\nらないんだ。", "NORMAL" ]},
