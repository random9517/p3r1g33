		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「隊長どの、来てくれたか。うむ……他でもない。ちょっと切羽詰まった事情\nがあってな……こんなところに呼ばせてもらった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0804101" ]},
		{"command":[ "SETCHARA", "0", "char_00010008_01", "2", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「その……このバニーガール姿の性なのか……ウサギの習性とでも言うべきな\nのか……自分でも何とも説明がつかないんだが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0804102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「とにかく、身体が火照って……ムラムラして仕方ないんだ……。これは、も\nう自分独りではどうしようもなくてな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0804103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あぁ……うぅぅっ……もう回りくどい話は後だっ……私にご奉仕をさせて欲\nしいからっ、ほらっ、そこにベッドに来てくれっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0804104" ]},
		{"command":[ "SETCHARA", "0", "char_00010008_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……んんっ……はしたないと思われるのも仕方ないが……だが、\nもう……そんなことを気にする余裕はない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0804105" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00010008_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「私の疼きを鎮められるのは隊長どのしかいない……ふふ、隊長どののペニス\nも準備万端なようで何よりだ……んくぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0804106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んっ……あぁ……すぐにでも、奥まで入れてしまいたいが……ここまで来た\nら焦らない……はぁ、んっ、こちらの準備も済ませないと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0804107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふぅ……んふぅ……ワレメに……ぴったりと押し付けて……柔らかく……擦\nり上げていくっ……んっ、ふっ、あっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0804108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あぁ、隊長どののペニスが……もっと上向きに……んっ、はぁ……こんなに\nギンギンにさせて……待ちきれなくなってるんだな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0804109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「もうすぐだ……あぁ、私も……待ちきれない……はぁ、はぁ……んっ、もう\n入れる……入れてしまう……ペニス……ハメるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0804110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んんっっ！　くふぅぅぅぅっ、ふっ……んぁっ、ああぁぁぁぁぁぁぁんっ…\n…！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0804111" ]},
		{"command":[ "SETIMAGE", "0", "still_00010008_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あぁぁ……くぅっ……根元ぉ……一番奥深くまで……みっちり……埋まった\nぁ……はぁっ、んくっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0804112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ま、まだ動いてないのに……あくぅ……子宮口の近くに……亀頭が当たって\n……はっ、ふっ……イ、イキそうだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0804113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「いや、だ、大丈夫……んっ、あっけなく終わるなんてことはないからな……\nちょっとだけ時間をくれ……すぅっ、はぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0804114" ]},
		{"command":[ "SETIMAGE", "0", "still_00010008_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んっ、大丈夫だ……一旦落ち着いたから……ゆっくり動かしていく……隊長\nどのは、それでいいか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0804115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「分かった……じゃあ、腰を使って行くからな……んんっ、あふっ、んっく、\nあっ、おっ、おふっ……んっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0804116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ゆっくり腰を持ち上げて……また、落とし込む……んんっ、どう、だろうか\n……上手くできているかは……分からないが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0804117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ちゃんと……気持ちいい？　そ、そうか……んっ、それならいい……トレー\nニングのスクワットに近い感覚ですればよさそうだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0804118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「本格的に動かしていくぞ……はっ、んふっ、あっ、んっく、はっ、んんっ…\n…あ、うんっ……はぁっ、あぁぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0804119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「うぁぁ……考えてみれば……騎乗位なんて、ほとんどしたことがなかった…\n…あっふ、自分でするのは……こんな感じ、なんだな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0804120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んっくっ、はっ……んんっ……一度、腰を落とす度に……あぁっ、カリのと\nころが……肉壁に擦れてっ、くぅっ、たまらないっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0804121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「は、んんっ……んふぅ……中から広げられていくぅ……あぁ、太すぎて……\n思い切り……動けない……んくっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0804122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ゆっくりで構わないか……んくっ、すまないな……なかなか、私からリード\nという感じになれなくて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0804123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「だが、一緒に……気持ちよくなっていく……んっ、ふっ……はぁ……そんな\n風にできれば……嬉しい……はぁ、んっ……くっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0804124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あっ、おっ……おぉっ、んっ……！　あぁ、隊長どのからも……突き上げが\n……んくっ、始まって……くっ、あぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0804125" ]},
		{"command":[ "SETIMAGE", "0", "still_00010008_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「はぁっ……中で……太いのが……ヒダを擦りまくって来るっ……！　あっ、\nひっ、はっ、恥ずかしい音がっ……響くぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0804126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んっ、はっ、身体が……ぷるぷるっ、跳ねてっ……おっぱいが揺れるっ……\nんぁっ、くっ、ふぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0804127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「はっ、ふっ、あぁっ……ウサギが跳ねるのは……当たり前っ……それはっ、\nそうだがっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0804128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「こんなっ、ペニスをぱっくり咥えこんで……跳ね回るのはっ、あっ、はひぃ\nっ、い、いやらし……過ぎるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0804129" ]},
		{"command":[ "SETIMAGE", "0", "still_00010008_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「はぁっ、うんっ……！　子宮が欲しがってる……んっ、もっと……激しくし\nていくからなっ、くぅっ、んふぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0804130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あっ、ぉぉっ！　亀頭が……さっきより膨らんでるようなっ……中でっ……\nごりゅごりゅ、擦れてっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0804131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あぁっ……気持ちいいっ……！　欲しいっ、もっと欲しいっ……奥までいっ\nぱいにしてっ……私をよがらせてっ……んひぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0804132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「はひぁっ……顔が緩むぅっ……止まらないっ、あぁっ、スケベピストンっ…\n…くふぅっ、気持ちよすぎるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0804133" ]},
		{"command":[ "SETIMAGE", "0", "still_00010008_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んっ、くぅっ……はぁんっ……あっ……あぁっ……ペニスが中で……広がっ\nていくっ……！　これぇっ……射精したくなってるんだなっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0804134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「はぁっ、んっ、いいぞっ……このまま続けるからっ……何も考えずにっ……\n欲望をそのままっ、吐き出してくれっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0804135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んぁぅっ、私もっ……イクっ、一緒にイクぞっ、あひっ、あっ、あぁっ、ア\nソコが熱いっ……！　も、もうっ、イクぅぅぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0804136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふぁぁぁっ！　あっ、出てきたっ……隊長どのの精液が……子宮に流し込ま\nれていくぅっ！　はっ、あぁぁぁぁぁぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0804137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010008_02_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「熱い……どんどん流れ込んでくる……はぁぁ……精液がいっぱいに満たされ\nて……はぁぁ……受精するぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0804138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んっ、ふはぁ……イッたぁ……身体が浮き上がるような感覚のまま……続い\nてるぅ……あふぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0804139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「これがメスウサギの喜びなのか……んっ、あぁ……しばらく余韻に浸ってい\nたい……最高の気分だ……は、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0804140" ]},
		{"command":[ "SETIMAGE", "0", "still_00010008_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふぅ……はぁ……んっ、これで私の疼きも落ち着くかと思ったが……そんな\nことはないな……バニースーツが蒸れるほど熱い……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0804201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「埋まったままのペニスの中心からずっと熱い感覚が広がっていて……んくぅ\n……もっとして欲しいと……アソコが訴えてきている……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0804202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「続きをしてもいいだろうか……このまま、抜かずにもう一回だ……今度はも\nっと私からも動かしていくから……んぁっ、ふっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0804203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「はっ、はぁっ、んっ、あっ、あふっ……あぁっ、逞しいっ……！　身体の芯\nから貫かれて……支配されている感じがするっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0804204" ]},
		{"command":[ "SETIMAGE", "0", "still_00010008_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「元より……バニーガールとしてっ、主人に尽くしたい……そんな気持ちはあ\nったが……もう、後には戻れないっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0804205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あぁっ、そうだ……このセックスを覚えた以上っ……私は、隊長どのなしで\nは生きていけないかも知れないっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0804206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「いやらしい場所同士をこすり合わせる……それだけなのにっ……もう勝手に\n身体が動いてっ……全然……止められないっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0804207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「はぁんっ、あぁっ……隊長どのっ……あぁっ、私の腰振りでっ……楽しめて\nいるかっ？　バニージャンプでっ、感じてくれているかっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0804208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あぁっ……嬉しいっ……ちゃんと……あぉっ、このピストンが……隊長どの\nを悦ばせているんだと……嬉し、過ぎるぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0804209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「私はっ……あぁっ、すっかりメスに目覚めてっ……あひぁっ、全身が……悦\nんでしまってるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0804210" ]},
		{"command":[ "SETIMAGE", "0", "still_00010008_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「隊長どのの目の前でっ……はしたなくおっぱいを揺らしてっ……緩みきった\nトロ顔を晒しながらっ、どんどん恥をかいてしまうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0804211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「だがっ、もうそれでもいいっ！　隊長になら見せていいっ、太いペニスを咥\nえこんでっ、よがり声を上げているところぉっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0804212" ]},
		{"command":[ "SETIMAGE", "0", "still_00010008_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「だからっ、あぁっ、私を……隊長どののメスにしてくれっ……はひぃっ！　\nそこぉっ、その突き上げがいひぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0804213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あっ、んちゅっ……あぷっ……はぁぁ……そ、そのキスはぁ……ＯＫの意味\nでいいんだな……？　私に尽くさせてくれるんだな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0804214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ならば……もっと、腰を振るっ……！　ぬめった粘膜を、ねっとり押し付け\nてっ……新しい蜜で中をどんどん満たしてっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0804215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あぁっ、ぐちゅぐちゅっ……恥ずかしい音をさせるぅっ！　うんっ、はぁっ\n、おっぱい震わせてっ、隊長どのの目も楽しませるぅっ！", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0804216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あぁっ、はぁぁんっ、駄目だっ……またイキそうになってるっ……隊長どの\nはっ……お、同じかっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0804217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んんっ、一緒がいいっ……隊長どのの欲望まみれの射精でっ、私を……その\nままメスにさせてっ、またイキたいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0804218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あひぁぁぁぁっ！　亀頭が膨らんでるっ……出たがってるのが分かるっ！　\nどうするんだっ……中かっ？　身体にマーキングかっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0804219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「もう、何でもいいっ！　一緒にイって！　あぁっ、駄目だっ……もう我慢で\nきないっ……くぅぅんっ、またイクっ、あぉぉっ、イクぅぅぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0804220" ]},
