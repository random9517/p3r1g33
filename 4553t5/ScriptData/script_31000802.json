		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んんんんんんーーーーっ！　あぁっ……また……な、なかぁっ……びゅくっ\nて……出たぁ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0804301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010008_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「はぁぁぁぁぉ……おぉぉ……何だこの量は……あぁぁ……熱くて、ドロドロ\nで……膣がいっぱいになっていく……んぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0804302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あ……っひ♪　イ、イッてる……んっ、ずっとイッてるぅ……気持ちよすぎ\nて……イクの止まらなくなってるぅ……はひぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0804303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ほ……ぁぉ……ぉぉ……あぁ……出した……？　子宮に……隊長どのの子種\n……全部……出してくれた……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0804304" ]},
		{"command":[ "SETIMAGE", "0", "still_00010008_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……んふぁ……あぁ……少しだけ落ち着いた……もう、腰がガク\nガクして……動けないままだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0804305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「すまないが、あとちょっと……このままでいさせてくれないか……？　ああ\n、ありがとう……今、この気持ちにもう少し浸りたい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0804306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「それにしても……もう完全に隊長どののペニスに堕とされてしまったな……\n自分でも、ここまで乱れてしまうとは思わなかった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0804307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「もう、他の相手で満足することはないのかも知れないな……もう、私は隊長\nどのに染められてしまったから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0804308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「こ、こんなエッチな私でも……お嫁に貰ったりしてくれないだろうか……？\n　いや、別に冗談で言っている訳じゃないぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0804309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふむ……即答はできないか。まあ、答えを急ぐつもりはないさ。でも、少し\n位は考えてみてくれ、隊長どの♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0804310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んんんんんんーーーーっ！　ふぁぁぁっ！　あっ、ペニス……抜けてっ……\n身体に……掛かってるぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0804401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010008_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふぁぁぁ……熱いのが……おっぱいに……いや、顔にまで……はぁぁ、なん\nて濃いにおいだ……んふぅ……あぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0804402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あふっ……！　ずっとイッてる……んくぅっ、精液漬けにされて……身体の\n疼きが止まらない……んふぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0804403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んっ……あぁっ……やっと、射精……止まった……はぁ、はぁ……身体中…\n…ねとねとだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0804404" ]},
		{"command":[ "SETIMAGE", "0", "still_00010008_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ああ、ほんの少しだけ落ち着いた……気持ちは高ぶったままだが……とりあ\nえずは満足だ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0804405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「はぁ……まだ中にペニスが入ってるような感覚が残ってる……全身が鈍い痺\nれに包まれたままだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0804406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「それにしても……もう完全に隊長どののペニスに堕とされてしまったな……\n今、こうして見ているだけでまだムラムラするほどだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0804407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「いや、とりあえずは一休みしなくては身体がもちそうもないが……だが、そ\nの後ならまだまだ続きができそうな気がする」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0804408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「これも隊長どのにそうさせられたから……これは、お嫁に貰って責任を取っ\nてもらうより他にないな、うむ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0804409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「言っておくが、決して冗談というつもりではないぞ？　その……まあ、その\n気があるなら考えてみてくれ。隊長どの♪」", "NORMAL" ]},
