{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0027" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「よし、全員乗ったな。ワゴンのレンタカーに空きがあって助かったぜ」", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「オーディションを終わらせちゃいましたけど、いいんですか～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_010023610001" ]},
		{"command":[ "SETCHARA", "0", "char_00027401_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「そういや、長官に連絡しなくていいのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023610001" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「さっき連絡したんだが、真っ昼間から酔っ払ってたから放っておく。なにが\n別件だ。飲みたかっただけじゃねえか。俺は休日出勤してるのに」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「……そうだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023610002" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「全員、シートベルト締めてくれよ。今はヒーローも法律を遵守する時代だか\nらな」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「はいはい～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_010023610002" ]},
		{"command":[ "SETCHARA", "0", "char_00027401_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「分かりました！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_010023610001" ]},
		{"command":[ "SETCHARA", "0", "char_00026101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「よし、じゃあうららは助手席でナビゲートを頼むな。大まかな場所は分かる\nけど、細かいところは――」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「？　カツマさん、どうしたんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_010023610002" ]},
		{"command":[ "SETCHARA", "0", "char_00026101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「あー……これは……そのですな、うらら殿、シートベルトがあなたの身体に\n食い込んで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023610001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「見事におっぱいを強調しているわね～。パイスラって言ったかしら～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_010023610003" ]},
		{"command":[ "SETCHARA", "0", "char_00027401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「えっ？　あっ、ひああっ、見ないでっ！！　見ないでくださいっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_010023610003" ]},
		{"command":[ "SETCHARA", "0", "char_00026101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「男ってマジで巨乳好きだよな～。おっぱいに夢中で脇見運転するなよ～！！\n　いや、この場合はパイ見運転か！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023610003" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「言う事がいちいち下品なんだよお前……！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「しかしながら今回のは完全に自業自得かと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023610002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「あう……ごめんなさい、私のせいで」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_010023610004" ]},
		{"command":[ "SETCHARA", "0", "char_00026101_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いやいや、俺が悪い……運転手として確認しただけだから、その、もう出発\nするぞ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0183" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ずいぶん来たな……そういや、うららの本家ってどんな所なんだ？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「私の家は……昔は名のある武家だったそうです。本家はその末裔で……春風\nはさらにその分家になります」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_010023610005" ]},
		{"command":[ "SETCHARA", "0", "char_00026101_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ほーん、武家か。だからブラックの奴、刀の使い方が上手かったんだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023610004" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「ええ、本家は今でも剣術の道場を開いてます。元々の素養があった姉は、そ\nこで才能を開花させて……ヒーローになったのもその辺りなんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_010023610006" ]},
		{"command":[ "SETCHARA", "0", "char_00026101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「それは良かったんですけど、ついには本家の誰もが敵わないほどにまでの剣\n術家になっちゃって。本家の当主に据えられちゃって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_010023610007" ]},
		{"command":[ "SETCHARA", "0", "char_00026101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そりゃすげえじゃねえか。なりたくてなれるもんじゃねえだろうし」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「万年中間管理職のご主人が言うと重みがありますな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023610003" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いちいち混ぜっ返すんじゃねえよ。放り出すぞお前。それで、姉貴はどうな\nったんだ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「分からないんです。そこから本家の方に住むようにって言われたらしくて、\nヒーローも辞めちゃって。手紙はくれるんですけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_010023610008" ]},
		{"command":[ "SETCHARA", "0", "char_00026101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「いつも問題なく暮らしてるって。他は私のことばかり気にかけてくれてて…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_010023610009" ]},
		{"command":[ "SETCHARA", "0", "char_00026101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「どうもお姉ちゃんが当主になったことで本家の一部からは春風の家は睨まれ\nてるらしくて、会いに行きたいって言ってもやんわりと断られてて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_010023610010" ]},
		{"command":[ "SETCHARA", "0", "char_00026101_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「だから、お姉ちゃんが当主になってから本家に行くのは私も初めてなんです\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_010023610011" ]},
		{"command":[ "SETCHARA", "0", "char_00026101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「なるほどねぇ。ようやくあいつのバカみてえな強さに納得できたぜ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023610005" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ほむらがそんな風に言うって……どれぐらい強かったんだ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「少なくとも、刀を持って近接戦闘をしたら俺とタメを張るぐらいだな。ある\nいは、最強だったかもしれねえ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023610006" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「そんな人、敵に回したくありませんね～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_010023610004" ]},
		{"command":[ "SETCHARA", "0", "char_00027401_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「怪人という時点ですでに敵なのでは……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023610004" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「あ……見えてきましたよ。あそこです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_010023610012" ]},
		{"command":[ "SETCHARA", "0", "char_00026101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「え……あれって、めっちゃ豪邸じゃねえか……まあそりゃ末裔とか本家とか\n言うならそんなもんか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「別に家の大きさでケンカするわけじゃねえんだ。ガツンとぶちかましてやろ\nうぜ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023610007" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「完全にケンカ売りに来た人の言葉ですね～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_010023610005" ]},
		{"command":[ "SETCHARA", "0", "char_00027401_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ともあれ、どっかに車を停めて取り次いでもらうか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「とりあえず、私が最初に話してみま――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_010023610013" ]},
		{"command":[ "SETCHARA", "0", "char_00026101_01", "0", "CENTER", "0" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "PLAYSE", "SE_M_009" ] },
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「っ！？　なんだ、敵襲か！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA","1"]},
		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「うららーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーー\nっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_020023610001" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "SETCHARA", "1", "char_00027502_01", "9", "CENTER", "-1500" ]},
		{"command":[ "MOVECHARA", "0", "CENTER", "400", "NORMAL" ]},
		{"command":[ "MOVECHARA", "1", "CENTER", "0", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA","0"]},
		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「ひああああああっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_010023610014" ]},
		{"command":[ "SETCHARA", "0", "char_00026101_01", "3", "CENTER", "400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA","1"]},
		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「うららうららうららうららうららうららうららうらら～～～～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_020023610002" ]},
		{"command":[ "SETCHARA", "1", "char_00027502_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA","0"]},
		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「あうううっ、お、お姉ちゃん……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_010023610015" ]},
		{"command":[ "SETCHARA", "0", "char_00026101_01", "9", "CENTER", "400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA","1"]},
		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「うん、お姉ちゃんだようらら～！！　ああ、うららの匂いがするって思って\n出てきたらまさかの本物！！　うららうらら～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_020023610003" ]},
		{"command":[ "SETCHARA", "1", "char_00027502_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA","0"]},
		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「お姉ちゃん、そんなに抱きしめられたら苦しい……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_010023610016" ]},
		{"command":[ "SETCHARA", "0", "char_00026101_01", "4", "CENTER", "400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA","1"]},
		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「私もうららに会えなくて苦しかったよ～！！　んんん、うららの匂い、うら\nらの感触……どれ、味も見ておこう……れろっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_020023610004" ]},
		{"command":[ "SETCHARA", "1", "char_00027502_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA","0"]},
		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「ひあっ！？　ぺろぺろしないで～！！　お姉ちゃん、他の人も見てるからっ\n！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_010023610017" ]},
		{"command":[ "SETCHARA", "0", "char_00026101_01", "9", "CENTER", "400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA","1"]},
		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「へっ！？　えっ……あっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_020023610005" ]},
		{"command":[ "SETCHARA", "1", "char_00027502_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「ゴホン、お見苦しいものをお見せしました。うららの知り合いの様子。どな\nたでしょうか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_020023610006" ]},
		{"command":[ "SETCHARA", "1", "char_00027502_01", "0", "CENTER", "0" ]},
		{"command":[ "MOVECHARA", "1", "CENTER", "-400", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「すげぇ、あの状況からなにもなかったみたいに振る舞ってる」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「鋼の精神力を感じさせますな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023610005" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「ええと、この人たちは先輩というか、お世話になる人……？　大事な人……\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_010023610018" ]},
		{"command":[ "SETCHARA", "0", "char_00026101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「もしや……うららの彼氏とか？　であるならば、適切に処理しなければなり\nませんが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_020023610007" ]},
		{"command":[ "SETCHARA", "0", "char_00027502_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「無表情で迫ってくるなよ怖え！！　ていうか処理ってなんだよ、単語に不穏\nしかねえんだけど！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「うららに近づく男は全て害虫ですので。害虫は掃除する。当然でしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_020023610008" ]},
		{"command":[ "SETCHARA", "0", "char_00027502_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おいうらら、このお姉ちゃん怖いんだけど！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「お姉ちゃんは私のことになるとこうなっちゃうんです……ごめんなさい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_010023610019" ]},
		{"command":[ "SETCHARA", "0", "char_00026101_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「なるほどなあ。服装といい、お前、家だったらこんなだったんだな、ブラッ\nク」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023610008" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「ブラック……？　何を言って――ってレッド先輩！？　なぜここに！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_020023610009" ]},
		{"command":[ "SETCHARA", "0", "char_00027502_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「なんでって、お前に会いに来たんだよ。とりあえず、上げてくれよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023610009" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0"]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0050" ]},
		{"command":[ "PLAYBGM", "BGM_013" ]},
		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「ブルー先輩が倒れて、それでマスカレードの新隊員オーディションに偶然\nうららが。なるほど、事情は理解しました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_020023610010" ]},
		{"command":[ "SETCHARA", "0", "char_00027502_01", "4", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "1", "char_00003402_01", "0", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "1"]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「うららの話を聞いてたら、どうもお前がブラックっぽかったからな。こうし\nて確かめに来たわけだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023610010" ]},
		{"command":[ "SETCHARA", "1", "char_00003402_01", "6", "CENTER", "400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0"]},
		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「その……なにも言わずに脱退したのはご迷惑をおかけしたとは思っています\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_020023610011" ]},
		{"command":[ "SETCHARA", "0", "char_00027502_01", "4", "CENTER", "-400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "1"]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「あー、いい。いい。人それぞれ事情はあるだろうしな。脱退に関しては俺も\n人のことを言えた立場じゃねえ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023610011" ]},
		{"command":[ "SETCHARA", "1", "char_00003402_01", "3", "CENTER", "400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おお、ほむらがまたまともなこと言ってるんげっ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0"]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「これはまた痛そうな１撃……ご主人、そろそろ学習した方がよろしいのでは\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023610006" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "1"]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「今日はお前に伝えることがあって来ただけだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023610012" ]},
		{"command":[ "SETCHARA", "0", "char_00027502_01", "0", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "1", "char_00003402_01", "1", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0"]},
		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「私に……ですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_020023610012" ]},
		{"command":[ "SETCHARA", "0", "char_00027502_01", "3", "CENTER", "-400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "1"]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ああ。うららをマスカレードに入れっから。学生だから、学業優先だけどな\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023610013" ]},
		{"command":[ "SETCHARA", "1", "char_00003402_01", "8", "CENTER", "400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「は？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ふむ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023610007" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「あらあら～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_010023610006" ]},
		{"command":[ "SETCHARA", "0", "char_00027401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「え……ええええええええええええええ！？　いつの間にそんな話に！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_010023610020" ]},
		{"command":[ "SETCHARA", "0", "char_00026101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「さっき決めたからな。元々入りたくてオーディションに来たんだろ？　なら\n合格でいいじゃねえか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023610014" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「ええと、それはそうですけど、そんな流れじゃなかったじゃないですか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_010023610021" ]},
		{"command":[ "SETCHARA", "0", "char_00026101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "STOPBGM" ]},
		{"command":[ "SETTEXT", "「却下です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_020023610013" ]},
		{"command":[ "SETCHARA", "0", "char_00027502_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「ふえ！？　お姉ちゃん？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_010023610022" ]},
		{"command":[ "SETCHARA", "0", "char_00026101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "PLAYBGM", "M17" ]},
		{"command":[ "SETTEXT", "「うららはとても戦闘向きの子ではありません。先輩ほどの力量なら分かるで\nしょう？　むざむざ妹を危険に晒すような真似はさせません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_020023610014" ]},
		{"command":[ "SETCHARA", "0", "char_00027502_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「そうかもな。でも、そうじゃないかもな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023610015" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「なにを意味の分からないことを……とにかく不許可です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_020023610015" ]},
		{"command":[ "SETCHARA", "0", "char_00027502_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「おいおい、お前はもうマスカレードを抜けたんだ。人員に関して口出す権利\nはねえだろ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023610016" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "1"]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "（それはお前もだろ……と思うが、口には出さない。俺は学習できる男）", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "（さすがですご主人。３度目の正直は回避ですな）", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023610008" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "（こいつ……頭の中に直接！？）", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0"]},
		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「ぐっ……ともかく却下です。うららは私が護ります。それを邪魔するのであ\nれば先輩といえど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_020023610016" ]},
		{"command":[ "SETCHARA", "0", "char_00027502_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「俺といえど、なんだよ？　なあ、なんだってんだ？　はっきり言ってみろよ\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023610017" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「……容赦はしません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_020023610017" ]},
		{"command":[ "SETCHARA", "0", "char_00027502_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「はっはぁ！！　いいね、よく言った。いきなり逃げた奴だと思ってたが、い\nい根性してんじゃねえか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023610018" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「なにも知らずに……あなたはいつもそうですね。人のことを顧みず、自儘に\n振る舞って」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_020023610018" ]},
		{"command":[ "SETCHARA", "0", "char_00027502_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ああん？　自分でなにも言わないでも察してくれるだろうなんて、たいそう\n傲慢なこって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023610019" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんか……めちゃくちゃ不穏な雰囲気になってないか？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「静夜ちゃんは分からないけど、ほむらちゃんはあえて挑発してる感じね～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_010023610007" ]},
		{"command":[ "SETCHARA", "0", "char_00027401_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「あわわわわ、と、止めないと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_010023610023" ]},
		{"command":[ "SETCHARA", "0", "char_00026101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや～無理だろ。ほら、見てみろ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「上等だ、表に出ろ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023610020" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「いいでしょう……私の剣技、とくと見せてさしあげます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_020023610019" ]},
		{"command":[ "SETCHARA", "0", "char_00027502_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}