{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0144" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「さてさて、予選が終了しまして、各チームどのような状況になったでしょう\nか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023130001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「えー、第１ラウンドはルナルバース１３世選手が獲得し、原作部門チームが\n１ポイント」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110023130001" ]},
		{"command":[ "SETCHARA", "0", "char_00000514_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「続く第２ラウンドは、アナザールナテミス選手が取りまして、殿堂入り部門\nチームが１ポイント」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023130002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「そして、先程行われた第３ラウンドはアン＝クァー選手が取りまして、オリ\nジナル部門が１ポイント」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110023130002" ]},
		{"command":[ "SETCHARA", "0", "char_00000514_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「と言うことは……なんと、全部門１ポイントずつで並ぶという見事な大混戦\nとなりました！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023130003" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「やや白々しい気もしますが……それで、こういう場合はどうするんです？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110023130003" ]},
		{"command":[ "SETCHARA", "0", "char_00000514_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「はい、ポイント上位のチームの３人で戦うというルールでしたので、そのポ\nイントが並んでいる以上、答えは一つ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023130004" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ここからは、９人全員のバトルロイヤルで決着をつけて頂きます！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023130005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「……長い前フリの割には、結局雑に決着をつけるんですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110023130004" ]},
		{"command":[ "SETCHARA", "0", "char_00000514_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ルールはシンプル！　特設の闘技場でバトルを行いながら、賞品のカツマ殿\nが登場したタイミングでキスをするだけ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023130006" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「闘技場から場外へ落ちた者から脱落するです。バトルに反則はなし。何をし\nても大体ブライド時空補正で何とかなります」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110023130005" ]},
		{"command":[ "SETCHARA", "0", "char_00000514_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「さあ、本来の実力以上のものが発揮されるこのブライド時空！　果たして、\n今回の勝者は一体誰になるのか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023130007" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「泣いても笑っても、これがラストバトルです。レッツファイッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023130008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「……ファイトと言われましても……どのようにしたら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_010023130001" ]},
		{"command":[ "SETCHARA", "0", "char_00022101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「迂闊に手を出してら、どんな罠が待ってるか分からない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010023130001" ]},
		{"command":[ "SETCHARA", "0", "char_00000214_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「だが、そうは言っても、ずっと様子見という訳にもいくまい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010023130001" ]},
		{"command":[ "SETCHARA", "0", "char_00004908_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「さあ、全員出だしはやや慎重なスタートか。お互いの様子を窺っている感じ\nです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023130009" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ふん、まだるっこしことは好かぬ！　余にケンカを売ることの恐ろしさ、た\nっぷりと教えてやるわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_040023130001" ]},
		{"command":[ "SETCHARA", "0", "char_00000703_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「あっと、戸惑う選手達を尻目に、最初に仕掛けたのはルナルバース陛下だ！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023130010" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「とにかく、まとめて吹き飛ばしてしまえばええんじゃろっ、最大火力じゃっ\n……おらぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_040023130002" ]},
		{"command":[ "SETCHARA", "0", "char_00000703_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ひぁぁぁぁぁんっ！　旦那さまぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_010023130002" ]},
		{"command":[ "SETCHARA", "0", "char_00022101_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「きゃぁぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_020023130001" ]},
		{"command":[ "SETCHARA", "0", "char_00003004_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「おーーっと！　陛下の手から凄まじいエネルギーの波動が放たれてっ、一気\nに二人を吹き飛ばした！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023130011" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「まだまだぁっ！　そーら、まとめて行くがよいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_040023130003" ]},
		{"command":[ "SETCHARA", "0", "char_00000703_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「更にラッシュは終わらない！　これは本当に全員吹き飛ばしてしまうのかー\nっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023130012" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ふん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010023130001" ]},
		{"command":[ "SETCHARA", "0", "char_00020103_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「おっとと……危ないな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090023130001" ]},
		{"command":[ "SETCHARA", "0", "char_00000122_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「この程度なら……しっかりガードできる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010023130002" ]},
		{"command":[ "SETCHARA", "0", "char_00000214_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「んなっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_040023130004" ]},
		{"command":[ "SETCHARA", "0", "char_00000703_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「実際の世界であれば、圧倒的な力で全員吹き飛ばせたのかも知れませんが、\nブライド時空は人気が全てですからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110023130006" ]},
		{"command":[ "SETCHARA", "0", "char_00000514_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「陛下渾身の攻撃も、人気上位組には通用せず！　そして、攻撃の直後は隙だ\nらけだーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023130013" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「貴方の部下たちならば恐縮もするだろうが、私の立場は異なるのでな。せい\nっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010023130002" ]},
		{"command":[ "SETCHARA", "0", "char_00004908_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ほぎゃーーーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_040023130005" ]},
		{"command":[ "SETCHARA", "0", "char_00000703_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ここで、冴島長官の蹴りがクリーンヒット！　凄まじい勢いでルナルバース\n陛下が画面外へ吹き飛んだー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023130014" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「画面外って……どんな大乱闘ゲームですかね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110023130007" ]},
		{"command":[ "SETCHARA", "0", "char_00000514_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ともあれ、この間に一気に３人が脱落！　残る６人はいったいどうする？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023130015" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ちっ……ここは迂闊に手を出すと、巻き込まれる可能性がありますね……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000518_01", "7", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_005_010023130001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「怖い人達には近寄らないようにしないと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010023130001" ]},
		{"command":[ "SETCHARA", "0", "char_00001801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「中心からやや距離を取ろうとしているのは、オボロ選手とグリムロック選手\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023130016" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「おっと、そうはいかんぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090023130002" ]},
		{"command":[ "SETCHARA", "0", "char_00000122_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「敵前逃亡など言語道断！　正々堂々と向かってくるがいい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010023130003" ]},
		{"command":[ "SETCHARA", "0", "char_00004908_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ここで、アナザールナテミス選手と、冴島長官が一気に距離を詰めていく！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023130017" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「うわわぁぁー！　わ、私は平和主義だからぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010023130002" ]},
		{"command":[ "SETCHARA", "0", "char_00001801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「そんな奴がここに参加している訳ないだろうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090023130003" ]},
		{"command":[ "SETCHARA", "0", "char_00000122_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「さあ捕まえ……うぁっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010023130004" ]},
		{"command":[ "SETCHARA", "0", "char_00004908_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「あぁっ、グリムロック選手を捕まえようとした長官が足を滑らせた……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023130018" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んひゃあっ！？　ちょっ……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000518_01", "3", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_005_010023130002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「その手が、もつれたオボロ選手の方へっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023130019" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「は、離すですっ！　式神っ！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000518_01", "3", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_005_010023130003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ちょっ……！？　おおぉいっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090023130004" ]},
		{"command":[ "SETCHARA", "0", "char_00000122_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「これはっ、態勢を崩しながらのオボロ選手の式神が、あらぬ方向に飛んでア\nナザールナテミス選手にヒット！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023130020" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「きゃあああああああっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010023130005" ]},
		{"command":[ "SETCHARA", "0", "char_00004908_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「は、離すですっ、ひゃああああっ！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000518_01", "3", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_005_010023130004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「うわあぁぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090023130005" ]},
		{"command":[ "SETCHARA", "0", "char_00000122_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「そして、もつれた足を立て直せないまま、オボロ選手もろとも場外へダウン\n！　更にルナテミス選手も巻き込んだー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023130021" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「さっきの予選で走った疲れが、しっかりと効いていたようですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110023130008" ]},
		{"command":[ "SETCHARA", "0", "char_00000514_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「た、助かったの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010023130003" ]},
		{"command":[ "SETCHARA", "0", "char_00001801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「勝手に共倒れをしてくれたようだな。やはり、母は偉大なのだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010023130002" ]},
		{"command":[ "SETCHARA", "0", "char_00020103_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「……ここまで来たら負けない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010023130003" ]},
		{"command":[ "SETCHARA", "0", "char_00000214_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「さあ、残り３名になったところで……あーっと、これはっ！　天井からカツ\nマ殿が降りてきたぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023130022" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「くっ、くそっ……何がどうなってっ……こんな状態になってんだっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「簀巻きのようにして吊るされてますね……身動きが取れませんよ、あれは」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110023130009" ]},
		{"command":[ "SETCHARA", "0", "char_00000514_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「なかなか滑稽な姿ですが、選手たちにとっては些末なことです。３選手とも\n一斉にカツマ殿に迫っていく！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023130023" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「カツマっ！　私とっ……キキ、キスをっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010023130004" ]},
		{"command":[ "SETCHARA", "0", "char_00000214_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「待っておったぞ。さあ、母はここじゃ。しかと愛をかわそうではないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010023130003" ]},
		{"command":[ "SETCHARA", "0", "char_00020103_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「こ、ここまで来たら、どさくさ紛れに勝ってみせるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010023130004" ]},
		{"command":[ "SETCHARA", "0", "char_00001801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「これはっ、ロープに括られたカツマ殿に向かって、３選手が下からしがみつ\nいているーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023130024" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「まるで蜘蛛の糸ですね。果たして、どんな決着が待っているんでしょうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110023130010" ]},
		{"command":[ "SETCHARA", "0", "char_00000514_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「カツマ……！　顔をこっちに……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010023130005" ]},
		{"command":[ "SETCHARA", "0", "char_00000214_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そんな器用にできるかっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「さあ、母の手を持つがよい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010023130004" ]},
		{"command":[ "SETCHARA", "0", "char_00020103_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ぐるぐる巻きに縛られてるんですが！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「は、離さないよ……ふひっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010023130005" ]},
		{"command":[ "SETCHARA", "0", "char_00001801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「てかっ、ま、待て！　そんなに一度に群がられたらっ……お、落ちるっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「これはっ、ロープが激しく揺らいでっ……危ないぞっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023130025" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「あ……駄目ですね、これは……切れます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110023130011" ]},
		{"command":[ "SETCHARA", "0", "char_00000514_01", "3", "CENTER", "0" ]},
