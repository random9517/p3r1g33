		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「んふっ……まだ吸い付いたままなんて……もう、本当に甘えん坊さんなんで\nすから……よしよし、いい子ですね……」", "NORMAL" ]},
