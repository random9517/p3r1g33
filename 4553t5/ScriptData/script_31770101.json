		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「あぁ……おっぱいも……また溢れて来る……んんっ、わ、私ったら……まる\nで射精してるみたいに……は、恥ずかしい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「あっ……あぁ……ありがとうございます……はい、勿体ないですから、もっ\nと吸って下さい……ん、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0103303" ]},
		{"command":[ "SETIMAGE", "0", "still_00017701_01_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「熱い……んっ、身体がずっと高揚感に包まれたままです……ずっと忘れてい\nたこの感じぃ……ちゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0103304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「はぁぁん……ザーメンも美味しい……あぁ、プリッとした新鮮で濃厚な味が\n……まだ、もう少し出そうですか？　全部出しちゃいましょうね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0103305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「んふっ！　ほら……出てきました……素敵です、隊長さんのオチンポ……本\n当に逞しくて……私の身体……全部塗り替えられてしまいそう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0103306" ]},
		{"command":[ "SETIMAGE", "0", "still_00017701_01_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……やっと収まって来ましたね……私も、こんなに母乳を出し\nたのは初めてです。随分、はしたない姿をお見せしてしまいました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0103307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「そんなことありませんでしたか？　ふふっ、ありがとうございます。ですが\n、隊長さんにならお見せしてよかったと思っていますから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0103308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「待って下さいね、綺麗に後始末をしてしまいますから……そ、その、よ、よ\nろしければシャワーなどもご一緒に……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0103309" ]},
		{"command":[ "SETIMAGE", "0", "still_00017701_01_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「あ……も、もう、私ったらすぐに先走って……でも、ありがとうございまし\nた、隊長さん……一夜限りでも、嬉しかったですわ……」", "NORMAL" ]},
