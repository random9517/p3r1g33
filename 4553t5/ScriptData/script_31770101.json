		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「あっ、顔にっ……あぁんっ！　ここまで届くなんてっ……あぁ……すごく元\n気です……んふっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0103301" ]},
