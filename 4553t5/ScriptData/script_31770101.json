{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017701_01_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「ええと……そうですね、はい……そのまま楽になさっていて下さい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0103101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「その……今日は、日頃お世話になっているからという訳ではありませんが…\n…絆を深めるということで、その……オチンポへのご奉仕を……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0103102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「あの、どうか……誤解なさらないで下さいね？　私……誰にでも、こんなこ\nとをするような女ではないんです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0103103" ]},
		{"command":[ "SETIMAGE", "0", "still_00017701_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「ですが隊長さんには……誰にも言えない私の秘密も……知っておいて頂きた\nくて……それは、その……すぐ分かります」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0103104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「では……まず、オチンポを扱かせて頂きます……んっ、ふっ、もう……ビク\nビクしていて……本当に逞しい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0103105" ]},
		{"command":[ "SETIMAGE", "0", "still_00017701_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「どうでしょうか、最初はこれ位の加減でいかがですか？　ちょうど、皮の剥\nけた所……優しく握って参りますね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0103106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「んっ、んふっ……はい、おっぱいも……気になりますよね。ええ……どうぞ\n、お口に合うか分かりませんが……あんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0103107" ]},
		{"command":[ "SETIMAGE", "0", "still_00017701_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「あっ、は……はい……大丈夫、です……ちゅうっと吸って頂いて……はっ、\nうんっ！　あぁっ……はっ、んふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「ふふ……隊長さん……思ったよりも甘えん坊さんみたいですね……それなら\n私も優しくオチンポを癒やしてあげませんと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0103109" ]},
		{"command":[ "SETIMAGE", "0", "still_00017701_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「んっ、あふっ……しこしこ……ちゅくちゅく……どうですか……？　これ位\nの加減……気持ちいいですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「あんっ……んっ、んふっ、もっと強くてもいいみたいですね……んっ、乳首\nに催促して来るなんて、隊長さんったら……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0103111" ]},
		{"command":[ "SETIMAGE", "0", "still_00017701_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「分かりました……それじゃあ、もうちょっと大きく動かして……はぁっ、ん\nっ、はい……オチンポの先、シコシコしますぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0103112" ]},
		{"command":[ "SETIMAGE", "0", "still_00017701_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「んっ、結構……激しくしても、大丈夫なのですね……その、私……そこまで\n詳しくはないので……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「ですが、喜んで頂けてるなら嬉しいです……あぁ……んっ、はい、おっぱい\nもどうぞ……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「だ、大丈夫です……もっと強く吸って頂いても……ただ、そうしますと……\nあっ、も、もうすぐ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0103115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「あっ、はっ、あぁぁぁんっ！　んっ、出ちゃうっ……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0103116" ]},
		{"command":[ "SETIMAGE", "0", "still_00017701_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「はぁ……んふっ、はい……実は、私……母乳が出てしまう体質なのです……\n恥ずかしいので、他の方には秘密なのですが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0103117" ]},
		{"command":[ "SETIMAGE", "0", "still_00017701_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「隊長さんには、知られても……その……いいかなと……あっ、あぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「あっ、ちゅうって……んっ、あっ……吸われるぅっ……おっぱい、吸われち\nゃいますぅっ、んぁっ、あぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0103119" ]},
		{"command":[ "SETIMAGE", "0", "still_00017701_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「あぁっ……はい、確かに……んっ、今日は……こうなるかもと……期待して\n、いました……ご奉仕をする為に、どうすればいいかと考えて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「こうして、母乳を飲んで頂きながら、オチンポを扱けば……隊長さんに喜ん\nでもらえるのではと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0103121" ]},
		{"command":[ "SETIMAGE", "0", "still_00017701_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「んっ……はしたないのは承知ですが、どうか軽蔑なさらないで下さい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0103122" ]},
		{"command":[ "SETIMAGE", "0", "still_00017701_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「あぁ……そ、そんな……ずっと身を持て余していたとか……そんな、ことは\n……あ、ふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「だ、ダメですね……これ位で集中を乱しては……。ちゃんと、オチンポ扱き\nを続けます……ふっ、んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「はぁっ、んっ、あぁ……幹がこんなに反り返って……逞しい……あの人のよ\nりずっと……あ、い、いえ、何でもありません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0103125" ]},
		{"command":[ "SETIMAGE", "0", "still_00017701_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「んっ、んふっ……あんっ、乳首……あまり悪戯するのは許して下さい。思っ\nた以上に、敏感になってて……いつもより母乳も出ちゃって……んっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「はっ、ふっ……んんっ、あっ……気持ちいいですか？　はい……私も、おっ\nぱい……とっても気持ちいいです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0103127" ]},
		{"command":[ "SETIMAGE", "0", "still_00017701_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「こうして……一緒に、高まって行くと……隊長さんとの絆がもっと深まるよ\nうな感じで……素敵……ですわっ、はぅんっ、あっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「はい……指を……入り口の所に押し込むんですね？　どうですか……痛く、\nありませんか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0103129" ]},
		{"command":[ "SETIMAGE", "0", "still_00017701_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「いい感じなんですね……はい、もっともっと感じて下さい……嬉しいです、\n私の手でオチンポ感じて下さってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「あぁ……ビクビク震えて……もうすぐ出てしまいそうですか？　んっ、えぇ\nっ、どうぞ……我慢なさらないで……お好きなタイミングで出して下さい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「隊長さんの精液……んっ、オチンポから出る、新鮮なミルク……あぁ……ド\nキドキします……は、早くぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0103132" ]},
		{"command":[ "SETIMAGE", "0", "still_00017701_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「はいっ、このまま手の中でも大丈夫ですっ……んっ、はっ、あっ、どうぞっ\n……あ、あぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「あっ……はぁぁぁんっ！　オチンポミルクっ……いっぱい……出てますぅっ\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0103134" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017701_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「んっ、はぁぁぁ……あふっ……これが隊長さんの……あぁ……こんなに沢山\n……指に絡まって来ています……あぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0103135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「んふ……一緒に母乳も出て来ちゃいました……あぁ……済みません、お顔を\n汚してしまいますね……んっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0103136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「大丈夫ですか……？　はい、吸って下さい……おっぱいの奥に残ってる分も\n……あっ、あんっ……そうです、ちゅうって……あふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0103137" ]},
		{"command":[ "SETIMAGE", "0", "still_00017701_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「んっ、やっと落ち着いて来ましたね。思った以上に沢山出して頂いて……少\nしびっくりしました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「気持ち……良かったですか？　あぁ、そ、そうですか。褒められると……そ\nの、くすぐったい気分ですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「でも喜んで頂けたのなら、私も頑張った甲斐がありました。ふふ……よかっ\nたですわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「あっ……隊長さん……どうされましたか……？　んっ！　ま、また……オチ\nンポ……大きく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0103201" ]},
		{"command":[ "SETIMAGE", "0", "still_00017701_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「私の母乳で……また元気になったから……それは、あ、ありがとうございま\nす。でも、そうだとしたら……まだ終わりには出来ませんわね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「はい、承知しています。このまま、もう一回……オチンポが射精するまで手\nコキを続けさせて頂きますわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0103203" ]},
		{"command":[ "SETIMAGE", "0", "still_00017701_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「ひぁっ！　あっ……乳首もっ……続けてっ！？　は、はい……それは、もち\nろん……隊長さんのお好きになさって下さい……んぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0103204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「あっ、あぁっ、歯を……そんなに、押し当てられたら……んっ、ま、また…\n…乳首……敏感になって……ミルク……出ちゃいますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「あひっ、あぁっ、で、出るぅっ！　お、おっぱい出ますぅっ！　あっ、はぁ\nぁぁぁぁぁぁぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0103206" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017701_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「んっ……はぁぁ……申し訳ありません……ずっとドキドキして……身体全体\nが……熱くなってまして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「はい、オチンポご奉仕続けます……オチンポ、シコシコしますから……ご遠\n慮なく……ミルクも飲んで下さい……んふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0103208" ]},
		{"command":[ "SETIMAGE", "0", "still_00017701_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「あぁ……くちゅくちゅして……オチンポが精液でヌルヌルになるのはご不快\nではありませんか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「よかった……では、このぬめる感じを使わせていただきますね……んっ、ん\nくっ、は……んぅん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0103210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「ふふ……どうですか、気持ちいいですか？　あん……もう、そんなにおっぱ\nいに吸い付いて……隊長さんは思った以上に甘えん坊さんですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0103211" ]},
		{"command":[ "SETIMAGE", "0", "still_00017701_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「よしよし……大丈夫ですよ、いい子いい子……もっと、オチンポ気持ちよく\nしてあげますからね……ほら、指でおしっこの出る所……してあげます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「ふふっ、今の……よかったですか？　腰がビクって動いて……とっても可愛\nいですよ、隊長さん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「もっともっと気持ちよくなりましょうね……子供っぽいのに、オチンポはこ\nんなに立派で逞しくて……んっ、あっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0103214" ]},
		{"command":[ "SETIMAGE", "0", "still_00017701_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「あぁ……おっぱいもずっと張ってしまってます……内側からどんどんミルク\nが溢れて来ちゃう……こんなの、初めてです……んっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0103215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「これが、気持ちが一つになっていく感じなのでしょうか……ずっと忘れてい\nた感覚……あたたかくて……あぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0103216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、また、オチンポがビクビクしてますね……分かっていますよ\n、ドピュって出したいんでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「いいんですよ……後もう少しですからね……頑張れー、頑張れー、オ、チ、\nン、ポ、さんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0103218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「あっ……！　んふっ、乳首も……強くっ、されてぇっ……わ、私も一緒に、\nイッてしまいそうですっ……んぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0103219" ]},
		{"command":[ "SETIMAGE", "0", "still_00017701_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「はいっ……一緒が……一緒がいいですっ、ドピュッとして下さいっ……！　\nおっぱいっ、一緒に出しますからぁっ、あ、はぁぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0103220" ]},
