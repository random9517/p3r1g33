		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「はぁぁんっ……あぁっ、母乳も出ちゃう……あぁ……オチンポミルクと……\n私のミルクが……一緒に混ざってしまいます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「んっ……あぁ……隊長さん、まだおっぱいそのまま……はい、勿体ないです\nし、吸い出してしまって下さい……あひっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0103403" ]},
		{"command":[ "SETIMAGE", "0", "still_00017701_01_16" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「あぁ……止まらない……こ、こんなに母乳が出るなんてぇ……あぁっ……気\n持ち、いい……んふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0103404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「私も……オチンポミルクの味見、失礼しますね……ちゅぷっ……んんっ、あ\nぁ……濃いの……美味しいですわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0103405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「まだ出そうですか？　はい……搾り出してしまいましょう……隊長さんのオ\nチンポまだ硬い……素敵ですわ……んふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0103406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「あぁ……やっと落ち着いて来ましたか。はぁ……私も、こんなに母乳を出し\nたのは初めてです……」", "NORMAL" ]},
