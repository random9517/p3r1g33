{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0078" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "襲来者" ]},
		{"command":[ "SETTEXT", "「そんな……バカな……！？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「これで襲来者（インベーダー）は全員倒せたみたいだな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「さて、それじゃあ会場に戻ってコンテストの続きを……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「って、あれ？　会場は何処に行ったんだ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「先ほどの戦闘のせいで、綺麗さっぱり崩れてしまったようだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090021520026" ]},
		{"command":[ "SETCHARA", "0", "char_00000111_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピースムーン" ]},
		{"command":[ "SETTEXT", "「しかも会場だけでなく、周囲にもかなり被害が出てますね。これでは、コン\nテストどころではありませんよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_040021520017" ]},
		{"command":[ "SETCHARA", "0", "char_00000811_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「ちょっとあなたたち！　なんてことをしてくれるんですか！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「こんな状態になったら、コンテストなんてできません！　今年のコンテスト\nは中止ですよ、中止！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「中止って、そりゃないぜ！　まだ一回もポロリを見てないってのに！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人……今はポロリを気にするよりも、こちらの方を気にした方がよいと\n思いますぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021520061" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はぁ？　ポロリ以外に大切なことなんて……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「カツマ……ちょっといいかしら……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070021520025" ]},
		{"command":[ "SETCHARA", "0", "char_00000107_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「えっと、お嬢様……？　どうしてそんなに怒ってらっしゃるんです？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「どうしてもこうしてもないわ！　あなた、なんてことをしてくれたの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070021520026" ]},
		{"command":[ "SETCHARA", "0", "char_00000107_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「お前のせいでコンテスト会場どころか、周りの建物も壊れたじゃないか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040021520015" ]},
		{"command":[ "SETCHARA", "0", "char_00000404_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「わ、私……カツマのために……が、頑張ったのに……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_050021520020" ]},
		{"command":[ "SETCHARA", "0", "char_00000205_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「あっ……で、でも……コンテスト中止は……ちょっと、嬉しいかも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_050021520021" ]},
		{"command":[ "SETCHARA", "0", "char_00000205_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「えっ！？　俺なんもしてねぇだろ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「いいえ、これは全てカツマさんのせいです。あなたの指示が悪かったから、\nこうなったんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_060021520016" ]},
		{"command":[ "SETCHARA", "0", "char_00000506_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「せっかくディアナちゃんがやる気出してあげたのに、これじゃあ賞品どころ\nか、お買い物もできないじゃな～い！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_050021520016" ]},
		{"command":[ "SETCHARA", "0", "char_00000605_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「みんなここから避難したせいで、男どもがみんな居なくなっちゃったじゃな\nい！　どう責任取ってくれるのよ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021520015" ]},
		{"command":[ "SETCHARA", "0", "char_00000306_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いやいや！　指示っていうか、お前らが必要以上に大暴れしたからだろ！？\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「思ってた以上に手ごわかったね。ちょっと本気出しちゃった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_030021520023" ]},
		{"command":[ "SETCHARA", "0", "char_00001203_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「でもいつも以上に出力を出さないと、負けるところだったわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_020021520030" ]},
		{"command":[ "SETCHARA", "0", "char_00001402_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「余力を持って戦えば、危険だったです。結構キツめのヤバめだったですよ！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021520023" ]},
		{"command":[ "SETCHARA", "0", "char_00010103_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「とはいえ、負ける気はしませんでしたが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_010021520014" ]},
		{"command":[ "SETCHARA", "0", "char_00010203_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「コンテスト会場が壊れちゃったのは残念だけど、仕方ないね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021520018" ]},
		{"command":[ "SETCHARA", "0", "char_00010303_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「会場が壊れた原因は、お前たちにもあるからな！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「ふむ。無事……とは言えんが、なんとか倒せたようだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010021520033" ]},
		{"command":[ "SETCHARA", "0", "char_00010002_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「コンテスト会場もなくなっちゃし、この勢いと戦力で敵の本拠地を叩きに行\nこうよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010021520026" ]},
		{"command":[ "SETCHARA", "0", "char_00009602_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「そうだな！　これだけの戦力があれば、すぐに制圧できるぜ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_010021520015" ]},
		{"command":[ "SETCHARA", "0", "char_00009702_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「今度は油断しないように、万全の状態で挑まないとね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021520016" ]},
		{"command":[ "SETCHARA", "0", "char_00009802_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「そんなワケで隊長さん。引き続き、襲来者（インベーダー）退治よろしくね\n～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_010021520015" ]},
		{"command":[ "SETCHARA", "0", "char_00009902_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ふざけるな！　俺はもう付き合わないからなーーー！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「あっ、ご主人！　お待ちください！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021520062" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
