{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0195" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「話は全て聞かせていただきました！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_030022700001" ]},
		{"command":[ "SETCHARA", "0", "char_00017803_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「あ、あ、あ、あゆちゃん！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010022700001" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "天野川ホールディングスへ向かい話をするといきなり社長室に通される。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "大人気アイドル、天野川・織姫・あゆむを待っていた俺達は……突如現れた本\n人に騒然となった。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「い……いきなり本人が出てくるとは……！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「あっ！　あっあっ！　秘書さんか誰かにご相談するつもりで……！　い、一\n体どうしたら……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020022700001" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「すっごい！　すっごい！！　生のあゆちゃんってこんなにキラキラしてるん\nだ！　カワイすぎ！　輝いてる～ッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010022700002" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「ヤ、ヤムさん……！　す、す、すみません、私、こういう時にどう対応して\nいいかよくわからなくて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020022700002" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「そんなに緊張なさらないで。ちょうど時間が空いたところに、面白そうなお\n話を聞いてきただけですから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_030022700002" ]},
		{"command":[ "SETCHARA", "0", "char_00017803_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あー……えっと。な、何から話せばいいんだか……。そ、その……本日は、\nお日柄もよく……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "緊張してガチガチになっている俺の肩にぽん、と手を置くとあゆむは自分の方\nから話を切り出してくれた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「そ・れ・で……今回のお話ですけど……。もちろん、私の歌でよければやら\nせていただきたいと思っております」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_030022700003" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「や、や、や、やった～～～～ッ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010022700003" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「あわわわわ、そ、そんな……そんな恐れ多い……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020022700003" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ホントにいいんですか？　その、町内会のちっちゃな祭りなんですよ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「イベントの規模は関係ありません。今回の件、私の新しいステージを開ける\nと思います。だから全力で曲を作り、歌わせていただきますね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_030022700004" ]},
		{"command":[ "SETCHARA", "0", "char_00017803_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「さっすがあゆちゃん！　わかってるぅ！　ますます大好きになっちゃったぁ\n♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010022700004" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「ああ……。一流の歌手は、心まで広く美しいんですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020022700004" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「さすがトップアイドル……言うことが違いますなぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022700001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「でも、前に会った時には……かなりカッとんだ性格の人だったような……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「フフフフ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_030022700005" ]},
		{"command":[ "SETCHARA", "0", "char_00017803_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「本当に任せていいんだろうか……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "不安になってきた俺の指を、イルルがちょいちょいと引っ張ってきた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「おとーさん、多分、大丈夫だと……おもうよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010022700001" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「あの人からは、いい曲を作ること、歌うのが好きなことしか伝わってこない\nよ、新しいすてーじ？　も、本心だと思う……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010022700002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうか。イルルが言うなら少し安心だな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「えへへ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010022700003" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「それじゃ……あらためてお願いします」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「ええ。あとは私に任せて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_030022700006" ]},
		{"command":[ "SETCHARA", "0", "char_00017803_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "快諾するあゆむにホッとする俺達一同。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "それを見て嬉しくなったのか、イルルは再び俺に小さな声で囁いてくる。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「あと……あゆむさん。しょく、しゅ？　なにかうねうねしたものがすごく好\nきみたい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010022700004" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「それはイルルは知らなくていい、無視しなさい」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010022700005" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0041" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「まさかのＯＫでしたね。驚きました……。はぁ、まだ胸が早鐘を打っていま\nす」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020022700005" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「あははっ。センセー、びっくりしすぎて何も言わなくなっちゃってたし！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010022700005" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「…………そうですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020022700006" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「えっ！？　なになに！？　傷つけちゃった！？　だったらゴメンッ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010022700006" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「いえ、そうではなく……カツマさんの活躍に比べて、私は何も出来ていない\nな、と……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020022700007" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「そ、そんなことないよ！？　こうして付いてきてくれてるじゃん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010022700007" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「……しかし……。あっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020022700008" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「どうした？　何か言い忘れたことでもあったのか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「い、いいえ。そういうことではなくて……。あの。今、とっさに思いついた\nだけですが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020022700009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「私からも１つ提案したいことがあります。聞いてもらえますか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020022700010" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}