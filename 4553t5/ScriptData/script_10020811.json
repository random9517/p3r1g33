{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0147" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "そして、決戦の日とやらなわけだが……。", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「よくぞ逃げずに待っていたわねえ、敗北者が」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113940001" ]},
		{"command":[ "SETCHARA", "0", "char_00000311_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「この間までの私とは、違う……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113940001" ]},
		{"command":[ "SETCHARA", "0", "char_00001604_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……なあ、なんで修羅姫までエファと似たり寄ったりな格好になってんだ？\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「色々あったんです、色々……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010113940001" ]},
		{"command":[ "SETCHARA", "0", "char_00001701_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ふーん？　なんか、他の連中もやけに荒んでるというか……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「いたな、裏切り者……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010113940001" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ここ数日の鬱憤、思い切り晴らしてやるのですよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010113940001" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "なぜか俺に向けて、親の仇でも見るかのような視線を送ってくるんだが！？", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「こちらこそ、驚きました。まさかエファさんの連れていた者たちが、襲来者\n（インベーダー）で……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010113940002" ]},
		{"command":[ "SETCHARA", "0", "char_00001701_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "塾生一号" ]},
		{"command":[ "SETTEXT", "「今日は正々堂々勝負ッス！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00090201_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "塾生二号" ]},
		{"command":[ "SETTEXT", "「お互い悔いのないよう全力を尽くすッス！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00090301_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "塾生三号" ]},
		{"command":[ "SETTEXT", "「勝っても負けても恨みっこなしッス！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00090401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「や、やけに、スポーツマンシップに目覚めていませんか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010113940003" ]},
		{"command":[ "SETCHARA", "0", "char_00001701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あー……こっちもまあ、色々あったんだよ。色々」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒサイレーン" ]},
		{"command":[ "SETTEXT", "「ふーん。興味深い現象ではあるね。襲来者（インベーダー）の間で、どんな\n化学変化が生じたのか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010113940001" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「カツマくんも……敵になった？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010113940001" ]},
		{"command":[ "SETCHARA", "0", "char_00001801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ってかなんで俺が憎まれているんだよ！！　俺は何もしてないぞ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「そうですな、いつも以上に今回は、まったくといっていいほど、蚊帳の外で\nすな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113940001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ああでも、動画でこちら側の皆様を焚き付けたのは、ご主人だったのでは？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113940002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「俺が塾生側の黒幕であるかのようにしれっと言うな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「エールの交換はそこまで！　各々、位置について！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_020113940001" ]},
		{"command":[ "SETCHARA", "0", "char_00002502_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "学園長もノリノリで審判役かよ……止めなくていいのかよ、普通。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「両者、用意はいいかい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_020113940002" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「いつでも」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113940002" ]},
		{"command":[ "SETCHARA", "0", "char_00000311_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「必ず……勝つ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113940002" ]},
		{"command":[ "SETCHARA", "0", "char_00001604_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYBGM", "BGM_027" ]},
		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「では――これより、『乱杰李威仏斗暴屡（らんじぇりい・ふっとぼうる）』\nを開始する！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_020113940003" ]},
		{"command":[ "SETCHARA", "0", "char_00002502_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "塾生一号" ]},
		{"command":[ "SETTEXT", "「よぉし、まずは――」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00090201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「行かせねぇ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010113940002" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "塾生一号" ]},
		{"command":[ "SETTEXT", "「ぐわっ！？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00090201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「大丈夫か！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113940003" ]},
		{"command":[ "SETCHARA", "0", "char_00000311_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "塾生一号" ]},
		{"command":[ "SETTEXT", "「へ、平気です、このぐらい……ちょっと、激しい当たりだっただけで」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00090201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「そうか……しかし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113940004" ]},
		{"command":[ "SETCHARA", "0", "char_00000311_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「いきなりのご挨拶じゃないか！　脈絡もなくラフプレイを仕掛けてくるなん\nて！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113940005" ]},
		{"command":[ "SETCHARA", "0", "char_00000311_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「さって、なんのことかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010113940003" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "……随分とぼけるな、セレーナの奴。今のは俺にも、わざと体当たりしたよう\nにしか見えなかったぞ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「……いいでしょう。反則ではない、というのであれば」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113940006" ]},
		{"command":[ "SETCHARA", "0", "char_00000311_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "いきなり波乱含みだなおい……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「では――続行！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_020113940004" ]},
		{"command":[ "SETCHARA", "0", "char_00002502_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "塾生二号" ]},
		{"command":[ "SETTEXT", "「ぐはっ！？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00090301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「んっ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "再開してすぐに、また一人……今度はすっ転んだ？　いや、足を引っ掛けられ\nたのか？", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「これは失礼。まさかそんなところに足を引っ掛けるとは思いもしなかったの\nです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010113940002" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "オボロか……なら、上手くごまかしたろうな。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「審判！！　今のは――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113940007" ]},
		{"command":[ "SETCHARA", "0", "char_00000311_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「悪いけど、私には何も見えなかったよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_020113940005" ]},
		{"command":[ "SETCHARA", "0", "char_00002502_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「っ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113940008" ]},
		{"command":[ "SETCHARA", "0", "char_00000311_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "やっぱりな。オボロの奴、審判の死角で何か仕掛けやがったんだ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "塾生二号" ]},
		{"command":[ "SETTEXT", "「大丈夫……です、塾長！　こんなことで負けません！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00090301_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "塾生三号" ]},
		{"command":[ "SETTEXT", "「試合はまだ続いています、こんな奴らすぐに見返してやりましょう！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00090401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「そうか……そうだな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113940009" ]},
		{"command":[ "SETCHARA", "0", "char_00000311_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「私は、お前たちを信じる！　お前たちも、私が教えたことを信じろ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113940010" ]},
		{"command":[ "SETCHARA", "0", "char_00000311_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「一人はみんなのために、みんなは一人のためにだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113940011" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "塾生たち" ]},
		{"command":[ "SETTEXT", "「はい、塾長！！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00090201_01", "6", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "1", "char_00090301_01", "6", "CENTER", "0" ]},
		{"command":[ "SETCHARA", "2", "char_00090401_01", "6", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "DISPCHARA", "2", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "……なんだか、なあ。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "DISPCHARA", "2", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "エファたちのノリは相変わらずだが、よっぽどクリーンな姿勢で試合に臨んで\nいて……。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "一方、我が同僚たちときたら……。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒサイレーン" ]},
		{"command":[ "SETTEXT", "「あ、そこは落とし穴になってるから、気をつけてね～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010113940002" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「そうであるか。では敵を誘導するのである」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_010113940001" ]},
		{"command":[ "SETCHARA", "0", "char_00002001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「ふふ……罠だらけのコート……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010113940002" ]},
		{"command":[ "SETCHARA", "0", "char_00001801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "……悪の組織としては、正しい姿なんだろうけど、なあ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「さすがのわたくしめも、あまりに凄惨な光景に、頭がフット―しそうですぞ\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113940003" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "5", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「凄惨っつうか、なあ……どっちを応援すればいいのか、迷うな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「あー、ご主人はいわば、攫われたお姫様ポジションですからなあ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113940004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……いっそこのまま逃げ出したくなるな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「手段は問わない！　勝てば官軍！　勝利を我が手に！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113940003" ]},
		{"command":[ "SETCHARA", "0", "char_00001604_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「そのねじ曲がった根性、叩き直す……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113940012" ]},
		{"command":[ "SETCHARA", "0", "char_00000311_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}