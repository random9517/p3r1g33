{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0116" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_019" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "――なんとか謎のクノイチグループを追い払った氷華。", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "だが、その疲労は激しく、消耗した身体を癒やすため『居酒屋・正義』を訪れ\nていた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「は～～い、いらっしゃ～～～～…………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020021550006" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「って、てめーかよ……。一体なんのようだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020021550007" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「居酒屋を訪れる理由に、それほど多様な選択肢があるとは思えませんね。酒\nを飲むために決まっているじゃありませんか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_020021550023" ]},
		{"command":[ "SETCHARA", "0", "char_00005002_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「持って回った言い方すんじゃねぇ！　ぶっとばすぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020021550008" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「ここは中立地帯のはずでしょう？　それに、それは店員の態度とは思えませ\nん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_020021550024" ]},
		{"command":[ "SETCHARA", "0", "char_00005002_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「……そのとおり。金さえ貰えば、正義側も悪側も、しっかりもてなすのがウ\nチの店の方針だからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020021550009" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「いらっしゃいませー！　一人、入りまーす！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020021550010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "やややけっぱち気味のほむらの接客に、氷華は苦笑しながら席に案内される。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「お客様、お飲み物お伺いしまーす！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020021550011" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「純米のみぞれ酒で」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_020021550025" ]},
		{"command":[ "SETCHARA", "0", "char_00005002_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「……相変わらず冷たいヤツだな。たまには熱燗でも飲めっての……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020021550012" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ご新規カウンターさーん、みぞれ酒！　はいよ、今日のお通しは特製のチリ\nコンカーンだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020021550013" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「……私、辛いものが得意ではないこと、憶えてないのですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_020021550026" ]},
		{"command":[ "SETCHARA", "0", "char_00005002_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「……そうだっけ？　まあ、でも試してみろよ。食えねえほど辛いものを出す\nわけねーだろ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020021550014" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「それに、これは俺が昼から仕込んだんだ……結構いい出来だぜ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020021550015" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「昼から……ですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_020021550027" ]},
		{"command":[ "SETCHARA", "0", "char_00005002_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ああ、そうだ。店長がよぉ、またギックリ腰をやっちまってな……今日一日\n仕込みが大変だったんだぜ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020021550016" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「そうですか……今日一日……。それは大変でしたね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_020021550028" ]},
		{"command":[ "SETCHARA", "0", "char_00005002_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「はいよ！　みぞれ酒お待ち！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020021550017" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "アツアツの小皿に入ったチリコンカーンの横に、キンキンに冷えた冷酒入りの\nグラスが添えられる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "燃えるように赤い煮物と、淡く青いグラスの間には、温度差に干渉された空気\nが穏やかに漂っているように見えた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「……そうですか。どうやら思い過ごしのようです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_020021550029" ]},
		{"command":[ "SETCHARA", "0", "char_00005002_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「何をブツブツ言ってんだ？　せっかくのみぞれが溶けちまうぜ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020021550018" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「そうですね……いただきます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_020021550030" ]},
		{"command":[ "SETCHARA", "0", "char_00005002_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「…………うん、これなら食べられるかも」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_020021550031" ]},
		{"command":[ "SETCHARA", "0", "char_00005002_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "彼女特性の、ピリカラ煮物を箸の先で舐めつつ、凍った日本酒をちびちび啜る\n。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "酒が一段と美味しく感じられた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「……今夜は長い時間、カウンターを陣取ることになりそうですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_020021550032" ]},
		{"command":[ "SETCHARA", "0", "char_00005002_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そのまま箸でチマチマとチリコンカーンを突きながら、酒を舐め取っていく。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "客" ]},
		{"command":[ "SETTEXT", "「お～～い、ほむらたん！　おあいそー！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ほむら『たん』は止せって言ってんじゃねーか！　出禁にすっぞ、コラァ！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020021550019" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "客" ]},
		{"command":[ "SETTEXT", "「ほむたん、追加注文いいかなー？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "客" ]},
		{"command":[ "SETTEXT", "「ほむらん、同じのおかわりー！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "厨房" ]},
		{"command":[ "SETTEXT", "「ほむほむ、フライドポテト、あがったよー！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「てめーら、好き勝手呼ぶんじゃねぇ！　ったく、次呼んだら、全員ぼったく\nるからな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020021550020" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_020021550033" ]},
		{"command":[ "SETCHARA", "0", "char_00005002_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "にぎやかな店内を縦横無尽に動き回るほむらを見ながら、氷華はどこか在りし\n日を懐かしむような表情を浮かべていた――。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}