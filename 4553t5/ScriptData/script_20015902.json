{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0027" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「どうやら、敵は片付いたみたいだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023810001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「ありがとうございます、助かりました……どうも、いつもの動きが思ったよ\nうにできなくて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_010023810001" ]},
		{"command":[ "SETCHARA", "0", "char_00027901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒルデガード" ]},
		{"command":[ "SETTEXT", "「確かに……身体が重たくて、加護の力も万全には発揮できませんでしたね…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_281_010023810001" ]},
		{"command":[ "SETCHARA", "0", "char_00028101_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「いやいや、それでも十分に素晴らしい戦いぶりだった。かなりの使い手と見\nた」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090023810001" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「そちらこそ、見事な体捌きだった。人の子でありながら、相当な修行を積ん\nだのだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_010023810001" ]},
		{"command":[ "SETCHARA", "0", "char_00028001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「人の子って言うには色々無理がありそうな奴らなんだけどな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒルデガード" ]},
		{"command":[ "SETTEXT", "「貴方は、人の子で間違いありませんでしたね。でも、頑張られていたと思い\nます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_281_010023810002" ]},
		{"command":[ "SETCHARA", "0", "char_00028101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「普通に戦い方がショボかったってことだろ……分かってるよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒルデガード" ]},
		{"command":[ "SETTEXT", "「あ……ご、ごめんなさい……そんなつもりじゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_281_010023810003" ]},
		{"command":[ "SETCHARA", "0", "char_00028101_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ええい、卑屈になるな鬱陶しい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023810002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「とにかく、ここでは落ち着いて話もできんな。１度、我々の本部に来てもら\nうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090023810002" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そうだな、ケガの治療もできる。色々と話も聞きたいところだし、一緒に来\nてくれるか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023810003" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「今は他に頼れる方もいません。助かります」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_010023810002" ]},
		{"command":[ "SETCHARA", "0", "char_00027901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「傷の手当てはありがたい……が、何か１つ忘れているような……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_010023810002" ]},
		{"command":[ "SETCHARA", "0", "char_00028001_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒルデガード" ]},
		{"command":[ "SETTEXT", "「アリーヤさんもですか？　私も、何か思い出せないことがある気がしたんで\nすが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_281_010023810004" ]},
		{"command":[ "SETCHARA", "0", "char_00028101_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「どうした？　こっちだ、早く来い」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090023810003" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒルデガード" ]},
		{"command":[ "SETTEXT", "「は、はい、すみません！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_281_010023810005" ]},
		{"command":[ "SETCHARA", "0", "char_00028101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0000" ]},
		{"command":[ "SETTEXT", "……", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "…………", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "………………", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0027" ]},
		{"command":[ "SETNAME", "スクルド" ]},
		{"command":[ "SETTEXT", "「ひゃぁぁぁぁぁーーーーーーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_283_010023810001" ]},
		{"command":[ "SETCHARA", "0", "char_00028301_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スクルド" ]},
		{"command":[ "SETTEXT", "「あったた……えっ……と、ここ……どこ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_283_010023810002" ]},
		{"command":[ "SETCHARA", "0", "char_00028301_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0101" ]},
		{"command":[ "PLAYBGM", "BGM_011" ]},
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「すると、ここは未来の人間たちが暮らしている場所……何千年後かのミッド\nガルドということですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_010023810003" ]},
		{"command":[ "SETCHARA", "0", "char_00027901_01", "6", "CENTER", "0" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「そういうことになるな。もちろん、あなた方の名前が我々の知る神話上のそ\nれと一致しているだけで、必ずしも同じとは限らないが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090023810004" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「それにしても、レイアにアリーヤ、ヒルデガードか……更にはオーディン様\nと来た……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「北欧神話の神々たちが、実際にいたとはな。いや、今更驚くようなことでも\nないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023810004" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「それで、神族と魔族が、人間の版図を巡って戦っていると……全く今も昔も\nすることは変わっていないようだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090023810005" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「お前たちの説明を聞く限りでは、どうして私たちがこの地に迷い込んだのか\nは分からないと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_010023810003" ]},
		{"command":[ "SETCHARA", "0", "char_00028001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒルデガード" ]},
		{"command":[ "SETTEXT", "「時間も、場所も異なっていますが……どこかで地続きになってしまったとい\nうことでしょうか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_281_010023810006" ]},
		{"command":[ "SETCHARA", "0", "char_00028101_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「我々もまだ状況は把握しきれていないが……あの空にできた空間は、次元の\n裂け目というやつかも知れんな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090023810006" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「次元の裂け目？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「こことは、時間軸、或いは因果律の異なる世界と、あの裂け目を通じて繋が\nっている状態のことだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090023810007" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……つまり、あの向こうに全く違う世界があるということか？　それこそ、\nレイア達がいる世界が」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あなた達は、戦いの最中に突然現れた、謎の裂け目に吸い込まれたという話\nだったな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090023810008" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「はい。私たち神族が魔族たちと戦っている時に、突然巨大な穴ができたかと\n思うと、引きずり込まれるように……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_010023810004" ]},
		{"command":[ "SETCHARA", "0", "char_00027901_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「魔族たちの新たな手管かと思ったが……その割には、魔族共も混乱している\nようだったな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_010023810004" ]},
		{"command":[ "SETCHARA", "0", "char_00028001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒルデガード" ]},
		{"command":[ "SETTEXT", "「お陰で、さほど苦労せずに戦いに勝てたのはよかったですが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_281_010023810007" ]},
		{"command":[ "SETCHARA", "0", "char_00028101_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「けど……私たちがこうしている間に、天界の方はどうなっているのでしょう\nか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_010023810005" ]},
		{"command":[ "SETCHARA", "0", "char_00027901_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「時間軸が歪んでいる以上、何とも言えないが……いなくなっているという状\n態も十分考えられるだろうな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090023810009" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒルデガード" ]},
		{"command":[ "SETTEXT", "「困りましたね……戦いの最中ですし、早く元の世界に戻らないと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_281_010023810008" ]},
		{"command":[ "SETCHARA", "0", "char_00028101_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「その、空の裂け目とやらに行けば、戻れるんじゃないか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_010023810005" ]},
		{"command":[ "SETCHARA", "0", "char_00028001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「どうだろうな……そんな単純な話なら問題ないが、一筋縄で行くかどうか…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090023810010" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「とにかく、私たちが落ちてきた、あの裂け目を調べる必要はありそうですね\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_010023810006" ]},
		{"command":[ "SETCHARA", "0", "char_00027901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ふむ、それならば、我々と協力しないか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090023810011" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「えっ、あなた方と……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_010023810007" ]},
		{"command":[ "SETCHARA", "0", "char_00027901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「確かに、場所が場所だし、何かとバックアップがあった方がいいだろうな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「どうせ私たちも、あの裂け目は調査せねばならんからな。目的が一致してい\nるなら協力するのがいいだろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023810005" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「それは……確かに、ありがたい申し出ですが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_010023810008" ]},
		{"command":[ "SETCHARA", "0", "char_00027901_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒルデガード" ]},
		{"command":[ "SETTEXT", "「はい、とても心強いです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_281_010023810009" ]},
		{"command":[ "SETCHARA", "0", "char_00028101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「待て、私はまだお前たちのことを完全に信用してはいない。この茶番自体、\nお前たちが仕組んだという可能性もあるからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_010023810006" ]},
		{"command":[ "SETCHARA", "0", "char_00028001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「アリーヤ……！　そんなこと……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_010023810009" ]},
		{"command":[ "SETCHARA", "0", "char_00027901_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ふん、随分と好きなように言ってくれるな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023810006" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「当然だ。私はレイアやヒルダお嬢様のように、お人好しではない。たかだか\n１度共闘した程度で信用できるか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_010023810007" ]},
		{"command":[ "SETCHARA", "0", "char_00028001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ふむ……困ったな。そちらで意思の統一ができていなければ、勝手に話を進\nめるわけにも行かん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090023810012" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「アリーヤ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_010023810010" ]},
		{"command":[ "SETCHARA", "0", "char_00027901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「何を言われようと、知ったことか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_010023810008" ]},
		{"command":[ "SETCHARA", "0", "char_00028001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒルデガード" ]},
		{"command":[ "SETTEXT", "「……あの、こういう時はですね……ごにょ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_281_010023810010" ]},
		{"command":[ "SETCHARA", "0", "char_00028101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「えっ……？　そ、それを……俺が？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒルデガード" ]},
		{"command":[ "SETTEXT", "「手が離れている今がチャンスです。今のうちに……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_281_010023810011" ]},
		{"command":[ "SETCHARA", "0", "char_00028101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「マジかよ……うぅっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「アリーヤ、考え直してくれませんか。今はバラバラになっている時では……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_010023810011" ]},
		{"command":[ "SETCHARA", "0", "char_00027901_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「お前たちが勝手に徒党を組むなら好きにすればいい。私は私だけでやらせて\nもらう。それだけのことだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_010023810009" ]},
		{"command":[ "SETCHARA", "0", "char_00028001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ちょ、ちょっと待ったぁ～」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「何だ……？　今、貴様を相手にしている暇は……お、おいっ、その槍はっ！\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_010023810010" ]},
		{"command":[ "SETCHARA", "0", "char_00028001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あんまり聞き分けが悪いと、こいつがどうなってもいいのかな？　お、おー\nん？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「ぐっ……！　や、やはり貴様らは……そういう輩だったか……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_010023810011" ]},
		{"command":[ "SETCHARA", "0", "char_00028001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あれは……何をしているんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023810007" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「アリーヤは槍が何よりも大切なのです。ですので人質と言いますか、槍質と\n言いますか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_010023810012" ]},
		{"command":[ "SETCHARA", "0", "char_00027901_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「さ、さあ、協力すると言え。じゃないと、この槍が……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「わ、分かった……！　協力するっ、すればいいんだろう！　だから……オー\nディン様に頂いた私の槍を返してくれっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_010023810012" ]},
		{"command":[ "SETCHARA", "0", "char_00028001_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「え……えっと、それじゃあ……はい」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「え……？　か、返してくれるのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_010023810013" ]},
		{"command":[ "SETCHARA", "0", "char_00028001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「とりあえず言質を取ったら返していいって……それでいいんだよな？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒルデガード" ]},
		{"command":[ "SETTEXT", "「はい、大丈夫です。ですがアリーヤさん……ご自分で言った言葉には責任が\nありますよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_281_010023810012" ]},
		{"command":[ "SETCHARA", "0", "char_00028101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「ぐ……まさか、ヒルダお嬢様の差し金とは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_010023810014" ]},
		{"command":[ "SETCHARA", "0", "char_00028001_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「アリーヤ、あの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_010023810013" ]},
		{"command":[ "SETCHARA", "0", "char_00027901_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「ええい、勝手にしろっ！　私の足を引っ張ることがあればこの槍が黙ってい\nないからな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_010023810015" ]},
		{"command":[ "SETCHARA", "0", "char_00028001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「何と言うか……神族は神族で色々と大変なようだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090023810013" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「あはは……その、常にこうという訳ではないのですけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_010023810014" ]},
		{"command":[ "SETCHARA", "0", "char_00027901_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ともあれ、これで共同戦線を張ることができるわけだな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023810008" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「長官からも指示を受けている。インクレディブル・スクワッドの任は一旦外\nれて、あの次元の裂け目を調査しろということだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090023810014" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「うむ、ヴァルキリー特務隊の発足だな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023810009" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「え……俺も戦乙女になっちまうのか……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}