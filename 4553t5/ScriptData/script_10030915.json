		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「いやぁ、ついにボクらのアナザーが登場かぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020115950001" ]},
		{"command":[ "SETCHARA", "0", "char_00002202_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「珠魚から聞かされて驚いたのである」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_020115950001" ]},
		{"command":[ "SETCHARA", "0", "char_00002002_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「ボクも、カツマくんから聞いたときには驚いたよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020115950002" ]},
		{"command":[ "SETCHARA", "0", "char_00002202_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「私も、実際見てびっくりしたな……。まさか、あんなに似ているなんて……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_020115950001" ]},
		{"command":[ "SETCHARA", "0", "char_00001802_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「たしかにグレーテルのアナザーは結構似てたね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020115950003" ]},
		{"command":[ "SETCHARA", "0", "char_00002202_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「珠魚のアナザーもかなり似ていたのである」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_020115950002" ]},
		{"command":[ "SETCHARA", "0", "char_00002002_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「ええっ、そんなに似てた？　あんな痴女みたいな衣装、恥ずかしくて着られ\nないよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020115950004" ]},
		{"command":[ "SETCHARA", "0", "char_00002202_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「衣装じゃなくて、性格的な話だと思うな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_020115950002" ]},
		{"command":[ "SETCHARA", "0", "char_00001802_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「それにしても、これからも我々のアナザーがでてくるのであろうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_020115950003" ]},
		{"command":[ "SETCHARA", "0", "char_00002002_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「そういや、修羅姫のアナザーはまだ見てないよね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020115950005" ]},
		{"command":[ "SETCHARA", "0", "char_00002202_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「修羅姫の姿は赤鬼だから……青鬼？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_020115950003" ]},
		{"command":[ "SETCHARA", "0", "char_00001802_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「あははっ、ただの２Pカラーみたいになりそう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020115950006" ]},
		{"command":[ "SETCHARA", "0", "char_00002202_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「あとは……Ｍ．Ａ．Ｍ．Ａとか？　ほら、『Ｙ．Ａ．Ｍ．Ｉ』って、Ｍ．Ｏ\n．Ｅのアナザーもいたし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020115950007" ]},
		{"command":[ "SETCHARA", "0", "char_00002202_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「いたね。どんなだろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_020115950004" ]},
		{"command":[ "SETCHARA", "0", "char_00001802_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「名前は……Ｇ．Ｉ．Ｂ．Ｏとか、どうであるか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_020115950004" ]},
		{"command":[ "SETCHARA", "0", "char_00002002_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「ありえるねぇ。それで、やっぱり性能としては、Ｍ．Ａ．Ｍ．Ａと同じくら\nいなのかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020115950008" ]},
		{"command":[ "SETCHARA", "0", "char_00002202_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「我のアナザーのように、別の機能に特化した形でチューンされている可能性\nもあるのである」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_020115950005" ]},
		{"command":[ "SETCHARA", "0", "char_00002002_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「たしかに、遥架のアナザーは、見た目があんまり似てなかったもんね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_020115950005" ]},
		{"command":[ "SETCHARA", "0", "char_00001802_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「見た目がバスではない可能性があるのである。電車とか、新幹線とか、宇宙\n戦艦とか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_020115950006" ]},
		{"command":[ "SETCHARA", "0", "char_00002002_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「うわぁ、ありそう。そうなると、もしかしたらＭ．Ａ．Ｍ．Ａより移動に便\n利かもしれないね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020115950009" ]},
		{"command":[ "SETCHARA", "0", "char_00002202_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「フフフ……そうかもね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_020115950006" ]},
		{"command":[ "SETCHARA", "0", "char_00001802_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「宇宙を自由に移動できる手段は、持っておくべきである」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_020115950007" ]},
		{"command":[ "SETCHARA", "0", "char_00002002_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「Ｍ．Ａ．Ｍ．Ａを下取りにだして、そっちに買い替える？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020115950010" ]},
		{"command":[ "SETCHARA", "0", "char_00002202_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「もーっ！　さっきからなんの話をしてるのよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010115950001" ]},
		{"command":[ "SETCHARA", "0", "char_00021202_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}