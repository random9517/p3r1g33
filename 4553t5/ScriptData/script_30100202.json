{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001002_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「ふむぅ、おまえさんとこんなことをする日がやってくるとはな……いささ\nか想定外だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0204101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「私は族長……精を受ける相手は、できるだけ選ばねばならん。まあ、若い\n頃はなかなか衝動が抑えられず、随分奔放に楽しんだものだが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0204102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「しかし今の私は、肉体的には若返っているが中身は老人だ……はてさて、\n一体どうなることことやら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0204103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「まあいい。とにかくベッドに寝転んで、すべて私に任せろ……ふふふ。さ\nあ、行くぞ……ッ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0204104" ]},
		{"command":[ "SETIMAGE", "0", "still_00001002_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「ほほう、こうして改めてみると、なかなかのものだな。大きすぎず、小さ\nすぎず……太さも硬さもまずまず……いいちんぽだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0204105" ]},
		{"command":[ "SETIMAGE", "0", "still_00001002_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「いいちんぽの定義？　色々あるとは思うが、私は誰しもが同じように楽し\nめるちんぽこそが、いいちんぽだと思っているぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0204106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「まあ、そんなことはどうでもいい……私の体がオスを求めて、だんだん熱\nくなってきているのでな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0204107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「さて、と……そろそろ挿れさせてもらうぞ……ふふふ。何百年ぶりかのイ\nチモツだ……それじゃあ早速――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0204108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「ふぐぅぅぅ……！　こ、これは意外だな。はぁ、はぁ……まさか体が生娘\nだった頃にまで戻っているとは……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0204109" ]},
		{"command":[ "SETIMAGE", "0", "still_00001002_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「ふぅ、この歳になって未通女（おぼこ）のような体験をするとは……いさ\nさか、恥ずかしいものだな……あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0204110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「うぐぅ、うぁぁ……なかなか、まんこの入り口が開こうとせん……だが、\nんん、くぅ……ゆっくりと、ちんぽを飲み込んでいるぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0204111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「それにしても、こんなにキツイものだったか……？　ええい、私は月狼族\nの族長だ……この程度のこと、なんとも……ぐぅ、うう……ッ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0204112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……苦しさと、快感が同時に襲ってきよる……ぐっ、ふぅ…\n…初めての時と同じ……！　長らく忘れていた感覚だ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0204113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「ぐぅ、ううぅ……うあぁっ！　はぁ、はぁ……あはぁ、ほら、ようやく奥\nまで入ったぞ……ふぅ……ふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0204114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「やや時間はかかったが……これでようやく、セックスの初手を指し終えた\nというところかな……ふふふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0204115" ]},
		{"command":[ "SETIMAGE", "0", "still_00001002_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「どうだ？　わかるか？　今、子宮がおまえさんの亀頭で持ち上げられてい\nるぞ……はぁ……ふぅ……いい感触だ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0204116" ]},
		{"command":[ "SETIMAGE", "0", "still_00001002_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「ヘソの下あたりを圧迫される苦しみ……これが気持ちいいのだから、セッ\nクスとは不思議なものだな……ぐぅ、あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0204117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「おっと……余韻に浸っているだけでは、ちんぽが気持ちよくならんな。待\nっていろ……今動いてやる……よっ、こい、しょっとぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0204118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「ん……んんぁ、はぁ……ふぅ……ほら、どうだ？　気持ちいいか？　ふぅ\n、ふふふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0204119" ]},
		{"command":[ "SETIMAGE", "0", "still_00001002_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「上になった時の、腰の動かし方……どうやら忘れてはいないようだな……\nぐふふ、さすは私だ……はぁ、んふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0204120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「ん、くぅ……ふぅ、ふふふ……先っちょが子宮に擦り当てられて……あっ\n、んん、コリコリ音が、響いてくる……ん、んあぁ、はあぁあん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0204121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……あああ、いかんな……腰が勝手に、早く動いてしまう…\n…しっかり制御せんと……ふぐぅ、あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0204122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「あっ、あああっ……はぁ、あはぁぁ……動作を少し速めただけなのに、快\n感がこんなに大きく……んっ、くぅ……はひぃぃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0204123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「はぁ……ふぅ……参ったのう……体が汗ばんできたぞ……それに、中がじ\nっとりと濡れてきて……はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0204124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「おい、おまえさん。ぼーっとするんじゃない……男なら、私の動きに合わ\nせて……腰を持ち上げたりするべきだろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0204125" ]},
		{"command":[ "SETIMAGE", "0", "still_00001002_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「うぐっ、あはぁぁ……そ、そうだ……たまらないな……ああっ、奥を突か\nれて、擦られる感覚……ん、んんぁ、あぁ……はへぇぇぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0204126" ]},
		{"command":[ "SETIMAGE", "0", "still_00001002_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「あ、あ、はぁ……はぁぁ……これはいかんな……腰が止まらん……んっ、\nぐぅ、はぁ……あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0204127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「ちんぽが……一番深いところに……ぐぅ、ううぁっ、はぁ……あぁぁあん\n……！　随分と女泣かせなちんぽなことだ……ふふふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0204128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「なに？　気持ちよくて出そうだと？　いいだろう。我慢せずにいつでも出\nすといい……はあ、ふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0204129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「あ、ん……ああぁ……私も、イキ、そうだ……はー……ふぅ……んんっ、\nこ、このまま全力でイク、ぞ……はぁ、はぁ……ふぐぅぅ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0204130" ]},
		{"command":[ "SETIMAGE", "0", "still_00001002_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「あっ、くうぅ……はぁ、ああぁ……！　さあ、出せ……！　はぁ、ふぅ…\n…このまま奥にブチまけろ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0204131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……あっ、ひぃ……イッ、イク……もう、イッ……はぁ、ん\nんっ、んぐぅ！　ひぐぅぅぅぅぅ……！！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0204132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「あっ……ぐっ、んひぃぃぃぃぃ！！　はあぁ……はぁ……腹の奥が、熱い\n……数百年ぶりの精液が、赤子（あかご）の部屋に……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0204133" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001002_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「んっ、んん……どぴゅどぴゅ注がれて……んっ！　子宮が女の役目を思い\n出したようだ……はー……ふうぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0204134" ]},
		{"command":[ "SETIMAGE", "0", "still_00001002_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「ふふ、おっと、私は今、未通娘（おぼこ）だったな……初めて男の味を知\nって、身体が驚いておるのかもしれん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0204135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「うっ、くっ……！　まだ出すとは……どれだけ精を溜め込んでいるのだ…\n…はー……はー……んふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0204136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「ようやく打ち止めか……たっぷり出してくれたようだな……まんこの隙間\nから、こんなに溢れ出しているぞ……ああ、精液の匂い……なんと芳しい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0204137" ]},
		{"command":[ "SETIMAGE", "0", "still_00001002_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「どうだ？　満足したか？　いや、してないはずがないな……なにせ、この\n私のまんこを味わっているのだからな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0204138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「私としても、数百年ぶりのセックスだ……この姿のうちに、もっと楽しん\nでおきたいのだが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0204139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「無理にとは言わんぞ……オスのちんぽは、一度射精すると暫く勃起しない\nものだしな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0204140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「おや？　まだカチカチのままとは……満足したと思ったが、私の思いすご\nしのようだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0204201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「続きがしたい？　ほう……目覚めたばかりの私の子宮を、ここぞとばかり\nに快楽漬けにしようというのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0204202" ]},
		{"command":[ "SETIMAGE", "0", "still_00001002_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「ふふふ……いいだろう。せっかく初々しい体になったのだから、思い切り\n楽しまないとな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0204203" ]},
		{"command":[ "SETIMAGE", "0", "still_00001002_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「よし……では動くぞ……二人で気持ちよくなれるよう、動きを合わせるの\nだぞ……わかったな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0204204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「はぁ……ふぅ……ん、んんぁ、あぁぁあん……いっ、一度イッたせいか…\n…体が貪欲に、なっているな……ぐぅ、ふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0204205" ]},
		{"command":[ "SETIMAGE", "0", "still_00001002_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「ぐぅ……うううぁ、いかん……年甲斐もなく、ちんぽがどんどん恋しくな\nってきたぞ……もっと、ちんぽ……ちんぽ欲しい……ん、んんぁ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0204206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「はっ、はぁ……あぁぁ……ちんぽ、いいぃ……はぁ、はぁ……ちんぽ、ち\nんぽちんぽ、ちんぽぉ……あああ……たまらん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0204207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「まんこの中が、ぐちゅぐちゅかき回されて……腹の隅々まで精液に犯され\nているようだ……はー……はー……んひぃぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0204208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「くぅ、ふぅ……精液のぬるぬるが、気持ちいい……まんことちんぽが擦り\nつけられるだけで、子宮が震えてくる……ああ、たまらん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0204209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「おまえさんも、もっと動いてくれ……私のまんこが壊れるぐらい、激しく\n……ぐぅ、くぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0204210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……そう、その調子だ……！　やはりおまえさんは飲み込みが\n早い……こんなオスは初めてだ……はぁ、あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0204211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「い、いいぞ……まんこが悦んでおる……！　はぁ、はぁ……ああああ、私\n、また、イキそうだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0204212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「ふふふ……体がどんどんメスになっていくのがわかるぞ……はぁ、ふぅ…\n…これは妊娠してしまうかもしれんな……はぁ、あはぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0204213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「くふああぁ……！　なんだ、そんなにちんぽをビクビクさせて……妊娠さ\nせたくて、しょうがないのか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0204214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「ふふふ……男の欲望とは、いつの時代も変わらないな……いいだろう。好\nきにするといい……ぐぅ、ふぅ……はぁ、はへぇぇぇ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0204215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ……！　もう、イキそうだ……はぁ、ふぅ……もっと、ちんぽ\nを味わいたいのに……あっ、んん、はぁ……あぁぁあん……」", "NORMAL" ]},
