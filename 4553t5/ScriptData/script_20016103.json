{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0114" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "あれから３日後。", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "俺は滅棲俄鬼の船で無理やりに働かされ……てはいたものの、すっかりなじん\nで快適な暮らしを手に入れていた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0132" ]},
		{"command":[ "PLAYBGM", "M02" ]},
		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「おにーさんおにーさん♪　宿題を手伝ってほしいのですが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_010024020001" ]},
		{"command":[ "SETCHARA", "0", "char_00020701_01", "5", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああ、待っててくれ。すぐにそっちに行く」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「きゃはぁっ♪　ありがとうございます！　おにーさんがこんなに頼れる方だ\nったなんて……意外でしたわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_010024020002" ]},
		{"command":[ "SETCHARA", "0", "char_00020701_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はっはっ、おだてても何も出ないぞ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「やだ～。心からの本心ですわ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_010024020003" ]},
		{"command":[ "SETCHARA", "0", "char_00020701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「なあなあなあ！　それが終わったら、あたいとドッジボールしようぜ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_010024020001" ]},
		{"command":[ "SETCHARA", "0", "char_00020801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「昨日やった後、ちょーすげー必殺技を考えたんだ。今日こそはぜーったいに\n負けないっ！　いいよなっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_010024020002" ]},
		{"command":[ "SETCHARA", "0", "char_00020801_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「リサシュルカの無限の体力には感心させられたが……。負けてなお、創意工\n夫してくるところはいいな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「だろ！？　だろだろっ！？　だって……あたいとこんなに真剣に遊んでくれ\nるヤツなんかいなかったし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_010024020003" ]},
		{"command":[ "SETCHARA", "0", "char_00020801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「おまえが来てから、あたいの生活は最ッ高だぞ！　ずーっとここにいてほし\nい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_010024020004" ]},
		{"command":[ "SETCHARA", "0", "char_00020801_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「労働よりは向いてるからな。遊びの方が」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「あああああ、早く見せたいなぁ。あたいの必殺ショット！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_010024020005" ]},
		{"command":[ "SETCHARA", "0", "char_00020801_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「えいえい、くらえ！　もう待ちきれないっ。早くしろっ、早くはやく～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_010024020006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「慌てなくてもじっくり付き合わせてもらうって」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「……本当か？　約束だぞ、おまえはわたしといーっぱい遊ぶんだ、それなら\nおとなしく待っててやる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_010024020007" ]},
		{"command":[ "SETCHARA", "0", "char_00020801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「んもぅ……。よそ見ばっかりしちゃイヤですよぉ。まずはこちらでたっぷり\nと♪　オトナのお勉強を教えてくださいませ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_010024020004" ]},
		{"command":[ "SETCHARA", "0", "char_00020701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「なんか、やらしー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_010024020008" ]},
		{"command":[ "SETCHARA", "0", "char_00020801_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「いやらしいと思う方がいやらしいのですわ！　えっと、えっと♪　おにーさ\nん、ここです。わからないのは♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_010024020005" ]},
		{"command":[ "SETCHARA", "0", "char_00020701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「優しくやさし～く教えてくださいね？　ふふふっ。もっと近くにきてくださ\nい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_010024020006" ]},
		{"command":[ "SETCHARA", "0", "char_00020701_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「あ～っ！　あたいも隣に座る！　座りながらボール磨いとく！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_010024020009" ]},
		{"command":[ "SETCHARA", "0", "char_00020801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「こらこら２人とも。そんなにくっついたら何もできないっつうの！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00020701_01", "2", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "1", "char_00020801_01", "6", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SPOTCHARA", "1" ]},
		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「へへへへへ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_010024020010" ]},
		{"command":[ "SETCHARA", "1", "char_00020801_01", "6", "CENTER", "400" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「うふふふふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_010024020007" ]},
		{"command":[ "SETCHARA", "0", "char_00020701_01", "8", "CENTER", "-400" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「そんなことよりめしだ！　めし！　めし！　めし！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_010024020001" ]},
		{"command":[ "SETCHARA", "0", "char_00020901_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「おまえのいっちばん大事な仕事は～！　わたしのごはんをつくることだ～！\n　えい、えいえい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_010024020002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「こぉらーっ！　フォークとナイフを俺の尻に刺して催促するなっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「おまえがかまってくれないとつまらない！　それに……おまえの作るめしは\nうまい……。だから好きだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_010024020003" ]},
		{"command":[ "SETCHARA", "0", "char_00020901_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……ったく……。そんな風に素直に甘えられると、こっちも強く注意しにく\nいだろ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「グラちゃんは、それをわかっていてやっているのですわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_010024020008" ]},
		{"command":[ "SETCHARA", "0", "char_00020701_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「なにぃ！？　あたいもそうしよう！　これでおまえはあたいだけのモノ……\n♪　決定決定決定！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_010024020011" ]},
		{"command":[ "SETCHARA", "0", "char_00020801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「誰のものでもないっつうの！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「みんなのカツマおにーさま♪　ですものね～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_010024020009" ]},
		{"command":[ "SETCHARA", "0", "char_00020701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「うううっ、イチャイチャするなぁ！　抜けがけは禁止って決めたはずだぞぉ\n！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_010024020012" ]},
		{"command":[ "SETCHARA", "0", "char_00020801_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「そうでしったけ～？　忘れちゃいましたねぇ～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_010024020010" ]},
		{"command":[ "SETCHARA", "0", "char_00020701_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……やれやれ。最初にお前らに捕まった時には、どんな過酷な労働をさせら\nれるかと思ってビビッたが……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「フタをあけてみれば、先生ごっこに運動、ゲーム。飯を作ってみんなで食う\nのんびりっぷり……。安心したぞ」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "実際今の生活は、メス〇キが好きな人間からすれば、天国といえなくもない環\n境だ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「誰かに頼りにされるっていうのはいいなあ……。しかし、こんなことばっか\nりしてていいんだろうか」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そういえば、最近フィルの姿を見ていない。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "それに、次元統制局やインクレディブル・スクワッド……この海域を荒らして\nいる何者かについても何も判明していない。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "（何もかもを放棄して、ただ３人と楽しく過ごしているだけのような……？）", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「いいんだ。おまえはここにいてくれれば」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_010024020004" ]},
		{"command":[ "SETCHARA", "0", "char_00020901_01", "5", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「そーだよ！　あたい達、ずーっと遊んで暮らすんだから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_010024020013" ]},
		{"command":[ "SETCHARA", "0", "char_00020801_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「おにーさんは、もはや名誉メス〇キですわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_010024020011" ]},
		{"command":[ "SETCHARA", "0", "char_00020701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「名誉メス〇キ……！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「敵とかにざーこざーこって言っていいんだぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_010024020014" ]},
		{"command":[ "SETCHARA", "0", "char_00020801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「よわよわ～。って一緒に敵を笑ったりするぞ！　見下しながら……。そうだ\n、うまいうまい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_010024020005" ]},
		{"command":[ "SETCHARA", "0", "char_00020901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「おにーさんがいてくれれば、わたくし達も安泰ですわ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_010024020012" ]},
		{"command":[ "SETCHARA", "0", "char_00020701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうかそうか。そこまで言ってくれるなら……俺はここで……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYBGM", "BGM_023" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "PLAYSE", "SE_M_009" ]},
		{"command":[ "SETTEXT", "「うあああああっ！？　な、なんだあ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「すさまじい爆音……敵か！？　それならわたしの出番だ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_010024020006" ]},
		{"command":[ "SETCHARA", "0", "char_00020901_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「くっ……。なごみタイムに突然現れるなんて……最悪ですわ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_010024020013" ]},
		{"command":[ "SETCHARA", "0", "char_00020701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「誰だ！　出てこいっ、楽しい時間を邪魔して……許せない！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_010024020015" ]},
		{"command":[ "SETCHARA", "0", "char_00020801_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「っくぅううっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_010024020007" ]},
		{"command":[ "SETCHARA", "0", "char_00020901_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「船が揺れるぞ！　みんな、俺に捕まっていろ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「おにーさん……っ♪　素敵ですっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_010024020014" ]},
		{"command":[ "SETCHARA", "0", "char_00020701_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYBGM", "BGM_005" ]},
		{"command":[ "SETNAME", "ダイヤナＤ" ]},
		{"command":[ "SETTEXT", "「あらあらあらあらぁ～？　随分と楽しそうねぇ、カツマちゃぁん？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_110024020001" ]},
		{"command":[ "SETCHARA", "0", "char_00000611_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お前は……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナＤ" ]},
		{"command":[ "SETTEXT", "「もちろん知っているでしょぉ？　あたしはダイヤナ・ダーク」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_110024020002" ]},
		{"command":[ "SETCHARA", "0", "char_00000611_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナＤ" ]},
		{"command":[ "SETTEXT", "「平行世界に存在する、数多のダイヤナちゃんの１つの可能性の姿よぉ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_110024020003" ]},
		{"command":[ "SETCHARA", "0", "char_00000611_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「つまりは敵でしょう！？　す、すぐに部下たちに指示を出さないと！　総員\n集合！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_010024020015" ]},
		{"command":[ "SETCHARA", "0", "char_00020701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「敵の来襲を受けていますっ！　今からわたくしの指示に従って動きなさいっ\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_010024020016" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「…………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_010024020016" ]},
		{"command":[ "SETCHARA", "0", "char_00020801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「…………」", "NORMAL" ]},
