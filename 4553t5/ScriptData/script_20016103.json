		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お、おいっ。なんでお前らは何もしないんだ！　ぼーっと傍観してる場合か\n！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「んー。スーちゃんの指示がまだだし。ふわぁ……。あたいが必要になったら\n呼ばれるはず～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_010024020017" ]},
		{"command":[ "SETCHARA", "0", "char_00020801_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「まずは下っ端たちへの指示だ。まだ、わたしたちの出る幕じゃないんじゃな\nいか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_010024020009" ]},
		{"command":[ "SETCHARA", "0", "char_00020901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そんな悠長な……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「おにーさん。心配ありませんわ。わたくし達を信じてください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_010024020017" ]},
		{"command":[ "SETCHARA", "0", "char_00020701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナＤ" ]},
		{"command":[ "SETTEXT", "「……とかのんびりしてる間にぃ？　ふふふふふっ♪　あたしがこの船を壊し\nちゃってもいいのかしら～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_110024020004" ]},
		{"command":[ "SETCHARA", "0", "char_00000611_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナＤ" ]},
		{"command":[ "SETTEXT", "「もうこの海で、何隻沈めたか覚えてないけどぉ。邪魔な船はいらないの。だ\nからぶっ潰してあげちゃうわねぇ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_110024020005" ]},
		{"command":[ "SETCHARA", "0", "char_00000611_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「……くっ！　その発言……自白とお認めになるのですわね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_010024020018" ]},
		{"command":[ "SETCHARA", "0", "char_00020701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ど、どういうことだ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「どーもこーもないよ。こいつが、海域を荒らしてた真犯人って意味に決まっ\nてる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_010024020018" ]},
		{"command":[ "SETCHARA", "0", "char_00020801_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「そうか……。こいつが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_010024020010" ]},
		{"command":[ "SETCHARA", "0", "char_00020901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「じゃあ、ますますまずいだろうが！　ど、ど、どうすれば……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「はん！　アタシを忘れてもらっちゃ困るねぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_129_010024020001" ]},
