		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "ダイヤナ・ダークの背後から突如現れたのは、メス〇キ達に拘束されていたは\nずのフィルだった。", "NORMAL" ]},
