        {"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あんっ？　う、ぐっ……うおおっ！？　か、身体が勝手に……！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「きゃあっ！？　な、何するの！　離してっ……このままじゃ、あなたもやら \nれるんだよ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "013_020101010019" ]},
