        {"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「冗談じゃねぇ！　お前らの言うことを素直に聞くと……思った、か！　ぐ、 \nうううおおおおおお～～！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ほう、下僕のくせに、意外と頑張るものだなぁ。なら、これならどうだ？」", "NORMAL" ]},
