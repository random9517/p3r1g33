{
	"scriptCommands" :  [
        {"command":[ "FADEIN", "NORMAL" ]},
        {"command":[ "SETIMAGE", "0", "bg_0022" ]},
        {"command":[ "DISPIMAGE", "0", "true" ] },
        {"command":[ "FADEOUT", "NORMAL" ]},
        {"command":[ "PLAYBGM", "BGM_003" ]},
        {"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "──まったく人気のない、ある山奥で、俺はそいつと対峙していた。", "NORMAL" ]},
        {"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……はぁ、はぁ。流石はシルバスター……なかなかやるな」", "NORMAL" ]},
        {"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「こんなところまで連れてきてどういうつもりだか知らないけど、もうやめた \nほうがいいよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "013_020101010001" ]},
        {"command":[ "SETCHARA", "0", "char_00001302_01", "0", "CENTER", "0" ]},
        {"command":[ "DISPCHARA", "0", "TRUE" ]},
        {"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「ムーンナイト、あなたじゃ私には勝てない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "013_020101010002" ]},
		{"command":[ "WAITINPUT" ]},
        {"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "……俺はすでに満身創痍だというのに、こいつはまだまだ平気な顔をしてやが \nる。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "やはり、俺では無理なのか……？", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
        {"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「どういうつもりかどうかは……お前を負かしてから教えてやる！　おりゃあ \n！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「うわっと！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "013_020101010003" ]},
		{"command":[ "SETCHARA", "0", "char_00001302_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「痛ぇ！！　な、何普通に顔面パンチしてくれてんだ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「いきなり襲い掛かってくるからだよ。そっちがその気なら、私だって全力で \nいくからね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "013_020101010004" ]},
		{"command":[ "SETCHARA", "0", "char_00001302_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「っ……コノヤロ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「そりゃっ！　うりゃっ！　とりゃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "013_020101010005" ]},
		{"command":[ "WAITINPUT" ]},
        {"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "──人里離れた夜の採掘場に、２つの素早い影が交差する。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "かれこれ２時間近く、だましだまし戦ってはきたが……流石に限界が近づいて \nきた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "我らグレート・ルナリアムとこいつ……シルバスターと名乗る、いわゆる『正 \n義のヒロイン』とは、長い間敵対してきたが……。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "悔しいが、未だ一度として勝てた試しがない。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "認めたくはないが、こいつの戦闘能力は……俺を凌駕し、うちの幹部の女共に \nも匹敵するだろう。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
        {"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いてっ！　あだっ！　ぬああああああ～～！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
        {"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "俺がちょっと動けば、相手はさらに上回る運動量で迎え撃ってくる。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "こ、このままじゃ、俺が一方的にやられるだけだ……。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "かくなる上は……！", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
        {"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……ふ、ふふふふふ。こうなったら仕方ない……俺のとっておきの技を見せ \nてやるぜ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「な、なんですって！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "013_020101010006" ]},
		{"command":[ "SETCHARA", "0", "char_00001302_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「この技を受けて、今まで無事だったものは居ない……四肢が吹き飛んじまっ \nても知らんぞ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「くっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "013_020101010007" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「くらえ！　秘技、ダブル・バレット・シャワー！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
        {"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "腰から抜いた２丁拳銃を構え、目にも止まらぬ速さで引き金を引き続ける。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "この２丁拳銃こそ俺の唯一にして最大の武器。最後に頼れるのはやはりこいつ \nらだけだ！", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
        {"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うおおおお！！　くらえっ、乱れ撃ちだああああああ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「うわっ、わっ、わっ。な、なんかヤケクソになってきてない！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "013_020101010008" ]},
		{"command":[ "SETCHARA", "0", "char_00001302_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
        {"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "とりあえず、時間稼ぎだ！", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "『シルバスターを採掘場におびき出せ』", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "詳しいことは教えてもらえなかったが、そう命令された以上、俺に撤退は許さ \nれない。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "これでのこのこと逃げ帰った日には、あの女どもの恐ろしいお仕置きが……。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "とにかく、事態が好転するまで粘るしかねぇ！！", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
        {"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「これで貴様を最後にしてやる！　死ね死ね死ねぇぇぇぇぇ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「あ、危ないってば！　も～、今日は一段と気合が入ってるなあ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "013_020101010009" ]},
		{"command":[ "SETCHARA", "0", "char_00001302_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「いけないシルバスター！　それは時間稼ぎよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "014_010101010001" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「お姉ちゃん！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "013_020101010010" ]},
		{"command":[ "WAITINPUT" ]},
        {"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "不意にシルバスターからもう一つの声が響く。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
        {"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「私たちをここに連れてきたのはなにかの罠よ。ムーンナイトはその罠が発動 \nするまでの時間稼ぎをしようとしてるのよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "014_010101010002" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「な、なるほど～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "013_020101010011" ]},
		{"command":[ "SETCHARA", "0", "char_00001302_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
        {"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "シルバスターが自分から出た声に反応してうんうんと頷く。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "別に腹話術とか二重人格とかそんなものじゃない。シルバスターは２人組みな \nのだ。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "スーツを着て直接戦闘を行う者と、それをサポートする者。シルバスターとは \nその２人が合体、変身した形態のことを指す。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "今声を上げたのはそのサポート役のほう、というわけだ。まったく厄介なこと \nだぜ。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
        {"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「ようし……一気に決めるよ！　輝け、シルバライドブレード！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "013_020101010012" ]},
		{"command":[ "SETCHARA", "0", "char_00001302_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYSE", "SE_AK_005" ]},
        {"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "シルバスターがそう叫び、手にしたブレードが光り輝く。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
        {"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うおっ、まぶしっ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
        {"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "……あぁ、はいはい。結局いつものパターンね。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "我が王国の精鋭たちをことごとく葬ってきた伝家の宝刀。かくいう俺もあれに \n何度も煮え湯を飲まされてきたクチだ。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
        {"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「いくぞっ、ムーンナイト！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "013_020101010013" ]},
		{"command":[ "SETCHARA", "0", "char_00001302_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「くそっ……！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
        {"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "光り輝くブレードを構え、シルバスターが突進してくる。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "毎回のように、この瞬間だけは慣れねぇ！　冷や汗が出てきやがる……！", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "STOPBGM" ]},
        {"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「──そこまでだ、シルバスター！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010101010001" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「なっ……！？　誰！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "013_020101010014" ]},
		{"command":[ "SETCHARA", "0", "char_00001302_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お、おお！　あいつらは……！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "STOPBGM" ]},
        {"command":[ "PLAYBGM", "BGM_002" ]},
        {"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "崖の上を見上げると、俺とシルバスターを囲むように、６つのシルエットが浮 \nかび上がった。", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
        {"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「お、お前は……ルナテミス！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "013_020101010015" ]},
		{"command":[ "SETCHARA", "0", "char_00001302_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
        {"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "シルバスターが、声を上げた人物の方を向いて身構える。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "思わずシルバスターも警戒するあいつは、俺も所属する組織最強の女幹部、ル \nナテミス。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "俺にあんな命令をしたのもこの女だ。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
        {"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「うっ……囲まれてる！？　いつの間に……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "013_020101010016" ]},
		{"command":[ "SETCHARA", "0", "char_00001302_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「お前はもう袋のネズミ。今宵こそ、我が王国に仇なすシルバスターに引導を \n渡してやろう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010101010002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お、おい！　囲んでる暇があったら、もっと早く助けに来いよ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「…………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010101010003" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「シルバスターに引導を渡してやろう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010101010004" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おおおい！　俺の存在を無かったことにするな！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「口を慎むがいい、下僕。同じ幹部だからと、気安く話しかけるな。虫唾が走 \nる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010101010005" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんだとぉ！？　と、ともかく、何か様子がおかしいぞ！　何故こんなにも \n幹部クラスのヤツが……！　ダイヤナ、オボロ、セレーナに、エファナティカ、\nそれにカグヤまで……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「…………」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「…………」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「…………」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「…………」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「…………」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
        {"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "見回すと、どれも俺にとっては見覚えのある顔ぶれだ。", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "しかも全員が、俺と同じかそれ以上の『紋章もち』と呼ばれる幹部クラス…… \n。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "Ｇ（グレート）・ルナリアムの中でも、女王の次に力と権力を持つ実力者が勢 \n揃いしている。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "今まで、任務のために６人の幹部たちが一堂に会したことはない。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
        {"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おい！　そろそろ俺にも、今回の作戦とやらを教えやがれ！　また俺にだけ \nダンマリか！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「……貴様に教えることなど何もない。もう無駄なことだからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010101010006" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ど、どういう意味だ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「貴様は黙って、私たちに従っていればいい。さぁ、始めろ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010101010007" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「……案ずる必要は無し、すぐに終わる。これぞ奥義、高速潮流の陣……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "005_010101010001" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「えっ……きゃあっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "013_020101010017" ]},
		{"command":[ "SETCHARA", "0", "char_00001302_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なな、何だ……！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
        {"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "安心したのも束の間、突然、地面に女幹部６人を頂点とした大きな六芒星が浮 \nかび上がった。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "こ、これは……！　あいつが得意とする『陣』の中の……めったに見ることは \nない秘術！？", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
        {"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お、おい！？　ちょっと待て！　誰か一人、助けるのを忘れちゃいないか！ \n？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「……この陣からは、何者も逃れられない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "005_010101010002" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「俺も逃げられないってことじゃねぇかチクショウ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
        {"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "気づけば、いつの間にか俺も陣の効果範囲の中に入れられていた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
        {"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まさかあいつら……俺もろとも……！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「な、何をしようというの？　あっ……じ、地面が……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "013_020101010018" ]},
		{"command":[ "SETCHARA", "0", "char_00001302_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
        {"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "そうこうしている内に、辺りが小刻みに振動し、低い地響きが鳴り始める。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
        {"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「やべぇ……！　逃げないと俺までやられるっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「どこへ行く下僕？　貴様にはまだやるべきことがあるだろう」", "NORMAL" ]},
