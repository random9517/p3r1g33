		{"command":[ "WAITINPUT" ]},
        {"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "我が身を犠牲にして、このままシルバスターの足止めをしろ、ということか。", "NORMAL" ]},
