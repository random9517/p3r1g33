		{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
        {"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "ルナテミスが、逃げようとした俺を睨みつけてくる。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
