		{"command":[ "PLAYVOICE", "007_0403301" ]},		{"command":[ "SETNAME", "ルナルバース" ]},		{"command":[ "SETTEXT", "「んふうううっ！　はむぅっ、んぐんぐっ、ちゅぱっ、じゅるるっ、んちゅう\nうううううっ！！」", "NORMAL" ]},
