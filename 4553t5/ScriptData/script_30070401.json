		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "PLAYVOICE", "007_0403401" ]},		{"command":[ "SETNAME", "ルナルバース" ]},		{"command":[ "SETTEXT", "「んくっ、はぁふぁあっ、余の顔に……んちゅっ。遠慮なくびゅーびゅーと精\n液……んんふぅっ、ああああっ！！」", "NORMAL" ]},
