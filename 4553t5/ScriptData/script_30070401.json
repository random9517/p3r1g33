		{"command":[ "PLAYVOICE", "007_0403410" ]},		{"command":[ "SETNAME", "ルナルバース" ]},		{"command":[ "SETTEXT", "「夏の浜辺と言えば出会いのチャンスが溢れているというのに、無駄打ちする\nしかできないとは……情けないチンポじゃな！　あはははっ」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
