		{"command":[ "PLAYVOICE", "007_0403402" ]},		{"command":[ "SETNAME", "ルナルバース" ]},		{"command":[ "SETTEXT", "「ちゅっ、んぅっ、ヨーグルトみたいに真っ白でドロドロのチンポ汁を、びち\nゃびちゃと……はぁはぁ、んふぅううっ！！」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0403403" ]},		{"command":[ "SETNAME", "ルナルバース" ]},		{"command":[ "SETTEXT", "「くっふふっ、いきなり腰を引いて何をするのかと思えば……余の顔を、そん\nなにも汚したかったのか？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000704_01_14" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0403404" ]},		{"command":[ "SETNAME", "ルナルバース" ]},		{"command":[ "SETTEXT", "「この愛くるしい顔を己の欲望で染め上げたいとは、本当に最低のド変態趣味\nじゃのう」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0403405" ]},		{"command":[ "SETNAME", "ルナルバース" ]},		{"command":[ "SETTEXT", "「はぁはぁ、んぅ、もう顔中にくっさい精液の臭いが染み込んで、取れなくな\nったではないか」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0403406" ]},		{"command":[ "SETNAME", "ルナルバース" ]},		{"command":[ "SETTEXT", "「すぐにでも海に飛び込んで身を清めたいところじゃが……この変態チンポは\nまだ物足りなさそうじゃな？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000704_01_13" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0403407" ]},		{"command":[ "SETNAME", "ルナルバース" ]},		{"command":[ "SETTEXT", "「余の顔をここまで汚しておいて、それでもまだ足りぬとはな……とんだ強欲\nチンポじゃ」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0403408" ]},		{"command":[ "SETNAME", "ルナルバース" ]},		{"command":[ "SETTEXT", "「くっふふっ、呆れられて喜んでおるのか？　余を誘うように、また無様に痙\n攣しおって……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000704_01_14" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0403409" ]},		{"command":[ "SETNAME", "ルナルバース" ]},		{"command":[ "SETTEXT", "「いいじゃろう。そんなに精液の無駄打ちをしたいのなら、もう少し弄んでや\nるとしよう」", "NORMAL" ]},
