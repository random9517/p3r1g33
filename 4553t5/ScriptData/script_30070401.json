		{"command":[ "PLAYVOICE", "007_0403302" ]},		{"command":[ "SETNAME", "ルナルバース" ]},		{"command":[ "SETTEXT", "「くっふふ、またぁ、んぐっ、本当にっ、の、喉の奥へ容赦なくぶちまけおっ\nて……んくんくっ、ちゅっ、ちゅぱっ、ちゅううっ」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0403303" ]},		{"command":[ "SETNAME", "ルナルバース" ]},		{"command":[ "SETTEXT", "「はぁはぁ……余の口の中を、お主のチンポ臭で染め上げて、取れなくするつ\nもりか？　剛胆な男よ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000704_01_11" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0403304" ]},		{"command":[ "SETNAME", "ルナルバース" ]},		{"command":[ "SETTEXT", "「じゅるるるっ、ちゅっ、ほれ……んちゅっ、ストローのように吸ってやる。\n残りの精液もすべて余に捧げてしまえ、ちゅうううっ」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0403305" ]},		{"command":[ "SETNAME", "ルナルバース" ]},		{"command":[ "SETTEXT", "「あははっ、イッたばかりのチンポを刺激されるのは、くすぐったくて耐えが\nたいのか？　腰を浮かせて……無様じゃのう」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000704_01_10" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0403306" ]},		{"command":[ "SETNAME", "ルナルバース" ]},		{"command":[ "SETTEXT", "「じゃが、手は抜かぬぞ。何しろ、お主のチンポはまだまだ萎える気配が見え\nぬではないか」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0403307" ]},		{"command":[ "SETNAME", "ルナルバース" ]},		{"command":[ "SETTEXT", "「無駄に元気だけはある変態チンポめが。萎えてみっともないヘナチンになる\nまで、徹底的にヌキ倒してくれよう」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0403308" ]},		{"command":[ "SETNAME", "ルナルバース" ]},		{"command":[ "SETTEXT", "「せっかくの爽やかな夏の砂浜で、こんなイカ臭いことばかりというのは正直\nどうかと思うが……ちゅっ、んちゅっ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000704_01_11" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0403309" ]},		{"command":[ "SETNAME", "ルナルバース" ]},		{"command":[ "SETTEXT", "「躾の行き届いていない部下がひと夏の過ちを犯しでもすれば、月の女王たる\n余の沽券に関わるからのう」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0403310" ]},		{"command":[ "SETNAME", "ルナルバース" ]},		{"command":[ "SETTEXT", "「日光浴がてら、夕暮れまでとことん遊んでやろうではないか。感謝するのじ\nゃぞ？　あはははははっ！！」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
