{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0050" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「今日もお茶会にお付き合いいただき、ありがとうございます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0104101" ]},
		{"command":[ "SETCHARA", "0", "char_00018601_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「ふふっ、あなた様とのお話は、とても楽しいですわ。あなた様となら……そ\nの……ちょっと下品なお話もできますし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「それで……あなた様は覚えていらっしゃるでしょうか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0104103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「わたくしの、お礼のことを……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0104104" ]},
		{"command":[ "SETCHARA", "0", "char_00018601_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「うふふ、おはようございます。さっそくですが、謝らないといけませんわね\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0104105" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00018601_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「あなた様がなかなか私の下半身に興味を持ってくださらないので、少々強引\nな手段を使わせていただきました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0104106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「具体的には……今日の紅茶に睡眠薬を混ぜたくらいでしょうか？　その場で\n押し倒すのは、優雅ではありませんから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0104107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「あなた様にご奉仕したときから……んっ、ずっと気になっていたんですよ…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0104108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「このオチンポをわたくしのオマンコにぶち込んだら、いったいどんな感じが\nするのだろうかと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0104109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「はい。今、あなた様のオチンポに当たっているのが、わたくしのオマンコで\nすわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0104110" ]},
		{"command":[ "SETIMAGE", "0", "still_00018601_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「先ほどから、あなた様の勃起を感じるように擦りつけて……ンッ、濡らして\nおりましたの……んふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0104111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「あなた様のオチンポ……とっても熱くて……。こうしている間にも、身体が\n疼いて、オマンコから汁が溢れますわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0104112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「そ、それではあなた様のオチンポを、わたくしのオマンコへご案内いたしま\nすね……んふっ、腰、浮かせて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0104113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「んんぅっ！！　ああっ、オチンポが、中に一気に……入ってしまいました…\n…っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0104114" ]},
		{"command":[ "SETIMAGE", "0", "still_00018601_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「はぁっ、ああっ、すごいですわ……！　こんなに……オマンコの中、ギチギ\nチに満たされ……んっ、ああぁ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0104115" ]},
		{"command":[ "SETIMAGE", "0", "still_00018601_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「ふふっ、わたくしが動きますから、あなた様はそのまま寝ていてくださいま\nせ。んんっ、それでは……まいりますね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0104116" ]},
		{"command":[ "SETIMAGE", "0", "still_00018601_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「あぁんっ！　これが……あなた様のオチンポ……！　んっ、んふぅっ、わた\nくしの中……ゴリゴリってして、ますわぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0104117" ]},
		{"command":[ "SETIMAGE", "0", "still_00018601_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「オマンコを隙間なく満たして、ンッ、オチンポの形……血管のふくらみまで\nわかってしまうようです……！　ああっ、あはぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0104118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「オマンコにオチンポをハメるのが、こんなにも気持ちよかったなんて……！\n　あんっ、わたくし知りませんでしたわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「んっ、こんな……ああっ、腰が勝手に動いてしまう快感ぅ……！　んっ、は\nぁっ、ああっ、もっと欲しくなってしまいます……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0104120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、あなた様のことも……ちゃんと気持ちよくしますからね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0104121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「わたくしの初物マンコ……んふっ、少々、キツめかもしれませんが……んっ\n、あぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「こうして、ぐりぐりって腰を振って、オマンコをあなた様のオチンポにひろ\nげてもらって……んっ、はぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0104123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「中で、オチンポが暴れてますわ……！　あんっ、わたくしのイイところを、\nオチンポが抉るぅ……んっ、んんぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0104124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「こうして、動くと……んくぅっ、どんどんオマンコから、はしたない汁が溢\nれてきてしまいますわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「愛液が……んっ、腰を、上下させるたびに、糸をひいて……んっ、ああっ、\nとってもいやらしい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「ああっ、あなた様のオチンポ……とっても悦んでいるようですわね……。ん\nふっ、どんどん硬くなって……んぁあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0104127" ]},
		{"command":[ "SETIMAGE", "0", "still_00018601_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「わたくしの、オマンコの奥まで……んっ、ああっ、オチンポが届いています\nわ……あっ、あぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「もっと、激しく動いてしまいますわね！　んっ、んっ、ああっ、オチンポ、\nあぁんっ！　オマンコいっぱいに感じるよう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0104129" ]},
		{"command":[ "SETIMAGE", "0", "still_00018601_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「んはぁっ、ああっ、ああっ！　いいっ、いいですわ！　オマンコ、ずぼずぼ\nって……んっ、んくっ、気持ちいい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「立派なオチンポに、オマンコめちゃくちゃにされて……ああっ、ああっ、わ\nたくし……イキそうになってます……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「ああっ、あなた様……あなた様も……一緒にイキましょう……？　んふっ、\n我慢なさらなくても、いいですからぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「わたくしのオマンコ……あなた様の精液を浴びながらイキたいと駄々をこね\nておりますわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「ですので、ねっ？　射精っ、あなた様、あなた様……射精して……！　ああ\nっ、だしてぇええぇええっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「ああぁっ！　ああぁぁああぁぁんっ！！　でてるっ！　中に……オマンコに\n注がれるぅううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0104135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018601_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「アツアツの、あなた様の精液ぃ……！　はぁっ、はぁああぁぁっ！　これが\n中出し……ああぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0104136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「わたくし……頭の中が真っ白になってしまいましたわ……。んはぁ……はぁ\n……子宮に精液が当たる衝撃……すごすぎますわぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0104137" ]},
		{"command":[ "SETIMAGE", "0", "still_00018601_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「こんなの……んぅ……わたくし、イケナイことを知ってしまった気分ですわ\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「あなた様……もっと、いたしましょう……？　わたくし、もっとあなた様の\n射精を、オマンコで浴びたいですわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0104139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「ふふ……あなた様に拒否権はありません……。あなた様はこうして……わた\nくしの糸に捕らわれているのですから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0104140" ]},
		{"command":[ "SETIMAGE", "0", "still_00018601_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「あぁんっ！　それにしてもまだ、オチンポが硬いぃ……。そうですわね……\n一度の射精では萎えませんわね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0104201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「まだまだガチガチのオチンポ……。んっ、んふぅ……。わたくしのオマンコ\nで、もっと、射精させて差し上げます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「んんぅっ！　あっ、ああっ、すごいですわ……。オマンコ……さっきよりも\n感度が上がっている、気がしますわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0104203" ]},
		{"command":[ "SETIMAGE", "0", "still_00018601_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「オチンポをさっきより……敏感に感じてしまいます……！　んふぅっ、ああ\nっ、ああっ、もっと感じたい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0104204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「こうで……いかがですかぁ……？　あぁんっ！　腰を、上下に、んっ、あっ\n、動かして……あぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0104205" ]},
		{"command":[ "SETIMAGE", "0", "still_00018601_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「オチンポこすれて、気持ちよくなってしまいますわ……！　んふっ、はっ、\nはっ、あぁんっ！　いいっ、いいぃ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0104206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「ああっ、だめ……気持ちよすぎて、腰が抜けてしまいますわ……！　あなた\n様のオチンポ、とっても立派で……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「あひゃぁっ！？　なっ、あなた様、腰を動かして……んぁあっ！　そんな、\n下から……んっ、あぁあんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0104208" ]},
		{"command":[ "SETIMAGE", "0", "still_00018601_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「あなた様からも動かれると、んっ、ああっ、オチンポが、より深いところに\n刺さって……あはぁああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「子宮を持ち上げられていますわっ！　こ、これ……あっ、あっ、やべぇ、や\nべぇですわこんな……んぉおおおっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0104210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「んぁっ、こ、これは違いますの！　わたくしはそんな下品なキャラじゃ……\nおっ、おおぉっ！　くほぉおおっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0104211" ]},
		{"command":[ "SETIMAGE", "0", "still_00018601_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「チンポっ、チンポぶっ刺さってますわっ！　マンコの奥にぃいいっ！　んひ\nぃいいっ！　効くっ！　スケベマンコにチンポ効くぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0104212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「ああっ、ああっ、チンポにっ、んひぃっ、子宮揺さぶられまくって！　あっ\n、あひっ、マン汁っ、ドバドバって……あっ、ああぁっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0104213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「気持ちよすぎて、わたくしの腰も止まんねぇですわぁっ！　おっ、おおっ、\nチンポいいのぉっ！　あなた様のチンポよすぎぃっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0104214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「じゅっぼん！　じゅっぼんって！　あなた様のデカチンにマンコほじられて\nぇ！　デカ乳、下品に揺らしくっちまいますのぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0104215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「んぉおっ、おおっ、イグッ、イグッ！　もうマンコがイキそう……イキそう\nですの……おっ、おおぉおお……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0104216" ]},
		{"command":[ "SETIMAGE", "0", "still_00018601_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「ああっ、あなた様も……んくっ、イキそうなら、ど、どうぞ……精液、だし\nて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0104217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「わたくしに、好きなだけぇ……！　あなた様の精液っ、どぴゅどぴゅって、\n放ってくださいませぇえええっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0104218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「んぉおっ、おっ、おおぉおっ！　わたくしももう限界ぃ……優雅にふるまう\nのも……イクの、我慢するのも……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0104219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「全部……あなた様の精液で……押し流されてしまいますわぁあああぁぁぁっ\n！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0104220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「んひぃいいいぃぃぃっ！！　イッ、イクッ、イッぐぅうううぅぅぅ～～～～\nっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0104301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018601_02_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「オマンコにっ、んぁあっ、熱いのっ、精液のクソ熱い塊がぁあああっ！！　\n子宮にどびゅどびゅ撃ち込まれてますのぉおおっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「ああっ、ああっ、イクのとまんねぇ……ですわぁ……。んぐぅ……ふぅ……\nああぁ……中出し……気持ちいい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0104303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「まだ……でてるぅ……。あなた様のオチンポ、ビクビクして……ンッ、射精\n……長すぎですわぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0104304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「ああ……わたくしのオマンコも……ンッ、あなた様から精液搾ろうと……動\nいて、しまってますわぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0104305" ]},
		{"command":[ "SETIMAGE", "0", "still_00018601_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「ああ……子宮が、ごくごく精液飲んでますのぉ……。んふぅ……あなた様の\n熱い精液で……子宮が、いっぱいぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0104306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「んふぅ……あぁ……はぁ……。えっと……その……。あなた様には、見苦し\nいところをお見せしてしまいましたわね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0104307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「あまりに気持ちよすぎて、優雅ではない部分がでてしまいまして……。うっ\n、こっちが素じゃねぇですわよ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0104308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「まったく……。ですが、こんなところを見せてしまった以上、あなた様には\nこの秘密を墓場までもっていってもらいますわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「怯えないでください。命は奪いませんわ。……ところで、人間は『結婚は人\n生の墓場』というそうですわね。ふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「んぉっ、おおっ、チンポ抜け……っ！？　あんっ、あっ、ああ……精液……\nンッ、かかる……あっ、ああぁぁんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0104401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018601_02_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「ああ……なんて勢い……っ！　あなた様のドロドロ精液が、わたくしの身体\nを汚して……っ、んっ、ああっ、もうこれだけでイク……ッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0104402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……っ！　ぶっかけられて……あなた様のオスの臭気に包まれ\nて……んっ、イクッ、イッ……くぅ……っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0104403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「んんんぅうううぅぅっ！！　これだけでイッてしまうなんて……オマンコだ\nけでなく肌まで敏感になったようですわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0104404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「あなた様のオチンポ……とっても気持ちよくて……。んふふ、これ……もう\n手放したくありませんわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0104405" ]},
		{"command":[ "SETIMAGE", "0", "still_00018601_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「これまで優雅に、お上品にふるまっていましたが……オチンポを前にしたら\nやっぱり素がでてしまいますわね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0104406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「ですが、わたくしがこんなに乱れたのは、あなた様のオチンポがあまりに気\n持ちよかったからですので」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0104407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「まあ……あなた様のオチンポしか受け入れたことはありませんが。はじめて\nでこんなに気持ちいいオチンポとめぐり合うなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0104408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「やはり、わたくしとあなた様は運命の赤い蜘蛛糸で結ばれていたんですわね\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0104409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「そんなことないって？　それでは、これから、わたくしがあなた様と繋がる\n糸を紡いでいきますわっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0104410" ]},
