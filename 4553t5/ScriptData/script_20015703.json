{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0186" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_005" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「……と、カツマがバカ姉の心をゲットしたところで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_010023720001" ]},
		{"command":[ "SETCHARA", "0", "char_00028701_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「ゲ、ゲットされておりませんわよぉ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_010023720001" ]},
		{"command":[ "SETCHARA", "0", "char_00028501_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「次はバカ姉２こと、ティシポ姉について考えてもらっていいかな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_010023720002" ]},
		{"command":[ "SETCHARA", "0", "char_00028701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おう。やれるだけやってみるぞ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「うっし！　んじゃ、気合入れて自己紹介させてもらうとすっかな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_010023720001" ]},
		{"command":[ "SETCHARA", "0", "char_00028601_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "ティシポネーは１歩前に出ると、腰に手を当てて俺をジロジロと見回した。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「……あたしは、軟弱そうなてめぇや他の姉妹とは一味違うぜ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_010023720002" ]},
		{"command":[ "SETCHARA", "0", "char_00028601_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おおおお……。すごい自信だな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「あたしは姉妹の中では単純に武力要員っつうか……。冥府に漂う死者の魂を\n罰する役割を持った女神だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_010023720003" ]},
		{"command":[ "SETCHARA", "0", "char_00028601_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「まあ、見た目も怖ぇし、周囲からはビビられてるかな。とにかく腕っぷしの\n強ぇオンナだと思ってもらえりゃ間違いないねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_010023720004" ]},
		{"command":[ "SETCHARA", "0", "char_00028601_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「へーえ。ってことは、３姉妹の特攻隊長ってことだな。で、ティシポネーは\nどの部門を狙ってるんだ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「あぁ？　見たらすぐわかんだろ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_010023720005" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……わからん。教えてくれ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「はーぁ……。あたしは『姉にしたいキャラ部門』と『妹にしたいキャラ部門\n』を狙ってる。てかそれしかありえねーだろ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_010023720006" ]},
		{"command":[ "SETCHARA", "0", "char_00028601_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「姉はともかく……。妹……っぽくはないかもしれない……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「はぁあ！？　あたしは確かにメガイラの姉だけどよ、アレクト姉の妹なのは\nガチだぜ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_010023720007" ]},
		{"command":[ "SETCHARA", "0", "char_00028601_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「ええ、そうです。過激に見えて、ティシポネーには可愛らしいところもたく\nさんたくさんあるのですよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_010023720002" ]},
		{"command":[ "SETCHARA", "0", "char_00028501_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「……結構ガキだし。コドモだし。単純だし、妹要素多いと思う……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_010023720003" ]},
		{"command":[ "SETCHARA", "0", "char_00028701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……そうかもしれないが、パッと見で求められる『妹感』とは違う気がする\nんだよな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「まあ……あたしは３姉妹の中で、１番タッパが……。身長がデカいってのは\nあるけどな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_010023720008" ]},
		{"command":[ "SETCHARA", "0", "char_00028601_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「んでもよ！　それを補って余りあるほどのスッゲー妹感ってやつが出せるハ\nズなんだよ！　信じてくれ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_010023720009" ]},
		{"command":[ "SETCHARA", "0", "char_00028601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「そうだ！　試しにあたしにオススメの妹感とかねぇか！？　すぐにやってみ\nせてやるぜ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_010023720010" ]},
		{"command":[ "SETCHARA", "0", "char_00028601_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「オススメ……？　オススメの妹感……って、たとえば何……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_010023720004" ]},
		{"command":[ "SETCHARA", "0", "char_00028701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「一般的には幼さとか、あどけなさとか、甘えん坊感とかか……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「はいはいはいはい。ソッチ系な。……ったく……マジで特別だかんな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_010023720011" ]},
		{"command":[ "SETCHARA", "0", "char_00028601_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「えぇっ？　何をするつもりなのですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_010023720003" ]},
		{"command":[ "SETCHARA", "0", "char_00028501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「目ぇかっぽじってよーく見てろよ！　可愛いあたしをなァ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_010023720012" ]},
		{"command":[ "SETCHARA", "0", "char_00028601_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "PLAYBGM", "BGM_023" ]},
		{"command":[ "SETTEXT", "「うきゅ～☆　おにいちゃん、ティシポネーのお名前は～、ティシポネーって\nいうの～。かわいい～？　かわいい～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_010023720013" ]},
		{"command":[ "SETCHARA", "0", "char_00028601_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「おにいちゃんにだったらぁ、と・く・べ・つに頭……なでなでさせてあげて\nもいーよ♪　んっ、あぁん♪　くすぐったぁい～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_010023720014" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「……ぷっ……、くくく……、ぷくくくく……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_010023720005" ]},
		{"command":[ "SETCHARA", "0", "char_00028701_01", "5", "CENTER", "400" ]},
		{"command":[ "SETCHARA", "1", "char_00028501_01", "5", "CENTER", "-400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "1" ]},
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「ふふっ、うふふふっ……笑っちゃいけませんわ、絶対に笑ってはいけません\nわ……！　ふふふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_010023720004" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA","2", "3" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「だ……駄目だ、まだ笑うな……！　こらえるんだ……っ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「おにいちゃんと一緒にいるとぉ～、胸がポカポカして……内臓がキュンキュ\nンしてきちゃうんだぁ♪　これが恋なのぉ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_010023720015" ]},
		{"command":[ "SETCHARA", "0", "char_00028601_01", "2", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「ティーちゃん、おにいちゃんのこと、だいだいのだ～いすき☆　だいちゅき\nだいちゅき☆　大きくなったらお嫁さんになりゅ～☆」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_010023720016" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「ぷっ……。う、うん……っ。い、い、い、いいんじゃない、かな……？　あ\nはっ、あははっ、あははは……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_010023720006" ]},
		{"command":[ "SETCHARA", "0", "char_00028701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「だ、だめよ……笑ったりしては。真剣に妹キャラを極めようと努力している\nのに……。ふふ、ふふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_010023720005" ]},
		{"command":[ "SETCHARA", "0", "char_00028501_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「めちゃくちゃ笑ってんじゃねえか……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "PLAYBGM", "BGM_005" ]},
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「……ってカンジなんだが、どうだ？　改善点とかあっか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_010023720017" ]},
		{"command":[ "SETCHARA", "0", "char_00028601_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「も、もう少し……ポーズを変えてみたらどうかしら。おててを丸めて、子猫\nのように……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_010023720006" ]},
		{"command":[ "SETCHARA", "0", "char_00028501_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「にゃぁ～ん☆　おおっ、こういうカンジかよ！？　確かにあどけねぇな！！\n　ポイント高いぜぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_010023720018" ]},
		{"command":[ "SETCHARA", "0", "char_00028601_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「……小首をかしげて目をうるうるさせてみて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_010023720007" ]},
		{"command":[ "SETCHARA", "0", "char_00028701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「はっ！　容易い御用だっつうんだよ！　まかせやがれ！　こうかよ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_010023720019" ]},
		{"command":[ "SETCHARA", "0", "char_00028601_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「うきゅぅ～ん……☆　夜は１人で眠れないにゃぁん☆　おにいちゃんがいて\nくれないとヤダヤダにゃぁん☆」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_010023720020" ]},
		{"command":[ "SETCHARA", "0", "char_00028601_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「キツい！　却下！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「あぁん！？　なんだとてめぇゴラァ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_010023720021" ]},
		{"command":[ "SETCHARA", "0", "char_00028601_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ティシポネーには妹キャラは向いていないことがわかった。だが、やる気と\n前向きさは伝わったぞ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「…………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_010023720022" ]},
		{"command":[ "SETCHARA", "0", "char_00028601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「……あ、あたしの……妹キャラは見るに耐えねえくれぇ恥ずかしい出来だっ\nたってのかよ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_010023720023" ]},
		{"command":[ "SETCHARA", "0", "char_00028601_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「い、いえいえいえっ！？　そ、そんなことは！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_010023720007" ]},
		{"command":[ "SETCHARA", "0", "char_00028501_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「……うん。まあそうかも」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_010023720008" ]},
		{"command":[ "SETCHARA", "0", "char_00028701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「メ、メガイラっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_010023720008" ]},
		{"command":[ "SETCHARA", "0", "char_00028501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「や、やばい！　キレたか！？　それとも泣かせたか！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "沈黙し、うつむいたティシポネーに戦慄する俺たち３人。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETCHARA", "0", "char_00028601_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "しかし、次の瞬間……ティポシネーは急にもじもじしはじめ、顔を真っ赤にし\nながら悶えだした。", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00028601_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「恥ずかしい……っ。恥ずかしいあたし！　でも感じちゃうぅうう♪　……ビ\nクンビクン！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_010023720024" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うわっ、くねくねしてなんだ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「恥ずかしいあたしをもっと見て！　も、もうダメだぁ……イ、イッちまうぅ\nうう～っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_010023720025" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「こ、これはいけません！　こんな姿を皆様方に見られてしまったら！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_010023720009" ]},
		{"command":[ "SETCHARA", "0", "char_00028501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「人気投票にさしさわる……！　おしまい、この話はおしまい……！」", "NORMAL" ]},
