{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010007_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ、くっ……！　この恰好で出歩いていたせいか、すっかり身体が\n火照ってしまったな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0704101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「この疼きを鎮めるために、おまえがなにをしないといけないか……言わずと\nもわかるだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0704102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふふっ……ペニスがかなり勃起しているな。準備万端というわけか……では\n、私のアナルに挿れさせてやろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0704103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ただし、挿れる前にしっかりとローションで尻の穴をほぐしてもらうぞ。そ\nこにあるサンオイルを私にかけてくれ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0704104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ああ、そうだ……好きなだけかけるといい。ヌルヌルした方が、おまえも動\nきやすいだろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0704105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あっ……んんっ……！　ふっ、んふっ……！　冷たい感触が尻いっぱいに広\nがってくるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0704106" ]},
		{"command":[ "SETIMAGE", "0", "still_00010007_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「その調子で、もっとオイルを垂らしていくといい……！　尻の周りだけでな\nく、奥の方にも入るくらいたっぷりかけていけ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0704107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ひぐっ、あっ、ふぐっ……！　あっ、あっ……！　尻の奥までしっかりとオ\nイルが入ってくるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0704108" ]},
		{"command":[ "SETIMAGE", "0", "still_00010007_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「肛門がトロトロになって……んんっ！　腸の奥がヌルヌルのぐちゅぐちゅに\nなってきているぞ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0704109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、あっ……ああっ……！　そろそろ、いいだろう……！　この\n火照った敏感アナルに、おまえの太いペニスを突き刺して来い……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0704110" ]},
		{"command":[ "SETIMAGE", "0", "still_00010007_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あはああぁ……！　はっ、入ってくるぅ……！　熱い肉の塊が、私の肛門を\n広げながら……おっ、奥まで……んひっ、おっ、おほおぉぉぉ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0704111" ]},
		{"command":[ "SETIMAGE", "0", "still_00010007_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「この尻の穴がめくれる感触……！　亀頭で無理やりヒダを擦られ、えぐられ\nる感じ……たまらないっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0704112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「はぁ、んんっ、くっ、あはぁ……！　どうした……遠慮しないで、もっと奥\nまで突き入れていいんだぞ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0704113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んふっ、くっ……わ、私のアナルがキツすぎて、奥まで入らない……？　も\nっと尻穴を緩めて欲しいだと……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0704114" ]},
		{"command":[ "SETIMAGE", "0", "still_00010007_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「まったく……わかってないヤツだな……！　このギチギチの尻穴を無理やり\nホジられるのがいいんじゃないか……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0704115" ]},
		{"command":[ "SETIMAGE", "0", "still_00010007_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「わかったら、もっと全身に力を込めて腰を突き入れろ……！　私をレイプす\nるみたいに、思いっきり犯すんだ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0704116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「おっ、おおおおおぉぉぉ！？　おほおおおぉぉぉぉんっ！？　そ、そうだっ\n！　いいぞっ！　その突き入れ、最高だっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0704117" ]},
		{"command":[ "SETIMAGE", "0", "still_00010007_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「もっと奥まで……！　ペニスの根本が肛門に当たるくらい、激しく挿入する\nんだ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0704118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「くっ……あっ、あはあぁ……！　ふふっ……キツキツのアナルに、ずっぷり\nとペニスが入ったようだな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0704119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「だが、本番はここからだ……！　肛門の締め付けに負けないように、しっか\nりと腰を振るんだぞ……！　手を抜いたら、バツを与えるからな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0704120" ]},
		{"command":[ "SETIMAGE", "0", "still_00010007_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あっ！　あっ！　んふっ、おっ、んおぉぉぉ！？　ペニスがズリズリ動いて\n、肛門をめくってくるぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0704121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あああっ！　いい速度だっ！　肛門の肉が外にハミ出てしまいそうなくらい\n、しっかりとえぐられているぞっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0704122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ペニスの先端が腸の奥まで届いているし、カリもヒダを撫でまわしているっ\n！　この快感が欲しかったんだっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0704123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んひっ！？　がっ、うぐっ、あはぁぁぁ！　オイルのおかげでかなり滑りも\nよくて……！　ああっ！　自然とエッチな汁が溢れてくるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0704124" ]},
		{"command":[ "SETIMAGE", "0", "still_00010007_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「はぁ、んっ！　あっ、あっ！　ひっ、んひぃ！？　尻の奥でペニスがビクビ\nク跳ねながら、我慢汁をまき散らしているのを感じるぞっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0704125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「そのまま子宮の裏側を突いてくれ……！　ペニスをえぐり込みながら、私の\n大事なところをメチャクチャに犯すんだ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0704126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「おほっ、おほぉぉぉぉぉ！？　いいっ、いいぞっ！　腸越しにペニスが子宮\nに当たって……んっ、あっ！　あっ！　あああぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0704127" ]},
		{"command":[ "SETIMAGE", "0", "still_00010007_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「容赦なく子宮を責められ、犯されるの気持ちいいっ！　本当にレイプされて\nいるみたいで、アソコが疼いてくるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0704128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「こんなの我慢できるわけがないっ！　私も動かさせてもらうぞっ！　しっか\nりとペニスを勃起させながら、タイミングを合わせて腰を振れっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0704129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あっ！　んっ！　ひっ、あっ！　おっ、んおおおぉっ！？　おまえの身体と\n私の尻がぶつかりあって、パンパンと卑猥な音がするぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0704130" ]},
		{"command":[ "SETIMAGE", "0", "still_00010007_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「肛門の疼きとアソコの疼きが重なって……！　ひっ、あっ、あひぃ！？　感\nじすぎて、イッてしまうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0704131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「はぁ、んっ、あっ！　わ、私がイクとき、おまえも一緒にイクんだぞっ！　\n勝手に射精したら、お仕置きだからなっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0704132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「わかったら最後まで腰を振り続けろっ！　私の尻の中で射精して、子宮の裏\n側から種付けしろぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0704133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「うぐっ、がっ、んんっ！　おっ、ああぁ！　イクッ！　イクッ！　すごいの\nが来ているっ！　アソコの奥から、気持ちいのがきて……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0704134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あああぁぁぁっ～～～～！　イックうううぅぅぅぅぅ～～～～～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0704135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「おっほおおおぉぉぉぉぉっ！？　で、出ているっ！　オイルに負けないくら\nい、ヌルヌルの濃厚ザーメンが尻の中に出されているぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0704136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010007_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「びちゃびちゃと卑猥な音を立てながら、腸内に広がって……！　あああっ！\n　熱いっ！　ケツ穴熱いぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0704137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「こんなに熱いのをびゅーびゅー出されたら、肛門が火傷してしまいそうだっ\n！　だが、この熱と感触がたまらなく気持ちいいぞっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0704138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あんんっ！　あっ、はっ、あはぁ！　もっと出せっ！　おまえのありったけ\nの精子を、私のアナルに注ぎ込めっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0704139" ]},
		{"command":[ "SETIMAGE", "0", "still_00010007_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「最後までしっかりと射精して、私を感じさせ続けろっ！　んっ、くっ！　あ\nっ！　あああああぁぁぁんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0704140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「くっ、あぐっ……んんっ……！　ふふっ……どうやらたっぷりと出したよう\nだな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0704201" ]},
		{"command":[ "SETIMAGE", "0", "still_00010007_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「尻の中がおまえの精液とオイルでベトベトだ……それに勢いがありすぎたせ\nいか、肛門の隙間から溢れ出してきているぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0704202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んっ……こんなにこぼすと、もったいないな……肛門を締めるから、ペニス\nに力を入れておけよ……ふっ、ぐっ……んんんんんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0704203" ]},
		{"command":[ "SETIMAGE", "0", "still_00010007_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「はぁ、おっ、んぐっ……！　肛門を締めれば締めるほど、ペニスが大きくな\nってきているぞ……まだシたいというのか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0704204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふふっ……さっきので精子を搾りきったと思ったが、まだ出せるようだな…\n…ならもう１回、楽しませてもらうとするか……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0704205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「おっ、おっ！　んふっ、くううぅ！　射精したばかりなせいか、精子とオイ\nルが混ざって、かなり滑りがいいな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0704206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「肛門のめくれ具合も強くなって……！　あはぁ！　いいぞっ！　もっとカリ\n首でヒダと肛門をズリズリしろっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0704207" ]},
		{"command":[ "SETIMAGE", "0", "still_00010007_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「その段になっている部分で尻の中を引っかかれると……！　あっ！　んっ！\n　自然と身体が反応して、震えてくるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0704208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ケツ穴だけでなく、アソコも疼いて……！　ああんっ！　エッチな汁が止ま\nらないっ……！　腸の中からも、汁が溢れまくってくるぞっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0704209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「はぁ、んっ！　あぐっ、んひぃ！？　さっきみたいに、奥を突くといいっ！\n　精液まみれになった子宮の裏側を、思い切り刺激してくれっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0704210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あああぁぁぁっ！　そうだっ！　アナルを無理やり広げながら、子宮を押し\nつぶせっ！　腸内がペニスの形になるくらい、激しく擦るんだっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0704211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ひっ、んふっ！　がっ、あっ！　おっ、おほぉっ！？　その円を描くような\n動きは、かなりいいぞっ！　腸全体に亀頭が当たってくるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0704212" ]},
		{"command":[ "SETIMAGE", "0", "still_00010007_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「もっと尻の奥をかき回して、精液を塗りたくれっ！　臭いが取れなくなるく\nらい、私の体内に精液を染み込ませろっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0704213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あっあっあっ！　ひっ、んふっ、あはぁぁぁ！　気持ちよすぎて、声が止ま\nらないっ！　こんなに大声で喘いだら、誰かに聞かれてしまいそうだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0704214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「こんな場所でアナルセックスをしていると知られたら……！　ああぁ！　そ\nれはそれで、凄く興奮するっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0704215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「おおおおおぉぉぉ……！？　ペニスがさらに大きくなって……！？　お、お\nまえも人に見られていることを想像して、興奮しているんだなっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0704216" ]},
		{"command":[ "SETIMAGE", "0", "still_00010007_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ならこのまま、イクところも見てもらうとしようっ！　本当に人が寄ってく\nるくらいの声でイキまくり、喘ぐ姿を見せつけてやるんだっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0704217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ほらっ！　イケッ！　イケッ！　こんな場所でアナルセックスに興じるドス\nケベなヤツだということを、周りの奴らに見せつけてやれっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0704218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んっ、おっほおおおぉぉぉっ！？　ペニスがビクビク動いているっ！　来る\nっ！　射精くるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0704219" ]},
		{"command":[ "SETIMAGE", "0", "still_00010007_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あああっ！　あっ、あっ！　イクッ！　イクぅぅぅんっ！　ビーチでアナル\nセックスする変態だと思われながら……イッ、イクぅぅぅぅぅっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0704220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あはあああぁぁぁっ！　出てるっ！　また尻の奥にびゅーびゅー精子出され\nているぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0704301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010007_02_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「気持ちいいっ！　人に見られながらイッてると思うと、さっきよりも感じて\nしまうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0704302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んっ、はっ、あはぁ！　イクの止まらないっ！　気持ちいいの、ずっと子宮\nから来て……んんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0704303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「もっと出せっ！　もっとイかせろっ！　ケツ穴に種付けされて悦ぶ姿を、ギ\nャラリーどもに見せつけてやろうぞっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0704304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ひっ、うぐっ！　あっ、んはぁ！　イクッ！　またイクッ！　くっ、あっ…\n…イクうううぅぅぅっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0704305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、あっ、ふううぅ……これだけ大きな声で喘げば、絶対に感づ\nくヤツも居ただろうな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0704306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふふっ……どうした？　射精し終えて冷静になったせいで、急に恥ずかしく\nなってきたのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0704307" ]},
		{"command":[ "SETIMAGE", "0", "still_00010007_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「そんなに恥ずかしがらなくても、おまえはもう立派な変態だ……無論、私も\nな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0704308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふふっ……おまえがどんなに白い目で見られても、私だけはおまえを見捨て\nないから安心しろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0704309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「なぜなら、おまえは私のモノだからな……私だけはおまえの味方だ……光栄\nに思うがいい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0704310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んひいぃぃぃんっ！？　ケツ穴が一気にめくれてっ……！？　あっ！　抜け\nるっ！　ペニスが引き抜かれるぅ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0704401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010007_02_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あはあぁぁんっ！　精子が尻にびゅるびゅるかけられているぅ！　こんなに\n熱いのをかけられたら、日焼けどころじゃなくなってしまうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0704402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んんっ、くっ、ああっ！　いっぱいかけられているっ！　私の尻が真っ白に\nなって……臭いも染みついてしまうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0704403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ひぐっ、あひっ、んひぃ！　ぶっかけられただけでイクッ！　精子浴びなが\nらイクなんて……ああああぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0704404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「イクッ！　イクッ！　あっ、あっ！　来るっ！　イッてるのに、また凄いの\nが来て……イックぅぅぅぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0704405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んっ……ふっ、くうぅ……こんなに開放的な気分でイッたのは、初めてかも\nしれないな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0704406" ]},
		{"command":[ "SETIMAGE", "0", "still_00010007_02_16" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「やはり野外でセックスするのはいい……次はもっと人の居るところ……それ\nこそ、街中でするのも一興だな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0704407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「……さすがに街中でヤると捕まるだと？　ふふっ……そんな心配はしなくて\nいいぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0704408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「私たちの邪魔をするヤツらは全員始末すればいい……そうだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0704409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aニャンコ先生" ]},
		{"command":[ "SETTEXT", "「……本当に邪魔者を始末したら、誰にも見てもらえなくなりそう？　ふむ…\n…確かにそうだな。ならば街中ではなく、もっと別の場所でするとしよう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0704410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}