{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017801_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「はぁ、んっ……！　あっ、ああぁ……！　こんなに荒々しく絡んでくるなん\nて……本当にしょうがない子たちね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0104101" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「こんなことしなくても、私は逃げたりしないのに……それとも、拘束するの\nは触手の本能なのかしら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「あんんっ……！　おっぱいが搾り上げられて……んっ、あっ……！　それ、\nダメっ……！　乳首、感じちゃうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0104103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「このヌルヌルの感触で敏感なところを責められたら……クリトリスが勃起し\nちゃうわっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0104104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「それにアソコからもエッチな汁が出てきて……あっ、あぐっ……！　子宮が\n切なくなってきちゃうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0104105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「あああぁんっ！　触手たちも私を犯したくてたまらないみたい……！　アソ\nコの奥まで入り込んで、膣内をズポズポしたいのね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0104106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「ふふっ……触手たちに責められて、ぐちょぐちょに犯される自分を想像する\nだけで……あっ、んあっ……！　アソコが疼いてくるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0104107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「エッチな蜜がどんどん溢れてきてるっ……！　私のアソコ、触手の粘液みた\nいにヌルヌルになってきてるわっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0104108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「ほら……遠慮せずに、奥まで突き入れなさい……私のアソコをメチャクチャ\nにしていいのは、貴方たちだけなんだから……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0104109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「んっ、くっ……！　いいわよ……そのままそのぶっとい触手を、アソコに突\nっ込んでっ……！　私のエッチな穴を、いっぱい感じさせてっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0104110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「あはあああぁ……！　しょ、触手が入ってくるぅ……！　ズリズリされなが\nら、奥まで押し込まれてるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0104111" ]},
		{"command":[ "SETIMAGE", "0", "still_00017801_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「あっ、ぐっ、あふっ……！　こんなに太い触手なのに、ぐっぽり咥え込んで\n……！　あっ、あっ！　もっと、奥まで突っ込んでぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0104112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「おほおぉ……！？　子宮口のところにまで触手の先端が届いてるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0104113" ]},
		{"command":[ "SETIMAGE", "0", "still_00017801_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、あっ、あはあぁ……！　どうしたの……？　奥に挿れただけ\nで満足しちゃったのかしら……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0104114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「ふふっ……そんなはずないわよね……だって貴方たちは触手なんだもの……\n女である私を犯したくて、たまらないんでしょう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0104115" ]},
		{"command":[ "SETIMAGE", "0", "still_00017801_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「身体の膣内も膣外もメチャクチャにして……自分だけのモノにしたい……そ\nう考えてるんでしょ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0104116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「だったら、遠慮なんてすることないわ……貴方たち触手が持つ本能のままに\n、私を犯しなさいっ……！　いっぱい、ヨガらせて頂戴っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0104117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「あああぁぁぁんっ！　触手がアソコに出入りしてるぅ！　じゅぽじゅぽって\nエッチな音させながら、動きまわってくるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0104118" ]},
		{"command":[ "SETIMAGE", "0", "still_00017801_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「アソコの奥だけじゃなくて、Ｇスポットにも這いずってきて……！　んんっ\n！　私の弱点、全部知られてるのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ！　それ、ダメっ！　Ｇスポットを押しながら粘液と一緒にズリ\nズリするの、感じすぎちゃうからぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0104120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「んひっ、あっ、ぐっ！　ひあぁ、ああああぁ！　こんなの、勝手に腰が動い\nちゃうっ！　犯されてるのに、身体が触手を求めちゃうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0104121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「あっ、んっ、あっ！　おっぱいの触手たちももっと激しく這いずってきて…\n…！　ひぎっ！　あっ、ああぁ！　乳首クリクリされるの、好きぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「アソコをズポズポ責められながら、おっぱいを搾られるなんて……！　こん\nな快感、貴方たちじゃないと味わえないわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0104123" ]},
		{"command":[ "SETIMAGE", "0", "still_00017801_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「ふぐっ、あふっ、んんんっ！　あっ、あっ！　犯されてるのに、身体が悦ん\nで……！　勝手にアソコが絞まっちゃうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0104124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「おっ、おっ……！？　おおおぉぉぉ……！？　アソコに入ってる触手が、締\nまりに合わせて膨らんでるぅ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「ただでさえ太いのに……また大きくなるのっ……！？　あっ、ひぎっ……！\n？　あ、アソコがどんどん触手の形に拡がってっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「んひいいいぃぃぃんっ！？　極太触手でアソコズリズリされてるぅ！　こん\nなの、お腹の中が引っ張りだされちゃうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0104127" ]},
		{"command":[ "SETIMAGE", "0", "still_00017801_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「あっ、ああっ！　んひっ、あひぃ！？　子宮口に触手の先端があたって、子\n宮がズンズンって響いてるのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「そんなに激しくされたら、子宮口が開いちゃうわっ！　私の赤ちゃんの部屋\n、触手汁まみれにされちゃうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「ああっ！　でも、それってすごく素敵だわっ！　触手たちに犯されるだけじ\nゃなくて、触手汁で孕んで、お母さんになれるだなんてぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0104130" ]},
		{"command":[ "SETIMAGE", "0", "still_00017801_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「貴方たち触手が私の子供であり、夫になるだなんて……！　そんなの幸せす\nぎて……んんっ！　あっ、あっ！　想像だけでイクぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「んぎっ、あっ、んふうぅ！？　触手がアソコの奥でブルブル震えてるわっ…\n…！　貴方たちもイキそうなのね……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「いいわよっ……！　このまま思いっきり、膣内に触手汁を注いで頂戴っ！　\n子宮の中を貴方たちの色で染め上げてっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「貴方がイクのに合わせて、私もイクからっ……！　あっあっ！　来るっ！　\n触手汁すぐそこまできて……！　あああああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「イッ、イクッ！　イクッ！　イクぅぅぅ！　触手に犯されながら、イックう\nううぅぅぅぅぅ～～～～～んっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0104135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017801_02_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「おほおおおぉぉぉ！？　きっ、きたぁ！　触手汁、膣内にびゅるびゅる出て\nるの感じるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0104136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「こんなに気持ちいいの味わわされたら、私も出ちゃうっ！　あっ、あっ！　\n潮吹きしちゃうううぅぅぅ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0104137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「あはあああぁぁぁ！　触手汁で孕まされながら潮吹きするの、たまらないわ\nっ！　何回だってイケちゃいそうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「ひぐっ、あっあっ！　ま、またイクッ！　潮吹きしてるのに、また新しい潮\nがアソコから出ちゃうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0104139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「んんんっ！　あっ、イクッ！　イクッ！　イッ……あっはあああぁあぁぁぁ\nぁぁんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、んふうぅ……さすがは私の可愛い触手たちね……こんなに激\nしくイカされるなんて、思ってもみなかったわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0104201" ]},
		{"command":[ "SETIMAGE", "0", "still_00017801_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「んっ……あふっ……子宮の奥まで、触手汁でいっぱいよ……こんなに出され\nたら、妊娠確定ね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「あぁあんっ……！　また触手たちがズルズル這いずってるっ……！　私を孕\nませたことが嬉しいのかしら……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「ふふっ……でも、１回孕ませただけで満足なの……？　もっと私を犯したい\nんじゃないの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0104204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「ああっ……！　アソコに入ってる触手が、また動き出してるっ……！　いい\nわよっ……！　貴方たちが満足するまで、付き合ってあげるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0104205" ]},
		{"command":[ "SETIMAGE", "0", "still_00017801_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「あっ！　ひぎっ！？　おっ、おおおぉぉぉ！？　いきなり激しすぎっ……！\n　あはああぁんっ！　容赦ないピストンだわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0104206" ]},
		{"command":[ "SETIMAGE", "0", "still_00017801_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「アソコの一番奥から入り口の手前まで、一気に触手が引っ掻いてきて……！\n　あんんっ！　このズリズリされる感覚、大好きなのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「おっ、あっ、んふうぅ！？　おっぱいもさっきより強く搾り上げられてるっ\n……！　触手が思い切り食い込んできて……ああぁ！　気持ちいいぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「もっと乳首弄りながら、触手ズポズポしてぇ！　ぶっとい触手で、アソコを\nグチャグチャにしてぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「んひいいいぃぃぃ！？　おっ、おほおぉ……！？　今、杭を打つみたいに、\nいきなりズンって奥まで触手が届いて……！　あっ、あああぁ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0104210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「い、今のもう１回してっ！　私の子宮口を突き破るくらいの勢いで、触手を\n叩きつけてぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0104211" ]},
		{"command":[ "SETIMAGE", "0", "still_00017801_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「んひっ！？　あっ！　あっ！　あああああぁ！？　触手たちの容赦ない感じ\n、本当にたまらないわっ！　こんなの、またすぐにイッちゃうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0104212" ]},
		{"command":[ "SETIMAGE", "0", "still_00017801_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「もっと触手たちに犯されたいのに、身体がイキたがって……！　気持ちいい\nの、子宮からどんどん降りてきてるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0104213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ！　触手たちもまたブルブルって激しくうごめいて……！　あ、\n貴方たちもイキそうなの……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0104214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「んふっ、おっ、おほぉ！？　触手汁をびゅるびゅる出したいって気持ちが、\n触手全体から伝わってくるわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0104215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「いいわよっ、また好きに出しなさいっ！　貴方たちの欲望は、全部私が受け\n止めてあげるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0104216" ]},
		{"command":[ "SETIMAGE", "0", "still_00017801_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「どれだけ汚されても構わないし、触手の赤ちゃんだって悦んで産んであげる\nわっ！　だから遠慮しないで好きに動いて、触手汁出してぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0104217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「あはああぁ！　私ももうイクからぁ！　んっ、あっ！　あっ、ひぎっ、ああ\nああぁ！　くっ、来るっ！　アソコの奥から、またすごいのくるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0104218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ！　イッてっ！　触手たちっ！　膣内でも膣外でも、好きなとこ\nろに触手汁ぶっかけてぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0104219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「んあああっ！　イクッ！　イクッ、イクッ、イクッ！　イックうううぅぅぅ\nぅぅ～～～～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0104220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「おっほおおおおおぉぉぉぉぉ！？　また子宮に触手汁びゅーびゅー注がれて\nるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0104301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017801_02_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「身体が触手汁に反応して、また潮吹いちゃうぅ！　膣内出しされたら潮吹き\nするように、躾けられてるみたいだわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「触手たちに犯されて、調教されるだなんて……！　貴方たちの愛、アソコの\n奥でしっかり感じてるわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0104303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「もっと貴方たちの欲望と愛を注ぎ込んでぇ！　子宮の奥の奥……卵管や卵巣\nも、触手汁まみれにしてぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0104304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「あああぁ！　イクッ！　何回だってイッちゃうぅ！　触手たちに愛されなが\nらイクの、最高なのおおおぉぉぉぉぉ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0104305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、うぐっ、あはぁ……子宮に入りきらなかった触手汁が、アソ\nコから溢れてくるわっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0104306" ]},
		{"command":[ "SETIMAGE", "0", "still_00017801_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「こんなに出してくれたのに、全部受け止められなくてごめんなさいね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0104307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「あんっ……！　触手たちが優しくズリズリ這いずってくるぅ……！　ふふっ\n……気にしないでって言ってるのかしら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0104308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「そんなに優しくされたら、もっと愛して欲しくなって……アソコがまた疼い\nてきちゃうわっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「ふふっ……貴方たちもまだまだやる気みたいね……いいわよ。それじゃ、も\nっともっと楽しみましょうか……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「あはああああぁ！？　触手がアソコから一気に抜けてぇ！？　あああああぁ\nんっ！　触手汁、身体にかけられてるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0104401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017801_02_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ！　熱くて臭いのが全身に飛び散って……！　これ、ダメっ！　\nこの臭いと感触で、また潮吹いちゃうのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0104402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「おっ、おおおぉぉぉ……！？　触手汁浴びながら潮吹きするの、気持ちよす\nぎるぅ……！　イッてる感覚が、おさまらないわっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0104403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「んふっ、あぐっ、あはぁ！　触手汁もまだ出てっ……！　いいわっ、もっと\nぶっかけてっ！　私のこと、触手汁まみれにしてぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0104404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「貴方たちの色で私を染め上げてっ！　心も身体も１つにして……あああっ！\n　もっと、もっとぉ！！　触手汁、びゅるびゅるしてぇぇぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0104405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「んんっ……あっ、あふっ……全身ドロドロにされちゃったわ……それにこの\n鼻を刺激する香り……はああぁ……たまらないわっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0104406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「この臭いだけでイッちゃいそうになるくらいよ……もうずっと、この臭いの\n中で生活したい気分だわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0104407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「でもそうしたら、私の臭いを貴方たちに届けることができなくなるわね……\nそれはちょっと寂しいかも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0104408" ]},
		{"command":[ "SETIMAGE", "0", "still_00017801_02_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「あんっ……！　触手たちが私のアソコやワキの臭いを嗅いでるっ……！　ふ\nふっ……貴方たちも私の臭いが愛おしいのね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0104409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「じゃあ、今度は私のエッチな汁で貴方たちをグチャドロにしてあげるわ……\nふふっ……楽しみにしておきなさい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0104410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}