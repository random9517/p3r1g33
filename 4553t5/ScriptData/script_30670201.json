		{"command":[ "PLAYVOICE", "v2_067_0203217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「はっ、はぁあっ！　強くおっぱいで扱いてあげるから……あっ、あんっ……\n！　んっあぁぁぁっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0203218" ]},
		{"command":[ "SETIMAGE", "0", "still_00006702_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
