		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「はあ……こんな時間に呼び出しなんて、なんの用かと思ったら……こういう\nことね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0203101" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00006702_01", "0", "CENTER", "0" ]},
