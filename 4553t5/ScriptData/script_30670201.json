		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「水着で来いなんて言うから、ある程度は予想できてたけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0203102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「……それで私はなにをすればいいのかしら？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0203103" ]},
		{"command":[ "SETCHARA", "0", "char_00006702_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「パワーアップのために胸でご奉仕？　つまりパイズリをしろってことね……\nいいわよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0203104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「いいのかって、自分で言い出したんじゃない。えっ……断る？　そんなはず\nないでしょ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0203105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「少なくとも、私を選んでくれたんでしょう？　パイズリをして欲しい女とし\nて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0203106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「それって嬉しいじゃない。だから私も、その期待に応えてあげたいの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0203107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「あと、単純に訓練だと思えば……断る理由なんてないわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0203108" ]},
		{"command":[ "SETCHARA", "0", "char_00006702_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「じゃあ、早速始めるわよ。水着だし、このまま挟んであげるわ……んんっ…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0203109" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00006702_01_02" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「あっ、あんっ……なに？　もうこんなに熱くなっちゃってるの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0203110" ]},
		{"command":[ "SETIMAGE", "0", "still_00006702_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「私の水着姿を見た時から、ムラムラしてた？　ふふっ……正直すぎるわよ。\nでも嫌いじゃないわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0203111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「んっ……可愛いわね、ビクビク震えちゃって……ほら、もっと強くおっぱい\nで挟んであげるわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0203112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「どう、気持ちいいかしら？　わざわざ聞かなくても……答えはわかってるけ\nど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0203113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「そうよね、気持ちいいに決まってるわよね。だって、さっきからチンポが硬\nくて、熱くなってるし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0203114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「でも、これからが本番よ……んっ、んんっ……こうやっておっぱいを揺らし\nて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0203115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「ほら……気持ちいい、でしょう？　んっ、んふぅっ……はぁ……はっ、んっ\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0203116" ]},
		{"command":[ "SETIMAGE", "0", "still_00006702_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「先っぽから、我慢汁が出てきてるわ……ヌルヌルしてて……どんどん溢れて\nくる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0203117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「いいわ、もっと感じて……私のおっぱいで、気持ちよくなってね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0203118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「あっ、あん……またチンポが大きくなってる……硬いし、おっぱいと擦れて\n……熱がこっちまで伝わってくるわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0203119" ]},
		{"command":[ "SETIMAGE", "0", "still_00006702_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「はぁっ……んっ……すごい、ギンギンに勃起して……今にも弾けちゃいそう\nね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0203120" ]},
		{"command":[ "SETIMAGE", "0", "still_00006702_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「あんっ……またおっぱいの中で跳ねた……元気いっぱいね……溜まってたの\nかしら？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0203121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「安心してちょうだい……私が全部搾り取ってあげるから……あふっ……うぅ\nんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0203122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「はっ、あんっ……あぁっ……熱いわ、ヤケドしちゃいそう……貴方の興奮っ\nぷりが、よくわかるわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0203123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「私のおっぱいで、こんなに興奮してくれるなんて……嬉しいわ。もっとサー\nビスしてあげたくなっちゃう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0203124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「んっ、んふっ……チンポ、いっぱい感じさせてあげるわ……あっ、あふっ…\n…んっあぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0203125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「はぁっ……はっ、はぁあっ……！　んっ、先っぽが……どんどん濡れてきて\n……おっぱいまで我慢汁まみれになってきたわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0203126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「おもらししたみたいに我慢汁溢れてきてるじゃない……いっぱい感じてくれ\nてるみたいで、嬉しいわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0203127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「水着だから余計に興奮してるの？　ふふっ、エッチなんだから……でも、わ\nざわざ水着を着てきたかいがあったわね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0203128" ]},
		{"command":[ "SETIMAGE", "0", "still_00006702_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「あっ、あふっ……い、いいわよ……出そうになったら、いつでも射精してい\nいから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0203129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「貴方の大好きなおっぱいで……全部受け止めてあげる……ンっ……はっあぁ\n……あっ、あんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0203130" ]},
		{"command":[ "SETIMAGE", "0", "still_00006702_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「はぁあっ……はっ、んっ……ほら、腰が動いちゃってるわよ……我慢しない\nで、早く出しちゃって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0203131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「んっ、はっ……はっ、はぁ、はぁぁっ……イッて、射精してっ……私のおっ\nぱいにいっぱい出してっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0203132" ]},
		{"command":[ "SETIMAGE", "0", "still_00006702_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「はっ、あぁぁぁぁっ！　んっはぁぁぁっぁぁぁぁ～～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0203133" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00006702_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「ああぁ……すごい、んっ……で、出てる……ドクドクいってる……んっ、ふ\nぅっ……ああ、いいわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0203134" ]},
		{"command":[ "SETIMAGE", "0", "still_00006702_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「出してぇ……思いっきり出してちょうだい……私のおっぱいにたっぷり中出\nししてちょうだい……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0203135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁぁっ……んっ、匂いもすごいわ……生臭くて、オス臭くて……\nあぁ……素敵よ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0203136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「ふふっ……たっぷり出たわね……私のおっぱいは気持ちよかったかしら？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0203137" ]},
		{"command":[ "SETIMAGE", "0", "still_00006702_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「喜んでもらえて、嬉しいわ。でも、まだチンポは硬くなったままね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0203138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「そう言うと思ったわ。一回射精したくらいじゃ、満足できないわよね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0203139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「もちろんいいわよ。とことん付き合うから、私のおっぱいを楽しんでちょう\nだい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0203140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁっ……あ、あんっ……熱いわ……今射精したばかりなのに……全\n然萎えてないわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0203201" ]},
		{"command":[ "SETIMAGE", "0", "still_00006702_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「ンっ、すごいわ……むしろさっきより大きくなってる……そんなに私のおっ\nぱいが気に入ったのかしら？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0203202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「嬉しいわ……こんなにいい反応してくれると、こっちもやる気になるわ……\nんっ、んっ……はっ、んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0203203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「もっと強く擦っていいの？　じゃあ……こんな感じで……はっ、んぁっ……\nあふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0203204" ]},
		{"command":[ "SETIMAGE", "0", "still_00006702_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「はぁあっ……あんっ……おっぱいの中で、チンポがビクビク跳ねてる……気\n持ちいいって言ってるみたいね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0203205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「んっ、貴方が出したザーメンのせいで……おっぱいがべちょべちょになって\nるわ……んっ、んはぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0203206" ]},
		{"command":[ "SETIMAGE", "0", "still_00006702_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「おっぱいがすべって……ヌルヌルしてるでしょ？　んっ……あんっ……私も\n気持ちよくなってきちゃった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0203207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「はあっ……んふぅっ……乳首が勃ってる？　もうっ、いちいち言わなくてい\nいのよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0203208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「あんっ……意識したら、胸が火照ってきちゃったわ……はぁ、はぁっ……そ\nうね、汗ばんできたわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0203209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「あら、そう？　色気が増してきた？　そう、言われると……その気になっち\nゃうわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0203210" ]},
		{"command":[ "SETIMAGE", "0", "still_00006702_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「貴方のチンポも素敵よ……さっきから硬くて、ゴツゴツしてて……たくまし\nいし、惚れ惚れしちゃうわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0203211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「ふぅっ……そろそろまた射精しそう？　早いわね……ふふっ、冗談よ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0203212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「私のおっぱいで感じてくれてるってことなんだから……嬉しいに決まってる\nわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0203213" ]},
		{"command":[ "SETIMAGE", "0", "still_00006702_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「んっ、んっあっ……はっ……はあっ！　たっぷり射精できるように……して\nあげるわよ……はぁ、んあっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0203214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「ほら、ほらぁ……私のおっぱいで、搾り取ってあげるから……ンっあっ……\nくっ、くふぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0203215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「あぁ、チンポがまたヒクヒクしだしたわよ……！　イキそうになってるんで\nしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0203216" ]},
		{"command":[ "SETIMAGE", "0", "still_00006702_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
