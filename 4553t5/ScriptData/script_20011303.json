{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0132" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "戦闘が行われている宙域に近づく一行。", "NORMAL" ]},
	{"command":[ "DISPTEXT", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "すると、そこではダイアンサスの長年のライバルにして、次元海賊団・アルデ\nバランのボス……金の銃騎士ことアルフィルク。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "セリカが『フィルちゃん』と呼んでいる宇宙海賊が、何者かと激しい戦闘を行\nっていた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「間違いありません。次元海賊団……アルデバランです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_010021540001" ]},
	{"command":[ "SETCHARA", "0", "char_00019301_01", "0", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「ど……どちらに加勢すべきなのでしょうか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_010021540001" ]},
	{"command":[ "SETCHARA", "0", "char_00019201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「そうだなぁー……。フツーならフィルちゃんが一般船団を襲ってるーって判\n断するところなんだけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_010021540001" ]},
	{"command":[ "SETCHARA", "0", "char_00019001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「どーもスイレンちゃんはそうじゃないって思ってるみたいね？　意見を聞い\nてみましょうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_010021540002" ]},
	{"command":[ "SETCHARA", "0", "char_00019001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「……アルデバランと対峙している船団が、異常です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_010021540001" ]},
	{"command":[ "SETCHARA", "0", "char_00019101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「今まで見たことのない反応……。また、アルデバランが防戦一方になってい\nることから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_010021540002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「アルフィルクが自ら仕掛けた戦いではないのではないか、と考えられます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_010021540003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「よーくわかってるみたいじゃないか。さっすがダイアンサスの副艦長サンだ\nねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_129_010021540001" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「あっ！　フィルちゃん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_010021540003" ]},
	{"command":[ "SETCHARA", "0", "char_00019001_01", "6", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "声だけで、その主が誰かわかったのか……セリカがぱぁっと目を輝かせる。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「フィルちゃんから通信でしょ、そうでしょ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_010021540004" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「その通りです。……次元海賊団アルデバランより緊急通信。立体映像での会\n話を希望しているようです。どうしますか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_010021540002" ]},
	{"command":[ "SETCHARA", "0", "char_00019301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「繋いで。んっ、んっ……。もう喋っても大丈夫かしら。……すぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_010021540004" ]},
	{"command":[ "SETCHARA", "0", "char_00019101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「『こちら旗艦、ダイアンサス。副艦長、スイレン・アファナシエフ。当艦に\n通信を求めた理由を述べてください』」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_010021540005" ]},
	{"command":[ "SETCHARA", "0", "char_00019101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「……金の銃騎士こと、アルフィルク様ともあろう御方が、随分と慌てていら\nっしゃるようですね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_010021540006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "スイレンの呼びかけに、ジジッ、とアルフィルクの姿がクルーたちの前に出現す\nる。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「やーあ。会いたかったよ、ダイアンサスの諸君」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_129_010021540002" ]},
	{"command":[ "SETCHARA", "0", "char_00012901_01", "6", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「なにぶん、久方ぶりの遭遇だ。積もる話もあると思うけどね、緊急事態だ。\n手短に話させてもらうよ。耳かっぽじってよく聞きな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_129_010021540003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「……この次元は今、侵略者（インベーダー）と呼ばれる連中に攻め込まれて\nいる。コイツらがハンパなくヤバイやつらでね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_129_010021540004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「太陽系どころか、全宇宙が滅亡する危険ってのに迫られてる。……そこで、\nあんたらの力が必要なんだ。力を貸しちゃくれないか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_129_010021540005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「共に戦えと？　事の真偽もわからないのに？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_010021540007" ]},
	{"command":[ "SETCHARA", "0", "char_00019101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「ああ。もうこれに関しては、アタシを信じろとしか言えないねぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_129_010021540006" ]},
	{"command":[ "SETCHARA", "0", "char_00012901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ニヒルに微笑む宇宙海賊と、視線を交わすこと数秒。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "普段はぬぼらーっとしているスイレンが、冷たい声で一喝する。", "NORMAL" ]},
	{"command":[ "SETCHARA", "0", "char_00019101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「冗談でしょう。スミレ、本部に報告を。それから指示をあおいでもらえる？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_010021540008" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「は、はいっ……でも、でも、えっと……！　本部はたぶん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_010021540002" ]},
	{"command":[ "SETCHARA", "0", "char_00019201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「ええ。この戦闘に対しては、私達の介入を許さないでしょうね。それが答え\nです、金の銃騎士」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_010021540009" ]},
	{"command":[ "SETCHARA", "0", "char_00019101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「私達はあなたに協力は出来ない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_010021540010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「そうかい……。残念だ。せいぜい、背中に気をつけて戻るんだね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_129_010021540007" ]},
	{"command":[ "SETCHARA", "0", "char_00012901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「……背中？　何を言っているんです……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_010021540011" ]},
	{"command":[ "SETCHARA", "0", "char_00019101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「アタシらは忙しくて構ってやれないが、ホラ。そうやってモタモタしてるか\nら……囲まれてるよ、アンタら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_129_010021540008" ]},
	{"command":[ "SETCHARA", "0", "char_00012901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「……侵略者（インベーダー）、ダイアンサスの右舷……いえ、左舷、……後\n方にも出現しました！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_010021540003" ]},
	{"command":[ "SETCHARA", "0", "char_00019301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「なんですって……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_010021540012" ]},
	{"command":[ "SETCHARA", "0", "char_00019101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "周囲を見渡したスイレンが、ギリッと奥歯を噛みしめる。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "と、すかさずセリカがその肩に顎を乗せて、ニヤケた声で笑いを浮かべた。", "NORMAL" ]},
	{"command":[ "SETCHARA", "0", "char_00019001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「……どうせ帰るなら、人助けしてからにしろーって、宇宙の神様のおぼしめ\nしなんじゃないかな～？　セリカおねーさんはそう思うよー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_010021540005" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「そうしたいのはやまやまですが……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_010021540013" ]},
	{"command":[ "SETCHARA", "0", "char_00019101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「したいことをするのが、ダイアンサスでしょ☆」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_010021540006" ]},
	{"command":[ "SETCHARA", "0", "char_00019001_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「宇宙がピンチだってんなら、やっちゃうしかないよねーっ！　皆もそう思う\nでしょっ☆」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_010021540007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「まぁ……私もダイアンサスのクルーですから。艦長が決めたことには従いま\nすけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_010021540003" ]},
	{"command":[ "SETCHARA", "0", "char_00019201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「あは……♪　なんだかんだ言って、毎回艦長にいっちばん甘いのってスミレ\nだよねー♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_010021540004" ]},
	{"command":[ "SETCHARA", "0", "char_00019301_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「そぉそぉ～。最後の一押しするのよね～。そこが可愛いトコロなんだけど～\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_010021540014" ]},
	{"command":[ "SETCHARA", "0", "char_00019101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「ち、ち、違いますぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_010021540004" ]},
	{"command":[ "SETCHARA", "0", "char_00019201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「んじゃま、ポチっとなー♪　スミさん！　リリさん！　やーっておしまいー\n☆」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_010021540008" ]},
	{"command":[ "SETCHARA", "0", "char_00019001_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「ダイアンサス、一斉射！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_010021540005" ]},
	{"command":[ "SETCHARA", "0", "char_00019201_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「せいぜい映（ば）えるアングルで散ってください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_010021540005" ]},
	{"command":[ "SETCHARA", "0", "char_00019301_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "主砲の照準を侵略者達に合わせたダイアンサスの、一斉射撃がはじまった。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「ひゅーっ♪　やっちゃえやっちゃえー♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_010021540009" ]},
	{"command":[ "SETCHARA", "0", "char_00019001_01", "8", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "セリカの、大歓声を乗せたまま……。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}