	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「山道での暴走車たちをぶっちぎり、学園まで戻ってきた」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_999_010114090001" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「カツマちゃん！　……って、あら？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114090001" ]},
		{"command":[ "SETCHARA", "0", "char_00011101_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「あなた、どこへ行っていたの！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070114090001" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「みんなこそどうしたの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114090002" ]},
		{"command":[ "SETCHARA", "0", "char_00011101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「襲来者（インベーダー）が出現したみたいなんだけど、カツマが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_030114090001" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「カツマちゃんになにかあったの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114090003" ]},
		{"command":[ "SETCHARA", "0", "char_00011101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「街で起こってる混乱に巻き込まれたらしいのよ。ああもう、こんなときに！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070114090002" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「街で……？　もしかして、車の暴走と関係あるのかしら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114090004" ]},
		{"command":[ "SETCHARA", "0", "char_00011101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「そうそう。車が襲来者（インベーダー）に乗っ取られてるんだって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_030114090002" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「下僕が乗っているＭ．Ａ．Ｍ．Ａも暴走状態になってしまっているみたいな\nの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070114090003" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「なんてこと！　じゃ、じゃあ、早くカツマちゃんを助けに行かないと！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114090005" ]},
		{"command":[ "SETCHARA", "0", "char_00011101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「待ちなさい！　私も行くわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070114090004" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「私も行くよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_030114090003" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「わかった。さ、早く乗って！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114090006" ]},
		{"command":[ "SETCHARA", "0", "char_00011101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「ルルーナとセレインは、Ｍ．Ａ．Ｍ．Ａが暴走しているという市街地へと向\nかった！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_999_010114090002" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0137" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「その道中の山道」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_999_010114090003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「やっほー！　いつもカツマが乗ってる運転席、乗ってみたかったんだよねー\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_030114090004" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「あ、安全運転でお願いね？　というか、もうすでに飛ばし過ぎじゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070114090005" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「カツマちゃんのピンチだもの！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114090007" ]},
		{"command":[ "SETCHARA", "0", "char_00011101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「それに……これは、私のせいでもあるんだから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114090008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「わっ。なにあれ、後ろから車が……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_030114090005" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「運転席に人がいませんわ！　もしかして、暴走している車ってあれのこと！\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070114090006" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「あのナンバープレート……学園に戻るときに絡んできた車だわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114090009" ]},
		{"command":[ "SETCHARA", "0", "char_00011101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「さっきのリベンジのつもりかしら？　しつこい車は嫌われるわよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114090010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「ちょ、ちょっと待ちなさい！　さらに加速するつもり……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070114090007" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「この峠道、一気に登りきるわ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114090011" ]},
		{"command":[ "SETCHARA", "0", "char_00011101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「よーし、いけーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_030114090006" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「ま、待ちなさ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070114090008" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「その時である！　前の崖から暴走車両が滑り降りてきた！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_999_010114090004" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「なにぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_030114090007" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「前と後ろで挟み撃ちです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070114090009" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「こんな狭い道で、前方を並走されたら追い越せないじゃないの……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114090012" ]},
		{"command":[ "SETCHARA", "0", "char_00011101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「もしかして、時間稼ぎ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_030114090008" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「市街地へ向かわせないことが目的の可能性もありますね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070114090010" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「それなら、こっちにだって考えがあるんだから！　ふたりとも、シートベル\nトは締めてるわね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114090013" ]},
		{"command":[ "SETCHARA", "0", "char_00011101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「な、なにをするつもり……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070114090011" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「崖を走れるのは、貴方たちだけじゃないってところをみせてあげる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114090014" ]},
		{"command":[ "SETCHARA", "0", "char_00011101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「カーブに差し掛かるとインコースに無理やり割り込んだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_999_010114090005" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「ぎゃーっ！　どうなってるの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070114090012" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「崖を走ってる！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_030114090009" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「掟破りの崖走りで前方車両を抜いたが、その進路を再び自然が阻む！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_999_010114090006" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「ちょっ！　この先の橋、壊れてる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_030114090010" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「構わないわ。通るわよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114090015" ]},
		{"command":[ "SETCHARA", "0", "char_00011101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「ええっ！？　本気なの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070114090013" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「だって近道だもの！　私は、一刻も早くカツマちゃんのところに行かないと\nいけないんだから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114090016" ]},
		{"command":[ "SETCHARA", "0", "char_00011101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「それに、もう迂回する分かれ道は過ぎちゃったし。行くしかないわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114090017" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「そんな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070114090014" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "sbg_0151" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「うおおぉぉぉっ！　かっとべＭ．Ｏ．Ｅ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_030114090011" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「いくわよぉおおっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114090018" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「ぎゃぁあああっ！　車がっ、車が空を飛ぶぅうううぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070114090015" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「壊れた橋を飛び越えて向こう側へ着地した！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_999_010114090007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0147" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「い……いきてる……？　わたし……生きてる……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070114090016" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「待っててね、カツマちゃん！　このまままっすぐカツマちゃんのところへ向\nかうから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114090019" ]},
