		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「１つ１つの攻撃が鋭くて、しかも威力があります……！　当たらないように\n気をつけてください！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_010023890001" ]},
		{"command":[ "SETCHARA", "0", "char_00027901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒルデガード" ]},
		{"command":[ "SETTEXT", "「ですが……動きも速すぎて……避けるのが精一杯です！　こんなに強くなる\nなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_281_010023890001" ]},
		{"command":[ "SETCHARA", "0", "char_00028101_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「奴の魂と、ヴァルキリーとの相性が良すぎるんだ……何倍にも力が増幅され\nているぞ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_010023890001" ]},
		{"command":[ "SETCHARA", "0", "char_00028001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「これは……少し困りましたわね……この状況であの人にこの地を献上するの\nは色々と難しそうです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_010023890001" ]},
		{"command":[ "SETCHARA", "0", "char_00028201_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「そんなことを言ってる場合か！　ヤツめ、もはや我々のことも味方だとは思\nっていないぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_010023890001" ]},
		{"command":[ "SETCHARA", "0", "char_00028401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「にひひっ、ちょーっと色々と予定からは違っちゃってるけど、まぁ、エファ\nナティカ様が楽しそうだからヨシっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010023890001" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「まだまだ力が湧いてくるぞ。そうら、吹き飛べっ！」", "NORMAL" ]},
