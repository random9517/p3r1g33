		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「くそ……向こうばっかりあんなチート級なやつ……こっちも、何かあればい\nいのにな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「こっちも……ヴァルキリーに？」", "NORMAL" ]},
