		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんか出来てるし！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「何だこれは……すごいぞ……力が身体の奥底から湧いてくるような感じだ…\n…！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023890005" ]},
		{"command":[ "SETCHARA", "0", "char_00000133_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒルデガード" ]},
		{"command":[ "SETTEXT", "「あの鎧姿は……私達のものと同じ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_281_010023890005" ]},
		{"command":[ "SETCHARA", "0", "char_00028101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「なるほど……思ったよりもずっと装甲が軽い……だが、粗末な雰囲気はなく\n、むしろ確かな強度を感じることができる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090023890004" ]},
		{"command":[ "SETCHARA", "0", "char_00000134_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「身体も軽く感じるぞ……！　原理は全く分からんが、とにかくパワーアップ\nしたのは間違いないな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023890006" ]},
		{"command":[ "SETCHARA", "0", "char_00000133_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「な、な……なっ……はぁぁぁーっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010023890002" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ボクが苦労して見つけたヤツなのに……何テキトーなやり方でヴァルキリー\n化させちゃってんのぉっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010023890003" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「何だ、苦労したのか？　それは悪かったな。私の溢れ出る才能が、自然にさ\nせてしまったようだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023890007" ]},
		{"command":[ "SETCHARA", "0", "char_00000133_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あっさりと種明かしをしたお前たちが迂闊だったな。手の内を隠していれば\n、まだ分からなかったかも知れんがな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090023890005" ]},
		{"command":[ "SETCHARA", "0", "char_00000134_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「だ、だからって……こんなアタマ悪い話、納得できないしー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010023890004" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「フン……下らぬ。貴様らが強くなろうとも、余がまとめて退けるまでよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100023890005" ]},
		{"command":[ "SETCHARA", "0", "char_00000318_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「フッ、さて、そう上手く行くかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023890008" ]},
		{"command":[ "SETCHARA", "0", "char_00000133_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ヴァルキリーとなった私達を、簡単にどうこうできると思っては困るな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090023890006" ]},
		{"command":[ "SETCHARA", "0", "char_00000134_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「口で言っても始まらんな。貴様らに直接分からせてやろう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100023890006" ]},
		{"command":[ "SETCHARA", "0", "char_00000318_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「望む所だっ。行くぞっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023890009" ]},
		{"command":[ "SETCHARA", "0", "char_00000133_01", "7", "CENTER", "0" ]},
