{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024801_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「カツマ先輩って、本当に台車の交換ができるんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0104101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「あっ、いえ！　決して疑っているわけではないんです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「ただ、こういった作業はかなり専門的なことなので、それなりの知識がない\nと難しいと思って……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0104103" ]},
		{"command":[ "SETIMAGE", "0", "still_00024801_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「ちゃんと整備したいから、台車交換について勉強したり、講習を受けたりし\nてくれたんですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0104104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「そんなっ……！　ノゾミのためにそこまでしてくれるなんて……！　凄く嬉\nしいです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0104105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「では、ノゾミの車体と台車のメンテナンス、よろしくお願いします！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0104106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「んんっ……！　そうです……まずは台車の下から手を伸ばして、ボルトなど\nを外していってください……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0104107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「あまり強く工具を使われると、車体が傷つきますので……なるべく、優しく\nっ……！　あっ、んっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0104108" ]},
		{"command":[ "SETIMAGE", "0", "still_00024801_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「凄く丁寧な作業で安心できますっ……！　カツマ先輩の指先の感触が、台車\nを通じて車体に伝わってきて……はぁ、あっ！　ふくっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0104109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「足回りにゆっくりと指が這ってきてるっ……！　ノゾミの汚いところ、全部\n見られてるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0104110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「えっ……？　軽く触っただけでも指が真っ黒になって、油汚れのヌルヌルし\nた感触がする……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0104111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「ご、ごめんなさいっ……！　こまめに洗車はしてるんですが、台車の細部ま\nでは綺麗にできないので、どうしても汚れが残っちゃうんです……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0104112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「不快だったら、作業を中断してもらっても大丈夫ですのでっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0104113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「あっ、んっ！　あぁんっ！　さらに奥にまで手が伸びてきてるっ……！　ノ\nゾミの汚いところ、いっぱいぐちゅぐちゅされてるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0104114" ]},
		{"command":[ "SETIMAGE", "0", "still_00024801_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「はぁ……！　やっ、あっ！　そこ、ダメっ……！　カツマ先輩の手だけじゃ\nなくて、爪の中まで真っ黒になっちゃいますっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0104115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「ノゾミが綺麗になるためにやってるから、手が汚れるくらい全然気にならな\nい……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0104116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「そ、そんなこと言われたら、もっとして欲しくなっちゃいますっ！　留め具\nだけじゃなくて、圧力センサーまで触って欲しくなっちゃうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0104117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「ひああぁ！？　一本リンクにまで手が伸びてるっ……！　ノゾミと台車と繋\nぐ大事な部品が、ゆっくりと外されて……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0104118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「それを取られたら、ノゾミの車体が丸見えになっちゃいます……！　今まで\nカツマ先輩に見せたことのないところ、本当に全部晒しちゃうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「でも、これは整備ですし……！　ノゾミの大事なとこ、全部見てくださいっ\n……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0104120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「あっ！　あっ！　車体の平行を保つ空気バネのエアーが抜けていってるっ…\n…！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0104121" ]},
		{"command":[ "SETIMAGE", "0", "still_00024801_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「ノゾミの身体からシューッっていやらしい音がしてるっ……！　か、カツマ\n先輩っ！　ノゾミから出る空気の音、まじまじと聞かないでくださいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「た、確かに空気が完全に抜けたかどうか、耳で判断する必要はありますけど\n……！　この音を聞かれるの、凄く恥ずかしいんですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0104123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「んひぃ！？　バネを押しちゃダメですぅ！　そんなことしたら、もっと激し\nく空気が抜けていって……ひっ、あっ！　んふっ、くうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0104124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「ノゾミのエッチな空気音が漏れ響いてますっ！　やっ、あんんっ！　もうこ\nのエッチな音、車体の下から響かせないでぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……んっ、あふっ……やっと空気が抜けたんですね……！　な\nら次は、ジャッキを使って車体を持ち上げていってください……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「これで台車を下げることができるはずなので……んっ、んんっ……！　あっ\n、少しずつ、車体と台車の間に空洞ができていってるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0104127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「ああぁんっ！？　ど、どうして急にジャッキを止めるんですかぁ！？　もう\n少しで、車体と台車の繋ぎが外れるのにっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「安全のためにも、ちゃんと繋ぎが外れたかどうか確認が必要……？　あっ、\nそ、そうでしたね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「注意一秒、怪我一生ですし……整備は指差し確認をしながら、確実に作業す\nる必要がありますよね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「やっぱりカツマ先輩は凄いです……！　初めてなのに、ノゾミのことこんな\nにも気にかけてくれるなんて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「くっ、ふぐっ……！　は、はいっ……準備できました……！　このまま台車\nを降ろして、完全に車体から外してくださいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「んっ……あっ……！　ノゾミの車体から、台車がなくなっていってますっ…\n…！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「ノゾミの大事なところ、カツマ先輩に見られてるっ……！　あっ、あっ！　\n恥ずかしいっ……！　恥ずかしいですっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「でも、もっと見てくださいっ……！　ノゾミの生まれたままの姿……もっと\n見てっ……！　んっ、んんっ！　んくうぅぅぅぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0104135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「あはあぁぁぁっ……！　車体が外れた反動と、カツマ先輩に大事なところを\n見られた恥ずかしさで……イッ、イッてますっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0104136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024801_02_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「快感が先頭車両に溢れてきてっ……！　反射的にウォッシャー液が噴き出し\nちゃってますぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0104137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「あぁぁぁんっ！　イクの止まりませんっ！　台車の取り外しでこんなに感じ\nるなんて、初めてですぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「あっ！　ひっ、んんっ！　ノゾミの全部、カツマ先輩に知られちゃったっ…\n…！　大事なところも、感じてるとこも見られて……んくうぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0104139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「ひあああぁっ！？　まだウォッシャー液出るぅ！　びゅーびゅー止まってぇ\n！　もうこれ以上、カツマ先輩の前で粗相しないでぇ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「はぁ……あふっ、んっ……ご、ごめんなさい……少し、興奮しすぎちゃいま\nした……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0104201" ]},
		{"command":[ "SETIMAGE", "0", "still_00024801_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「ですが車体が外れたので……これからがメンテナスの本番ですよね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「ノゾミの大事なところに手を入れたり、目視したりして……しっかり確認し\nてください……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「あっ、でも……できるだけ、優しく触ってください……本体部分は特にデリ\nケートなので……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0104204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「台車は交換すればいいですが、車体に何かあったら、ノゾミは大規模な修繕\nが必要になっちゃいますから……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0104205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「あふっ……！　カツマ先輩の指が、直接ノゾミに当たってきてますっ……\n！　はぁ、あっ……！　やっ、くっ、んふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0104206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「そんなっ……！　撫でるみたいに、優しく指を這わすなんてっ……！　そん\nな触られかたしたら、ゾクゾクしちゃうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「それに、撫でるだけじゃなくて目視もされてっ……！　ノゾミの身体、隅々\nまで視姦されちゃってますぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「ふえっ……？　次はハンマーを使って打診をする……？　わ、わかりました\n……！　ノゾミのこと、しっかり叩いてくださいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「あああぁんっ！　カンッ、カンッって、ハンマーの音が響いてますぅ！　ノ\nゾミの車体、優しく叩かれてるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0104210" ]},
		{"command":[ "SETIMAGE", "0", "still_00024801_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「痛くないくらいの丁度いい力加減で……！　んっ、んんっ！　だ、ダメっ！\n　振動が後続の車両にも響いてますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0104211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「カツマ先輩にカンカン叩かれるの、凄く感じるぅ！　エアーを抜く音とはま\nた違った、エッチな音がして……んっ！　んっ！　あんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0104212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「やああぁっ！　叩いたところを撫でるのは反則ですっ！　ジンジンする個所\nに触れられると、感じて……！　んくうぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0104213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「叩かれたところをもっと触って欲しいって思うだなんて、普段は絶対ないの\nにっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0104214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「そんな変態みたいなことっ……！　あっ！　ダメっ！　こんなに感じたら、\nまたイキそうになっちゃうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0104215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「ひあぁっ！？　あっ、んはぁぁぁっ！？　またハンマーの音が強くなってる\nぅ！　細かなところまで、しっかりと打診されてますぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0104216" ]},
		{"command":[ "SETIMAGE", "0", "still_00024801_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「これ以上叩かれたら、本当にイッちゃいますっ！　カンカン叩かれるのが好\nきな、変態になっちゃうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0104217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「あっ！　あっ！　来るっ！　ハンマーの振動にあわせて、気持ちいいのが車\n体の奥から来てるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0104218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「か、カツマ先輩っ！　もう打診は十分ですからっ！　これ以上叩かないでく\nださいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0104219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「ノゾミのエッチな音、聞かないでっ……！　んっ！　あっ！　あっ！　ひあ\nあああぁぁぁぁぁ～～～っ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0104220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「んはぁぁぁぁぁんっ！？　さらに奥までカツマ先輩の指が届いてきてるぅ！\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0104301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024801_02_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「奥の奥までホジられたから、オイルが漏れるの我慢できませんっ！　ノゾミ\nの汚い汁、ドプドプ溢れ出ちゃうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「オイルが漏れるくらい気にならないって……！　カツマ先輩はそうかもしれ\nませんが、ノゾミが気になるんですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0104303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「やああぁ……！　カツマ先輩がオイル塗れになっちゃいますっ！　ノゾミの\nエッチな汁でベトベトになっちゃうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0104304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「んひぃぃぃっ！？　指の動きに合わせてハンマーで打診しないでぇ！　それ\n、本当に感じるんですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0104305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「あっ！　んっ、んんっ！　ダメっ！　またイクッ！　指で車体の奥をホジホ\nジされながらハンマーで叩かれると、またオイル漏れちゃうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0104306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「あああぁぁぁっ！　イクッ！　イクッ！　カツマ先輩が車体の下に居るのに\n、イクの止まりません～～～～～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0104307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「あっ、あうぅ……！　ノゾミのエッチな姿、全部見られちゃった……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0104308" ]},
		{"command":[ "SETIMAGE", "0", "still_00024801_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「ごめんなさい、カツマ先輩……整備してくれてたのに、オイル塗れにしちゃ\nって……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「あ、あの……！　ノゾミのこと、嫌いになっちゃいましたか……？　えっ…\n…？　そ、そんなことない……？　ああっ、よかったですっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「んひぃぃぃ……！？　きゅ、急に台車を戻すなんてぇ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0104401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024801_02_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「あっ、あああぁ……！　台車が取り付けられた反動が一気に車両全体に響い\nてますぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0104402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「こんなの、またウォッシャー液が止まらなくなっちゃうっ……！　びゅーび\nゅー噴き出して、フロントガラスがベトベトになるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0104403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「ひぎっ！？　がっ、あっ……！？　台車を戻すだけじゃなくて、ボルトで締\nめ付けてくるだなんてぇ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0104404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「あっ！　あっ！　一本リンクが取り付けられる感じがするぅ……！　こんな\nに激しい整備、生まれて初めてですっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0104405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「ダメっ……！　これ、感じすぎて言葉が出なくなっちゃうっ……！　ノゾミ\nの超人工知能、オーバーヒートしちゃうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0104406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「ひぐっ、んふっ、んくぅぅぅっ……！　イクッ……！　また、イッちゃうっ\n……！　ウォッシャータンク、空っぽになるぅぅぅ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0104407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……！　んっ、あふっ……！　カツマ先輩の手つき……とても\n初めてとは思えないほどでした……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0104408" ]},
		{"command":[ "SETIMAGE", "0", "still_00024801_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「でも……こんなに激しく点検されたら、もう普通の点検には戻れませんっ…\n…！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0104409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「こんな身体にしたんですから、カツマ先輩には責任を取ってもらって、ノゾ\nミをお嫁さんにしてもらいますからねっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0104410" ]},
