{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0045" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_007" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……というわけで、あてもなく龍神の力の断片……。クラミツハの力のカケ\nラを探しに出発することにしたはいいものの……」", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「切り離したってトカゲみたいに言われても、形や色が分からないとなぁ。そ\nれこそ尻尾みたいな感じなのか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「わしが認めたお嬢であれば、龍の力を秘めたカケラには必ず気付く」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_010023680001" ]},
		{"command":[ "SETCHARA", "0", "char_00027601_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「せ、先生に私が認められている……！？　が、頑張らなくては……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023680001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「お嬢。お嬢がカケラの近くに行けば、封印が解けて力を貸してくれるはずじ\nゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_010023680002" ]},
		{"command":[ "SETCHARA", "0", "char_00027601_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「わかりました！　全力で探索します！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023680002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「おとーさん。イルルたちもドラゴンだから……、匂いでさがせるかもしれな\nい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010023680001" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "3", "CENTER", "400" ]},
		{"command":[ "SETCHARA", "1", "char_00017502_01", "0", "CENTER", "-400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "1" ]},
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ヤムたち犬じゃないんだけど！？　ま、まあ……非常事態だし、仕方ないよ\nね。協力してあげる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010023680001" ]},
		{"command":[ "SETCHARA", "1", "char_00017502_01", "1", "CENTER", "-400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「イルル、ヤム、２人ともありがとう……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「くんくん……。あっちだよ、おねーさん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010023680002" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "そして、龍神の力のカケラを探すこと数分後。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「……カケラって、これかな？　お賽銭箱の後ろにころころ転がってたの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010023680003" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「でかした！　私が近づいてみよう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023680003" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おおおっ！　光りましたよ！　姫様に反応してるみたいです！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「先生！　カケラってこれでいいの？　これをたくさん集めるんだよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010023680002" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「ああ、そうじゃよ。本来は、わしがカケラのありかを記憶しておくべきなの\nじゃが……その」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_010023680003" ]},
		{"command":[ "SETCHARA", "0", "char_00027601_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「なんせ、なくしたのが相当前のことで、今はどこにあるかを把握しておらぬ\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_010023680004" ]},
		{"command":[ "SETCHARA", "0", "char_00027601_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まあ、逆転のヒントをくれただけでありがたい」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「そう言ってもらえると助かるのう。ほれ、これが１つ目のカケラじゃ。よく\n見て覚えて他を探すといい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_010023680005" ]},
		{"command":[ "SETCHARA", "0", "char_00027601_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……ん？　カケラっていうからもっと尖ってるもんだと思ってたが……丸い\nな。玉だなこりゃ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「それに、うっすらオレンジ色に光ってて……。って、これってもしかして、\nドラゴンボー……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「ていっ！　それ以上は言うてくれるな！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_010023680006" ]},
		{"command":[ "SETCHARA", "0", "char_00027601_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "俺の手をぺしっとはたいたクラミツハはゆっくりと頭を横に振った。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「この世には、言うてはならぬことがあるのじゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_010023680007" ]},
		{"command":[ "SETCHARA", "0", "char_00027601_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「先生！　カケラの数はいくつなのですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023680004" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「おおよそ７つくらいかのぉ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_010023680008" ]},
		{"command":[ "SETCHARA", "0", "char_00027601_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……！！　やっぱりドラゴンボ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「やめるのじゃ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_010023680009" ]},
		{"command":[ "SETCHARA", "0", "char_00027601_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「こら！　先生を困らせるな！　とっとと探しに行くぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023680005" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はい……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETTEXT", "それから俺たちは、手分けをして神社の中をさんざん駆けずり回った。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「む！？　漬物石になっておりましたぞ！　これで２つ目です！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023680001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「こっちにもあった！　狛犬の台座の下に隠されていた！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023680006" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「４個目……どこだろう。くんくん、くんくん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010023680004" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「あっ！　屋根の上でキラキラしてる……！　とれるかなぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010023680005" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ねえ。鳥居の根っこに何か埋まってるかも。すん……すんすん、龍の匂い…\n…ちょっとする」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010023680003" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「……待て。灯篭の奥にもう１つ……。んぐ……！　深くはまりこんでいて…\n…んぐぐぐ！　と、取れたぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023680007" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「こっちにもあった！　お守り売り場に普通に置かれてたぞ！　御朱印帳の重\nしに使っていたみたいだ！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "こうしている間にも、アナザー・稲穂姫は神社の色んな場所を爆破している。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "これ以上被害が拡大しないうちに、と必死に走りまわっている俺たちを……ク\nラミツハは腕を組んで、うんうんとうなずきながら見つめていた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「お嬢、そしてお嬢の仲間たちは着々と成長する人生を歩んでいる……。今は\nまだその途中に過ぎない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_010023680010" ]},
		{"command":[ "SETCHARA", "0", "char_00027601_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんなんだそのドヤ顔は！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「すまぬ。どうしても言ってみたくてのう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_010023680011" ]},
		{"command":[ "SETCHARA", "0", "char_00027601_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……と、冗談はさておき、俺が見つけたやつでカケラは７つ全部そろったぞ\n。これで龍の力を秘めたボールが集結した！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「素晴らしい働きであった。これならば……お嬢の力を解放してやることがで\nきる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_010023680012" ]},
		{"command":[ "SETCHARA", "0", "char_00027601_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "STOPBGM" ]},
		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「いでよ、龍神の力！　そして願いを叶えたまえ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_010023680013" ]},
		{"command":[ "SETCHARA", "0", "char_00027601_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「くぅうううっ……！　溢れ出すこの圧倒的なパワーは……！　ああああああ\nっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023680008" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "ドンッ、とルナテミスから衝撃波が放たれた、次の瞬間……。", "NORMAL" ]},
		{"command":[ "SETIMAGE", "1", "bg_0000" ]},
		{"command":[ "DISPIMAGE","1", "TRUE" ]},
		{"command":[ "FADEINIMAGE", "1", "VERYFAST" ] },
		{"command":[ "FADEOUTCHARA", "0", "VERYFAST" ] },
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "PLAYBGM", "BGM_022" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「こ、この姿は……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023680009" ]},
		{"command":[ "SETCHARA", "0", "char_00000132_01", "3", "CENTER", "0" ]},
		{"command":[ "FADEOUTIMAGE", "1", "VERYFAST" ] },
		{"command":[ "FADEINCHARA", "0", "VERYFAST" ] },
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「これこそが神竜の力を得た龍神モード！　お嬢の新しい姿じゃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_010023680014" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「姫様！　むちゃくちゃ神秘的ですよ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「まさに神が宿った煌めきですな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023680002" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「へぇええ～っ！　すっごいじゃん！　カッコイイ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010023680004" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「……おねーさん、とっても強そう。これが龍の神様の力なんだ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010023680006" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "神々しい衣装に身を包んだルナテミスに、全員の期待が盛り上がるのを感じた\n。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「イケる！　これならアナザー・稲穂姫にも勝てるはずだ！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00000132_01", "7", "CENTER", "0" ]},
