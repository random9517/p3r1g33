{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「はぁ～……。なんなのです～？　夜中にこんなところに呼び出して～。無能\nな隊長さんとは違って、全知全能の黒き神はいそがし～のですが～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0103101" ]},
		{"command":[ "SETCHARA", "0", "char_00025401_01", "4", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「……と、文句を言い続けてあげたいところですが。最近、妙に隊長さんに助\nけられることが多いですし。ここらで１つ、恩返しでもしてあげるのです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0103102" ]},
		{"command":[ "SETCHARA", "0", "char_00025401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「……なんですか。その疑いの目は。フン。天才の考えなど、どうせ凡人には\nわからないのです。……ほら、とっとと横になってください。よいしょっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0103103" ]},
		{"command":[ "SETCHARA", "0", "char_00025401_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「あっははははっ♪　い～い眺めですね～♪　……はぁ？　上から見下ろして\n、一体何をするつもりか……って、ここまでされてまだわからないのです？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0103104" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00025401_01_02" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「ご・奉・仕ですよ、ご・奉・仕……♪　わたしにご奉仕をしてもらえる人間\nなんて、長い歴史上でも隊長さんが最初で最後なんじゃないですか～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0103105" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「くふっ、ふふふっ♪　でも～。いくら日頃のお礼と言ったって、私が上であ\nることは譲れませんからね～？　この体勢で好きにやらせてもらうのです♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0103106" ]},
		{"command":[ "SETIMAGE", "0", "still_00025401_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「そう。愚かでおバカな隊長さんでも、や～っと理解したみたいですね？　そ\nうなのです。私がするのは足コキなのです。ある意味屈辱的でしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0103107" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「む～っふっふっふっふ～♪　今更イヤとは言わせませんよ～？　それにぃ～\n。この男性器……いわゆるちんちんというモノが既に勃起している現状」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0103108" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「隊長さんが本気でイヤがっているとはとても思えないのです♪　あ～ああ～\n？　元からドM……マゾなのですか？　それとも、もしかしてぇ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0103109" ]},
		{"command":[ "SETIMAGE", "0", "still_00025401_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「わたしのこーんな小さな胸を見て、ちんちんを硬くしちゃっているのですか\n～？　だとしたらヘンタイの極みなのです。ヘ～ンタイ、ヘ～ンタイ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0103110" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「……ちょっと信じられないのです～。わたしに罵られて、足の裏でちんちん\nを踏みしめられて……どんどん股間を熱くしてくるのですが～？　あっはっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0103111" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「挑発されて～、煽られて～。グシグシ容赦なく、大事な大事なちんちんを足\n蹴にされて～。それで感じるとか、異常性癖もいいところです♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0103112" ]},
		{"command":[ "SETIMAGE", "0", "still_00025401_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「ですが、わたしは慈悲深き、スラヴのチェルノボグ……。この程度のおイタ\nは見逃してさしあげるのです。あ～、なんと心優しい神なのでしょう～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0103113" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「……くふふふ♪　いいですよ？　今だけは……わたしのこの、愛らしい足の\n裏で……隊長さんのバキバキちんちんを慰めてさしあげるのです♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0103114" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「ほぉら……♪　ぐーにぐに、ぐーにぐに……♪　んふふ、すっごい抵抗力で\nすねぇ～。わたしの足が跳ね返されますよ～。あっは力づよ～い、コワーい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0103115" ]},
		{"command":[ "SETIMAGE", "0", "still_00025401_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「超攻撃的ちんちんですが、いくらその首を伸ばしても～。無駄無駄無駄の無\n駄なので～す。ほぉら！　ぐいっと踏みしめられて終了～。んふんふんふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0103116" ]},
		{"command":[ "SETIMAGE", "0", "still_00025401_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「くやし～ですか～？　くやし～ですよね～。わたしみたいなちびっこに～。\n自分の弱点♪　一番敏感な部分をいじくり回されて、なぶられて♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0103117" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「ほーらほら、すりすりすり～♪　キメ細やかなタイツの感触でぇ、粘膜をも\nてあそばれて、ぐにゅぐにゅこすられて……。あっはっはっはっはっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0103118" ]},
		{"command":[ "SETIMAGE", "0", "still_00025401_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「なっさけないですね～♪　こ～んな姿～？　いつも隊長さんのこと……信頼\nしている、憧れている、恋してる人達が見たら幻滅確定ですよね～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0103119" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「さ～いてい♪　さ～いあく♪　ド変態ドMちんちん♪　罵倒されてま～た興\n奮してる～♪　やぁっば♪　裏筋と血管が浮き上がってるんですけど！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0103120" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「……ほ～んと、よくもまあ……。足コキ初体験、超初心者のわたしの……た\nどたどしい愛撫でここまでビンビンにしちゃえますよね～？　ヒきます～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0103121" ]},
		{"command":[ "SETIMAGE", "0", "still_00025401_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「……ん？　ちょっと変質者さ～ん？　なんかちんちんの先っちょから、透明\nな……。ヘンなお汁が滲み出してきてるのですが～？　なんですコレは？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0103122" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「……はぁ！？　わたしの足がモゾモゾちんちんの上を這い回るせいで、おか\nしな気分になってきた？　わ、わ、わたしのせいにしないでもらえます～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0103123" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「これっ！　このちんちんがっ！　いけないっ！　んですよねっ！　わたしの\nっ！　せいじゃないのですっ！　このちんちんがエロいのですっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0103124" ]},
		{"command":[ "SETIMAGE", "0", "still_00025401_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「このっ、このぉ……！　んんっ！　なんだか更に抵抗する力が増してきてい\nるのです……！　お、おとなしく踏まれてよがっていてください～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0103125" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「いきますよ！　ぐりっ……ぐりっ、ぐりぐりっ！　お、おおお……。これく\nらい強くしても平気だなんて、ちんちんのパワーってすごいのです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0103126" ]},
		{"command":[ "SETIMAGE", "0", "still_00025401_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「これなら力いっぱいコスっても、いじってもいけそうですねっ……！　そぉ\nれっ、ぐりぐりっ♪　ぐにぐにっ！　ずりっ、ずりっ♪　ぐりぐりぃっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0103127" ]},
		{"command":[ "SETIMAGE", "0", "still_00025401_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「あれぇっ？　隊長さん……腰がヘコヘコ動いてますよぉ？　もしかしてぇ、\nわたしの足の動きに合わせて……もっと気持ち良くなろうとしてますです？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0103128" ]},
		{"command":[ "SETIMAGE", "0", "still_00025401_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「あはっ♪　あははは♪　いいですよ～、そんなに喜んでもらえているなら、\nこちらもちんちんを踏んでいるかいがあるってものです……。踏み、踏み」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0103129" ]},
		{"command":[ "SETIMAGE", "0", "still_00025401_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「ちんちんの形に添って～……ぐりっ、ぐりっ♪　一番ふと～い、でっぱって\nいるところをぐにっ、ぐにっ……。あとは裏筋ですかぁ？　ずり、ずりっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0103130" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「んふふふっ♪　さっすがに全知全能のわたしも……男の人がこ～んなに快感\nに弱いとは知りませんでした♪　なんて面白いのでしょう♪　ぐにぐに♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0103131" ]},
		{"command":[ "SETIMAGE", "0", "still_00025401_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「あはっ♪　はぁっ……♪　敏感な反応……楽しすぎです♪　そんなにちんち\nんをピクピク痙攣させられたら……仕方ないのです♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0103132" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「わたしが♪　隊長さんをとびっきり気持ち良くしてあげます……♪　んんっ\n……、こうですね♪　これがいいんですね♪　踏み、踏み、踏みっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0103133" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「あれあれ～っ？　隊長さぁん、ちんちんの反応が激しくなってきましたよぉ\n？　ど～したんですか？　ちんちんどうなっちゃうんですか～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0103134" ]},
		{"command":[ "SETIMAGE", "0", "still_00025401_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「ぜ～んぜんわかりません～♪　でもぉ、お望みでしたらいっぱい強～く踏み\nしめてあげますね♪　ぐりぐりぐり♪　あっ、痙攣してますぅっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0103135" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「は～い、ぴゅっぴゅ～♪　ぴゅっぴゅっぴゅ～♪　足の裏なんかでカンタン\nにイかされちゃって、せ～えきぴゅっぴゅしちゃって恥ずかしいのです～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0103136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00025401_01_04" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「……へ？　せ～えきの存在を知っていたのか……！？　ふ、ふざけないでほ\nしいのです！　全知全能の黒き神に知らないことなどありません！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0103137" ]},
		{"command":[ "SETIMAGE", "0", "still_00025401_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「わ、わたしの見た目がちっちゃいからってバカにして……！　な・め・な・\nい・でほしいのです！　許せません！　こうなったら徹底的に絞ります！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0103138" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「そぉれっ！　出すのです！　ありったけせ～えきを撒き散らすのですっ！　\nこのっ……このっ、ただの人間ごときがナマイキな～っ！　もっとですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0103139" ]},
		{"command":[ "SETIMAGE", "0", "still_00025401_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「はぁ！？　こんなものではありませんよね！？　もっと出すのですっ！　び\nゅぶーっ、びゅぶーっとマヌケな喘ぎを漏らしながら出しまくるのです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0103140" ]},
		{"command":[ "SETIMAGE", "0", "still_00025401_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「はーっ、はーっ、はーっ……。ふ～……♪　どうなのです？　これで、どち\nらが格上の存在か……。隊長さんが誰を崇めるべきかハッキリしましたね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0103201" ]},
		{"command":[ "SETIMAGE", "0", "still_00025401_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「あ～ああ……。わたしの素晴らしい足がせ～えきでドロッドロなのです……\n。ど～やってつぐなうつもりなのです？　んん？　それそれそれそれぇ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0103202" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「……あ～♪　そ～なのですか♪　ま～たすぐに勃起して、もう一度足コキで\n遊ばせてやるから許せ、ということです？　は～どうしましょう～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0103203" ]},
		{"command":[ "SETIMAGE", "0", "still_00025401_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「２回も続けて足でコくのは疲れますし～。ダルいですし、わたしに得もあり\nませんし～？　でも、おねがいされたのなら仕方ありませんですね～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0103204" ]},
		{"command":[ "SETIMAGE", "0", "still_00025401_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「いいですよ、このせ～えきまみれのクサクサよわちんちん！　わたしの足で\nなくっちゃイケなくなるまで遊んであげます。心から感謝するよ～に～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0103205" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「……んふふふっ。それじゃあこのぉ～、ばっちいばっちいベタベタちんちん\nの～♪　ま～っしろな精液をわたしの足の指で塗り広げていってあげますぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0103206" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「そぉ～れ♪　そぉ～れぇ～♪　あはっ、ニュルニュルしててヘンなカンジで\nすねぇ～？　せ～えきってぇ、ローションやジェルとも違ってぇ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0103207" ]},
		{"command":[ "SETIMAGE", "0", "still_00025401_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「独特のにゅぶにゅぶ感があるんですよねぇ～♪　しかも、……ほらっ♪　ほ\nらほらほらっ！？　わかりますか！？　この強烈な臭い！　ううううぇ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0103208" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「きちゃな～い♪　こんな臭いの、女の子のカラダからは出るコトないのです\n～♪　なのに隊長さんのちんちんからドクドク溢れ出しちゃって～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0103209" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「ヤ～だヤだ、キモチわ～る～いのですぅ～♪　……って、それならなんでシ\nゴくのをやめないのか、ですか？　決まってるじゃないですかぁ～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0103210" ]},
		{"command":[ "SETIMAGE", "0", "still_00025401_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「ブザマに感じている隊長さんの、今にも泣きそ～な顔をじ～っくり観察して\nるのです♪　それそれそれ♪　にゅちにゅちにゅち♪　聞こえますぅ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0103211" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「わたしの足の裏とぉ、隊長さんのちんちんの表面とで、いやらし～音鳴っち\nゃってますですよぉ～？　んはははっ♪　もっと聞かせてほしいのです♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0103212" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「そぉ～れ、ぐっちゅっぐっちゅっにゅっぷっにゅっぷっ♪　あは～～っ♪　\nタイツにせ～えきが染みこんできて生あったか～い♪　粘りすぎ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0103213" ]},
		{"command":[ "SETIMAGE", "0", "still_00025401_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「キモキモのキモなのです♪　えぇ～♪　わたしみたいなナマイキな女の子に\nぃ、一方的に搾取されて、ビクビクちんちん喜ばせて♪　ありえないです♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0103214" ]},
		{"command":[ "SETIMAGE", "0", "still_00025401_01_04" ]},		
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「なんなんですかぁ？　このちんちん！　んふっ♪　力をこめればこめるほど\n、強く踏んであげればあげるほど勃起力が上がってくるです～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0103215" ]},
		{"command":[ "SETIMAGE", "0", "still_00025401_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「恥を知れ～♪　……んふっ！？　う、わ……♪　せ～えきでドロッドロなの\nに、更に再びちんちんの先っちょからお汁もしたたらせちゃって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0103216" ]},
		{"command":[ "SETIMAGE", "0", "still_00025401_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「ぷくくく♪　汁だくエロエロちんちんは成敗するで～す♪　えいっ、えいっ\n……えいえい♪　あれ～？　イジメられてまた昂ってるのですか～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0103217" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「こうですか？　それともこう？　足コキなんかです～ぐせ～えき溜まっちゃ\nうんですね～♪　んん？　出したいのですか？　あがってきてるのですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0103218" ]},
		{"command":[ "SETIMAGE", "0", "still_00025401_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「えぇ～♪　んふふふっ、どうしましょうかね～？　このままギュッ♪　と親\n指で圧力をかけて……ず～っと出せなくしてあげてもいいのですが～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0103219" ]},
		{"command":[ "SETIMAGE", "0", "still_00025401_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「んっ♪　それじゃああまりにもかわいそ～ですので、しっかりイカせてあげ\nるのです♪　ほらほらっ、足で絞り抜きますよぉ～！　ん～～～～っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0103220" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「きゃはぁっ♪　あはっ、あはははっ、びゅるーっ♪　びゅるるーっ♪　待っ\nてほしいのです～っ♪　一度目より勢いが凄まじいのです～っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0103301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00025401_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「えっ？　えっ！？　どういう構造してるんです！？　隊長さんのちんちんっ\n……！　ヤッバいくらい出てるのです、大噴火って感じなのです！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0103302" ]},
		{"command":[ "SETIMAGE", "0", "still_00025401_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「うわ～～～～♪　うわぁ～～～～♪　びゅぶーっ、ばびゅーって、飽きもせ\nずちんちんが痙攣して、無限に白い汁が出てくるです～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0103303" ]},
		{"command":[ "SETIMAGE", "0", "still_00025401_01_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「あっ♪　熱いっ……！　ちょっとぉ、あんまりタイツにかけないでほしいの\nです！　あっ♪　あっ♪　クサクサせ～えきがとれなくなりますからっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0103304" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「って言ってるのに～♪　こっちがしおらしくお願いしてもぉ、完全無視でび\nゅるびゅる爆発させちゃってるじゃないですか～♪　止められないのです？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0103305" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「あはっ♪　あはっ♪　足にへばりつくこの感触ぅ……♪　一生忘れられませ\nんよぉ♪　ひゃ～っ、壊れた蛇口みたいに出てます～っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0103306" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「ん、ふふ♪　やっとなのです？　や～っと全てを出し尽くしたのです？　あ\n～あ～♪　とんでもない惨状ですよ、あたりそこらじゅうせ～えきまみれ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0103307" ]},
		{"command":[ "SETIMAGE", "0", "still_00025401_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「でも～、こちらも楽しくなくはなかったですよお～？　ちんちんで遊ぶのっ\nて、面白いし笑えるんですねぇ～♪　ぷくくく♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0103308" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「……え？　本来なら、この量のせ～えきが、おなかの中に……アソコに注が\nれるモノなんだぞ、って……？　うッ！？　それは想定してなかったのです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0103309" ]},
		{"command":[ "SETIMAGE", "0", "still_00025401_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「へ、へ～……？　そ～なんですか～……？　ま、まあわたしには関係ありま\nせんけどね～♪　いつか注げるといいですね、応援してますです～……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},
		
		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「ひぁっ！？　んえええっ！？　ちょっ、ちょっと隊長さんっ！　せ～えきを\n飛ばしすぎなのですっ！　んひゃぁあっ、う、ウソでしょう！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0103401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00025401_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「何をど～やったら、足でシゴいたちんちんから！　わたしの顔や胸にまで…\n…んぷぷぷぷぅっ！？　せ～えきが飛んでくることになるのですぅうう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0103402" ]},
		{"command":[ "SETIMAGE", "0", "still_00025401_01_12" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「あッ♪　こ、これ止められないんですかぁっ！？　ひゃんっ！　あぁううう\nっ！？　一回目より高く遠く飛ばすなんて、普通ありえないのですぅっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0103403" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「んぷぅっ、んうぅうっ！　あっ！　苦いです、口に入りましたぁ……！　そ\nれに胸ぇ……、だ、誰にも触らせたことすらない胸にせ～えきがぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0103404" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「こ……これをもし、狙ってやっているなら、隊長さんはわたし以上のサドで\nす、イジワルですっ……！　ひぁっ！？　も、もう充分ですからぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0103405" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「かけないで、あっついんですぅっ！　ヌルヌルもドロドロも、足だから心の\n準備ができていたわけでぇっ、それより上は無理なのです～～～～～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0103406" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「っぷぅう……っ。や、やっと終わりましたね……っ。こちらの制止もきかず\n、好き勝手にやりたい放題ぶちまけてくれちゃったようですが……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0103407" ]},
		{"command":[ "SETIMAGE", "0", "still_00025401_01_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「ま、まあわたしは隊長さんと違って？　精神的に大人ですし、全知全能の黒\nき神ですから……？　この程度の凡人の行動は想定済み……って」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0103408" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「は、はいぃ、ウソです！　大嘘なのです！　う……うふふふ、もうやめてほ\nしいのです……。ちんちんピクピクさせないでください……すみませぇん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0103409" ]},
		{"command":[ "SETIMAGE", "0", "still_00025401_01_11" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「うぁああ……。調子にのって隊長さんを挑発したら、こういうことになるの\nですね……。よ、よ～く覚えておきますです……はい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0103410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}