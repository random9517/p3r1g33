        {"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "女怪人" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……ま、また負けた……！　くそっ、こんなアホアホ三姉妹に \n……っ」", "NORMAL" ]},
        {"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「……ええ？　あたしもアホ扱いぃ……？　そりゃないよ……トホホ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "102_010021010040" ]},
		{"command":[ "SETCHARA", "0", "char_00010201_01", "4", "LEFTEND", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
        {"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「って、破お姉ちゃんがヘコんでる間に、また逃げちゃったけど……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "103_010021010037" ]},
		{"command":[ "SETCHARA", "1", "char_00010301_01", "0", "RIGHTEND", "0" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "SPOTCHARA", "1" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「何のんびりしてるの、二人共！　早く追うです！　また赤点でいいの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "101_010021010041" ]},
		{"command":[ "SETCHARA", "2", "char_00010101_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "2", "TRUE" ]},
		{"command":[ "SPOTCHARA", "2" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「いいわけないでしょ！　さあ、また追っかけっ子の始まりよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "102_010021010041" ]},
		{"command":[ "SETCHARA", "0", "char_00010201_01", "7", "LEFTEND", "0" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "逃げ出した女怪人を追って公園を出て、道路を走る三人。そしてついに女怪人 \nを追い詰める。", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
        {"command":[ "SETIMAGE", "0", "bg_0006" ]},
        {"command":[ "DISPIMAGE", "0", "true" ] },
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "DISPCHARA", "2", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "逃げ場を失った女怪人が三姉妹を睨みつけた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "女怪人" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……クソっ……どうしてこんなことに……」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「はー……はー…………一番乗りぃ……あーうー、いっぱい汗かいちゃったよ \nぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "103_010021010038" ]},
		{"command":[ "SETCHARA", "1", "char_00010301_01", "4", "RIGHTEND", "0" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "SPOTCHARA", "1" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「ふぅ……もう走り回るのは勘弁したいなぁ……ということで、もう逃げない \nでね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "102_010021010042" ]},
		{"command":[ "SETCHARA", "0", "char_00010201_01", "0", "LEFTEND", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "女怪人" ]},
		{"command":[ "SETTEXT", "「くぅ……貴様ら……だ、誰が逃げるものか！　ちょ、ちょっと形勢を立て直 \nすため、戦略的な撤退をしただけだ」", "NORMAL" ]},
		{"command":[ "SPOTCHARA", "3" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「なんとまあ、往生際の悪い……では、そろそろテストのため、私達の犠牲に \nなるです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "101_010021010042" ]},
		{"command":[ "SETCHARA", "2", "char_00010101_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "2", "TRUE" ]},
		{"command":[ "SPOTCHARA", "2" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "女怪人" ]},
		{"command":[ "SETTEXT", "「て、テスト……？　さっき正義がどうとか言ってなかったか？」", "NORMAL" ]},
		{"command":[ "SPOTCHARA", "3" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「もちろん、正義のためが一番の目的です！　あなたは正義と、赤点回避のた \nめ、星となるのです……さあ、覚悟！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "101_010021010043" ]},
		{"command":[ "SPOTCHARA", "2" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "勝利を確信する三人だったが、女怪人は余裕の笑みを浮かべる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SPOTCHARA", "0","1","2" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "女怪人" ]},
		{"command":[ "SETTEXT", "「……ふふふ、はははは……あーっはっはっは！！！」", "NORMAL" ]},
		{"command":[ "SPOTCHARA", "3" ] },
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「なっ……そ、その悪人笑い…………まさかリアルでそんな笑いが見られるだ \nなんて……敵ながらあっぱれ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "101_010021010044" ]},
		{"command":[ "SPOTCHARA", "2" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "女怪人" ]},
		{"command":[ "SETTEXT", "「ほざけ！　ただ闇雲に逃げ回ってたと思ったのか？　戦略的な撤退と言った \nだろう！」", "NORMAL" ]},
		{"command":[ "SPOTCHARA", "3" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「……何よ。いったいどういうつもりなの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "102_010021010043" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "女怪人" ]},
		{"command":[ "SETTEXT", "「ふっふっふ、あれを見るがいい！」", "NORMAL" ]},
		{"command":[ "SPOTCHARA", "3" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "女怪人が指した先には、高い塀に囲まれた大きな屋敷が見えた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "DISPCHARA", "2", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「……ちょ、ちょっとぉ……あれ、エッチなホテルでしょ～～？　もう、急み \nたいな子には刺激が強すぎるってばぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "102_010021010044" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETCHARA", "2", "char_00010101_01", "7", "CENTER", "0" ]},
		{"command":[ "SETCHARA", "0", "char_00010201_01", "1", "LEFTEND", "0" ]},
		{"command":[ "SETCHARA", "1", "char_00010301_01", "0", "RIGHTEND", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "DISPCHARA", "2", "TRUE" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「……ラブホテルぐらい知ってるってばぁ。あれでしょ？　お盛んになるんで \nしょ？　ベッドの上で」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "103_010021010039" ]},
		{"command":[ "SPOTCHARA", "1" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「こらっ、急！　知らない人の前で、そんな話しちゃ駄目でしょ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "101_010021010045" ]},
		{"command":[ "SPOTCHARA", "2" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "女怪人" ]},
		{"command":[ "SETTEXT", "「あ、あれはラブホテルじゃない！　ムーンランド公国の大使館だ！　ここで \n騒ぎを起こせば国際問題になるだろうな」", "NORMAL" ]},
		{"command":[ "SPOTCHARA", "3" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「ムーン、ランド……公国？　知らないなぁ……でも、大使館の前で騒いだだ \nけで、国際問題に発展するの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "103_010021010040" ]},
		{"command":[ "SPOTCHARA", "1" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「うーん……まずいといえば、まずい…………のかな？　でもまあ、騒ぎにな \nるのはマズイかも……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "102_010021010045" ]},
		{"command":[ "SETCHARA", "0", "char_00010201_01", "3", "LEFTEND", "0" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「じゃあ、どうすんの？　このまま見逃しちゃうの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "103_010021010041" ]},
		{"command":[ "SPOTCHARA", "1" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「そんなわけないでしょ！　正義と成績のため、私達が頑張らなきゃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "101_010021010046" ]},
		{"command":[ "SPOTCHARA", "2" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "女怪人" ]},
		{"command":[ "SETTEXT", "「……いいのか？　国際問題になるぞ」", "NORMAL" ]},
		{"command":[ "SPOTCHARA", "3" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ただの女学生が、調子に乗ってはしゃいだだけ！　そう主張するです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "101_010021010047" ]},
		{"command":[ "SPOTCHARA", "2" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "女怪人" ]},
		{"command":[ "SETTEXT", "「な……んだと……世間はそこまで女学生に甘いのか……？」", "NORMAL" ]},
		{"command":[ "SPOTCHARA", "3" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「そもそも、騒ぎになるまえにあなたを片付ければ問題なしなしです！　いく \nですよ、二人とも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "101_010021010048" ]},
		{"command":[ "SPOTCHARA", "2" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「おっけー……じゃ、このままガチッちゃう？　ほんとはもっと小細工を張り \n巡らせたいところだけどね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "102_010021010046" ]},
		{"command":[ "SETCHARA", "0", "char_00010201_01", "7", "LEFTEND", "0" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「……やっと、血祭りに挙げられる。おっと、場所的にそういうのは良くない\nのかな……？　ま、どうでもいっか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "103_010021010042" ]},
		{"command":[ "SETCHARA", "1", "char_00010301_01", "6", "RIGHTEND", "0" ]},
		{"command":[ "SPOTCHARA", "1" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "女怪人" ]},
		{"command":[ "SETTEXT", "「くぅ……お前達、自分が何を言ってるのかわかってるのか？　国際問題だぞ \n？」", "NORMAL" ]},
		{"command":[ "SPOTCHARA", "3" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「国際問題……？　うーん……わかんなーい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "103_010021010043" ]},
		{"command":[ "SPOTCHARA", "1" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "女怪人" ]},
		{"command":[ "SETTEXT", "「くそっ、ことの重大さを理解できぬほど、バカどもだったか……わ、わかっ \nた。じゃあ、こうしよう。金をやる」", "NORMAL" ]},
		{"command":[ "SPOTCHARA", "3" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "ジリジリと狭まっていた三人の輪が、ピタリと動きを止めた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「な、い、い、いいいいい今更何を言ってるですか！？　この私達をば、ば、 \n売春しようとするだなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "101_010021010049" ]},
		{"command":[ "SETCHARA", "2", "char_00010101_01", "3", "CENTER", "0" ]},
		{"command":[ "SPOTCHARA", "2" ] },
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「お姉ちゃん、『買収』ね。春を売っちゃ駄目。そっちの方が色々ヤバいから \n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "102_010021010047" ]},
		{"command":[ "SETCHARA", "0", "char_00010201_01", "0", "LEFTEND", "0" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「そ、そうね……よよ。よし、じゃあとりあえず、話を──」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "101_010021010050" ]},
		{"command":[ "SPOTCHARA", "2" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「え～～い！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "103_010021010044" ]},
		{"command":[ "SETCHARA", "1", "char_00010301_01", "7", "RIGHTEND", "0" ]},
		{"command":[ "SPOTCHARA", "1" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "女怪人" ]},
		{"command":[ "SETTEXT", "「ほげぇぇえ！！？　な、なんだ？　取引に応じる空気だったじゃないか！　 \nいきなり何をする！」", "NORMAL" ]},
		{"command":[ "SPOTCHARA", "3" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「いや、その……お金なら、倒してから奪えばいいかなーって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "103_010021010045" ]},
		{"command":[ "SETCHARA", "1", "char_00010301_01", "6", "RIGHTEND", "0" ]},
		{"command":[ "SPOTCHARA", "1" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「……あ、なるほど。その発想はなかったわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "102_010021010048" ]},
		{"command":[ "SETCHARA", "0", "char_00010201_01", "6", "LEFTEND", "0" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "女怪人" ]},
		{"command":[ "SETTEXT", "「そ、それでいいのか！？　正義の味方！」", "NORMAL" ]},
		{"command":[ "SPOTCHARA", "3" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「正義を行うには、いろいろと入用なの！　活動資金のためには、仕方ないの \nです。そーいうことなのですっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "101_010021010051" ]},
		{"command":[ "SETCHARA", "2", "char_00010101_01", "7", "CENTER", "0" ]},
		{"command":[ "SPOTCHARA", "2" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "女怪人" ]},
		{"command":[ "SETTEXT", "「ぐぅ……本当にヤバいな、お前ら……」", "NORMAL" ]},
		{"command":[ "SPOTCHARA", "3" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「話はもうお仕舞いですね？　それじゃ……破、急……為すべきことは唯一つ \n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "101_010021010052" ]},
		{"command":[ "SETCHARA", "2", "char_00010101_01", "0", "CENTER", "0" ]},
		{"command":[ "SPOTCHARA", "2" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "三人" ]},
		{"command":[ "SETTEXT", "「悪・即・斬！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "101_910021010053" ]},
		{"command":[ "SETCHARA", "2", "char_00010101_01", "7", "CENTER", "0" ]},
		{"command":[ "SETCHARA", "0", "char_00010201_01", "7", "LEFTEND", "0" ]},
		{"command":[ "SETCHARA", "1", "char_00010301_01", "7", "RIGHTEND", "0" ]},
		{"command":[ "SPOTCHARA", "0","1","2" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "三人" ]},
		{"command":[ "SETTEXT", "「不言行殺三姉妹！　サムライテール！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "101_910021010054" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
