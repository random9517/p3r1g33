{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ど……どうしたの？　いきなり、こんなところに連れ込んで……。えっ？　\nふ、二人っきりになりたかった……？　……嬉しい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1303101" ]},
		{"command":[ "SETCHARA", "0", "char_00000213_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「って、どうしてもしてほしいことがある？　何？　散多の術をここで使って\n欲しい？　それで、オチンチンを分身と舐めて欲しい……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1303102" ]},
		{"command":[ "SETCHARA", "0", "char_00000213_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「……やっぱり、スケベなお願いだった。ロマンチックなムードを期待した私\nが馬鹿だった……けど。本当に、してほしいのなら……しても、いい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1303103" ]},
		{"command":[ "SETCHARA", "0", "char_00000213_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「大事なあなたの一生のお願いなら……。そう……わかった。月影流忍術奥義\n・散多の術（さんたのじゅつ）……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1303104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「……これは幻影じゃなく、実体が２つに分かれているから……ぺろっ……。\nこうして、同時に奉仕出来る。オチンチンを２倍気持ち良く出来ると思う」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1303105" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00000213_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「そして私が２人目のカグヤ。あなたから見て左の方。完全に意識も２つにわ\nけたから、別々の動きが可能になった。その分楽しんでもらえる、かな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1303106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「これは実際にやってみた方がわかりやすいと思う……。早くしろって？　\nぅ……わかった。始めるね……。んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1303107" ]},
		{"command":[ "SETIMAGE", "0", "still_00000213_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んっ……れろっ……れろっ、ぴっちゃっ……。ん、ふぅ……。汗の臭いと、\nしょっぱい味……。今日はまだお風呂に入ってないの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1303108" ]},
		{"command":[ "SETIMAGE", "0", "still_00000213_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「そう、なんだ……。ん、いいよ。私が汚れたところを……綺麗にするから。\nれろ……れろ、れろ……。こ、こんな……感じ？　れろっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1303109" ]},
		{"command":[ "SETIMAGE", "0", "still_00000213_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「……待って。私もする……。私が術を使ったんだから私に責任がある……。\n任せて。……ちろっ、ぴちゃ、ぺっちゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1303110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ん……ん……んっ。すごく反応してる……。私、見ないから。いいよ、素直\nに感じて……。れろっ、れろ、れろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1303111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「む……随分気持ちよさそう。感じるのはいいけど、私が本物のカグヤだから\n……私がする。ンッ、ぴちゃ、ぴちゃ、ぴちゃぴちゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1303112" ]},
		{"command":[ "SETIMAGE", "0", "still_00000213_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ん、気を使わないでもう一人の私……私の方が上手に出来るから。こうして\n裏筋から、カリ首まで的確に舐め上げて……んっんっ。こうすればいい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1303113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「それは私も知ってる……。あなたこそ、私にまかせて。　んん、れろ……。\nね？　出来てるでしょ……。大丈夫だから……。ぴちゅっ、くちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1303114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あ……い、いいから。私がする……。　ね？　私の方が気持ちいい……よね\n。くちゅっ、ぴちゃぴちゃぴちゃ、くっちゅっ……どう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1303115" ]},
		{"command":[ "SETIMAGE", "0", "still_00000213_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「え……？　二人で争っていてもしょうがない？　どっちがどっちかわからな\nい？　そ……それはそうだけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1303116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「自分自身ってわかっていても、あなたのをするのは私がいい……。だから判\n断して。どっちがより多く快感を与えたか、測ってほしい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1303117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「頑張るから……ぐちゅっ……れるれるれるれるれるれる……くっちゅっ。ぺ\nろっ、ぺろっ、れろれろれろ……ちゅるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1303118" ]},
		{"command":[ "SETIMAGE", "0", "still_00000213_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「そう……。うまく出来たら選んでくれたら、いい……。二つの舌、どっちが\n気持ちいい……？　ちゅっ……チュ、ちゅっ……ちゅく」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1303119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「チロッ、ちろ、舌を尖らせてつついたり……。んんんむ……。一度にオチン\nチンを丸ごと全部唾まみれにしたり……。じゅる……じゅるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1303120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「努力は得意だから……。はぷッ……。ん、ん、ん、んん……。ちゅぷっ……\nちゅっくっ、ぺろ……れろ……れろ、れろ、れろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1303121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「はぁっ。長い付き合いだから　感じるところは大体わかってる……。っぷち\nゅっ。ちゅっ、クチュッ……ちゅっ、ぺろっ、れろ、れろ、れる、れるん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1303122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ん……。すごい。肉棒から放たれる熱気で、頭がぼうっとしてきた……。い\nつもだんだんこうして身体が熱くなる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1303123" ]},
		{"command":[ "SETIMAGE", "0", "still_00000213_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「私も……私も、オチンチンに吸い寄せられてる……。とてつもない引力……\n。……ぺちゃっぺちゃぺちゃっ……ちゅぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1303124" ]},
		{"command":[ "SETIMAGE", "0", "still_00000213_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁ、はぁ、はぁ……。二人でするの、難しい。うまく舐められな\nい……。どいて……。ぴちゃっ！　ぺっちゃっぴちゃっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1303125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あなたこそ退いて……。んむっ……。舐めたいところに割り込んでくる、か\nら……。舌がぶつかって……接吻になってしまう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1303126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「チュッ……！　あっ……。自分の唇に口づけなんてしてる場合じゃない……\n。私は、ご奉仕してほしいって言われたから。んっんっんん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1303127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「そう。分身同士で一本を奪い合っている場合じゃ……んんぁっ……。チュッ\n……んっ、ま、また……！　どっちも退かないから大変……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1303128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「女同士でこんなことしたって、オチンチンが硬くなるわけじゃないのに……\n。って、あ、あれ？　なんだかさっきより太くなってる……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1303129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「もしかして……。２人の私がもみくちゃになってるの……時々ぶつかってキ\nスしてるのを見ると興奮するの？　……そ、そうなんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1303130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「お肉が今にも破裂しそうなくらいに膨張して……！　ンン……！　ぐいぐい\n舌を押し戻してくる……。なんて強い精力の持ち主……ぺろっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1303131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「女を陶酔させて、発情に導く最高のフェロモンが漏れ出てるよ……。あぁ…\n…、れろっ、ぴちゃっぴちゃっ、くちゅ……。え？　射精したくなった？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1303132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「うん。うん、うん……。いつでも出していいよ。私、待ってる……待ってる\nから……。注いで……れろ……れろれろれろ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1303133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あ……出来るなら、私の口の中にも欲しい……。ちゅぱっ、ちゅぱっ………\n…。お願い……くちゅ……ちゅぷっくちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1303134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んむぅ……！　いっぱい……いっぱい出た……。これは、私がうまくできた\nから……？　ぷぁ……そうだったら嬉しい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1303135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000213_01_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「違う……。私が心を込めて奉仕したから……。そうだよね？　私の方が気持\nち良かったはず……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1303136" ]},
		{"command":[ "SETIMAGE", "0", "still_00000213_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「こんなにたくさん出して……。舌が全部埋まるくらい、信じられない量が出\nてる……。ん、ん……これは私の影響……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1303137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「そうかも……でも、とっても苦くて濃い精液になったのは私の成果。あなた\nは先端ばかり舐めていた、でも私は陰嚢や男根も丁寧に愛撫したから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1303138" ]},
		{"command":[ "SETIMAGE", "0", "still_00000213_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「気持ち良く射精出来るように、尿道口を舐めてほぐして広げたのは私だから\n……あっ。勢い良く噴き上がって……。ふぅうう……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1303139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あっあっあっ！　シャワーみたいに降り注いだお汁を多く飲んでるのは私の\n方……。それは好きだから、たくさん喜んでほしいから……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1303140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「むうう……。一回だけじゃ、どっちが優れていたかよくわからない。勝負を\n続行する。このままじゃ、悔しくて終われない……。いい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1303201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「望むところ……。今度こそちゃんと見てて。私ももっと努力する……。たと\nえば、……んぐっ、ごくんっ……ごくっ。こうやって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1303202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「出したての精液を、躊躇なく飲み干すことも……。それに……んれろっ、こ\nうして、お汁まみれのオチンチンをすぐにお掃除フェラしてあげたり……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1303203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ぴちゃっ……ぴちゃっ、れろっ……れろぉ……れろっ、ごきゅ……♪　ごく\nんっ……れろっ……♪　レロッ、れろ……れろぉおお……ぴちゃっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1303204" ]},
		{"command":[ "SETIMAGE", "0", "still_00000213_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あっ！　ズ、ズルい……！　私もするっ……！　れろっ……れろ……れるぅ\nっ……。ぴちゃっ、ぴちゃ、ぴちゃ、ぴちゃ……んんん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1303205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「精液の臭いと味で頭がクラクラする……。いつもよりえぐみが強いみたい？\n　喜んでくれてるんだ……。また、気持ち良くするから……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1303206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ぺちゃっ、ぴちゃっ、ぴちゃっ、くっちゅっ……。ぢゅるるるる……。尿道\nに残った分まで全部もらうね……。ぢゅるっ、ぢゅるるるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1303207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「私はこぼれた分……。一滴だって無駄になんかしない……。れろっ……れろ\nっ、ごくっ……。ごきゅっ……美味しい……もっと欲しい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1303208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ん……やるね……あなた。さすが私……。このオチンチンの悦ぶところを知\nり尽くしてる……。負けないけど、少し……感心した」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1303209" ]},
		{"command":[ "SETIMAGE", "0", "still_00000213_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んんっ、あ、ありがと……。あなたもすごい。尽くし方が、全身全霊ご奉仕\nしたいってわかるくらい。学ぶべきテクニックも、ある……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1303210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「……せっかく二人いるんだから……二回目はあなたと協力してしたい。二人\nで、全力で好きな人を……イかせる。そういうのって、どう？　れろっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1303211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「……他の誰かに譲るのは嫌だけど……。うん。あなたは私だから……。協力\nする。二人でなら、きっとこのオチンチンを射精に導ける」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1303212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「わかった。最初は……はぁ、はぁ……私がオチンチンの全部を、まずは丁寧\nにねぶって清める……。あーん……れろぉ……れろ、れろぉおお……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1303213" ]},
		{"command":[ "SETIMAGE", "0", "still_00000213_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「次は……私が先端を舐めるから、あなたは肉竿をおしゃぶりしていいよ。交\n代しながら、あらゆる部分を二つの舌で舐めつくして……れろ、れろれろ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1303214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あ……ありがと……。うん、サポートは得意……。平等に、だけど激しく…\n…ぺろっ。れろっ、れろ……ぴちゃっ、ぴちゃ、ぴちゃっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1303215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んん……！　んん……んっ、んんん……！　競い合う相手がいると……熱が\n入る……。舐める……舐め回す、おしゃぶりする……ぢゅるぢゅるぢゅる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1303216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んぷぁ……っ、れろぉ……れろっ、くちゅ。くちゅっ、くちゅ……！　んぁ\nあ……。お口に入りきらないくらい高まっている……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1303217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ん、あぁ……っ。今にも新鮮な精液がビュルッビュルッと飛び出してきそう\n。はむ、　んん……元気で格好のいいオチンチンでうれひい……ん、む」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1303218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「いいよ……。私達、どっちもあなたが射精するの、待ってるから……。ラス\nトスパート……ぢゅるぢゅるぢゅるっ、くちゅっ、ぢゅるぢゅるぢゅる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1303219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「好きなところに、出ひて……。んっ、はぷっ……くちゅるちゅるちゅるっ！\n　ぢゅっ……ぢゅるるるじゅるううう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1303220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ああっ！　や、やった……！　んぁああっ……こっち、こっち……。あむっ\n……！　んぷっ……。ンッ、んっんっんん……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1303301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000213_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あ、ああ……ぁ、舌いっぱいに広がるこの味、この芳香……あなたの味……\n。もっと、もっと……。全部私の口に流し込んで……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1303302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んー……っ。あは……、んんん……。ひゅごい。いっぱい出らねぇ……。こ\nれ、私の口内にかけてくれた分は、私のもの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1303303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「うん、だけど私の口にびゅるっびゅるって飛び込んできた分は私の分……。\n最大限に、舌の上に溜めて、溜めて、……独り占めする。ごくっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1303304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んんん……！　ごくんっ。　ごくっ……。ああああ……！　脳天が痺れるく\nらいに美味しい……。ん……。私、上手に飲めたよね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1303305" ]},
		{"command":[ "SETIMAGE", "0", "still_00000213_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「やっぱり、私の方があなたのことを……。って、待って。私が飲んだ量より\n、あっちが飲んだ量が多い。やり直し……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1303306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「まさか……絶対に嫌！　そっちの精子の方が白くて濃かった。だけど、私が\nもらった分はあげない。これは私の……もう胃に飲み込んだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1303307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「……あなたを２倍気持ち良く出来るけど、精液は半分ずつ分けることになる\n……。散多の術にはまだ改良が必要」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1303308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「でも、貴重な経験が出来た気がする。これからも、色んな術を編み出すから\n……気に入ったものがあったら、遠慮なく言ってほしい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1303309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「恥ずかしいけど……あなたがどうしてもって言うなら、私は……。ぁ……い\n、今の言葉は忘れて。や、やっぱり……恥ずかしくって……ううう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1303310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ああっ……。ああああっ……んあああああ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1303401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000213_01_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ぷぁっ、んぷっ、けほっ、けほ……！　あっ。あ、熱い、熱いっ……。激し\nすぎる精液の雨、白濁の嵐……凄まじすぎる……んっうっ……ううぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1303402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「はぁあああっ……！　そのまま、私達の顔で受け止める、から……よく狙っ\nて……！　うんっ……うん、そこ、そこ！　そこにかけて……ああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1303403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あぁぁ……っ。右に左に、かわるがわる精液が飛び交って……！　真っ白な\n精液が顔中に……。あ、熱い……すごいにおい……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1303404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ぷはっ。あぁっ……ああ……。わ、私の顔にまで……！　２人に出して、二\n度目なのにこんな量……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1303405" ]},
		{"command":[ "SETIMAGE", "0", "still_00000213_01_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「私１人じゃこぼしてしまいそうなくらいの精液……。ふぅっ……！　ふ、ぅ\nう……すごい。首の方まで垂れてきて……。あああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1303406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「とても満たされた気持ち……。はぁ、はぁ、私も身体に火が付いたみたいだ\nった……。口でしているだけですごく気持ちが良くて、夢中だった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1303407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「……あなたもそうなんだ。私と一緒……。この術、こっちの感度も２倍に増\nえている気がする……。顔がジンジンする」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1303408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「このまま……この熱さに、臭いにしばらく浸っていたい……。すぅううう…\n…。はぁあああ……。ああ、すごくいやらしいニオイ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1303409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「こんなにあなたが興奮してくれるなら、たまにこの術を使っても……。……\nあっ。ち、違う……誘っているんじゃないからね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1303410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}