{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0116" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_019" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「いいかぁ！　君に足りないのは、隊長としての心構えだっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021600001" ]},
		{"command":[ "SETCHARA", "0", "char_00004902_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「もっとこう……あのバカどもに、ビシッと言い返すぐらいの気概を持て！　\nいいなっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021600002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「下手に言い返したら、ボコボコにされるだろ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「それは君に威厳がないからだっ！　君に足りないのは、隊長としての威厳だ\nっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021600003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「さっきと言ってることが違うじゃねぇか……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ったく。今日はいつにも増して酔いつぶれてんな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020021600001" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「すまない。４人なんだが、席は空いているだろうか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021600001" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「いらっしゃい。そこの酔っ払いの近くでよかったら空いてるよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020021600002" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「問題ない。席まで案内してくれ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021600002" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「あいよ。ご新規４名様だな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020021600003" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「ここが正義（まさよし）か。感じのいい店だな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_010021600001" ]},
		{"command":[ "SETCHARA", "0", "char_00016001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「ここって名前もいいけど、料理も結構美味いんだ。姉御もきっと気に入ると\n思うぜ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_010021600001" ]},
		{"command":[ "SETCHARA", "0", "char_00020601_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「んん～～～？　おぉ、イグニスじゃないかぁ！　こんな時間にどうした……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021600004" ]},
		{"command":[ "SETCHARA", "0", "char_00004902_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「って、ら、ライオットぉ！？　それにフランカまで！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021600005" ]},
		{"command":[ "SETCHARA", "0", "char_00004902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「あぁ？　んだよ、アタシの名前を大声で叫びやがって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_010021600001" ]},
		{"command":[ "SETCHARA", "0", "char_00016101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「げっ！？　冴島じゃねぇか！　こんなところで、なにしてやがるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_010021600002" ]},
		{"command":[ "SETCHARA", "0", "char_00016101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「それはこっちのセリフだっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021600006" ]},
		{"command":[ "SETCHARA", "0", "char_00004902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「お前たち、長官と知り合いなのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021600003" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「私の記憶に該当する人物はいない。多分、一方的に知られているだけだろう\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_010021600002" ]},
		{"command":[ "SETCHARA", "0", "char_00016001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「アタシは知ってるっていうか、なんていうか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_010021600003" ]},
		{"command":[ "SETCHARA", "0", "char_00016101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「おいっ！　ここは私の心のオアシスなんだ！　邪魔者は帰れっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021600007" ]},
		{"command":[ "SETCHARA", "0", "char_00004902_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「誰が邪魔者だっ！　アタシたちは、普通に飯を食いに来たんだよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_010021600004" ]},
		{"command":[ "SETCHARA", "0", "char_00016101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「ってか、テメェみたいな酔っ払いがいると、飯が不味くなるだろうが！　勘\n定置いて、さっさと帰りやがれ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_010021600005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「なんだとぉ！？　私たちは先客だぞっ！　帰るなら、お前が帰れっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021600008" ]},
		{"command":[ "SETCHARA", "0", "char_00004902_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「ライオット！　入って早々、喧嘩をするんじゃない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021600004" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「この酔っ払いだけでも迷惑だってのに、また厄介者が増えやがったな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020021600004" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「姉御。あんなバカは放っておいて、アタシらはなに食べるか決めようぜ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_010021600002" ]},
		{"command":[ "SETCHARA", "0", "char_00020601_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「ああ、そうだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_010021600003" ]},
		{"command":[ "SETCHARA", "0", "char_00016001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「お前たちは随分とマイペースだな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021600005" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なあ。イグニスはともかく、このデカパイ女たち、長官の知り合い？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「知り合いというより、ライオットは因縁の相手だ。あとの二人の内、一人は\n情報だけ知っている」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021600009" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00004902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「えっと……そこのクールなヤツが、フランカ・マクマナス。どこの組織にも\n所属していない、フリーのエージェントだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021600010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ヴォーパル・バニーと呼ばれてるんだが……まあ、なんだ。簡単に言うと、\n倫理観が変に極振りされたヤバいヤツだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021600011" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「それと、さっきから口うるさく絡んできている眼帯女がライオット……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021600012" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「私設組織Ｆ．Ｉ．Ｒ．Ｅ．Ｓ（ファイアーズ）を率いるヤバいヤツで、とに\nかく反りが合わん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021600013" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「あと、マスク姿のデカパイ女は……よくわからん。見たことも、聞いたこと\nもないな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021600014" ]},
		{"command":[ "SETCHARA", "0", "char_00004902_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「とはいえ、フランカたちとつるんでるぐらいだし、ヤバいヤツに違いない！\n　私のカンがそう言っている！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021600015" ]},
		{"command":[ "SETCHARA", "0", "char_00004902_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「おい！　誰がヤバいヤツだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_010021600006" ]},
		{"command":[ "SETCHARA", "0", "char_00016101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「アタシをライオットの野郎と一緒にすんな！　あっ、でも、姉御と同じ扱い\nなのは、ちょっと嬉しいかも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_010021600003" ]},
		{"command":[ "SETCHARA", "0", "char_00020601_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「デビルトンファー。この店のオススメはなんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_010021600004" ]},
		{"command":[ "SETCHARA", "0", "char_00016001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「なんでフランカはそんなに落ち着いているんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021600006" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「私は誰にどう思われようと、構わないからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_010021600005" ]},
		{"command":[ "SETCHARA", "0", "char_00016001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「さっすが姉御！　そういうクールなとこ、マジカッコいい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_010021600004" ]},
		{"command":[ "SETCHARA", "0", "char_00020601_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「それにしても、長官がここまで毛嫌いするなんて珍しいな。なにがあったん\nだ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「よく聞いてくれたな、隊長！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021600016" ]},
		{"command":[ "SETCHARA", "0", "char_00004902_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「いいか！　この眼帯女とは、とにかく合わないんだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021600017" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「例えば、私が唐揚げを頼んでレモンをかけようとしたら、塩派のことも考え\nろとか言って、邪魔をして来るんだぞ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021600018" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「勝手にレモンかけようとしたら、怒られて当然だろ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「他にも、天ぷらを頼んだらつゆ派か塩派かで揉めるし！　だし巻きを頼んだ\nら、醤油かマヨネーズかで意見が分かれるし！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021600019" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「とにかく、あいつとはいろんな因縁があるんだ！　わかったか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021600020" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「それだけ聞くと、すげぇどうでもいい因縁としか思えないんだけど……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「あんだテメェ！　今の話のどこがどうでもいいってんだ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_010021600007" ]},
		{"command":[ "SETCHARA", "0", "char_00016101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「そうだぞ、隊長！　かなり重要な話だっただろう！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021600021" ]},
		{"command":[ "SETCHARA", "0", "char_00004902_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「今日はいつにも増して、賑やかになりそうだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021600007" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「賑やかどころか、忙しくなりそうだよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020021600005" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「店員さーん！　唐揚げ頂戴！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_010021600005" ]},
		{"command":[ "SETCHARA", "0", "char_00020601_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「私はお造り盛り合わせと、芋の水割りを」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_010021600006" ]},
		{"command":[ "SETCHARA", "0", "char_00016001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「あいよ。唐揚げとお造り、あと芋の水割りだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020021600006" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「っと、そうだ……おい、イグニス。悪いけど店を手伝ってくれ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020021600007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「えっ！？　なぜ私が店の手伝いをしなければならないんだ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021600008" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「面倒なヤツを連れてきた罰だ。しっかり働きな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020021600008" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「ちょ、ちょっと待ってくれ！　騒いでいるのはライオットで、私のせいでは\n……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021600009" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「いいからさっさと手伝いな。今日のまかない丼もサービスしてやるから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020021600009" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「くっ……！？　そ、そんなまかないで私が言いなりになるとでも……くうう\nっっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021600010" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00016704_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そう言いながらヨダレ垂らしてエプロンつけてんじゃねーか。体は正直だな、\nおい」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「先ほどの話に戻るが、この因縁の始まりを作ったのはライオットだ！　そう\n思うだろ、隊長！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021600022" ]},
		{"command":[ "SETCHARA", "0", "char_00004902_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「いいや！　全ての元凶は冴島、テメェだっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_010021600008" ]},
		{"command":[ "SETCHARA", "0", "char_00016101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「大体、いっつもアタシの話を聞かねぇで、自分の意見ばっか言いやがって！\n　いい加減にしろよ、この年増野郎っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_010021600009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「年齢は関係ないだろうが！　この眼帯中二病女っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021600023" ]},
		{"command":[ "SETCHARA", "0", "char_00004902_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「わかった、わかったから！　とりあえず、俺を間に挟んで言い争うのはやめ\nてくれっ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「ライオットのヤツ、めっちゃ騒いでるな……ったく。周りの迷惑も考えて欲\nしいもんだぜ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_010021600006" ]},
		{"command":[ "SETCHARA", "0", "char_00020601_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「あの騒々しさがライオットの特徴だよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_010021600007" ]},
		{"command":[ "SETCHARA", "0", "char_00016001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「だが、なるべくなら声は小さくして欲しいとは思っている」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_010021600008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「あ、あのさ……やっぱ姉御は、騒がしいってイヤだったりするのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_010021600007" ]},
		{"command":[ "SETCHARA", "0", "char_00020601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「ほら……ライオットほどじゃないけど、アタシも結構うるさい方かなーって\n思っててさ……姉御が不快に思ってないかなーって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_010021600008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「そんなことはない。それに私は、こういうひと時を守るために悪と戦ってい\nる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_010021600009" ]},
		{"command":[ "SETCHARA", "0", "char_00016001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「勿論、こうしてデビルトンファーと食事をする時間も、守りたいものの一つ\nだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_010021600010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「不快じゃない……？　それに、アタシとの時間も……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_010021600009" ]},
		{"command":[ "SETCHARA", "0", "char_00020601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「そっか……へへっ！　やっぱ姉御は最高の正義の味方で、アタシが惚れたヒ\nーローだぜ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_010021600010" ]},
		{"command":[ "SETCHARA", "0", "char_00020601_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「よーし！　姉御も飲むことだし、アタシも飲むとするかっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_010021600011" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「イグニス！　アタシにも姉御と同じ芋の水割り頂戴！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_010021600012" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「了解だ。すぐに持っていくぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021600011" ]},
		{"command":[ "SETCHARA", "0", "char_00016704_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「ふふっ。飲むのはいいが、ほどほどにしておけよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_010021600011" ]},
		{"command":[ "SETCHARA", "0", "char_00016001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「わかってるって！　正義のヒーローが酒に負けたら、形無しだもんな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_010021600013" ]},
		{"command":[ "SETCHARA", "0", "char_00020601_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "酔っ払いたちの騒ぎ声を肴にしながら、フランカは守るべきものを思い浮かべ\n、終始笑みを浮かべるのだった……", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}