{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0116" ]},
		{"command":[ "DISPIMAGE","0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_019" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"] },
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「もぉ～！　なんだったのよ、あの訓練はぁ～！　ダイヤナちゃん、ほんとワ\nケわかんない～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010106190001" ]},
	{"command":[ "SETCHARA", "0", "char_00000601_01", "7", "CENTER", "0" ]},
	{"command":[ "DISPTEXT", "TRUE" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「いや、だからアレにはな？　極限状態での適応力を鍛えるという、大事な意\n味があって――おっと、もう空だ。ほむらたん！　芋焼酎ロックで！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010106190001" ]},
	{"command":[ "SETCHARA", "0", "char_00004901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「はいよ！　ほむら『たん』言うな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020106190001" ]},
	{"command":[ "SETCHARA", "0", "char_00003402_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「こちらもグラスワインの白を頼むぞ、ほむらたん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090106190001" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「はい、白ね。だからほむら『たん』言うなっつーの！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020106190002" ]},
	{"command":[ "SETCHARA", "0", "char_00003402_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「しかしオボロは途中から、あれが訓練だと気づいてたようだけど。どこで気\nづいたんだい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010106190001" ]},
	{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「最初から薄々は気づいていました。このメンバーが、あそこまであっさりと\n殺されるのはどうも不自然だと。それになにより――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010106190001" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「最初の犠牲者がアナザーと言うのは、どう考えても変です。しかも、爆発事\n故に巻き込まれて、などと。この中でウチの次ぐらいにしっかりした人が」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010106190002" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「はははははは！　違いないね！　セレーナならともかく！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010106190002" ]},
	{"command":[ "SETCHARA", "0", "char_00000301_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「なんだよ、それー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010106190001" ]},
	{"command":[ "SETCHARA", "0", "char_00000401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010106190001" ]},
	{"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「カグヤさん、どうしたの？　さっきからキョロキョロしてるけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010106190001" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「カツマの姿が見えない……お店に入ったときから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010106190002" ]},
	{"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「それは、わたしも気になっていたの。……いえ、ちょっと待って？　考えて\nみると、その前から――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010106190001" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「……そういえば。あいつ、帰りのバスに乗っていたか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010106190001" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「たしかに、乗っていなかったような気が……ん？　んんっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010106190003" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "一同" ]},
		{"command":[ "SETTEXT", "「あっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010106190002" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "-600" ]},
	{"command":[ "SETCHARA", "1", "char_00001201_01", "3", "CENTER", "-200" ]},
