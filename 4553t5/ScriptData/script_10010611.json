		{"command":[ "SETIMAGE", "0", "sbg_0065" ]},
		{"command":[ "DISPIMAGE","0", "true" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おおーい！　みんなぁ～！　どこ行ったんだよぉ～！　出してくれ！　トイ\nレから出してくれよぉ～っ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まさか、みんな殺人鬼に……！？　ひいいいいっ！　冗談じゃねえ！　この\nままじゃ俺もやられちまう！　助けてくれ！　助けてくれ～っ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ここから出してくれぇえええええええ～っ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
	{"command":[ "EXIT" ]}
	]
