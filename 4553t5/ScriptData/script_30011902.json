{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「今日もあなたにはマッサージをしてもらいますわ。それにしても……なんで\nすの、この穴の開いた板は」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1904101" ]},
		{"command":[ "SETCHARA", "0", "char_00000119_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「マッサージに使う道具？　これが？　あまりそのようには見えませんわよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1904102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「……なっ！　あなた、また私のことをバカにしましたわね！　この板使うマ\nッサージがあることくらい、私も知っていますわ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1904103" ]},
		{"command":[ "SETCHARA", "0", "char_00000119_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「使い方も知っていますけど……と、特別に、あなたに説明させてあげますわ\n。さあ、どうすればいいのか説明なさい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1904104" ]},
		{"command":[ "SETCHARA", "0", "char_00000119_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「ふむふむ、そこが開きますのね。そして半円のくぼみに身体を……こうです\nか？　変わった姿勢でマッサージをするのね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1904105" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00000119_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「……って、なにをしたの！？　身体が、板に嵌ってしまってますわ！　んっ\n、んんぅっ！　後ろの様子も見えない……ひゃうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1904106" ]},
		{"command":[ "SETIMAGE", "0", "still_00000119_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「あなた後ろからなにを……んんっ、すーすーしますわ。まさか、服を脱がし\nたんですか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1904107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「それで、お尻を撫でまわして……これもマッサージですって！？　で、でも\nその触り方……ンッ、そんなふうに触られたら……はぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1904108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「んふぅっ、ああ、身体が火照って……ンッ、マッサージの効果がでているの\nかしら……はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1904109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「お尻を撫でまわされて……んっ、なんだかもどかしい気分ですわ……あぁん\nっ！　頭が、ぼーっとしてきますわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1904110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「ちょっとこれ、本当にマッサージなの？　さっきから、身体がもどかしいば\nかりで、ぜんぜんスッキリしませんわ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1904111" ]},
		{"command":[ "SETIMAGE", "0", "still_00000119_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「それならちょうどいいものがある、ですって？　は、はやくそれを使ってマ\nッサージなさい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1904112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「これだけ濡れていればいいだろうって、なんのことを言っているの？　いい\nからこの身体のモヤモヤをなんとかしなさ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1904113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「んひぃいいいぃぃぃっ！？　ちょ、ちょっと待ちなさい！　なにかが、身体\nにぃいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1904114" ]},
		{"command":[ "SETIMAGE", "0", "still_00000119_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「ああっ、熱いものが、私の中に入ってしまっている……！？　あ、あなたな\nにをしたの……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1904115" ]},
		{"command":[ "SETIMAGE", "0", "still_00000119_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「ち……チンポをハメた、ですって……？　チンポって、あの？　それに、ハ\nメたっていったい、どこに？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1904116" ]},
		{"command":[ "SETIMAGE", "0", "still_00000119_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「お、オマンコですって！？　あなた誰の許可を得て私のオマンコに挿入を…\n…んひっ、チンポ、動かさないで……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1904117" ]},
		{"command":[ "SETIMAGE", "0", "still_00000119_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「確かにマッサージをしろとは言いましたが、チンポを使えとは一言も……ん\nぁっ、んはぁあんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1904118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「だから動かさないでと……ああっ、ああっ、チンポがずりずりって、オマン\nコの中を擦るぅ……んはぁっ、ああぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1904119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「お、オマンコの中を、チンポでマッサージしてやるって……んっ、ああっ、\nそんなこと、しなくても結構……んくぅうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1904120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「だめ、声が出ちゃう……ああんっ！　チンポが動くたびに、声が出るの、我\n慢できない……ああっ、あぁあんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1904121" ]},
		{"command":[ "SETIMAGE", "0", "still_00000119_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「マッサージされて気持ちよくなってるんだろうって？　うぅ……こんなマッ\nサージで、気持ちよく……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1904122" ]},
		{"command":[ "SETIMAGE", "0", "still_00000119_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「あぁんっ！　オマンコをチンポで、マッサージ……んひぃっ、ずりずりって\n、中……擦られて、気持ちいい……んっ、ああぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1904123" ]},
		{"command":[ "SETIMAGE", "0", "still_00000119_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「意識したら、ますます……お、オマンコ……気持ちよくなって……。あっ、\nああぁんっ、身体が……なんだか、疼いて……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1904124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「ああっ、いいっ、そのマッサージ、気持ちいいですわっ！　あぁんっ！　チ\nンポで中を、たくさんひっかくように動かして……はぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1904125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「ごりごりって、ンッ、オマンコ、ほぐされるの……はぁんっ！　チンポマッ\nサージ、あんっ、とっても、気持ちいい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1904126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「認めるっ、認めますわっ！　ああっ、チンポマッサージ気持ちいいの！　い\nっぱい突かれるの、感じちゃうぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1904127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、勢いすごいっ！　力いっぱい、後ろからずんずんされてる！　\nんぉっ、奥にまでチンポが届いて……るぅううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1904128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「マッサージ、もっと、もっと強く……！　ああっ、マッサージじゃなくて子\n作り？　子作りしてるんだって？　えっ、ええっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1904129" ]},
		{"command":[ "SETIMAGE", "0", "still_00000119_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「子作りですって！？　ちょ、ちょっと待ちなさ、んひゃぁっ！　あなた私を\nだまして、そんなこと……んひぃいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1904130" ]},
		{"command":[ "SETIMAGE", "0", "still_00000119_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「い、今すぐ抜きなさいっ！　チンポを抜いて……ああっ、抜ける、チンポ抜\nけてく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1904131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「あひぃいいぃぃっ！　抜くと思ったら一気に奥までぇえっ！　ここまで来た\nら最後までしてやるですって？　さ、最後って……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1904132" ]},
		{"command":[ "SETIMAGE", "0", "still_00000119_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「あっ、ああぁっ！　ますます、チンポ激しくっ！　んひっ！　奥にっ、チン\nポが奥に……んぁっ、ああぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1904133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「先っぽが、私のオマンコの一番奥にゴツゴツ当たるっ！　あっ、あっ、ああ\nっ、ああぁ！　それ、それだめ……頭がおかしくなるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1904134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「このまま出してやるって、なにを……いったい……ああっ、ああっ、チンポ\nが膨らんで……きて……るぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1904135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「んぁあっ、ああぁぁああぁぁっ！！　中にっ、中にぃいいっ！　熱いのっ、\n入ってきてっ、注がれて……っ！　くひぃいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1904136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000119_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「まさかっ、ああっ、あなたの精液が中にっ、中出しぃいいいっ！？　すごい\n勢いで、ドクドクってきて……るぅうぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1904137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「ああ……中出しをされてしまうなんて……。中出しされて、気持ちよくなっ\nてしまうなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1904138" ]},
		{"command":[ "SETIMAGE", "0", "still_00000119_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「わ、私がこんな男にぃ……んふぅ……マッサージと騙されて中出しまでされ\nるなんて、屈辱ですわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1904139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「き、気持ちよかっただろう、ですって……。それは……うぅ、知りませんわ\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1904140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「というか、なんでまだチンポを挿入したままなの？　中出しまでしたんだか\nら、もういいでしょ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1904201" ]},
		{"command":[ "SETIMAGE", "0", "still_00000119_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「んひっ！　な、なんでまた動いていますの！？　も、もっと私に、子作りの\n快感を教え込むですって……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1904202" ]},
		{"command":[ "SETIMAGE", "0", "still_00000119_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「そんなの結構です……んひぃっ！　ちょっと、私の話を無視して、ち、チン\nポを動かして……んぁあっ、ああぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1904203" ]},
		{"command":[ "SETIMAGE", "0", "still_00000119_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「なっ、なんだか先ほどよりもっ！　んっ、あなたのチンポの存在を意識して\nしまうぅっ、んぁっ、大きい……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1904204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「イッたから感度があがってるだろうって、イッたって、なんのこと……あぁ\nあんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1904205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「さっき中出しされたときの感覚……。頭が真っ白になるような衝撃……。あ\nれが、イクということなの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1904206" ]},
		{"command":[ "SETIMAGE", "0", "still_00000119_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「そんなの知らない！　わかりませんわ！　んぁあっ！　だったらまた教えて\nやるって、んひぃっ！　チンポ激しいぃいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1904207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「お、オマンコ容赦なくっ、ああっ、チンポでずぼずぼされてる！　んひっ、\n何度も奥に、チンポをゴツゴツって、あぁあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1904208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「動けない私のオマンコを、思いっきり突いて、ああっ、子作り！　子作りす\nるなんて……はぁんっ！　好き放題、されてるのにぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1904209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「ああっ、だめ、感じてしまう……チンポ、感じてしまいますわぁっ！　ああ\nっ、ああっ、オマンコで感じてしまうのぉおっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1904210" ]},
		{"command":[ "SETIMAGE", "0", "still_00000119_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「ああっ、あなたに、教えられてしまうっ！　小作り快感、教えられてしまい\nますのっ、あっ、あっ、ああぁあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1904211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「はっ、はひっ、オマンコに集中っ、オマンコに意識を向ける……んぁあっ！\n　チンポのこと、もっと……締め付けます……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1904212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「んひぃっ！　ご、ゴリゴリって、中をいっぱい擦ってくるのを感じちゃうぅ\nううっ！　ああっ、それ、いいっ、いいですわぁあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1904213" ]},
		{"command":[ "SETIMAGE", "0", "still_00000119_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「ひぃ、ひぃ、止まりませんのぉ……。いっぱい感じて、気持ちいいのが、全\n身に広がっていっちゃう……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1904214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「ああっ、ますますチンポが膨らんでっ、あっ、あなたまた、私に向かって射\n精するつもりなのね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1904215" ]},
		{"command":[ "SETIMAGE", "0", "still_00000119_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「い、いいですわ。射精していいですわぁっ！　中出ししなさいっ！　さっき\nの快感を、もう一度私に味わわせてぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1904216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「いやらしいナマイキオマンコ、いっぱい締め付けますわ！　あなたの射精を\n促すためにきゅうきゅう締め付けますわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1904217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「だからっ、だから……んはぁああっ！　激しくっ、いっぱいオマンコの中を\nごりごりってして、射精っ、射精……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1904218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁっ、はぁっ、はぁあっ！　私も、また、先ほどの……ああ、イ\nク、イッてしまいますわ！　先ほどのように……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1904219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「ああっ、あなたのっ、あなたのチンポでまた、イクッ、イかされるっ！　子\n作りしながらイッちゃいますわぁあああぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1904220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「んはぁああっ！　ああっ、ああぁああああぁぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1904301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000119_02_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「来てますわっ！　精液っ、精液ぃいいいっ！　あっ、熱いのがまた、どぷど\nぷ中にっ、んひぃいいいぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1904302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「さっきより多いっ！　精液多すぎますwっ！　ああっ、中にっ、お腹が膨れ\nるほどに射精されてますわぁあああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1904303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「んはっ、はぁあっ、まだ脈打って……チンポが、びっくんびっくん、中で震\nえて……んひぃ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1904304" ]},
		{"command":[ "SETIMAGE", "0", "still_00000119_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「いったいどれだけ……射精すれば気が済むの……んはぁ、まだ、まだ射精し\nてる……はぁああ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1904305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「んふぅ……やって……終わりましたのね……。ううぅ……思い返せば、とん\nでもなく破廉恥なことを……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1904306" ]},
		{"command":[ "SETIMAGE", "0", "still_00000119_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「でも……子作り気持ちよかったですわ……。下手なマッサージより、気持ち\nが晴れ晴れとしているような……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1904307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「ふふ……。あなたは嘘を言っていたわけではないようですわね。悔しいです\nが、そこだけは認めて差し上げますわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1904308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「ところで、私と子作りしたということは、このあとの責任を取るつもりです\nよね、当然」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1904309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「……って、どこに行くつもりですの！　ちょっと、私をこれにハメたまま放\n置だなんて、ゆ、許しませんわよ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1904310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「んはぁっ！？　ちょ、ちょっと待ちなさい、いきなりチンポを抜くなんて…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1904401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000119_02_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「えっ、私の顔の前に回り込んで……んはぁっ、ああぁっ、んっくぅうううぅ\nぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1904402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「ああっ、ドロドロしたっ、こ、これって……この感覚……！　あなたがマッ\nサージのたびに、私にかけたり、飲ませたりした……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1904403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「やっと気づいたのかって……くぅうっ、ずっと私はあなたの精液の味や感触\nを覚え込まされていたのね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1904404" ]},
		{"command":[ "SETIMAGE", "0", "still_00000119_02_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「こ、こんな……いつも肌に塗りこんでいたドロドロのネバネバが精液だった\nなんて……。んふぅ……あうぅ……でも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1904405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「すっかりこの臭いに慣らされて……ああ、もう嫌悪感もわきませんわ……す\nっかり身体が、あなたの精液を覚えてしまっているぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1904406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「ああっ、もっともっと、私の顔をドロドロに……んっ、チンポを目の前でし\nごいて、ぶっかけて……あっ、ああぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1904407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「すっごい臭いで、顔中ドロドロまみれですわ……んぁっ、ああっ、だめ……\nイッてしまうぅううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1904408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「精液まみれで、イク姿を晒すなんて……はぁ、はぁ……屈辱ですわ……んふ\nぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1904409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「それなのに、こんなに清々しい気分で……。もう、自分がわからなくなって\nしまいそうです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1904410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
