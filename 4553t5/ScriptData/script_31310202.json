		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ちゅぱ、ちゅっ、んっ、んんっ、ちゅる、ちゅるる……んあぁぁん、はあぁ\n……あふぅ」", "NORMAL" ]},
