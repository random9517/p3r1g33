		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あっ！　あああああああ……はぁあああっ！　出てるっ！　私のオマンコの\n奥に……いっぱい……はぁああん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0204301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00013102_02_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ああああ、熱いです……熱くて濃いのが、いっぱい……あああ、もう、さっ\nきの分と合わせて、私の中、もういっぱいですぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0204302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「はぁああ……もう……ダメだって言ったのに、また中出しするなんてぇ……\n。あ、まだ出てますぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0204303" ]},
		{"command":[ "SETIMAGE", "0", "still_00013102_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「どうしてこんなに射精しちゃうんですかぁ……そんなに、私を妊娠させちゃ\nいたいんですかぁ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0204304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あ、ああっ……私のオマンコ、勝手にひくひくして……あなたの精液、搾り\n取ってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0204305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「は、はい……正直言うと……中にたくさんほしいな、って思ってました。あ\nなたの精液……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0204306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「赤ちゃん、できちゃうかも、って？　ええ。さっきも言った通り、わたしの\n子宮、あなたとの子供を欲しがってるみたいです。ふふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0204307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ですから、隊長さん。これからもどんどん、私の中にあなたの精液、いっぱ\nい出してくださいね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0204308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ふふふっ、なんだか私、とってもエッチな子になってしまったようです。で\nも、隊長さんはそんな子、嫌いじゃないですよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0204309" ]},
		{"command":[ "SETIMAGE", "0", "still_00013102_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「よかった……あの、隊長さん？　それじゃ、私のこと、もっともっと気持ち\nよくしてくれますか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0204310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あ、ああああっ！？　抜いちゃいやです……ふぁあああああん！？　オチン\nポから、精液が吹き上げてるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0204401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00013102_02_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あ、あ、あああああっ！　私のオマンコに、熱い精液がかかって……はぁあ\nああん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0204402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「んぁああああ……オマンコだけじゃないですぅ……お腹にも、胸にも、顔に\nまで……精液いっぱぁい……ああああ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0204403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あなたの精液、すごい匂いです……全身に、あなたの匂いがしみ込んで、私\nがまるごとあなたのものになってしまいそう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0204404" ]},
		{"command":[ "SETIMAGE", "0", "still_00013102_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あ、まだ、出てます……それも、かけてください。最後の一滴まで、私の上\nにぶちまけて……はぁあ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0204405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ああああ……ヌルヌルの青臭い精液……あなたの、赤ちゃんの元が……私の\n全身を白く染めていくんですね……はぁあああ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0204406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「すごい……こんなに出るなんて。私、体中ヌルヌルです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0204407" ]},
		{"command":[ "SETIMAGE", "0", "still_00013102_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あああああ……こうして、ヌルヌルを体に塗りつけているだけで、興奮して\nきます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0204408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あの……もっと、してください。お願いですから、今夜は、私を寝かせない\nで……そして、もっともっと、精液をかけてください……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0204409" ]},
		{"command":[ "SETIMAGE", "0", "still_00013102_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あ、でも、中に出してもらうのもいいですね。ふふふっ、どっちがいいか、\n迷ってしまいます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0204410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}