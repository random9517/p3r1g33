		{"command":[ "SETCHARA", "0", "char_00013102_01", "8", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_131_0204103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「きょ、今日は……私のヴァージン、捧げちゃい……ます。えっ、もし怖かっ\nたら前みたいに魔石を使って性格を上書きしてもいいって……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0204104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ううん、今日のこの瞬間は……私の意思で決めたいんです。だから……あっ\n」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00013102_01", "6", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_131_0204105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「大事なトコロ……見えちゃって、ますよね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0204106" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00013102_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「はあぁっ、言わないで……！　興奮して、愛液……しみ出しちゃってるんで\nす……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0204107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「だから、きっと初めてでも痛くない……んっ、んん！？　はぁ、ああぁ……\nい、入れますね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0204108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「くっ……ん、んんんっ！　んあああぁ、あっ！　あぁ～～～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0204109" ]},
		{"command":[ "SETIMAGE", "0", "still_00013102_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「はぁ、はっ……はあぁ、入っ……ちゃっ……た、はぅ！　はぅぅん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0204110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「えっ……！？　あっ、どうして腕を掴むんですか？　ひゃっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0204111" ]},
		{"command":[ "SETIMAGE", "0", "still_00013102_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あっ、あああぁ～～！！！？　奥まで、入っちゃって……んあぁぁん！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0204112" ]},
		{"command":[ "SETIMAGE", "0", "still_00013102_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「やだぁ、自分から腰を振られたら、子宮ぅ、きゃぅ！　きゃぅぅ！？　当た\nっちゃ……当たってます……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0204113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「やあぁ……また抜いてって、ひゃううぅぅっ！！？　さ、先っぽから根元ま\nで一気に入れるのナシですっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0204114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「頭の奥にジーンてきて、ビリビリって電流きちゃって、何も考えられなくな\nっちゃうんです……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0204115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「そ、それがイクってこと？　これが絶頂なんですか？　でも、でもぉ……ん\nあああぁ～～！？　またぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0204116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「イクッ、イキ続けてっ……ひっ！　ひぅぅ！？　ま、まだこれより気持ちイ\nイのあるんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0204117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「やあぁん！　激しく子宮ぅ突かれて、私ぃ……子宮ぅ下りてきちゃってます\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0204118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あうぅ、あっ、あぁ～！？　こ、このまま中出しはダメ……ですっ、とにか\nくダメなんです……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0204119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「理由なんて、はうぅ、はぁぁ！　だって妊娠しちゃう……んああぁ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0204120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「んあぁん、えっ……！？　最初から孕ませる気でやってる？　そ、そんなぁ\n……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0204121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「はうぅ、イヤっ、答えさせないで……はぁ、あぁぁ！　私のカラダ、あなた\nになびいてきちゃってるんです……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0204122" ]},
		{"command":[ "SETIMAGE", "0", "still_00013102_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「子宮が、あなたの子を孕みたがってるの分かるんです……だからダメぇ、中\n出しされたら、くっ……くぅぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0204123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「んああぁん！　あぁぁ！？　やあぁ……！！　本当のアクメを教えてやるっ\nて……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0204124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「おっぱい弱いんです、いじっちゃイヤぁ……！！　先っぽいじられると、甘\nいうずきが……あぅぅん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0204125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「オマンコも突かれてるのにぃ、くぅぅっ！？　ごつごつ突かれて、電流ビリ\nビリきちゃってるのにっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0204126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「乳首までくりくりされたら、ふあぁ……あぁぁ！　私っ……あなたに射精し\nて欲しくなっちゃいます、きっと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0204127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「んあぁ！　あっ、あ～～～っ！！？　中出しだなんて、ダメ……ダメぇ、ダ\nメダメっ、んああぁぁ～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0204128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「やあぁん！！　また手をからめて……はひっ！　ひっ！　ひぃぃ！　子宮に\n当たってる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0204129" ]},
		{"command":[ "SETIMAGE", "0", "still_00013102_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「んあぁ、あっ……もぅダメぇ、こんなぁ、こんな激しく突き上げ、られたら\nっ……ひぃぃ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0204130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「もうイクッ……アクメきちゃいます、あぁ～～っ！！？　あああ……んあぁ\n、あああぁぁ～～～！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0204131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「やっ、やあぁ、イク、イクイクッ……んあああぁぁん！？　あぁぁ～～～！\n？　イクぅぅぅ～～～～！！！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0204132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ひゃうぅ！　あっ！？　ああぁぁ……！？　ナカに、熱いのが一杯……くう\nぅ！　注ぎ込まれて……ますっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0204133" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00013102_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「い、いぃっぱい……んあぁ、子宮のナカで渦巻いて……やうぅん！　ひっ…\n…ひああぁん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0204134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「はあぁーっ、はぁ！　はああぁ……！　だから、中出しはダメって言った…\n…のに……んふぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0204135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「そんな生意気な口を利けなくする……？　ま、まだするつもりなんですか…\n…？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0204136" ]},
		{"command":[ "SETIMAGE", "0", "still_00013102_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あぅ……！　た、確かに、期待……しちゃって、ます。もっとされたいって\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0204137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あなたに子宮を陥落させられたがってるんです…………！　んんっ、んああ\nぁ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0204138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「また大きくなったオチンポが子宮に当たって……！　今晩は、寝かさない…\n…？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0204139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あうぅ、来てっ……あなたの好きなように責めて下さい、くっ、くぅぅ、ん\nあぁぁ～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0204140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あ、あ、あ、ああっ！　好きなようにって言いましたけど、そんなに激しく\nされると……はぁああん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0204201" ]},
		{"command":[ "SETIMAGE", "0", "still_00013102_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「んんんんっ！　すごい……！　あなたのオチンポすごいですっ！　私の中で\n、ぐりぐり暴れて……ふあぁああん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0204202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ああっ、はっ！　んんんんっ！　はぁああ～ん！　あっ！　あああん！　あ\nんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0204203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ど、どうしましょう！　私、セックスしたのは今日が初めてなのに、こんな\nに感じてしまって……はぁああん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0204204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ち、違いますっ！　私がいやらしい女の子なんじゃなくて……あなたのオチ\nンポが……あああん！　あっ！　あっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0204205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あなたのオチンポが、気持ちよすぎるんですぅ！　はあぁあん！　あんっ！\n　あんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0204206" ]},
		{"command":[ "SETIMAGE", "0", "still_00013102_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「もっと、もっと突いてくださいっ！　奥の方をもっと……あ、はぁああん！\n　そこですぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0204207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ああああ……っ！　奥がそんなに気持ちいいなんて……知りませんでした、\n知りませんでしたぁ！　ああああん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0204208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「んあぁっ！？　そんな角度で！？　あああん！　あっ！　すごいっ！　そこ\nもいい……ああぁん！　あ、あ、ああっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0204209" ]},
		{"command":[ "SETIMAGE", "0", "still_00013102_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ふぁあああ！　あああっ！　だ、ダメです！　そんなにグイグイ攻められた\nら、また、私、イッちゃいそうで――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0204210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ああああん！　ダメですっ！　ヤメちゃダメっ！　もっと、もっと激しくし\nてくださいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0204211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「んぁっ！？　な、なんか今、私のオマンコが勝手にきゅぅうっ、って……！\n　は、初めてです、こんなの……はぁああ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0204212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あああああああっ！　こすれてるぅ！　あなたのオチンポが、私の中にいっ\nぱいこすれて……はぁああああん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0204213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あ、あ、あ、気持ちいいっ！　こすって！　あなたのオチンポで、オマンコ\nぐりぐりしてくださいっ！　はぁああああん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0204214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あああああっ！　なんかもう、だんだん頭が真っ白になってきて……本当に\n私、イッちゃいそうですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0204215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あ、あなたもイクんですか？　イキそうなんですか？　私の中が気持ちいい\nから？　う、うれしいです……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0204216" ]},
		{"command":[ "SETIMAGE", "0", "still_00013102_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「はいっ！　わかりますっ！　あなたのオチンポ、私の中で限界まで大きくな\nってます！　あなたも、イクんですねっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0204217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「んんんんっ！　ああああっ！　はいっ！　来てくださいっ！　一緒に、一緒\nにイキたいですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0204218" ]},
		{"command":[ "SETIMAGE", "0", "still_00013102_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ああああっ！　はっ、はっ、はっ、はああああっ！　あああああっ！　イキ\nますっ！　イキますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0204219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「出して！　出してくださいっ！　あなたの精液、私の中にしみこませて……\nああああああああああっ！　はぁあああああああああ～～～んっ！」", "NORMAL" ]},
