		{"command":[ "SETIMAGE", "0", "still_00027901_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「でも、んんっ……もっと気持ちよくなれるなら……きゅんって……くぅぅぅ\nっ……しますからぁっ、あぁんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0104213" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「そう、ですっ……私は……オチンチンが大好きな……戦乙女ですっ……！　\n認めますっ、認めますからっ……もっと激しくして下さいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0104214" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「あぁっ……とうとう、こんな宣言までぇ……でも、気持ちいいのに逆らえな\nい……もう、オチンチンがないとダメなのぉ……」", "NORMAL" ]},
