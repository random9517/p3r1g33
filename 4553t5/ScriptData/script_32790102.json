		{"command":[ "PLAYVOICE", "v2_279_0104308" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「もう、私は……このオチンチンに負けてしまった……淫らな戦乙女……レイ\nアです……」", "NORMAL" ]},
