		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「中だけじゃなくて……私の全身……全部、精液まみれにさせるんですね……\nあぁ……熱いのが……いっぱいにぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0104402" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
