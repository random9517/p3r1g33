		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「はぁぅんっ！　あっ、んぁぁぁっ……また、奥ぅっ……！　オチンチンっ…\n…届き……ますぅっ！」", "NORMAL" ]},
