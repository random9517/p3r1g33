		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「もっと……オチンチン……ズボズボしてっ、ぐちゅぐちゅのオマンコっ……\n突きまくってっ、気持ちよくなって下さいっ……！」", "NORMAL" ]},
