		{"command":[ "SETIMAGE", "0", "still_00027901_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「はいっ、私のオマンコも締め付けますっ……んんっ！　オチンチン……もっ\nと感じて欲しくてっ、ずりゅってぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0104211" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「どう、ですかっ？　あっ、ふっ……！　これぇ……私も……気持ちよくて…\n…頭が……ボーッとしてきちゃいます……はふぁぁう……」", "NORMAL" ]},
