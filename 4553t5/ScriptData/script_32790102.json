		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「あぁ……今、危ない日かもしれないのに……こんなに出されたら……赤ちゃ\nんできちゃう……はぁぁ、でも……気持ちいいのぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0104302" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「はっ、あぁぁんっ……射精しながら……まだオチンチン突かれてる……イッ\nてるオマンコを……グリグリされてますぅ……」", "NORMAL" ]},
