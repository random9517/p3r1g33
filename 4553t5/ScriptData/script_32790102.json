		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「あぁっ、腰が……勝手に動いちゃうっ……オチンチン……もっと感じたくて\nっ、はぁんっ、いやらしく……腰……振っちゃいますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0104208" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「あぁっ、中で……ぐちゅって擦れてぇっ……はぁんっ、今の……好きっ……\n硬いオチンチンが当たるのっ、好きぃっ……！」", "NORMAL" ]},
