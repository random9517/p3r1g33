		{"command":[ "SETIMAGE", "0", "still_00027901_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「はぁっ、はひっ、かき混ぜて下さいっ……中出しされた精液っ……オマンコ\n全体に染み込ませてぇ……あっ、んぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0104204" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「ふぁぁっ、んくぅっ……あぁっ、身体……もっと密着させて……はい、おっ\nぱいも……ぎゅって……揉んで下さい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0104205" ]},
		{"command":[ "SETIMAGE", "0", "still_00027901_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「そ、そうです……ずっと乳首も……疼かせていました……乱暴にしてもいい\nですから……強くして……あっ、はぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0104206" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「は、恥ずかしい……コリコリの先端つまみ上げられてぇ……んぁっ、引っ張\nられたらっ……あくぅんっ！」", "NORMAL" ]},
