		{"command":[ "SETIMAGE", "0", "still_00027901_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「欲しいんです……オマンコ……気持ちよくさせて……あぁ……一番奥のオマ\nンコの弱いところ……ぎゅっと強く……して下さいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0104129" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「はぁんっ！　あひっ、はひぃんっ！　あぁっ……そ、それですっ……んぁぁ\nっ、オチンチンっ、奥にっ……来ますぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0104130" ]},
		{"command":[ "SETIMAGE", "0", "still_00027901_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「あぁっ、ダメ……気持ちいいのが止まらないっ、あぁ……そうです……こう\nして欲しかったんですっ、あぁっ、オチンチン気持ちいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0104131" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「もっと……はぁんっ、いっぱいかき回してっ……は、はいっ、私も……腰を\n振りますからぁっ、こ、こうですかっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0104132" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「はぁんっ、あぁ……そうですっ、私は……もう……淫乱なヴァルキリーっ…\n…オチンチンが大好きなっ、いやらしい戦女神なんですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0104133" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「ほ、欲しいっ……精液が……中に欲しいですっ！　ドピュドピュっ……出し\nてっ、オチンチンっ……来てぇっ！」", "NORMAL" ]},
