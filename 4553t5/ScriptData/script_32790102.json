		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「ンンンんんんーーっ！　あぁぁっ……中に出てる……はぁぁ……赤ちゃんで\nきちゃうかも知れないのに……いっぱい出されてぇ……」", "NORMAL" ]},
