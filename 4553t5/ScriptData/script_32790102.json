		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「もう、戻れない……民のためじゃなく……オチンチンに尽くすヴァルキリー\nになってしまったんですっ、はっ、あぁぁぁんっ！」", "NORMAL" ]},
