		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「……あぁ……や、やっぱり恥ずかしい……こんな、はしたない姿を晒すなん\nて……どうか、あまり見ないで……下さい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0104101" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「確かに……呼んだのは私です……全て、貴方の言いなりになった訳ではあり\nません……ありませんが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0104102" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「でも……ずっと疼いてしまっているんです……貴方に開発されてしまった身\n体が、どうしても欲しいと……だから、こんな形で……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0104103" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「は、はい……どうすればいいか……ま、まずおねだりから……ですよね……\n言う通りに……します……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0104104" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「うぅ……そ、そうです……私のオマンコは……貴方のオ、オチンチンが欲し\nくて……もう、濡れてしまっています……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0104105" ]},
		{"command":[ "SETIMAGE", "0", "still_00027901_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「どうか、今日も……貴方の太くて逞しい……オ、オチンチンで……私の……\nオマンコを……か、可愛がって下さいませ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0104106" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「あぁ……また、こんなことを言わせるなんて……どこまで私を淫らにしてい\nけば気が済むのですか……あっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0104107" ]},
		{"command":[ "SETIMAGE", "0", "still_00027901_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「んっ、ち、違います……も、もう少し上の方……あぁ、焦らさないで……ち\nゃんとオチンチン……入れて下さい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0104108" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「はぁぁんっ……！　あっ、んぅぅぅぅぅんっ……！　あぁぁぁ……オチンチ\nン……入って……来ます……ぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0104109" ]},
		{"command":[ "SETIMAGE", "0", "still_00027901_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「はぁぁぅ……あぁ……太いのが、奥までぇ……あっく……んっ、中をかき分\nけて……は、ひぃぃんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0104110" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「い、一番根元まで……簡単に飲み込んで……あぁ……な、馴染んでなんか…\n…ダメ……また、濡れてきてしまう……はふぁっ、んふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0104111" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「んっ、く……う、動かないんですか……？　もっと、私のことを犯したら…\n…いいじゃないですか……ん、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0104112" ]},
		{"command":[ "SETIMAGE", "0", "still_00027901_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「そ、そうして欲しいという訳では……んっく……意地悪です……ここまでし\nておいて、生殺しのようにするなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0104113" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「また……おねだりさせるんですね……？　お願いします……う、動かして下\nさい……オマンコの中……もっとオチンチンでかき回して……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0104114" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「ヌルヌルにぬめったオマンコを、グリグリ……ズボズボ……いっぱい、かき\n回して……私を浅ましく……よがらせて下さい……あぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0104115" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「はひぃっ！　あっ、あぁっ、んぁぁんっ！　あっ、オチンチンっ……動きっ\n、ますぅっ、はっ、んぁっ、あぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0104116" ]},
		{"command":[ "SETIMAGE", "0", "still_00027901_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「あぁぁ……深いっ……くうぅんっ……奥のところぉ……はぁぁっ、ごりゅっ\nて擦れてぇ……はぁっ、あくぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0104117" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「ほ、欲しかったなんて……そんな、私は……そんなつもりじゃ……あぅんっ\n！　あぁっ……硬いのがっ……中で暴れてっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0104118" ]},
		{"command":[ "SETIMAGE", "0", "still_00027901_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「はぁぁんっ……あぁっ、オマンコ……熱くなって……んくぅっ、ダメ……疼\nいて来ちゃうっ……いけないことなのにっ、あぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0104119" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「気持ちいい……あぁっ、いやっ、認めてしまったら……私……もっと、堕ち\nてしまうのにっ……あっ、そ、そこぉっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0104120" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「はっ、んふぅっ……ま、待って下さい……そ、こはっ……あっ、弱くて……\nんんっ、あふぅっ、あっ、あひぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0104121" ]},
		{"command":[ "SETIMAGE", "0", "still_00027901_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「で、ですからっ……オ、オマンコのっ……奥ぅっ……！　今……オチンチン\nが擦っている襞のところっ、ですぅっ……んぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0104122" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「あぁっ、熱い先端でっ……そんなに、ズリズリ……されたらぁっ、私っ、あ\nぁっ、お、おかしくなってしまいますっ、はぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0104123" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「なって……いい……んっ、あぁっ……ダメ……おかしくなったら……本当に\n戻れなくなっちゃいますから……あっ、あぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0104124" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「あっ……ふっ……！　はぁ、はぁ……んっ、と、止まった……あぁ……ので\nすか……？　んっ、どうして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0104125" ]},
		{"command":[ "SETIMAGE", "0", "still_00027901_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「い、いえ……やめない方がよかったということでは……んんっ……！　あっ\n、ふっ、でも、こんなにゆっくりにするなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0104126" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「あぁ……んっ、オチンチン……と、届かない……んっ、さ、さっきまで擦っ\nてた場所なのにぃ……あ……ぅぅう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_0104127" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「ダメ……あぁ、もう私……はぁん……戻れない……して、して下さい……も\nっとオチンチン……してぇ……」", "NORMAL" ]},
