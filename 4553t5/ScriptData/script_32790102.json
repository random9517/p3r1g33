		{"command":[ "SETIMAGE", "0", "still_00027901_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「んぁぁぁっ……イ、イクっ……！　イキますっ！　あぁっ、オチンチン激し\nくてっ……んひぁぁっ、オマンコッ……イキますぅぅっ！」", "NORMAL" ]},
