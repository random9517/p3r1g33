		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「はぁ、ふぅ……んっ、あぁ……射精……終わりましたか……？　まだ、奥に\n少しだけ……はい……後は、私が……んんっ！」", "NORMAL" ]},
