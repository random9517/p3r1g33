		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「あぁ……オマンコも自然にヒクヒクして……貴方の精液……飲んでるみたい\nに……なってます……」", "NORMAL" ]},
