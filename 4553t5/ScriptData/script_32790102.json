		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「んふっ……今ので搾り取ることができましたか……？　あふ……よかった…\n…もう残っていませんよね……？」", "NORMAL" ]},
