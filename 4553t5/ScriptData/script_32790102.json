		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「んふぁぁぁ……はぁぁ……あぁ……オチンチン震えてます……まだ、出し続\nけてるんですか……どこまで……こんなぁ……」", "NORMAL" ]},
