		{"command":[ "PLAYVOICE", "v2_279_0104403" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「あぁ……オ、オマンコがヒクヒクしてるなんて……言わないで……恥ずかし\nいです……まだオチンチンを欲しがってるなんてそんなことぉ……」", "NORMAL" ]},
