		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「決して貴方には逆らえないと……分かってしまったから……今は、もう……\nこの気持ちよさに身を委ねさせて下さい……」", "NORMAL" ]},
