		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「あぁ……こんなに、オチンチンが気持ちいいなんて……私……もう、本当に\n戻れません……あふぁ……」", "NORMAL" ]},
