{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0117" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「カツマと旅行か。楽しみだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090021520002" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「カツマ……旅行券が当たったって本当？　勿論、私と行くんだよね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010021520001" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「南国旅行なんて、いいモン当てたじゃないか。ほら、さっさとチケットをよ\nこしな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010021520001" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「南国かー。きっと美味しいモノとかたくさんあるんだろうなぁ～。どんな料\n理が出るか、今から楽しみだぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010021520001" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「海は嫌いですが、旅行となれば話は別です。せっかくの機会ですし、堪能さ\nせてもらいます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010021520001" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「リゾートだなんて、さすがはカツマちゃんね～！　い～っぱいお買い物して\n、美味しいモノ食べましょ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010021520001" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピースムーン" ]},
		{"command":[ "SETTEXT", "「私は皆様の護衛もありますし、誰と行くことになったとしても、お供させて\nいただきます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_040021520002" ]},
		{"command":[ "SETCHARA", "0", "char_00000809_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「旅行かぁ。最近ずっと襲来者（インベーダー）と戦ってばっかりだったし、\n息抜きには丁度いいかもね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_030021520002" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「か、カツマさんと旅行だなんて……ジュンジローさんが居るとはいえ、これ\nはもう実質的に二人きりの旅行と言ってもいいのでは……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_020021520002" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「みんな、とりあえず落ち着いて……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「おい、下僕！　いい加減、誰と行くかはっきり決めたらどうだ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010021520007" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「基地で美女に囲まれるとは……まさにハーレムですな、ご主人」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021520023" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「こうなったのも、全部お前が余計なことをしたせいだからな！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「余計なこととは心外ですな。わたくしは悩めるご主人の為に、こうして皆様\nにご報告をさせていただいたというのに」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021520024" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「だからそれが余計なんだよ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「うだうだ言ってないで、誰と旅行に行くのか、今ここで決めろ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010021520008" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「勿論、私とだよな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090021520003" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「私とだよね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010021520002" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「当然、あたしだよな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010021520002" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「私だろ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010021520002" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ウチとですよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010021520002" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ダイヤナちゃんとよねぇ～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010021520002" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「わたしと一緒だよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_030021520003" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「わたしと……ですよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_020021520003" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピースムーン" ]},
		{"command":[ "SETTEXT", "「わたしは除外していただいて構いません。あくまでも護衛として付いていく\nだけですので」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_040021520003" ]},
		{"command":[ "SETCHARA", "0", "char_00000809_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "（クソっ！　こんなの、誰を選んでも地獄じゃないか！）", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "（せっかくの休暇だってのに……邪魔されてたまるかよ！）", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "（こうなったら、もう俺と駄犬だけでこっそりと行くしかねぇ！）", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「わかった、わかった！　誰と行くかは、旅行の前日に当選者に教える！　そ\nれまでのお楽しみにしておいてくれ！　以上、解散！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あっ、こら！　逃げるな、このボケナスビーーー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010021520009" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPIMAGE", "0", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "こうして俺は休暇を満喫するために、誰にも声をかけることなく、駄犬と共に\nひっそりと飛行機に乗ったのだった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}