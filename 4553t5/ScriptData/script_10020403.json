		{"command":[ "PLAYVOICE", "v2_001_070113580006" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「ちょ、ちょっと待ってーっ！」", "NORMAL" ]},
