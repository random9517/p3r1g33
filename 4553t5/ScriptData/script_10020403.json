	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「いい加減にしなさーい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020113580001" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "セレインをめぐる果てしないバトルは、明日楽のカミナリによって幕を下ろし\nた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「あなたたちはどうしてそう、時と場所を選ばずに暴れるんですか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020113580002" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「一般学生とのトラブルを起こしたばかりなんですから、学習してください！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020113580003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ごもっとも。しかしそんな学習能力があったらそもそも問題は起こしてないわ\nけで……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「ここまでもめるなら、教員の参加はなしですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020113580004" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「そんなあ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113580001" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "みんと" ]},
		{"command":[ "SETTEXT", "「むぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_020113580001" ]},
		{"command":[ "SETCHARA", "0", "char_00001502_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「ええ～っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040113580001" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんでお前まで残念がるんだよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「だってー、参加したかったしー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040113580002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「とにかく、チーム決めはもっと平和的な解決法でおこなってください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020113580005" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「例えばどんな方法ですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113580002" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「グーパーで？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020113580006" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "みんと" ]},
		{"command":[ "SETTEXT", "「……まあ、それなら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_020113580002" ]},
		{"command":[ "SETCHARA", "0", "char_00001502_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "というわけで、チーム分けが終了。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ルルーナのチームには、ルルーナ、流々那、マーガレット、夜日楽、ハルカの\n部下。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "みんとのチームには、まりあ、つきみ、桃花、珠魚の部下にグレーテルの部下", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「ルルーナ様、大丈夫でしょうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_050113580001" ]},
		{"command":[ "SETCHARA", "0", "char_00000204_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ルルーナも心配だが、なんだか夜日楽も顔色が悪いな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0159" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "放課後から、各チームに分かれて練習が始まる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020113580001" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「大丈夫か、夜日楽」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「私、やっていけるんでしょうか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020113580002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "うん、そうだな。同情はする。だが代わってもやれんし、代わりたくもない。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "sbg_0125" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「さあ、特訓を始めるわよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113580003" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "夜日楽が心配になり、校庭をのぞいてみると……ルルーナのチームがコンダラ\nを引いている。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「とにかく体力が大事です！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113580004" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「は～い！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020113580001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……。わかった……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130113580001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「お、重い……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020113580003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0160" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「ルルーナ様……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_050113580002" ]},
		{"command":[ "SETCHARA", "0", "char_00000204_01", "4", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ん？　その声は輝夜……って、なに電信柱の陰からチームを見守っているんだ\n。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "というか、その電信柱はどこからもってきたんだ？", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「ひぃー……ひぃー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020113580004" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "4", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「さあ、休まずいくわよ！　瞬発力を鍛えないといけないから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113580005" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "と、ルルーナが用意したボールが火炎を纏う。", "NORMAL" ]},
