		{"command":[ "SETCHARA", "0", "char_00015602_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……しゃあないな」", "NORMAL" ]},
