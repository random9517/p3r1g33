		{"command":[ "SETCHARA", "0", "char_00021202_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「ああ……って、情けをかけられたところで、感謝なんかしないんだからなっ\n！」", "NORMAL" ]},
