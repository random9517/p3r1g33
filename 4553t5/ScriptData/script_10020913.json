		{"command":[ "SETCHARA", "0", "char_00021202_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「本部から連絡よ。街の暴走車両は無事に停車しているみたい」", "NORMAL" ]},
