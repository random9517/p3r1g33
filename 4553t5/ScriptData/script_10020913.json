		{"command":[ "SETCHARA", "0", "char_00015602_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「おぼえてろぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010114170010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ああ、行ってしまわれましたな」", "NORMAL" ]},
