		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうか。ならこれで一件落着だな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
