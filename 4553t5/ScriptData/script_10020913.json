		{"command":[ "SETCHARA", "0", "char_00015602_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「待って、みんな。今回は逃がしてあげましょう」", "NORMAL" ]},
