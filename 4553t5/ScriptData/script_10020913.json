		{"command":[ "SETCHARA", "0", "char_00021202_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「なに言ってるのよＭ．Ａ．Ｍ．Ａ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114170001" ]},
		{"command":[ "SETCHARA", "0", "char_00011102_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「だってこの子は、みんなと一緒に私に乗ったファミリーだもの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114170002" ]},
		{"command":[ "SETCHARA", "0", "char_00021202_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「……っ！　ママぁ……っ！」", "NORMAL" ]},
