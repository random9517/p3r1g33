		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「こいつの待遇はきっと俺と同じだ。組織の末端だろうから、敵の情報なんか\nロクにもってないだろう」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……そうだよな？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「そ、そうだ！　私は知らない！　陛下の指示に従って動くだけだからな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010114170008" ]},
		{"command":[ "SETCHARA", "0", "char_00015602_01", "3", "CENTER", "0" ]},
