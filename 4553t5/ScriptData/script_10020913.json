		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ということで、これが逃げ出そうとしていた襲来者（インベーダー）のリー\nダーだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「くそぅっ！　二度もこんなやつらに捕まるなんて！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010114170003" ]},
		{"command":[ "SETCHARA", "0", "char_00015602_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「煮るなり焼くなり、エロ同人誌みたいにするなり好きにしろ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010114170004" ]},
		{"command":[ "SETCHARA", "0", "char_00015602_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「百部刷って在庫を抱えてしまえー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010114170005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「また自棄を起こして泣き叫んでますな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010114170002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「お前には話してもらいたいことがたくさんあるからな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114170002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ああ。本部に連れ帰ってしかるべき処置をしよう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090114170002" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「ひぃい……っ！」", "NORMAL" ]},
