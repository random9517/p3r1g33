		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「……お前に、下手に匂わせることを言っても仕方ない。単刀直入に言う……\n今のヴァルキリー状態のことだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3403102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「普段以上に力が漲ってくるのはいいのだが……どうしても、まだ身体の制御\nというか……色々と持て余すものがあってな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3403103" ]},
		{"command":[ "SETCHARA", "0", "char_00000134_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「つまり……せ、性欲というか……何だか無性にお前の……せ、精液を浴びた\nくなっているのだ。だから、ご奉仕パイズリをさせてくれっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3403104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「急なのは分かっている……だが、私の方も待ちきれなくてな……んっ、イヤ\nではなさそうだな……では、早速……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3403105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ほら……見てみろ……こ、こんなに乳首が硬くなっているだろう……もう、\n昼間のうちからずっとそうで……ウズウズしていたんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3403106" ]},
		{"command":[ "SETIMAGE", "0", "still_00000134_01_01" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「おっ……ふふ……なんだ、私のおっぱいであっという間にオチンポが勃起し\nてきたじゃないか。お前も発情していたのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3403107" ]},
		{"command":[ "SETIMAGE", "0", "still_00000134_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「まぁ、お前のおっぱい好きは今に始まったことじゃないものな。話が早くて\n助かる……ほら、さっさとオチンポを入れないとご奉仕できないぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3403108" ]},
		{"command":[ "SETIMAGE", "0", "still_00000134_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ……あぁ……んふ……そうだ……この感触……これを、ずっと挟んでや\nりたかった……肌がチリチリと逆立っている……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3403109" ]},
		{"command":[ "SETIMAGE", "0", "still_00000134_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「さて……動かすぞ……んっ、ちょっと……唾液を垂らして……滑りやすいよ\nうにな……んっ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3403110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ふふ……早速オチンポがいい感じに暴れているな……んっ、いかにもやんち\nゃなきかん坊だ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3403111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「まずは、じっくりと亀頭を可愛がってやろう……先端は一番敏感な場所だか\nらな……ん、ぁっ、んく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3403112" ]},
		{"command":[ "SETIMAGE", "0", "still_00000134_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「皮をズリズリとめくり上げて……んっ、はぁっ……こら……嬉しそうに跳ね\nさせるのはいいが、おっぱいからはみ出るんじゃない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3403113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「気持ちいいのは分かるが、パイズリがしにくいからな……ご奉仕しやすいよ\nうに協力してくれ。んっ、ふっ、そうだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3403114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「今日は全部身を任せてくれればいい。いっぱいシコシコ扱いて……新鮮なザ\nーメンをたっぷり搾り出してやるからな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3403115" ]},
		{"command":[ "SETIMAGE", "0", "still_00000134_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ、はぁ……んっ、んふぅ……はぁ……あっ、ふっ……どうだ……オチン\nポ全体をマッサージしてやるからな……は……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3403116" ]},
		{"command":[ "SETIMAGE", "0", "still_00000134_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「感触はどうだ？　柔らかいか……それにすべすべしている……？　ふふ……\n他にはどうだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3403117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「時々乳首が擦れて気持ちいい……？　皮が捲れる瞬間が堪らない……そうか\n、そうか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3403118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「そんなことを聞かされたら、もっともっとしてやりたくなって来るな。いい\nぞ……まだまだ、ここからが本番だからな……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3403119" ]},
		{"command":[ "SETIMAGE", "0", "still_00000134_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「今度は……左右からのプレス……んっ、オチンポを窒息させてしまうような\n……圧を掛けていくぞ……は……んふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3403120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ふふっ……気持ちよさそうな顔をして……可愛い声まで出てるじゃないか。\nもっと、その呻き……聞かせてもらおうか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3403121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ほぉら……んっ、んんっ、あっ、ふっ……！　乳首も……ツンっと……アク\nセントだ……んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3403122" ]},
		{"command":[ "SETIMAGE", "0", "still_00000134_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あふっ、私も……ヘンな声が出てしまっているな……何しろ、ヴァルキリー\nになって感度がかなり上がってしまっているからな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3403123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「こうしてオチンポに密着しているだけで……身体が火照って……分かるだろ\nう……こんなに熱くなっているのが……んぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3403124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁ、んっ……もっと余裕を持って……してやりたいが……んぁっ、ふっ…\n…扱いているだけでも……気持ちよくてな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3403125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「はっ、んぁっ、くぅっ……声が出てしまうのは許してくれ……何……？　そ\nの方がずっと興奮する？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3403126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「んふっ……そうだったな……確かに、私もお前の声を聞いてそうなるんだ…\n…お互い様ということか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3403127" ]},
		{"command":[ "SETIMAGE", "0", "still_00000134_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ならば、下手に我慢せず……一緒に気持ちよくなっていこう……はっ、んん\nっ、あっ、ふっ……あぁ……いい感じだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3403128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「擦れば擦るほど……滑りがよくなって……オチンポのビクビクもいっぱいに\n感じる……おっぱいが犯されている気分だ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3403129" ]},
		{"command":[ "SETIMAGE", "0", "still_00000134_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ふふ……腰が自然に突き出てしまうみたいだな……一生懸命足を踏ん張らせ\nて……可愛い奴め……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3403130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「こうして、ずりずりと……根元の方も包み込んでやると……ほぉら、また跳\nねた。また乳首で……ぎゅっと……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3403131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あひっ！　あぁ……カリと乳首のキス……気持ちよすぎる……んっ、あぁ…\n…オチンポがおっぱいの間でビクビクしてる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3403132" ]},
		{"command":[ "SETIMAGE", "0", "still_00000134_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、先走りも滲んできた……後もうちょっと我慢だぞ？　もう一\n扱きで……思いっきり射精させてやるからな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3403133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「そうだ……ギリギリまで我慢して出すと……気持ちいいからな……ビクビク\nしてる……いよいよ限界だな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3403134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「はっ、ふっ……んんっ、もちろん……このおっぱいに中出しだ……私のおっ\nぱいを孕ませるつもりで出してみろっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3403135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ、くっ、ふぁっ、はぁっ……さぁ……いいぞっ、遠慮なく……出せっ…\n…んっ、ふっ、はっ、んんんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3403136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あふっ……！　あぁっ……来たっ……この熱いのを待っていたぞ……んんっ\n、ザーメンミルクが……溢れて来るぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3403137" ]},
		{"command":[ "SETIMAGE", "0", "still_00000134_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁ……ねっとりして……最高の感触だ……んんっ、おっぱいが熱い……く\nぅん……オチンポが谷間の中で震えてる……可愛いな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3403138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁ、はふ……どうだ、しっかり溜めた分、かなり気持ちいい射精だっただ\nろう？　もう少し粘れたかも知れないな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3403139" ]},
		{"command":[ "SETIMAGE", "0", "still_00000134_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ふふ、腰砕けになりそうだったか？　まあ、無理もない。力が抜ける位の射\n精だからな……上出来だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3403140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「おっと……まだ腰を引くには早いぞ？　射精も一段落したとはいえ、まだ一\n発出しただけだからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3403201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「どうだ？　続きをして欲しいんじゃないか？　さあ……どうする？　んっ、\n逆……？　　まだ続きをしたいのは私の方……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3403202" ]},
		{"command":[ "SETIMAGE", "0", "still_00000134_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ま、まぁな……それを言われると……確かにそうなんだが……だが、お前の\nオチンポも欲しがっているのは確かだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3403203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ほら……こうして、またぎゅっと挟み込まれて……いっぱい扱かれたいだろ\nう……？　んっ、ふっ、あぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3403204" ]},
		{"command":[ "SETIMAGE", "0", "still_00000134_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ダメだ……んんっ、私の方が……もう待ちきれなくなってる……パイズリ…\n…続きさせてくれ……オチンポもっと扱かせてくれ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3403205" ]},
		{"command":[ "SETIMAGE", "0", "still_00000134_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「はっ、んんっ……谷間の中に精液がどっぷり入って……今……すごいことに\nなっている……んっ、ふっ、くっ……ヌルヌルだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3403206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「オチンポ全体も精液まみれだ……ちょっと気持ち悪いんじゃないか？　それ\nとも、このヌルヌルは、やっぱり快感になってしまうのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3403207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「私は……んっ、あふっ……ずっと気持ちいいままで……はぁ……んっ、おっ\nぱいが……どんどん熱くなってしまってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3403208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「心臓の鼓動も高鳴るばかりだ……分かるか？　こうすると……ちゃんとオチ\nンポにも伝わっているだろう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3403209" ]},
		{"command":[ "SETIMAGE", "0", "still_00000134_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「はっ、ふっ……んんっ、乳首も……コチコチになっている……オチンポの敏\n感な場所同士でくんずほぐれつして……あっ、んくぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3403210" ]},
		{"command":[ "SETIMAGE", "0", "still_00000134_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁぅっ……んんっ、んふっ……気持ちよくなると……自然に、あっ……動\nきも大きくなって……おっぱいが揺れるっ！」", "NORMAL" ]},
