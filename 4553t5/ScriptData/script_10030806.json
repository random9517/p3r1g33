{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0025" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「ああもうっ！　なんでわたしがお姉ちゃんに攻撃されなきゃならないの！？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010115700001" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「確かに不可解だな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090115700001" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「あんな変な格好で襲い掛かってくるなんておかしいだろ。それに狼の方がつ\nよいぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010115700001" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「そういう問題じゃないだろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010115700001" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「まさか、時間帝国に操られているのでは！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115700001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「なんだって！　時間帝国……許せん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010115700001" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「もう一回渦に飛び込もう。今度こそお姉ちゃんを助け出すんだから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010115700002" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ちょっと待ってくれ、カグヤの姿が見えないな。どこへ行った？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090115700002" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0154" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "一方、保健室。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「とにかく、まりあのいる空間に入り込める方法を探して」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010115700001" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「まりあは、絶対に抜け駆けするつもりでいる。あんな空間を生みだして、邪\n魔になるわたしたちを排除して……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010115700002" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「そんなこと許さない。カツマは渡さない。ふふ、ふふ、ふふふふふふふ……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010115700003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「お、落ち着いて。うん、キミの言いたいことは大体わかったから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010115700001" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「ボクだって、今の状況はかなりマズいとおもってる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010115700002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「それで、いろいろと分析したんだけど……どうやらまりあとカツマは、タイ\nムループに捕らわれているらしい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010115700003" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「同じ時間を繰り返しているってこと？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010115700004" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「そう。ただ、まったく同じ時間を繰り返しているわけじゃないみたいだね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010115700004" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「そうなんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010115700005" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「ほら、キミたちがちょくちょく介入しているだろう？　だから、スタートが\n同じでも結果までの過程が違ってくるんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010115700005" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「でも、最終的には初めに戻る。例えるなら、コンビニに行くのに最短距離で\nいくか、あちこち寄り道するかの違いかな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010115700006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「なるほど。それで、どうすればループからカツマを助けられるの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010115700006" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「それは簡単。でも一番難しい。なにせ、まりあくんをどうにかしないといけ\nないからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010115700007" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「ループの中は、まりあくんに都合のいい世界になっている。だから邪魔者を\n排除することができるんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010115700008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「つまり、まりあに邪魔されず、カツマを連れだせばいい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010115700007" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「そういうこと。ただ、その方法はまだわからな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010115700009" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「今すぐそれを見つけて！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010115700008" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「ひぃっ！　そ、そんな怖い顔しないで。ちゃんと見つけるから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010115700010" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「……お願い」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010115700009" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「わ、わかったよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010115700011" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「こ、こわ……。さっきの顔、学園長より怖かったんだけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010115700012" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}