		{"command":[ "SETNAME", "巨大ルナテミス" ]},
		{"command":[ "SETTEXT", "「ふんが～～～～～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_998_130105170001" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
	{"command":[ "DISPTEXT", "TRUE" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うわわああああっ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「カツマ！　大丈夫！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010105170001" ]},
	{"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あ、ああ！　大丈夫だ！　すげえ馬鹿力だな、あいつ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「あいかわらずこっちの攻撃が効いてないな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010105170001" ]},
	{"command":[ "SETCHARA", "0", "char_00000401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「アナザー！　準備はまだか！　ドラグソードは！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010105170001" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「待たせた！　今ならいける！　メカ・ジュンジロー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090105170001" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａジュンジロー" ]},
		{"command":[ "SETTEXT", "「了解（ラジャー）……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_040105170001" ]},
	{"command":[ "SETCHARA", "0", "char_00000904_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090105170002" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "アナザーは飛行形態に変形したメカ・ジュンジローに飛び乗り、巨大ルナテミ\nスへと向かっていく。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "sbg_0011" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ゴラド・イザヤ・ムーン、月龍の血の元に――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090105170003" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "アナザーの剣が光を放ち、大空に魔法陣を描く。そして、その魔法陣の中から\n――", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「出でよ！　ドラグソード！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090105170004" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYBGM", "BGM_007" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「来たぁっ！　ドラグソードッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_020105170001" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0015" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ざまぁ見なさい、でっかいルナテミスちゃん！　こっちのお顔のほうが大き\nいんだからーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010105170001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0022" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "巨大ルナテミス" ]},
		{"command":[ "SETTEXT", "「がおおおおお～～～～～っ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_998_130105170002" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "巨大ルナテミスの注意が、ドラグソードに向く。その機を逃さず、アナザーが\nドラグソードに命じる。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「放て！　竜の咆哮（ドラゴンズロア）！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090105170005" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0015" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ドラグソードの巨大な口からまばゆい閃光が放たれた！", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0015" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "だが――", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0022" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "巨大ルナテミス" ]},
		{"command":[ "SETTEXT", "「うおおおおおおおおおおーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_998_130105170003" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
