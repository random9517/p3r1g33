	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0022" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「まさか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010105170001" ]},
	{"command":[ "SETCHARA", "0", "char_00000301_01", "3", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「巨大ルナテミスも光線を！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010105170001" ]},
	{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "一同" ]},
		{"command":[ "SETTEXT", "「うわああぁーっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010105170002" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "-600" ]},
	{"command":[ "SETCHARA", "1", "char_00000109_01", "3", "CENTER", "-200" ]},
	{"command":[ "SETCHARA", "2", "char_00000201_01", "3", "CENTER", "200" ]},
	{"command":[ "SETCHARA", "3", "char_00001302_01", "3", "CENTER", "600" ]},
	{"command":[ "DISPCHARA", "1", "TRUE" ]},
	{"command":[ "DISPCHARA", "2", "TRUE" ]},
	{"command":[ "DISPCHARA", "3", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ドラグソードと巨大ルナテミス、両者の中間で光線がぶつかり合い、さらに強\n烈な閃光を発する。", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0000" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
	{"command":[ "DISPCHARA", "1", "FALSE" ]},
	{"command":[ "DISPCHARA", "2", "FALSE" ]},
	{"command":[ "DISPCHARA", "3", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "あまりのまぶしさに、何も見えない！", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "いったい、状況はどうなっちまってるんだ！？", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "やがて、光が薄れ、しだいにあたりのようすが見えてくると――", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0022" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "巨大ルナテミス" ]},
		{"command":[ "SETTEXT", "「ぐうぅうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_998_130105170004" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "1", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "俺たちの目に飛び込んできたのは、がっくりと膝をつく巨大ルナテミスの姿だ\nった！", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「やったのか！？」", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「仕留めることまではできなかった。しかし、かなりのダメージは与えたはず\nだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090105170007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「もう一発撃てるか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「残念だが、それは無理だ。ドラグソードは、まだ完全ではないのだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090105170008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「だったら、わたしたちがやっつければいいよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_020105170003" ]},
	{"command":[ "SETCHARA", "0", "char_00001302_01", "0", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「やれるのかい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010105170003" ]},
	{"command":[ "SETCHARA", "0", "char_00000301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａジュンジロー" ]},
		{"command":[ "SETTEXT", "「今の攻撃により、目標はナノマシン同士の結合が弱まっていると思われる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_040105170002" ]},
	{"command":[ "SETCHARA", "0", "char_00000904_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「つまり弱体化しているということだな！　行こう！　我々の手で仕留めるん\nだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010105170003" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「自分の手でカタをつける、ってことですね！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「だからあれは偽者だーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010105170004" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
	{"command":[ "EXIT" ]}
