	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「ごきげんよう、坊や……忍術の強化訓練を行うって聞いてるんだけど……そ\nれ、本気でござるかしら？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0203101" ]},
		{"command":[ "SETCHARA", "0", "char_00015202_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「ふふふ、ヘタな言い訳ね……目的は、わかってるでござるのよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0203102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「……こっそりエッチなこと、するつもりなんでござるでしょ？　ふふ、男の\n子ってみんなそう……隊長氏？　目線がずーっとエッチだったわよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0203103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「けど……その……知ってるでしょう？　わたし、いえ、その……拙者は……\nまだ、未経験だって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0203104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「そう、よかった。経験までは至らないなら全然オッケーでござるわ。いっぱ\nい頑張っちゃう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0203105" ]},
		{"command":[ "SETCHARA", "0", "char_00015202_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「ええっと……それで……パ、パイズリをすればいいのね……ええ、任せてお\nいてでござる……これで、いいのよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0203106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015202_01_03" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「はぁ……オチンポ、大きい……谷間の中で、熱く脈打ってる……はぁ、すご\nぉい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0203107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「うぅん♪　そんな目で見ないでぇ……いつもセクシー路線だけど、こういう\nことに免疫がないこと、知ってるでござろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0203108" ]},
		{"command":[ "SETIMAGE", "0", "still_00015202_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「それにしても、上手くできるかしら……ドキドキでござるわ……。ヘタでも\n、文句言わないでね？　約束よ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0203109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「はぁ……その目、たまらない……ぞくぞくしちゃう……。ふぅ……それじゃ\n、そろそろ始めるわね――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0203110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「ん、んん、はぁっ、あぁぁ……あふぅ……どう、でござるか？　ん、ふぅ…\n…谷間の中で、スルスル擦れて、気持ちいいでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0203111" ]},
		{"command":[ "SETIMAGE", "0", "still_00015202_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「え？　もっとヌルヌルが欲しい……？　唾液を垂らせばいいでござるか……\n？　んん……んべー…………これでいい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0203112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「んんぁ、あはぁあぁ……唾液でトロトロしてる……はぁ、なんだか、すごく\nエッチぃ……ふふ、坊やのその目も素敵ぃ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0203113" ]},
		{"command":[ "SETIMAGE", "0", "still_00015202_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「はぁ……見られているだけで、ゾクゾクしてきちゃう……見てぇ、乳首がビ\nンビンになっているでござる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0203114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「はぁ……おっぱいを動かすと、ん、んん……擦れて気持ちいい……はぁ、ふ\nぅ……思ったよりも、楽しいでござるね、これ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0203115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「ん、ふぅ……坊やのその目、たまらない……はぁ、あふぅ……乳首がもっと\nビンビンになっちゃうでござる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0203116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「んふふ……随分余裕？　そんなことないわよ……慣れないことやらされて、\n実は心臓バクバクなんだからぁ……ふふふ……はぁ、あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0203117" ]},
		{"command":[ "SETIMAGE", "0", "still_00015202_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「そうね……多少は慣れてきたかも……え？　やだ……本物のエッチはまだち\nょっと……また今度にしましょ？　ね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0203118" ]},
		{"command":[ "SETIMAGE", "0", "still_00015202_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「うふふ、ありがとう……優しいのね、坊やって……はぁ、ふぅ……本当にい\nつもいつも感謝しているでござるよ、かたじけない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0203119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「あはは、ござる口調、わたし、全然上達しないわね……まあ、それはともか\nく、もっとエッチなこと、したくなって来ちゃった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0203120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「ん、んぁむ、れろ、ねろぴちゃ、ぬるん……ぬる、ぴちゃ、れろれろ……は\nぁ、あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0203121" ]},
		{"command":[ "SETIMAGE", "0", "still_00015202_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「うぅん……♪　オチンポの味ぃ……はぁ、はぁ……すごく美味しい……れろ\n、ぴちゃ……ぬるる……あふぅ……この匂い、好きぃ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0203122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「れろぬるる、ぴちゃ、ぬちゅぅ……はぁ、あはぁ……オチンポって、全然嫌\nいじゃないわよ……なんだか、愛おしくなって来ちゃったぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0203123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「え？　エッチな顔してる……？　やぁん……もっと見てぇ……はぁ、はぁ…\n…見られると、もっとエッチになっちゃうぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0203124" ]},
		{"command":[ "SETIMAGE", "0", "still_00015202_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「あぁん……その目、いい……わたしを、目で犯してる……はぁ、はぁ……れ\nろれろ、ねるん、ぬちゅ、ぴちゃ、ちゅぬるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0203125" ]},
		{"command":[ "SETIMAGE", "0", "still_00015202_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「あ、ああ……おっぱいが……お口が、止まらない……ねる、れろん、ぴちゃ\nぴちゃ、ねりゅる、ぬちゅぴちゃぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0203126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……それにしても、ペロペロしながら、おっぱいを動かすのっ\nて、大変ねぇ……はぁ、あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0203127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「れる、ねろねろ、ぴちゃぁ……はぁ、ふぅ……でも、坊やのためなら、いく\nらでも頑張れるわぁ……くちゅ、ぬるる、れろぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0203128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁあん……ねるねる、にちゃ、んちゅ、ちゅちゅぅ……れるん、に\nちゃねろ、れるれろ、ちゅちゅぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0203129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「あはぁぁあん……おっぱいと、口で、オチンポいっぱい感じちゃうぅ……は\nぁ、ふぅ……興奮が止まらないわぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0203130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「え？　坊やもいっぱい興奮する？　そう……じゃあ、もっと激しくするわね\nぇ……よいしょっと、ん、ん、はぁ……ああぁぁん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0203131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「れろ、れろれろ、ねるん、ぬちゅぴちゃ……はぁ、あはぁ……オチンポ、ヒ\nクヒクしてるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0203132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「ねる、ぬるる、ぴちゃぴちゃ、くちゅぅぅ……んふふ、谷間の中で、脈打っ\nてる……オチンポ、気持ちよさそうにしてる……んんぅん……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0203133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「え？　イキそう……？　いいのよ……出してぇ……はぁ、はぁ……れろちゅ\nちゅ、ぬちゅ、れろにゅるる、ちゅぼぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0203134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「あ、ああ……震えてる……れろれろ、ねろん、あああ……オチンポの中を、\n駆け上がってくる……んん、はぁ……はぁぁぁあん……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0203135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「あぁぁん♪　はっ、あぁ……はぁぁぁぁん……♪　オチンポ、ずごぉお……\nんん、はぁ……はぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0203136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015202_01_05" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「んっ、んんっ、んはぁ……はぁぁ、濃いぃ……♪　肌に、へばりついて……\nああん、ゆっくり滴っていく……あはぁ……気持ちいい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0203137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「うぅんっ、口の中も、ううん……鼻の奥まで……精液でビチャビチャ……は\nぁ、はぁ……味と匂いと触れ心地……ああん、五感で精液、感じちゃう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0203138" ]},
		{"command":[ "SETIMAGE", "0", "still_00015202_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「ねえ、見てぇ……今のわたし、いっぱいいやらしい……はぁ、ふぅ……坊や\nは、いやらしいわたし、好きぃ……？　ふふ、そう、よかったぁ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0203139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「ふぅ……ねえ、もっとしたいんじゃない？　だって、オチンポ、まだこんな\nにカチカチなんだもん……このまま続き、しましょ――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0203140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「ふふふ、わたしのこの姿を見て、もっと興奮したんでしょ？　あはぁ……嬉\nしい……いっぱい見てぇ……エッチな視線で、わたしを舐め回してぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0203201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「ん、んん……はぁ、精液の味が口の中にこびり付いてる……はぁ、ふぅ……\n変な味ぃ……少ししょっぱくて、後味が苦い……大人の味ねぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0203202" ]},
		{"command":[ "SETIMAGE", "0", "still_00015202_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「はぁ……ふぅ……あぁん、谷間の中で、精液がニチャニチャしてる……はぁ\n、トロトロオチンポ、かわいい……んふふふ……ン～～～……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0203203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「んはむ、ぴちゃ、ねるん、れろれろ……ちゅるるぅ……ゴクン……はぁ、少\nしはキレイになったかしら？　お掃除フェラ……楽しい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0203204" ]},
		{"command":[ "SETIMAGE", "0", "still_00015202_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「ふふ、れろ、れろれろ、ねろん……舌を動かしていくたびに、坊やの目線が\n、どんどんエッチになっていく……ああん、たまらない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0203205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「はぁ……あふぅ……見られてるだけで、アソコを直接弄り回されてるみたい\n……ん、ちゅ、ぴちゃぴちゃ……はぁ、子宮がうずくぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0203206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「んふふ、もっと人前でしてみたいわねぇ……なーんて、冗談よ。わたしは、\nあなただけのものだもん……でも、見られるだけなら、楽しそう……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0203207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「ん、ふぅ……れろれる、ぬるる、ちゅぽぉ……はぁ、想像しただけで、興奮\nしちゃった……ああん、舌が止まらない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0203208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「ぴちゃ、ぴちゃ、れろれろ、ねろん……はぁん、おっぱいの中から、にちゃ\nにちゃ音が聞こえてくる……はぁ、あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0203209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「精液、気持ちいい……触れ心地も、味も匂いも好きぃ……子宮がジンジンし\nちゃうぅ……はぁ、はぁ……あぁぁあん……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0203210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「え？　もっと締め付ければいいの？　いいわよぉ……はぁ、はぁ……ん、ん\nん～～……どう？　みっちりおっぱい気持ちいい……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0203211" ]},
		{"command":[ "SETIMAGE", "0", "still_00015202_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「ん、れろ、ねろれる、はぁ……んん、ぴちゃぬるる、れろれろ、ちゅぬる、\nちゅちゅずちゅ、じゅぼぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0203212" ]},
		{"command":[ "SETIMAGE", "0", "still_00015202_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「はぁ……あぁぁあん……おちんぽ、ビクンビクンしてる……はぁ、ふぅ……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0203213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
