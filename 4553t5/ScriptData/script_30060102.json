{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000601_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "PLAYVOICE", "006_0104101" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「……ね～え？　どうしてダイヤナちゃんのことを縛るのかしら？　こんなこ\nとしなくたって、もう逃げたりしないわよ？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0104102" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「それに、これってマッサージに使うものよねぇ？　確かに肩は凝るけど、お\nっぱいとかはべつに凝ってないし……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0104103" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「Ｈなところばっかりに貼って、これでいったいナニをするつもり……ひゃぐ\nううううっ！？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000601_02_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0104104" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ひゃあああああんっ！　ダメっ、ダメダメぇっ！　これすごすぎるぅっ！　\nおっぱいがブルブルってしてぇ、おかしくなっちゃうっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0104105" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「おねがい、これ止めてぇっ！　でないとダイヤナちゃんの身体がぁっ……あ\nっ、あっあっあっ……キちゃうっ！　変なのキちゃうぅぅぅっ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0104106" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あぁぁぁ……ナニ、コレぇ……イッちゃった、Ｈな道具で、あっさりイかさ\nれちゃったぁっ……」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000601_02_03" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0104107" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あぁんっ！　待って、イったからぁっ……！　今、身体が敏感になっちゃっ\nてるのぉっ……お願い止めてぇ……！　おかしくなっちゃうからぁっ……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000601_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0104108" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「強すぎるぅっ、気持ちいいのが全然止まらなくってぇっ、あっあっあっ、ダ\nメぇっ！　またイっちゃうっ、イっちゃうっ！　イヤぁぁぁんっ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0104109" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁっ……おねがい、もう十分だからぁ……いっぱい気持ちよくな\nったから、もう止めてぇ……でないと、ホントにおかしくなっちゃうっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0104110" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あ、あ、あ、ダメ、またキちゃう、キちゃってるっ！　気持ちいいのが止ま\nらなくて、もうずっとイってるのぉっ！　んあぁぁっ！　らめぇええっ！！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000601_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0104111" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「はぁぁぁっ、はぁっ、はぁっ……！　どうして、こんなひどいことするのぉ\n、あぁあんっ、何か怒ってるなら、謝るからぁっ、だからもう止めてぇっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0104112" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「……え？　ま、待って……このまま放置って……ウソ、よね？　そ、そんな\nことされたら、ダイヤナちゃん、壊れちゃうっ……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000601_02_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0104113" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ま、待ってぇっ！　お願い、行かないでぇっ！　このままなんて、そんなの\nホントにおかしくなっちゃうからぁっ！　頭がバカになっちゃうぅっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0104114" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あ、あ、あ、またクるっ、キちゃうぅっ！　大っきいのキちゃってるっ！　\n気持ちいいのがドンドン強くなって、身体が変になっちゃってるぅっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000601_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0104115" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「お願い、許してぇっ……！　あぁぁぁ～～～っ、ダメ、ダメダメぇっ……大\nっきいのキちゃってる、もうイく、イっちゃうからぁっ、んあぁぁっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0104116" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「……ひぃ、ひぃぃっ、あぁ、またキちゃうっ、イっちゃうっ、もうずっとイ\nってるの、頭おかしくなっちゃった、バカになっちゃったぁ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0104117" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あ、あ、あ、イぐっ、またイぐぅっ……っ、っ……はぁ、はぁ……あぁ、ダ\nメぇ、見ないでぇ、こんなダイヤナちゃんを見ないでぇ……っ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0104118" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「はぁぁっ、はぁぁっ……や、やっと止まったぁ……。ひどいじゃないのぉ、\nホントにあのまま置いていくなんてぇ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000601_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0104119" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ずっとイキっぱなしで、狂っちゃうかと思ったんだからぁ……身体は気持ち\nいいのに、イけばイくほど、オマンコの奥がじんじん痺れてきちゃって……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0104120" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「イってもイっても、物足りなくて……なのに、オマンコはどんどん切なくな\nってくるし……今だって、もうホントにたまらないんだから……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0104121" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「だからぁ……お願い、挿れてぇ……あなたのオチンチンを、ダイヤナちゃん\nのオマンコに、奥までずっぷり突き刺して欲しいのぉ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0104122" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「お願い、なんでもするからぁ……いつでもどこでも、ダイヤナちゃんの身体\nを好きに使って、おっきなおっぱいを玩具にしてもいいから、だから……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0104123" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ダイヤナちゃんのＨな姿を見てガチガチに勃起したペニスを、トロトロのオ\nマンコに奥くまで挿入して、ぐちゃぐちゃにかき回してぇっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0104124" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「んはぁあああ～～～っ！！　オマンコに入ってきたぁっ……！　おっきくて\n固いオチンチンが、オマンコの中に、ずぷずぷ入ってきてるぅっ……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000601_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0104125" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「こんなの気持ちよすぎるわよぉっ……！　オマンコが敏感になってるからぁ\nっ、オチンポのデコボコが、ひとつひとつまでわかっちゃうぅっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0104126" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「んぁあああっ、すごいぃっ、オマンコ気持ちよすぎるぅっ！　あなたが初め\nてなのにっ、気持ちいいのが止まらないの～！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0104127" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「もっとしてぇっ！　あなたのオチンチンで、ダイヤナちゃんのぴちぴちオマ\nンコを、もっとしつけてぇっ！　あなたのオチンチンの形にしてぇっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000601_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0104128" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あ、あ、あ……！　すごいの、クるっ……！　あなたのオチンポでオマンコ\nをハメハメされてぇ、イかされちゃうっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0104129" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あなたも一緒にイってぇ……もう、出そうなんでしょ？　わかるわよ、出し\nたそうな顔してるもの……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0104130" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「目の動きとか、息遣いとかぁ、あぁんっ、オチンチンの固さで、何となくわ\nかっちゃうのぉ、あなたがイクときのクセ、全部覚えちゃったのぉ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000601_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0104131" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「だから、オチンチン、イってぇっ、ダイヤナちゃんのオマンコにいっぱい中\n出ししてっ、子宮が溺れちゃうくらい、オマンコの奥にたっぷり射精してっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0104132" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、あっ、もう、ダメぇっ！　あたしもイっちゃうっ！　オマンコ\nの奥までオチンポでかき回されてぇっ、もう、イっちゃうううううっ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0104133" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あはぁあああああんっ！！　出てるっ、オマンコの中に、熱くてドロドロの\nせーえきが、いっぱい出てるぅ……！」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000601_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0104134" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「奥の壁にびゅうびゅう当たってるぅっ……！　気持ちいいぃ～～っ、Ｈなザ\nーメン中出しされて、オマンコまたイっちゃうぅぅっ……！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0104135" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「んはあぁぁっ……オマンコの中に精液が広がってぇ……熱くて、じんじん痺\nれて、奥まで染み込んじゃうぅ……オチンポしゅごいぃ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0104136" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「……えぇ～、ひどぉい、ダイヤナちゃんは淫乱なんかじゃないんだからぁ…\n…ホントに、あなたが初めてだったのよ？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000601_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0104137" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「……だって、昔の男は触ってもこなかったから……まだ地味だった頃のあた\nしにお金目当てで近づいて……あっさりと捨てたのよ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0104138" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「だからあたしは、誰もがうらやむような美女になって、世界中の男たちを見\n返してやろうと思ったの。……でも、やっぱり男の人が怖くてね……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0104139" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「このまま一生、あたしは処女のままで終わるんだなって、諦めてたのよ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0104140" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「でも今、こうしてあなたとできて……すっごく嬉しいわぁん♪　ホントはも\nっと、ロマンチックな感じが良かったのだけれど～」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0104201" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「だから、お願い……もっとして……身体がビンカンになってて、まだまだ物\n足りないのよ。もとはといえば、あなたのせいなんだからね？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0104202" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「責任取って、あなたのオチンポであたしのオマンコを気持ちよくして……も\nっとあなたのことを感じさせてほしいの……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0104203" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「んっはぁぁぁ～～～……っ！　カチカチの亀頭が、オマンコのお肉をぷりぷ\nりかき分けてぇ、あぁああんっ、奥まで入ってくるぅ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000601_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0104204" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あひぃんっ！？　あっ、あっ、オチンポの先っぽがぁ、あぁんっ、ぐりっ、\nぐりぃってぇ、子宮の入り口を擦ってるのぉっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0104205" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、あひぃいいんっ！　オチンポがズポズポ出入りする度にぃ、ひ\nぃんっ、ぶっといカリ首がオマンコの中をほじくってるぅっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0104206" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あはぁああんっ！　激しいぃっ！　ビンビンの勃起オチンポがぁ、オマンコ\nの中をぐちゃぐちゃにかき回してぇ、あぁああんっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0104207" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「オチンポ固くって、大っきくってぇ、とっても素敵よぉ～！　奥までゴリゴ\nリぃ、オマンコが擦られて、気持ちいいぃ～～！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0104208" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ダメ男なんて言ってごめんなさぁいっ！　あぁんっ、アレは全部ウソだった\nのぉっ！　もうずっと前から、あなたに夢中だったのよぉっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000601_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0104209" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あぁんっ、ごめんなさぁいっ！　ひどいことばかり言った、ウソつきでナマ\nイキなオマンコに、あなたのオチンポでお仕置きしてぇんっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0104210" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「頭空っぽのおバカなホルスタイン女を、あはぁああんっ、オチンポで、たっ\nぷりとしつけてぇっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0104211" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あひぃいいいんっ！！？　待ってぇっ、そのスイッチは入れちゃダメぇっ！\n　ひぁああんっ！　またビリビリしちゃうぅっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000601_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0104212" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「おっぱいもオマンコもぜんぶがしびれちゃうっ！　からだじゅうがビンカン\nになって、ムキたてのクリちゃんみたいになっちゃうぅっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0104213" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あひぃっ！　ひぃいいんっ！　きもちよすぎてぇ、頭がおかしくなっちゃう\nぅっ！　ホントにおバカになっちゃうのぉっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "006_0104214" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
