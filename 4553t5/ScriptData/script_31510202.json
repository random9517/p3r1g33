		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「うぅん……わざわざ呼び出さなくても、こっちから行くつもりだったんだよ\nぉ？　それで、どーしたんでござる？　お殿様ぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0204101" ]},
		{"command":[ "SETCHARA", "0", "char_00015102_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「ねえねえ、いっそのこと、拙者、この部屋に住んじゃおうかなー……そうし\nたら、行き来しなくていいから、楽になるでござるよ～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0204102" ]},
		{"command":[ "SETCHARA", "0", "char_00015102_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「あ……でも、そうなるとぉ、他の子を部屋に呼べなくなっちゃうのかぁ……\nそれは良くないかもでござるねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0204103" ]},
		{"command":[ "SETCHARA", "0", "char_00015102_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「……うーん、浮気は許すけどさぁ……でも、うーん、生活空間で浮気される\nのはちょっとなぁ……でも、面倒な子だって思われたくないしぃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0204104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「……んー、ま、いっか。こーいう話って、必要になってからすればいいでご\nざる。色々考えるの面倒だし……それじゃ、始めましょ、お殿様♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0204105" ]},
		{"command":[ "SETCHARA", "0", "char_00015102_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「んっ、はっ、あぁぁぁ……オチンポ、オチンポが……オマンコに入ってくる\nぅ……ぬぬぬって感じで……ああ、気持ちいい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0204106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015102_02_06" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「はぁ……んぅん……気持ちいいでござるぅ……はぁ、はぁ……あ、駄目かも\n、これ、すぐイク、パターンでござる……あ、ああ、はあぁあん！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0204107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「んはぁ……はぁ……はぁぁぁあん……♪　イッちゃい、ましたぁ……はー…\n…はー……あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0204108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「いきなり気持ちよくなって、申し訳ないでござるぅ……でも、お殿様のオチ\nンポ、気持ちいいんですもの～～……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0204109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「拙者だけじゃ悪いから、お殿様も気持ちよくなってもらいたいなぁ……はぁ\n、はぁ……動いてくれてよいでござるよ……拙者も動くでござるから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0204110" ]},
		{"command":[ "SETIMAGE", "0", "still_00015102_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「ん、んん♪　んはぁ、はぁ……一緒に動くと、一体感が気持ちいいでこざる\nねぇ……♪　はぁ、あぁぁあん……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0204111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「オマンコに、ずっぽりハマったオチンポが、全体を使ってこすりつけてくる\n……あ、ああ、すごぉい……内側の膜がピッタリ密着してる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0204112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「オチンポの形が、んん、はぁぁん……ハッキリとわかるでござるよぉ……あ\nあ、ゴツゴツしてて、色んな所、ゴリゴリされてるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0204113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……入ってくる……オマンコの一番深いところ、グイグイ押し込\nまれちゃうでごぁるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0204114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「はぁ……んんぅん……奥に、届いてる……気持ちいいところに、コツンコツ\nンぶつかってるでござるよぉ……ニンニン……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0204115" ]},
		{"command":[ "SETIMAGE", "0", "still_00015102_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「あぁぁん……硬い……奥から、硬いもの同士が、あ、ああ……ぶつかってる\n音が、んん……聞こえてくるでござる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0204116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「うふふ、先っちょがコツコツって、ノックしてくる……あぁん、これ、すっ\nごく気持ちいいよ、ダーリン……じゃなく、お殿様ぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0204117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「あはは、クノイチのキャラ、うっかり忘れちゃう……でも、頑張らなきゃ…\n…はぁ、んん……腰を引くと、中が、引っ張られちゃうぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0204118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「オマンコ全部が、オチンポにくっついていっちゃうよぉ……あ、ああ、あは\nぁぁ……気持ちいい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0204119" ]},
		{"command":[ "SETIMAGE", "0", "still_00015102_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「出たり入ったり……オマンコが押し込まれたり、引っ張られたり……はぁ…\n…はぁあん……オチンポにいっぱい犯されてるよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0204120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……出たり入ったり、押し込まれたり引っこ抜かれたり……は\nぁぁあん……ゆっくりとした動きが、じれったいでござる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0204121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「あぁん……！　や、駄目ぇ……だんだん激しくなって……ひっ、あっ、はぁ\n……はぁぁあん……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0204122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「すごぉい……身体が熱くなっていく……ん、んん、はぁ……あはぁぁん……\n♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0204123" ]},
		{"command":[ "SETIMAGE", "0", "still_00015102_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「腰の奥で、快感の火花が散ってるって感じぃ……はー……はぁあん……お殿\n様ぁ……いっぱい気持ちいいでござるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0204124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「ん、はぁっ、あああん……駄目ぇ……中が、掻き回されてるぅ……ん、あは\nぁ、ぐぅ……ひうぅぅ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0204125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「ま、またイキ、そう……はぁ、あふぅ……んっ、あぁ！　あはぁぁああん！\n！　はぁ……また、イッちゃ、たぁ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0204126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「あはぁ……中が締まってるでしょ♪　ねえねえ、お殿様ぁ……気持ちいい？\n　気持ちいいでしょう？　はぁ……嬉しいでござるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0204127" ]},
		{"command":[ "SETIMAGE", "0", "still_00015102_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「んくぅ……あはぁ……子宮が、ヒクヒクしてる……はぁ、んん、駄目ぇ……\nもっとイキたい……腰が、クネクネ動いちゃうぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0204128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「あっ、はぁ……突き上げられてるぅ……。身体が浮かび上がっちゃうよぉ…\n…はぁ、あふぅ……気持ち、いい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0204129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「ダーリン……ううん、お殿様ぁ……ぎゅーってしてぇ……力いっぱい抱きし\nめてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0204130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「はっ、ああっ、下から、オチンポが……お殿様の身体がズンズン突き上がっ\nてくるぅ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0204131" ]},
		{"command":[ "SETIMAGE", "0", "still_00015102_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「ひゃうぅ、んぐぅ！　はっ、あっ、あぁあ……駄目ぇぇ……またイク……イ\nッちゃいますぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0204132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、イク……んっ、もう駄目ぇ……はぁ、はぁ……あぁぁ……すご\nい……今日で、一番気持ちいいのが、来るぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0204133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「ねえ、お殿様ぁ……一緒にイッてぇ……はぁ、はぁ……ぎゅーってしてぇ…\n…ぎゅーっと……もっと……ん、んん、はぁ、あぁぁあん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0204134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「あ、ああ、イク……あはぁ、出してぇ……中に全部……んっ！　くっ！　は\nぁ……はぁぁぁあん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0204135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「んくぅ！　ひゃうぅぅ！　はっ、あっ、あああ……はへぇぇぇぇ……すごぉ\nい……頭の中まで精液が入ってくる、みたいぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0204136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015102_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「あはぁぁ……入ってくる……熱いのは、オマンコの中に……子宮の奥まで…\n…染み込んでくるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0204137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「きゃうぅ、あはぁ……中で、ヒクンヒクン動いてる……はぁ、あはぁぁ……\n子宮が、喜んでるよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0204138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「あはぁ……はぁ……気持ち、よかったぁ……ふぅ……はへぇ……イキまくっ\nたでござるよぉ……はー……幸せぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0204139" ]},
		{"command":[ "SETIMAGE", "0", "still_00015102_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「うふふ……お殿様、最高のセックスをありがとう……それじゃ、しからば御\n免…………って、わけにもいかないよね、これ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0204140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「だって、ほら……まだこんなにカッチカチなんだもん……ふふふ、すごいで\nござる……ビンビンしてる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0204201" ]},
		{"command":[ "SETIMAGE", "0", "still_00015102_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「はぁ……中で精液が掻き混ぜられてる……クチュクチュ音がする……はぁあ\nん、精液、気持ちいい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0204202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「子宮が、精液でいっぱいになってるでござる……はぁ、はぁ……大きくなっ\nてるから、いっぱい中でぶつかってくるでござるよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0204203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「あはぁ……気持ちいい……あ、ああ、またイク……あ、はぁ……ひうぅぅう\nん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0204204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……もう、何度イッたか、わかんないでござるよぉ……ニンと\nもカンとも……んはぁ、はぁ……あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0204205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「でも、まだイキたりないでござる……もっと拙者イキたいでござる……はぁ\n、はぁ……もっとお殿様に可愛がられたいよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0204206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「んあぁぁあ……はぁ、あああん……下から、ズンズンくるぅ……駄目ぇ……\n子宮が、弾んじゃうぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0204207" ]},
		{"command":[ "SETIMAGE", "0", "still_00015102_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「やっ、あ、あああん……中で、オチンポ、暴れてる……！　オマンコがグチ\nャグチャに掻き混ぜられちゃうぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0204208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「はー……あぁあん……精液が、泡立ってる……中でシュワシュワ泡が弾けて\n……はぁ、はぁあん……変な感じがするぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0204209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「クンクン……はぁ、はぁ……精液が割れ目から溢れてる……精液の匂いでい\nっぱいになってるよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0204210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「はー……はー……ダーリン♪　あたし、この体位、すごく好きかも……だっ\nて、ぎゅーってしながらいっぱい気持ちよくなれるんだもん……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0204211" ]},
		{"command":[ "SETIMAGE", "0", "still_00015102_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「あぁ、はぁ……おっぱいが、擦れて気持ちいい……え？　お殿様も……？　\nうふふ、嬉しいでござるよ……はぁ、あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0204212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「ああ……駄目ぇ……目の前が霞んできちゃったぁ……あはぁ、これって、気\n持ちが良すぎるからかなぁ……はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_0204213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「ああ……拙者、我を忘れてしまいそう……でござる……はぁ、ふぅ……ああ\nう、ござる口調、めんどいよぉ～～……」", "NORMAL" ]},
