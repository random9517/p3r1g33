		{"command":[ "SETCHARA", "0", "char_00016401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お？」", "NORMAL" ]},
