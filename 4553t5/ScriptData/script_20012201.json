		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「話をややこしくするなっての！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「まぁ、確かに貴方にそんな甲斐性があるような雰囲気は、毛ほども感じませ\nんけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021760011" ]},
