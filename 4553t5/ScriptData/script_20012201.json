		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ふぅ……やれやれ、やっと寝てくれたか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「子守も楽ではありませんな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021760001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「全くだ……基地内だろうが、外だろうが、人目があろうがお構いなしで甘え\nて来るからな……周囲の視線が痛ぇなんてもんじゃねぇぞ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「確かに、実の親子ならば微笑ましくもありますが、現実は不審者ですからな\nぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021760002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「だーれが不審者だ。と言いたいが……中でも外でもこの調子じゃな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「基地の中は、多少慣れて来たようですが、外は白黒ツートンカラーのお車が\n手ぐすね引いて待っていそうですな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021760003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……ぐ……言い返せねぇのがムカつく……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「特に公園は危ないですぞ。ママ友ネットワークは、かなりの精度と速度で情\n報を共有するようですからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021760004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「何でお前がママ友事情に詳しいんだよ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「そこはそれ、ワタクシめは犬ですからな。公園を駆けずり回っても何もおか\nしなことはありませんから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021760005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……なるほど、それで通報されたって訳か」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「な、なぜそれを……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021760006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「十分に不審な犬だからだろ。ったく、仕事ほっぽり出して一人で散歩とは優\n雅なご身分だよな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「元はと言えば、ご主人が私を構わなくなってるからですぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021760007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「どういうことだよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「そうやって、お子様にうつつを抜かすヒマがあるなら、もっと愛犬に対して\nも気を配って頂いていいんですぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021760008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「無駄飯喰らいの駄犬は黙ってろ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「どストレートなのはあんまりですぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021760009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はぁ……だが、今のままべったりって訳にもいかねぇのは確かだな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ただなぁ……あいつのことを考えると、今更突き放すってのも中々難しいん\nだよなぁ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "思い返されるのは、倉庫整理を任された……あの時のことだ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0025" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ったく……何だって俺がこんな作業をしなくちゃならないんだよ……」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人が一番ヒマそうに見えるんでしょうなあ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021760010" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「オマエにだけは言われたくねえよ！？　って言うか、ボンヤリ見てるヒマが\nあんなら、手伝ったらどうだ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「お言葉ですが、犬が無理して手伝おうとしても、かえって足手まといになる\n可能性が高いですぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021760011" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ぐ……だったら、せめて視界の外に消えてろっ、チョロチョロされても邪魔\nなだけだ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「そんなつれないことを。親愛なるご主人に精一杯のエールを送る仕事がどれ\nだけ重要なものか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021760012" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「１ミリも重要じゃねぇ。大体、エールどころか、こっちのやる気ゲージを下\nげることばかり言いやがって。もっと俺に相応しい仕事が……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「……あら……私の与えた仕事に、何かご不満があるのかしら？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021760001" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うぉわっ！？　かっ、館長っ……い、いや、これは……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「しっかり働いているかと見に来てみれば……のんびり犬と戯れているなんて\n……随分と査定に自信がおありのようね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021760002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「い、いやいやっ、館長直々に拝命して下さった仕事ですからっ、しっかりっ\n……全身全霊を掛けて、果たしますから！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「仕事は、倉庫整理だけじゃないんです。無駄に時間を掛けて、進みが悪いよ\nうでは困りますから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021760003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「もちろん分かっておりますっ！　とりあえず、この奥のやつを速やかに片付\nけて……うぉわっとぉっ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「……何をしているんですか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021760004" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「い、いや、ちょっと躓いちまっただけでして……って、何だこの箱……えら\nく年季が入ってるな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「確かそれは、一番奥にあったのをとりあえず引っ張り出して来たものですな\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021760013" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……くそ、そう言えば、こいつを片付ければ一段落と思って、出しておいた\nんだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「何でもいいけど、そこにあると邪魔だわ。片付けてしまって頂戴」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021760005" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「へいへい……っと、思ったより重いな。何が入って……ん？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021760017" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「な……ガ、ガキ……？　何で子供がこんな所にいるんだ……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「待って……この子、人間じゃないわ。頭の所……ツノが生えてる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021760006" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「本当だ……まあ人間の子供だったら、国際問題レベルでヤバい気がしますが\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「どういうことかしら……この倉庫も、色々な贈り物や戦利品を片っ端から放\nり込んであるから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021760007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「要するに、心当たりが全くないと……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「むしろ、あり過ぎると言ったほうがいいかもしれないわね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021760008" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「それで……どうするんです？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「どうするって言われても……流石に私の一存じゃ、これは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021760009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「…………ん…………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021760018" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「え……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「んみゅ……んっ……ふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021760019" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「か、館長……子供が……意識を……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「…………んっ……ふぁぁぁ……ふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021760020" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お……起きた……のか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「んむぅ………………お……」", "NORMAL" ]},
