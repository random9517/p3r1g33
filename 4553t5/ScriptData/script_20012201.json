		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「それはそれでヒドくないすか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「んみゅ……お……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021760024" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「えっ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021760012" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「……おかーさん？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021760025" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「な、何言ってるのっ！　私、そんな……まだ子供を産んだことはありません\nっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021760013" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、問題はそっちじゃないですから！　ていうか、こいつは……まさか刷\nり込み？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「最初に見たモノを親と認識するというアレですな。ということは、ワタクシ\nめは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021760015" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「…………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021760026" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「……いぬ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021760027" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まぁ、それはそう以外の何者でもないよな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「何を期待していたのかしら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021760014" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「当たり前の筈なのに、何故か少し傷つきますぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021760016" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
