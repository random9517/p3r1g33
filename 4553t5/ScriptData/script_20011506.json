{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0081" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「さあ、今年もやってまいりました！　渚のマーメイドコンテスト！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「それではさっそく、本コンテストの参加者を紹介させてもらいましょう！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「なお参加者の皆さんには、事前に紅組と白組に分かれていただき、キャプテ\nンも決めさせてもらっています！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「それでは、まずはこの方！　紅組キャプテン、ルルーナ・フォンブラウン・\nムーンランドさん！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「おーーーほっほっほ！　私のパーフェクトでエレガントな水着姿、とくと堪\n能するといいわ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070021520008" ]},
		{"command":[ "SETCHARA", "0", "char_00000107_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「いやー、綺麗なお嬢さんですね！　どうですか、意気込みの方は！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「私が居る限り、紅組が優勝すること間違いなしです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070021520009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「頼りになるキャプテンです！　それでは、続いて白組のキャプテン、Ａ・ル\nナテミスさん！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「今日は私の肉体美を見せつけに来た。好きなだけ堪能してくれ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090021520011" ]},
		{"command":[ "SETCHARA", "0", "char_00000111_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「自慢する通り、すごい筋肉だ！　これは競技に期待が持てそうです！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「私が全ての競技に出たいところだが、これはチーム戦だからな。だが、勝て\nる試合は勝たせてもらうぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090021520012" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「こちらも頼りになるキャプテンのようです！　それでは、あとは順繰りにメ\nンバーを紹介しましょう！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「まずは紅組！　月影輝夜さん、エファ・グラナーダさん、ピースムーンさん\n、十五夜つきみさん、ホクサイさん、ゲンナイさん、サチ・ハマダさん、若苗\n破さんです！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「か、カツマが応援してくれてるんだから……は、恥ずかしがっちゃダメ……\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_050021520009" ]},
		{"command":[ "SETCHARA", "0", "char_00000205_01", "9", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「んっふふ～♪　応援よろしくね～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021520008" ]},
		{"command":[ "SETCHARA", "0", "char_00000306_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピースムーン" ]},
		{"command":[ "SETTEXT", "「お嬢様のためにも、精一杯頑張ります」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_040021520010" ]},
		{"command":[ "SETCHARA", "0", "char_00000811_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「絶対優勝してみせるからね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_030021520010" ]},
		{"command":[ "SETCHARA", "0", "char_00001203_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「やるからには全力を出すよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010021520013" ]},
		{"command":[ "SETCHARA", "0", "char_00009602_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「ラビットパワー！　イェーイ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021520003" ]},
		{"command":[ "SETCHARA", "0", "char_00009802_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「ふふっ。私のニンジュツをとくと見せてやろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010021520006" ]},
		{"command":[ "SETCHARA", "0", "char_00010002_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「姉さんと急とは別チームですかー。残念ですねー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_010021520007" ]},
		{"command":[ "SETCHARA", "0", "char_00010203_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「キャプテンに負けず劣らずの美女揃い！　実に素晴らしい！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「続いて白組！　セレイン・チャンさん、朧兎子さん、ディアナ・アーマーン\nさん、十五夜まりあさん、ウタマロさん、シャラクさん、若苗序さん、若苗急\nさんです！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「よーし！　頑張るぞー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040021520007" ]},
		{"command":[ "SETCHARA", "0", "char_00000404_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「アナザーさんとセレインさんが居ますし、戦力的には充実してますね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_060021520008" ]},
		{"command":[ "SETCHARA", "0", "char_00000506_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「ディアナちゃん痛いのはイヤだから、そういうのはナシにしてね～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_050021520007" ]},
		{"command":[ "SETCHARA", "0", "char_00000605_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「カツマさんも応援してくれてるし……みんなの足を引っ張らないように頑張\nらないと……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_020021520010" ]},
		{"command":[ "SETCHARA", "0", "char_00001402_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ホクは別チームか。こりゃ勝負のし甲斐があるな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_010021520003" ]},
		{"command":[ "SETCHARA", "0", "char_00009702_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「できればみんなと一緒がよかったんだけど、しょーがないよね～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_010021520003" ]},
		{"command":[ "SETCHARA", "0", "char_00009902_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「古人曰く、一念通天閣。優勝しようとする強い信念があれば、その心は通天\n閣のビリケン様に通じ、必ず成就するということです。負けませんよー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021520007" ]},
		{"command":[ "SETCHARA", "0", "char_00010103_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「……ボクだけスク水って、……なんか場違いな感じがする……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021520008" ]},
		{"command":[ "SETCHARA", "0", "char_00010303_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「これだけの水着美女を堪能できて、私の股間も元気いっぱいです！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いい感じに分かれてるみたいだな。これは面白そうだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「それでは、まずは最初の競技と参りましょう！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「最初の競技はこれ！　ビーチフラッグ争奪戦ーーー！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「競技の内容は普通だな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「さすがに変な競技があれば、誰も参加しなくなると思いますぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021520039" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「ビーチフラッグ争奪戦は紅組、白組から２名ずつ。計４名が選出されます！\n」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「ルールは簡単！　参加者の方には、顔をフラッグと反対側に向けてうつ伏せ\nに寝てもらいます！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「準備ができ次第、私がタイミングを見て号砲を鳴らしますので、フラッグに\n向けて全力で走り、フラッグを掴んでください！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「なお、フラッグの数は参加者４人に対して１つしかありません！　つまり勝\n者は一人だけです！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「しかもコンテストの特別ルールで、参加者に向けてかなり勢いのある放水が\n行われます！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「一筋縄ではいかない状態でのフラッグ争奪戦……！　参加するのはこの人！\n　紅組からは十五夜つきみさんと若苗破さん！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「そして白組は、十五夜まりあさんと若苗急さんです！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「い、いきなり私……！？　それに、つきみと勝負するだなんて……！　こん\nなの、絶対勝てるワケないわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_020021520011" ]},
		{"command":[ "SETCHARA", "0", "char_00001402_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「お姉ちゃんが相手でも、手は抜かないよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_030021520011" ]},
		{"command":[ "SETCHARA", "0", "char_00001203_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「放水の邪魔があることを考えると、これは中々苦戦しそうな感じがしますね\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_010021520008" ]},
		{"command":[ "SETCHARA", "0", "char_00010203_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「……誰が相手だろうと、関係なくぶっ倒すけどね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021520009" ]},
		{"command":[ "SETCHARA", "0", "char_00010303_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「いきなり姉妹対決とは、楽しませてくれますな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021520040" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「だけどこれ、まりあにとってはかなり不利な状況だろ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「確かにそうですが、勝負は時の運とも言います」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021520041" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「それに放水という特別ルールもありますし、どう転ぶかわかりませんぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021520042" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「それもそうだな。よし、ちょっとまりあを応援してやるか……頑張れー！　\nまりあー！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「か、カツマさん……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_020021520012" ]},
		{"command":[ "SETCHARA", "0", "char_00001402_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「では、参加される方はビーチのスタートラインに寝そべってください！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「カツマさんも応援してくれてるし、頑張らないと……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_020021520013" ]},
		{"command":[ "SETCHARA", "0", "char_00001402_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「さて……各選手の準備が整ったようなので、はじめさせていただきます！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「それでは、ビーチフラッグ争奪戦……スタート！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYBGM", "BGM_002" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「行っくぞーーー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_030021520012" ]},
		{"command":[ "SETCHARA", "0", "char_00001203_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「この反応速度……急が最大の敵と思ってたけど、つきみさんも中々やります\nねー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_010021520009" ]},
		{"command":[ "SETCHARA", "0", "char_00010203_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「…………お姉ちゃんには……負けないよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021520010" ]},
		{"command":[ "SETCHARA", "0", "char_00010303_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「あうぅ……！　みんな速い……！　でも、私だって……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_020021520014" ]},
		{"command":[ "SETCHARA", "0", "char_00001402_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「真っ先に反応したのはつきみ選手！　それを僅差で追いかける破選手に、急\n選手！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「そこから少し遅れてまりあ選手！　これが普通のビーチフラッグなら、勝利\nは絶望的だ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「だがしかし！　このビーチフラッグには放水ルールがあります！　勢いよく\n水をブッかけられて、びちょびちょになってもらいましょう！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんかイヤらしい言い方だな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「そういうふうに捉えるご主人が、一番イヤらしいですぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021520043" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「皆さんお待ちかね！　嬉し恥ずかし、放水ターーーーーイム！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「きゃあああぁーーーーー！？　ちょ、これ……かなり勢いが……あうううぅ\n！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_030021520013" ]},
		{"command":[ "SETCHARA", "0", "char_00001203_01", "9", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「全然前に進めないー……！　わっ、わわわっ！？　水着がズレて……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_010021520010" ]},
		{"command":[ "SETCHARA", "0", "char_00010203_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「勢い強すぎるよぉ……こんなの、まともに走れない～……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021520011" ]},
		{"command":[ "SETCHARA", "0", "char_00010303_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……やっと追いついた……って、なにこれ……！？　こんな水の\n中を走らないといけないの……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_020021520015" ]},
		{"command":[ "SETCHARA", "0", "char_00001402_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「これぞ渚のビーチコンテスト名物！　ドキッ！　放水のあるビーチフラッグ\n！　ポロリもあるよ！　だーーー！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "観客たち" ]},
		{"command":[ "SETTEXT", "「待ってましたあああぁーーーーーっ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「やっぱりイヤらしいじゃねぇか！　いいぞ、もっとやれ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「と、取れちゃう！　水着、取れちゃうからぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_030021520014" ]},
		{"command":[ "SETCHARA", "0", "char_00001203_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「卑怯な手を……！　これでは、前に進めませんー……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_010021520011" ]},
		{"command":[ "SETCHARA", "0", "char_00010203_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「おおっと！　つきみ選手と破選手がしゃがみこんだー！　そんな調子じゃ、\nまともに動けないぞー！？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「つきみ！　破！　なにやってんだ！　ちゃんと立って、気合入れて走れ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「そんなこと言われても、水着が……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_030021520015" ]},
		{"command":[ "SETCHARA", "0", "char_00001203_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「ボクはスク水だから、脱げる心配はないけど……うぐっ！　勢いがありすぎ\nて、中々前に進めない……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021520012" ]},
		{"command":[ "SETCHARA", "0", "char_00010303_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「前年度はあまりにも放水の勢いがなさすぎたせいか、まったくポロリがあり\nませんでした」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「ですので、今年は特に勢いを強めて、いつポロリが発生してもおかしくない\nように調整してあります！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「余計なことを……！　ぐっ、あうぅ……だ、ダメ……！　水着を押さえてな\nいと、脱げちゃうよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_030021520016" ]},
		{"command":[ "SETCHARA", "0", "char_00001203_01", "5", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「頑張れ頑張れできるできる絶対出来る頑張れもっとやれるって！　やれる気\n持ちの問題だ頑張れ頑張れそこだ！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そこで諦めんな絶対に頑張れ積極的にポジティブに頑張る頑張る！　急だっ\nて頑張ってるんだから！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「うぅ……つきみでダメなら、私なんて絶対に無理だわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_020021520016" ]},
		{"command":[ "SETCHARA", "0", "char_00001402_01", "2", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なにやってんだまりあーーー！　行けーーーー！　進めーーーーー！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「カツマさん……！　はい……！　私、頑張ります……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_020021520017" ]},
		{"command":[ "SETCHARA", "0", "char_00001402_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「どうしてでしょう。先ほどからご主人の応援に、邪な気を感じますぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021520044" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「くっ……あっ、んんぅ……！？　やっ、ダメっ……！　いろんなとこに水が\n当たって……はううぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_020021520018" ]},
		{"command":[ "SETCHARA", "0", "char_00001402_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「おおっと！　ここでまりあ選手が放水ゾーンに足を踏み入れたーーーーー！\n？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いいぞーーー！　まりあーーー！　そのまま真っすぐ進めーーー！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「まりあ選手！　水着を押さえ、フラフラしながらも確実に前へと進んでおり\nます！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「やっ、あんんっ……！　み、水着がズレて……！　ひっ、あふっ……あはあ\nぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_020021520019" ]},
		{"command":[ "SETCHARA", "0", "char_00001402_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「水着を押さえてないで、走るときは腕をしっかり振れ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「腕を振るなんて……！　そんなことしたら、本当に水着が……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_020021520020" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「おーっと！　これはきわどい！　まりあ選手、ポロリをしてしまうのかーー\nーーー！？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「ポロリなんてさせない！　お姉ちゃんは……私が守る！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_030021520017" ]},
		{"command":[ "SETCHARA", "0", "char_00001203_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「な、なんとつきみ選手！　まりあ選手を庇うように、放水の前に立ちふさが\nったーーーーー！？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「つきみ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_020021520021" ]},
		{"command":[ "SETCHARA", "0", "char_00001402_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「んなっ……！？　あいつ、なにを……！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「お姉ちゃん！　私が水をなんとかするから、このまま放水ゾーンを抜けてい\nって！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_030021520018" ]},
		{"command":[ "SETCHARA", "0", "char_00001203_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「急さんも全然前に進めてないみたいだし、ここから走れば逆転できるよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_030021520019" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「で、でも……どうして……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_020021520022" ]},
		{"command":[ "SETCHARA", "0", "char_00001402_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「カツマさんがあんなに応援してくれてるんだし、期待に応えてあげないとカ\nッコ悪いもんね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_030021520020" ]},
		{"command":[ "SETCHARA", "0", "char_00001203_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「っ……！　うん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_020021520023" ]},
		{"command":[ "SETCHARA", "0", "char_00001402_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「まりあ選手！　つきみ選手を盾にして、ペースを上げております！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「だがつきみ選手。水着を手で押さえているものの、限界寸前といった様子！\n　いったい、どうなってしまうんでしょうかーーー！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「だああああぁ！　なにしてんだ、つきみ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「別に怒るようなことでもないでしょう。美しい姉妹愛ですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021520045" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「俺が見たいのは姉妹愛じゃなくて、ポロリなんだよ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「それは絶対に、まりあ殿の前で言わない方がいいですぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021520046" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「まりあ選手、ついに急選手に並んだーーーーー！！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「もうここまで来たの……！？　でも、負ける気はないよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021520013" ]},
		{"command":[ "SETCHARA", "0", "char_00010303_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「ここで急選手、一気に前に出たーーー！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「もう少しで放水ゾーンを抜けて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021520014" ]},
		{"command":[ "SETCHARA", "0", "char_00010303_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「って、うわあああああぁ～～～～～！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021520015" ]},
		{"command":[ "SETCHARA", "0", "char_00010303_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「急選手、功を焦りすぎてしまったか！　ここで転倒！　そこに追い打ちをか\nけるように、大量の水がブチ撒かれていきます！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「た、助けて～～～！　お姉ちゃ～～～ん！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021520016" ]},
		{"command":[ "SETCHARA", "0", "char_00010303_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「急……！　ごめんね……！　助けてあげたいのは山々だけど今、急と水着を\n選ぶなら……水着かなーって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_010021520012" ]},
		{"command":[ "SETCHARA", "0", "char_00010203_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「破選手と急選手、もはや一歩も動けないといった様子です！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「そんな中、ついにまりあ選手がつきみ選手の力を借りて、放水ゾーンから抜\nけ出していったーーーーー！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……！　つきみ、大丈夫……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_020021520024" ]},
		{"command":[ "SETCHARA", "0", "char_00001402_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「うん、平気だよ……！　私のことはいいから、早くゴールして……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_030021520021" ]},
		{"command":[ "SETCHARA", "0", "char_00001203_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ありがとう、つきみ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_020021520025" ]},
		{"command":[ "SETCHARA", "0", "char_00001402_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「ゴォォォォォル！　ビーチフラッグ争奪戦を制したのは、十五夜まりあ選手\nです！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「まずは勝利したまりあ選手に、盛大な拍手をお願いします！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「やった……！　やりましたよ、カツマさん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_020021520026" ]},
		{"command":[ "SETCHARA", "0", "char_00001402_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「クソっ！　どこがポロリもあるよ、だ！　まったくねぇじゃねーーーか！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「なんというか、救いようがありませんな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021520047" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「それでは、勝者のまりあさんにインタビューをしてみましょう！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「まりあさん。序盤はかなり出遅れており、さらにつきみ選手の手助けもあっ\nてのゴールですが……いかがでしたか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「私を助けてくれたつきみ……それに、応援してくれたカツマさんのおかげで\nす……！　本当に嬉しいです……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_020021520027" ]},
		{"command":[ "SETCHARA", "0", "char_00001402_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「応援のおかげですか。いいですねー。ちなみに、そのカツマという人は、ま\nりあさんの恋人かなにかで？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ち、違います……！　恋人じゃなくて……えっと、その……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_020021520028" ]},
		{"command":[ "SETCHARA", "0", "char_00001402_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「インタビューはそれぐらいにして、早く次の競技に進んでもらえませんか…\n…！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070021520010" ]},
		{"command":[ "SETCHARA", "0", "char_00000107_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「そ、そそそ……！　そうよ……！　そんなインタビュー……長々と続けてな\nくて……いいから……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_050021520010" ]},
		{"command":[ "SETCHARA", "0", "char_00000205_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「おっと。これは失礼しました！　では、勝利した白組には１ポイントを進呈\nします！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「それでは次の競技、行ってみましょう！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}