{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0101" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「さて……それではお覚悟はよろしいですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_010022480001" ]},
		{"command":[ "SETCHARA", "0", "char_00023001_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「こいつは……かなりヤバそうだね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022480001" ]},
		{"command":[ "SETCHARA", "0", "char_00000312_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「荒事にしたくはなかったのですが……やむを得ないようですからね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_010022480002" ]},
		{"command":[ "SETCHARA", "0", "char_00023001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「カツマ！　イルルとヤムのこと守ってやりな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022480002" ]},
		{"command":[ "SETCHARA", "0", "char_00000312_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お、俺っ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「そっちまで手が回らないんだよ！　分かるだろ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022480003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「わ、分かった！　おいこっちだっ！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「おとーさっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010022480001" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ヤ、ヤムは別に……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010022480001" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いいから、こっちに隠れてろ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「……そうですね。後でお迎えに行きますから、今はそちらに預けておくのも\nいいでしょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_010022480003" ]},
		{"command":[ "SETCHARA", "0", "char_00023001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……保育園みたいなこと言ってやがる……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「いずれにしましても、私の邪魔をするということでしたら、相応の覚悟はし\nていただきませんと……ふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_010022480004" ]},
		{"command":[ "SETCHARA", "0", "char_00023001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「くぅっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022480004" ]},
		{"command":[ "SETCHARA", "0", "char_00000312_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「ほう……？　今の一撃を躱すとは……貴方も口先だけという訳ではなさそう\nですね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_010022480005" ]},
		{"command":[ "SETCHARA", "0", "char_00023001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「いきなりやってくれるじゃないか……上等だよっ！　はぁぁぁーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022480005" ]},
		{"command":[ "SETCHARA", "0", "char_00000312_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「ふんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_010022480006" ]},
		{"command":[ "SETCHARA", "0", "char_00023001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ぐぁっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022480006" ]},
		{"command":[ "SETCHARA", "0", "char_00000312_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「それなりに腕に覚えはあるようですが……力の差は歴然としているようです\nね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_010022480007" ]},
		{"command":[ "SETCHARA", "0", "char_00023001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「……そうやって、敵のことをナメてると……カマされるよっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022480007" ]},
		{"command":[ "SETCHARA", "0", "char_00000312_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「むぅっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_010022480008" ]},
		{"command":[ "SETCHARA", "0", "char_00023001_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「はぁぁぁぁぁぁっ！　こいつを喰らいなっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022480009" ]},
		{"command":[ "SETCHARA", "0", "char_00000312_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「むっ！　っくぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_010022480010" ]},
		{"command":[ "SETCHARA", "0", "char_00023001_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「くくっ、れろっ……しっかり手応えがあったようだねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022480010" ]},
		{"command":[ "SETCHARA", "0", "char_00000312_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「ふっ！　なるほど、軽々に力を見極めようとしてしまったのは、私の不徳の\n致すところです。確かに、貴方も応分の技量を備えられていると」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_010022480012" ]},
		{"command":[ "SETCHARA", "0", "char_00023001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「フン……余裕ぶった言い方……気に入らないね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022480012" ]},
		{"command":[ "SETCHARA", "0", "char_00000312_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「まだ、私自身が脅かされるという程ではありませんので。ですが、しっかり\nとお相手をする必要はありそうですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_010022480013" ]},
		{"command":[ "SETCHARA", "0", "char_00023001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「……ちっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022480013" ]},
		{"command":[ "SETCHARA", "0", "char_00000312_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「今度は私の力をお見せしましょうっ。ぬぅぅぅぅーーーーーーっ、剛力の咆\n哮（バスタークライ）！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_010022480014" ]},
		{"command":[ "SETCHARA", "0", "char_00023001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「さあ、行きますよ！　貴方の本気を見せて頂きますっ、はぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_010022480015" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「上等だっ！　狂魔元帥の恐ろしさっ、分からせてやるよっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022480015" ]},
		{"command":[ "SETCHARA", "0", "char_00000312_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピースムーン" ]},
		{"command":[ "SETTEXT", "「ひぃぃぃぃっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_010022480001" ]},
		{"command":[ "SETCHARA", "0", "char_00000803_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「やべぇ……エファナティカの必殺技を使って、それでもまだ苦戦してるじゃ\nねぇか……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「だからムリだって……！　あいつと互角に戦ってる時点で何かの間違いレベ\nルなんデスけど……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010022480002" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「おかーさん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010022480002" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「とにかく、顔を出すな。ていうか、迂闊に動くだけでも、流れ弾が飛んで来\nてやべぇからな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「う、うん……わかった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010022480003" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「とは言え、このままじゃヤベェな……もしエファナティカが押し切られちま\nったら……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「こんにちはーっ、すみませーーーんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_010022480001" ]},
		{"command":[ "SETCHARA", "0", "char_00022001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「な、何だ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「あのぉー、失礼いたします。すみません。お約束の時間ギリギリになっちゃ\nって～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_010022480002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「斬っ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_010022480016" ]},
		{"command":[ "SETCHARA", "0", "char_00023001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「くうっ……なんのっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022480016" ]},
		{"command":[ "SETCHARA", "0", "char_00000312_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「えぇと、私……怪人派遣協会から参りました、兎怪人・バニーママと申しま\nす～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_010022480003" ]},
		{"command":[ "SETCHARA", "0", "char_00022001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「バ、バニーママっ？　いや、こんな時に……それどころじゃ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「あら……もしかして、取り込み中でしたか？　それは申し訳ありません……\n日を改めた方がよろしいでしょうか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_010022480004" ]},
		{"command":[ "SETCHARA", "0", "char_00022001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……い、いやっ、あんた怪人なんだよな？　もうすぐに助っ人って行けるの\nか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「あっ……えっと、それは採用して頂けるということでしょうか～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_010022480005" ]},
		{"command":[ "SETCHARA", "0", "char_00022001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「するっ、するからっ！　すぐに手を貸してくれっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「あっ、はーいっ、承知しました～。あのぉ、そうしましたら大変お手数なの\nですが、こちらの書類にサインを頂けますとー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_010022480006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「だーっ、サインでも何でもするからっ！　ほらっ、これでいいのかっ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「あっ、はーいっ、ありがとうございますー。あ、すみません。ここと、ここ\nにもいただけますかー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_010022480007" ]},
		{"command":[ "SETCHARA", "0", "char_00022001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「こことここにもサインしたからっ、早くっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「はーい、ありがとうございますー。えぇと、それで……この状況でどちらに\n加勢すればいいのでしょうか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_010022480008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「エファナティカだっ！　肌の青い方の味方を頼むっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「はい～。あのぉ……どちらの方も青いような気がするのですが……どちらで\nしょうか～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_010022480009" ]},
		{"command":[ "SETCHARA", "0", "char_00022001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うがぁーっ、紛らわしいっ！　眼鏡だっ、眼鏡をかけてる方で頼むっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「あぁぁー、はいはい、分かりました。あちらの方にご協力するということで\n、早速始めさせて頂きますー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_010022480010" ]},
		{"command":[ "SETCHARA", "0", "char_00022001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お、おう」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「それでは、改めましてー失礼しますー♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_010022480011" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「あいつ正気なの？　何でもないみたいに向かってるんデスけど！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010022480003" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……この状況で、何も動じないって……怪人って、そこまでやべぇ奴だった\nか……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}