{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0005" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "鈴と葉金を連れて、カツマは大使館へと戻ってきた。", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんだか前で揉めてるみたいだな」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「なにがあったんでしょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021200001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「で、ですからー、神様なんですー。鋳物のー。しってますでしょ？　鋳造。\nいえいえ、テニスの人ではなくー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_010021200001" ]},
		{"command":[ "SETCHARA", "0", "char_00011901_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「あ、あれシコリンじゃん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_010021200001" ]},
		{"command":[ "SETCHARA", "0", "char_00011401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あれが！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "本部入り口前にいるのは、言われてみれば女神のように見える姿の女性。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETCHARA", "0", "char_00011901_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ただし、威厳はあまりない。半泣き状態だった。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「おーい、シコリーン」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_010021200002" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00011401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「す、鈴！　コホン。私は石凝姥命です。シコリンはその……あまりにも……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_010021200002" ]},
		{"command":[ "SETCHARA", "0", "char_00011901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「石凝姥命だと呼びにくいだろ。それにシコリンの方が親しみやすくていいじ\nゃん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_010021200003" ]},
		{"command":[ "SETCHARA", "0", "char_00011401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「いや、親しみやすいという問題ではなくですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_010021200003" ]},
		{"command":[ "SETCHARA", "0", "char_00011901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「…………」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "確かにシコリティの高い体つきをしているな……", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「石凝姥命さま、ここにいらしたのですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_010021200001" ]},
		{"command":[ "SETCHARA", "0", "char_00011501_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「葉金、聞いて下さい。この警備の方が私を通してくれないんです。どう見て\nも神様でしょうに、コスプレだと疑うんですよー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_010021200004" ]},
		{"command":[ "SETCHARA", "0", "char_00011901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まあ、この世界じゃあんたみたいな格好しているやつは珍しくないからな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「でも、この二人をこの世界に寄越したってことは、本物の神様なんだろう？\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「ああ、貴方は信じてくれるのですね。ありがとうございますー……はっ。コ\nホン。人の子よ、感謝します」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_010021200005" ]},
		{"command":[ "SETCHARA", "0", "char_00011901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……急に偉そうになったぞ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「こんなだけど、シコリンは実際偉いらしいぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_010021200004" ]},
		{"command":[ "SETCHARA", "0", "char_00011401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「私たちに戦う力を与えた張本人ですからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_010021200002" ]},
		{"command":[ "SETCHARA", "0", "char_00011501_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まあ、合流できたことだし、今回のことについて、聞きたいことが山ほどあ\nるんだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「はい。私もこの世界の方々に説明しないといけないことがたくさんあるんで\nす。ですが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_010021200006" ]},
		{"command":[ "SETCHARA", "0", "char_00011901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ですが？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「それは後半でいいですよね？　もー、私この警備員さんを説得するので疲れ\nてしまいましたー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_010021200007" ]},
		{"command":[ "SETCHARA", "0", "char_00011901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「後半ってなんの話だ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0000" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_007" ]},
		{"command":[ "SETTEXT", "次回予告", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "異世界からやってきた少女、鈴、葉金。そして二人を遣わせた女神、石凝姥命\n。女神の口から語られるクラッドの恐るべき野望とは……！？", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「もうやってられるか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_010021200005" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00011401_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「わたくしも、もう限界ですわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_010021200003" ]},
		{"command":[ "SETCHARA", "0", "char_00011501_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「アタシは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_010021200006" ]},
		{"command":[ "SETCHARA", "0", "char_00011401_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「わたくしは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_010021200004" ]},
		{"command":[ "SETCHARA", "0", "char_00011501_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「アマルガメイト、解散だ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_010021200007" ]},
		{"command":[ "SETCHARA", "0", "char_00011401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「アマルガメイト、解散ですわ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_010021200005" ]},
		{"command":[ "SETCHARA", "0", "char_00011501_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
