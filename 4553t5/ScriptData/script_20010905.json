		{"command":[ "SETTEXT", "次回、ふたりはブリキ１", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},

		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "コンビ解消！　異世界でケンカ別れ！？", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

