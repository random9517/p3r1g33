		{"command":[ "SETIMAGE", "0", "bg_0005" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「次回も見るのですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_010021200008" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00011901_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……これって結局仲直りする流れだよな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「しーっ、そういうことをいうのは無粋ですぞご主人」", "NORMAL" ]},
