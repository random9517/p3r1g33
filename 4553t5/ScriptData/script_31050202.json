		{"command":[ "SETIMAGE", "0", "still_00010502_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「あっ、隊長さんから……そんなに、あっ、突き上げ……られたらっ、あひっ\n、はひぁんっ、あっ、あぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0204213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「すごっ、あっ……さっきとっ、んんっ、違うっ……！　オチンチンが……オ\nマンコっ……弱いとこにっ……当たってぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0204214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「はひっ、あひんっ！　あっ、おっぱいもっ……一緒にされたらっ、んひぅっ\n、あぁっ、感じ……過ぎますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0204215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「あぁっ、はんっ、隊長さんっ……はいっ、気持ちいいっ……オ、オマンコ…\n…いいですっ、ズボズボされてっ……オマンコっ、感じますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0204216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「そこっ、はひぁっ、もっとして下さいっ、あぁっ、私もっ……んんっ！　オ\nマンコキュンってしますからっ、あっ、乳首こりこりらめぇっ！」", "NORMAL" ]},
