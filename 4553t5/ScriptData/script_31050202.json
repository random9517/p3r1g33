		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「こ、ここなら……大丈夫ですよね……？　う……結構、オープンな気がする\n……プールサイドだから仕方ないけど……」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "PLAYVOICE", "v2_105_0204101" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「でも、貸し切りって聞いたし……も、もう……思い切るしかっ……えっ……\nえいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0204102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「あぁ……私……押し倒しちゃいました……隊長さんのこと……水着もずらし\nて……恥ずかしい所……全部見せちゃってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0204103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「うぅっ……でも、もう決めたんです……今日は……隊長さんの元気な精液を\n……直接貰うって……だから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0204104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「し、しちゃいます……セックス……隊長さんのオチンチン……ぱくって……\n食べちゃいますからっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0204105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「えっ？　おっぱい……ですか？　あ……は、はい……その、どうぞ……あん\nっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0204106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……あっ、いきなりそんな……ぐにゅって……あっ、だ、大胆で\nすっ……隊長……あんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0204107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「お互い様……？　それは……確かに、そう、なんですけど……だって、これ\n位思いきらないと……私、中々動き出せなくて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0204108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「あっ、だから……うんっ、その、アシスト……ですか……は、はい……そう\nいうことでしたら……んっ、あっ、あんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0204109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「大きいのは……んっ、分かってます……あんっ！　か、感度……それはっ、\nわ、分かりません……けどっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0204110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「あっ……隊長さんの指が食い込むと……ドキドキして……あふっ……あぁ…\n…待ちきれない……感じになって……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0204111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「あぁ……も、もう入れちゃっても……いいですか……？　隊長さんのオチン\nチン……ハメて……オマンコに入れて……いいですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0204112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「はい、行きます……んっ、あっ、はぁぁぁぁぅっ……あっ……はぁぁぁぁぁ\nぁぁぁんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0204113" ]},
		{"command":[ "SETIMAGE", "0", "still_00010502_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「あぁ……入れちゃいました……隊長さんのオチンチン……硬いの、すごく熱\nくなってます……あ、ふぅぅぅ……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0204114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「んくぅぅ……あっ、あぁ……やだ……中で……大きいのが、どんどん広がっ\nていくみたいな……くぅぅ……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0204115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「はぁぁ……あっ、奥まで届いちゃいました……オマンコ……オチンチンでい\nっぱいになっちゃってます……んふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0204116" ]},
		{"command":[ "SETIMAGE", "0", "still_00010502_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「自分からまたがって……こんな、ぱっくり咥えこんじゃうなんて……私……\nどんどんスケベに……なっちゃってます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0204117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「けど……んっ、あぁ……こうしてると……ドキドキが止まらなくて……すご\nく、気持ちよくて……もっとして欲しいって……思っちゃって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0204118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「だから、んっ、あぁ……もう、自分に正直になっちゃいます……腰……振っ\nちゃいます……からぁっ、あんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0204119" ]},
		{"command":[ "SETIMAGE", "0", "still_00010502_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「はんっ、あっ、あんっ、はっ、あふんっ、あぁ……擦れてます……んっ、グ\nリグリって……オマンコのヒダ……何回もぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0204120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「あふっ、内側から……愛液が……じゅくじゅくって……溢れ出して……どん\nどん滑りやすくなって行きます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0204121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「あぁ……こんな、明るい場所で……見られるかもしれないって思うと……こ\n、興奮してっ……はぁっ、あぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0204122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「あっ……乳首……つまんでっ……あっ、くりくり転がされてるぅ……先端が\n、どんどんしこって来ちゃいます……あっ、あひぃっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0204123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「感じて……はいっ、感じて……ますぅっ……だってっ……あっ、こんなにオ\nチンチン……擦り合わせたらっ、んぁぅっ、くぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0204124" ]},
		{"command":[ "SETIMAGE", "0", "still_00010502_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「隊長さんはっ……こんなっ、いやらしい……スケベな女……嫌いですか？　\nはしたないって……軽蔑したりしませんかっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0204125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「んぅっ……だ、大好きっ……あぁぅっ……そこまでストレートに言われると\nぉっ、あっ、う、嬉しすぎてぇ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0204126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「でもっ、よかったです……もっと、おっぱい……ゆさゆさって……揺らし…\n…ますね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0204127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「うんっ、ふっ、はふっ、あふんっ、あぁっ……恥ずかしいっ、おっぱい……\nこんなにぷるぷるさせるなんて……いやらしいのっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0204128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「んんっ……んふっ……隊長さんの視線……すごく……感じますっ……やっぱ\nり、おっぱい……大好きなんですね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0204129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「はい……ずっとコンプレックスでしたけど……こんな風に喜んで貰えるなら\n……私……大きくて良かったです……んっ、はっ、あんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0204130" ]},
		{"command":[ "SETIMAGE", "0", "still_00010502_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「このおっぱい……隊長さんのものですからっ……お好きなだけ……いっぱい\n、揉んで……下さい……あんっ、はんっ、あはぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0204131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「はんっ、あっ、ふっ……腰も……全然止まらないですっ……だってっ、あっ\n、オチンチンが……太いからっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0204132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「色んな所っ……いっぱい擦り上げてっ……オマンコの感じる所っ、全部され\nてっ……あぁっ、すごくっ……気持ちいいっ……ですぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0204133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「はんっ、あぁっ……ダメ……私っ、そろそろ……イッちゃいそうですっ、隊\n長さんはっ……どうですかっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0204134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「もうすぐっ……はいっ、お願いします……このまま、直接出して下さいっ…\n…オマンコの中にっ、いっぱい……精液……出してっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0204135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「んんぁぁぁぁぁっ！　あっ、出てますっ……！　あひんっ、射精……始まっ\nてるっ！　んひぃっ、私もっ……イキっ、ますぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0204136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010502_02_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「はぁぁぁっ……あっ、ふっ……あぁっ……中がどんどんいっぱいになってま\nす……ダメです、もう入りきらないのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0204137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「んんっ……はぁぁ……子宮が喜んじゃってる……足が震えて……止まらない\n……はぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0204138" ]},
		{"command":[ "SETIMAGE", "0", "still_00010502_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「あ……ふっ、はぁぁ……気持ちいいです……んふぁ……ふわふわしてぇ……\nはぁぁ……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0204139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「中出し……いいです……んっ、あぁ……いっぱい出してくれて……ありがと\nうございました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0204140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「はぁ……んふっ、射精……落ち着きましたね……でも、まだオチンチン……\n元気いっぱいですよね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0204201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「イキましたけど……私も……もっとしたいなって……ダメ……ですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0204202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「ふふっ、ズルい聞き方でしたか。んっ、ありがとうございます……じゃあ、\nお言葉に甘えて……続けさせて貰いますね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0204203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「んっ、しょっ、はっ……あぁぁ……今……イッたばかりだから……ゆっくり\n、しますね……んっ、あふっ、はふんっ、あっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0204204" ]},
		{"command":[ "SETIMAGE", "0", "still_00010502_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「こうやって、んっ……じっくり動かすのも、気分が違って……いいかも……\nですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0204205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「んぁっ……また……おっぱい鷲掴みに……んんっ！　こっちも、さっきより\n……敏感になってる気がします……は、ふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0204206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「あんっ……あぁ、乳首……そこ……あふっ、くにくにってぇ……指ぃ……あ\nっ、いい……ですぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0204207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「うんっ、んくっ、あふんっ……私も……あっ、お返しに……んんっ、んふっ\n！　オマンコ……締め付けますっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0204208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「ふふっ……どうですか？　隊長さんのオチンチンの弱点……この辺ですよね\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0204209" ]},
		{"command":[ "SETIMAGE", "0", "still_00010502_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「私だって……ちゃんと、見てるんですから……隊長さんのこと……どういう\n時に反応が良くて……気持ちいいって思うのか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0204210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「ただ、んんっ、キュンってすると……私も……気持ちよくなりすぎちゃうの\nが……困るトコですけど……あっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0204211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「んぁっ、また……激しく、なってっ……あひっ、あっ、はっ、んぁぁぁぁん\nっ！」", "NORMAL" ]},
