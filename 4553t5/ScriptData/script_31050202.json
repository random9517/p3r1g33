		{"command":[ "PLAYVOICE", "v2_105_0204218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「あぁっ、オマンコっ……また中に下さいっ……おっぱいでもいいですっ、オ\nチンチンっ……気持ちよく射精してっ！」", "NORMAL" ]},
