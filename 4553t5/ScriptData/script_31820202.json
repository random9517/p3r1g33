{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018202_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「あーん、こんなところに人妻を連れ込むなんて……あなたって、本当に悪い\n人ですね……ふふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0204101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「あら？　そうでしたっけ？　わたしが誘惑しただなんて……普通に腕を組ん\nで歩いてただけじゃないですかー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0204102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「だって私、おっぱい大きいですから。どうしても腕に当たっちゃうんです。\nワザとじゃないです、本当ですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0204103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「あ、あん……意地悪言わないで……ここまできたんだから……ね？　ねえ？\n　あなたもヤリたくて堪らないでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0204104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「ほら、チンポ勃起してる……ふふっ、ズボンの上からでもわかるわ。そんな\n状態でお店の中を歩いてたら通報されちゃうわよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0204105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「だから、わたしのオマンコで……スッキリしていって。もちろん……このH\nカップのおっぱいも好きにしていいから～……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0204106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「わたしだって……あなたとお出かけしてるんだから、こういうこと期待して\nるに決まってるじゃないですか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0204107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「んふっ……アソコはもうぐしょぐしょですよ……あ、あんっ……ほら、早く\nそのチンポで……確かめて、みて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0204108" ]},
		{"command":[ "SETIMAGE", "0", "still_00018202_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「んっんんっ……！　あぁ、素敵……それ、そのチンポ……わたしを女に戻し\nてくれたチンポぉ……早く欲しい、お願い……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0204109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「……あはぁっ！　き、きた……はいって、きたぁ……あんっ……若いオスチ\nンポぉ……んっ、んんぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0204110" ]},
		{"command":[ "SETIMAGE", "0", "still_00018202_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「カリがゴリゴリ擦れてぇ……んんっ……あっ、あぁっ……おっきぃ、いいっ\n……は、あぁっ……あふっ、んぅうっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0204111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「あ、あんっ……あぁんっ……それぇ、ゆっくり……中、かき回す……の……\nんぅっ、ズルい……はぁ、ああっ……感じるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0204112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「もっと、奥、まで……お願い、焦らさないで……んぅっ……は、ああっ……\nあんっ、あっあふっ……んっ、はあっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0204113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「き、気持ちいい、です……けど……あんっ、あんっ……浅い、とこ……くち\nゅくちゅするの、切なくって……んふぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0204114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「あっ……はぁあぁぁっ……だって、この体勢じゃ、わたしから……動けない\n、ですし……んっ、あっ、んっはぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0204115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「そうだって、言ったじゃないですかぁ……もうずっとこうしたくて、オマン\nコ、びしょびしょなんです……あぁあっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0204116" ]},
		{"command":[ "SETIMAGE", "0", "still_00018202_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「んはぁっ！　そ、そうっ……このチンポぉ……あなたの、デカチンが欲しく\nてぇ……堪らなくてぇ……んっはぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0204117" ]},
		{"command":[ "SETIMAGE", "0", "still_00018202_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「あっ、あっあぁ……あんっ！　そう、です……毎日、チンポのことで、頭が\nいっぱいでぇ……んぅんっ、あっあぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0204118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「そう、淫乱人妻なのぉ……でも、そうしたのはあなたですよ……あなたのチ\nンポが……悪いんですよ……ほ、本当に……んぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0204119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「だって、夫と全然違って……よすぎるんです……やっぱり若いオスのチンポ\n最高ぉ……んっ、んんっ、はっんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0204120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「はぁあ、あっあっ……あんっ！　チンポ、中で、また大きくなってるぅ……\nんんっ……あはぁぁ……あっ、ふぅ、あぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0204121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「い、いい……？　わたしのオマンコ、気持ちいい……ですか？　んあっ……\nあっ、はぁあっ……あぁ、嬉しい……あん、あぁんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0204122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「あぁ、あっあんっ……もっと、味わって……いっぱい、いっぱいオマンコ、\nチンポでかき回してぇ……んっ！　んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0204123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「そ、そうっ……奥っ、いいっ……！　奥まで、ガンガン突いてぇ……！　は\nっ、んっあっ、あっ……ひっ、ひぃうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0204124" ]},
		{"command":[ "SETIMAGE", "0", "still_00018202_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「ひっ、ひぃあっ、あぁっ……あなたも、わたしのオマンコでぇ……気持ちよ\nくなってぇ……はっ、はひぃぃぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0204125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「あっんっ！　んぅっ、はぅぅっ！　そ、そうっ……もっと激しく、んっんん\nっ……！　太いチンポで、突いてぇぇ……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0204126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「はあっ……あひぃんっ！　す、すご、いぃぃっ……ぶっといオチンポが、奥\nっ……ガンガン突いてくるぅ……！　ひっ、いぃんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0204127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「あぁん、あっはぁっ……！　夫以外のチンポ咥え込んで……感じちゃってぇ\n……はっ、あはぁぁ……オマンコ、感じちゃうぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0204128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「ひっ、はひぃっ……ぐちゅぐちゅ、イヤらしい音が……あぁっ……あんっ！\n　本気汁、溢れて……恥ずかしい、んっ、んんぅぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0204129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「あぁあっ……あっ、あっ、イク……イッちゃうっ……デカチンで、イカされ\nちゃうぅぅ……ひっうっ……んっひぃぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0204130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「中、もちろん中がいい、ですっ……オマンコにいっぱい中出ししてください\nっ……んっ、はぁあっ……あっあぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0204131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「はぁっ……！　は、恥ずかしいのに、気持ちいいのぉ……んっ、チンポすご\nいぃ……ひっ、ひうっ！　んっ、ひぃいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0204132" ]},
		{"command":[ "SETIMAGE", "0", "still_00018202_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「あぁ、あぁぁ……子宮にまで、届いてぇ……ひっ、ひぃいっ！　イク、イク\nっ……！　あなたも、一緒に……きてぇぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0204133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「はぁあ、あっ、あんっ！　一緒にアクメ、したいっ……中出しアクメ、デカ\nチンで孕ませてぇぇっ！　ひっあっ……あっあっ、あぁあぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0204134" ]},
		{"command":[ "SETIMAGE", "0", "still_00018202_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「あああっ！　イクッ、イクイクイクぅぅぅぅっ～～～！！　んっ、出して…\n…あなたも出してぇぇぇぇぇ～～～～～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0204135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「んんん～～っ！　ひっんんっ！　んっはぁっぁあっぁぁあぁ～～～っ！　あ\n、あついっ……なかぁ、あっ……あぁぁぁ～～～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0204136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018202_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「ザーメンが、ドクドク流れ込んでくるぅ……！　ひっ、ひぃいいっ……あっ\n、あぁぁっ……すごいっ……んんんっ、うぅんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0204137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「はっ、はひっ……はあっ、あぁあっ……こんなに出されたら……絶対にぃ、\n孕んじゃうぅ……ひっ、ひぐっ……ンぅうっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0204138" ]},
		{"command":[ "SETIMAGE", "0", "still_00018202_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「はぁはぁ……んっ、んんぅっ……しゃ、しゃせぇ……しながら、奥ぅ……グ\nリグリするのダメぇ……感じすぎちゃうぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0204139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「んっ、んあっ……い、いいですよ……このまま抜かずに……続けて、はぁ、\nああっ……んっはぁ……きて、ぇぇ……んんぅぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0204140" ]},
		{"command":[ "SETIMAGE", "0", "still_00018202_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「ああ、やっぱり若いって、すごぉい……あぁんっ……抜かずにできちゃうん\nですから……んっ、んんっ……ひっ、ひぃうっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0204201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「はぁ……さっき出しなのに、ガチガチに勃起したままで……あぁ、最高ぉ…\n…このチンポ好き……このチンポなしじゃ生きてけないぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0204202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「んっ、はぁっ、あっあっ……あんっ！　いい、ですよ……好きなだけ、突い\nて……あなたが満足するまで、浮気オマンコ味わってぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0204203" ]},
		{"command":[ "SETIMAGE", "0", "still_00018202_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「あ、あんっ！　ご、ごめんなさい……声、我慢できなくて……感じすぎて、\n忘れてました……んぅ、はっ……はっんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0204204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「あぁんっ……！　だ、めぇ……出ちゃう、気持ちよすぎて……喘ぎ声、出ち\nゃうっ……んんぅぅっ！　はっ、はっぁぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0204205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「だってぇ、悪いのは……あなたのチンポ、ですよ……こんなデカチンで、オ\nマンコかきまわされて……ひっ、ひぐぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0204206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「はっ、あっあっ、あんっ……これで、感じないなんて、むりぃ……はっ、は\nひっ……んっあっあぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0204207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「こえ、我慢しても……オマンコぐちゅぐちゅ音がして、バレちゃう……誰か\n来たら、浮気セックスしてるのバレちゃうぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0204208" ]},
		{"command":[ "SETIMAGE", "0", "still_00018202_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「人が来ないうちに、イかせて……も、もうイかせて……んんっ！　おく、ガ\nツガツ突きまくって……お願い、ですからぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0204209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「んっひぃ！　あっああ……オチンポ、いいっ！　そ、そう、それぇ……若さ\nムキ出しの、腰使い……乱暴で、あっああ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0204210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「発情オマンコ、力任せに突いてくるぅ……んっ、んひっ！　ひぃあっ！　あ\nんっ！　あっ、あんっ！　あっはぁぁ……あぁぁあんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0204211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「こ、こえ、許して……あっ、あんっ！　オマンコ……よすぎて、我慢できな\nいぃ……！　あっあんっ……はぁぁぁあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0204212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「ま、またイクっ……イッちゃいますっ！　んんっ……んひっ、ひぃいっ……\nこ、このままイかせてぇぇ……このチンポでぇ、んっひぃい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0204213" ]},
		{"command":[ "SETIMAGE", "0", "still_00018202_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「ひっ！　ひぃいんっ！　オマンコ、オマンコぉ……わたしの淫乱浮気妻オマ\nンコ、イかせて欲しいんですぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0204214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「んっ、んおっ……おっおほっ……イ、イクっ！　出して……オマンコ、また\n熱々の濃厚ザーメンでイかせてくださいぃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0204215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「はっ、あぁぁぁっ……！　あんっ、あぁぁあっ……くっ、ひぃんっ！　おっ\nおっ、おほぉっ！　ひっ、ひぐぅっ……イクイクぅぅぅっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0204216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
