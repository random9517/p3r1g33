		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「はっ、あっ、あっ！！　んくうっ、奥、ゴツゴツってされて、もう、もうま\nたイっちゃうっ、貴方のおちんちんでまたイくっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0204214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「また、また一緒にイきましょう！！　私と貴方、おまんことおちんちん、一\n緒に、ラブラブで一緒にイきましょうっ！！　んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0204215" ]},
		{"command":[ "SETIMAGE", "0", "still_00027502_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「んっんっんっ、はっ、あっ、一緒に、んっ、二人で一緒に、愛しあって……\nふああっ、あっ、あっ、そこ、奥、ぐりぐりってされるの、好きっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0204216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「あああああっ、中、中が熱くなって……じゅくじゅくって、溶けて……貴方\nに絡みついて……かき回されて……頭の中まで……んっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0204217" ]},
		{"command":[ "SETIMAGE", "0", "still_00027502_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「つま先から、頭のてっぺんまで、貴方のことを好きって、愛してるって、身\n体全部が言ってる、んっ、ふああああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0204218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「自分もそうだ……って、そんなこと言われたら、もう、もう我慢できない、\nイく、イくうっ、イっちゃううううううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0204219" ]},
		{"command":[ "SETIMAGE", "0", "still_00027502_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「イっく、んっ、あああああああああああああああああああああああああああ\nっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0204220" ]},
		{"command":[ "SETIMAGE", "0", "still_00027502_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「あくうううううっ、二回目の、二回目の子作り射精来たあああああっ、あっ\n、んんっ、ふああああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0204301" ]},
		{"command":[ "SETIMAGE", "0", "still_00027502_02_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「子宮の中、さっきの精液に追加されてまた……んっ、ふううっ、あっ、こん\nな、ねばねばなのが分かるぐらい濃いの……んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0204302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「お腹、たぷたぷになってる、あんっ、まだ妊娠してないのに、お腹が膨らむ\nぐらい注がれちゃってるっ！！　あくうううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0204303" ]},
		{"command":[ "SETIMAGE", "0", "still_00027502_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「あんっ、んんっ、出しながらぐりぐりするの、ダメっ、んっ、お腹の中に、\n精液すり込まれる、んっ、ふうっ、ふああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0204304" ]},
		{"command":[ "SETIMAGE", "0", "still_00027502_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「あっあっあっ、出されるたびに、好きって、大好きってなっちゃう、んっ、\nお腹、びくびくって動いて……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0204305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「あくうっ、まだ出てる……んっ、絶対に孕ませるって、そんな中出しされて\nる……嬉しいっ、んっ、ふうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0204306" ]},
		{"command":[ "SETIMAGE", "0", "still_00027502_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「んんっ、ふっ、全部、私の中に出しましたね……ふふふっ、これだけ出され\nたら、確実に赤ちゃんができますね……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0204307" ]},
		{"command":[ "SETIMAGE", "0", "still_00027502_02_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「昔はうららだけが私の生きがいでした。そこに貴方が加わって……それでま\nた、次に私たちの子供がそこに加われば……幸せですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0204308" ]},
		{"command":[ "SETIMAGE", "0", "still_00027502_02_16" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「私たちの子供なら、きっと可愛らしく強い子になるでしょうね。男の子でも\n、女の子でも、どちらでも楽しみです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0204309" ]},
		{"command":[ "SETIMAGE", "0", "still_00027502_02_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「いつまでも、仲のいい素敵な家族でいましょうね、貴方……好きです。愛し\nてますよ、ずっと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0204310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「あんっ！？　あっ、なんでおちんちん抜いて……きゃあっ、あっ、精液、あ\nんっ、あああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0204401" ]},
		{"command":[ "SETIMAGE", "0", "still_00027502_02_20" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「身体中に、んっ、かけるなんて……んっ、熱いっ、どろどろが……ふううっ\n、あっ、んっ、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0204402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「こんな、こんな凄い量をさっきは私の中に……ひあっ、肌に貼りついて、落\nちていかない……濃くて、匂いも……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0204403" ]},
		{"command":[ "SETIMAGE", "0", "still_00027502_02_19" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「こんなのふりかけられたら、いつまでも匂いが取れなくなって、私があなた\nのものだって分かっちゃいますね……ふふ、望むところですけれど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0204404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「んふっ、でも、動物じゃないんですから、そんなマーキングせずとも、貴方\nの子を孕んだら、私が貴方のものだって一目でわかるでしょうに」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0204405" ]},
		{"command":[ "SETIMAGE", "0", "still_00027502_02_18" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「男の人って、こういうことをしたがりますよね……んっ、まあいいですよ。\n私はできた女ですからね。貴方のそういう所も許容します」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0204406" ]},
		{"command":[ "SETIMAGE", "0", "still_00027502_02_17" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「それに……貴方の精液を浴びるというのも、中々興奮するものですし。本当\nは中に出して欲しかったですけれど。これはこれで……好き」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0204407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「焦ることはないですよね。これからも、何回も貴方と愛しあうのですから…\n…好きなときに、好きな場所に出してもらえれば……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0204408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「んふうっ、全部ぶっかけて、満足しましたか？　おちんちん、まだびくびく\nしてますよ。まだ出し足りないんじゃないですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0204409" ]},
		{"command":[ "SETIMAGE", "0", "still_00027502_02_18" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「もう一回……します？　中でも外でも、いっぱい出してください。愛してる\n貴方のものなら、なんだって全部受け止めますから……ね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0204410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
