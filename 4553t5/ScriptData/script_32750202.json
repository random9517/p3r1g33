		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「あんっ……うっ、この格好、恥ずかしいのですけれど……もう、そんな顔で\n見ないでください……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0204101" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「普段の私と全然違うからって……私をそうさせるのは貴方でしょうに……こ\nんな姿を見せるのは、貴方だけですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0204102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「最初はまったく理解できませんでしたが、今なら分かります……うららがな\nぜ貴方を好いたのか……そして私も」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0204103" ]},
		{"command":[ "SETIMAGE", "0", "still_00027502_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「姉妹揃って同じ男に好意を寄せるなんて業が深い……でも、もう自分をごま\nかすことはできませんし、しません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0204104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「貴方のことが好きです……愛してます。ですから、抱いてください……もう\n、この格好、恥ずかしいから早く入れてください……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0204105" ]},
		{"command":[ "SETIMAGE", "0", "still_00027502_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「あっ、んんんんんっ！！　入って、来たあっ、んっ、そんな、いきなり全部\nなんてっ、ふうっ、あああっ、あんっ！！　あっ、イっく、んんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0204106" ]},
		{"command":[ "SETIMAGE", "0", "still_00027502_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「んくううううっ、ふっ……ふうっ、いきなり全部入れるから、ちょっとイっ\nて……んっ、ふうっ、んんんんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0204107" ]},
		{"command":[ "SETIMAGE", "0", "still_00027502_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「ふうううっ、奥まで、全部……貴方のおちんちんが、私の中に入ってる……\nんっ、凄い……貴方がいるのが分かる……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0204108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「んふうっ、んっ、熱くて、硬い……私の中が満たされて……んふうっ、んっ\n、お腹が、吸いついちゃう……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0204109" ]},
		{"command":[ "SETIMAGE", "0", "still_00027502_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「あっあっあっ、あんっ、いきなり、奥をコツコツするの、ダメっ、んっ、ん\nんっ、あっ、あんっ、あくうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0204110" ]},
		{"command":[ "SETIMAGE", "0", "still_00027502_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「ダメ……ダメですってば……あんっ、おちんちんでノックするのダメ、んっ\n、あんっ、あっ、んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0204111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「そんなにトントンされたら、降りて来ちゃう……んんっ、あっ、赤ちゃんの\n部屋、降りて来ちゃう、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0204112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「ふうっ、ふっ、んっ、んんっ、中、熱くなって……おちんちんに絡みついて\nるのに、またトントンされたら、ノックされたら、ふああああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0204113" ]},
		{"command":[ "SETIMAGE", "0", "still_00027502_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「んんんんっ、あんっ、あっ、あううっ！！　お腹、お腹の奥から、子宮降り\nてきたっ、ノックされておちんちんに子宮呼び出された、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0204114" ]},
		{"command":[ "SETIMAGE", "0", "still_00027502_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「こんな風にされたら、今出されたら、絶対赤ちゃんできちゃう……んんっ、\n孕んじゃうっ、んっ、あうっ、ああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0204115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「赤ちゃんの部屋が、おちんちんにちゅうちゅう吸いついて、抱きついて、お\nねだりしてる……んっ、ふうっ、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0204116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「ふえっ……私との赤ちゃんが欲しいって……産んで欲しいって……そんな、\nそんなこと言われたら……んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0204117" ]},
		{"command":[ "SETIMAGE", "0", "still_00027502_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「あっ、んっ、また、またイくっ、んんんんんっ！！　ふうっ、あっ、あふう\nっ……腰……動いてないのに、二回も……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0204118" ]},
		{"command":[ "SETIMAGE", "0", "still_00027502_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「私……本気にしますよ、赤ちゃん、本気で孕みますよ……んっ、本当に、本\n当にいいんですね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0204119" ]},
		{"command":[ "SETIMAGE", "0", "still_00027502_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「んっ、うっ、嬉しい……ふふっ、じゃあ動いて……私の中、いっぱいかき回\nして、どろどろにして、子供を作る準備して……ね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0204120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「あんっ、あっ、ああっ、あうっ！！　ふうううっ、来た、おちんちんのピス\nトン来たっ！！　んっ、んんっ、あっ、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0204121" ]},
		{"command":[ "SETIMAGE", "0", "still_00027502_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「ごりごりって、カリ首でひっかかれて、ずんずんって突かれて、ふううっ、\nんっ、んくうっ！！　気持ちいい……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0204122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「あんっ、あっ、あっあっあっ、それ、腰を押しつけてごりごりってされるの\n、好きっ、んっ、ふうううっ、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0204123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「貴方も……貴方も気持ちいい？　んんっ、ふっ、あふうっ、返事、聞かなく\nても、顔で……んっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0204124" ]},
		{"command":[ "SETIMAGE", "0", "still_00027502_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「気持ちよさそうな顔で分かります……んうっ、ふっ、ふふっ、嬉しい……も\nっと、もっと気持ちよくなって、あんっ、あっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0204125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「あっあっあっ、凄い、んっ、腰が、ピストンが、がちがちのおちんちんが私\nの中かき回してっ、んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0204126" ]},
		{"command":[ "SETIMAGE", "0", "still_00027502_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「あくうっ、私の中、じゅくじゅくになって、どろどろになって……おちんち\nんに絡みついてる……んっ、ふううっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0204127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「貴方の形が、お腹の中で分かる……んっ、大きくて、硬くて、逞しくて……\nんっ、これが私の中で……んんっ、ふうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0204128" ]},
		{"command":[ "SETIMAGE", "0", "still_00027502_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「あっ、ダメっ、想像しただけでまた、んっ、イきそうに……ふあああっ、あ\nっ、イきそうなのに、動いたらダメっ、ダメですっ、んううううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0204129" ]},
		{"command":[ "SETIMAGE", "0", "still_00027502_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「あんっ、あんっ、あっ、ひあああっ！！　奥っ、奥突かれたらっ、んんっ、\n吸いついて、おちんちんにキスして、おねだりしちゃうっ、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0204130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「赤ちゃんのもと、欲しい欲しいって、貴方の子供欲しいって、子宮がおねだ\nりしちゃう！！　んんっ、あくうっ、あああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0204131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「あくううっ、今、今動かれたら、あっあっあっ、んんっ、あんっ、もう、も\nうダメ、イく、またイく、おちんちんでイっちゃう、んんんっ、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0204132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「今度は、んんっ、今度は貴方も一緒に、一緒にイきましょう？　ね、私と一\n緒にイって、赤ちゃん作りましょう……んっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0204133" ]},
		{"command":[ "SETIMAGE", "0", "still_00027502_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「一緒にイって、赤ちゃんのもと、いっぱいください……んっ、あんっ、あっ\n、ああっ、あくうっ、ふうっ、腰、んんっ、凄いっ、あんっ、あっあっあっ！\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0204134" ]},
		{"command":[ "SETIMAGE", "0", "still_00027502_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「んんんっ！！　おちんちん、膨らんできてるっ！！　私の中に出そうとして\nるっ！！　ふあああっ、あっ、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0204135" ]},
		{"command":[ "SETIMAGE", "0", "still_00027502_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「んくううっ、あっ、ああっ、イっく、イっく、貴方のおちんちんで、イっく\n、んんんんんんんんんんんんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0204136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「ふああああああっ！！　お腹、お腹に精液が来たあっ、ああっ、あっ、あく\nうううっ！！　熱いいいいい、んっ！！　ふああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0204137" ]},
		{"command":[ "SETIMAGE", "0", "still_00027502_02_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「あううううううっ、あっあっあっ、んっ、気持ちいい、中出し気持ちいいっ\n！！　ふあああっ、んっ、んくううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0204138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「お腹が貴方の精液、美味しそうに飲み干してる……ふううっ、赤ちゃんのも\nと、嬉しそうに飲んでる……んんっ、ふうっ、ふああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0204139" ]},
		{"command":[ "SETIMAGE", "0", "still_00027502_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「私の中……全部満たされました……貴方の精液で……愛情で……んんっ、射\n精の律動すら愛おしい……好き……好きです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0204140" ]},
		{"command":[ "SETIMAGE", "0", "still_00027502_02_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「んんっ、まだ硬いですね……おちんちん、出したりないってびくびくしてま\nす……ねえ、もう一回、しましょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0204201" ]},
		{"command":[ "SETIMAGE", "0", "still_00027502_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「一回だけじゃ足りないかもしれませんし……それに私ももっともっと、貴方\nに愛してもらいたいから……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0204202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「あんっ！！　ふふっ、腰が反応してますね……んっ、もっと言って欲しいん\nですか？　いいですよ。好き……好き……愛してます、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0204203" ]},
		{"command":[ "SETIMAGE", "0", "still_00027502_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「大好き……だから、貴方の子供、ください……んああああっ、あっ、あっ、\nあっ、んんんっ、またっ、ピストンが……ふあああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0204204" ]},
		{"command":[ "SETIMAGE", "0", "still_00027502_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「あんっあんっ、あっ！！　それ、いっぱい突きながらぐりぐりってするのも\n、好きっ！！　貴方も、貴方のおちんちんも好きっ、あくううううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0204205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「んふううっ、だからっ、私もおちんちんを抱きしめて……んんっ、お腹の中\nで抱きしめてっ、ふううっ、んっ、んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0204206" ]},
		{"command":[ "SETIMAGE", "0", "still_00027502_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「あんっ、今、抱きついてるのに、おまんこで抱きついてるのに、動かれたら\n、ふああっ、あっ、あっあっあっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0204207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「また、私の中が溶けて、どろどろになって、おちんちんと混ざっちゃう、ふ\nうっ、あっ、あんっ、あううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0204208" ]},
		{"command":[ "SETIMAGE", "0", "still_00027502_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「んふううううっ、おちんちんの形、私の中、おちんちんの形に広げられて、\nかき回されて、あんっ、ふうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0204209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「あんっ、あんっ、あくうっ、私が、私の中がっ、貴方の子供のための場所に\n変えられてる、変わっていってる、んっ、ふああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0204210" ]},
		{"command":[ "SETIMAGE", "0", "still_00027502_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「んんんんっ、また、奥をコツコツって、今ノックされたら、子宮ノックされ\nたら、んうううっ、あっ、ああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0204211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「今ノックされたら、もうドア全開で迎え入れちゃう！！　おちんちんも精液\nも、全部迎え入れちゃうっ、ふああああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0204212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「あっ、ああっ、好きっ、好きっ！！　もう全部好きっ！！　貴方の全部、愛\nして抱きしめてあげるっ、んんっ、ああっ、あくうううっ！！」", "NORMAL" ]},
