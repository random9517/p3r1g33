{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0132" ]},
		{"command":[ "DISPIMAGE","0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「なにが宇宙だ！　このボケナスビィイイイイイイイーーーーーーーーッ！！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010107060001" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
	{"command":[ "DISPTEXT", "TRUE" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「落ち着け！　宇宙ではお前の悲鳴は誰にも聞こえない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090107060001" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「っていうか、落ちてる！？　おい！？　わたしら地球に向かって落ちてない\nか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010107060001" ]},
	{"command":[ "SETCHARA", "0", "char_00000401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「いやぁあああああああーっ！　母上様ぁーーーーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010107060002" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0000" ]},
		{"command":[ "DISPIMAGE","0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SETTEXT", "ドッギャアアアアアアアン！", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "………………。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "…………。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "……ロケット発射から、どれだけの時間が経ったのだろう。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "一瞬？　永遠？　……俺達はどうやら気を失っていたらしい。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いってえええええ……！　ううう……！」", "NORMAL" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "bg_0134" ]},
		{"command":[ "DISPIMAGE","0", "true" ]},
		{"command":[ "PLAYBGM", "BGM_006" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "大破したロケットから投げ出されたらしい俺達が目覚めると、そこは真っ白な\n大地だった。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ここは……？　っていうか、みんなは無事か？」", "NORMAL" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「うきゅうぅううう……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010107060003" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ううううん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010107060001" ]},
	{"command":[ "SETCHARA", "0", "char_00000201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「まりあ姉ちゃぁ～ん……ごめんなさい、ごめんなさぁ～い……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010107060001" ]},
	{"command":[ "SETCHARA", "0", "char_00001201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……よかった、全員無事らしいな。まあ、頑丈だけがとりえの連中だからな\n……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「宇宙……宇宙こわい……宇宙こわい……ブルブルブルブル……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010107060004" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「姫様？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「カ、カツマ……。こいつを私の記録回路に取り付けろ。Ａ・ルナテミスの回\n路を参考に開発した……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010107060005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なに言ってんすか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「すごいぞ!　私の戦闘力は数倍に跳ね上がる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010107060006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ルナテミス……！　酸素欠乏症で……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "とはいえ、いつもとたいして変わんねえな。まあ、深呼吸でもさせときゃ治る\nだろ。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ところで、アナザーは大丈夫か？」", "NORMAL" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「う……うぅん……平気だ……。あちこちぶつけたようだが、動けないほどで\nはない。痛たた……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090107060002" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "1", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうか……。でもまあ、それだけ頭がマトモなら、ルナテミスよりだいぶま\nしだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「ここは……？　ここはどこなんだ？　カツマ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090107060003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「どこって……そういえば、どこだ？　ここ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ロケットが不時着して、どこかに墜落したことはわかる。でも、地名も何も、\nヒントになりそうな建造物が見えない。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ただただ、広大な大地がどこまでも広がっているだけの、真っ白な土地に俺達\nはいた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「わかりませんが、宇宙港ではないことはたしかですな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010107060001" ]},
	{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「宇宙港どころか、地球なのかどうかすらわかんねえぞ、これじゃ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「ってことは、もしかして他の惑星！？　いったい、わたしたちどこまで飛ば\nされちゃったんだろう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010107060002" ]},
	{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「……ぶるるるるっ！　寒い！　なんですか、この寒さは」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010107060001" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「風が冷たい。そして、この空気……今までに感じたことのない種類のよう、\nだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090107060004" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「大気の組成が違うのかしら。普通に呼吸ができているところを見ると、酸素\nは充分含まれていて、有毒な成分はなさそうだけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010107060001" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａジュンジロー" ]},
		{"command":[ "SETTEXT", "「センサー不調。詳細な分析は不可能」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_040107060001" ]},
	{"command":[ "SETCHARA", "0", "char_00000904_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「まあ呼吸ができているのだから問題はない。その点は幸運だったが……この\n寒さはな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090107060005" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あ、ああ。言われてみれば寒いな。言われるまで気付かなかったけど」", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0133" ]},
		{"command":[ "DISPIMAGE","0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "冷たいものが頬に当たって、バッ！　と顔をあげる。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「雪？　雪が降ってるぞ！」", "NORMAL" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「雪！？　おおっ！？　ホントだ！　雪だ！　っていうか、すっげえ吹雪いて\nきた！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010107060002" ]},
	{"command":[ "SETCHARA", "0", "char_00000401_01", "3", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "セレーナの言った通り、天気は見る見る悪化して……うぉおおお！？　強風が\n！　横殴りの雪が！　寒い！　半端じゃねえぞ、この寒さ！", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「冗談ではないぞ……。ううう、なんで私がこんな目にぃぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010107060007" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "あ、ルナテミスが元に戻った。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ここが別の惑星だとしたら、助けはあんまり期待できないのか……。参った\nな……」", "NORMAL" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あああ、もうダメだ……。母上様……ルナテミスはもう……もう、母上様の\n元には帰れません……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010107060008" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ロケットもこの有り様だし……。これが絶望ってやつか……困ったぞ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「……？　カツマ。何かおかしな音がしないか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090107060006" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「音……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「なにかが近づいてくる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010107060003" ]},
	{"command":[ "SETCHARA", "0", "char_00000401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「……っ！？　こ、この音は……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010107060009" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「気をつけろ！　敵襲だ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090107060007" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あれは……この惑星の住人！？　地球の猿にそっくりですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010107060002" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「んなこたぁどーでもいい！　襲ってくるぞ！　追っ払え！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010107060004" ]},
	{"command":[ "SETCHARA", "0", "char_00000401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
	{"command":[ "EXIT" ]}
	]
}