		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「このジュンジロー、『あ、これなんかヤバい攻撃キタ』と感じて、咄嗟にご\n主人から離れたりはしておりません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010108180021" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……まあ、いい。とにかくこのクソッたれな空間から脱け出したい。どうす\nればいい」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「あなたは自力で“同じ座標”に辿り着いた。今そちらが居る場所と、こちら\nで攻撃を受けた場所は重なっているんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090108180020" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ひょっとして……それが、伝説の大木とやらがあった場所か？　空間の干渉に\nより消し飛んだ、とか。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「私の声にも気づき、互いに言葉が届いた。一度繋がった以上、あとはその糸\nをたぐればいいだけのはずだが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090108180021" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
