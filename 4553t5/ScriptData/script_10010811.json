{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0031" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「おや。ご主人とわたくしめが感動の再会を果たした場所ですな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010108180001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「……え。ではまさか、わたくしとご主人がその、伝説の大木に祝福されし運\n命の相手」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010108180002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「気持ちの悪い連想はやめろ。そんな迷信は脇にのけておけ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「わたくしも、ヒロインを攻略出来なかった救済措置のような、友情エンドや\nＢＬエンドはご免被りたい所ですが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010108180003" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「そこまでないがしろにするのも感心しませんなあ。どれほどの恋愛初心者が\n、その伝説に縋りたいと思っていることか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010108180004" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いいから、何か手懸かりがないか探せ。フラグだなんだと言い出したのはお\nまえだぞ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「こういう場所を捜索するなら、虫眼鏡とか手とかせめて矢印のアイコンでも\n出てこないと、気分が盛り上がらないのですが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010108180005" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんの話をしているんだ、なんの」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人こそ、ここぞとばかりに何か思い出したりしないのですか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010108180006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「関連性のある場所へフラグを立ててから移動すると、特殊なイベントが発生\nするものですぞ、普通は」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010108180007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「だからなんの普通なんだよ。これはゲームじゃない――」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……あ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「どうされました？　まさか、本当に何か思い出した、とか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010108180008" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや……まさかな。そんな都合良く――」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "bg_0117" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "『思い出してもらわねば困るぞ、隊長！』", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090108180001" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "bg_0031" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "！？", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "なん……だ。今のは？　あそこはどこだ、あれは……誰だ！？", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人？　どうされました？　幻覚だけでなく、謎の声が聞こえるとか言い\n出さないで下さいましよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010108180009" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「え……いや、なんだ？　おまえ、今の……聞こえなかったのか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「はあ？　一体何を仰っているのですかあ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010108180010" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "bg_0117" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "『忘れたかカツマ！！　あなたの本当の戦いを！！』", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090108180002" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "bg_0031" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ぐ……っ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ああ……知っている。あの場所を、あいつを、俺は、知っている……！！", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あいつは――あいつの名は……アナザー・ルナテミス！！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "bg_0117" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「そうだ！　私の名を呼んだな、カツマ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090108180003" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "bg_0031" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「うわっ！？　ら、落雷ですか！？　空は晴れているのに……ええっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010108180011" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「どうしたジュンジロー――っと！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "間近に雷のような光が降ってきたと思ったら……空が、割れて……何かが見え\nる！？", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「あれは、元々ご主人とわたくしがいた世界……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010108180012" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「分かるのかジュンジロー！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「はい。あの、割れた空と言えばよろしいんでしょうか、ともかくその合間に\n見える光景は間違いなく」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010108180013" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「そうだ！　あなたたちが本来居るべき場所だ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090108180004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ひょっ！？　なんですか今の声は！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010108180014" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おまえにも聞こえるようになったか。アナザー・ルナテミスだよ、分かるか\n？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「え、あ、はい。アナザー殿ですか、なーんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010108180015" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「はっ！？　そういえばご主人、幹部の皆様はことごとく“こちら”にいらっ\nしゃいましたが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010108180016" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああ。まだ“アナザーにだけは会えていなかった”な！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「当然だ。私はその“罠”から辛くも逃げ延びたからな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090108180005" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「罠？　どういうことだ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「襲来者（インベーダー）との戦闘中、あなたは攻撃を受けて意識を失った…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090108180006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「そこにすかさず、奴らは精神的な攻撃を続け様に仕掛けてきたのだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090108180007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「精神的？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「対象の無意識を増幅し、妄想で練り上げられた世界を構築、そこに人々の意\n識を捕らえてしまうという恐ろしい攻撃だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090108180008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ははーん。やはりこの世界は、ご主人の無意識を反映したものでしたかー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010108180017" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「日頃からよっぽど現実逃避したかったんですな、ご主人様」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010108180018" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「悪かったな！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「今、こちらで覚醒しているのは私とステラルクスたちぐらいのもの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090108180009" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「特にグレート・ルナリアムの関係者は皆、昏倒していて何をしても目を醒ま\nさない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090108180010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんてこった……悪の組織として情けない限りだな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「そうでもない、単に運と……あとは、人望かな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090108180011" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「人望？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「あなたの周囲に居た人間だけが巻き込まれているのだよ、カツマ“隊長”」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090108180012" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "…………。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「それの意味する所は無事戻ってから考えれば良いとして――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090108180013" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「敵が、搦め手できたという事だ。力押しではなくメンタルへの攻撃。知らな\nければまともに喰らってしまうのも無理はない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090108180014" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……おまえは、知っていたのか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「ああ。この種の敵とは以前戦った事がある」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090108180015" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「その時は仲間のひとりが幼児退行してしまってな。赤ちゃんプレイを永遠に\n繰り返す世界から、遂に還ってこれなかった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090108180016" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「それはまた、本人にとっては極楽かもしれませんなあ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010108180019" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや地獄だろ。しかもアナザーたちに観測されている訳だし」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「うむ。こちらからはあらゆる方法を用いて、そちらが丸見えだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090108180017" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……で、なんでジュンジローだけは正気を保っているんだ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「攻撃の影響範囲には居たようだが、あなたからは微妙に距離をとっていた様\n子だからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090108180018" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「言ったろう？　“あなたの周囲に居た人間だけが”巻き込まれた、と」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090108180019" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "…………。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「いやいや、人間ではないから無事だっただけかもしれませんぞ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010108180020" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
