		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「だが？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYBGM", "BGM_007" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「っ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「奴らも必死だ。阻止するために障害を送り込むだろう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090108180022" ]},
