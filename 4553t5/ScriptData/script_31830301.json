		{"command":[ "SETIMAGE", "0", "still_00018303_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「あなたは私に、おとなしくパイズリされていればいい……。なんて。説明す\nる必要もなかったわね。もう、こんなにチンポが大きくなってるんだもの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0303105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「ん……本当に、硬くて大きくて……あの人のモノとはわけが違う……。毎回\n見る度に……んっ、触れる度に驚愕するわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0303106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁっ……。本気で挟んでも、胸を押し戻してくる弾力……それに\n、谷間からはみ出るくらい長くて……臭いもキツい……。んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0303107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「こんな立派なチンポに奉仕しているなんて、籠絡部のみんなもうらやましが\nるわよね……。ふぅっ、これに狂わされてみたいって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0303108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「……え？　今日の私が積極的すぎる？　いつもはそんなにぐいぐい胸を押し\nつけてこない……？　いやだ。心の中までお見通しってわけね。そうよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0303109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「聖夜にも……クリスマスにも、家に帰ってこない夫へのあてつけ。ここに来\nるまでに見たでしょ？　ホテルに行列を作るカップル達の多さ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0303110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「みーんなデートに浮かれてたわ。でも、いいの……。私にはこの素晴らしい\nチンポが、あなたの太い肉棒があるんだから。……ねえ、お願い」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0303111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「今夜だけ。私の胸に欲望をうんとぶつけてほしい。余計なことを忘れるくら\nい、私のコレ。ぱんぱんに膨らんだ乳房をめちゃくちゃに汚して……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0303112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「っん……っ。あなたのコレ……最初はすっごくパイズリしづらいのよ、ねっ\n……！　はぁっ、はぁ……。単純に、サイズがスゴくて胸を動かせないし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0303113" ]},
		{"command":[ "SETIMAGE", "0", "still_00018303_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「ずっしり重くて……んっ、んっ、うぅ……っ！　鉄の棒にでもご奉仕してい\nる気分になるの……。あっ、だって金属みたいに硬いから……っ、はぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0303114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「色んな女の子に言われるでしょ？　スゴいチンポだって。名器なのよね。女\nを……特に人妻を、トロトロにしちゃう危険なチンポ……。んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0303115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「夫の……他の男のモノを熟知しているからこそ、スゴさが際立ってわかるの\nよね。……っん、見て？　自分でも大きいと思うでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0303116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「あなたのチンポ……いつだって、湯気が出そうに熱くて、ほんと、女を誘惑\nするのが上手すぎるの。貞淑な人妻ですらただのオンナに変えるチンポ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0303117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「……あっ……♪　こうして胸にコレを挟んで、しごいているとね……♪　亀\n頭が目の前にっ、飛び出してきて、たまらなくなるの……っ。あっあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0303118" ]},
		{"command":[ "SETIMAGE", "0", "still_00018303_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「ここから……この先端の穴からビュッビュッて、夫の子種とは比べ物になら\nない濃い若い精液が飛び出してくるんだって……想像して感じちゃう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0303119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「んぅ……ンン、早く欲しいわ……。私の顔も、胸も、何もかも真っ白に塗り\nつぶして……♪　あっ……これくらいの力がいいの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0303120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「いいわよ。何もかも、あなたのいいようにしてあげるから……なんでも言っ\nて。んっ……、こう、かしら……？　あっ、もう少し強く、する？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0303121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「私の吐息がかかるように……？　いいわよ。あっ……んんっ……。胸の中で\nビクビクしてる……。お風呂、後にして良かったわね……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0303122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「あなたの汗で蒸れた股間……。このニオイがたまらなく好きなの……。ンッ\n……こうして摩擦すればするほど、香りが強くなってくる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0303123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「すぅうぅう……。んん……かぐわしい香り。若いオスのニオイ。夫とは違う\nニオイ……。この臭いをうんと胸にたくさんこすりつけて……それで」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0303124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「気付かれてしまうのもいいかもね。私の不貞……。あン……♪　こうして聖\n夜にいやらしいホテルで、母性の象徴である大切な乳房……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0303125" ]},
		{"command":[ "SETIMAGE", "0", "still_00018303_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「旦那と赤ちゃんのためだけにあるはずのオッパイを、浮気相手に与えて、全\n力で卑猥なニオイを染みつかせている……。んっ、私って最低ね……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0303126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「でも、やめられない……止まれないの。いけないことだと、わかって、るの\nに……んんっ。こうして胸を動かすのを優先してしまう……。はぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0303127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「……ってあなた。何、を他人事みたい、な顔しているの……。あなただって\n共犯なんだから。こんなにチンポを刺激させて……。ふぅううう……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0303128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「……あはっ。息を吹きかけたらピクピクしてる。感じやすいんだ。もっと感\nじてよ。ほら……ほら、肉欲にまみれた本性を見せなさい……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0303129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「……ぅ？　あら……やだ♪　素敵なオチンチンからカウパーが滲み出してき\nてるじゃない。そうなんだぁ……気持ちいいんだ。ウフフ、可愛いわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0303130" ]},
		{"command":[ "SETIMAGE", "0", "still_00018303_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「ほら。にちゃ、にちゃ、って谷間に汁が広がってく……。あっ……やっ♪　\nヌルヌルが増えると、こっちもかなり感じるわね……。あっ！　あっぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0303131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「ダ、メ……♪　あぁんッ……乳首がこすれて……はぁあっ♪　ヘンな気持ち\nよ……。あっ♪　あっ、んもぅっ、腰を動かさないで……んぁあんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0303132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「あ、あなたの腰使い……むちゃくちゃ上手いから困る、のよぉ……！　あっ\n……こらっ！　も、もう早くイッてぇ……こっちがやられちゃう……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0303133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「あンッ♪　んっ、ンッ……！　んふ……くぅっ、ンンっ……やん……っ！　\n力強く突き上げ、ないで……まるでセックスしてるみたい、じゃない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0303134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「あっ♪　あっぁっ……そうなの？　出したいの？　……だったらこのままっ\n……あんっ！　このまま来て！　ちょうだい、あなたのザーメン……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0303135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「っアッ……♪　きたわ、あぁっ……！　私の胸の中を駆け上がって……。ん\nっ！？　ぷっ……んうううっ……！　とびきり濃い精液が……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0303136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018303_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「あぁっ！？　やぁ……！　どんどん飛んでくる！　あっ……どれだけの量を\n溜め込んでたのよぉ……！　んぁっ、ああ……！　すっごいっ、ぷぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0303137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「シャワー、みたい……っ！　どぷっ、ドピュって……絶え間なく放たれる白\nい弾丸……。あっ♪　それが顔に、口元にはりついて……んぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0303138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「絶対！　ぜったい浮気がバレるわ……っ。あああっ……！　ザーメン臭が髪\nにまでこびりついてるもの……！　同じ男の夫にはすぐ、わかる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0303139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「自分の妻から精液のニオイがするって……！　はぁっ、はぁ、不倫パイズリ\nしてきたんだって！　あっ……あぁ……あああ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0303140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「はーっ……♪　はーっ……♪　ありがと……嫌な現実が吹き飛ぶくらい、す\nごい射精だった……。女を虜にするのが上手すぎるわよ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0303201" ]},
		{"command":[ "SETIMAGE", "0", "still_00018303_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「……これでスッキリしたかって？　そうねぇ……だいぶ楽になったけど。で\nも、まだダメ。終わらせてあげないわ。いいわよね？　続けても」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0303202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「フフ……。あなただって全然、チンポが萎えてないじゃない。こんなに出し\nてもまだビンビン。これって、わたしにまだシてほしいって事でしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0303203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「んっ……私、も……身体の疼きがまだおさまらないの。だから、このまま２\n回戦させてもらうわね。大丈夫。うんと気持ち良くしてあげる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0303204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「は、ぁ……はぁ、んふ……ふぅっ、ふ……♪　は、ぁ……♪　んふ……っ♪\n　射精したてとは思えない逞しいオチンポね……信じられない、わ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0303205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「えぇ？　私の顔に精液をかけたら、ものすごく興奮したから？　……んっ…\n…な、なによ、それ……。そんなこと言われたら、わ、私……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0303206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「……い、いいからあなたはチンポだけに集中しなさい！　わ、私のことなん\nかそんなに見なくていいのよ。ど、道具みたいにただ使ってくれれば……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0303207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「んんんっ……！　ザーメンコーティングされた、ヌルヌルのオッパイってさ\nっきとは全然違うでしょ？　オチンポ全体を包み込む粘液が……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0303208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「少しずつわたしの体温であたたまって……。あッ♪　潤滑油のかわりになっ\nて……。ンンッ……♪　いやらしいニオイがあたりそこらじゅうに広がって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0303209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「いやらしいことしてる、って強烈に自覚させられるわ。はぁっ……♪　私達\n、今オッパイとチンポでエッチしてるわね♪　あっ……濃厚なセックス♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0303210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ、ふぅっ、んん♪　あらあらあら？　あなたもすごく盛り上がっ\nてきてるわね。やぁだ、このオチンポ暴れすぎ……ジッとしてぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0303211" ]},
		{"command":[ "SETIMAGE", "0", "still_00018303_01_05" ]},
		{"command":[ "WAITINPUT" ]},

