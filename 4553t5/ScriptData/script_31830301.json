		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「……今日は、私の呼び出しに応じてくれてありがと。忙しいのに、悪いわね\n。クリスマスなのに、他の子達との約束は良かったの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0303101" ]},
		{"command":[ "SETCHARA", "0", "char_00018303_01", "6", "CENTER", "0" ]},
