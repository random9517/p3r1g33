		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「え……私があまりにも寂しそうだったから？　失礼ね……でも。ええ、そう\nよ。私は今日、独りで身体を持て余していた……。だから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0303102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「あなたを籠絡するための仕事という言い訳で、呼んだの。こっちに来て。そ\nう、ラブホテル。何も言わずに、黙って私についてきて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0303103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「んっ……。フフ、部屋に入るなり、シャワーも浴びずにいきなりズボンを下\nろされて……困惑しているようね。余計なことは何も考えなくていいの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0303104" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
