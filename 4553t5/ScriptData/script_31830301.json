		{"command":[ "SETTEXT", "「あッ……あっ、あっ、はぁっはぁっ……♪　私が胸を動かすリズムに、合わ\nせて腰を突き上げて……。あンっ♪　そう、そうよ上手よ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0303212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁっ、限界まで溜めて……我慢してね。私もだんだん気持ち良くな\nってきたから……一緒にイキたいの。あぁ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0303213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「あなたのチンポ、本当に素敵……。ずっと挟んでシゴいていられるわ……。\nっぁ……♪　ふぅっ、ふぅう……♪　欲しい反応をすぐにくれて……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0303214" ]},
		{"command":[ "SETIMAGE", "0", "still_00018303_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「敏感なのに耐久力もすごくって……。あっ♪　悪いチンポね……♪　でもい\nいのよ、私だって悪い人妻だし、おっぱいを悪いことに使ってるもの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0303215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「だか、らっ♪　悪い者同士で思いっきり……イきましょ♪　あぁっ♪　あん\nっ、んん……これはさすがに、気持ちよすぎ……あっあっあっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0303216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「ご、めんなさい……！　我慢をしろと言ったこちらの方が……んぁっ。感じ\nる……！　あッ♪　い、いいわよね？　今日くらいっ……んんんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0303217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「誰かの妻であることを忘れてっ……！　淫らに喘いでも！　あぁっ♪　あぁ\nんっ、んんっ、ん～～～っ！　イクぅ……オッパイでイクのぉっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0303218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「あはぁっ♪　あぁあんっ、ち、くび……♪　こすれてすごく気持ちいい！　\nあっ、ぁっ♪　あなたのっ、あなたのチンポももう限界、でしょ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0303219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「イッて……っ！　私もまた、すぐイケるからっ……！　あっ♪　お願いよ、\n出して……出して、浴びせてっ……ザーメンっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0303220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「ふぁっ……♪　そのまま、出したいだけ出して……！　あっ♪　上手にピュ\nッピュ出来てるわね……！　待ってて、今絞り出してあげるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0303301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018303_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「んんっ……！　谷間をぐっと寄せて……チンポの根元から先端までシゴきあ\nげて……。っあんっ！　ほら、ビュッてまた溢れてきたわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0303302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「あはっ……！　んっ、ぁっ、あっ……フフフッ♪　絞れば絞るほど次々飛び\n出してくる……。あんっ！　私、射精のサポートの才能があるのかも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0303303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「ふふ、調子に乗ってどんどん絞り取ってあげるわよ……。そぉれ……♪　っ\nぷぁ……！　いいのよ、口に入るくらい……。んっ……それそれっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0303304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「はぁあっ♪　飛んだ飛んだ……♪　なんだか自信がついたかも……。私、ま\nだこんなに誰かを……喜ばせることができるんだなぁって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0303305" ]},
		{"command":[ "SETIMAGE", "0", "still_00018303_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「だって、見て？　この精液の濃さ……指でつまめちゃいそうじゃない。この\nイカくさいニオイ……。たっぷり子種が詰まってる証拠だわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0303306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「これだけの素晴らしい精液を出せるあなたも素晴らしいけど……その百分の\n一くらいは、私が魅力的だったから、頑張ったからだと思ってもいいでしょ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0303307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「……そうね。あなたを射精させると、私の心も満たされていくみたい。だっ\nたら、落ち込んでいないでエッチの腕を磨こうかしら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0303308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「そのためには、当然パイズリだってもっともっと上手くならなくちゃいけな\nいし……。ねえ？　これからも、私の練習に付き合ってくれる？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0303309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「いいじゃない。面倒くさがらないで。私がうんと上手になったら……一番に\nそれを体験させてあげるから。楽しみにしていてほしいものだわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0303310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「んぅっ！　ンッ……んんんっ♪　あったかいのが胸に流れこんでくる……。\n気持ちいいっ……♪　あぁ、イ、く……あぁあんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0303401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018303_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「オチンポ、脈打って次々にザーメンを吐き出してる……。あぁ、そんなに気\n持ち良くなってくれたの……？　嬉しすぎるわ……！　っあっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0303402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「見て……胸の中に真っ白な精液の泉ができてく……。これが全部あなたの子\n種だと思うと、興奮するわ。あっ♪　やだ、まだ出せるの……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0303403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「あンッ……んんっ、いいわ、もっと……もっとちょうだい……！　っあぁあ\nあ……！　ゾクゾクしちゃう、あなたの種に溺れそう……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0303404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「やっ……また震えて……。まだ尿道に少し精液が残っているかもしれないか\nら、胸で刺激して搾ってあげる……。んっ……ん、ん……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0303405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「は、ぁ……♪　ドロッて、残り汁が……♪　ねえ、いつもより精液が臭い気\nがするわ……。二度目なのになんて臭さなのよ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0303406" ]},
		{"command":[ "SETIMAGE", "0", "still_00018303_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「フフ……私が少し息をするだけで、プルプルって精液が揺れてるわ……。ど\nう？　この胸に、あなたの精子……自由に放出したご感想は」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0303407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「……あなたにパイズリをすると、予想よりもたくさん出してくれるから好き\nよ。私の胸も、まだまだ捨てたものじゃないって思えるし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0303408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「今度はこうしてみようかしら、ああやってチンポを刺激したらどうかしらっ\nて、前向きな気持ちになる。これって本当にすごいことよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0303409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「あなたは気持ちよく精を出せて、私はプライドを取り戻せる。……私達、結\n構いいコンビなのかもしれないわ。だから、また……よろしくね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0303410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}