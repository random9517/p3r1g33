{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0101" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁっ、はぁっ……くっ、そっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022490001" ]},
		{"command":[ "SETCHARA", "0", "char_00000312_01", "4", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「思ったより手を掛けさせてくれましたが……そろそろお疲れのようですね？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_010022490001" ]},
		{"command":[ "SETCHARA", "0", "char_00023001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「はん……言ってな。そっちも、技のキレが鈍ってるんじゃないのかい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022490002" ]},
		{"command":[ "SETCHARA", "0", "char_00000312_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「お口はまだまだ元気のようですね。ですが、ご自分でも旗色の悪さは自覚な\nさっていると思いますが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_010022490002" ]},
		{"command":[ "SETCHARA", "0", "char_00023001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「だったら、素直に引き下がれってかい？　何一つ笑えない冗談だね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022490003" ]},
		{"command":[ "SETCHARA", "0", "char_00000312_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「冷静な忠告のつもりでしたが……仕方ありません。直接思い知って頂くしか\nないようですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_010022490003" ]},
		{"command":[ "SETCHARA", "0", "char_00023001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「っ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022490004" ]},
		{"command":[ "SETCHARA", "0", "char_00000312_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「あのぉー、お取り込み中のところ、失礼致します～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_010022490001" ]},
		{"command":[ "SETCHARA", "0", "char_00022001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「ん……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_010022490004" ]},
		{"command":[ "SETCHARA", "0", "char_00023001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「……な、バカ野郎っ……こんな危ない所に何をっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022490005" ]},
		{"command":[ "SETCHARA", "0", "char_00000312_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「あ、先程……あちらの方からご依頼を頂きましたので、えぇと、あなたがエ\nファナティカ様でしたか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_010022490002" ]},
		{"command":[ "SETCHARA", "0", "char_00022001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「私～怪人派遣協会から参りました兎怪人・バニーママと申します～。加勢す\nるように仰せつかいましたのでー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_010022490003" ]},
		{"command":[ "SETCHARA", "0", "char_00022001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「カツマが……？　いや、だが並の怪人でどうにか出来るわけ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022490006" ]},
		{"command":[ "SETCHARA", "0", "char_00000312_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「とりあえず、ちょっとお怪我をされているようですし、失礼いたしますね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_010022490004" ]},
		{"command":[ "SETCHARA", "0", "char_00022001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「えっ……あっ……お、おい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022490007" ]},
		{"command":[ "SETCHARA", "0", "char_00000312_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「はーい、痛いの痛いの～飛んでいけ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_010022490005" ]},
		{"command":[ "SETCHARA", "0", "char_00022001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「っ……痛みが……引いていく……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022490008" ]},
		{"command":[ "SETCHARA", "0", "char_00000312_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「とりあえず、しばらくはこれで大丈夫だと思います。動けますか～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_010022490006" ]},
		{"command":[ "SETCHARA", "0", "char_00022001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あ、あぁ、行けそうだ。すまん、助かったよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022490009" ]},
		{"command":[ "SETCHARA", "0", "char_00000312_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「いえいえ～、それでは参りましょうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_010022490007" ]},
		{"command":[ "SETCHARA", "0", "char_00022001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「人数が増えても、状況は変わらないと思いますが？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_010022490005" ]},
		{"command":[ "SETCHARA", "0", "char_00023001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「状況は存じませんが、これも大切なお仕事ですので～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_010022490008" ]},
		{"command":[ "SETCHARA", "0", "char_00022001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「貴方もご理解いただけないと……では、早々にご退場を願いましょう……は\nぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_010022490006" ]},
		{"command":[ "SETCHARA", "0", "char_00023001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「えいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_010022490009" ]},
		{"command":[ "SETCHARA", "0", "char_00022001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「っ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_010022490007" ]},
		{"command":[ "SETCHARA", "0", "char_00023001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「わぁ……鋭い一撃ですねぇ。それでは、私の方からも……はっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_010022490010" ]},
		{"command":[ "SETCHARA", "0", "char_00022001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「っくっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_010022490008" ]},
		{"command":[ "SETCHARA", "0", "char_00023001_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「あら、本当にお強いですねぇ。私も、もっと頑張らないと～、えーいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_010022490011" ]},
		{"command":[ "SETCHARA", "0", "char_00022001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「っ……これはっ……く……ふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_010022490009" ]},
		{"command":[ "SETCHARA", "0", "char_00023001_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「エファナティカさんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_010022490012" ]},
		{"command":[ "SETCHARA", "0", "char_00022001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「おおよっ！　そうりゃあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022490010" ]},
		{"command":[ "SETCHARA", "0", "char_00000312_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「くっ……小癪な……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_010022490010" ]},
		{"command":[ "SETCHARA", "0", "char_00023001_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うーわ、マジか。あのプルリーってのと互角に渡り合ってるぞ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ナンなのアレ……何者？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010022490001" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「怪人協会の人なんだが……うちの幹部より強いって……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「なるほどね……あんな感じにすればいいんだ……そーいうことならっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010022490002" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あっ、おいっ！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「驚きました……まさか、これ程までの使い手がいらっしゃるとは……ふっ…\n…！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_010022490011" ]},
		{"command":[ "SETCHARA", "0", "char_00023001_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「とんでもないです～。貴方も、素晴らしいお力の持ち主で～、えーいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_010022490013" ]},
		{"command":[ "SETCHARA", "0", "char_00022001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「くぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_010022490012" ]},
		{"command":[ "SETCHARA", "0", "char_00023001_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「スキありぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010022490003" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「っ……！　一度大人しくしていたと思ったら、また貴方も……あまりいい状\n況ではありませんね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_010022490013" ]},
		{"command":[ "SETCHARA", "0", "char_00023001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「さっきの仕返ししなきゃ気分ワルいままだし？　今しかないもんね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010022490004" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「どうやら、形勢逆転のようだね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022490011" ]},
		{"command":[ "SETCHARA", "0", "char_00000312_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「ふむ、確かに状況は変わりましたが……だからと言って、私も簡単に引き下\nがるつもりはありません。かくなる上は……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_010022490014" ]},
		{"command":[ "SETCHARA", "0", "char_00023001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「はいはいはーいっ、プルリーちゃん、そこまでー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010022490001" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「お、お前はっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022490012" ]},
		{"command":[ "SETCHARA", "0", "char_00000312_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「お久しぶりー。やー、ごめんねぇ。ちょーっと手違いがあったみたいでさ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010022490002" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「なんですか、貴方は……あっ……ぐっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_010022490015" ]},
		{"command":[ "SETCHARA", "0", "char_00023001_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「本来は、この次元と繋がることはなかった筈なんだけど、まぁ、色々ややこ\nしくなって、ご迷惑をお掛けしちゃいましたっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010022490003" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「離しなさいっ！　私には、なさなけらばならないことがっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_010022490016" ]},
		{"command":[ "SETCHARA", "0", "char_00023001_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「どうにも、娘恋しさに先走って来ちゃったみたい。ちゃんと連れ帰るんで～\nごめんねー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010022490004" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「ま、待ちなさいっ！　私はイルルを連れて帰らなくてはっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_010022490017" ]},
		{"command":[ "SETCHARA", "0", "char_00023001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「だから、貴方が追っかけてるのは、そのイルルちゃんじゃない方だからー。\nはーい、とにかく帰りますよー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010022490005" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「あぁっ……イルルーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_010022490018" ]},
		{"command":[ "SETCHARA", "0", "char_00023001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「…………いなくなっちまった……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「……終わった……のかい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022490013" ]},
		{"command":[ "SETCHARA", "0", "char_00000312_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「おかーさんっ……だいじょうぶっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010022490001" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あぁ……イルル。なんとかね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022490014" ]},
		{"command":[ "SETCHARA", "0", "char_00000312_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「……よかった……おかーさん……ありがと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010022490002" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「あのー、本日のお仕事は他にございますかー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_010022490014" ]},
		{"command":[ "SETCHARA", "0", "char_00022001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あ……いや、大丈夫っす。その、マジで助かりました」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「いえいえ。それでは、今日はこれで失礼致します。またの機会がございまし\nたら、ぜひよろしくお願いします～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_010022490015" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あれが、怪人協会の肝煎りか……結構やるって話は聞いてたけど、あそこま\nでとはね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022490015" ]},
		{"command":[ "SETCHARA", "0", "char_00000312_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「どう考えても、カタギじゃなかったよな……人は見た目に寄らないなんてレ\nベルじゃなかったぜ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「バニーママか。いや……あたしもいい勉強になったよ。母親には敵わないっ\nて言葉を身をもって味わった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022490016" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「まだまだあたしも修行が足りないね。イルル……お前の為にも、あたしも強\nくならないとね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022490017" ]},
		{"command":[ "SETCHARA", "0", "char_00000312_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「ううんっ、おかーさんっ、強かった！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010022490003" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや……母は強しってそういうことじゃないからな……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「やれやれ……なーんか、とんだとばっちりだったわ。何でヤムが……っと、\nそっか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010022490005" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「…………？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010022490004" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「はい、やるわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010022490006" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「これ……アメ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010022490005" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ちょっと、こいつを渡してやろうと思ったら、このザマだもん。ありがたく\n思って食べなさいよね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010022490007" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「……うん。ヤム……ありがと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010022490006" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ふ……ふんっ！　じゃあねっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010022490008" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}