		{"command":[ "SETCHARA", "0", "char_00015601_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},


		{"command":[ "SETNAME", "人型襲来者たち" ]},
		{"command":[ "SETTEXT", "「リーダ～～～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_010114510004" ]},
		{"command":[ "SETCHARA", "0", "char_00090201_01", "3", "CENTER", "-500" ]},
		{"command":[ "SETCHARA", "1", "char_00090301_01", "3", "CENTER", "0" ]},
		{"command":[ "SETCHARA", "2", "char_00090401_01", "3", "CENTER", "500" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "DISPCHARA", "2", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「うんうん……！　よかったな！　よかったなぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_010114510002" ]},
		{"command":[ "SETCHARA", "0", "char_00003401_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "DISPCHARA", "2", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「青春だ……！　そうとも、これが青春なんだ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010114510002" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「って、そこ！　勝手に終わった感を出さないでください！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010114510003" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「はぁっ！？　なんだおまえ！　せっかく感動的なシーンなのに、野暮なこと\n言ってんじゃねえよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_010114510003" ]},
		{"command":[ "SETCHARA", "0", "char_00003401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「あなたこそ、なにを言ってるんですか！　野暮だとかなんだとか、そういう\n問題ではないでしょう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010114510004" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「ほかにどういう問題だってんだよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_010114510004" ]},
		{"command":[ "SETCHARA", "0", "char_00003401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「今回の騒ぎは、まだまだ進行中です！　まだ、なにも解決していないんです\nよ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010114510005" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「わかってらあ！　でもよ、それ、いま言うことか！？　いまはこいつらの見\nせ場だろうが！　襲来者（インベーダー）たちと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_010114510005" ]},
		{"command":[ "SETCHARA", "0", "char_00003401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「この『ルミナス』のよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_010114510006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「…………は？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010114510006" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「ルミナス……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010114510003" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者リーダー" ]},
		{"command":[ "SETTEXT", "「ルミナスって……？　え！？　わ、私のことか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010114510006" ]},
		{"command":[ "SETCHARA", "0", "char_00015601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「ま、まあな。なんか、いつまでも『襲来者（インベーダー）』呼ばわりもな\nんだと思って。つい、思いついたんで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_010114510007" ]},
		{"command":[ "SETCHARA", "0", "char_00003401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「あなたにしては、ずいぶんと乙女チックなネーミングですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010114510007" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「うるせえ黙れ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_010114510008" ]},
		{"command":[ "SETCHARA", "0", "char_00003401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「ですが、悪くない名前だと思いますよ。ルミナスというのは」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010114510008" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者リーダー" ]},
		{"command":[ "SETTEXT", "「レッドにブルー……こんな私に、新しい名前を……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010114510007" ]},
		{"command":[ "SETCHARA", "0", "char_00015601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「そうだ……！　『ルミナス』！　それが私の、地球での新しい名前だ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_040114510001" ]},
		{"command":[ "SETCHARA", "0", "char_00015601_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「冴島だ！　こちらの準備は片付いた。宇宙船はいつでも発進できる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010114510003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「お！　来たな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_010114510009" ]},
		{"command":[ "SETCHARA", "0", "char_00003401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ＥＤＯはこれより、Ｇルナリアムの支援を開始する！　時間帝国へ乗り込む\nぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010114510004" ]},
		{"command":[ "WAITINPUT" ]},

