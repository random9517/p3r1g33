		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ＭＯＥ" ]},
		{"command":[ "SETTEXT", "「こっちも宇宙船を分捕ったわ！　整備良好燃料満タン、現状渡しで乗り出し\nＯＫよ！」", "NORMAL" ]},
