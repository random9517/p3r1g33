		{"command":[ "PLAYVOICE", "v2_049_010114510002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「了解です。さて、こちらは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010114510002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
