		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "DISPCHARA", "2", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「いや、私たちそこまで言ってませんけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_010114510003" ]},
		{"command":[ "SETCHARA", "0", "char_00090301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「でもまあ、そういうことではあるけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_010114510003" ]},
		{"command":[ "SETCHARA", "0", "char_00090401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者リーダー" ]},
		{"command":[ "SETTEXT", "「その気持ちはわかる！　私がお前たちの立場なら、同じことをしてしまった\nだろう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010114510004" ]},
		{"command":[ "SETCHARA", "0", "char_00015601_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「リ、リーダー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_010114510003" ]},
		{"command":[ "SETCHARA", "0", "char_00090201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「わかっちゃって、しちゃうんですか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_010114510004" ]},
		{"command":[ "SETCHARA", "0", "char_00090301_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者リーダー" ]},
		{"command":[ "SETTEXT", "「頼りないリーダーですまなかった～っ！　許してくれ～～～～っ！」", "NORMAL" ]},
