		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者リーダー" ]},
		{"command":[ "SETTEXT", "「お前たちはきっと、こんなよわよわで、だめだめで、ヘタレなリーダーにつ\nいていったら、どうなるかと不安になってしまったんだろう……」", "NORMAL" ]},
