		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「わ、わ、わたしたち、ただ、あの二人が怖くて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_010114510001" ]},
		{"command":[ "SETCHARA", "0", "char_00090301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「うわああああ～～ん！　リーダー！　ごめんなさい！　ごめんなさぁ～～～\nいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_010114510001" ]},
		{"command":[ "SETCHARA", "0", "char_00090401_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「お、おい、リーダー。こいつらも反省してるんだろうし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_010114510001" ]},
		{"command":[ "SETCHARA", "0", "char_00003401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「そうだ。漢字書き取り５００回ぐらいで許してやっては……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010114510001" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "3", "CENTER", "0" ]},
