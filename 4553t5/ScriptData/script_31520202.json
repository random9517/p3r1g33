		{"command":[ "SETIMAGE", "0", "still_00015202_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「はぁぁぁん……すごぉい……気持ちいいのが、溢れてる……はぁ、はぁ……\nあへぇぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0204209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「ぐぅっ、ひうぅぅ……中で、精液がグチュグチュ、音立ててるぅ……はぁ、\nはぁぁあん……いやらしい……」", "NORMAL" ]},
