		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「はー……あふぅ……すごくよかったぁ……ふふ、ありがとう、坊や……素敵\nな初体験をさせてくれて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0204140" ]},
