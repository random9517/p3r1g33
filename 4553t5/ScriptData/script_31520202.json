		{"command":[ "SETIMAGE", "0", "still_00015202_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「震えてる……ああ、中で震えてる……オチンポ、ビクンビクンして……あっ\n、あっ、あああ……はぁぁぁぁぁあん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0204135" ]},
		{"command":[ "WAITINPUT" ]},

