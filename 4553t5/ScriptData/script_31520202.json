		{"command":[ "PLAYVOICE", "v2_152_0204202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「はぁぁん……見て見てぇ……ドロドロが、隙間から滴ってる……ほらぁ、太\nももにベッタリ張り付いてる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0204203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……視線が、絡みついてくる……はぁ……坊やの視線が絡みつ\nいてくる……あぁん、いやらしい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0204204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「ふふ、精液で汚れたわたしを視姦しながら、後ろから犯されちゃう……あぁ\nん、ヤバい……たまんないよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0204205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「はぁん、やだぁ……わたし、自分でお尻、突き出してる……ん、んん……は\nぁ、腰がもっとぶつかっちゃうぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0204206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「わたし、はしたない……普段からはしたないけど、今人生で一番はしたない\n瞬間かも……はぁ、はぁ……あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0204207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「んんっ、くぅ……はぁ、はぁ……子宮と亀頭がゴツゴツぶつかって……あ、\nはぁ……音と振動が伝わってくる……」", "NORMAL" ]},
