	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「えーっとぉ……前に言ったかもしれないけど……拙者、その……経験が無く\nて……え？　知ってたでござるか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0204101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「そ、そう……それなら別にいいんでござるけど……この体位、難易度高くな\nいでござるか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0204102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「天蓋付きのベッドで、オーシャンビューの部屋で初体験……とまでは言わな\nいでござるが……立ったまま、後ろからとは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0204103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「もっと、こう……初心者に優しい初体験をお願いしたいところでござるけど\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0204104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「……まあ、正直、隊長氏が相手ならなんでもいいんでござるが…………って\n、ああ、もう、ござる語、面倒くさい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0204105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「さて、と……いつでもどうぞ。坊や、わたし……もうすっかり準備オッケー\nよ。見ればわかるでしょう？　ふふふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0204106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「ああ……見られて興奮する……はぁ、身体が熱い……アソコが溶けてしまい\nそう……ふふふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0204107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「んんっ、はぁ……あっ、あぁぁぁ……アソコが、開いちゃうぅ……！　うく\nぅ……あはぁ……ひうぅぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0204108" ]},
		{"command":[ "SETIMAGE", "0", "still_00015202_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「ん、くぅ……はぁ、あはぁぁぁ……先っちょが、ん、くぅ……隙間の中に、\n割り込んでくる……はぁ、はぁ……ひぐぅぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0204109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、ひゃひいぃ！？　きゃうぅぅぅぅぅ……っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0204110" ]},
		{"command":[ "SETIMAGE", "0", "still_00015202_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「はっ……はぁ…………は、入っちゃったぁ？　全部……？　そ、そう……ま\nだ、先っちょが入っただけ……なのね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0204111" ]},
		{"command":[ "SETIMAGE", "0", "still_00015202_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「ふふ、大丈夫よ……そこまで痛くはないから……。ちょっとビックリしちゃ\nったけど……ふふふ……はふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0204112" ]},
		{"command":[ "SETIMAGE", "0", "still_00015202_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「けど、ここからがもっと痛くなるのよね？　ええ、心配しないで……ちゃん\nと覚悟してるから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0204113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「んっ！　くぅ……うぐぅ！　はぁ……あぁぁぁ……っ！　んんんんっ！　は\nぁ……入って、くるぅ……あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0204114" ]},
		{"command":[ "SETIMAGE", "0", "still_00015202_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「中が、こじ開けられてるぅ……ぐぅ、ひぅぅ……はぁ、はぁ……アソコが、\n裂けちゃいそう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0204115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「ん……んん、あうぅ……中から、メリメリ音が聞こえてくる……これが、処\n女膜……なの……？　はー……ふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0204116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「くぅぅ！　あふぅ……はぁ、あっ……ぁぁぁあああ！！？　はぁ、はぁ……\nい、今、中でズルッと、薄皮がめくれるような……はぁ、ふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0204117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「ふう……少し痛い、かも……でも、ん、んん、大丈夫よ……動いてくれてい\nいのよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0204118" ]},
		{"command":[ "SETIMAGE", "0", "still_00015202_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「んぅっ……んんん、はぁ……ああぁ……はー…………中で、動いてる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0204119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「う、うん……痛くはない、かな……ううん、やっぱりちょっと痛い……でも\n、平気よ……わたし、痛いの、嫌いじゃないし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0204120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「そう、そのまま……はぁ、はぁ……あ、はぁ……入って、くる……ん、ああ\nあん！　お腹の隙間が、押し広げられてる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0204121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「んくぅ、あふぅ……はぁ、あはぁ……アソコが、敏感になってる……オチン\nポの形が、クッキリと伝わってくる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0204122" ]},
		{"command":[ "SETIMAGE", "0", "still_00015202_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「先っちょが丸く膨らんで……はぁ、ふぅ……雁首のくぼみがあって……あ、\nああ……アソコの粘膜に絡みついてくる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0204123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「はぁ……血管がプクプク浮かび上がってる……この中に、血が流れているの\nね……はぁ……ふぅ……ふふ、わたし今、坊やとつながってるのね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0204124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……身体だけじゃなく、心もつながっているみたい……ん、は\nぁ……あああん……すごぉい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0204125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「あ、はぁ……はぁあん……すごぉい……出たり入ったりしてる……太くて、\n硬いものが、ゴリゴリ、中に擦れちゃう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0204126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「んくぅ……あはぁ……あぁ、ああ、奥が、押しこまれ……ゴリゴリと擦り付\nけられて……あ、ああ、はぁ……ふぐぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0204127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「もう、全然痛くない……はぁ、はぁ……むしろ気持ちいいよぉ……こ、この\nまま、お願い……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0204128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「あっ……ああぁん……っ！　あはぁ……きゃうぅぅ……すごぉい……気持ち\nいいのが、こんなにぃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0204129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「うん……激しいのに、優しい……坊やって、上手なのね……ふふ、見直しち\nゃったぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0204130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「あああ……はぁ、んん、はぁぁぁぁん……アソコの奥が、ジンジンしてきち\nゃったぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0204131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「え？　あなたも……？　そう……ふふ、ん、はぁ……いいのよ……もっと激\nしくしてくれても……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0204132" ]},
		{"command":[ "SETIMAGE", "0", "still_00015202_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「んくぅ！　あはぁ……はぁ、あぁぁぁああん……！　だ、大丈夫、だから…\n…このまま、動いてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_0204133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「ひやぁ！　あぁ！　中で、ぶつかってくる……！　子宮が、持ち上がっちゃ\nうぅ！　はぁ……はぁ……んんん……」", "NORMAL" ]},
