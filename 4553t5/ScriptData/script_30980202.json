{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009802_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「あ、あのー隊長？　日焼け止めローションを塗ってもらうだけのはずが、ど\nうしてこんな体勢になっちゃうのかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0204101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「興奮したのは私だろって？　そ、それは、隊長のせいでしょ！　分かってる\nんだからね、この日焼け止めローション、変な成分はいってるでしょ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0204102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「そ、そりゃあ、このまま性交渉に入るとどんなに気持ちいいか……って興味\nはあるし、私の身体がどうなっちゃうか、観察したい気持ちもあるけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0204103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「なにもこんな青空の下ですることないでしょ！　だ、誰かに見られたらどう\nするの！？　は、恥ずかしいんだってば！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0204104" ]},
		{"command":[ "SETIMAGE", "0", "still_00009802_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「なんだい、そのいやらしい手の動き……ま、まさか……ああぁんっ！？いき\nなりおっぱいや乳首を摘ままないでっ！今は駄目なんだって、あぁんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0204105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「あっ、ふあぁ、んあぁんんっ！　身体が敏感すぎて……私の身体なのに、こ\nんな反応見た事ないよぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0204106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「ラビットパワーで乗り切れって？　この反応の観察も科学の為？　無茶苦茶\nだよ！　それっぽいことを言えば、私が納得すると思ってるの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0204107" ]},
		{"command":[ "SETIMAGE", "0", "still_00009802_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「だったらホントに観察はしなくていいのかって……？　うぅ、確かに改めて\n聞かれると、こんなチャンスを逃すのは惜しい、かも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0204108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「んああぁん！　隊長の先っぽが、割れ目の入り口に当たってっ……んんっ！\n　すりすりされると、声、止められなくてっ、ああぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0204109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「わ、分かった、分かったよぉ隊長。こうなったら私の身体がどこまで感じる\nか、とことんまで観察するから……！　だから……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0204110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「も、もう我慢できないのっ、入れてよ隊長っ！　そのガチガチなペニス、私\nの中に……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0204111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「んひゃぁあぁぁあぁんっ！？　あっ、ふあぁあんんっ！！　い、イッちゃっ\nた、隊長の入れただけで、軽く絶頂しちゃった、よぉ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0204112" ]},
		{"command":[ "SETIMAGE", "0", "still_00009802_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「だ、大丈夫、止めなくていいよ。苦しかったりはしないから……だからこの\nまま、ね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0204113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「ああっ、んんふぅぅ……！　ゆっくり動きながら、中の壁を削って……ぐり\nぐりって奥まで来てっ、あぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0204114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「なんか、一人でするよりずっと気持ちいい……！　もしかしてこのローショ\nンのせい？　それとも、隊長にされてるから……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0204115" ]},
		{"command":[ "SETIMAGE", "0", "still_00009802_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「お腹の奥から温かくて幸せな何かが広がって、あっ、ふあぁんんっ！　一人\nじゃ絶対に感じられない快感が……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0204116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「隊長……もっと早くしてくれていいよ？　この先にどんな快感がまっている\nのか、私に観察させてっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0204117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「あ、あっ、あああぁんっ！　はぁあああ……あっ！　ふあぁんっ！　すごい\n、ホント少し早くなっただけなのに、快感、やばっ、んひゃぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0204118" ]},
		{"command":[ "SETIMAGE", "0", "still_00009802_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「体勢のせいか、少し腰を突き上げられるだけで一番奥まで届いてくる、んな\nぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0204119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「奥の奥、私の一番大事なトコロぉ、あひっ、んあぁんんっ！　子宮がコンコ\nンってされるたび、頭がまっしろになって、あひゃぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0204120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「こ、これイッてるっ！　私、小さく何回もイッてるんだっ！　こんな連続で\n絶頂出来るなんて、知らなかったっ！　あっ、んあぁんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0204121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「愛液の量もすごいことになっちゃってる。結合部がドロドロに蕩けちゃって\nるじゃないかってぐらい気持ちいい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0204122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「んんんっ……！　隊長の副隊長も、私のアソコの中でどんどん膨張してきて\nるのが分かるよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0204123" ]},
		{"command":[ "SETIMAGE", "0", "still_00009802_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「気持ちいいんだよね？　私の中で喜んでくれてるんだよね？　うん、言葉に\nしなくても伝わってるよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0204124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「お願い、隊長。最初みたいにおっぱいも触って！　このまま乳首を苛められ\nたら、私の身体がどうなっちゃうか、観察させてよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0204125" ]},
		{"command":[ "SETIMAGE", "0", "still_00009802_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「あひぃいぃんっ！　あっ、あぁんんっ♪　　オー、イェッ！　イェッ！　い\nいよ隊長、もっときて、もっとぉ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0204126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「これが未知の快感！　もっとおっぱい乱暴に揉んで、乳首をひっぱって！　\n隊長の好きなようにこねくり回してくれていいから、あぁんんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0204127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「周りの誰かに声を聞かれるかもしれないって……？　そ、それはそうだけど\n、今更抑えられるはずないでしょ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0204128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「それに、他人に見られながらする性交渉に関しての感情を観察することにす\nるからね！　だから遠慮せず、もっと激しく責めてよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0204129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「んひひぃんっ！　きたっ、また奥まで亀頭がグリッて食い込んできたぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0204130" ]},
		{"command":[ "SETIMAGE", "0", "still_00009802_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「こ、これっ、ふあぁんっ！　愛液が増えてるから、動きも早くなってるんだ\n。ズンズンってすごい勢いで突き上げられてるんだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0204131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「お腹の裏側、おへその下辺りぐりぐりって、あひっ、んおぉんんっ！　奥も\nいいけど、浅いトコロを先っぽで削られるのもいい！　気持ち良い！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0204132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「大きいのくるっ、今までとは比べ物にならないほど大きい絶頂の波がきそう\nでっ……あっ、んあぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0204133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「た、隊長もだよね！　もうイキそうなんだよね！　お腹の中で隊長の副隊長\nがビクビクって暴れ回ってるから、すぐにわかるよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0204134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「いいよ、私の中にたっぷり精液を流し込んで！　中に出していいから……う\nんう、中に出してほしいの！　一番奥に注ぎ込んで！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0204135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「あっ、ふあぁんっ、あひっ、んひゃぁんっ！　だ、だめ、ホントにもう限界\n！　奥からくる、熱いの奥から溢れてきてっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0204136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009802_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「んひぃいぃぃぃんっ！！　あひっ、おっ、んおぉぉおんっ！　にゃにこれ、\n膣内出し気持ち良過ぎて、にゃにか出るのぉ！　んひぃんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0204137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「し、知ってるこれ、潮を吹いてるんだ！　オーガズムの瞬間に内側から尿道\nを圧迫されて、潮吹いちゃったんだ！　あっ、ふあぁんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0204138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「あひっ、あっ、ふあぁんんっ！　射精のドクドクする感覚が気持ち良過ぎて\n、イクの止まらない！　もっとイきたいのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0204139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「すごい、こんな快感知らないぃ……あひっ、んひぃんっ……青空の下で開放\n的にセックスするのがこんなに気持ちいいなんて、新発見だよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0204140" ]},
		{"command":[ "SETIMAGE", "0", "still_00009802_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……ね、ねぇ隊長？　もう出ない、精液全部出し切っちゃったの\nかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0204201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「そんなことないよね、隊長の副隊長はまだこんなに元気なままだもん。まだ\nまだ私の知らない快感を観察させてくれるよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0204202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「え？　もちろんだろって？　むしろ本番はここから？　……自分で振ってお\nいてなんだけど、回復早すぎない！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0204203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「ふふっ、もちろん大丈夫に決まってるでしょ。今度は私からも動いて、隊長\nのペニスの動きをアソコで観察しちゃうんだから、ねっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0204204" ]},
		{"command":[ "SETIMAGE", "0", "still_00009802_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「んんんんっ！　やっぱり根元まで入ると深い……あっ、んんふぅん……でも\nその分、副隊長の形をぴったりと感じられて……あひぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0204205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「あひっ、あっ、ふあぁんんっ！　二回目だからって、最初からそんなに激し\nくっ、あぁんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0204206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「いいよ、今度は負けないって決めたんだから！　私だってその気になれば、\n速く動けるし……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0204207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「ふあぁ、んんんっ！　上下に動くだけじゃなくて、左右に腰をぐりぐりって\nして……ふふ、これ結構効いてるでしょ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0204208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「言葉にしなくても反応で分かるよ。左右にペニスを振り回すたび、口元がヒ\nクヒクして小さいけど喘ぎ声漏れてるの、気付いてる？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0204209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「なるほどね、これが隊長が本気で感じてる時の顔。中々観察し甲斐があるよ\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0204210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「な、なんだい隊長。そのよこしまな目は……弱点を把握してるのは俺も同じ\n？　あ！　ち、ちょっとまっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0204211" ]},
		{"command":[ "SETIMAGE", "0", "still_00009802_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「んひあぁぃぃんっ！？　しょ、しょれ、子宮を一気に突き上げられたら、だ\nめにゃんらってっ！　あひっ、んひゃぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0204212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「ち、乳首もまた、ひっぱられてっ、あっ、あっ、んひぃんんっ！　おっぱい\n乱暴に揉み込まないで！　あっ、ふあぁんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0204213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「ま、負けない、私だって負けないんだからっ！　ら、ラビットパワー全開で\nこうして、こうだっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0204214" ]},
		{"command":[ "SETIMAGE", "0", "still_00009802_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「あひっ、あっ、ふあぁんんっ！　腰が引き抜かれていくたび、先っぽの膨れ\nてるトコロぉ……か、カリが中をゴリゴリって削って、あひぃんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0204215" ]},
		{"command":[ "SETIMAGE", "0", "still_00009802_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「ふあぁぁんんっ！　隊長のペニスが、また中で一回り大きくなってるのが分\nかるよ！　ドクドクって脈打ってるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0204216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「いいよ、突いて、このままパンパンって下品な音いっぱい鳴らして、奥を突\nきまくって！　あひっ、あぁんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0204217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「も、もうイク、何回目か分からないけどまたイクのっ！　隊長もだよね？　\nさっきみたいにいっぱい精液出すんだよね！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0204218" ]},
		{"command":[ "SETIMAGE", "0", "still_00009802_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「見てるから、最後まで観察してるから、また一緒にイこうっ！　私の知らな\nい快感の先を教えてっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0204219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「あひっ、あ、ふあぁんんっ！　イク、イクイクっ、もうイクの！　おっきな\n波が来て、あひっ、あっ、ふあぁんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0204220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「んひっぃいぃいぃんんっ！　しゅ、しゅごい、また潮が溢れてっ、びゅーび\nゅーって、あひっ、あっ、ふあぁんんっ！！」　", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0204301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009802_02_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「隊長の精液も中にたっぷり注ぎこまれてる！　私の中の奥の奥までドロドロ\nに満たしてる！　き、気持ち良過ぎて、あっ、ふあぁんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0204302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「止まらない、絶頂の波が止まらないのっ！　ふあぁんんっ！　こんなのまと\nもに観察できないっ、あひっ、んひゃぁんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0204303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「あ、あ、あああぁぁあぁ……はぁ、はぁ……んふ……あぁ……も、もう、だ\nめ……全身に力、入らなくて……んぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0204304" ]},
		{"command":[ "SETIMAGE", "0", "still_00009802_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「隊長……いくらなんでもこのローション、変な成分強すぎじゃない？　何も\n考えられないほど頭真っ白になる経験とか、初めてなんだけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0204305" ]},
		{"command":[ "SETIMAGE", "0", "still_00009802_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「あくまでちょっとそれっぽい気分になるだけ？　じゃあ、あの快感の強さは\nいったい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0204306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「ビーチでセックスする開放感から興奮しただけ……？　そ、そんなはずない\n！　……と、思いたいけど、心理的要因が興奮に繋がる事もあるわけだし…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0204307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「え？　嘘？　私、もしかしてそっちの気があるの？　ろ、露出？　人に見ら\nれるのが好き、とか？　……いやいや、まさか……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0204308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「で、でも……調べず、観察せずにそう決めちゃうのは……よくないよね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0204309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「ねぇ、隊長……？　今度時間があればでいいからさ、私の新しい実験、突き\n合ってくれたら、嬉しいな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0204310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「ふあぁんんっ！　は、激し過ぎてペニスが抜けて……んんんっ！　すごい勢\nいで精液が飛び散ってるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0204401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009802_02_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「こ、これ、全身が白濁液でドロドロになって……あっ、ふあぁんんっ！　精\n液のシャワー、気持ちいいい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0204402" ]},
		{"command":[ "SETIMAGE", "0", "still_00009802_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「あっ、ふあぁ、んんんっ……！　膣内に出された訳じゃないのに、イクの止\nまらない！　かけられたところが熱くなって、ああぁんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0204403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「知らなかった……快感に火照った身体に精液をぶっかけられるのって、こん\nなに気持ちいいものなんだ……んんんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0204404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……んっ……もう、出ないかな？　隊長、全部出し切った？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0204405" ]},
		{"command":[ "SETIMAGE", "0", "still_00009802_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「んんっ……それにしても、汗とローションと精液がぐちょぐちょに混ざり合\nって、私の身体、大変な事になっちゃったね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0204406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「すんすん……ふふっ、匂いも凄い。これはこれで癖になるなるかも……すん\nすん、すんすん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0204407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「どうしての隊長？　顔赤いよ？　……え？　匂いを嗅いでる私の姿に興奮し\nたって？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0204408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「ね、ねぇ……どうしてあれだけ出したのに、また固くなってるのさ……ほん\nと。隊長の性欲は無限大だね……性癖もよく分からないし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0204409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「ふふふっ、やっぱりとっても観察し甲斐がある人だよね、隊長って♪　これ\nからもいっぱい観察させてもらうから、よろしくね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0204410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
