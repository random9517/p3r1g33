{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「お呼びになりましたか。はい、時間通りに参上しましたよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2003101" ]},
		{"command":[ "SETCHARA", "0", "char_00000520_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「それでご用件は……と聞くところですが、まぁ、この部屋に呼び出している\n時点で、もうどういうことかは大体理解しています」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2003102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「ええ……要するに、ウチのこの姿に欲情してしまったのでしょう？　ふん…\n…別に驚くことでもなんでもありません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2003103" ]},
		{"command":[ "SETCHARA", "0", "char_00000520_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「なにせこの数日、至る所でとある人物からの視線を嫌という程感じておりま\nしたから。全く……バレていないと思ったんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2003104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「ふふ……しょうがないご主人様ですね。ですが、ウチはビキニメイドです。\nご主人様の、その望み……しっかり応えてみせましょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2003105" ]},
		{"command":[ "SETCHARA", "0", "char_00000520_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「という訳で、邪魔なものは取ってしまいましょう……あぁ、案の定分かりや\nすく大きくさせてますね……んっしょ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2003106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000520_01_02" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「それで……このオチンポはどういうご奉仕をお望みですか？　舐めて欲しい\n？　おっぱいで擦って欲しい？　それとも両方ともですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2003107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「ふん……即答で両方になりましたね。全く……ウチのおっぱいは、余りオチ\nンポを包むには厳しいサイズなんですが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2003108" ]},
		{"command":[ "SETIMAGE", "0", "still_00000520_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「ですが、ご主人様は、そういう小さいおっぱいで欲情する変態ですし……こ\nれを放っておくと、どんな犯罪を犯すかも分かりませんからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2003109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「ウチが一生面倒を見てあげないとダメでしょうね。この小ぶりなおっぱいに\n存分に甘えて下さいね……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2003110" ]},
		{"command":[ "SETIMAGE", "0", "still_00000520_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「んふっ、少し骨ばっているかも知れませんが……一応は柔らかさもあるつも\nりです……いかがですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2003111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「……めちゃくちゃ興奮しているじゃないですか……。そんなにオチンポを震\nわせて……ウチも少し引くレベルですよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2003112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「全く……んっ、しょうがないご主人様です……んっ、ふっ、だから、もっと\nいっぱい押し付けてあげますね……は、んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2003113" ]},
		{"command":[ "SETIMAGE", "0", "still_00000520_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「亀頭も、もっとして欲しいって感じになっていますね……いかがですか？　\nおしゃぶりして欲しいっておねだりできますか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2003114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「ふふん……多少葛藤するところも見たかったですが、ちゃんとおねだりしま\nしたね……じゃあ、私のお口でたっぷりと甘えさせてあげます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2003115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「はぷ……んんっ、ちゅぽっ……んふぅ……相変わらず……んぽっ、大きいオ\nチンポれふね……れろ、口で持て余ひひゃいまふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2003116" ]},
		{"command":[ "SETIMAGE", "0", "still_00000520_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「れろ、えろ……んっ、最初は、舌先で……優しく撫でてあげるところかられ\nふね……ちゅぷっ、りゅぷんっ……えろっ、れろぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2003117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「んふ……くすぐったいですか？　最初はそうかも知れませんが……少しだけ\n我慢してくらひゃい……ちゅぽ、んちゅぷぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2003118" ]},
		{"command":[ "SETIMAGE", "0", "still_00000520_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「おっぱいと……一緒に動かすことで……んふっ、くすぐったいだけじゃなく\nなりますからね……れろ、ぴちゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2003119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「ちゅぷっ、あ……んふ……気に入ったところ……見つかりましたね……れろ\n、ちゅぱっ……ふふ……ここれふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2003120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「ふぉら……当たりれひょう……この反応……ちゅぷっ、ご奉仕のしがいがあ\nりまひゅね……ちゅぽっ、ぴちゅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2003121" ]},
		{"command":[ "SETIMAGE", "0", "still_00000520_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「んちゅるっ……ぴちゃ……たっぷりと唾液をまぶしたところで……んふっ、\nその雫を……おっぱいにも少し垂らして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2003122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ、これで……もうちょっと滑りやすくなったと思います……はふ\nっ、いかがですか……よく滑る感じ……しますか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2003123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「はい……ウチも、オチンポの感触をはっきり感じるようになってます……あ\nぁ……乳首がムズムズしてきました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2003124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「えっ……乳首で、オチンポをスリスリして欲しい……相変わらず、欲望に忠\n実すぎますね……まぁ、いいでしょう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2003125" ]},
		{"command":[ "SETIMAGE", "0", "still_00000520_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「んっ、こんな感じでいかがですか……？　はぁ……んっ、亀頭の……付け根\nのところと……乳首の硬いところが、ツンって当たってます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2003126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「んんっ、ムズムズする感じ……んぅぅ……確かに、これは……気持ちいいか\nもしれません……はっ、んっ、あっ、んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2003127" ]},
		{"command":[ "SETIMAGE", "0", "still_00000520_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「これをしながら……んっ、れろ、ちゅぷっ……オチンポを咥えてご奉仕する\n……んんっ、忙しいれふね……でも、あっ、んふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2003128" ]},
		{"command":[ "SETIMAGE", "0", "still_00000520_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「んんっ……これは、ウチも気持ちよくて……あっ、一緒に気分が高まってい\nく感じがします……はぁっ、んふぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2003129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「ちゅぷっ、んちゅぅぅっ……それで、貴方の感想はどうなんですか？　チュ\nウチュウ吸われて……オチンポ気持ちいいんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2003130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「んちゅぅぅ……尿道口を吸われるのが堪らないですか……ふふっ、そんな可\n愛い呻き声を出されたら……もっとしてあげたくなりますね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2003131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「ちゅぷぅっ、んちゅっ、ちゅっ、んちゅぅぅぅっ、はぁん……もう、カウパ\nーが染み出して……少ししょっぱい味が広がってます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2003132" ]},
		{"command":[ "SETIMAGE", "0", "still_00000520_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……おっぱいの中の……オチンポの中心も、ビクンビクンってし\nて……そろそろ出ちゃいそうな感じですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2003133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「どうなんですか？　ウチのパイズリフェラで……オチンポ射精したいんでし\nょう？　りゅぷっ……ちゃんと言わなきゃお預けですよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2003134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「んふっ、出したいんですね……？　じゃあ……言えたご褒美に……全部飲ん\nであげます……じゅぷっ、りゅぷっ、んちゅぷっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2003135" ]},
		{"command":[ "SETIMAGE", "0", "still_00000520_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「このまま……ウチの……口の中にっ、ドピュドピュっ……せーえきっ、いっ\nぱいらひてくらひゃいっ……んじゅっ、ちゅぷぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2003136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「んんんんんんんっ……！　ふぶっ……んぐっ、こくっ、んくっ、こくんっ…\n…んくっ、んふぅぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2003137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000520_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「ぷぁっ……とびきり濃いのが……いっぱい出ましたね……じゅるっ……んち\nゅっ……あふっ、ザーメンの味……舌に残ります……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2003138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「れろっ、ちゅぱっ……口の周りが汚れちゃいました……れろ、ちゃんと全部\n舐め取らないと……りゅぷっ、ぷぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2003139" ]},
		{"command":[ "SETIMAGE", "0", "still_00000520_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「はふ……ふふ、ビキニメイドのご奉仕……楽しんで頂けたみたいで何よりで\nすね……満足しなかったとは言わせませんですよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2003140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「ということで、ウチのご奉仕はこれで完了……と言いたいところですが、ど\nうもこのオチンポはそれで納得したくないようですね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2003201" ]},
		{"command":[ "SETIMAGE", "0", "still_00000520_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「まるで物足りなかったと言わんばかりに勃起を震わせて……ふん、これはウ\nチに対する挑戦とみなしてよろしいですね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2003202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「ふふ……軽い冗談です。単に、ウチがまだこの精液の残っていそうなオチン\nポに興味津々と言うだけのこと……ちゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2003203" ]},
		{"command":[ "SETIMAGE", "0", "still_00000520_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「まだ出せそうなら……それを頂いてしまおうかと……あぁんむ……りゅぱっ\n、ちゅぶっ……んふっ、精液の味も残ってますしね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2003204" ]},
		{"command":[ "SETIMAGE", "0", "still_00000520_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「んふぅ……はぁぁ……さっきよりもオチンポのにおいがキツくなっています\n……んんっ、精液のにおいが凄すぎるせいですね……ちゅぱっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2003205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「はぁ……あぁ、このにおいを嗅げば嗅ぐほど……乳首がしこって来て……今\nでは、もう敏感になり過ぎて……んぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2003206" ]},
		{"command":[ "SETIMAGE", "0", "still_00000520_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「おっぱいを寄せて……んっ、オチンポに擦り寄せるだけで……はぁっ、あっ\n、ジンジンして……くぅっ、感じてしまいます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2003207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、エッチな顔をしてる……？　そんなの……お互い様です……\nオチンポをビクビク震わせながらよく言うですよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2003208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「それにぃ……ん、れろぉ……ウチのエッチな表情で……はぁ……んっ、また\n……興奮してるんでしょう……？　れろ、んりゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2003209" ]},
		{"command":[ "SETIMAGE", "0", "still_00000520_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「分かりやすいご主人様……バレバレなんですからぁ……んふっ、あっ、あぁ\nっ……いい、感じぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2003210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「れろ、んちゅぷっ……あむ……んんっ、でも、ウチも……同じです……はぁ\n……必死でおっぱいのお肉を集めて……オチンポに押し付けて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2003211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「太い幹の根元をコリコリしながらぁ……んっ、あっ……オチンポの熱をいっ\nぱい感じて……はぁん……お股がムズムズしますぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2003212" ]},
		{"command":[ "SETIMAGE", "0", "still_00000520_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「りゅぷっ、くぷっ、んちゅぷんっ……オチンポの味も……病みつきになって\n……口から、涎が溢れてぇ……ちゅぱっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2003213" ]},
		{"command":[ "SETIMAGE", "0", "still_00000520_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「れろ……んっ、あぁ……ちゅるっ、先走り……吸います……んふう……えろ\nぉ……ぺろぉ……れる……れろぉ、んりゅぷぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2003214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「ふふ……二回目のオチンポ射精が近づいて来ましたね……いいんれふよ……\n？　また、欲望に任せて出してしまうです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2003215" ]},
		{"command":[ "SETIMAGE", "0", "still_00000520_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「じゅぱっ、ほら……先端も出したい出したいって可愛く震えて……んりゅぷ\nっ、続けて私に飲ませますか？　それとも……顔やおっぱいに出しますか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2003216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「ウチはどちらでも構いません……ご主人様の欲望のままに……ひたすら、パ\nイズリフェラを……りゅぷっ、続けるだけですっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2003217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「はぁ……んんっ、でも……あっ、このエッチなにおいに……おっぱいが気持\nちよくて……ウチもこのままイキそうです……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2003218" ]},
		{"command":[ "SETIMAGE", "0", "still_00000520_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「はい、んっ、出していただくところで……一緒にイキたいですっ、だから…\n…ドピュって……いっぱい出して下さいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2003219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「メイドのご奉仕で……オチンポ気持ちよくなってっ……残ってるザーメンっ\n、全部っ、ピュッピュってして下さいっ、んちゅぷっ、りゅぷぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2003220" ]},
		{"command":[ "SETIMAGE", "0", "still_00000520_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「んふぅぅぅぅんっ……！　んぐっ、あっ、んんっ……お口に……まら……濃\nいのっ、れてっ、まひゅっ……んくっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2003301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000520_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「んぐっ、んぶっ……！　なんれふか……この勢い……あぷっ、口から溢れて\nぇ……まだ、どぷどぷ……れてまひゅぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2003302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「んぐっ……ぷぁっ、はぁ、はぁ……はふぁ……くぷんっ、ぷぁっ……んちゅ\nるっ、ちゅるぅぅ……ふはっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2003303" ]},
		{"command":[ "SETIMAGE", "0", "still_00000520_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……何とか飲むことができました……お腹いっぱいになりそうで\nす……口の中にまだ味が残ってます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2003304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「れろ……ぴちゃ……んっふ……少しじっとしていて下さい……このままお掃\n除までしてしまいますから……れろ……ちゅぱ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2003305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「それにしても、すごいオチンポです……まだ脈動して……硬いままで……奥\nに精液を残してますか……？　ちゅるるるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2003306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「んふっ……ちゅぱっ、とりあえず、今回はこれでよしとしましょう。楽しん\nで頂けましたか……？　それは何よりです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2003307" ]},
		{"command":[ "SETIMAGE", "0", "still_00000520_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「まあ、はだけたビキニにこれだけ興奮されると、ウチとしても多少日々の心\n配をしないこともないですが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2003308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「もし、またムラムラするようなことがあれば、早いうちに言って下さいね。\nウチも暇じゃありません。急に対応できるとは限りませんから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2003309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「ええ、最高のご奉仕をするには何事も準備が肝心です。今から次を予約……\n？　ふふ……それがいいかも知れませんね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2003310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「ふぁぷっ……！　はぁんっ、オチンポ引いて……あっ、掛けられるんですね\n……？　あぷっ、はい……どうぞっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2003401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000520_01_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「んぁぷっ……はぁぁ……オスの強烈なにおいが染み付いていきますぅ……は\nぁぁ、ダメ……イクっ……ウチもイって……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2003402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「はぷっ、んぁぁ……お腹にも、おっぱいにも精液いっぱい出されてぇ……あ\nぁ……マーキングされるの気持ちいいです……んふぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2003403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「あぁ……んっ、射精……止まりました……でも、まだオチンポの先にお汁が\n浮いてます……れろ、ちゅぷ……ぴちゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2003404" ]},
		{"command":[ "SETIMAGE", "0", "still_00000520_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「ちゃんと綺麗にするところまでがご奉仕ですから……あぁ……んっ、オチン\nポを頬に押し付けて……拭って下さい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2003405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「ウチの肌で全部拭き取りますからぁ……残さず出し切って……はぁ……んっ\n、ちゅぷっ、んふぅ……綺麗にしますぅ……ぴちゃ、れろっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2003406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「んは……これでいいでしょう。オチンポ……いかがでしたか？　ウチのご奉\n仕でご満足頂けましたか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2003407" ]},
		{"command":[ "SETIMAGE", "0", "still_00000520_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「ふふん……当然です。あれだけドプドプだしておいて、大したことなかった\nなんて言われたら、そのままオチンポに噛み付いてやるとこでした」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2003408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「大丈夫ですよ、こんな上等なオチンポ……基本的には大切にするつもりです\nから……れろ、ちゅぷ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2003409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「また催したらちゃんと言って下さいね。しっかりと準備を整えて、楽しんで\n頂けるご奉仕をしますから……」", "NORMAL" ]},
