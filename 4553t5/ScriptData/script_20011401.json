{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0101" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_011" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「ぴっ……ぴっ……ぴっ……ぽ～ん！　おっしゃー！　定時だ！　交代の時間\nだ！　クリスマスイブだぁ～～～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010021460001" ]},
	{"command":[ "SETCHARA", "0", "char_00000401_01", "8", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPTEXT", "TRUE" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「なにをはしゃいでるんですか。今日がクリスマスイブなのは、朝からわかっ\nていることでしょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010021460001" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「はぁ！？　なに言ってんだ！　私が言いたいのはそういうことじゃない！　\nパーティーだよ、パーティー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010021460002" ]},
	{"command":[ "SETCHARA", "0", "char_00000401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「もちろんわかっています。ですが、いい年してそんなにはしゃぐようなこと\nですか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010021460002" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「いいじゃんいいじゃん！　今日は事件もなかったし、みんなで思いっきり騒\nごうよ！　でっかいケーキもあるっていうし！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010021460001" ]},
	{"command":[ "SETCHARA", "0", "char_00001201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「そうそう。たまには息抜きも必要よ。今夜は、仕事を忘れて楽しみましょ？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010021460001" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「いえ、ウチだって、たまの息抜きはありがたいですし、楽しみにしていない\nわけではないのですが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010021460003" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「まあこの子がこうやってセレーナに絡むのは、テンションが上がってるしる\nしさ。大目に見てやりなよ、はははっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010021460001" ]},
	{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「は～い、皆さぁ～ん？　正義（まさよし）のほむらちゃんからお電話よ～？\n　会場の準備、できたからいつでも来い、ですって～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010021460001" ]},
	{"command":[ "SETCHARA", "0", "char_00000601_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「それでは移動するか！　……おい下僕？　なにをしている。行くぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010021460001" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「え？　ああ、俺ですか？　俺はちょっと……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「どうしたの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010021460001" ]},
	{"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ちょっと、その……急ぎの仕事が残っててさ。それを片付けてから行くわ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「なんと！？　ご主人にしてはめずらしく勤勉ですな。こんな時期に急ぎの仕\n事とは、いったいなんですかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021460001" ]},
	{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うるせえ！　よけいなこと言うな！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「そんなの、明日でいい。今日はクリスマスイブ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010021460002" ]},
	{"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そうだぞ下僕。今日はせっかく、みんなが楽しみにしていたパーティーなん\nだぞ。それなのに――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010021460002" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「い、いや、べつに貴様など、いてもいなくてもかまわないが……ただその、\n欠席者が出てしまうと――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010021460003" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ははは、やだなあ、姫様！　欠席するとは言ってませんって。こいつを片付\nけたら、大急ぎで正義（まさよし）に行きますって」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「私も手伝いましょうか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010021460002" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「私も！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010021460003" ]},
	{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああ！　いいからいいから！　おまえらは先に行っててくれ。そんなにたい\nした量でもないから！　な！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「そう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010021460004" ]},
	{"command":[ "SETCHARA", "0", "char_00000201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「わかりました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010021460003" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「貴様がそういうのなら、無理に、とは言えんが……。だが、できるだけ早く\n来るんだぞ！　いいな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010021460004" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はいはい、大丈夫ですよ。それじゃみんな、またあとでなー」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "と、手を振る俺を残して、みんなは部屋を出ていく。やれやれ、どうにかごま\nかせたか。", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "あいつらとクリスマスパーティーとか、どう考えても、ろくな目にあわない。\nそのことはもう、わかりきってるからな。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "行ったところでどうせ、説教されたりイジられたりおもちゃにされたり……ス\nトレスのはけ口にされるに決まってるんだ！", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0116" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_016" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「どうしておまえはいつもいつも、私の足を引っ張るんだこのボケナスビ！　\n私が貴様のせいで、どれだけ苦労しているかわかってるのか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010021460005" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ほら、カツマ！　飲みな！　いいから飲めってんだよ！　あぁん！？　なん\nだい、あたしの酒が飲めないってのかい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010021460002" ]},
	{"command":[ "SETCHARA", "0", "char_00000301_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「わはははははは！　おーいカツマ！　メリクリパーンチ！　あはははははは\n！　楽しいなあ！　メリクリキーック！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010021460003" ]},
	{"command":[ "SETCHARA", "0", "char_00000401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「カツマ、食べて。せっかくなんだから、お腹いっぱい食べなきゃダメ。いい\nから口開けて。ほら、もっと、もっと……まだ入る！　もっと！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010021460005" ]},
	{"command":[ "SETCHARA", "0", "char_00000201_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0101" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_011" ]},
		{"command":[ "SETTEXT", "うううううううっ！　ぜったい、こんな風になるに決まってる！　嫌だ！　さ\nすがにもう、こんな扱いはごめんだっ！", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "と、いうわけでクリスマスパーティーは、仕事を口実にパスさせてもらう。行\nくとしても、最後の最後にちょっとだけ顔出して……。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ふぁあああ……あれ……？　なんか眠くなってきたな。まだこんな時間だって\nのに。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "はぁああああ……疲れてんのかな……本格的に……眠くなって……きて――", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}