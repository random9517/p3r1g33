{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「おいっ！　おい、おまえっ！　あたいのオヤツを知らないか？　さっき食べ\nようと思ったらなくなっていたのだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0103101" ]},
		{"command":[ "SETCHARA", "0", "char_00020801_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「ずっとここにいたから知らないぃ？　そんなわけない！　あたいがオヤツを\nなくすなんてずぇーったいにありえない！　だからおまえのせいだ絶対！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0103102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「自分で食べたんだろぉお？　フンッ、だぁ～か～ら～！　あたいはそんな失\n敗なんかしないってーの！　グズなおまえじゃないんだから……って」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0103103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「う！？　にゃ、にゃにをするう！？　はぁ？　ここに座れぇ？　おまえ、あ\nたいを誰だと思ってエラソーに命令してるんだっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0103104" ]},
		{"command":[ "SETCHARA", "0", "char_00020801_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「あたいは宇宙海賊団滅棲俄鬼（メスガキ）の超！　特攻隊長だぞ！　本来な\nらおまえなんかと１対１で喋ることなんかないくらいエラーイんだっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0103105" ]},
		{"command":[ "SETCHARA", "0", "char_00020801_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「ふっふーん♪　恐れおののいたならはーやーくあたいのオヤツを返せ！　食\nべちゃったのなら買って返せ！　２倍にして返せ！　この愚民！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0103106" ]},
		{"command":[ "SETCHARA", "0", "char_00020801_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「はぅおっ！？　へ？　えっ？　え、え？　なんだ、いきなりチンポなんか出\nして……そんなことであたいがビビるわけ……。うきゃぁっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0103107" ]},
		{"command":[ "SETCHARA", "0", "char_00020801_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「んぁぶううっ！？　んぶっ、ぷぅっ、んぷぅううっ！？　な、なにやっれん\nら！　口の中にチンポ入れるなっ！　バ、バ、バカかおまえぇええ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0103108" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00020801_01_04" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「こらぁっ！　頭抑えるな……！　んむっ！？　あっぷっ！　んぷっ……！　\nぐちゅっ！　ぐっちゅっぐちゅっ！　んええええっ……ぐぷぷっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「んぢゅぷっ！　んえっ……！　じゅっぷっ、ぷぇえっ……！？　ぐちゅっ、\nぐっちゅっ……！　んぉっ……！？　おっ、ぉっ……ぐぷぷぷっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「おいぃい……！　一旦っ、一旦チンポを口から抜けえぇえ……！　あぷぷっ\n！？　んぐじゅっ、ぐっちゅっ、これじゃ何も話しぇにゃいぃいい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0103111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「けほっ、けほけほっ！　よ、よし……いいぞ、やっとわかったか……！　も\nう二度とあたいの口にチンポを突っ込むなよ！　許さないからなっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0103112" ]},
		{"command":[ "SETIMAGE", "0", "still_00020801_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「……なんだぁ？　そのナマイキな顔はぁ……！　ちょーっとチンポを口に突\nっ込んだからって、あたいがおとなしくなるわけないだろっ、おバカ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「はー、ひどいめにあった……。もうオヤツのことなんかどうでもいい！　お\nまえとは絶交だ、このチンポマン！　二度と一緒に遊んでやらな……うう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0103114" ]},
		{"command":[ "SETIMAGE", "0", "still_00020801_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「んんっぷ……！？　な、なにをひゅるぅううう……！　も、もうチンポっ…\n…ひんぽを口に入れるにゃと言ったりゃろ！　んぷっ、んっんっんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0103115" ]},
		{"command":[ "SETIMAGE", "0", "still_00020801_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「んぷ！　あ、あたいが悪いメスガキだったかりゃぁ……？　ぷぅっ、し、知\nるかぁ……！　だからってチンポ入れていいと思っれんのかぁあああ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「そんなにょ、誰がつくった法律ら……！　あたいは絶対に従わにゃひ……！\n　っむぅううっ！　奥にっ、奥につっこむな、く、くるひ……うぐぅうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「んぁふぅっ！？　んぶぶぶっ……！　こ、こりゃあっ！　反対！　チンポに\nよる説得なんか禁止だっ……あうっ、喉、喉にまでねじこむとかっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「おまえ悪魔かぁっ……！　あぷぁっ、あぶっ！　んぶぶっ……じゅぷっ！　\nタ、タンマっ！　一旦休憩っ……きゅうけ……んぷぷぷっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0103119" ]},
		{"command":[ "SETIMAGE", "0", "still_00020801_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「う、ぁ……！　はぁっ……はぁ、はぁはぁ……！　た、たすかった……！　\nおまえな！　あたいがちょっといい子にしてたら調子のんなよっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0103120" ]},
		{"command":[ "SETIMAGE", "0", "still_00020801_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「さっきはちょっと不意を突かれただけで！　あたいが本気を出したらおまえ\nみたいなよわよわやろーはワンパンで気絶しちゃんだからな……って」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「んむ～～～～！　んくぷっ！？　ま、またチンポぉおおお……！　やめっ…\n…んぷっ、お、おまえぇええ、ヘンタイかこのロリコンんんん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0103122" ]},
		{"command":[ "SETIMAGE", "0", "still_00020801_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「んちゅ、くっちゅっ、ちゅぷっ、くっちゅっ……！　お……っ、ぉっ、グニ\nュグニュチンポを前後しゃしぇるな……唾が、ちゅばが出る、やめれっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「おぷっ……！　んんぇっ……！　ぐっちゅっ、ぬっぷっ、ぬぷぷっ、ぶっち\nゅっ……！　お、おいぃい……人の話を聞けぇええ……！　ぐっちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「気に食わないとすぐチンポっ、入れるの、おまえの悪いクセらぞ……！　ん\nぁっ……デカくてくるひぃい、太い……ぃ、太すぎりゅ……ぐっちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「あう、あう、あう……！　チンポで舌の上、ズコズコされると……なんかヘ\nンな気分、になってくりゅ……。まじで、まじでやめれぇえ、抜けぇえ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「んぷぁあ、ぁっ……あっ、んぁ～っ、ああっ……！　ぐちゅっ、ぐっちゅっ\n！　ぷぴゅっ！　ううっ……や～め～れぇえええ～、はぅぁああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0103127" ]},
		{"command":[ "SETIMAGE", "0", "still_00020801_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「ベロっ……！　ベロの上がニュルニュルひゅるぅう……っ！　なんかっ、透\n明な汁がチンポから出てきて……口ん中がヌロヌロのベトベトで……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「な、な、なんらこれぇえ……！　んぶっ！　あたいの口はチンポ入れじゃな\nいろ……ッ！　んむっ！　動かひゅなっ……あっ、んむっ、んぷぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「おっぷっ、うぅっぷっ……ぢゅぽっ、ぢゅぷぷぷ……じゅっぷっ！　んぉぇ\nえっ……！　ズボズボ入ってくりゅっ……んぷぷっ！　ぐちゅっぷっぶちゅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0103130" ]},
		{"command":[ "SETIMAGE", "0", "still_00020801_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「んーーーーっ、んんっ、んぅううっぅうう～～～！　ぶちゅっ！　ぐちゅっ\n！　にゅぷぷっ、ぐちゅっ！　んぁあネトネトが止まらないぃい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「しかもそれを口の中でかき混じぇてくりゅ……！　ムカつくぅううう……！\n　んにゅぁああっ、うぷぁっぁっ……！　んん～～～っ、んぶぅうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「ってか、チンポ……！　チンポ、だんだん太くなってきてないか！？　お、\nおかひいぞ！　んぶっ……最初に１回おっきくなったのに、……あぶっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「あたいの口をヌプヌプしてたらまたデカくぅ……！　な、なんでだ！？　え\nっ？　射精しそうだから？　しゃせい？　しゃせいってなんだよっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「んっんっ！　せいし？　精子が出ること？　……んぷっ！　お、おいまさか\n、あたいの口の中に出すちゅもりか！？　ヒエエッ、や、やめろぉおっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0103135" ]},
		{"command":[ "SETIMAGE", "0", "still_00020801_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「やめ……やめっ！　んぷっ！　うぷっ、んんっ、うぁっあっぁっ！　早くこ\nするなっ！　精子準備するな！　本気で怒るぞ、やだ、無理無理無理ぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0103136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「ッんっ、ぷっ、んぐぅうううううう～～～～！？　んぅうううう！？　あぶ\nっ、あぷっ！　溺れっ……おぼれりゅ、せいし、精子多すぎぃいい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0103137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00020801_01_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「おぷっ……！　んっんっんっ……んぐぅううう……！　にゃ、何……？　飲\nめぇ？　こ、この気色悪いネバネバを……？　あっ、あうっ、ううう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「熱くて臭くて、口の中全部に張りついて、くるこのドロドロを飲めぇ……！\n？　ふ、ふじゃけるにゃあああ……誰が飲むかぁああ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「うぷっ……、ま、まだびゅるって出た……！　お、おまえぇえ……！　やり\n返し方がインケンだぞぉ……！　口っ、ゆすがせろ……って」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0103140" ]},
		{"command":[ "SETIMAGE", "0", "still_00020801_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「んぐ！　あたいの口を閉じさせるなぁああ……！　あうぁあああ……！　せ\nいし……精子、ベロにくっついて、うぁ、とれなくなる……んぁあ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0103201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「苦いぃいい……！　あ、あたい……苦いクスリも一人じゃ飲めない、のに、\nこんなわけわかんない汁ドピュドピュ出しやがってぇえええ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「怒ったぞ、おまえとはもう遊んでやんないかんな！　後で泣いたって謝った\nって無視してやるっ！　あたいは本気だぞ……って」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0103203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「うっにゅぅううっ！　またっ……またチンポデカくなって、口、口に入って\nきたぁあああ……！　おえっ、喉、喉の奥までもぐりこんでくりゅ、うう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0103204" ]},
		{"command":[ "SETIMAGE", "0", "still_00020801_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「んんっ……うぁっ、うっ！　うぶっ……！　せーし、口の中にぬりぬりする\nなぁあ……！　あっ……あっぁっ……んぁああ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「くちゅっ、じゅっぷっ！　じゅぷっ、にゅっぷっ！　ほんとに……ホントに\n苦いんだってばぁ……！　っぐちゅっ！　じゅっぷっ、ぷぢゅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「うぁ……うぁああ……！　あっ、そ、そうか……！　この苦いの、いつまで\nも口に残してるからマズいんだ、全部飲んじゃえば……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0103207" ]},
		{"command":[ "SETIMAGE", "0", "still_00020801_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「っぢゅるっ……じゅるっ、じゅるるるっ……ごくっ！　ん～～～～！　エグ\nい味がひゅるううう！　でも……でも負けるかぁ！　じゅるっ、じゅるるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「ごくっ……ごく、ごくっ……！　っぷ、これで……ちょっとはマシに……！\n　っん！？　チンポ、チンポぐりぐり突っ込んでくりゅなぁああ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「しぇ、しぇっかく精子飲んだのに……また透明なネバネバがぁああ……！　\nっはぷっ！？　んぐっ、んぶぅうっ、んぷ～っ！　く、くるひぃい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0103210" ]},
		{"command":[ "SETIMAGE", "0", "still_00020801_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「チンコ、チンコデカしゅぎる……っ！　んじゅぷっ！　ぐちゅっ……ぢゅる\nっ、ううう、飲んでも飲んでもネバネバが発生しゅるぅうう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「え？　あたいをわからせてることに興奮ひてる、らと！？　お、おまえ～っ\n！　わからされてなんかないっ、あたいは、あたいはぁあ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「あたいはチンポなんかに負けないぃ！　……んんうっ！　あたいはぁっ、\nあたいは最強の滅棲俄鬼特攻隊長なんらぞ……！　っはぅうっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「あぷっ！　んぷぅっ！　んじゅぷっ！　ぐちゅっ！　さ……さいきょ……最\n強ぅう……っ。あうっ！　んぐっ！　ぶちゅっ、ぐちゅっ、あぁうう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0103214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「お、おまえのチンポ……咥えさせられてりゅと、頭がボーッとして……なん\nか、お股が熱く……。はぁっ、はぁ、はぁ……うぁああ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0103215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「こ、こんな感覚知らないぞ……。あっ、ムズムズ……する、身体中がチンポ\nに支配されてるみたい、だ……あっ、うぁ、こ、怖いぃ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0103216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「はぷっ……ぐちゅっ！　ぐぷんっ、ぢゅるっ……んぁあ……れろっ、れろ…\n…あうぅ！　っぢゅっぽっじゅっぽっじゅっぽっぐちゅぷっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「た、頼むかりゃ激しく動かひゃないれくれええええ……！　あっぐっ、ぐち\nゅっ！　じゅぽっ！　じゅっぽっ、んぷぅっ……ぐちゅぷっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0103218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「な、なんでおまえは……あたいの口なんかでそんな嬉しそうにしてりゅんら\nぁ……。き、気持ちいいのか……？　んぷっ、ぐちゅっ、じゅっぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0103219" ]},
		{"command":[ "SETIMAGE", "0", "still_00020801_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「ど、どうせまたしゃせーするんなら……は、早くしろぉ……！　あたいだっ\nて無敵じゃない、いつまでも耐えていらんないんだからなぁあ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「んむぐぅうううっ！　うっぷっ、うう～～～！　うううう～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0103301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00020801_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「ごくっ……！　ううっ、勢いで飲んじゃったぁあ……！　ごくっ……ごくっ\n、ごくっ……！　苦い、ネトネトすりゅ……口ん中へばりつくぅう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「……ごぷっ！　ううう……！　おまえはどーして、何度も私の口を汚すんら\nぁ……！　し、しつけ？　しつけなんてあたいには必要ないぃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0103303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「っんん……！　んぁ……あぁ、あうっ、うう、う～～～……！　ドピュドピ\nュ、ドピュドピュ溢れてくるぅ……こんなに精子いらないぞぉ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0103304" ]},
		{"command":[ "SETIMAGE", "0", "still_00020801_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「んぁあ……♪　あたいの息まで精子臭く……っ。も、もういい！　これ以上\n出さなくていい……っ！　あぷっ、うっ、ううっ……んうーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0103305" ]},
		{"command":[ "SETIMAGE", "0", "still_00020801_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「はーっ……。はー、はぁああ……っ♪　おまえぇ……あたいが優しい特攻隊\n長で良かったな……、こんな、こんなひどいことをして……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0103306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「他のやつらだったらメタメタのギタギタにされてたぞ……。っんぷ……。あ\nぁ……。まだ精子の臭いがそこらじゅうにこびりついてるぅう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0103307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「……おまえぇ。あたいに精子飲ませて楽しかったか？　せ、せめて楽しかっ\nたって言え……。じゃないと咥え損、しゃぶり損じゃないかぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0103308" ]},
		{"command":[ "SETIMAGE", "0", "still_00020801_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「その上飲み損でもあるんだぞぉ……。気持ち……良かったか？　だ、だった\nらまあ……許す。はぁっ、はぁ、はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「で、でも二度とするなよ！　こういうのはっ……あたいをオトしてからじっ\nくりやれ！　じゃないと……じゅ、順番がおかしいからな……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「うっ、うぁああっ！？　よ、よりにもよってあたいの……あたいの顔にぶっ\nかけるなんて！　い、いい度胸してるなぁああ～っ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0103401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00020801_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「んぁああっ、ぷぁっ、あぷぁあっ……！　目っ、目に入るだろぉ……！　顔\nはやめろよぉっ……！　ふぁっ、かけすぎだからっ！　うああっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「精子を人の頭にかけるとか、おまえどーかしてんじゃないのかっ……！　あ\nっ、く、くっさっ……！　くさい……！　ネバネバするぅう！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0103403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「あうっ、ぁ、あ、あ……！　ど、どーすんだこのニオイ……！　とんでもな\nいぞ、洗ってもおちなかったら最悪だからなぁああ……っ！　んぷ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0103404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「……も、もういいからっ！　もうじゅうっぶん浴びたから！　だから終わり\nにしてくれぇえ……！　どんだけ出す気だよ、チンポ壊れてるのかぁあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0103405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「う、ううううぁ……。あぅううう……。はー……♪　はぁー……♪　ひっど\nいめにあわされた……。ちょっとつっかかっただけなのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0103406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「清廉潔白なあたいの口に突然チンコ突っ込んで、精子ひっかけて逃げような\nんて……神サマがゆるしてもあたいは、あたいはゆるさにゃいぞ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0103407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「っぅ……。だ、だめだ……。喋るとダラダラ精子がこぼれてくる……。ふぁ\nあ、髪にもべったりついて……。全然とれない……嘘だろぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0103408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「おまえぇ……あたいをネットネトのビッチャビチャにしてくれやがってぇえ\n……！　この借りはいつか返す……！　はぁ、はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0103409" ]},
		{"command":[ "SETIMAGE", "0", "still_00020801_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「今日は……み、見逃してやるから……。あたいがされるがままになってたこ\nと、誰にも言うんじゃないぞ！　言いふらすなよっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0103410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}