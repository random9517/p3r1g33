{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0151" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_020" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "サメはまた空間の裂け目に逃げていく。", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「畜生！　また逃げられた！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_010113750001" ]},
		{"command":[ "SETCHARA", "0", "char_00009501_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「レーダーから反応が完全に消えている。……ここまで厄介なサメは久しぶり\nだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010113750001" ]},
		{"command":[ "SETCHARA", "0", "char_00012701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "サメのことは向こうに任せて、気になるのはこの人の方だ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「大丈夫か？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00000607_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「は、はい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_070113750001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "それにしても、その人は見れば見るほどディアナに似ている。けれど、ディア\nナに比べるとずっと地味で気弱そうだ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「もしかして、アナザー・ディアナとか？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「あ、あなざー？　なんのことですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_070113750002" ]},
		{"command":[ "SETCHARA", "0", "char_00000607_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、なんでもない」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "アナザー・ルナテミスみたいな存在じゃないのか。ということは、もしかして\nただの他人の空似？", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "だけどそんな相手なら、ディアナが必死になってかばう必要もないよなぁ……\n。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「園子ちゃん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040113750001" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そこへ、ディアナたちもやってきた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「わわわっ、オバケっ、オバケがいるーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040113750001" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「いやいや、オバケなわけねーでしょ。脚はありますし、透けていませんし…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_050113750001" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「園子ちゃん、無事でよかった～……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040113750002" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「園子ちゃん？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子？" ]},
		{"command":[ "SETTEXT", "「え、私のことを知っているんですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_070113750003" ]},
		{"command":[ "SETCHARA", "0", "char_00000607_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "園子と呼ばれたその人が答える。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ディアナ、今度こそちゃんと説明してくれるな？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「あぁ……うぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040113750003" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "少し言葉を濁すディアナだったが、この状況では秘密にしておくことも出来な\nいと観念したようだった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「その子……園子ちゃんなの！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040113750004" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なに言ってんだお前」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「たしかに私は園子ですけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_070113750004" ]},
		{"command":[ "SETCHARA", "0", "char_00000607_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「オバケじゃないんだね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040113750002" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「失礼しちゃう！　園子ちゃんはオバケちゃんなんかじゃないんだから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040113750005" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「で、その園子さんとあなたはどんな関係で？　なんの関係もないわけじゃな\nいのでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_050113750002" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「そ、それは……その子は……園子ちゃんは……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040113750006" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "sbg_0141" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「昔のディアナちゃんなのよぅーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040113750007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
