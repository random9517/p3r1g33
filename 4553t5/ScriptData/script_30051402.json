		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「それでは、は、始めましょうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1404101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「別に、緊張している訳では……いえ、やはり少しは緊張しているかも知れま\nせん……その、特別な行為ですから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1404102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ですが、大丈夫です。妻としての務めは、しっかりと果たして参りますので\n……はい、それでは……上へとお邪魔致します」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1404103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んっ……あぁ……もう、オチンポがはちきれそうに勃起されてますね。それ\nだけ、楽しみにして下さっていたんですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1404104" ]},
		{"command":[ "SETIMAGE", "0", "still_00000514_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「あっ……いきなりおっぱい……んんっ、そんな……ウチのは、大きくないの\nに……あっ、はぁっ……舌が……激しくぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1404105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んんっ、あふっ、あぉっ……乳首……転がして来る……んっ、赤ちゃんみた\nいなことぉ……はっ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1404106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「貴方がそういうおつもりなら……ウチも……じっとしてはいられません……\nんっ、くぅっ……はふっ、このオチンポを優しくスリスリします……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1404107" ]},
		{"command":[ "SETIMAGE", "0", "still_00000514_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んふっ……あっ、はっ、んぁっ……ピクピク震えてます……ふふっ、割れ目\nに沿って……擦るとオチンポ……もどかしいですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1404108" ]},
		{"command":[ "SETIMAGE", "0", "still_00000514_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「あんっ！　おっぱいに反撃されてます……あっ、あぁっ……唇が……気持ち\nいい……んっ、くぅぅ……歯もコリコリってぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1404109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んっ、あっ、ふぁっ……くっ……ウチも負けてられません……んっ、ふっ…\n…はっ……あっ、はぁんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1404110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ほら……オチンポが震えて……んっ、欲しくなってますよね……？　すぐ近\nくにあるウチのオマンコに……ずぶって入れたいですよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1404111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「分かってます……んっ、ウチも……あっ、気持ちがどんどん高まって来て…\n…あぁっ、内側からお汁が……湧いて来て……はふぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1404112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「も、もう……いいですよね……？　ウチも、待ちきれないです……んっ、こ\nのオチンポ……そのままに出来なくなってます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1404113" ]},
		{"command":[ "SETIMAGE", "0", "still_00000514_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んふぅ……入れさせて下さい……トロトロに濡れた、ウチのオマンコに……\nこのぶっとい熱々のオチンポぉ……ハメさせて下さい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1404114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「あっ、んんんんんっ……はぁぁぁぁっ、んくぅぅぅっ……入って来ましたぁ\nっ……あ、ふぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1404115" ]},
		{"command":[ "SETIMAGE", "0", "still_00000514_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「くぅぅ……んっ、すごい……思ってたより……もっとっ、あっ、大きいの…\n…中……広がっていきますぅぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1404116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「あっ、くっ……あっ、あぁぁぁっ……ダメ……全部入って来ちゃうっ……あ\nっ、ひっ……ダメですっ、ウチ……入れただけなのにっ、んぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1404117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はぁっ、んんっ……は、はい……今……ちょっとだけ……入れただけで……\nウチ……軽く、イキ……ましたぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1404118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「違うんです……んっ、もっとゆっくり入れる筈だったんですけど……一気に\nずぶって沈んじゃって……それで、オ、オマンコがびっくりして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1404119" ]},
		{"command":[ "SETIMAGE", "0", "still_00000514_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「だ、だから、動くのは……もう少し待って下さい……落ち着いたら……ゆっ\nくり、オチンポ……よくしていきますから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1404120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はふっ……んっ、はい……もう、大丈夫です。えと……んっ、動かしていき\nます……ね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1404121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「あっ、んんっ……まず、奥まで入ったオチンポを……ゆっくりと引き上げて\n行き、ます……んくぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1404122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「やっぱり太い……んんっ、くぅっ……ずりゅって……膣壁が、擦れすぎて…\n…はぁっ、ゾクゾクしますっ……んふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1404123" ]},
		{"command":[ "SETIMAGE", "0", "still_00000514_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「オチンポが……顔を覗かせる位で……また、あっ……オマンコの中にっ……\nずぶってっ……あふぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1404124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んんんっ……くぅ……あっ、キツいです……んんっ、お腹の中をかき混ぜら\nれる感じ……全然……余裕なくて……はふぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1404125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ですけど、んっ……もっと、この太さを感じたいような……あっ、はっ、だ\nから……腰を回して、いき……ますねっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1404126" ]},
		{"command":[ "SETIMAGE", "0", "still_00000514_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「あふっ、んっ、ふっ……あぁんっ……揺らすとっ……乳首……んっ、口の中\nで擦れてっ……ピリピリしますっ……んふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1404127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「吸いにくいかも知れませんけど……んっ、はいっ……ぎゅっと……くっつい\nてもらって……あっ、離さないで……下さいね……あふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1404128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はっ、んんっ……あぁっ……オチンポ……硬いっ……んっ、ウチの……弱い\n場所を……ゴリって……抉るみたいな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1404129" ]},
		{"command":[ "SETIMAGE", "0", "still_00000514_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はぁぁっ、腰……震えちゃいます……んんっ、あぁっ、汗も……滲んで来ち\nゃう……んっ、あっ、そんな、腋の下なんか舐めたらダメです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1404130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はぁんっ、に、においもダメです……そんな場所……嗅がないで下さい……\nは、恥ずかしいですっ、からぁっ……んぁふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1404131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「た、確かにウチも……貴方のにおい……嗅いじゃうこと、ありますけどっ…\n…でもっ、こんなお互い様って言っても……そんなっ、のっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1404132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「あひっ！　あぁっ……オチンポっ……グリグリしちゃらめっ、あひっ、あぁ\nっ、な、何も言えなくなっちゃまひゅっ、ふぁっ、あぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1404133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「あっ、ふぁっ、あぁっ、ウチが……して、あげたいのにっ……あっ、激しく\nかき回されたらっ、んぁっ、あぁぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1404134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「らっ、めっ……！　ま、またイキますっ、オチンポ激しくてっ、ウチのオマ\nンコッ……ま、また……イキますっ、んくぅぅぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1404135" ]},
		{"command":[ "SETIMAGE", "0", "still_00000514_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んふぁぁぁぁぁっ……！？　なっ、中っ……出てるっ！？　あひっ、いきな\nりっ、中出しなんてっ……ウチッ……イキますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1404136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000514_02_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んんんっ……あはぁ……とぷんって……流れてくる……はぁぁ、一番深いと\nころに……濃いのが全部届けられてますぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1404137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はぁぁ……あふっ、こんなの妊娠するに決まってます……受精して……あっ\n、ダメ……オマンコ……ずっと悦んだままぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1404138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はふっ、んんっ……あっ、ぴゅるって……潮吹きしひゃう……はうぁ……頭\n……トロけちゃいまひゅぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1404139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んっ……くぅぅ……お、終わりました……？　あぁ……まだウチは……イッ\nてるのが……収まりません……は、ひぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1404140" ]},
		{"command":[ "SETIMAGE", "0", "still_00000514_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はふ……やっと、落ち着きましたね……んっ……まだ、オチンポが中で元気\nに動いてます……んぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1404201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「あっ……ふっ、はい、ちゃんと……ウチのオマンコも、まだして欲しいって\n思っていますから……このまま続けましょう……んっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1404202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はぁっ、ふっ……恥ずかしい音が……さっきよりもっと響いて来ます……ん\nくぅっ……ウチのオマンコから聞こえるぐちゅって音ぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1404203" ]},
		{"command":[ "SETIMAGE", "0", "still_00000514_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「あぁっ……オチンポの汁と……オマンコの汁が……一緒に合わさって……オ\nマンコの中でドロドロに混じってぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1404204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はぁっ、あふっ……ウチの膣壁っ……肉ヒダに……へばりついていくって思\nうとぉっ……あぁぁっ、ゾクゾクっ、しますっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1404205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んぁんっ！　あっ、また……おっぱい吸って……こんな小さいの、面白くな\nいんじゃないですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1404206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んんっ、そんなこと……ないん、ですか……んふふぅっ……はい、好きでい\nてくれるのなら……とても、嬉しいです……ぁふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1404207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「あぁ……でも……二箇所……同時に、刺激されたら……はぁっ、あっ、気持\nち……よくなりすぎて……また、身体……熱く……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1404208" ]},
		{"command":[ "SETIMAGE", "0", "still_00000514_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んっ、やだ……汗……舐めないで下さい……んっ、そんなの……汚いです…\n…はっ、ひぁぁぁっ……わ、腋の下もぉっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1404209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「あふっ、恥ずかしいですっ……あっ、あぁっ……弱い場所……全部されてっ\n……もっと、中……トロトロにされていきますっ……あ、うぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1404210" ]},
		{"command":[ "SETIMAGE", "0", "still_00000514_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はっ、ひっ、あぁっ、はいっ……もっとして下さいっ……んっ、下から……\nぐいって突き上げてっ！　くひぃっ……そこですぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1404211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「あぁっ、オチンポがっ……オマンコの気持ちいいところっ……次から次へと\n、擦ってくるっ……あっ、うんっ、はっ、ひっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1404212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「くぁぁぁぁんっ……！　あぁっ、ダメですっ、オチンポっ……熱くてっ、ん\nぁんっ、続けてされたらっ、力……抜けちゃうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1404213" ]},
		{"command":[ "SETIMAGE", "0", "still_00000514_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「くぅっ、ウチの……弱点っ、全部されてぇっ……あひっ、ひぃんっ、でもっ\n、ウチも……オマンコっ……負けてられないですっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1404214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んんっ……こ、ここぉっ……オチンポの先の方……弱いですよねっ？　弱い\nところ同士のキスぅっ……何度もしてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1404215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はぁっ、あぁっ、下の口から出るよだれ……止まらないですっ……はふぁっ\n、あぁっ、もっと、もっとかき回して欲しいですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1404216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はいっ、そこですっ！　あぁっ、オマンコ気持ちいいっ……！　何度もオチ\nンポで突きまくられてっ、ウチのオマンコッ、またイキそうですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1404217" ]},
		{"command":[ "SETIMAGE", "0", "still_00000514_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はぁっ、んぁっ……はいっ、後少し……頑張りますからっ……貴方も一緒に\nっ、イッて欲しいですっ、はっ、んぁぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1404218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「発情しきった……オマンコの中でもっ……ウチの身体に……全部ぶっかけで\nもっ、どっちでも嬉しいですからっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1404219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「出してっ……下さいっ……あひっ、ダメェっ、ウチもっ……またっ、あぁっ\n、オマンコっ、イキますぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1404220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「うくぁっ……出てる……あくぁっ……またっ、どぷどぷっ……出てるっ……\nオマンコの奥にっ……精液っ……届いてますぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1404301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000514_02_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ふぁぁっ、イクっ……またイってますっ……！　イッてるオマンコにっ……\n濃いのっ……流れ込んで来ますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1404302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「あ……あぁぁ……出てるのにっ……ま、まだ突き上げられてぇっ……あぁっ\n、つ、続けてイってるのっ……降りられないっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1404303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はぁぁぁ……んふぁっ、くぅぅぅんっ……あぁ、漏れてる……オマンコから\n……精液……溢れちゃってます……んふぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1404304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んっ、はぁ……あっ、もうすぐ……止まる……わ、分かりました……もう、\n腰が限界で……ですから、お任せします……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1404305" ]},
		{"command":[ "SETIMAGE", "0", "still_00000514_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「あっ……ふぁっ……お、終わりましたか……んっ……あぁ……はい、お疲れ\n様……でした……あぁ、まだオマンコ……痺れてます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1404306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「これが子作り……本気で取り組むと……気持ちよすぎて……どうにかなって\nしまいそうでした……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1404307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ウチのオマンコ……ちゃんと役目を果たせましたか……？　色々と乱れた姿\nをお見せしたのは不覚ではあるのですが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1404308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「そ、それがいい……うぅ……やっぱり不覚です。いくら顔を見せてなくても\n……恥ずかしいものは恥ずかしいですっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1404309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「こうなったら、忘れてもらうしかありません……もっとメロメロになるまで\n……子作り続行ですっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1404310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んぁぁっ！　あぁっ、身体っ……いっぱい掛かってますっ！　今度は……外\n側からっ……精液漬けぇっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1404401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000514_02_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んぁっ、イクっ……ウチもまたイキますっ……！　精液のにおいに包まれて\nぇっ……また……イクぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1404402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んふぁぁっ……ダメ……トロけます……発情して……オマンコぉ……ずっと\n気持ちいいままぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1404403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「あふぁ……ヌルヌルのが……まだ出て……あぁ……肌がべとべとになってい\nきますぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1404404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「あともう少しだけ……出る……？　はい……もう、ウチに止める術はありま\nせんから……最後まで……出して下さい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1404405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んっ……これで終わりですか……はい、お疲れ様……でした……あぁ、まだ\nオマンコ……痺れてます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1404406" ]},
		{"command":[ "SETIMAGE", "0", "still_00000514_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……抱きついちゃいます……貴方にも精液……ついちゃいますけ\nど……今更気にしませんよね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1404407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んふっ……こうしてくっついていると、幸せです……ウチは……ウチのオマ\nンコはちゃんと気持ちよかったですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1404408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「よかったです。満足していただけて……ウチのできる限りのことを詰め込み\nましたから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1404409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「でも、まだまだもっと楽しんで頂きたいですから……一休みしたら、また…\n…続き……したいです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1404410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
