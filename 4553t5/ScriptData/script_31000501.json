{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010005_01_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ん……。どれどれ……。ここをこうして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0503101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「お？　やっと気が付いたか。遅いぞ、相手が私だから良かったものの……。\nこんなに簡単に、敵に接近されてしまえば……死ぬぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0503102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「……私が何をしにきたのか？　状況を見てわからんか？　夜這いだ。\nただし、一方的に……私がお前を貪るだけの、な」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0503103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「クククク……。別に、減るものでもあるまい。それどころか、おまえにとっ\nては最高のプレゼントだろう？　ブラックサンタは優しいからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0503104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「良い子には素晴らしい快楽を与えてくれる……。悪い子には厳しいお仕置き\nだ。さあて、どちらが欲しい？　飴か、鞭か……フフフフ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0503105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「おおっ……？　どうやら返事は、おまえの股間がしてくれたようだな。鞭も\n飴も欲しい……なるほど。既にペニスは期待に満ち満ちているようだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0503106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ああ……先走り汁が滲む尿道。このすえた、イカ臭いニオイ……。私の中の\n猫の遺伝子が囁く。これを思う存分嬲りたいとな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0503107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「……私の豊満な乳房に、おまえのいきり勃ったペニスを挟みこんで……。\nおっと、暴れるんじゃない。すぐによくしてやるからな……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0503108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「フフ、人肌はあたたかろう……。ニンジャは、……特にダークニンジャは、\n愛撫も絶品だからな。好きなだけ悶絶してくれてかまわんぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0503109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「……さあて……まずは、フカフカの乳房でのパイズリだ……。くふふ、私の\n胸はダークニンジャになってから更に進化を遂げていてな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0503110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「わかるか？　自然と、ペニスに寄り添い、しっかりと包み込むようになって\nいる……♪　がっちりとおまえのチンポをホールドして……こうだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0503111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ずりゅっ……！　ムニュッ……！　ぐりゅっ……むにゅっ、むにゅっ……！\n　シルクのような質感に、なめらかに動く二つの塊……くふふふふ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0503112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「そう。おまえのモノの大きさに合わせて修行させた、特別制のオッパイだ…\n…。他の者には合わない、おまえだけの感触を楽しめ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0503113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「っふぅっ……♪　ふぅっ、ふぅうう……♪　ぐにゅっ、ぐにゅっ、ぐにゅ…\n…♪　おや？　股間がビクビクしているなぁ……ぐにゅ、ぐにゅぐにゅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0503114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「これは、もっともーっとかまってほしいという合図だろう？　痙攣し、イヤ\nらしい臭いをふりまくそのチンポ……成敗する！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0503115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ぺろっ……！　ぺろ、ぺろ……！　くちゅっ♪　クチュ……くちゅ……。\nゆっ……くりと、焦らしながら舌でチンポを舐めていく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0503116" ]},
		{"command":[ "SETIMAGE", "0", "still_00010005_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「れ、ろぉ……れるぅ……ぺちゃっ……♪　くちゃ……ぴちゃっ、ぴちゃ……\n。あはははっ、じれったくて気が狂いそうになるだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0503117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「それが私にとって最高にエキサイティングなんだ。音をたてて、激しくすす\nってほしがっているおまえを、観察しながらねっとり遅く責める」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0503118" ]},
		{"command":[ "SETIMAGE", "0", "still_00010005_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「く、ちゅ……。時には舌を止めたり……れろっ……。舐める寸前で寸止めし\nたり……。ふふふ、こうして私の良さを教え込む……。れ、ろ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0503119" ]},
		{"command":[ "SETIMAGE", "0", "still_00010005_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「おおっ？　さすがにチンポが怒っているか？　悪い悪い。ついつい可愛らし\nくてからかいすぎてしまう。……では、全力で参ろうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0503120" ]},
		{"command":[ "SETIMAGE", "0", "still_00010005_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「高速舐め回しに強引パイズリだ！　……っぐちゅっ！　ぐちゅっ、ぐちゅっ\n、ぐちゅっ！　ははは、さっきとの落差でイキそうだろう！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0503121" ]},
		{"command":[ "SETIMAGE", "0", "still_00010005_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あはっ……♪　はぁああっ♪　ちゅぽっ！　ちゅぱっ、くちゅっ、ぐちゅ、\nぐっちゅっ！　ぴちゃっぴちゃ、ぴちゃ……胸も力強く揺らすっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0503122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んん……♪　おまえの反応はいいな、どこがいいのかすぐにわかる……♪　\nれろっ……れろっ、れろれろ……くちゅくちゅくちゅ♪　こうだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0503123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふふ、気持ちよくなるとピクピクして……舐めがいがあるよ。そら、そら、\nもっと喜べ！　……ぴちゃっぴちゃっ、クチュクチュクチュ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0503124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「プルプルと生意気に震える亀頭……。アハハハッ……私に抵抗するチンポは\nこうしてやる……。ちゅるっ……れろっ、レロレロレロぉ……ぢゅぷっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0503125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んふっ……♪　当然おまえも知っているだろう、これは尿道責めだ……。\nぢゅぷっ！　おまえの尿道……チンポの先端に開いた小さな穴……れろっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0503126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「そこに私の長く細い舌をねじこんで……グチュグチュくちゅくちゅ刺激する\n……♪　んむッ……外皮は刺激に慣れているかもしれんがな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0503127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「チンポの内側、中まで鍛えることなど不可能だ……。よって、私はおまえの\n一番弱い部分をむしゃぶり倒す……いくぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0503128" ]},
		{"command":[ "SETIMAGE", "0", "still_00010005_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「くちゅっ♪　クチュ……くちゅ、くちゅっ、くちゅっ、くっちゅっ……！　\nフフフ、少しほじっただけで先走りが溢れ出してくる……ぢゅるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0503129" ]},
		{"command":[ "SETIMAGE", "0", "still_00010005_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「カウパーは全て舐め取る……。ぺろっ……れろっ、れる……れる……。そし\nて、飲み下す……。ごくっ……ンン……。細く糸を引く透明な粘液……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0503130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「美味くはない、が……これは美味なる精液の前触れだからな……。大事に喉\nに流し込んで……。ぢゅぷっ、ずぷっ、ぬぷ……にゅっぷっ、にゅぷ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0503131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んにゅぅ……ちゅぷっ！　くち、クチ……くちゅっ……。れる……っ、ちゅ\nぷ、くっちゅっ、クチュ……クチュ、ぬちっ、ぬちっねちっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0503132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「快楽を感じ取る神経が、集まっているペニスを……丁寧にほじくられるとゾ\nクゾクするだろう？　恐れることはない、身体の力を抜け……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0503133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「そうすれば、すぐに尿道に精液がせりあがってくるはずだ。んん……ちゅぷ\nっ、チュプ、ぷちゅ、くちゅっ……くっちゅっ……！　ああ来た来た！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0503134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あはっ……♪　精液を引きずり出されただろう……っ♪　いいぞ、いいぞ…\n…ありったけ撃ち出せ……！　んぁっ……んぷ、ぷぁ……あああ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0503135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010005_01_04" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「おまえは感じやすくてとても助かるよ……！　欲しい時に欲しいだけ、ビュ\nルビュルと精液を私に提供してくれるのだからな……！　んっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0503136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「思考が途切れてしまうくらい苦い……！　えぅ……、これはたっぷりと子種\nが詰まった精液に違いない……。あっ……あぁ、舌が火傷する……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0503137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ジュレのように舌先でプルプルと震える精液……。ああ、やっぱり先走りな\nんかとは比較にもならない……！　こちらが本物だ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0503138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ぢゅるっ……ぢゅるるっ、ごくっ……！　ごくっ……ごくんっ……！　もっ\nとご馳走してくれっ、この腹を、喉を、胃を埋めて満たせ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0503139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んぷ……！　ごくっ……ごくっ、ごく……！　ぷはぁっ……♪　美味い……\n♪　まだ、口の中にへばりついている……感動したぞ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0503140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふぅ……。我ながらいい仕事をした。が、わかっているだろうな？　一度の\n射精くらいで解放してやる私ではない……。フッフッフッ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0503201" ]},
		{"command":[ "SETIMAGE", "0", "still_00010005_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「せっかく精液を吐き出して、良い状態に仕上がっているんだ。敏感になった\nペニスを苛めたおして追いつめてやるとしよう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0503202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「……まずは、お掃除フェラだ。私がそこまでしてやるのは珍しいからな、\n感謝して受け取れ……。ん、む……れろ、れろ、れろ……ぴちゃぴちゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0503203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「くちゅっ……ぴちゃっ、ぺちゃ、ぴちゃ、ぴちゃ……♪　ぺちゃっ、ぺちゃ\n、ぺろ、ぺろっ……♪　ちゅっ、ちゅ、ちゅ……ぢゅるる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0503204" ]},
		{"command":[ "SETIMAGE", "0", "still_00010005_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ん？　尿道の奥にもまだ精液が残っているじゃないか……。隠すんじゃない\n。いただくぞ……。ぢゅうううっ♪　ぢゅるぢゅるぢゅる……ごくっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0503205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んん～……♪　至福の時だ……。こらこら、私の唇にジャレるんじゃない。\n慌てなくてもしっかりしゃぶってやる……れろっ、れろ、れろ、れろぉ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0503206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「おまえのだーい好きな、私の胸だぞ……。ほれ、……んん……！　亀頭を舌\nでねぶりながら……ユッサユッサと揺らしてやる……。ん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0503207" ]},
		{"command":[ "SETIMAGE", "0", "still_00010005_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「れろっ……れろっ、れろれろ……んんむ♪　ぐちゅっ……グチュッ、れろれ\nろれろ……。はぁっ♪　はぁ、肉棒にまとわりつく舌と乳房……んんんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0503208" ]},
		{"command":[ "SETIMAGE", "0", "still_00010005_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「濡れた舌が這い、柔らかな胸がペニスを押し潰してこねくりまわすと……\n男として生まれた喜びを感じるだろう？　れろっ、れろ、れろれろれろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0503209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふぅっ♪　ふぅっ……ふっ、ふぅうっ……ふぅっ♪　少し強めに圧迫して…\n…揺らす！　んっ……ンッ、ん……ん、んん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0503210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「どう、だ？　大迫力だろう……たゆたゆと弾む巨大な乳は……♪　あっ……\n！　私も、ペニスの感触で心地よいぞ……！　あっ♪　あっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0503211" ]},
		{"command":[ "SETIMAGE", "0", "still_00010005_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「この興奮……抑えきれんっ……！　チンポを吸わせてもらうっ……！　ぐぷ\nっ……くぷぷっ♪　ぐちゅっ……ぐっちゅっ、ぐちゅ……ぢゅるるる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0503212" ]},
		{"command":[ "SETIMAGE", "0", "still_00010005_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「じゅるるるっ、じゅるる……！　ぐっぷっ♪　ぐっぷっ、ぐぷっ、じゅっぷ\nっ……！　じゅぷぷぷぷ……♪　ぐっちゅっぐっちゅっぐっちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0503213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「れろぉ……ぐちゅぅうううっ♪　グチュッ……ぐちゅぅううっ……！　フフ\nフ、先走りが多くなってきたぞ……？　感じているな……。ぐっちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0503214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「わたひもおまえのチンポを舐めて興奮しているぞ……。あぁ……♪　これは\nわたひのモノら……誰にも渡すものか……レロッ……くちゅ、くちっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0503215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ぬちゅっ、ぬちゅっ、じゅぷぷぷ♪　じゅるっ……ぢゅるるっ……！　ぺろ\nっ、れろっ……れろ……ぬちゅっ、ヌチュ、ぬちゅっ、ぷっちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0503216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「何……？　もう我慢出来ない？　馬鹿が。せっかく、ブラックサンタ・マス\nターの舌技を思う存分楽しめる恍惚の時間だというのに……レロレロレロ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0503217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「それが終わりになってしまってもいいのか？　んん？　もう二度と、こんな\nチャンスはないかもしれんのだぞ？　ん……チュ、チュ、チュ、ちゅぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0503218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「……フフフ。辛抱させるつもりがないだろうって？　そうだな。私はおまえ\nが、耐えて顔を歪める姿が好きなのだ。ほら、ほらほらほら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0503219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「我慢して、我慢して、耐えて……絞り出せ。さすれば最高の快感が得られよ\nう……。ぢゅるっ、ぢゅるるるる……♪　お？　出るか？　出すのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0503220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んぷぁ……！　はははっ、あははは……出た出た出た♪　いじればいじるほ\nどビュルビュルと、面白いくらい簡単に射精しおってからに♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0503301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010005_01_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「おい……♪　さっきあれだけ派手に出したくせに、また、こんな量をひり出\nすのかっ……！　えう……♪　舌が真っ白だ……んっぁっあっあっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0503302" ]},
		{"command":[ "SETIMAGE", "0", "still_00010005_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「苦い……！　それに、ずっしりと重い……♪　ブリブリと弾む食感……ああ\n……♪　若い男の、煮詰まった白濁は美味だ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0503303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「……おまえは私だけの精液タンクだからな……♪　んんっ……美味なる精子\nをいつでも出せるように、健康には気をつけておけ……。ごくっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0503304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んんん……飲みにくい……。どれだけ粘り気のある液を発射しているんだ。\nこれは嬉しい誤算だぞ……。ごくっ……ごく、……はぁあああ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0503305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「この、独特の味が病みつきになる……♪　どうだ、私の舌と胸は気持ち良か\nったか？　……と、感想を聞いてやるまでもないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0503306" ]},
		{"command":[ "SETIMAGE", "0", "still_00010005_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「答えは精液が全て教えてくれた。これからも、この量と勢いを保て。そうす\nればいつでもゴクゴクとおまえの白濁液を飲み干してやらんこともない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0503307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「……ふうう……♪　久しぶりに味わった精子はまた、格別なものだったな…\n…。何？　ブラックサンタにホワイトクリスマスだと？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0503308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「おまえの冗談はいつもくだらない。が、身体が良いから重宝してやろうじゃ\nないか。イチャイチャはしないし、ラブラブなご奉仕もしてやらん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0503309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「だが……。おまえは私のサディスティックな責めからもう離れられない。そ\nうだろう？　これからも、私をその気にさせるのだぞ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0503310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あは～ははははっ！　出せたじゃないかっ……立派立派ぁ……！　あっ、お\nい……！　顔に出していいとは言っていないぞ……！　んっぶっんぶっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0503401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010005_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「こ、声を出すのも面倒になるくらいのザーメンシャワー……！　お、おまえ\n……！　こんなところで私に反抗してくるとは……笑止！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0503402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「愚か者め……！　ダークサンタ・マスターが顔射ごときに恐れをなすか！　\nって……だ、出し過ぎだ！　むぷっ！？　んう！　フフフっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0503403" ]},
		{"command":[ "SETIMAGE", "0", "still_00010005_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「そうかそうか、それほどまでに気持ち良かったか……！　仕方のないやつだ\n。私の顔を汚していいぞ……今日だけは見逃してやる……！　んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0503404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「……ふ……♪　ふぅうっ……♪　んふっ、ふぅう……！　あっ……あっ、ド\nロドロの精液で息が出来ない……♪　悪いヤツだな……。んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0503405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「おまえの精液をかけられすぎて、呼吸が出来なくなったらどうする……っ♪\n　そんな死に方はごめんだ、ぞ……！　ぷぁっ……はぁ、はぁはぁはぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0503406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「くぅうう……♪　卑猥な香りにべったりと糊のごとく貼りつく粘着力……♪\n　これ以上の精液は、そうそう見つけられるものではなさそうだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0503407" ]},
		{"command":[ "SETIMAGE", "0", "still_00010005_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「なあ……。おまえ、私の専属肉奴隷になるつもりは本当にないのか？　私さ\nえいれば、他の女など不要だろう。全てを凌駕する者、それが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0503408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「欲望の使者、ダークニンジャだ……。私のモノになれば、たまにこうして過\n激な衣装も着てやるし、……気まぐれに褒めてやらないことも……ない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0503409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「次までによーく考えておくんだな。こちらはもう、おまえに決めている。だ\nから……。……ん、この続きは、承諾を聞いてから言うとしようか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0503410" ]},
		{"command":[ "WAITINPUT" ]},
